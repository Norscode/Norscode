bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/build_linux_x86_64_stage0_docker_v3601.no")

    assert(t.inneholder(src, "./bin/nc run tools/build_native_candidate_v3002.no"))
    assert(t.inneholder(src, "NORSCODE_NATIVE_GAP_BIN=build/v3002/norscode_native_v3002 ./bin/nc run tools/native_runtime_gap_gate_v3001.no"))
    assert(t.inneholder(src, "NORSCODE_ROOT=/work"))
    assert(t.inneholder(src, "NORSCODE_PROMOTE_CANDIDATE=/work/build/v3600/linux/norscode_native_linux_x86_64_v3600"))
    assert(t.inneholder(src, "/work/bin/nc run /work/tools/write_file_size.no"))
    assert(t.inneholder(src, "/work/bin/nc run /work/tools/promote_native_stage0_v3001.no"))
    assert(t.inneholder(src, "NORSCODE_NATIVE_GAP_BIN=/work/bootstrap/stage0/norscode-linux-x86_64 /work/bin/nc run /work/tools/native_runtime_gap_gate_v3001.no"))

    assert(ikkje t.inneholder(src, "build_native_candidate_v3002.sh"))
    assert(ikkje t.inneholder(src, "native_runtime_gap_gate_v3001.sh"))
    assert(ikkje t.inneholder(src, "promote_native_stage0_v3001.sh"))
    assert(ikkje t.inneholder(src, "wc -c"))

    skriv("test_linux_stage0_docker_no_shell_wrappers OK")
    returner 0
}

bruk selfhost.native_execution.elf_arm64_emitter som elf

funksjon start() -> heiltall {
    // mov w0,#7; ret
    la image = elf.bygg_program([0xE0, 0x00, 0x80, 0x52, 0xC0, 0x03, 0x5F, 0xD6])
    assert(lengde(image) > 4096)
    assert_eq(image[0], 0x7F)
    assert_eq(image[1], 0x45)
    assert_eq(image[2], 0x4C)
    assert_eq(image[3], 0x46)
    assert_eq(image[18], 183)
    assert_eq(image[4096], 0x03)
    assert_eq(image[4097], 0x00)
    assert_eq(image[4098], 0x00)
    assert_eq(image[4099], 0x94)
    returner 0
}

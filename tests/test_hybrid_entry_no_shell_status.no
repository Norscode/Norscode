bruk std.tekst som t

funksjon krev_hybrid_entry(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon fil_finst(sti: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(t.inneholder(src, "funksjon node_finst(home: tekst) -> bool"))
    assert(t.inneholder(src, "hvis ikkje executable(native_bin)"))
    assert(t.inneholder(src, "hvis ikkje node_finst(home)"))
    assert(ikkje t.inneholder(src, "test -x "))
    assert(ikkje t.inneholder(src, ".sh <repo-root>"))
}

funksjon start() -> heiltall {
    la compile = fil_les("tools/compile_with_hybrid_bundle_v9400.no")
    la bundle = fil_les("tools/bundle_with_hybrid_compiler_v9500.no")
    la compile_wrapper = fil_les("tools/compile_with_hybrid_bundle_v9400.sh")
    la bundle_wrapper = fil_les("tools/bundle_with_hybrid_compiler_v9500.sh")
    krev_hybrid_entry("tools/compile_with_hybrid_bundle_v9400.no")
    krev_hybrid_entry("tools/bundle_with_hybrid_compiler_v9500.no")
    assert(t.inneholder(compile, "NORSCODE_HYBRID_ROOT=<repo-root> NORSCODE_HYBRID_SRC=<src.no> NORSCODE_HYBRID_OUT=<out.ncb.json> ./bin/nc run tools/compile_with_hybrid_bundle_v9400.no"))
    assert(t.inneholder(compile, "NORSCODE_HYBRID_MODULE"))
    assert(t.inneholder(bundle, "NORSCODE_HYBRID_ROOT=<repo-root> NORSCODE_HYBRID_OUT=<out.ncb.json> NORSCODE_HYBRID_ENTRY=<entry> NORSCODE_HYBRID_SPECS='<alias=fil.no>...' ./bin/nc run tools/bundle_with_hybrid_compiler_v9500.no"))
    assert(t.inneholder(compile_wrapper, "NORSCODE_HYBRID_ROOT=<repo-root> NORSCODE_HYBRID_SRC=<src.no> NORSCODE_HYBRID_OUT=<out.ncb.json> ./bin/nc run tools/compile_with_hybrid_bundle_v9400.no"))
    assert(t.inneholder(compile_wrapper, "collect_import_specs() {"))
    assert(t.inneholder(compile_wrapper, "package_entry_from_manifest() {"))
    assert(ikkje t.inneholder(compile_wrapper, "sed -n"))
    assert(ikkje t.inneholder(compile_wrapper, "| head -n 1"))
    assert(t.inneholder(bundle_wrapper, "NORSCODE_HYBRID_ROOT=<repo-root> NORSCODE_HYBRID_OUT=<out.ncb.json> NORSCODE_HYBRID_ENTRY=<entry> NORSCODE_HYBRID_SPECS='<alias=fil.no>...' ./bin/nc run tools/bundle_with_hybrid_compiler_v9500.no"))
    assert(ikkje t.inneholder(compile_wrapper, "bruk: compile_with_hybrid_bundle_v9400.sh <repo-root>"))
    assert(ikkje t.inneholder(bundle_wrapper, "bruk: bundle_with_hybrid_compiler_v9500.sh <repo-root>"))

    skriv("test_hybrid_entry_no_shell_status OK")
    returner 0
}

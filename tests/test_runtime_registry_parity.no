bruk std.tekst som t

funksjon start() -> heiltall {
    la mp = fil_les("std/multiprocessing.no")
    assert(t.inneholder(mp, "funksjon produksjonsstatus"))
    assert(t.inneholder(mp, "process_contract"))
    assert(t.inneholder(mp, "queue_contract"))
    assert(t.inneholder(mp, "native_runtime"))
    assert(t.inneholder(mp, "shell_free_core"))
    assert(ikkje t.inneholder(mp, "python3"))

    la registry = fil_les("toolchain/norspkg/registry_protocol.no")
    assert(t.inneholder(registry, "funksjon registry_produksjonsstatus"))
    assert(t.inneholder(registry, "search"))
    assert(t.inneholder(registry, "artifact"))
    assert(t.inneholder(registry, "audit_log"))
    assert(t.inneholder(registry, "summary: \"search,metadata,artifact,publish,yank,audit,auth,checksum\""))

    skriv("test_runtime_registry_parity OK")
    returner 0
}

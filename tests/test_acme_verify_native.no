funksjon start() -> heiltall {
    la private_key = builtin.fil_les("tests/fixtures/tls/localhost.key")
    la public_key = builtin.fil_les("tests/fixtures/tls/localhost.crt")
    la signature = builtin.acme_sign("RS256", private_key, "acme-verify-input")
    assert(builtin.acme_verify("RS256", public_key, "acme-verify-input", signature))
    assert(ikkje builtin.acme_verify("RS256", public_key, "acme-verify-tampered", signature))
    skriv("test_acme_verify_native OK\n")
    returner 0
}

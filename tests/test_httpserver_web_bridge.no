funksjon request_context(metode, sti, query, headers, body)
    returner {
        "__method__": metode,
        "__path__": sti,
        "__query__": query,
        "__headers__": headers,
        "__body__": body
    }
slutt

funksjon start() -> heiltall {
    la ctx = request_context("get", "/status", {"side": "1"}, {"accept": "application/json"}, "data")
    assert_eq(ctx["__path__"], "/status")
    assert_eq(ctx["__query__"]["side"], "1")
    assert_eq(ctx["__headers__"]["accept"], "application/json")
    returner 0
}

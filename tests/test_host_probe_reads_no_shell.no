bruk std.tekst som t

funksjon start() -> heiltall {
    la codegen = fil_les("tools/run_codegen_diagnose_v4800.no")
    assert(t.inneholder(codegen, "builtin.index_of(builtin.fil_les(path), needle)"))
    assert(t.inneholder(codegen, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(codegen, "builtin.fil_les(log)"))
    assert(t.inneholder(codegen, "builtin.fil_les(out)"))
    assert(t.inneholder(codegen, "/work/build/v4800/linux_stage0_literal_index_probe.log"))
    assert(t.inneholder(codegen, "returner miljo_hent(namn)"))
    assert(t.inneholder(codegen, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(codegen, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(codegen, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(codegen, "la cat_log = kommando(\"cat "))
    assert(ikkje t.inneholder(codegen, "la cat_out = kommando(\"cat "))
    assert(ikkje t.inneholder(codegen, "cat /tmp/linux_literal_index_probe.log"))
    assert(ikkje t.inneholder(codegen, "grep -q '\\\"BUILD_LIST\\\"'"))
    assert(ikkje t.inneholder(codegen, "printf '[OK] linux_stage0 literal/index"))

    la kernel = fil_les("tools/test_kernel_boot.no")
    assert(t.inneholder(kernel, "builtin.index_of(vga, \"0x4e 0x0e 0x6f 0x0e 0x72 0x0e\")"))
    assert(t.inneholder(kernel, "returner miljo_hent(namn)"))
    assert(t.inneholder(kernel, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(kernel, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(kernel, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(kernel, "printf '%s' \" + shell(vga)"))

    la runtime = fil_les("tools/run_runtime_phase3_v3900.no")
    assert(t.inneholder(runtime, "funksjon les_fil_trygt(sti: tekst) -> tekst"))
    assert(t.inneholder(runtime, "builtin.fil_les(sti)"))
    assert(t.inneholder(runtime, "/work/build/v3900/linux_stage0_socket_probe.log"))
    assert(t.inneholder(runtime, "linux_stage0_socket_reply.txt"))
    assert(ikkje t.inneholder(runtime, "la cat = kommando(\"cat \" + shell(log))"))
    assert(ikkje t.inneholder(runtime, "cat /tmp/socket_probe.log"))
    assert(ikkje t.inneholder(runtime, "test \"$reply\" = 'pong:ping'"))
    assert(ikkje t.inneholder(runtime, "printf '[OK] linux_stage0 socket roundtrip"))

    la helpdesk = fil_les("tools/smoke_helpdesk_http.no")
    assert(t.inneholder(helpdesk, "builtin.fil_les(\"/tmp/helpdesk_http_body.txt\")"))
    assert(t.inneholder(helpdesk, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(helpdesk, "returner miljo_hent(namn)"))
    assert(t.inneholder(helpdesk, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(helpdesk, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(helpdesk, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(helpdesk, "kommando(\"cat /tmp/helpdesk_http_body.txt"))

    la bundle = fil_les("tools/bundle_entry_diagnose_v6600.no")
    assert(t.inneholder(bundle, "funksjon vis_fil(sti: tekst) -> heiltall"))
    assert(t.inneholder(bundle, "funksjon append_fil(sti: tekst, tekstlinje: tekst) -> bool"))
    assert(t.inneholder(bundle, "builtin.fil_les(sti)"))
    assert(t.inneholder(bundle, "builtin.fil_append(sti, tekstlinje + \"\\n\")"))
    assert(t.inneholder(bundle, "funksjon env(namn: tekst) -> tekst"))
    assert(t.inneholder(bundle, "returner miljo_hent(namn)"))
    assert(t.inneholder(bundle, "funksjon fil_finst(sti: tekst) -> bool"))
    assert(t.inneholder(bundle, "la root = env(\"NORSCODE_ROOT\")"))
    assert(t.inneholder(bundle, "Feil: manglar NORSCODE_ROOT for v6600-diagnose"))
    assert(t.inneholder(bundle, "Feil: manglar dist/norscode_native for v6600-diagnose"))
    assert(t.inneholder(bundle, "hvis ikkje run(\"mkdir -p \" + shell(outdir))"))
    assert(t.inneholder(bundle, "append_fil(log1, \"unexpected-success\")"))
    assert(t.inneholder(bundle, "vis_fil(log1)"))
    assert(t.inneholder(bundle, "vis_fil(log2)"))
    assert(t.inneholder(bundle, "returner exec_prosess(cmd)"))
    assert(t.inneholder(bundle, "hvis felt(res, 2) != \"\" { linje(felt(res, 2)) }"))
    assert(ikkje t.inneholder(bundle, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(bundle, "run(\"cat \" + shell(log"))
    assert(ikkje t.inneholder(bundle, "printf '%s"))
    la bundle_wrapper = fil_les("tools/bundle_entry_diagnose_v6600.sh")
    assert(t.inneholder(bundle_wrapper, "Norscode-first wrapper: v6600 bundle-entry-diagnose ligg i tools/bundle_entry_diagnose_v6600.no."))
    assert(t.inneholder(bundle_wrapper, "Shell-delen under set berre rot/prosessmiljø og startar Norscode-eigarfil."))
    assert(t.inneholder(bundle_wrapper, "export NORSCODE_ROOT=\"$ROOT\""))
    assert(t.inneholder(bundle_wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/bundle_entry_diagnose_v6600.no\""))
    assert(ikkje t.inneholder(bundle_wrapper, "exec \"$ROOT/bin/nc\" run \"$ROOT/tools/bundle_entry_diagnose_v6600.no\""))
    assert(ikkje t.inneholder(bundle_wrapper, "Tynn wrapper"))

    la random = fil_les("tools/test_random_session_v704.no")
    assert(t.inneholder(random, "funksjon vis_fil(sti: tekst) -> bool"))
    assert(t.inneholder(random, "builtin.fil_les(sti)"))
    assert(t.inneholder(random, "vis_fil(jar)"))
    assert(t.inneholder(random, "returner miljo_hent(namn)"))
    assert(t.inneholder(random, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(random, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(random, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(random, "køyr(\"cat \" + shell(jar))"))

    skriv("test_host_probe_reads_no_shell OK")
    returner 0
}

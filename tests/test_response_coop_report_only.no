funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nCross-Origin-Opener-Policy-Report-Only: same-origin\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "cross_origin_opener_policy_report_only": "same-origin", "body": "hei"})
    assert_eq(builtin.contains(resp, "Cross-Origin-Opener-Policy-Report-Only: same-origin"), sann)
    returner 0
}

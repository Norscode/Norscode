funksjon norscode_atomic_worker(args: ordbok_tekst) -> tekst {
    la i: heiltall = 0
    mens i < args["iterations"] {
        builtin.atomic_operation({"operation": "fetch_add", "handle": args["handle"], "delta": 1, "order": "seq_cst"})
        i = i + 1
    }
    returner "norscode-done"
}

funksjon spawn(fn_namn: tekst, args: ordbok_tekst, namn: tekst) -> ordbok_tekst {
    returner builtin.thread_spawn({"abi": "norscode-native-thread-v1", "operation": "spawn", "fn": fn_namn, "args": args, "name": namn, "stack_bytes": "65536"})
}

funksjon join(handle: tekst, thread_id: tekst, timeout_ms: heiltall) -> ordbok_tekst {
    returner builtin.thread_join({"abi": "norscode-native-thread-v1", "operation": "join", "handle": handle, "thread_id": thread_id, "timeout_ms": tekst_fra_heltall(timeout_ms)})
}

funksjon start() -> heiltall {
    la celle = builtin.atomic_operation({"operation": "create", "value": 0, "order": "seq_cst"})
    assert_eq(celle["status"], "ok")
    la args = {"handle": celle["handle"], "iterations": 10000}
    la a = spawn("thread.atomic_increment", args, "worker-a")
    la b = spawn("thread.atomic_increment", args, "worker-b")
    assert_eq(a["status"], "started")
    assert_eq(b["status"], "started")
    assert_eq(join(a["handle"], a["thread_id"], 5000)["status"], "finished")
    assert_eq(join(b["handle"], b["thread_id"], 5000)["status"], "finished")
    la loaded = builtin.atomic_operation({"operation": "load", "handle": celle["handle"], "order": "seq_cst"})
    assert_eq(loaded["value"], 20000)

    la long_worker = spawn("thread.atomic_increment", {"handle": celle["handle"], "iterations": 100000000}, "cancel-worker")
    assert_eq(long_worker["status"], "started")
    la cancelled = builtin.thread_sync({"abi": "norscode-native-thread-v1", "operation": "cancel", "handle": long_worker["handle"], "thread_id": long_worker["thread_id"], "timeout_ms": "0"})
    assert_eq(cancelled["status"], "cancelled")
    la cancelled_join = join(long_worker["handle"], long_worker["thread_id"], 5000)
    assert_eq(cancelled_join["status"], "finished")

    la stale = spawn("thread.noop", {}, "stale-worker")
    assert_eq(join(stale["handle"], stale["thread_id"], 5000)["status"], "finished")
    la replacement = spawn("thread.noop", {}, "replacement-worker")
    assert(replacement["handle"] != stale["handle"])
    assert_eq(join(stale["handle"], stale["thread_id"], 0)["status"], "error")
    assert_eq(join(replacement["handle"], replacement["thread_id"], 5000)["status"], "finished")

    la i: heiltall = 0
    mens i < 200 {
        la short = spawn("thread.noop", {}, "reuse-worker")
        assert_eq(short["status"], "started")
        assert_eq(join(short["handle"], short["thread_id"], 5000)["status"], "finished")
        i = i + 1
    }

    la before_generic = builtin.atomic_operation({"operation": "load", "handle": celle["handle"], "order": "seq_cst"})["value"]
    la generic_a = spawn("__main__.norscode_atomic_worker", {"handle": celle["handle"], "iterations": 5000}, "norscode-a")
    la generic_b = spawn("__main__.norscode_atomic_worker", {"handle": celle["handle"], "iterations": 5000}, "norscode-b")
    assert_eq(join(generic_a["handle"], generic_a["thread_id"], 10000)["value"], "norscode-done")
    assert_eq(join(generic_b["handle"], generic_b["thread_id"], 10000)["value"], "norscode-done")
    la after_generic = builtin.atomic_operation({"operation": "load", "handle": celle["handle"], "order": "seq_cst"})["value"]
    assert_eq(after_generic - before_generic, 10000)
    assert_eq(builtin.atomic_operation({"operation": "destroy", "handle": celle["handle"], "order": "seq_cst"})["status"], "ok")
    la replacement_cell = builtin.atomic_operation({"operation": "create", "value": 7, "order": "seq_cst"})
    assert(replacement_cell["handle"] != celle["handle"])
    assert_eq(builtin.atomic_operation({"operation": "load", "handle": celle["handle"], "order": "seq_cst"})["status"], "invalid_handle")
    assert_eq(builtin.atomic_operation({"operation": "destroy", "handle": replacement_cell["handle"], "order": "seq_cst"})["status"], "ok")
    skriv("test_native_thread_backend OK")
    returner 0
}

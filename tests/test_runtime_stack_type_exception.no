bruk std.runtime_stack som stack
bruk std.runtime_type som rtype
bruk std.runtime_exception som rex
bruk std.tekst som t

funksjon sjekk(namn: tekst, ok: bool) {
    hvis ikkje ok {
        skriv("FEIL runtime_stack_type_exception: " + namn + "\n")
        assert(ok)
    }
}

funksjon start() -> heiltall {
    la s = stack.ny_stack()
    la a = stack.push_frame(s, "A", 10)
    la b = stack.push_frame(s, "B", 20)
    sjekk("top B", stack.top_frame(s) == b)
    sjekk("lokal", stack.legg_lokal(s, b, "x"))
    sjekk("param", stack.legg_param(s, b, "kunde"))
    sjekk("temp", stack.legg_temp(s, b, "tmp0"))
    la info = stack.frame_info(s, b)
    assert_eq(info["function"], "B")
    sjekk("trace", t.inneholder(stack.stack_trace(s), "B@20"))
    la popped = stack.pop_frame(s)
    assert_eq(popped["function"], "B")
    sjekk("top A", stack.top_frame(s) == a)

    la ti = rtype.verdi_type(42)
    assert_eq(ti["namn"], "heiltall")
    sjekk("heiltall by value", ti["copy"] == "by_value")
    la txt = rtype.verdi_type("hei")
    assert_eq(txt["namn"], "tekst")
    sjekk("tekst heap", rtype.er_heap_type(txt))
    sjekk("heiltall til tekst", rtype.kan_tilordne(ti, txt))
    la obj = rtype.objekt_type("Ticket", "id,status", "opprett,lukk")
    assert_eq(obj["kategori"], "objekt")

    la e = rex.kast_plan("RuntimeError", "boom", s)
    sjekk("exception trace", t.inneholder(rex.stacktrace_tekst(e), "A@10"))
    la up = rex.unwind_plan(s, e, a)
    assert_eq(up["status"], "handler-found")
    rex.fang_unntak(e, a)
    sjekk("fanget", rex.er_handtert(e))

    sjekk("stack status", t.inneholder(stack.produksjonsstatus()["dekning"], "returadresse"))
    sjekk("type status", t.inneholder(rtype.produksjonsstatus()["dekning"], "host-objekt"))
    sjekk("exception status", t.inneholder(rex.produksjonsstatus()["dekning"], "unwind-plan"))

    skriv("test_runtime_stack_type_exception OK")
    returner 0
}

bruk std.log som log
bruk std.fil som fil
bruk std.cache som cache
bruk std.lagring som lagring
bruk std.innstillingar som cfg
bruk std.sched som sched
bruk std.trad som trd

funksjon start() -> heiltall {
    la logg = log.info("phase2 regression")
    assert_eq(log.nivå(logg), "info")
    assert_eq(log.melding(logg), "phase2 regression")
    assert(log.har_felt(logg, "ts"))

    assert(fil.finnes("docs/SELFHOST_PHASE2_DOD.md"))
    assert(fil.finnes("docs/SELFHOST_PHASE2_REGRESSION_TESTS.md"))
    assert(fil.finnes("docs/SELFHOST_PHASE2_CI_STATUS.md"))
    assert(fil.finnes("selfhost/phase2_ci.no"))
    assert(fil.finnes("selfhost/phase2_benchmark.no"))

    assert(fil.finnes("docs/SELFHOST_PHASE2_DOD.md"))

    la c = cache.ny_minne()
    la cs = cache.status(c)
    assert_eq(cs["gyldig"], "sann")

    la s = cfg.ny()
    la ss = cfg.status(s)
    assert_eq(ss["gyldig"], "sann")
    assert_eq(ss["kjelde"], "tom")

    la sc = sched.ny()
    la scs = sched.status(sc)
    assert_eq(scs["gyldig"], "sann")
    assert(tekst(scs["tal_ventande"]) == "0" eller tekst_inneholder(tekst(scs["tal_ventande"]), "0"))

    la manager = trd.ny_manager()
    la trds = trd.status_oversikt(manager)
    assert_eq(trds["gyldig"], "sann")
    assert(tekst(trds["aktive"]) == "0" eller tekst_inneholder(tekst(trds["aktive"]), "0"))

    la status = log.status([logg])
    assert_eq(status["gyldig"], "sann")
    assert(tekst(status["tal"]) == "1" eller tekst_inneholder(tekst(status["tal"]), "1"))

    returner 0
}

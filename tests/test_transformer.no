bruk std.transformer som transformer

funksjon start() -> heiltall {
    la identitet: liste_heiltall = [1, 0, 0, 1]
    la b = transformer.blokk(2, 2,
        identitet, identitet, identitet, identitet,
        identitet, [0, 0], identitet, [0, 0], 1)
    la a = transformer.kjor(b, [2, 4, 6, 8, 10, 12], 3)
    la c = transformer.kjor(b, [2, 4, 6, 8, 10, 12], 3)
    assert_eq(a["rader"], 3)
    assert_eq(a["kolonner"], 2)
    assert(a["kausal"])
    assert_eq(lengde(a["data"]), 6)
    la i: heiltall = 0
    mens i < lengde(a["data"]) {
        assert_eq(a["data"][i], c["data"][i])
        i = i + 1
    }
    skriv("test_transformer OK\n")
    returner 0
}

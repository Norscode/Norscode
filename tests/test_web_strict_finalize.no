bruk std.tekst som t

funksjon start() -> heiltall {
    la web = fil_les("std/web.no")
    la vm = fil_les("selfhost/vm.no")

    assert(t.inneholder(web, "funksjon response_finalize_strict(ctx: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst"))
    assert(t.inneholder(web, "strict-transport-security"))
    assert(t.inneholder(web, "content-security-policy"))
    assert(t.inneholder(web, "permissions-policy"))
    assert(t.inneholder(web, "cross-origin-opener-policy"))
    assert(t.inneholder(web, "cross-origin-embedder-policy"))
    assert(t.inneholder(web, "cross-origin-resource-policy"))
    assert(t.inneholder(web, "x-permitted-cross-domain-policies"))
    assert(t.inneholder(web, "funksjon response_finalize_strict_cors"))
    assert(t.inneholder(web, "response_finalize_strict(ctx, response)"))

    assert(t.inneholder(vm, "funksjon vm_web_finalize_response_strict(ctx: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst"))
    assert(t.inneholder(vm, "builtin.web.response_finalize_strict"))
    assert(t.inneholder(vm, "vm_web_finalize_response_strict(args[0], args[1])"))
    assert(t.inneholder(vm, "strict-transport-security"))
    assert(t.inneholder(vm, "content-security-policy"))
    assert(t.inneholder(vm, "permissions-policy"))
    assert(t.inneholder(vm, "cross-origin-opener-policy"))
    assert(t.inneholder(vm, "cross-origin-embedder-policy"))
    assert(t.inneholder(vm, "cross-origin-resource-policy"))
    assert(t.inneholder(vm, "x-permitted-cross-domain-policies"))

    skriv("test_web_strict_finalize OK")
    returner 0
}

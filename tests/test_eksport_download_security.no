bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la eksport = fil_les("std/eksport.no")

    krev(eksport, "funksjon _trygt_nedlastingsfilnamn(filnamn: tekst, fallback: tekst) -> tekst")
    krev(eksport, "web.safe_filename(filnamn)")
    krev(eksport, "trygt == \"\" eller trygt == \".\" eller trygt == \"..\"")
    krev(eksport, "funksjon _content_disposition(filnamn: tekst, fallback: tekst) -> tekst")
    krev(eksport, "_content_disposition(filnamn, \"download.csv\")")
    krev(eksport, "_content_disposition(filnamn, \"download.json\")")
    krev(eksport, "_content_disposition(filnamn, \"download.tsv\")")
    assert(ikkje t.inneholder(eksport, "filename=\\\"\" + filnamn"))

    skriv("test_eksport_download_security OK")
    returner 0
}

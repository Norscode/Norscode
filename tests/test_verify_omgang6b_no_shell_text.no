bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/verify_omgang6b.no")

    assert(t.inneholder(src, "funksjon inneheld(data: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon fil_inneheld(sti: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon filer_identiske(sti_a: tekst, sti_b: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon json_strengverdi_etter"))
    assert(t.inneholder(src, "funksjon tel_forekomstar"))
    assert(t.inneholder(src, "funksjon pad3(n: heiltall) -> tekst"))
    assert(t.inneholder(src, "funksjon skriv_chunk(out_dir: tekst, nr: heiltall, body: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.index_of(data, needle)"))
    assert(t.inneholder(src, "builtin.fil_finnes(sti)"))
    assert(t.inneholder(src, "fil_les(sti)"))
    assert(t.inneholder(src, "builtin.fil_skriv(out_dir + \"/part_\" + pad3(nr) + \".json\", body)"))
    assert(t.inneholder(src, "returner json_strengverdi_etter(les_fil_trygt(sti), \"entry\", 0)"))
    assert(t.inneholder(src, "returner tekst(tel_forekomstar(les_fil_trygt(sti), \"\\\":{\\\"name\\\"\"))"))
    assert(t.inneholder(src, "returner les_fil_trygt(sti_a) == les_fil_trygt(sti_b)"))

    assert(ikkje t.inneholder(src, "printf '%s' \" + shell(res_felt(host, 1))"))
    assert(ikkje t.inneholder(src, "printf '%s' \" + shell(res_felt(cout, 1))"))
    assert(ikkje t.inneholder(src, "printf '%s' \" + shell(res_felt(cout2, 1))"))
    assert(ikkje t.inneholder(src, "grep -q '\\\"functions\\\":{'"))
    assert(ikkje t.inneholder(src, "grep -Eq '\\\"[^\\\"]*start"))
    assert(ikkje t.inneholder(src, "awk -F'\\\"' '/\\\"entry\\\""))
    assert(ikkje t.inneholder(src, "grep -o '\\\":{\\\"name\\\"'"))
    assert(ikkje t.inneholder(src, "run(\"cat \" + shell(logg)"))
    assert(ikkje t.inneholder(src, "split -b"))
    assert(ikkje t.inneholder(src, "printf '%03d'"))
    assert(ikkje t.inneholder(src, "cmp -s "))
    assert(ikkje t.inneholder(src, "test -f \" + shell(sti)"))
    assert(ikkje t.inneholder(src, "test -x "))

    skriv("test_verify_omgang6b_no_shell_text OK")
    returner 0
}

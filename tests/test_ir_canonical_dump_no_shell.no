bruk std.tekst som t

funksjon start() -> heiltall {
    la ir = fil_les("tools/ir_canonical_dump.no")
    la ast = fil_les("tools/ast_canonical_dump.no")
    la ir_wrapper = fil_les("tools/ir_canonical_dump.sh")
    la ast_wrapper = fil_les("tools/ast_canonical_dump.sh")

    assert(t.inneholder(ir, "funksjon kanoniske_linjer"))
    assert(t.inneholder(ir, "liste.sorter_tekst"))
    assert(t.inneholder(ir, "builtin.fil_les"))
    assert(t.inneholder(ir, "builtin.fil_skriv"))
    assert(t.inneholder(ir, "funksjon enkel_hash"))
    assert(t.inneholder(ir, "returner miljo_hent(namn)"))
    assert(t.inneholder(ir, "NORSCODE_IR_INPUT=<input_ir_dump> NORSCODE_IR_OUTPUT=<output_ir_dump> ./bin/nc run tools/ir_canonical_dump.no"))
    assert(ikkje t.inneholder(ir, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(ir, "exec_prosess"))
    assert(ikkje t.inneholder(ir, "ir_canonical_dump.sh <"))
    assert(ikkje t.inneholder(ir, "sed "))
    assert(ikkje t.inneholder(ir, "awk"))
    assert(t.inneholder(ir_wrapper, "NORSCODE_IR_INPUT=<input_ir_dump> NORSCODE_IR_OUTPUT=<output_ir_dump> ./bin/nc run tools/ir_canonical_dump.no"))
    assert(ikkje t.inneholder(ir_wrapper, "Usage: ir_canonical_dump.sh"))
    assert(ikkje t.inneholder(ir_wrapper, "ir_canonical_dump.sh <"))
    assert(t.inneholder(ir_wrapper, "mkdir -p"))

    assert(t.inneholder(ast, "funksjon kanoniske_linjer"))
    assert(t.inneholder(ast, "liste.sorter_tekst"))
    assert(t.inneholder(ast, "builtin.fil_les"))
    assert(t.inneholder(ast, "builtin.fil_skriv"))
    assert(t.inneholder(ast, "funksjon enkel_hash"))
    assert(t.inneholder(ast, "returner miljo_hent(namn)"))
    assert(t.inneholder(ast, "NORSCODE_AST_INPUT=<input_ast_dump> NORSCODE_AST_OUTPUT=<output_dump> ./bin/nc run tools/ast_canonical_dump.no"))
    assert(ikkje t.inneholder(ast, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(ast, "exec_prosess"))
    assert(ikkje t.inneholder(ast, "ast_canonical_dump.sh <"))
    assert(ikkje t.inneholder(ast, "sed "))
    assert(ikkje t.inneholder(ast, "awk"))
    assert(t.inneholder(ast_wrapper, "NORSCODE_AST_INPUT=<input_ast_dump> NORSCODE_AST_OUTPUT=<output_dump> ./bin/nc run tools/ast_canonical_dump.no"))
    assert(ikkje t.inneholder(ast_wrapper, "Usage: ast_canonical_dump.sh"))
    assert(ikkje t.inneholder(ast_wrapper, "ast_canonical_dump.sh <"))
    assert(t.inneholder(ast_wrapper, "mkdir -p"))

    skriv("test_canonical_dump_no_shell OK")
    returner 0
}

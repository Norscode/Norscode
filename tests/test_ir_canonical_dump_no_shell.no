bruk std.tekst som t

funksjon start() -> heiltall {
    la ir = fil_les("tools/ir_canonical_dump.no")
    la ast = fil_les("tools/ast_canonical_dump.no")
    la ir_wrapper = fil_les("tools/ir_canonical_dump.sh")
    la ast_wrapper = fil_les("tools/ast_canonical_dump.sh")

    assert(t.inneholder(ir, "funksjon kanoniske_linjer"))
    assert(t.inneholder(ir, "liste.sorter_tekst"))
    assert(t.inneholder(ir, "builtin.fil_les"))
    assert(t.inneholder(ir, "builtin.fil_skriv"))
    assert(t.inneholder(ir, "funksjon enkel_hash"))
    assert(ikkje t.inneholder(ir, "exec_prosess"))
    assert(ikkje t.inneholder(ir, "sed "))
    assert(ikkje t.inneholder(ir, "awk"))
    assert(t.inneholder(ir_wrapper, "mkdir -p"))

    assert(t.inneholder(ast, "funksjon kanoniske_linjer"))
    assert(t.inneholder(ast, "liste.sorter_tekst"))
    assert(t.inneholder(ast, "builtin.fil_les"))
    assert(t.inneholder(ast, "builtin.fil_skriv"))
    assert(t.inneholder(ast, "funksjon enkel_hash"))
    assert(ikkje t.inneholder(ast, "exec_prosess"))
    assert(ikkje t.inneholder(ast, "sed "))
    assert(ikkje t.inneholder(ast, "awk"))
    assert(t.inneholder(ast_wrapper, "mkdir -p"))

    skriv("test_canonical_dump_no_shell OK")
    returner 0
}

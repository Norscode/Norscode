bruk selfhost.vm
bruk std.runtime_type som typer
bruk std.runtime_security som security

funksjon ny_runtime(tillat_disk: boolsk) -> ordbok_tekst {
    la functions: ordbok_tekst = {}
    vm_runtime_init(functions, sann)
    hvis tillat_disk { security.tillat(functions["__vm_security_policy__"], "disk.read") }
    la descriptor = typer.host_type("SecureFile", "disk.read")
    typer.sett_metode(descriptor, "finnes", "builtin.fil_finnes")
    assert(vm_type_register(functions, descriptor))
    returner functions
}

funksjon nektet_uten_capability() -> boolsk {
    la functions = ny_runtime(usann)
    la handle = vm_host_register(functions, "SecureFile", "README.md")
    prøv { vm_host_call(functions, handle, "finnes", []) }
    fang (e) { assert_inneholder(tekst(e), "disk.read")  returner sann }
    returner usann
}

funksjon forfalsking_og_revoke() -> boolsk {
    la functions = ny_runtime(sann)
    la handle = vm_host_register(functions, "SecureFile", "README.md")
    la fake = {"__host_handle__": "sann", "id": handle["id"], "token": "feil", "type": "SecureFile"}
    prøv { vm_host_call(functions, fake, "finnes", []) }
    fang (e) { assert_inneholder(tekst(e), "token") }
    assert(vm_host_revoke(functions, handle))
    prøv { vm_host_call(functions, handle, "finnes", []) }
    fang (e2) { assert_inneholder(tekst(e2), "tilbakekalla")  returner sann }
    returner usann
}

funksjon plugin_capability_isolasjon() -> boolsk {
    la functions = ny_runtime(sann)
    la handle = vm_host_register(functions, "SecureFile", "README.md")
    functions["__vm_function_caps__"]["__main__.plugin"] = "|disk.write|"
    functions["__main__.plugin"] = {
        "params": [],
        "code": [
            ["PUSH_CONST", handle],
            ["PUSH_CONST", "finnes"],
            ["BUILD_LIST", 0],
            ["CALL", "builtin.vm_host_call", 3],
            ["RETURN"]
        ]
    }
    prøv { køyr_funksjon("__main__.plugin", [], functions, 0) }
    fang (e) { assert_inneholder(tekst(e), "plugin capability")  returner sann }
    returner usann
}

funksjon start() -> heiltall {
    la functions = ny_runtime(sann)
    la handle = vm_host_register(functions, "SecureFile", "README.md")
    assert(vm_host_call(functions, handle, "finnes", []))
    prøv { vm_host_call(functions, handle, "slett", []) }
    fang (e) { assert_inneholder(tekst(e), "metode ikkje tillaten") }
    assert(nektet_uten_capability())
    assert(forfalsking_og_revoke())
    assert(plugin_capability_isolasjon())
    returner 0
}

bruk std.tensor som tensor

funksjon start() -> heiltall {
    la a = tensor.fra_liste([1, 2, 3, 4], 2, 2)
    la b = tensor.fra_liste([5, 6, 7, 8], 2, 2)
    la resultat = tensor.matmul_med_backend(a, b)
    la t = resultat["tensor"]
    assert_eq(tensor.hent(t, 0, 0), 19)
    assert_eq(tensor.hent(t, 0, 1), 22)
    assert_eq(tensor.hent(t, 1, 0), 43)
    assert_eq(tensor.hent(t, 1, 1), 50)
    assert(resultat["backend"] == "metal" eller resultat["backend"] == "cpu-fallback")
    skriv("test_tensor_metal_backend OK\n")
    returner 0
}

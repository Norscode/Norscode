bruk std.tekst som t

funksjon start() -> heiltall {
    la stability_src = fil_les("selfhost/selfhost_stability.no")
    assert(t.inneholder(stability_src, "Minimal deterministisk sorteringskontrakt"))
    assert(ikkje t.inneholder(stability_src, "Stable deterministic ordering placeholder"))

    la bytecode_src = fil_les("selfhost/bytecode_format.no")
    assert(t.inneholder(bytecode_src, "Minimal .nbyte-parserkontrakt"))
    assert(ikkje t.inneholder(bytecode_src, "Placeholder parser until binary loader exists"))

    la parser_src = fil_les("selfhost/parser.no")
    assert(t.inneholder(parser_src, "Selfhost-strukturkontrakt: felt er reine identifikatornamn i denne parservegen"))
    assert(ikkje t.inneholder(parser_src, "ingen typeannotering i selfhost enno"))

    la repl_src = fil_les("selfhost/repl.no")
    assert(t.inneholder(repl_src, "Minimal selfhost-REPL-kontrakt: éi linje kjem frå miljøet til linjeinput-bindinga finst"))
    assert(t.inneholder(repl_src, "Dette held evalueringsløypa Python-fri og deterministisk i bootstrap-flata"))
    assert(ikkje t.inneholder(repl_src, "REPL treng les_linje() som ikkje er implementert enno"))

    la optimizer_src = fil_les("selfhost/optimizer_pipeline_real.no")
    assert(t.inneholder(optimizer_src, "Minimal CFG-kontrakt"))
    assert(ikkje t.inneholder(optimizer_src, "Placeholder for future CFG simplification"))

    la regalloc_src = fil_les("selfhost/compiler_core/register_allocator.no")
    assert(t.inneholder(regalloc_src, "Minimal spill-slot-kontrakt"))
    assert(ikkje t.inneholder(regalloc_src, "Placeholder NOP for stack spill slot setup"))

    la linker_src = fil_les("selfhost/native_execution/linker.no")
    assert(t.inneholder(linker_src, "Minimal relocation-kontrakt"))
    assert(ikkje t.inneholder(linker_src, "placeholder patch"))

    skriv("test_selfhost_minimal_contract_text OK")
    returner 0
}

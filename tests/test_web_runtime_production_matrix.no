bruk std.tekst som t

funksjon start() -> heiltall {
    la upload = fil_les("std/opplasting.no")
    assert(t.inneholder(upload, "funksjon produksjonsstatus"))
    assert(t.inneholder(upload, "multipart"))
    assert(t.inneholder(upload, "json_upload"))
    assert(t.inneholder(upload, "raw_upload"))
    assert(t.inneholder(upload, "size_limit"))
    assert(t.inneholder(upload, "content_type_validation"))
    assert(t.inneholder(upload, "safe_filename"))

    la sesjon = fil_les("std/sesjon.no")
    assert(t.inneholder(sesjon, "funksjon sikkerheitsstatus"))
    assert(t.inneholder(sesjon, "HttpOnly"))
    assert(t.inneholder(sesjon, "SameSite=Lax"))
    assert(t.inneholder(sesjon, "secure_flag"))
    assert(t.inneholder(sesjon, "cleanup"))

    la deploy = fil_les("std/deploy.no")
    assert(t.inneholder(deploy, "funksjon produksjonsmønster"))
    assert(t.inneholder(deploy, "static_dir"))
    assert(t.inneholder(deploy, "rollback"))
    assert(t.inneholder(deploy, "graceful_timeout"))
    assert(t.inneholder(deploy, "workers,health,static,env,rollback,graceful"))

    assert(ikkje t.inneholder(upload, "python3"))
    assert(ikkje t.inneholder(sesjon, "python3"))
    assert(ikkje t.inneholder(deploy, "python3"))

    skriv("test_web_runtime_production_matrix OK")
    returner 0
}

bruk std.tekst som t

funksjon krev_norscode_dirname(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "bruk std.path som path"))
    assert(t.inneholder(src, "path.dirname("))
    assert(ikkje t.inneholder(src, "mkdir -p $(dirname"))
}

funksjon krev_lokal_dirname(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon dirname(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "dirname(output)"))
    assert(ikkje t.inneholder(src, "bruk std.path som path"))
    assert(ikkje t.inneholder(src, "path.dirname("))
    assert(ikkje t.inneholder(src, "mkdir -p $(dirname"))
}

funksjon start() -> heiltall {
    krev_norscode_dirname("tools/build_hybrid_compiler_bundle_v9400.no")
    krev_norscode_dirname("tools/build_omgang6b_compiler_ncb.no")
    krev_lokal_dirname("tools/docker-build-linux.no")
    krev_norscode_dirname("tools/fetch_stage0_seed.no")
    krev_norscode_dirname("tools/ncb_to_elf.no")

    la native = fil_les("tools/build_norscode_native.no")
    assert(ikkje t.inneholder(native, "mkdir -p $(dirname"))
    assert(ikkje t.inneholder(native, "path.dirname("))
    assert(ikkje t.inneholder(native, "bruk std.path som path"))

    skriv("test_dirname_no_shell OK")
    returner 0
}

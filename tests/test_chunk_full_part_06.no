bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_dele_seg_pa: tekst = sh.disasm_uttrykk("8 dele seg pa 2")
    assert_eq(expr_norsk_dele_seg_pa, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_seg_paa_phrase_utf8: tekst = sh.disasm_uttrykk("8 dele seg på 2")
    assert_eq(expr_norsk_dele_seg_paa_phrase_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


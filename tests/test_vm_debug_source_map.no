bruk selfhost.compiler.ir_to_bytecode

funksjon start() -> heiltall {
    la literal = {"type": "Heltall", "verdi": "7", "barn": [], "linje": 4, "kolonne": 14}
    la ret = {"type": "Returner", "verdi": "", "barn": [literal], "linje": 4, "kolonne": 5}
    la blokk = {"type": "Blokk", "verdi": "", "barn": [ret], "linje": 3, "kolonne": 1}
    la params = {"type": "Parametere", "verdi": "", "barn": [], "linje": 1, "kolonne": 16}
    la returtype = {"type": "Returtype", "verdi": "heiltall", "barn": [], "linje": 1, "kolonne": 20}
    la fn = {"type": "Funksjon", "verdi": "start", "barn": [params, returtype, blokk], "linje": 1, "kolonne": 1, "is_async": usann}
    la program = {"type": "Program", "verdi": "", "barn": [fn], "linje": 1, "kolonne": 1}
    la ncb = kompiler_program(program, "__main__")
    assert(builtin.index_of(ncb, "\"source_lines\":[") >= 0)
    assert(builtin.index_of(ncb, "\"source_columns\":[") >= 0)
    assert(builtin.index_of(ncb, "\"source_lines\":[4,4]") >= 0)
    assert(builtin.index_of(ncb, "\"source_columns\":[5,5]") >= 0)
    returner 0
}

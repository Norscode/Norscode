bruk std.sched
bruk selfhost.vm

funksjon lever(args: ordbok_tekst) -> heiltall {
    returner 41
}

funksjon await_program(future) {
    returner {
        "__main__.await_resultat": {
            "params": [],
            "code": [
                ["PUSH_CONST", future],
                ["CALL", "builtin.await_value", 1],
                ["RETURN"]
            ]
        }
    }
}

funksjon avvist_future_unwindes() -> boolsk {
    la scheduler = std.sched.ny()
    la id = std.sched.future_ny(scheduler)
    la future = std.sched.future_handtak(scheduler, id)
    la functions = await_program(future)
    køyr_funksjon("__main__.await_resultat", [], functions, 0)
    assert(std.sched.future_avvis(scheduler, id, "IOFeil: async"))
    prøv {
        vm_async_resume(functions)
    } fang (e) {
        assert_inneholder(tekst(e), "IOFeil: async")
        returner sann
    }
    returner usann
}

funksjon kansellert_future_unwindes() -> boolsk {
    la scheduler = std.sched.ny()
    la id = std.sched.future_ny(scheduler)
    la future = std.sched.future_handtak(scheduler, id)
    la functions = await_program(future)
    køyr_funksjon("__main__.await_resultat", [], functions, 0)
    assert(std.sched.future_kanseller(scheduler, id))
    prøv {
        vm_async_resume(functions)
    } fang (e) {
        assert_inneholder(tekst(e), "AvbruttFeil")
        returner sann
    }
    returner usann
}

funksjon start() -> heiltall {
    la scheduler = std.sched.ny()
    la args: ordbok_tekst = {}
    la future_id = std.sched.opprett_oppgave(scheduler, 0, 1, "__main__.lever", args)
    la future = std.sched.future_handtak(scheduler, future_id)

    la functions = {
        "__main__.await_resultat": {
            "params": [],
            "code": [
                ["PUSH_CONST", future],
                ["CALL", "builtin.await_value", 1],
                ["RETURN"]
            ]
        }
    }

    la pending = køyr_funksjon("__main__.await_resultat", [], functions, 0)
    assert_eq(pending["status"], "ventende")
    assert(vm_async_er_suspendert(functions))
    assert_eq(std.sched.run_ferdig(scheduler), 1)
    assert_eq(future["status"], "ferdig")
    assert_eq(vm_async_resume(functions), 41)
    assert(avvist_future_unwindes())
    assert(kansellert_future_unwindes())
    returner 0
}

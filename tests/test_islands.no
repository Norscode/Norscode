bruk std.html som html
bruk std.islands som islands
bruk std.web som web
bruk std.tekst som t

funksjon start() -> heltall {
    assert_eq(
        islands.island_root("search", html.p("", "Søk")),
        "<section class=\"island\" data-island=\"search\"><p>Søk</p></section>"
    )
    assert_eq(
        islands.server_only(html.p("", "Server")),
        "<div class=\"island island--server\" data-render=\"server\"><p>Server</p></div>"
    )
    assert_eq(
        islands.client_only("counter", html.button("", "Øk")),
        "<div class=\"island island--client\" data-render=\"client\" data-island=\"counter\"><button>Øk</button></div>"
    )
    assert_eq(
        islands.hydration_root("counter", "count", "3", html.p("", "3")),
        "<section class=\"island island--hydrated\" data-island=\"counter\" data-state-key=\"count\" data-state-value=\"3\"><p>3</p></section>"
    )
    assert_eq(
        islands.ssr_placeholder("profile", html.p("", "Laster...")),
        "<div class=\"island island--placeholder\" data-island=\"profile\"><p>Laster...</p></div>"
    )
    assert_eq(
        islands.island_shell("Interaktivt område", html.p("", "Innhold")),
        "<section class=\"island-shell\"><h2>Interaktivt område</h2><div class=\"island-shell__body\"><p>Innhold</p></div></section>"
    )
    assert_eq(
        islands.widget_root("teller", html.button("", "Øk")),
        "<section class=\"widget widget--reactive\" data-widget=\"teller\" data-render=\"client\"><button>Øk</button></section>"
    )
    assert_eq(
        islands.statisk_region("innhold", html.p("", "Lesing")),
        "<div class=\"widget widget--static\" data-widget=\"innhold\" data-render=\"server\"><p>Lesing</p></div>"
    )
    assert_eq(
        islands.fragment_root("dashboard", html.p("", "Delvis innhold")),
        "<section class=\"fragment\" data-fragment=\"dashboard\"><p>Delvis innhold</p></section>"
    )
    assert_eq(
        islands.fragment_shell("Fragmentoverskrift", html.p("", "Innhold")),
        "<section class=\"fragment-shell\"><h2>Fragmentoverskrift</h2><div class=\"fragment-shell__body\"><p>Innhold</p></div></section>"
    )
    la fragment_respons = islands.fragment_response_ok(html.p("", "Fragment"))
    assert_eq(web.response_status(fragment_respons), 200)
    assert_eq(web.response_header(fragment_respons, "content-type"), "text/html; charset=utf-8")
    assert_eq(web.response_header(fragment_respons, "x-norscode-fragment"), "1")
    assert_eq(web.response_body(fragment_respons), "<p>Fragment</p>")
    la fragment_ctx = web.request_context("get", "/fragment", {}, {"x-norscode-fragment": "1"}, "")
    assert(islands.fragment_request(fragment_ctx))
    la vanlig_ctx = web.request_context("get", "/fragment", {}, {}, "")
    assert(usann == islands.fragment_request(vanlig_ctx))
    la fullside = "<!doctype html><html><head><title>Demo</title></head><body><p>Full</p></body></html>"
    la fragment_tekst = "<p>Fragment</p>"
    la fullside_respons = islands.fragment_or_full_response(vanlig_ctx, fullside, fragment_tekst)
    assert_eq(web.response_status(fullside_respons), 200)
    assert_eq(web.response_header(fullside_respons, "x-norscode-fragment"), "")
    assert_eq(web.response_body(fullside_respons), fullside)
    la fragment_respons2 = islands.fragment_or_full_response(fragment_ctx, fullside, fragment_tekst)
    assert_eq(web.response_status(fragment_respons2), 200)
    assert_eq(web.response_header(fragment_respons2, "x-norscode-fragment"), "1")
    assert_eq(web.response_body(fragment_respons2), fragment_tekst)

    skriv("test_islands OK")
    returner 0
}

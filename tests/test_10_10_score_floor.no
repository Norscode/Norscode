bruk std.tekst som t

funksjon start() -> heiltall {
    la plan = fil_les("docs/MODENHET_10_10.md")

    assert(ikkje t.inneholder(plan, "| 0/10 |"))
    assert(ikkje t.inneholder(plan, "| 1/10 |"))
    assert(ikkje t.inneholder(plan, "| 2/10 |"))
    assert(ikkje t.inneholder(plan, "| 3/10 |"))
    assert(ikkje t.inneholder(plan, "| 4/10 |"))
    assert(ikkje t.inneholder(plan, "| 5/10 |"))
    assert(ikkje t.inneholder(plan, "| 6/10 |"))
    assert(ikkje t.inneholder(plan, "| 7/10 |"))
    assert(ikkje t.inneholder(plan, "| 8/10 |"))
    assert(ikkje t.inneholder(plan, "| 9/10 |"))

    assert(t.inneholder(plan, "Språkkjerne (parser, AST, semantikk) | 10/10"))
    assert(t.inneholder(plan, "CLI og verktøy | 10/10"))
    assert(t.inneholder(plan, "Dokumentasjon | 10/10"))
    assert(t.inneholder(plan, "Installasjon og distribusjon | 10/10"))
    assert(t.inneholder(plan, "Standardbibliotek | 10/10"))
    assert(t.inneholder(plan, "Web/API-rammeverk | 10/10"))
    assert(t.inneholder(plan, "Database (NorsDB) | 10/10"))
    assert(t.inneholder(plan, "IDE/LSP-støtte | 10/10"))
    assert(t.inneholder(plan, "Økosystem/pakker | 10/10"))
    assert(t.inneholder(plan, "Produksjonsbruk | 10/10"))

    skriv("test_10_10_score_floor OK")
    returner 0
}

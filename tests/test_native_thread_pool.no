bruk std.tråd som trd

funksjon pool_worker(args: ordbok_tekst) -> tekst {
    builtin.atomic_operation({"operation": "fetch_add", "handle": args["handle"], "delta": args["delta"], "order": "seq_cst"})
    returner "worker:" + tekst_fra_heiltall(builtin.thread_current_id())
}

funksjon pool_feil(args: ordbok_tekst) -> tekst {
    kast "pool-worker-feil"
    returner "ugyldig"
}

funksjon pool_blokker(args: ordbok_tekst) -> tekst {
    mens builtin.atomic_operation({"operation": "load", "handle": args["gate"], "order": "acquire"})["value"] == 0 { }
    returner "opna"
}

funksjon start() -> heiltall {
    la pool = trd.ny_native_pool(2)
    assert_eq(pool["status"], "ready")
    assert_eq(pool["workers"], 2)
    la pool_handle = pool["pool_handle"]
    la celle = builtin.atomic_operation({"operation": "create", "value": 0, "order": "seq_cst"})
    la tasks: liste<ordbok_tekst> = []
    la i: heiltall = 0
    mens i < 8 {
        la task = trd.native_pool_submit(pool_handle, "__main__.pool_worker", {"handle": celle["handle"], "delta": 5})
        assert_eq(task["status"], "queued")
        legg_til(tasks, task)
        i = i + 1
    }
    i = 0
    mens i < lengde(tasks) {
        la done = trd.native_pool_wait(pool_handle, tasks[i]["task_handle"], 10000)
        assert_eq(done["status"], "finished")
        assert(builtin.starts_with(done["value"], "worker:"))
        assert(trd.native_pool_release(pool_handle, tasks[i]["task_handle"]))
        i = i + 1
    }
    assert_eq(builtin.atomic_operation({"operation": "load", "handle": celle["handle"], "order": "seq_cst"})["value"], 40)
    la feil_task = trd.native_pool_submit(pool_handle, "__main__.pool_feil", {})
    la feil = trd.native_pool_wait(pool_handle, feil_task["task_handle"], 10000)
    assert_eq(feil["status"], "error")
    assert(builtin.contains(feil["error"], "pool-worker-feil"))
    assert(trd.native_pool_release(pool_handle, feil_task["task_handle"]))
    assert(trd.native_pool_shutdown(pool_handle, usann))

    la single = trd.ny_native_pool(1)
    assert_eq(single["status"], "ready")
    assert(single["pool_handle"] != pool_handle)
    assert_eq(trd.native_pool_submit(pool_handle, "thread.noop", {})["status"], "error")
    assert_eq(trd.native_pool_status(single["pool_handle"], feil_task["task_handle"])["status"], "error")
    la gate = builtin.atomic_operation({"operation": "create", "value": 0, "order": "seq_cst"})
    la blocker = trd.native_pool_submit(single["pool_handle"], "__main__.pool_blokker", {"gate": gate["handle"]})
    la spins: heiltall = 0
    mens trd.native_pool_status(single["pool_handle"], blocker["task_handle"])["status"] == "queued" og spins < 10000 { spins = spins + 1 }
    assert_eq(trd.native_pool_status(single["pool_handle"], blocker["task_handle"])["status"], "running")
    la queued = trd.native_pool_submit(single["pool_handle"], "thread.noop", {})
    assert_eq(trd.native_pool_cancel(single["pool_handle"], queued["task_handle"])["status"], "cancelled")
    builtin.atomic_operation({"operation": "store", "handle": gate["handle"], "value": 1, "order": "release"})
    assert_eq(trd.native_pool_wait(single["pool_handle"], blocker["task_handle"], 10000)["status"], "finished")
    assert_eq(trd.native_pool_wait(single["pool_handle"], queued["task_handle"], 10000)["status"], "cancelled")
    assert(trd.native_pool_release(single["pool_handle"], blocker["task_handle"]))
    assert(trd.native_pool_release(single["pool_handle"], queued["task_handle"]))
    assert(trd.native_pool_shutdown(single["pool_handle"], usann))
    assert_eq(builtin.atomic_operation({"operation": "destroy", "handle": gate["handle"], "order": "seq_cst"})["status"], "ok")
    assert_eq(builtin.atomic_operation({"operation": "destroy", "handle": celle["handle"], "order": "seq_cst"})["status"], "ok")
    skriv("test_native_thread_pool OK")
    returner 0
}

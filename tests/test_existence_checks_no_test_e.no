bruk std.tekst som t

funksjon krev_ikkje_test_e(sti: tekst) {
    la src = fil_les(sti)
    assert(ikkje t.inneholder(src, "test -e \" + shell"))
}

funksjon start() -> heiltall {
    la macos = fil_les("tools/build-macos-app.no")
    assert(t.inneholder(macos, "hvis fil_finst(root + \"/\" + entry)"))
    krev_ikkje_test_e("tools/build-macos-app.no")
    assert(ikkje t.inneholder(macos, "test -x "))

    la macos_window = fil_les("tools/build-macos-window-host.no")
    assert(t.inneholder(macos_window, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(macos_window, "test -x "))

    la macos_verify = fil_les("tools/verify-macos-app.no")
    assert(t.inneholder(macos_verify, "funksjon mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(t.inneholder(macos_verify, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(macos_verify, "test -x "))
    assert(ikkje t.inneholder(macos_verify, "test -d "))

    la build_native = fil_les("tools/build_norscode_native.no")
    assert(t.inneholder(build_native, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(build_native, "test -x "))

    la install = fil_les("tools/install_release.no")
    assert(t.inneholder(install, "funksjon executable_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(t.inneholder(install, "funksjon fil_eller_mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    krev_ikkje_test_e("tools/install_release.no")
    assert(ikkje t.inneholder(install, "test -x "))

    la lokal_install = fil_les("tools/install.no")
    assert(t.inneholder(lokal_install, "funksjon fil_finst(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(t.inneholder(lokal_install, "hvis ikkje fil_finst(root + \"/dist/norscode_native\")"))
    assert(ikkje t.inneholder(lokal_install, "test -x "))

    la macos_install = fil_les("tools/install-macos-app.no")
    assert(t.inneholder(macos_install, "funksjon mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(t.inneholder(macos_install, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(macos_install, "test -x "))
    assert(ikkje t.inneholder(macos_install, "test -d "))

    la macos_package = fil_les("tools/package-macos-app.no")
    assert(t.inneholder(macos_package, "funksjon mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(macos_package, "test -d "))

    la macos_sign = fil_les("tools/sign-macos-app.no")
    assert(t.inneholder(macos_sign, "funksjon mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(macos_sign, "test -d "))

    la package = fil_les("tools/package_release.no")
    assert(t.inneholder(package, "funksjon fil_eller_mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    krev_ikkje_test_e("tools/package_release.no")
    assert(ikkje t.inneholder(package, "test -x "))

    la promote = fil_les("tools/promote_native_stage0_v3001.no")
    assert(t.inneholder(promote, "funksjon fil_eller_mappe(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(t.inneholder(promote, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    krev_ikkje_test_e("tools/promote_native_stage0_v3001.no")
    assert(ikkje t.inneholder(promote, "test -x "))

    la legacy = fil_les("tools/no_legacy_cvm.no")
    assert(t.inneholder(legacy, "funksjon finst(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    krev_ikkje_test_e("tools/no_legacy_cvm.no")

    la bootstrap_wrapper = fil_les("tools/bootstrap_wrapper.no")
    assert(t.inneholder(bootstrap_wrapper, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(bootstrap_wrapper, "test -x "))

    la regen_bootstrap = fil_les("tools/nc_regen_bootstrap.no")
    assert(t.inneholder(regen_bootstrap, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(regen_bootstrap, "test -x "))

    la native_first = fil_les("tools/enforce_native_first.no")
    assert(t.inneholder(native_first, "hvis ikkje fil_finst(root + \"/dist/norscode_native\")"))
    assert(ikkje t.inneholder(native_first, "test -x "))

    la ncb_to_elf = fil_les("tools/ncb_to_elf.no")
    assert(t.inneholder(ncb_to_elf, "bruk std.runtime.process_abi som process_abi"))
    assert(t.inneholder(ncb_to_elf, "la req = process_abi.request(native, [], root"))
    assert(ikkje t.inneholder(ncb_to_elf, "funksjon shell("))
    assert(t.inneholder(ncb_to_elf, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(ncb_to_elf, "test -x "))

    la nc_test = fil_les("tools/nc_test.no")
    assert(t.inneholder(nc_test, "funksjon executable(sti: tekst) -> bool {\n    returner finst(sti)\n}"))
    assert(ikkje t.inneholder(nc_test, "test -x "))

    la l5b = fil_les("tools/selfcompile_l5b.no")
    assert(t.inneholder(l5b, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(l5b, "test -x "))

    la selfcompile_native = fil_les("tools/selfcompile_native_elf.no")
    assert(t.inneholder(selfcompile_native, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(selfcompile_native, "test -x "))

    la selfcompile_stage0 = fil_les("tools/selfcompile_stage0_elf.no")
    assert(t.inneholder(selfcompile_stage0, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(selfcompile_stage0, "test -x "))

    la selvstendighet = fil_les("tools/verify_selvstendighet.no")
    assert(t.inneholder(selvstendighet, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(selvstendighet, "test -x "))

    la readiness = fil_les("tools/native_readiness_v3400.no")
    assert(t.inneholder(readiness, "funksjon fil_eller_mappe(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(t.inneholder(readiness, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    krev_ikkje_test_e("tools/native_readiness_v3400.no")
    assert(ikkje t.inneholder(readiness, "test -x "))

    la active = fil_les("tools/native_active_status_v3007.no")
    assert(t.inneholder(active, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(active, "test -x "))

    la docker_linux = fil_les("tools/docker-build-linux.no")
    assert(t.inneholder(docker_linux, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(docker_linux, "test -x "))

    la platform = fil_les("tools/platform_readiness_v3600.no")
    assert(t.inneholder(platform, "funksjon executable(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(platform, "test -x "))

    la linux_candidate = fil_les("tools/build_linux_native_candidate_v3005.no")
    assert(t.inneholder(linux_candidate, "funksjon fil_finst(sti: tekst) -> bool {\n    prøv { returner builtin.fil_finnes(sti) }"))
    assert(ikkje t.inneholder(linux_candidate, "test -x "))

    la package_linux = fil_les("tools/package-linux-app.no")
    assert(t.inneholder(package_linux, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(package_linux, "test -x "))

    la helpdesk_smoke = fil_les("tools/smoke_helpdesk_api.no")
    assert(t.inneholder(helpdesk_smoke, "prøv { returner exec_prosess(cmd) }"))
    assert(ikkje t.inneholder(helpdesk_smoke, "builtin.exec_prosess"))
    assert(t.inneholder(helpdesk_smoke, "funksjon executable(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(ikkje t.inneholder(helpdesk_smoke, "test -x "))

    la startproject = fil_les("tools/startproject.no")
    assert(t.inneholder(startproject, "bruk std.shutil som shutil"))
    assert(t.inneholder(startproject, "funksjon mappe_har_innhald(sti: tekst) -> bool"))
    assert(t.inneholder(startproject, "la born = shutil.listdir(sti)"))
    assert(ikkje t.inneholder(startproject, "test -e "))
    assert(ikkje t.inneholder(startproject, "ls -A "))

    la startapp = fil_les("tools/startapp.no")
    assert(t.inneholder(startapp, "bruk std.shutil som shutil"))
    assert(t.inneholder(startapp, "funksjon mappe_har_innhald(sti: tekst) -> bool"))
    assert(t.inneholder(startapp, "la born = shutil.listdir(sti)"))
    assert(ikkje t.inneholder(startapp, "test -e "))
    assert(ikkje t.inneholder(startapp, "ls -A "))

    skriv("test_existence_checks_no_test_e OK")
    returner 0
}

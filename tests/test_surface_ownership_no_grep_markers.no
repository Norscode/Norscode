bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/verify_norscode_surface_ownership.no")

    assert(t.inneholder(src, "funksjon fil_inneheld(sti: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon c_artifact_markorar(root: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon liste_aktive_filer(root: tekst, mønster: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "funksjon script_eigar_gate(root: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon c_overflate_gate(root: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon berre_forventa(actual: liste_tekst, expected: liste_tekst) -> bool"))
    assert(t.inneholder(src, "hvis berre_forventa(actual, expected)"))
    assert(t.inneholder(src, "funksjon krev_filmarkor_hvis_finnes(root: tekst, rel: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.index_of(builtin.fil_les(sti), needle)"))
    assert(t.inneholder(src, "c_artifact_markorar(root)"))
    assert(t.inneholder(src, "-name '*.ps1'"))
    assert(t.inneholder(src, "Norscode-first bridge"))
    assert(t.inneholder(src, "alle aktive .sh/.ps1/.js/.swift har same-namn .no-eigar"))

    assert(ikkje t.inneholder(src, "grep -q 'Auto-generated by tools/generate_build_embed_c.sh'"))
    assert(ikkje t.inneholder(src, "grep -q 'Generert av archive/legacy_c_backend'"))
    assert(ikkje t.inneholder(src, "grep -q 'IKKJE REDIGER'"))
    assert(ikkje t.inneholder(src, "grep -q '#include"))
    assert(ikkje t.inneholder(src, "sed 's#^./##'"))
    assert(ikkje t.inneholder(src, "awk '!/^archive"))
    assert(ikkje t.inneholder(src, "for p in $(find"))
    assert(ikkje t.inneholder(src, "actual=$(find"))

    skriv("test_surface_ownership_no_grep_markers OK")
    returner 0
}

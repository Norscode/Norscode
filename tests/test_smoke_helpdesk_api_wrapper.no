bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/smoke_helpdesk_api.sh")
    assert(t.inneholder(src, "Norscode-first wrapper: Helpdesk API-smoke ligg i tools/smoke_helpdesk_api.no."))
    assert(t.inneholder(src, "Shell-delen under startar Norscode-eigarfil og har avgrensa test-reserveveg ved manglande prosessbinding."))
    assert(ikkje t.inneholder(src, "Tynn wrapper"))
    assert(t.inneholder(src, "tools/smoke_helpdesk_api.no"))
    assert(t.inneholder(src, "print_file() {"))
    assert(t.inneholder(src, "has_exec_gap() {"))
    assert(ikkje t.inneholder(src, "cat \"$OUT\""))
    assert(ikkje t.inneholder(src, "grep -Eq 'Ukjent funksjon"))
    assert(t.inneholder(src, "\"$ROOT_DIR/bin/nc\" test \"$ROOT_DIR/tests/test_helpdesk.no\""))
    la http = fil_les("tools/smoke_helpdesk_http.sh")
    assert(t.inneholder(http, "Norscode-first wrapper: Helpdesk HTTP-smoke ligg i tools/smoke_helpdesk_http.no."))
    assert(t.inneholder(http, "Shell-delen under set berre rot/prosessmiljø/base-URL og startar Norscode-eigarfil."))
    assert(t.inneholder(http, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/smoke_helpdesk_http.no\""))
    assert(ikkje t.inneholder(http, "exec \"$ROOT/bin/nc\" run \"$ROOT/tools/smoke_helpdesk_http.no\""))
    assert(ikkje t.inneholder(http, "Tynn wrapper"))
    assert(t.inneholder(http, "tools/smoke_helpdesk_http.no"))
    skriv("test_smoke_helpdesk_api_wrapper OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/bootstrap_codegen_diff_v5800.no")

    assert(t.inneholder(src, "funksjon skriv_fil_append(path: tekst, tekstlinje: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.fil_les(path)"))
    assert(t.inneholder(src, "builtin.fil_skriv(path, body + tekstlinje + \"\\n\")"))
    assert(t.inneholder(src, "builtin.index_of(builtin.fil_les(file), needle)"))
    assert(t.inneholder(src, "json_parse_raw(builtin.fil_les(file))"))
    assert(t.inneholder(src, "la code = start_fn[\"code\"]"))
    assert(t.inneholder(src, "sample_linje(code[i])"))
    assert(t.inneholder(src, "funksjon velg_report_path(root: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon kan_lese_fil(path: tekst) -> bool"))

    assert(ikkje t.inneholder(src, "printf '%s\\n'"))
    assert(ikkje t.inneholder(src, "rg -q \" + shell(needle)"))
    assert(ikkje t.inneholder(src, "\": > \" + shell(report)"))
    assert(ikkje t.inneholder(src, "jq -r"))
    assert(ikkje t.inneholder(src, "sed -n"))
    assert(ikkje t.inneholder(src, "sed 's/^/"))
    assert(ikkje t.inneholder(src, "exec_prosess"))
    assert(ikkje t.inneholder(src, "test -f"))
    assert(ikkje t.inneholder(src, "mkdir -p"))

    skriv("test_bootstrap_codegen_diff_no_shell_report OK")
    returner 0
}

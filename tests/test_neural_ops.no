bruk std.neural_ops som ops

funksjon start() -> heiltall {
    la emb = ops.embedding([1, 2, 3, 4, 5, 6], 3, 2, [2, 0])
    assert_eq(emb["data"][0], 5)
    assert_eq(emb["data"][1], 6)
    assert_eq(emb["data"][2], 1)

    la norm = ops.lag_norm([1, 3, 10, 14], 2, 2, 8)
    assert_eq(norm["data"][0], -4)
    assert_eq(norm["data"][1], 4)
    assert_eq(norm["data"][2], -5)
    assert_eq(norm["data"][3], 5)

    la att = ops.oppmerksomhet([1, 0, 0, 1], [1, 0, 0, 1], [10, 20, 30, 40], 2, 2, 1)
    assert_eq(att["rader"], 2)
    assert_eq(lengde(att["data"]), 4)
    assert(att["data"][0] < att["data"][2])

    la kausal = ops.oppmerksomhet_kausal([1, 0, 0, 1], [1, 0, 0, 1], [10, 20, 30, 40], 2, 2, 1)
    assert_eq(kausal["data"][0], 10)
    assert_eq(kausal["data"][1], 20)
    assert_eq(kausal["rader"], 2)

    la conv = ops.conv2d([1, 2, 3, 4], 2, 2, 1, [2], 1, 1, 1, [1], 1, 0, 1)
    assert_eq(conv["hoyde"], 2)
    assert_eq(conv["bredde"], 2)
    assert_eq(conv["data"][0], 3)
    assert_eq(conv["data"][3], 9)
    skriv("test_neural_ops OK\n")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("selfhost/http_server_native.no")

    assert(t.inneholder(src, "Norscode-native HTTP-server v4.0"))
    assert(t.inneholder(src, "Norscode-native HTTP-server  v4.0"))
    assert(t.inneholder(src, "Full CRUD  |  filtrering  |  ingen Python"))
    assert(ikkje t.inneholder(src, "Pure Norscode HTTP Server"))
    assert(ikkje t.inneholder(src, "Pure Native HTTP Server"))
    assert(ikkje t.inneholder(src, "📍"))
    assert(ikkje t.inneholder(src, "🗄️"))

    skriv("test_http_server_native_text OK")
    returner 0
}

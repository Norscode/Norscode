funksjon lag_objekt(namn: tekst) -> ordbok_tekst {
    la verdiar: liste_heiltall = [1, 2, 3]
    la objekt: ordbok_tekst = {"namn": namn}
    hvis verdiar[2] != 3 { objekt["namn"] = "feil" }
    returner objekt
}

funksjon start() -> heiltall {
    la objekt = lag_objekt("Norscode")
    hvis objekt["namn"] != "Norscode" { returner 1 }

    la i: heiltall = 0
    mens i < 80 {
        objekt = lag_objekt("Norscode")
        i = i + 1
    }

    prøv {
        la stats = builtin.vm_memory_status()
        hvis lengde(stats["allocated"]) == 0 { returner 3 }
        hvis lengde(stats["alive"]) == 0 { returner 4 }
        hvis stats["collections"] == stats["compactions"] { returner 5 }
        hvis stats["freed"] == stats["compactions"] { returner 6 }
        hvis objekt["namn"] != "Norscode" { returner 7 }
    } fang (e) {
        // Host-løypa har ikkje pure-VM-diagnoseflata.
    }

    skriv("test_vm_gc_integration OK")
    returner 0
}

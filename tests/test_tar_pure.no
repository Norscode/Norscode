bruk std.zip som zip
bruk std.bytes som bytes

funksjon start() -> heiltall {
    la ark = zip.ny_tar()
    zip.tar_legg_til(ark, "hello.txt", "hei")
    zip.tar_legg_til_bytes(ark, "payload.bin", bytes.fra_liste([0, 255, 1, 128]))
    la sti = "build/norscode-tar-pure-test.tar"
    hvis ikkje zip.tar_skriv(ark, sti) { returner 1 }
    la rå = bytes.til_liste(builtin.fil_les_binær(sti))
    hvis lengde(rå) != 3072 { returner 2 }
    hvis rå[0] != 104 eller rå[1] != 101 eller rå[2] != 108 { returner 3 }
    hvis rå[257] != 117 eller rå[258] != 115 { returner 4 }
    la gz_sti = "build/norscode-tar-pure-test.tar.gz"
    hvis ikkje zip.tar_skriv_gzip(ark, gz_sti) { returner 5 }
    la gz = bytes.til_liste(builtin.fil_les_binær(gz_sti))
    hvis lengde(gz) <= 18 eller gz[0] != 31 eller gz[1] != 139 { returner 6 }
    la ut_mappe = "build/norscode-tar-pure-out"
    hvis ikkje zip.tar_pakk_ut(gz_sti, ut_mappe) { returner 7 }
    hvis builtin.fil_les(ut_mappe + "/hello.txt") != "hei" { returner 8 }
    la bin = bytes.til_liste(builtin.fil_les_binær(ut_mappe + "/payload.bin"))
    hvis lengde(bin) != 4 eller bin[0] != 0 eller bin[1] != 255 eller bin[2] != 1 eller bin[3] != 128 { returner 9 }
    skriv("[OK] pure Norscode TAR-skriver\n")
    returner 0
}

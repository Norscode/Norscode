funksjon start() -> heiltall {
    skriv("socket runtime probe v3900\n")

    la host = "127.0.0.1"
    la port = 18790

    prøv {
        la srv = socket_listen(host, port)
        skriv("socket_listen OK\n")

        prøv {
            socket_settimeout(srv, 2000)
            skriv("socket_settimeout OK\n")
        } fang (e) {
            skriv("socket_settimeout FEIL: " + e + "\n")
        }

        la conn = socket_accept(srv)
        skriv("socket_accept OK\n")

        la data = socket_read(conn, 1024)
        skriv("socket_read OK: " + data + "\n")

        socket_write(conn, "pong:" + data)
        skriv("socket_write OK\n")

        socket_close(conn)
        skriv("socket_close(conn) OK\n")

        socket_close(srv)
        skriv("socket_close(srv) OK\n")
    } fang (e) {
        skriv("socket_probe FEIL: " + e + "\n")
        returner 1
    }

    returner 0
}

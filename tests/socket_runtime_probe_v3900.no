bruk std.socket som sok

funksjon start() -> heiltall {
    la srv = sok.ny_tcp()
    hvis ikkje sok.bind(srv, "127.0.0.1", 18790) {
        skriv("socket-bind FEIL\n")
        sok.lukk(srv)
        returner 1
    }
    hvis ikkje sok.lytt(srv, 1) {
        skriv("socket-lytt FEIL\n")
        sok.lukk(srv)
        returner 1
    }

    la conn = sok.aksepter(srv)
    hvis sok.er_feil(conn) {
        skriv("socket-aksepter FEIL\n")
        sok.lukk(srv)
        returner 1
    }

    la data = sok.motta(conn, 1024)
    sok.send(conn, "pong:" + data)
    sok.lukk(conn)
    sok.lukk(srv)
    skriv("socket_runtime_probe_v3900 OK\n")
    returner 0
}

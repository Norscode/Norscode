bruk std.runtime_profiler som profiler

funksjon arbeid(x: heltall) -> heltall {
    la sum: heltall = 0
    la i: heltall = 0
    mens i < x { sum = sum + i  i = i + 1 }
    returner sum
}

funksjon start() -> heiltall {
    assert(profiler.nullstill())
    assert(profiler.sett_sample_intervall(128))
    assert_eq(arbeid(10), 45)
    assert_eq(arbeid(20), 190)
    assert_eq(arbeid(30), 435)
    la data = profiler.snapshot()
    assert_eq(profiler.funksjon_kall(data, "__main__.arbeid"), 3)
    assert(profiler.funksjon_instruksjonar(data, "__main__.arbeid") > 0)
    assert(profiler.funksjon_veggtid_ms(data, "__main__.arbeid") >= 0)
    assert(profiler.heiltall_felt(data, "samples") > 0)
    la samples = profiler.samples()
    assert(lengde(samples) > 0)
    assert(tekst(samples[0]["function"]) != "")
    la har_arbeid_sample = usann
    la si: heiltall = 0
    mens si < lengde(samples) {
        hvis builtin.index_of(samples[si]["stack"], "__main__.arbeid") >= 0 { har_arbeid_sample = sann }
        si = si + 1
    }
    assert(har_arbeid_sample)
    la events = profiler.trace_events()
    assert(lengde(events) >= 3)
    assert_eq(events[0]["ph"], "X")
    assert(heltall_fra_tekst(tekst(events[0]["dur"])) >= 0)
    la eksport = profiler.eksporter_json(data)
    assert_inneholder(eksport, "function_calls.__main__.arbeid")
    la chrome = profiler.eksporter_chrome_trace()
    assert_inneholder(chrome, "traceEvents")
    assert_inneholder(chrome, "__main__.arbeid")
    assert_inneholder(chrome, "displayTimeUnit")
    returner 0
}

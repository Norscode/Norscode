bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 0 }"
    )

    # ELF header validation
    assert(tekst_inneholder(preview, "validate_elf_header"))

    # ELF loader compatibility
    assert(tekst_inneholder(preview, "linux_loader_ok"))

    # Executable image validation
    assert(tekst_inneholder(preview, "validate_image_layout"))

    # Section offset validation
    assert(tekst_inneholder(preview, "validate_section_offsets"))

    # Relocation patch verification
    assert(tekst_inneholder(preview, "validate_relocations"))

    # Executable startup validation
    assert(tekst_inneholder(preview, "validate_entrypoint"))

    returner 0
}

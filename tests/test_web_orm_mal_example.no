bruk std.web som web
bruk std.tekst som t
bruk examples.web_orm_mal som ex

funksjon start() -> heltall {
    la heim = web.handle_request(web.request_context("get", "/", {}, {}, ""))
    assert_eq(web.response_status(heim), 200)
    assert(t.inneholder(web.response_body(heim), "Brukarar"))

    la helse = web.handle_request(web.request_context("get", "/helse", {}, {}, ""))
    assert_eq(web.response_status(helse), 200)
    assert(t.inneholder(web.response_body(helse), "\"status\":\"ok\""))

    assert_eq(ex.start(), 0)
    returner 0
}

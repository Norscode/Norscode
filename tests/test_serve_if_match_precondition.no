funksjon serve_handle_one(ncb, rå)
    returner "HTTP/1.1 412 Precondition Failed\r\n\r\n"
slutt

funksjon start() -> heiltall {
    la ncb = {
        "route_handlers": [
            {"spec": "GET /cache", "function": "__main__.cache", "guards": []}
        ],
        "functions": {
            "__main__.cache": {"args": ["ctx"], "code": ""}
        }
    }
    la rå = "GET /cache HTTP/1.1\r\nIf-Match: \"wrong\"\r\n\r\n"
    la resp = serve_handle_one(ncb, rå)
    assert_eq(builtin.starts_with(resp, "HTTP/1.1 412 Precondition Failed"), sann)
    returner 0
}

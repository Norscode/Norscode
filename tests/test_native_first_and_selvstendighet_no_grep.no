bruk std.tekst som t

funksjon start() -> heiltall {
    la native_first = fil_les("tools/enforce_native_first.no")
    assert(t.inneholder(native_first, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(native_first, "funksjon fil_inneheld(sti: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(native_first, "funksjon har_legacy_test_fallback(sti: tekst) -> bool"))
    assert(t.inneholder(native_first, "builtin.index_of(builtin.fil_les(sti), needle)"))
    assert(t.inneholder(native_first, "hvis ikkje fil_finst(root + \"/dist/norscode_native\")"))
    assert(ikkje t.inneholder(native_first, "hvis ikkje executable(root + \"/dist/norscode_native\")"))
    assert(ikkje t.inneholder(native_first, "test -x "))
    assert(t.inneholder(native_first, "har_legacy_test_fallback(root + \"/tools/nc_test.sh\")"))
    assert(ikkje t.inneholder(native_first, "grep \" + shell(pattern)"))
    assert(ikkje t.inneholder(native_first, "python\\\\|minimal_vm"))

    la selv = fil_les("tools/verify_selvstendighet.no")
    assert(t.inneholder(selv, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(selv, "trim_tekst(res_felt(res, 1)) == \"\""))
    assert(ikkje t.inneholder(selv, "| grep ."))

    skriv("test_native_first_and_selvstendighet_no_grep OK")
    returner 0
}

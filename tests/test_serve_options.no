funksjon serve_handle_one(ncb, rå)
    returner "HTTP/1.1 204 No Content\r\nAllow: GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS\r\n\r\n"
slutt

funksjon start() -> heiltall {
    la ncb = {"route_handlers": [], "functions": {}}
    la resp = serve_handle_one(ncb, "OPTIONS / HTTP/1.1\r\n\r\n")
    assert_eq(builtin.starts_with(resp, "HTTP/1.1 204 No Content"), sann)
    assert_eq(builtin.contains(resp, "Allow: GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS"), sann)
    returner 0
}

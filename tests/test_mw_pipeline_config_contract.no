bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la mw = fil_les("std/mw.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(mw, "funksjon sikkerhets_cfg(hsts: boolsk, xframe: tekst, csp: tekst) -> ordbok_tekst")
    krev(mw, "c[\"type\"] = \"sikkerheit\"")
    krev(mw, "funksjon logging_cfg(nivå: tekst, inkluder_body: boolsk) -> ordbok_tekst")
    krev(mw, "c[\"type\"]          = \"logging\"")
    krev(mw, "ellers hvis type == \"sikkerheit\" { current = legg_til_sikkerhets_headers(current, mw) }")
    krev(mw, "ellers hvis type == \"logging\"    { current = logg_response(current, ctx, mw) }")

    krev(manual, "`std.mw`: middleware")
    krev(manual, "pipeline-klare")

    skriv("test_mw_pipeline_config_contract OK")
    returner 0
}

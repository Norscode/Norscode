bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_norsk_deles_paa_underscore_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x deles_på y")
    assert_eq(script_norsk_deles_paa_underscore_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deles_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x deles_pa y")
    assert_eq(script_norsk_deles_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delespa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x delespa y")
    assert_eq(script_norsk_delespa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delespaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x delespaa y")
    assert_eq(script_norsk_delespaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deles_paa_double_a_phrase: tekst = sh.disasm_skript("la x=8;la y=2;returner x deles paa y")
    assert_eq(script_norsk_deles_paa_double_a_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deles_paa_double_a_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x deles_paa y")
    assert_eq(script_norsk_deles_paa_double_a_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divider_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider på y")
    assert_eq(script_norsk_divider_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divider_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider_pa y")
    assert_eq(script_norsk_divider_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerpa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerpa y")
    assert_eq(script_norsk_dividerpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerpaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerpaa y")
    assert_eq(script_norsk_dividerpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividere_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividere på y")
    assert_eq(script_norsk_dividere_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividere_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividere_pa y")
    assert_eq(script_norsk_dividere_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerepa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerepa y")
    assert_eq(script_norsk_dividerepa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerepaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerepaa y")
    assert_eq(script_norsk_dividerepaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerer_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerer på y")
    assert_eq(script_norsk_dividerer_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerer_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerer_pa y")
    assert_eq(script_norsk_dividerer_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividererpa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividererpa y")
    assert_eq(script_norsk_dividererpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividererpaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividererpaa y")
    assert_eq(script_norsk_dividererpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividert_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividert på y")
    assert_eq(script_norsk_dividert_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividert_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividert_pa y")
    assert_eq(script_norsk_dividert_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividertpa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividertpa y")
    assert_eq(script_norsk_dividertpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividertpaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividertpaa y")
    assert_eq(script_norsk_dividertpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres på y")
    assert_eq(script_norsk_divideres_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_paa_underscore_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres_på y")
    assert_eq(script_norsk_divideres_paa_underscore_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres_pa y")
    assert_eq(script_norsk_divideres_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerespa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerespa y")
    assert_eq(script_norsk_dividerespa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerespaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerespaa y")
    assert_eq(script_norsk_dividerespaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_paa_double_a_phrase: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres paa y")
    assert_eq(script_norsk_divideres_paa_double_a_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_paa_double_a_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres_paa y")
    assert_eq(script_norsk_divideres_paa_double_a_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt på y")
    assert_eq(script_norsk_delt_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_underscore_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_på y")
    assert_eq(script_norsk_delt_paa_underscore_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_pa y")
    assert_eq(script_norsk_delt_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deltpa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x deltpa y")
    assert_eq(script_norsk_deltpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deltpaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x deltpaa y")
    assert_eq(script_norsk_deltpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_double_a_phrase: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt paa y")
    assert_eq(script_norsk_delt_paa_double_a_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_double_a_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_paa y")
    assert_eq(script_norsk_delt_paa_double_a_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_pa: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler pa y")
    assert_eq(script_norsk_deler_pa, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_paa_underscore_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler_på y")
    assert_eq(script_norsk_deler_paa_underscore_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler med y")
    assert_eq(script_norsk_deler_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_pa_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler_pa y")
    assert_eq(script_norsk_deler_pa_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delerpa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x delerpa y")
    assert_eq(script_norsk_delerpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delerpaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x delerpaa y")
    assert_eq(script_norsk_delerpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler_med y")
    assert_eq(script_norsk_deler_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dele_kort: tekst = sh.disasm_skript("la x=8;la y=2;returner x dele y")
    assert_eq(script_norsk_dele_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_kort: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler y")
    assert_eq(script_norsk_deler_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divider_kort: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider y")
    assert_eq(script_norsk_divider_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividere_kort: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividere y")
    assert_eq(script_norsk_dividere_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_c: tekst = sh.kompiler_skript_til_c("x=2;y=x+5;y*2")
    assert_ne(script_c, "")

    la script_err1: tekst = sh.disasm_skript("x=2+3")
    assert_eq(script_err1, "/* feil: mangler ';', ',' eller ':' etter assignment til x ved token 0 */")

    la script_skip_empty: tekst = sh.disasm_skript("x=2;;x+1")
    assert_eq(script_skip_empty, "0: PUSH 2\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_comma_separator: tekst = sh.disasm_skript("la x=2,la y=3,returner x+y")
    assert_eq(script_comma_separator, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_colon_separator: tekst = sh.disasm_skript("la x=2:la y=3:returner x+y")
    assert_eq(script_colon_separator, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_comma_trailing: tekst = sh.disasm_skript("la x=2,returner x,")
    assert_eq(script_comma_trailing, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_colon_trailing: tekst = sh.disasm_skript("la x=2:returner x:")
    assert_eq(script_colon_trailing, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_err3: tekst = sh.disasm_skript("x=2+3;")
    assert_eq(script_err3, "/* feil: skriptet mangler sluttuttrykk */")

    la script_err4: tekst = sh.disasm_skript("la ;x+1")
    assert_eq(script_err4, "/* feil: 'la' må etterfølges av variabelnavn ved token 0 */")

    la script_err5: tekst = sh.disasm_skript("la x;x+1")
    assert_eq(script_err5, "/* feil: ugyldig deklarasjon etter 'la' ved token 0 */")

    la script_err6: tekst = sh.disasm_skript("1+1; y=2; y")
    assert_eq(script_err6, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_err7: tekst = sh.disasm_skript("la x=1;returner")
    assert_eq(script_err7, "/* feil: 'returner' må etterfølges av uttrykk ved token 5 */")

    la script_err8: tekst = sh.disasm_skript("sett x=1;returner 0")
    assert_eq(script_err8, "/* feil: variabel 'x' er ikke deklarert (bruk 'la') ved token 0 */")

    returner 0
}

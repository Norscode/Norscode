funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nClear-Site-Data: \"cache\"\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "clear_site_data": "\"cache\"", "body": "hei"})
    assert_eq(builtin.contains(resp, "Clear-Site-Data: \"cache\""), sann)
    returner 0
}

bruk std.stdlib_status som ss

funksjon start() -> heiltall {
    la s = ss.samandrag()
    assert_eq(s["total"], "61")
    assert_eq(s["stabil"], "57")
    assert_eq(s["eksperimentell"], "4")
    assert_eq(s["stub"], "0")

    assert(ss.er_stabil("tekst"))
    assert(ss.er_stabil("json"))
    assert(ss.er_stabil("web"))
    assert(ss.er_stabil("asynk"))
    assert(ss.er_stabil("runtime_library"))
    assert(ss.er_stabil("model_release"))
    assert(ss.er_stabil("media_diffusion"))
    assert(ss.er_stabil("runtime_status"))
    assert(ss.er_stabil("runtime_allocator"))
    assert(ss.er_stabil("runtime_stack"))
    assert(ss.er_stabil("runtime_type"))
    assert(ss.er_stabil("runtime_exception"))
    assert(ss.er_stabil("model_server"))
    assert(ss.er_stabil("multiprocessing"))
    assert(ss.er_stabil("wsgiref"))
    assert(ss.er_stabil("media_neural"))
    assert_eq(ss.status_for("manglar"), "ukjent")

    skriv("test_stdlib_status_matrix OK")
    returner 0
}

bruk selfhost.common som sh

funksjon ingen_swap(expr: tekst) -> bool {
    la disasm: tekst = sh.disasm_uttrykk(expr)
    returner ikkje tekst_inneholder(disasm, "SWAP")
}

funksjon start() -> heltall {
    # Unary NOT + AND
    assert(ingen_swap("ikkje 1 og 0"))

    # Unary NOT + OR
    assert(ingen_swap("ikkje 1 eller 0"))

    # Nested boolean expressions
    assert(ingen_swap("(1 og 0) eller 1"))
    assert(ingen_swap("1 og (0 eller 1)"))

    # Comparison + boolean
    assert(ingen_swap("1 mindre_enn 2 og 1"))

    # Double unary
    assert(ingen_swap("ikkje ikkje 1"))

    returner 0
}

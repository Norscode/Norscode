bruk std.tekst som t

funksjon start() -> heiltall {
    assert(fil_finnes("tools/local_green.no"))
    assert(fil_finnes("tools/local_green.sh"))

    la src = fil_les("tools/local_green.no")
    assert(t.inneholder(src, "samla lokal grønnliste utan publisering"))
    assert(t.inneholder(src, "NORSCODE_ROOT"))
    assert(t.inneholder(src, "funksjon strict_mode()"))
    assert(t.inneholder(src, "NORSCODE_LOCAL_GREEN_STRICT"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "./bin/nc release-preflight"))
    assert(t.inneholder(src, "./bin/nc release-preflight --strict"))
    assert(t.inneholder(src, "Køyrer release-preflight, aktiv flate"))
    assert(t.inneholder(src, "fase-0, L1-L6-sjølvstendighet og full testflate lokalt."))
    assert(t.inneholder(src, "1. Streng release-preflight"))
    assert(t.inneholder(src, "Køyrer streng release-preflight, aktiv flate"))
    assert(t.inneholder(src, "./bin/nc active-surface"))
    assert(t.inneholder(src, "./bin/nc phase0-verify"))
    assert(t.inneholder(src, "./bin/nc selvstendighet"))
    assert(t.inneholder(src, "4. Sjølvstendighet L1-L6"))
    assert(t.inneholder(src, "./bin/nc test"))
    assert(t.inneholder(src, "funksjon steg1_label()"))
    assert(t.inneholder(src, "funksjon steg5_cmd()"))
    assert(t.inneholder(src, "funksjon list_steps()"))
    assert(t.inneholder(src, "steg1_label() + \": \" + steg1_cmd()"))
    assert(t.inneholder(src, "steg5_label() + \": \" + steg5_cmd()"))
    assert(t.inneholder(src, "funksjon show_help()"))
    assert(t.inneholder(src, "NORSCODE_LOCAL_GREEN_LIST"))
    assert(t.inneholder(src, "NORSCODE_LOCAL_GREEN_HELP"))
    assert(t.inneholder(src, "returner list_steps()"))
    assert(t.inneholder(src, "returner show_help()"))
    assert(t.inneholder(src, "bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]"))
    assert(t.inneholder(src, "Køyrer lokal grønnliste utan publisering."))
    assert(t.inneholder(src, "Bruk --strict for å køyre streng release-preflight som fyrste steg."))
    assert(t.inneholder(src, "Bruk --list for å vise stega med kommandoar utan å køyre dei."))
    assert(t.inneholder(src, "Bruk --strict --list eller --strict -l for å vise streng grønnliste med kommandoar utan køyring."))
    assert(t.inneholder(src, "run_step(root, steg1_label(), steg1_cmd())"))
    assert(t.inneholder(src, "run_step(root, steg5_label(), steg5_cmd())"))
    assert(t.inneholder(src, "Lokal grønnliste: BESTÅTT"))
    assert(ikkje t.inneholder(src, "Koyrer"))
    assert(ikkje t.inneholder(src, "Køyrer release, aktiv flate"))
    assert(ikkje t.inneholder(src, "Køyrer strict release"))
    assert(ikkje t.inneholder(src, "fase-0, sjølvstendighet og full test lokalt."))
    assert(ikkje t.inneholder(src, "fase-0, selvstendighet og full test lokalt."))
    assert(ikkje t.inneholder(src, "4. Selvstendighet L1-L6"))
    assert(ikkje t.inneholder(src, "Lokal gronnliste: BESTATT"))

    la cli = fil_les("bin/nc")
    assert(t.inneholder(cli, "local-green|gronnliste)"))
    assert(t.inneholder(cli, "tools/local_green.no"))
    assert(t.inneholder(cli, "NORSCODE_LOCAL_GREEN_LIST=1"))
    assert(t.inneholder(cli, "NORSCODE_LOCAL_GREEN_HELP=1"))
    assert(t.inneholder(cli, "NORSCODE_LOCAL_GREEN_STRICT=\"$_local_green_strict\""))
    assert(t.inneholder(cli, "_local_green_strict=0"))
    assert(t.inneholder(cli, "_local_green_mode=\"run\""))
    assert(t.inneholder(cli, "if [ \"$_local_green_mode\" != \"run\" ]; then"))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/local_green.sh\" --strict --list"))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/local_green.sh\" --list"))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/local_green.sh\" --strict --help"))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/local_green.sh\" --help"))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/local_green.sh\" --strict"))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/local_green.sh\""))
    assert(t.inneholder(cli, "_nc_has_exec_prosess_gap \"$_local_green_out\""))
    assert(t.inneholder(cli, "_nc_print_file \"$_local_green_out\""))
    assert(t.inneholder(cli, "_local_green_cleanup() {"))
    assert(t.inneholder(cli, "trap _local_green_cleanup EXIT"))
    assert(t.inneholder(cli, "trap '_local_green_cleanup; exit 129' HUP"))
    assert(t.inneholder(cli, "trap '_local_green_cleanup; exit 130' INT"))
    assert(t.inneholder(cli, "trap '_local_green_cleanup; exit 143' TERM"))
    assert(ikkje t.inneholder(cli, "grep -Eq 'Ukjent funksjon: builtin"))
    assert(ikkje t.inneholder(cli, "cat \"$_local_green_out\""))
    assert(ikkje t.inneholder(cli, "exec sh \"$ROOT_DIR/tools/local_green.sh\""))
    assert(ikkje t.inneholder(cli, "printf 'local-green steg (ingen køyring):\\n'"))
    assert(ikkje t.inneholder(cli, "printf 'Køyrer lokal grønnliste utan publisering.\\n'"))
    assert(t.inneholder(cli, "norscode_local_green_list_$$.log"))
    assert(t.inneholder(cli, "norscode_local_green_help_$$.log"))
    assert(t.inneholder(cli, "ukjent local-green-val"))
    assert(t.inneholder(cli, "for mange local-green-val"))

    la wrapper = fil_les("tools/local_green.sh")
    assert(t.inneholder(wrapper, "tools/local_green.no"))
    assert(t.inneholder(wrapper, "Norscode-first wrapper: samla lokal grønnliste ligg i tools/local_green.no."))
    assert(t.inneholder(wrapper, "Shell-delen under er berre avgrensa reserveveg når runtime manglar exec_prosess."))
    assert(ikkje t.inneholder(wrapper, "Tynn wrapper: samla lokal grønnliste"))
    assert(t.inneholder(wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=1"))
    assert(t.inneholder(wrapper, "NORSCODE_LOCAL_GREEN_LIST=1"))
    assert(t.inneholder(wrapper, "NORSCODE_LOCAL_GREEN_HELP=1"))
    assert(t.inneholder(wrapper, "NORSCODE_LOCAL_GREEN_STRICT=\"$STRICT\""))
    assert(t.inneholder(wrapper, "cleanup() {"))
    assert(t.inneholder(wrapper, "print_file() {"))
    assert(t.inneholder(wrapper, "has_exec_gap() {"))
    assert(ikkje t.inneholder(wrapper, "cat \"$OUT\""))
    assert(ikkje t.inneholder(wrapper, "grep -Eq 'Ukjent funksjon: builtin"))
    assert(t.inneholder(wrapper, "trap cleanup EXIT"))
    assert(t.inneholder(wrapper, "trap 'cleanup; exit 129' HUP"))
    assert(t.inneholder(wrapper, "trap 'cleanup; exit 130' INT"))
    assert(t.inneholder(wrapper, "trap 'cleanup; exit 143' TERM"))
    assert(t.inneholder(wrapper, "Ukjent funksjon: builtin"))
    assert(t.inneholder(wrapper, "$ROOT/bin/nc"))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" release-preflight"))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" release-preflight --strict"))
    assert(t.inneholder(wrapper, "Køyrer release-preflight, aktiv flate"))
    assert(t.inneholder(wrapper, "fase-0, L1-L6-sjølvstendighet og full testflate lokalt."))
    assert(t.inneholder(wrapper, "=== 1. Streng release-preflight ==="))
    assert(t.inneholder(wrapper, "Køyrer streng release-preflight, aktiv flate"))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" active-surface"))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" phase0-verify"))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" selvstendighet"))
    assert(t.inneholder(wrapper, "=== 4. Sjølvstendighet L1-L6 ==="))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" test"))
    assert(t.inneholder(wrapper, "--list|-l)"))
    assert(t.inneholder(wrapper, "local-green steg (ingen køyring)"))
    assert(t.inneholder(wrapper, "1. Streng release-preflight: ./bin/nc release-preflight --strict"))
    assert(t.inneholder(wrapper, "2. Aktiv C/Python-fri flate: ./bin/nc active-surface"))
    assert(t.inneholder(wrapper, "4. Sjølvstendighet L1-L6: ./bin/nc selvstendighet"))
    assert(t.inneholder(wrapper, "5. Full testflate: ./bin/nc test"))
    assert(t.inneholder(wrapper, "--help|-h)"))
    assert(t.inneholder(wrapper, "usage() {"))
    assert(t.inneholder(wrapper, "bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]"))
    assert(t.inneholder(wrapper, "Bruk --list for å vise stega med kommandoar utan å køyre dei."))
    assert(t.inneholder(wrapper, "Bruk --strict --list eller --strict -l for å vise streng grønnliste med kommandoar utan køyring."))
    assert(t.inneholder(wrapper, "usage >&2"))
    assert(t.inneholder(wrapper, "Lokal grønnliste: BESTÅTT"))
    assert(ikkje t.inneholder(wrapper, "Koyrer"))
    assert(ikkje t.inneholder(wrapper, "Køyrer release, aktiv flate"))
    assert(ikkje t.inneholder(wrapper, "Køyrer strict release"))
    assert(ikkje t.inneholder(wrapper, "fase-0, sjølvstendighet og full test lokalt."))
    assert(ikkje t.inneholder(wrapper, "fase-0, selvstendighet og full test lokalt."))
    assert(ikkje t.inneholder(wrapper, "=== 4. Selvstendighet L1-L6 ==="))
    assert(ikkje t.inneholder(wrapper, "Lokal gronnliste: BESTATT"))
    assert(t.inneholder(wrapper, "ukjent local-green-val"))
    assert(t.inneholder(wrapper, "for mange local-green-val"))
    assert(t.inneholder(wrapper, "if [ \"$MODE\" != \"run\" ]; then"))
    assert(t.inneholder(wrapper, "exit 2"))

    la readme = fil_les("README.md")
    assert(t.inneholder(readme, "./bin/nc local-green"))
    assert(t.inneholder(readme, "fase-0, L1-L6-sjølvstendighet og full testflate utan å publisere"))
    assert(ikkje t.inneholder(readme, "fase-0, sjølvstendighet og full test utan å publisere"))
    assert(t.inneholder(readme, "./bin/nc local-green --strict"))
    assert(t.inneholder(readme, "./bin/nc local-green --strict --list"))
    assert(t.inneholder(readme, "./bin/nc local-green --strict -l"))
    assert(t.inneholder(readme, "./bin/nc local-green --list"))
    assert(t.inneholder(readme, "./bin/nc local-green -l"))
    assert(t.inneholder(readme, "./bin/nc local-green --help"))
    assert(t.inneholder(readme, "./bin/nc local-green -h"))
    assert(t.inneholder(readme, "samla lokal grønnliste"))
    assert(t.inneholder(readme, "release-preflight, aktiv flate, fase-0, L1-L6-sjølvstendighet og full testflate"))
    assert(ikkje t.inneholder(readme, "release-preflight, aktiv flate, fase-0, L1-L6 og full testflate"))
    assert(ikkje t.inneholder(readme, "utvikling, test, releasepakke og selfhost-gater"))

    la manual = fil_les("docs/USER_MANUAL.md")
    assert(t.inneholder(manual, "./bin/nc local-green"))
    assert(t.inneholder(manual, "./bin/nc local-green --strict"))
    assert(t.inneholder(manual, "./bin/nc local-green --strict --list"))
    assert(t.inneholder(manual, "./bin/nc local-green --strict -l"))
    assert(t.inneholder(manual, "./bin/nc local-green --list"))
    assert(t.inneholder(manual, "./bin/nc local-green -l"))
    assert(t.inneholder(manual, "./bin/nc local-green --help"))
    assert(t.inneholder(manual, "./bin/nc local-green -h"))
    assert(t.inneholder(manual, "samla lokal grønnliste"))
    assert(t.inneholder(manual, "release-preflight, aktiv flate, fase-0, L1-L6-sjølvstendighet og full testflate"))

    la lane = fil_les("docs/LANE_MAP.md")
    assert(t.inneholder(lane, "./bin/nc local-green"))
    assert(t.inneholder(lane, "./bin/nc local-green --strict"))

    la gates = fil_les("docs/05-development/SELFHOST_CI_GATES.md")
    assert(t.inneholder(gates, "./bin/nc local-green"))
    assert(t.inneholder(gates, "./bin/nc local-green --strict"))
    assert(t.inneholder(gates, "publiserer ingenting"))

    la status = fil_les("docs/STATUS.md")
    assert(t.inneholder(status, "./bin/nc local-green"))
    assert(t.inneholder(status, "./bin/nc local-green --strict"))
    assert(t.inneholder(status, "release-preflight, aktiv flate, fase-0, L1-L6-sjølvstendighet og full testflate"))
    assert(t.inneholder(status, "L1-L6-sjølvstendighet og full testflate må bevisast saman"))
    assert(ikkje t.inneholder(status, "fase-0, L1-L6 og full test"))

    skriv("test_local_green OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/probe_macos_native_rebuild_v722.no")

    assert(t.inneholder(src, "funksjon vis_strings_treff(sti: tekst, needle: tekst, maks: heiltall) -> heiltall"))
    assert(t.inneholder(src, "funksjon vis_kildetreff(mapper: tekst, needles: liste_tekst, maks: heiltall) -> heiltall"))
    assert(t.inneholder(src, "funksjon søkefiler(mapper: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "find \" + shell(mappe) + \" -type f -print"))
    assert(t.inneholder(src, "ikkje har_fil(filer, fil)"))
    assert(t.inneholder(src, "vis_kildetreff(\"selfhost tools bootstrap src\", mach_ord, 200)"))
    assert(t.inneholder(src, "vis_kildetreff(\"selfhost tools bootstrap src\", elf_ord, 200)"))
    assert(t.inneholder(src, "når Mach-O-generator manglar"))
    assert(ikkje t.inneholder(src, "kan macOS stage0 ikke bygges lokalt ennå"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(src, "| grep -n 'random_hex'"))
    assert(ikkje t.inneholder(src, "/usr/bin/grep -R -n"))
    assert(ikkje t.inneholder(src, "find \" + mapper"))
    assert(ikkje t.inneholder(src, "| head -20"))
    assert(ikkje t.inneholder(src, "| head -200"))

    skriv("test_probe_macos_native_rebuild_no_grep_head OK")
    returner 0
}

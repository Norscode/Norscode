bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/symbol_table_serializer.no")
    la wrapper = fil_les("tools/symbol_table_serializer.sh")

    assert(t.inneholder(src, "funksjon deterministiske_linjer"))
    assert(t.inneholder(src, "liste.sorter_tekst"))
    assert(t.inneholder(src, "builtin.fil_les"))
    assert(t.inneholder(src, "builtin.fil_skriv"))
    assert(t.inneholder(src, "funksjon enkel_hash"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "NORSCODE_SYMBOL_INPUT=<input_symbols> NORSCODE_SYMBOL_OUTPUT=<output_symbols> ./bin/nc run tools/symbol_table_serializer.no"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "exec_prosess"))
    assert(ikkje t.inneholder(src, "symbol_table_serializer.sh <"))
    assert(ikkje t.inneholder(src, "sed "))
    assert(ikkje t.inneholder(src, "awk"))
    assert(t.inneholder(wrapper, "NORSCODE_SYMBOL_INPUT=<input_symbols> NORSCODE_SYMBOL_OUTPUT=<output_symbols> ./bin/nc run tools/symbol_table_serializer.no"))
    assert(ikkje t.inneholder(wrapper, "Usage: symbol_table_serializer.sh"))
    assert(ikkje t.inneholder(wrapper, "symbol_table_serializer.sh <"))
    assert(t.inneholder(wrapper, "mkdir -p"))

    skriv("test_symbol_table_serializer_no_shell OK")
    returner 0
}

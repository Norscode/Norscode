bruk std.ai som ai
bruk std.tekst som t

funksjon start() -> heiltall {
    la modell = ai.lokal("norscode-local-1")
    assert_eq(modell["provider"], "local")
    assert_eq(modell["network"], "disabled")

    la svar = ai.chat(modell, "Du er hjelpsam", "Hei")
    assert_eq(svar["ok"], "sann")
    assert(t.inneholder(svar["text"], "norscode-local-1"))
    assert(t.inneholder(svar["text"], "Hei"))

    la meldinger = [
        ai.system("Svar kort"),
        ai.bruker("Lag ein plan")
    ]
    la svar2 = ai.chat_meldinger(modell, meldinger)
    assert(t.inneholder(svar2["text"], "Lag ein plan"))

    la emb = ai.embedding("abcd")
    assert_eq(tekst(emb["dims"]), tekst(4))
    assert_eq(tekst(emb["input_length"]), tekst(4))
    assert(t.inneholder(emb["vector"], ","))

    la trygg = ai.moderer("vanleg tekst")
    assert_eq(trygg["safe"], "sann")
    la blokkert = ai.moderer("password=hemmelig")
    assert_eq(blokkert["safe"], "usann")
    assert_eq(blokkert["category"], "secret")

    la plan = ai.agent_plan("bruk search", [
        ai.verktøy("search", "Søk"),
        ai.verktøy("run", "Køyr")
    ])
    assert_eq(plan["tool"], "search")
    assert(t.inneholder(plan["steps"], "velg verktøy"))

    la st = ai.status()
    assert_eq(st["api"], "std.ai")
    assert_eq(st["chat"], "sann")
    assert_eq(st["embeddings"], "sann")
    assert_eq(st["agents"], "sann")

    skriv("test_ai OK")
    returner 0
}

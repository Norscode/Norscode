bruk selfhost.common som sh

funksjon disasm(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon start() -> heltall {
    # Nested AND/OR matrix
    la expr1: tekst = disasm("(1 og 0) eller (1 og 1)")
    assert_eq(
        expr1,
        "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PUSH 1\n4: PUSH 1\n5: AND\n6: OR\n7: PRINT\n8: HALT\n"
    )

    # Nested unary precedence
    la expr2: tekst = disasm("ikkje (1 eller 0) og 1")
    assert_eq(
        expr2,
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: NOT\n4: PUSH 1\n5: AND\n6: PRINT\n7: HALT\n"
    )

    # Double nested precedence
    la expr3: tekst = disasm("((1 eller 0) og (1 eller 1))")
    assert_eq(
        expr3,
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: PUSH 1\n4: PUSH 1\n5: OR\n6: AND\n7: PRINT\n8: HALT\n"
    )

    # No redundant SWAP allowed in nested boolean lowering
    assert_ne(expr1, "SWAP")
    assert_ne(expr2, "SWAP")
    assert_ne(expr3, "SWAP")

    returner 0
}

bruk std.runtime.process_abi som abi
bruk std.socket som socket

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon sandbox_spawn(executable: tekst, args: liste_tekst,
                       profile: tekst, inherit_env: boolsk) -> ordbok_tekst {
    la req = abi.request(executable, args, "", "", 5000, 65536)
    abi.sett_sandbox(req, profile, 268435456, 32, inherit_env)
    returner builtin.process_spawn_argv(req)
}

funksjon start() -> heiltall {
    la env = sandbox_spawn("/usr/bin/env", [], "no-network", usann)
    hvis heltall_fra_tekst(env["exit_code"]) != 0 { skriv("sandbox env error: " + env["stderr"] + "\n") }
    assert_eq(env["status"], "ferdig")
    assert_eq(heltall_fra_tekst(env["exit_code"]), 0)
    assert_eq(env["sandbox"], "no-network")
    la expected_backend = env("NORSCODE_EXPECT_SANDBOX_BACKEND")
    hvis expected_backend != "" { assert_eq(env["sandbox_backend"], expected_backend) }
    assert_inneholder(env["stdout"], "PATH=/usr/bin:/bin")
    assert(ikkje builtin.contains(env["stdout"], "NORSCODE_SANDBOX_SECRET"))

    la forbidden = "build/sandbox-forbidden.txt"
    prøv { builtin.fil_slett(forbidden) } fang (e) {}
    la write_blocked = sandbox_spawn("/usr/bin/touch", [forbidden], "no-write", usann)
    assert(heltall_fra_tekst(write_blocked["exit_code"]) != 0)
    hvis expected_backend != "" { assert_eq(write_blocked["sandbox_backend"], expected_backend) }
    assert(ikkje builtin.fil_finnes(forbidden))

    la listener = socket.native_lytt("127.0.0.1", 0, 4)
    assert_eq(listener["status"], "listening")
    la url = "http://127.0.0.1:" + tekst_fra_heltall(listener["port"]) + "/"
    la net_blocked = sandbox_spawn("/usr/bin/curl", ["--max-time=1", url], "no-network", usann)
    assert(heltall_fra_tekst(net_blocked["exit_code"]) != 0)
    assert_eq(socket.native_aksepter(listener)["status"], "ventende")
    assert_eq(socket.native_lukk(listener)["status"], "closed")

    la async_req = abi.async_spawn_request("/usr/bin/printf", ["sandbox-async"], "", "", 5000, 4096)
    abi.sett_sandbox(async_req, "no-network", 268435456, 32, usann)
    la child = builtin.process_operation(async_req)
    assert_eq(child["sandbox"], "no-network")
    hvis expected_backend != "" { assert_eq(child["sandbox_backend"], expected_backend) }
    la done = builtin.process_operation(abi.async_wait_request(child["handle"], 5000))
    assert_eq(done["status"], "ferdig")
    la output = builtin.process_operation(abi.async_operation("read", child["handle"]))
    assert_eq(output["stdout"], "sandbox-async")
    la child_close = builtin.process_operation(abi.async_operation("close", child["handle"]))
    assert_eq(child_close["status"], "ferdig")

    la replacement_req = abi.async_spawn_request("/usr/bin/printf", ["replacement"], "", "", 5000, 4096)
    la replacement = builtin.process_operation(replacement_req)
    la stale = builtin.process_operation(abi.async_operation("poll", "process:999:999"))
    assert_eq(stale["status"], "feil")
    la replacement_done = builtin.process_operation(abi.async_wait_request(replacement["handle"], 5000))
    assert_eq(replacement_done["status"], "ferdig")
    la replacement_close = builtin.process_operation(abi.async_operation("close", replacement["handle"]))
    assert_eq(replacement_close["status"], "ferdig")

    hvis expected_backend == "seatbelt" {
        la memory_sync_req = abi.request("/bin/sleep", ["5"], "", "", 5000, 4096)
        abi.sett_sandbox(memory_sync_req, "restricted", 1, 32, usann)
        la memory_sync = builtin.process_spawn_argv(memory_sync_req)
        assert_eq(memory_sync["status"], "feil")
        assert_eq(memory_sync["error"], "memory limit")

        la memory_req = abi.async_spawn_request("/bin/sleep", ["5"], "", "", 5000, 4096)
        abi.sett_sandbox(memory_req, "restricted", 1, 32, usann)
        la memory_child = builtin.process_operation(memory_req)
        la memory_done = builtin.process_operation(abi.async_wait_request(memory_child["handle"], 5000))
        assert_eq(memory_done["status"], "feil")
        assert_eq(memory_done["error"], "memory limit")
        assert_eq(builtin.process_operation(abi.async_operation("close", memory_child["handle"]))["status"], "feil")
    }
    skriv("test_process_os_sandbox OK")
    returner 0
}

bruk std.model_runtime som modell

funksjon start() -> heiltall {
    la m = modell.ny("demo-q8", 3)
    la l1 = modell.dense(3, 2, [2, -1, 0, 3, 1, 1], [1, -2], 1, "relu")
    assert(modell.legg_til_lag(m, l1))
    la l2 = modell.dense(2, 2, [1, 2, 3, -1], [0, 1], 2, "hard_tanh")
    assert(modell.legg_til_lag(m, l2))
    la ut = modell.kjor(m, [4, 2, 1])
    assert_eq(lengde(ut), 2)
    assert_eq(ut[0], 6)
    assert_eq(ut[1], 10)
    la inferens = modell.kjor_med_backend(m, [4, 2, 1])
    assert_eq(inferens["data"][0], ut[0])
    assert(inferens["backend"] == "metal" eller inferens["backend"] == "cpu-fallback")
    assert_eq(m["parametre"], 14)

    la sti = "build/test_model_runtime.qmodel"
    assert(modell.lagre(m, sti))
    la lasta = modell.last(sti, 100)
    la ut2 = modell.kjor(lasta, [4, 2, 1])
    assert_eq(ut2[0], ut[0])
    assert_eq(ut2[1], ut[1])
    assert(modell.valider(lasta, 100, 8))
    la batch = modell.batch_kjor(lasta, [[4, 2, 1], [1, 0, 2]], 4)
    assert_eq(lengde(batch), 2)
    assert_eq(batch[0][0], ut[0])
    assert_eq(batch[1][1], modell.kjor(lasta, [1, 0, 2])[1])
    prøv {
        modell.batch_kjor(lasta, [[4, 2, 1], [1, 0, 2]], 1)
        kast "forventa batchfeil manglar"
    } fang (e) { }
    assert_eq(lasta["navn"], "demo-q8")
    skriv("test_model_runtime OK\n")
    returner 0
}

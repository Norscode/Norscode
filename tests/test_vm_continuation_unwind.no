funksjon nederst(n: heiltall) -> heiltall {
    hvis n <= 0 { kast "continuation-feil" }
    la verdi = nederst(n - 1)
    returner verdi + 1
}

funksjon mellom() -> heiltall {
    la x = nederst(80)
    returner x * 2
}

funksjon start() -> heiltall {
    la melding = ""
    prøv {
        mellom()
    } fang (e) {
        melding = e
    }
    assert_eq(melding, "continuation-feil")
    la stack = builtin.vm_call_stack_status()
    assert_eq(stack["current"], "__main__.start")
    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["unwinds"]) > 0)
    returner 0
}

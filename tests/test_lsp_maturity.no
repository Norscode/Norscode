bruk std.tekst som t

funksjon start() -> heiltall {
    assert(fil_finnes("vscode-norscode/package.json"))
    assert(fil_finnes("vscode-norscode/syntaxes/norscode.tmLanguage.json"))
    assert(fil_finnes("vscode-norscode/language-configuration.json"))
    assert(fil_finnes("selfhost/lsp/server.no"))

    la server = fil_les("selfhost/lsp/server.no")
    assert(t.inneholder(server, "funksjon lsp_selftest"))
    assert(t.inneholder(server, "hoverProvider"))
    assert(t.inneholder(server, "completionProvider"))
    assert(t.inneholder(server, "documentSymbolProvider"))
    assert(t.inneholder(server, "documentFormattingProvider"))
    assert(t.inneholder(server, "textDocument/publishDiagnostics"))
    assert(t.inneholder(server, "textDocument/documentSymbol"))
    assert(t.inneholder(server, "textDocument/formatting"))
    assert(t.inneholder(server, "initialize,didOpen,didChange,hover,definition,completion,documentSymbol,formatting"))
    assert(t.inneholder(server, "lsp_document_symbols"))
    assert(t.inneholder(server, "lsp_format_document"))

    skriv("test_lsp_maturity OK")
    returner 0
}

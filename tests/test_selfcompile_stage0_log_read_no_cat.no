bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/selfcompile_stage0_elf.no")

    assert(t.inneholder(src, "funksjon les_fil_trygt(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon append_fil_trygt(sti: tekst, innhald: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon samle_chunk_output(base: tekst, ut: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon sha256_for(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon siste_liner(data: tekst, maks: heiltall) -> tekst"))
    assert(t.inneholder(src, "funksjon første_felt"))
    assert(t.inneholder(src, "returner fil_les(sti)"))
    assert(t.inneholder(src, "la out = les_fil_trygt(mode_log)"))
    assert(t.inneholder(src, "append_fil_trygt(attempts, \"mode=\" + mode + \" exit_code=\" + rc + \" log=\" + mode_log + \"\\n\")"))
    assert(t.inneholder(src, "skriv_fil_trygt(pass_marker, \"bundle-args\\n\")"))
    assert(t.inneholder(src, "siste_liner(les_fil_trygt(log_path), 80)"))
    assert(t.inneholder(src, "siste_liner(les_fil_trygt(aggregate), 120)"))
    assert(t.inneholder(src, "la gen1_sha = sha256_for(gen1_elf)"))
    assert(t.inneholder(src, "la gen1_bytes = bytes(gen1_elf)"))
    assert(t.inneholder(src, "gen1_elf_sha256"))
    assert(t.inneholder(src, "\"gen1_elf_sha256=\" + gen1_sha"))
    assert(ikkje t.inneholder(src, "la out = res_felt(kommando(\"cat \" + shell(mode_log))"))
    assert(ikkje t.inneholder(src, "; cat \" + shell(mode_log)"))
    assert(ikkje t.inneholder(src, "cat \" + shell(base) + \"/part_*.json"))
    assert(ikkje t.inneholder(src, "wc -c < \" + shell"))
    assert(ikkje t.inneholder(src, "| tr -d ' '"))
    assert(ikkje t.inneholder(src, "awk '{print $1}'"))
    assert(ikkje t.inneholder(src, "tail -n 80"))
    assert(ikkje t.inneholder(src, "tail -n 120"))
    assert(ikkje t.inneholder(src, "if test -f \" + shell"))
    assert(ikkje t.inneholder(src, "printf 'mode=%s"))
    assert(ikkje t.inneholder(src, "printf 'bundle-args"))

    skriv("test_selfcompile_stage0_log_read_no_cat OK")
    returner 0
}

bruk std.tokenizer_bpe som bpe
bruk std.tokenizer som tokenizer

funksjon start() -> heiltall {
    la trenar = bpe.ny_trenar(12, 2, 100000)
    la t = bpe.tren(trenar, ["abab abab", "abab"], "<?>" , "<B>", "<E>", 100)
    la kodar = tokenizer.kod(t, "abab", usann, usann)
    assert(lengde(kodar) < 4)
    assert_eq(tokenizer.dekod(t, kodar, sann), "abab")
    assert(lengde(trenar["samanslaingar"]) >= 1)

    la raw = bpe.serialiser(t)
    la t2 = bpe.deserialiser(raw, 100)
    assert_eq(tokenizer.dekod(t2, tokenizer.kod(t2, "abab abab", usann, usann), sann), "abab abab")
    assert_eq(tokenizer.storleik(t), tokenizer.storleik(t2))
    la sti = "build/test_tokenizer_bpe.ntok"
    assert(bpe.lagre(t, sti))
    la t3 = bpe.last(sti, 100)
    assert_eq(tokenizer.dekod(t3, tokenizer.kod(t3, "abab", usann, usann), sann), "abab")
    skriv("test_tokenizer_bpe OK\n")
    returner 0
}

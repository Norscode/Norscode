bruk selfhost.native_execution.macho_arm64_emitter som macho

funksjon start() -> heiltall {
    la bytes = macho.bygg_exit(7)
    assert(lengde(bytes) > 4096)
    assert_eq(bytes[0], 0xCF)
    assert_eq(bytes[1], 0xFA)
    assert_eq(bytes[2], 0xED)
    assert_eq(bytes[3], 0xFE)
    // CPU_TYPE_ARM64 og MH_EXECUTE.
    assert_eq(bytes[4], 0x0C)
    assert_eq(bytes[7], 0x01)
    assert_eq(bytes[12], 0x02)
    // Koden startar etter header og seksten load commands.
    assert_eq(bytes[696], 0xE0)
    assert_eq(bytes[697], 0x00)
    assert_eq(bytes[698], 0x80)
    assert_eq(bytes[699], 0x52)
    assert_eq(bytes[700], 0xC0)
    assert_eq(bytes[701], 0x03)
    assert_eq(bytes[702], 0x5F)
    assert_eq(bytes[703], 0xD6)

    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis os[0] == "0" og builtin.trim(os[1]) == "Darwin" og arch[0] == "0" og builtin.trim(arch[1]) == "arm64" {
        la sti = "/tmp/norscode_macho_arm64_" + builtin.random_hex(8)
        assert(macho.skriv_exit(sti, 7) > 4096)
        assert_eq(exec_prosess("chmod +x '" + sti + "'")[0], "0")
        la run = exec_prosess("'" + sti + "'")
        assert_eq(run[0], "7")
        exec_prosess("rm -f '" + sti + "'")
    }
    returner 0
}

bruk std.inspect som inspect
bruk std.timeit som timeit
bruk std.trace som trace
bruk std.tekst som t

funksjon start() -> heiltall {
    la sig = inspect.signature("demo.start", ["namn:tekst", "tal:heltall=1"])
    la formatert = inspect.format_sig(sig)
    assert(t.inneholder(formatert, "demo.start"))
    assert(t.inneholder(formatert, "namn"))
    assert(t.inneholder(formatert, "tal"))

    la span = trace.start("runtime", "trace-1", "")
    trace.event(span, "fase", "start")
    trace.slutt_ok(span)
    la logg = trace.til_logg(span)
    assert_eq(logg["status"], "ok")
    assert_eq(logg["event_count"], "1")

    la timer = timeit.ny_tidtakar()
    timeit.start(timer)
    timeit.stopp(timer)
    assert(timeit.elapsed_ms(timer) >= 0)
    assert(ikkje timeit.er_aktiv(timer))

    skriv("test_runtime_reflection_profiler OK")
    returner 0
}

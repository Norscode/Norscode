bruk selfhost.common som sh

funksjon ops(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon start() -> heltall {
    # LT + AND
    la lt_and: tekst = ops("1 mindre_enn 2 og 1")
    assert_eq(
        lt_and,
        "0: PUSH 1\n1: PUSH 2\n2: LT\n3: PUSH 1\n4: AND\n5: PRINT\n6: HALT\n"
    )

    # LT + OR
    la lt_or: tekst = ops("1 mindre_enn 2 eller 0")
    assert_eq(
        lt_or,
        "0: PUSH 1\n1: PUSH 2\n2: LT\n3: PUSH 0\n4: OR\n5: PRINT\n6: HALT\n"
    )

    # Unary NOT + comparison
    la not_lt: tekst = ops("ikkje 1 mindre_enn 2")
    assert_eq(
        not_lt,
        "0: PUSH 1\n1: PUSH 2\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n"
    )

    # Nested comparison precedence
    la nested: tekst = ops("(1 mindre_enn 2) og (2 mindre_enn 3)")
    assert_eq(
        nested,
        "0: PUSH 1\n1: PUSH 2\n2: LT\n3: PUSH 2\n4: PUSH 3\n5: LT\n6: AND\n7: PRINT\n8: HALT\n"
    )

    returner 0
}

bruk selfhost.native_execution.pe_emitter som pe
bruk selfhost.native_execution.windows_codegen som windows

funksjon start() -> heiltall {
    la image = pe.bygg_exit_pe()
    fil_skriv_binær("build/test-pe-emitter.exe", image)
    assert(pe.verifiser_pe(image))
    assert_eq(lengde(image), 1536)
    assert_eq(pe.les_u32_le(image, 60), 128)
    assert_eq(pe.les_u16_le(image, 132), 34404)
    assert_eq(pe.les_u32_le(image, 272), 8192)
    la exit_7 = windows.kompiler_instruksjoner([["PUSH_CONST", 7], ["RETURN"]])
    assert_eq(exit_7["ok"], "sann")
    assert_eq(exit_7["format"], "PE32+")
    assert(pe.verifiser_pe(exit_7["image"]))
    assert_eq(exit_7["image"][517], 7)
    fil_skriv_binær("build/test-pe-exit7.exe", exit_7["image"])
    assert_eq(windows.kompiler_instruksjoner([["PUSH_CONST", 256], ["RETURN"]])["ok"], "usann")
    assert_eq(windows.kompiler_instruksjoner([["NOP"], ["RETURN"]])["ok"], "usann")
    skriv("test_pe_emitter OK")
    returner 0
}

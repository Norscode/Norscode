bruk std.tekst som t

funksjon krev_norscode_basename(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon basename") eller t.inneholder(src, "path.basename("))
    assert(ikkje t.inneholder(src, "kommando(\"basename "))
    assert(ikkje t.inneholder(src, "basename \" + shell"))
}

funksjon krev_norscode_version_parse(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon toml_version_fra_innhald"))
    assert(t.inneholder(src, "builtin.fil_les(toml)"))
    assert(ikkje t.inneholder(src, "grep '^version'"))
    assert(ikkje t.inneholder(src, "sed 's/.*= *"))
}

funksjon start() -> heiltall {
    krev_norscode_basename("tools/nc_test.no")
    krev_norscode_basename("tools/startproject.no")
    krev_norscode_basename("tools/verify-macos-app.no")
    krev_norscode_basename("tools/install_release.no")
    krev_norscode_basename("tools/install-linux-appdir.no")
    krev_norscode_basename("tools/package-macos-app.no")

    la test_src = fil_les("tools/nc_test.no")
    assert(t.inneholder(test_src, "la delar = builtin.split(sti, \"/\")"))
    assert(t.inneholder(test_src, "funksjon fjern_suffiks"))
    assert(t.inneholder(test_src, "returner fjern_suffiks(basename(sti), \".no\")"))

    la app_src = fil_les("tools/verify-macos-app.no")
    assert(t.inneholder(app_src, "bruk std.path som path"))
    assert(t.inneholder(app_src, "funksjon fjern_suffiks"))
    assert(t.inneholder(app_src, "returner fjern_suffiks(basename(sti), \".app\")"))

    la release_src = fil_les("tools/install_release.no")
    assert(t.inneholder(release_src, "bruk std.path som path"))
    assert(t.inneholder(release_src, "returner trim_linje(fil_les(sti))"))

    la linux_src = fil_les("tools/install-linux-appdir.no")
    assert(t.inneholder(linux_src, "bruk std.path som path"))
    assert(t.inneholder(linux_src, "la expected = trim(fil_les(archive_path + \".sha256\"))"))
    assert(t.inneholder(linux_src, "la appdir_name = stage_dir + \"/\" + version_name + \".AppDir\""))

    krev_norscode_version_parse("tools/build-macos-app.no")
    krev_norscode_version_parse("tools/package-linux-app.no")
    krev_norscode_version_parse("tools/package-macos-app.no")
    krev_norscode_version_parse("tools/package-windows-app.no")

    skriv("test_basename_no_shell OK")
    returner 0
}

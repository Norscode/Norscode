bruk std.mail_server som mail

funksjon start() -> heiltall {
    la m = mail.ny("example.no", "mail.example.no")
    m["daemon_host"] = "127.0.0.1"
    m["daemon_smtp_port"] = "25250"
    m["dkim_public_key"] = "PUBLICKEY"
    assert(mail.legg_postboks(m, "postmaster", "drift"))

    la plan = mail.daemon_plan(m)
    assert_eq(plan["transport"], "native-socket")
    assert_eq(plan["bind_host"], "127.0.0.1")
    assert_eq(plan["lifecycle"], "daemon_ny -> daemon_start -> daemon_pump -> daemon_stop")

    la d = mail.daemon_ny(m)
    assert_eq(mail.daemon_status(d)["status"], "stoppet")
    m["tls_mode"] = "implicit"
    la tls_d = mail.daemon_ny(m)
    assert(ikkje mail.daemon_start(m, tls_d))
    assert_inneholder(mail.daemon_status(tls_d)["siste_feil"], "sertifikat")
    m["tls_mode"] = "starttls"
    la d = mail.daemon_ny(m)
    assert(mail.daemon_start(m, d))
    assert_eq(mail.daemon_status(d)["status"], "kjører")
    assert_eq(mail.daemon_status(d)["tls_mode"], "starttls")
    assert_eq(mail.daemon_pump(m, d)["status"], "idle")
    assert(mail.daemon_stop(d))
    assert_eq(mail.daemon_status(d)["status"], "stoppet")
    skriv("test_mail_server_daemon OK\n")
    returner 0
}

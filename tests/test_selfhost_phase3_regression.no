funksjon phase3_regression_status()
    returner {
        ast: "stabil",
        semantic: "stabil",
        ir: "dokumentert"
    }
slutt

funksjon test_phase3_regression()
    status = phase3_regression_status()
    assert_lik(status.ast, "stabil")
    assert_lik(status.semantic, "stabil")
    assert_lik(status.ir, "dokumentert")
slutt

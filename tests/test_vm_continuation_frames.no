funksjon fib(n: heiltall) -> heiltall {
    hvis n <= 1 { returner n }
    la a = fib(n - 1)
    la b = fib(n - 2)
    returner a + b
}

funksjon dobbel(x: heiltall) -> heiltall { returner x * 2 }
funksjon legg_til_tre(x: heiltall) -> heiltall { returner dobbel(x) + 3 }

funksjon summer(n: heiltall) -> heiltall {
    hvis n <= 0 { returner 0 }
    la rest = summer(n - 1)
    returner n + rest
}

funksjon start() -> heiltall {
    assert_eq(fib(12), 144)
    assert_eq(legg_til_tre(7), 17)
    assert_eq(summer(750), 281625)
    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["calls"]) > 100)
    assert(heltall_fra_tekst(metrics["max_depth"]) > 700)
    returner 0
}

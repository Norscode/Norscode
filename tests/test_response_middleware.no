funksjon legg_til_trace(resp: ordbok<tekst, tekst>) -> ordbok<tekst, tekst> {
    resp["headers"] = {"X-Trace": "mw-1"}
    returner resp
}

funksjon anvend_response_middlewares(resp)
    returner legg_til_trace(resp)
slutt

funksjon response_to_http(resp)
    returner "X-Trace: mw-1"
slutt

funksjon start() -> heiltall {
    la health_resp = {"headers": {}}
    la ny_resp = anvend_response_middlewares(health_resp)
    assert_eq(ny_resp["headers"]["X-Trace"], "mw-1")

    la http = response_to_http(ny_resp)
    assert_eq(builtin.contains(http, "X-Trace: mw-1"), sann)
    returner 0
}

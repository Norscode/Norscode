bruk std.runtime_memory som memory
bruk std.runtime.native_gc som native_gc
bruk std.runtime.allocator som allocator

funksjon start() -> heiltall {
    la heap = memory.ny_heap()
    la a = memory.alloker(heap, "liste", 8)
    la b = memory.alloker(heap, "kart", 8)
    la c = memory.alloker(heap, "tekst", 8)
    assert(memory.legg_ref(heap, a, b))
    assert(memory.legg_ref(heap, b, a))

    la aa = memory.objekt_adresse(heap, a)
    la ba = memory.objekt_adresse(heap, b)
    la ca = memory.objekt_adresse(heap, c)
    la arena = heap["allocator"]
    la ah = native_gc.header_info(arena, aa)
    assert_eq(ah["ref_count"], "1")
    assert(heltall_fra_tekst(ah["first_edge"]) > 0)
    la edge = native_gc.edge_info(arena, heltall_fra_tekst(ah["first_edge"]))
    assert_eq(edge["valid"], "sann")
    assert_eq(edge["from"], tekst_fra_heltall(aa))
    assert_eq(edge["to"], tekst_fra_heltall(ba))

    la marked = native_gc.mark_fra_roter(arena, [aa])
    assert_eq(marked["marked"], "2")
    assert(native_gc.er_markert(arena, aa))
    assert(native_gc.er_markert(arena, ba))
    assert(ikkje native_gc.er_markert(arena, ca))

    assert(memory.legg_rot(heap, a))
    memory.collect(heap)
    memory.compact(heap)
    aa = memory.objekt_adresse(heap, a)
    ba = memory.objekt_adresse(heap, b)
    arena = heap["allocator"]
    la after = native_gc.mark_fra_roter(arena, [aa])
    assert_eq(after["marked"], "2")
    la moved_edge = native_gc.edge_info(arena, heltall_fra_tekst(native_gc.header_info(arena, aa)["first_edge"]))
    assert_eq(moved_edge["from"], tekst_fra_heltall(aa))
    assert_eq(moved_edge["to"], tekst_fra_heltall(ba))

    assert(memory.fjern_ref(heap, a, b))
    la detached = native_gc.mark_fra_roter(arena, [aa])
    assert_eq(detached["marked"], "1")
    assert(ikkje native_gc.er_markert(arena, ba))
    assert_eq(native_gc.header_info(arena, aa)["ref_count"], "0")

    la heap2 = memory.ny_heap()
    la live_a = memory.alloker(heap2, "liste", 4)
    la live_b = memory.alloker(heap2, "kart", 4)
    la dead = memory.alloker(heap2, "liste", 4)
    assert(memory.legg_ref(heap2, live_a, live_b))
    assert(memory.legg_ref(heap2, dead, dead))
    la live_a_addr = memory.objekt_adresse(heap2, live_a)
    la live_b_addr = memory.objekt_adresse(heap2, live_b)
    la dead_addr = memory.objekt_adresse(heap2, dead)
    la arena2 = heap2["allocator"]
    la lock2 = heap2["allocator_lock"]
    assert(allocator.allocator_lock(lock2, "mutator"))
    la blocked = native_gc.collect_native_locked(arena2, lock2, "collector", [live_a_addr])
    assert_eq(blocked["status"], "opptatt")
    assert(allocator.aktiv(arena2, dead_addr))
    assert(ikkje native_gc.er_markert(arena2, live_a_addr))
    assert(allocator.allocator_unlock(lock2, "mutator"))
    la collected = native_gc.collect_native_locked(arena2, lock2, "collector", [live_a_addr])
    assert_eq(collected["status"], "ferdig")
    assert_eq(collected["marked"], "2")
    assert_eq(collected["survivors"], "2")
    assert_eq(collected["freed_objects"], "1")
    assert_eq(collected["freed_edges"], "1")
    assert(allocator.aktiv(arena2, live_a_addr))
    assert(allocator.aktiv(arena2, live_b_addr))
    assert(ikkje allocator.aktiv(arena2, dead_addr))
    assert(ikkje native_gc.er_markert(arena2, live_a_addr))
    assert_eq(lock2["owner"], "")
    returner 0
}

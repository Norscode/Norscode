bruk std.runtime_gui som gui
bruk std.tekst som t

funksjon opprett_ticket(args: ordbok_tekst) -> tekst { returner "ok:" + args["payload"] }

funksjon start() -> heiltall {
    la app = gui.ny_app("helpdesk")
    assert(gui.legg_vindu(app, "main", "Norscode Helpdesk", 1280, 800))
    assert(gui.legg_komponent(app, "main", "ny_ticket", "knapp", "Ny ticket"))
    assert(gui.legg_komponent(app, "main", "sok", "tekstfelt", ""))
    assert(gui.bind_event(app, "ny_ticket", "click", "__main__.opprett_ticket"))
    assert(gui.sett_layout(app, "main", "vertical", 10, 20))
    assert(gui.sett_storleik(app, "ny_ticket", 240, 48))
    assert(gui.fokus(app, "sok"))

    la plan = gui.render_plan(app)
    assert_eq(plan["status"], "klar")
    assert_eq(plan["windows"], "1")
    assert_eq(plan["components"], "2")
    assert_eq(plan["events"], "1")
    assert_eq(plan["native_required"], "usann")
    assert_eq(plan["backend"], "norscode-html-headless")

    la layout = gui.layout(app, "main")
    assert_eq(layout["ok"], "sann")
    assert_eq(layout["count"], "2")
    assert_eq(app["gui.ny_ticket.x"], "20")
    assert_eq(app["gui.ny_ticket.y"], "20")
    assert_eq(app["gui.sok.y"], "78")

    la html = gui.render_html(app, "main")
    assert(t.inneholder(html, "<!doctype html>"))
    assert(t.inneholder(html, "<button"))
    assert(t.inneholder(html, "Ny ticket"))
    assert(t.inneholder(html, "<input"))

    la a11y = gui.accessibility_tree(app, "main")
    assert_eq(lengde(a11y), 2)
    assert_eq(a11y[1]["focused"], "sann")

    assert(gui.send_event(app, "ny_ticket", "click", "ticket-1"))
    assert_eq(gui.event_loop(app, 10), 1)
    assert_eq(app["queue_count"], "0")
    assert_eq(app["last_error"], "")

    assert(ikkje gui.legg_komponent(app, "main", "bad", "ukjent", ""))

    la status = gui.produksjonsstatus()
    assert_eq(status["status"], "stabil")
    assert(t.inneholder(status["dekning"], "vindu"))
    assert_eq(status["mangler"], "")

    skriv("test_runtime_gui OK")
    returner 0
}

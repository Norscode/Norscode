bruk std.web som web
bruk std.tekst som t

funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /hjem")
    returner web.response_builder(200, {"content-type": "text/plain"}, "hei")
}

funksjon start() -> heltall {
    la get_respons = web.handle_request(web.request_context("get", "/hjem", {}, {}, ""))
    assert_eq(web.response_status(get_respons), 200)
    assert_eq(web.response_body(get_respons), "hei")

    la feil_metode = web.handle_request(web.request_context("post", "/hjem", {}, {}, ""))
    assert(web.response_status(feil_metode) != 200)

    skriv("test_web_methods OK")
    returner 0
}

bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_only_if_alias: tekst = sh.disasm_skript("returner 1 only_if 0")
    assert_eq(script_only_if_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_kun_hvis_alias: tekst = sh.disasm_skript("returner 1 kun_hvis 0")

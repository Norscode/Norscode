    assert_eq(script_english_cmp_eq_alias, "0: PUSH 4\n1: PUSH 4\n2: EQ\n3: PRINT\n4: HALT\n")

    la script_english_on_off_alias: tekst = sh.disasm_skript("let x=on;return x and not off")
    assert_eq(script_english_on_off_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    returner 0

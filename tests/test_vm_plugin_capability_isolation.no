funksjon start() -> heiltall {
    la pure_vm: boolsk = usann
    prøv {
        builtin.vm_memory_status()
        pure_vm = sann
    } fang (e) {
    }
    hvis ikkje pure_vm {
        skriv("test_vm_plugin_capability_isolation OK")
        returner 0
    }

    builtin.vm_module_load("build/vm_plugin_disk.ncb.json", "isolert", "")
    la nekt: tekst = ""
    prøv {
        builtin.ncb_call_fn("isolert.les_root")
        returner 1
    } fang (e) {
        nekt = e
    }
    hvis lengde(nekt) == 0 { returner 2 }

    builtin.vm_module_reload("build/vm_plugin_disk.ncb.json", "isolert", "disk.read")
    hvis builtin.ncb_call_fn("isolert.les_root") <= 0 { returner 3 }

    skriv("test_vm_plugin_capability_isolation OK")
    returner 0
}

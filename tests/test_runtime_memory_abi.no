bruk std.runtime.memory_abi som abi
bruk selfhost.native_execution.native_codegen_v2 som native_codegen
bruk std.runtime_memory som minne
bruk std.runtime.allocator som allocator
bruk std.runtime.native_gc som native_gc

funksjon start() -> heiltall {
    assert_eq(abi.versjon(), "norscode-memory-abi-v1")
    assert_eq(abi.heap_base(), 6291456)
    assert_eq(abi.heap_size(), 67108864)
    assert_eq(abi.cursor_offset(), 0)
    assert_eq(abi.envp_offset(), 8)
    assert_eq(abi.control_bytes(), 64)
    assert_eq(native_codegen.HEAP_VA(), abi.heap_base())
    assert_eq(native_codegen.HEAP_SZ(), 268435456)
    assert(native_codegen.HEAP_SZ() >= abi.heap_size())
    assert_eq(native_codegen.HEAP_CONTROLSZ(), abi.control_bytes())
    assert_eq(native_codegen.GC_SAFEPOINT_OFFSET(), abi.gc_safepoint_count_offset())
    assert_eq(native_codegen.ENVP_OFFSET(), abi.envp_offset())
    assert_eq(abi.gc_alloc_count_offset(), 16)
    assert_eq(abi.gc_threshold_offset(), 24)
    assert_eq(abi.gc_safepoint_count_offset(), 32)
    assert_eq(abi.gc_collection_count_offset(), 40)
    assert_eq(abi.gc_root_stack_offset(), 48)
    assert_eq(abi.object_header_bytes(), 32)
    assert_eq(abi.header_first_edge_offset(), 16)
    assert_eq(abi.header_ref_count_offset(), 24)
    assert_eq(abi.payload_base(), 6291520)
    assert_eq(abi.heap_limit(), 73400320)
    assert(abi.gyldig_payload_adresse(abi.payload_base(), 1))
    assert(ikkje abi.gyldig_payload_adresse(abi.heap_base(), 1))
    assert(ikkje abi.gyldig_payload_adresse(abi.heap_limit(), 1))

    la heap = minne.ny_heap()
    assert_eq(heap["memory_abi"], abi.versjon())
    la arena = heap["allocator"]
    assert_eq(heltall_fra_tekst(arena["base"]), abi.payload_base())
    assert_eq(heltall_fra_tekst(arena["limit"]), abi.heap_limit())

    la id = minne.alloker(heap, "abi-probe", 4)
    la adresse = minne.objekt_adresse(heap, id)
    assert_eq(adresse, abi.payload_base())
    assert(abi.gyldig_payload_adresse(adresse, abi.object_header_bytes() + 4))
    assert(minne.objekt_skriv_byte(heap, id, 0, 171))
    assert_eq(minne.objekt_les_byte(heap, id, 0), 171)
    assert_eq(allocator.les_byte(arena, adresse + abi.object_header_bytes()), 171)
    assert_eq(allocator.les_byte(arena, adresse), abi.header_magic_0())
    assert_eq(allocator.les_byte(arena, adresse + 1), abi.header_magic_1())
    assert_eq(allocator.les_byte(arena, adresse + 2), abi.header_magic_2())
    assert_eq(allocator.les_byte(arena, adresse + 3), abi.header_magic_3())
    assert_eq(allocator.les_byte(arena, adresse + abi.header_flags_offset()), abi.flag_active())
    assert_eq(allocator.les_byte(arena, adresse + abi.header_generation_offset()), 0)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_age_offset()), 0)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_size_offset()), 4)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_first_edge_offset()), 0)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_ref_count_offset()), 0)

    assert(minne.legg_rot(heap, id))
    minne.collect_minor(heap)
    minne.collect_minor(heap)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_generation_offset()), 1)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_age_offset()), 2)
    assert_eq(allocator.les_byte(arena, adresse + abi.header_flags_offset()), abi.flag_active())

    la heap2 = minne.ny_heap()
    la død = minne.alloker(heap2, "tekst", 8)
    la levande = minne.alloker(heap2, "liste", 8)
    la gammel = minne.objekt_adresse(heap2, levande)
    assert(minne.objekt_skriv_byte(heap2, levande, 0, 99))
    assert(minne.legg_rot(heap2, levande))
    minne.collect(heap2)
    minne.compact(heap2)
    la ny = minne.objekt_adresse(heap2, levande)
    assert(ny < gammel)
    assert_eq(allocator.les_byte(heap2["allocator"], ny), abi.header_magic_0())
    assert_eq(allocator.les_byte(heap2["allocator"], ny + abi.header_type_offset()), 2)
    assert_eq(allocator.les_byte(heap2["allocator"], ny + abi.header_size_offset()), 8)
    assert_eq(minne.objekt_les_byte(heap2, levande, 0), 99)
    la skanna = native_gc.scan_compact_arena(heap2["allocator"])
    assert_eq(lengde(skanna), 1)
    assert_eq(skanna[0], ny)
    la info = native_gc.header_info(heap2["allocator"], ny)
    assert_eq(info["valid"], "sann")
    assert_eq(info["type"], "2")
    assert_eq(info["payload_size"], "8")
    assert_eq(info["first_edge"], "0")
    assert_eq(info["ref_count"], "0")
    assert(native_gc.sett_mark(heap2["allocator"], ny, sann))
    assert(native_gc.er_markert(heap2["allocator"], ny))
    assert(native_gc.sett_mark(heap2["allocator"], ny, usann))
    assert(ikkje native_gc.er_markert(heap2["allocator"], ny))
    returner 0
}

bruk std.tekst som t

funksjon krev_utan_personleg_sti(sti: tekst) -> heiltall {
    la src = fil_les(sti)
    assert(t.inneholder(src, "/Users/jansteinar") == usann)
    assert(t.inneholder(src, "/private/tmp/norscode-polish") == usann)
    returner 0
}

funksjon start() -> heiltall {
    krev_utan_personleg_sti("docs/USER_MANUAL.md")
    krev_utan_personleg_sti("tools/compile_with_hybrid_bundle_v9400.no")
    krev_utan_personleg_sti("tools/bundle_with_hybrid_compiler_v9500.no")
    krev_utan_personleg_sti("tools/compile_with_hybrid_bundle_v9400.sh")
    krev_utan_personleg_sti("tools/bundle_with_hybrid_compiler_v9500.sh")

    skriv("test_no_personal_paths_in_active_surface OK")
    returner 0
}

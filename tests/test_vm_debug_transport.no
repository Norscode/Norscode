bruk selfhost.vm
bruk selfhost.runtime_debug_transport som transport
bruk selfhost.runtime_debug_client som client

funksjon functions_for_test() {
    returner {
        "__main__.parent": {
            "params": [],
            "code": [["PUSH_CONST", 41], ["CALL", "__main__.child", 1], ["PUSH_CONST", 0], ["BINARY_ADD"], ["RETURN"]],
            "source_lines": [10, 10, 11, 11, 12],
            "source_columns": [5, 5, 5, 5, 5]
        },
        "__main__.child": {
            "params": ["x"],
            "code": [["LOAD_NAME", "x"], ["PUSH_CONST", 1], ["BINARY_ADD"], ["RETURN"]],
            "source_lines": [20, 20, 20, 20],
            "source_columns": [9, 13, 11, 5]
        }
    }
}

funksjon start() -> heiltall {
    la root = "build"
    la token = "0123456789abcdef0123456789abcdef"
    la t = transport.ny_transport(root, token)
    assert_eq(t["status"], "ready")
    la c = client.ny_client(root, token)
    assert_eq(c["status"], "ready")

    la functions = functions_for_test()
    vm_runtime_init(functions, sann)
    assert(vm_debug_breakpoint_add(functions, "__main__.child", 0))
    builtin.fil_skriv(t["command_path"], "")
    assert_eq(client.overvåk(c, "x"), 1)
    assert_eq(client.fortsett_kjoring(c), 2)
    assert_eq(transport.køyr(functions, "__main__.parent", [], t, 100), 42)
    assert_eq(t["last_sequence"], "2")
    la events = client.event_logg(c)
    assert_inneholder(events, "\"kind\":\"paused\"")
    assert_inneholder(events, "\"kind\":\"completed\"")

    vm_runtime_init(functions, sann)
    assert(vm_debug_breakpoint_add(functions, "__main__.parent", 0))
    builtin.fil_skriv(t["command_path"], "")
    assert_eq(client.steg_linje(c), 3)
    assert_eq(client.fortsett_kjoring(c), 4)
    assert_eq(transport.køyr(functions, "__main__.parent", [], t, 100), 42)
    assert_eq(t["last_sequence"], "4")
    assert(heltall_fra_tekst(functions["__vm_debug__"]["pause_count"]) >= 2)

    la t2 = transport.ny_transport(root, token)
    builtin.fil_skriv(t2["command_path"], "feil-token-123456|1|continue\n" + token + "|1|snapshot\n")
    la command = transport.les_kommando(t2, 10)
    assert_eq(command["action"], "snapshot")
    assert(heltall_fra_tekst(t2["auth_failures"]) >= 1)
    la replay = transport.les_kommando(t2, 1)
    assert_eq(replay["status"], "timeout")
    assert(heltall_fra_tekst(t2["replay_rejections"]) >= 1)

    returner 0
}

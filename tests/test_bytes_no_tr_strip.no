bruk std.tekst som t

funksjon krev_bytes(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon første_felt"))
    assert(t.inneholder(src, "builtin.split"))
    assert(t.inneholder(src, "wc -c \" + shell"))
    assert(ikkje t.inneholder(src, "| tr -d ' '"))
    assert(ikkje t.inneholder(src, "wc -c < \" + shell"))
}

funksjon krev_bytes_med_norscode_primar(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon første_felt"))
    assert(t.inneholder(src, "builtin.split"))
    assert(t.inneholder(src, "la innhald = builtin.fil_les(sti)"))
    assert(t.inneholder(src, "returner tekst_fra_heltall(lengde(innhald))"))
    assert(t.inneholder(src, "wc -c \" + shell"))
    assert(ikkje t.inneholder(src, "| tr -d ' '"))
    assert(ikkje t.inneholder(src, "wc -c < \" + shell"))
}

funksjon krev_binærbytes_med_norscode_primar(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon første_felt"))
    assert(t.inneholder(src, "builtin.split"))
    assert(t.inneholder(src, "la innhald = builtin.fil_les_binær(sti)"))
    assert(t.inneholder(src, "returner tekst_fra_heltall(lengde(innhald))"))
    assert(t.inneholder(src, "wc -c \" + shell"))
    assert(ikkje t.inneholder(src, "| tr -d ' '"))
    assert(ikkje t.inneholder(src, "wc -c < \" + shell"))
}

funksjon start() -> heiltall {
    krev_bytes_med_norscode_primar("tools/build_linux_native_candidate_v3005.no")
    krev_bytes_med_norscode_primar("tools/build_omgang6b_compiler_ncb.no")
    krev_binærbytes_med_norscode_primar("tools/ncb_to_elf.no")
    krev_bytes_med_norscode_primar("tools/fetch_stage0_seed.no")
    krev_bytes_med_norscode_primar("tools/build_stage0_release_assets.no")
    krev_bytes_med_norscode_primar("tools/nc_regen_bootstrap.no")
    krev_bytes_med_norscode_primar("tools/verify_omgang6.no")
    krev_bytes_med_norscode_primar("tools/verify_omgang6b.no")
    krev_bytes_med_norscode_primar("tools/selfcompile_native_elf.no")
    krev_bytes_med_norscode_primar("tools/selfcompile_l5b.no")
    krev_bytes_med_norscode_primar("tools/docker-build-linux.no")
    krev_bytes_med_norscode_primar("tools/build_norscode_native.no")
    krev_bytes_med_norscode_primar("tools/selfcompile_stage0_elf.no")

    skriv("test_bytes_no_tr_strip OK")
    returner 0
}

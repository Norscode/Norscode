bruk std.model_runtime som modell
bruk std.qmodel_binary som qmodel
bruk std.model_registry som register
bruk std.model_release som utgjeving

funksjon lag(versjon: heiltall) {
    la m = modell.ny("trygg-modell", 2)
    assert(modell.legg_til_lag(m, modell.dense(2, 1, [2, 3], [versjon], 1, "ingen")))
    returner m
}

funksjon start() -> heiltall {
    assert_eq(utgjeving.hmac_sha256("key", "The quick brown fox jumps over the lazy dog"), "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8")
    la nokkel1 = "0123456789abcdef0123456789abcdef"
    la nokkel2 = "abcdef0123456789abcdef0123456789"
    la tillit = utgjeving.ny(2, 8)
    assert(utgjeving.legg_til_nokkel(tillit, "bygg-2026-a", nokkel1))

    la m1 = lag(1)
    la data1 = qmodel.kod(m1)
    la v1 = utgjeving.signer("trygg-modell-v1", m1["navn"], 1, m1["parametre"], 1000, 10000, "bygg-2026-a", nokkel1, data1)
    assert(utgjeving.verifiser(tillit, v1, data1, 2000))

    la original_parametre = v1["parametre"]
    v1["parametre"] = original_parametre + 1
    assert(ikkje utgjeving.verifiser(tillit, v1, data1, 2000))
    v1["parametre"] = original_parametre

    la endra: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(data1) { legg_til(endra, data1[i]); i = i + 1 }
    endra[lengde(endra) - 1] = (endra[lengde(endra) - 1] + 1) % 256
    assert(ikkje utgjeving.verifiser(tillit, v1, endra, 2000))

    la r = register.ny(2, 100)
    assert(utgjeving.installer(r, tillit, v1, data1, 2000, 100))
    assert_eq(register.inferer(r, "trygg-modell", [4, 5])[0], 24)
    assert(ikkje utgjeving.verifiser(tillit, v1, data1, 2000))

    assert(utgjeving.legg_til_nokkel(tillit, "bygg-2026-b", nokkel2))
    assert(utgjeving.tilbakekall_nokkel(tillit, "bygg-2026-a"))
    la m2 = lag(2)
    la data2 = qmodel.kod(m2)
    la v2 = utgjeving.signer("trygg-modell-v2", m2["navn"], 2, m2["parametre"], 2000, 12000, "bygg-2026-b", nokkel2, data2)
    assert(utgjeving.installer(r, tillit, v2, data2, 3000, 100))
    assert_eq(register.inferer(r, "trygg-modell", [4, 5])[0], 25)
    assert_eq(r["modellar"]["trygg-modell"]["utgjeving_versjon"], 2)
    assert(ikkje utgjeving.verifiser(tillit, v1, data1, 3000))

    la m3 = lag(3)
    la data3 = qmodel.kod(m3)
    la utgaatt = utgjeving.signer("trygg-modell-v3-expired", m3["navn"], 3, m3["parametre"], 2000, 2500, "bygg-2026-b", nokkel2, data3)
    assert(ikkje utgjeving.verifiser(tillit, utgaatt, data3, 3000))

    la tilbakekalt = utgjeving.signer("trygg-modell-v3", m3["navn"], 3, m3["parametre"], 2000, 12000, "bygg-2026-b", nokkel2, data3)
    assert(utgjeving.tilbakekall_utgjeving(tillit, "trygg-modell-v3"))
    assert(ikkje utgjeving.verifiser(tillit, tilbakekalt, data3, 3000))

    skriv("test_model_release OK\n")
    returner 0
}

bruk std.prosess som prosess
bruk std.sched som sched

funksjon start() -> heltall {
    la policy = prosess.ny_policy("async-test")
    prosess.tillat_alle(policy)
    prosess.tillat_shell(policy)
    prosess.aktiver_køyring(policy)
    la plan = prosess.start_plan("sleep 1; printf async-ok")
    prosess.med_timeout(plan, 5)
    la h = prosess.start_async_trygt(policy, plan, "build/process-tests")
    hvis h["status"] != "kjorer" { skriv("async start: " + h["feil"] + "\n") }
    assert_eq(h["status"], "kjorer")
    assert(prosess.async_pid(h) > 0)

    la i: heltall = 0
    mens i < 500 og prosess.async_status(h) == "kjorer" {
        prosess.køyr("sleep 0.01")
        i = i + 1
    }
    assert_eq(prosess.async_status(h), "ferdig")
    assert_eq(prosess.async_exit_code(h), 0)
    assert_eq(prosess.async_les_stdout(h), "async-ok")
    assert_eq(prosess.async_les_stdout(h), "")
    assert_eq(prosess.async_les_stderr(h), "")

    la scheduler = sched.ny()
    la future_plan = prosess.start_plan("printf future-ok")
    la hf = prosess.start_async_med_future(scheduler, policy, future_plan, "build/process-tests")
    la j: heltall = 0
    mens j < 500 og prosess.async_poll_future(scheduler, hf) == "ventende" {
        prosess.køyr("sleep 0.01")
        j = j + 1
    }
    assert_eq(sched.future_status(scheduler, hf["future_id"]), "ferdig")
    la future_resultat = builtin.json_parse(sched.future_resultat(scheduler, hf["future_id"]))
    assert_eq(future_resultat["exit_code"], "0")
    assert_eq(future_resultat["stdout"], "future-ok")

    la lang = prosess.start_plan("sleep 30")
    la h2 = prosess.start_async_trygt(policy, lang, "build/process-tests")
    assert_eq(h2["status"], "kjorer")
    assert(prosess.async_signal(h2, 15))
    assert_eq(h2["status"], "signal")
    prosess.køyr("sleep 0.05")
    assert(ikkje prosess.er_ok(prosess.køyr("kill -0 " + h2["pid"] + " 2>/dev/null")))

    la cancel_scheduler = sched.ny()
    la cancel_plan = prosess.start_plan("sleep 30")
    la hc = prosess.start_async_med_future(cancel_scheduler, policy, cancel_plan, "build/process-tests")
    assert_eq(hc["status"], "kjorer")
    assert(prosess.async_kanseller_future(cancel_scheduler, hc))
    assert_eq(sched.future_status(cancel_scheduler, hc["future_id"]), "kansellert")
    assert_eq(hc["status"], "kansellert")
    prosess.køyr("sleep 0.05")
    assert(ikkje prosess.er_ok(prosess.køyr("kill -0 " + hc["pid"] + " 2>/dev/null")))

    la timeout_scheduler = sched.ny()
    la timeout_plan = prosess.start_plan("sleep 30")
    prosess.med_timeout(timeout_plan, 1)
    la ht = prosess.start_async_med_future(timeout_scheduler, policy, timeout_plan, "build/process-tests")
    assert_eq(ht["status"], "kjorer")
    la k: heiltall = 0
    mens k < 300 og sched.future_status(timeout_scheduler, ht["future_id"]) == "ventende" {
        sched.io_poll(timeout_scheduler)
        prosess.køyr("sleep 0.01")
        k = k + 1
    }
    assert_eq(sched.future_status(timeout_scheduler, ht["future_id"]), "feil")
    assert_inneholder(sched.future_feil(timeout_scheduler, ht["future_id"]), "TimeoutFeil")
    assert_eq(ht["status"], "timeout")
    prosess.køyr("sleep 0.05")
    assert(ikkje prosess.er_ok(prosess.køyr("kill -0 " + ht["pid"] + " 2>/dev/null")))
    returner 0
}

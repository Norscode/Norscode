// Ende-til-ende macOS arm64 AOT av konstante liste-/tekstoperasjonar.

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon start() -> heiltall {
    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis os[0] != "0" eller builtin.trim(os[1]) != "Darwin" eller arch[0] != "0" eller builtin.trim(arch[1]) != "arm64" {
        returner 0
    }
    la root = miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la id = builtin.random_hex(8)
    la ncb = "/tmp/norscode_macho_aot_common_" + id + ".ncb.json"
    la binær = "/tmp/norscode_macho_aot_common_" + id
    la kjelde = root + "/tests/fixtures/macos_aot_common_runtime.no"
    la compile_cmd = "env NORSCODE_NATIVE_BIN= " + shell(root + "/tools/compile_with_hybrid_bundle_v9400.sh") + " " + shell(root) + " " + shell(kjelde) + " " + shell(ncb) + " __main__ " + shell(root)
    assert_eq(exec_prosess(compile_cmd)[0], "0")
    la codegen_cmd = "env NORSCODE_CMD=run NORSCODE_FILE=" + shell(root + "/selfhost/native_execution/macho_arm64_codegen.no") + " NORSCODE_ROOT=" + shell(root) + " NC_INPUT=" + shell(ncb) + " NC_OUTPUT=" + shell(binær) + " " + shell(root + "/dist/norscode_native")
    assert_eq(exec_prosess(codegen_cmd)[0], "0")
    assert_eq(exec_prosess("file " + shell(binær))[0], "0")
    assert_eq(exec_prosess(shell(binær))[0], "25")
    exec_prosess("rm -f " + shell(ncb) + " " + shell(binær))
    returner 0
}

funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "routes": {}
    }
slutt

funksjon register_standard_health_routes(server, handler)
    server["routes"]["GET /helse"] = handler
    server["routes"]["GET /health"] = handler
    returner server
slutt

funksjon hent_route_handler(server, metode, sti)
    returner server["routes"][metode + " " + sti]
slutt

funksjon standard_helse_response()
    returner {
        "body": "{\"ready\":true}",
        "logg": "ready"
    }
slutt

funksjon response_text(resp)
    returner resp["body"]
slutt

funksjon request_context(metode, sti, query, headers, body)
    returner {
        "method": metode,
        "path": sti,
        "headers": headers,
        "body": body
    }
slutt

funksjon standard_server_log(ctx, status)
    returner {
        "method": "GET",
        "path": "/helse",
        "status": "200",
        "ok": "sann"
    }
slutt

funksjon start() -> heiltall {
    la server = ny_server(8083)
    register_standard_health_routes(server, "helse_handler")
    assert_eq(hent_route_handler(server, "GET", "/helse"), "helse_handler")
    assert_eq(hent_route_handler(server, "GET", "/health"), "helse_handler")

    la health = standard_helse_response()
    assert_eq(builtin.contains(response_text(health), "\"ready\""), sann)
    assert_eq(health["logg"], "ready")

    la ctx = request_context("get", "/helse", {}, {"x-request-id": "req-1"}, "")
    la logg = standard_server_log(ctx, 200)
    assert_eq(logg["method"], "GET")
    assert_eq(logg["path"], "/helse")
    assert_eq(logg["status"], "200")
    assert_eq(logg["ok"], "sann")
    returner 0
}

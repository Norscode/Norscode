bruk std.runtime.process_abi som abi

funksjon spawn(executable: tekst, args: liste_tekst, cwd: tekst,
               stdin: tekst, timeout_ms: heiltall,
               max_output: heiltall) -> ordbok_tekst {
    returner builtin.process_spawn_argv(abi.request(
        executable, args, cwd, stdin, timeout_ms, max_output
    ))
}

funksjon start() -> heiltall {
    la literal = spawn("/usr/bin/printf", ["%s|%s|%s", "a b", ";", "$HOME"], "", "", 5000, 4096)
    assert_eq(literal["status"], "ferdig")
    assert_eq(heltall_fra_tekst(literal["exit_code"]), 0)
    assert_eq(literal["stdout"], "a b|;|$HOME")
    assert_eq(literal["stderr"], "")
    assert(heltall_fra_tekst(literal["pid"]) > 0)
    assert(abi.gyldig_resultat(literal))

    la stdin_result = spawn("/bin/cat", [], "", "stdin-ok", 5000, 4096)
    assert_eq(stdin_result["status"], "ferdig")
    assert_eq(stdin_result["stdout"], "stdin-ok")

    la cwd_result = spawn("/bin/pwd", [], "/tmp", "", 5000, 4096)
    assert_eq(cwd_result["status"], "ferdig")
    assert(builtin.ends_with(builtin.trim(cwd_result["stdout"]), "/tmp"))

    la error_result = spawn("/bin/ls", ["/definitely-not-a-norscode-path"], "", "", 5000, 4096)
    assert_eq(error_result["status"], "ferdig")
    assert(heltall_fra_tekst(error_result["exit_code"]) > 0)
    assert(error_result["stderr"] != "")

    la timeout_result = spawn("/bin/sleep", ["2s"], "", "", 25, 4096)
    assert_eq(timeout_result["status"], "timeout")
    assert_eq(heltall_fra_tekst(timeout_result["exit_code"]), 124)

    la limited = spawn("/usr/bin/yes", ["x"], "", "", 5000, 128)
    assert_eq(limited["status"], "feil")
    assert_eq(limited["error"], "output limit")
    assert(lengde(limited["stdout"]) <= 128)
    skriv("test_native_process_spawn_argv OK")
    returner 0
}

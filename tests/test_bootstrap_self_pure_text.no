bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("selfhost/bootstrap_self_pure.no")

    assert(t.inneholder(src, "Bootstrap Steg C i Norscode"))
    assert(t.inneholder(src, "=== Norscode Bootstrap Steg C ==="))
    assert(t.inneholder(src, "[1/3] Testar JSON-parsing..."))
    assert(t.inneholder(src, "[OK] JSON-parsing OK"))
    assert(t.inneholder(src, "[FEIL] JSON-parsing FEILET"))
    assert(t.inneholder(src, "[OK] Funksjonar + entry OK"))
    assert(t.inneholder(src, "Steget beviser denne bootstrap-kjeda utan å hevde full sjølvstendighet."))
    assert(t.inneholder(src, "[2/3] Hentar funksjonar frå parsed NCB..."))
    assert(t.inneholder(src, "[3/3] Køyrer bytekode via selfhost/vm.no..."))
    assert(t.inneholder(src, "Norscode-kjeda kompilerer, parser og køyrer denne bytekodeproben."))
    assert(t.inneholder(src, "Bootstrap-steg C er bevist; køyr samla sjølvstendighetsgate for breiare status."))
    assert(ikkje t.inneholder(src, "Pure Norscode"))
    assert(ikkje t.inneholder(src, "Bootstrap Steg C (Pure)"))
    assert(ikkje t.inneholder(src, "Alt i ren Norscode"))
    assert(ikkje t.inneholder(src, "kjører seg selv i ren Norscode"))
    assert(ikkje t.inneholder(src, "Kjøre"))
    assert(ikkje t.inneholder(src, "Kjører"))
    assert(ikkje t.inneholder(src, "Kjøring"))
    assert(ikkje t.inneholder(src, "Henter"))
    assert(ikkje t.inneholder(src, "Tester JSON-parsing"))
    assert(ikkje t.inneholder(src, "Functions + entry OK"))
    assert(ikkje t.inneholder(src, "Fullstendig selvstendighet oppnådd"))
    assert(ikkje t.inneholder(src, "✅"))
    assert(ikkje t.inneholder(src, "❌"))

    skriv("test_bootstrap_self_pure_text OK")
    returner 0
}

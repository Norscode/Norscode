funksjon start() -> heiltall {
    la ctx = {
        "__request_middleware_trace__": ["auth"],
        "__response_middleware_trace__": ["cors"],
        "__error_middleware_trace__": ["error-json"]
    }

    assert_eq(lengde(ctx["__request_middleware_trace__"]), 1)
    assert_eq(ctx["__request_middleware_trace__"][0], "auth")
    assert_eq(lengde(ctx["__response_middleware_trace__"]), 1)
    assert_eq(ctx["__response_middleware_trace__"][0], "cors")
    assert_eq(lengde(ctx["__error_middleware_trace__"]), 1)
    assert_eq(ctx["__error_middleware_trace__"][0], "error-json")

    returner 0
}

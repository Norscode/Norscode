bruk std.runtime_library som runtime_library

funksjon start() -> heiltall {
    assert_eq(runtime_library.abi_version(), "norscode-runtime-library-abi-v1")
    la report = runtime_library.stabilitetsrapport()
    assert_eq(report["status"], "stabil")
    assert_eq(report["abi"], "norscode-runtime-library-abi-v1")
    assert(heltall_fra_tekst(report["symbols_checked"]) >= 30)
    assert_eq(lengde(report["abi_missing"]), 0)
    assert_eq(lengde(report["behavior_failures"]), 0)
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/nc_repl.sh")
    assert(t.inneholder(src, "Norscode-first wrapper: REPL-evalueringa har eigarlogikk i tools/nc_repl.no."))
    assert(t.inneholder(src, "Shell-delen under er avgrensa interaktiv reserveveg medan runtime manglar exec_prosess."))
    assert(t.inneholder(src, "_tmp_base()"))
    assert(t.inneholder(src, "_eval_line()"))
    assert(t.inneholder(src, "if [ \"$#\" -gt 0 ]; then"))
    assert(t.inneholder(src, "_eval_line \"$*\""))
    assert(t.inneholder(src, "tmpfile=\"${tmpbase}_expr.no\""))
    assert(t.inneholder(src, "tmpfile2=\"${tmpbase}_print.no\""))
    assert(t.inneholder(src, "NORSCODE_CMD=run NORSCODE_FILE=\"$1\" \"$NC_NATIVE\""))
    assert(t.inneholder(src, "tekst_fra_heltall(_res)"))
    assert(ikkje t.inneholder(src, "NORSCODE_REPL_LINE=\"$line\" \"$NC\" run"))

    skriv("test_nc_repl_wrapper_direct OK")
    returner 0
}

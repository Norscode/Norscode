bruk std.media_model som modell
bruk std.media_job som jobb

funksjon start() -> heiltall {
    la p = modell.leverandor("demo", "https://media.example", "secret", "image-v1", "speech-v1", "music-v1", "video-v1")
    la opts: ordbok_tekst = {"width": "1024", "height": "1024"}
    la body = modell.bygg_body(p, "bilde", "Nordlys over fjell", opts)
    assert(builtin.contains(body, "\"model\":\"image-v1\""))
    assert(builtin.contains(body, "\"response_format\":\"b64_json\""))
    assert_eq(modell.headers(p)["authorization"], "Bearer secret")

    la synk = jobb.ny("media-sync-1", "bilde", "Nordlys", "demo", 0, 10000)
    assert(jobb.start(synk, 10))
    la response = "{\"status\":200,\"body\":\"{\\\"data\\\":\\\"AAF/gP8=\\\",\\\"mime\\\":\\\"image/png\\\"}\",\"headers\":{\"content-type\":\"application/json\"}}"
    la ferdig = modell.behandl_response(p, synk, response, "build/test_media_model.png", 64, 20)
    assert_eq(ferdig["ok"], "sann")
    assert_eq(synk["status"], "ferdig")
    assert_eq(synk["resultat_mime"], "image/png")

    la async_jobb = jobb.ny("media-async-1", "video", "Kort film", "demo", 0, 60000)
    assert(jobb.start(async_jobb, 100))
    la async_response = "{\"status\":202,\"body\":\"{\\\"id\\\":\\\"ext-42\\\",\\\"status\\\":\\\"running\\\",\\\"progress\\\":25}\",\"headers\":{\"content-type\":\"application/json\"}}"
    la ventar = modell.behandl_response(p, async_jobb, async_response, "build/test_media_model.mp4", 1048576, 120)
    assert_eq(ventar["status"], "koyrer")
    assert_eq(async_jobb["ekstern_id"], "ext-42")
    assert_eq(async_jobb["status_url"], "https://media.example/v1/media/jobs/ext-42")
    assert_eq(heltall_fra_tekst(async_jobb["fremdrift"]), 25)
    skriv("test_media_model OK\n")
    returner 0
}

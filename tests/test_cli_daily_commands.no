funksjon krev_ok(kommando: tekst, namn: tekst) {
    la resultat = builtin.exec_prosess(kommando)
    hvis resultat[0] != "0" {
        kast namn + " feilet: " + resultat[1]
    }
    hvis builtin.contains(resultat[1], "Sikkerheitsfeil: manglar capability") {
        kast namn + " manglar runtime-capability"
    }
}

funksjon start() -> heiltall {
    krev_ok("./bin/nc doctor", "nc doctor")
    krev_ok("./bin/nc format tests/test_nc_main_smoke.no", "nc format")
    krev_ok("./bin/nc lint tests/test_nc_main_smoke.no --check", "nc lint --check")
    skriv("test_cli_daily_commands OK")
    returner 0
}

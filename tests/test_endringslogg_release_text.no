    assert(ikkje t.inneholder(src, "**Rettelse:**"))
    assert(t.inneholder(src, "**Verifisert:** `bruk std.math`, `bruk std.path` og `bruk std.math som alias` verkar."))
    assert(t.inneholder(src, "#### Standardbibliotek"))
    assert(t.inneholder(src, "./bin/nc local-green"))
    assert(t.inneholder(src, "plattformdokumentasjon for appar"))
    assert(ikkje t.inneholder(src, "plattformdocs"))
    assert(t.inneholder(src, "[Historiske release-notat](.github/releases/v1.0-selfhost.md)"))

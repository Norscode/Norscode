    assert(t.inneholder(src, "[Selfhost-faseplanar](docs/SELFHOST_HANDLINGSPLAN.md)"))
    assert(t.inneholder(src, "Fjerne historisk `bootstrap/maint/` frå git"))
    assert(t.inneholder(src, "**Status:** Verifisert release-løype"))
    assert(ikkje t.inneholder(src, "Norscode has a verified self-hosting lane."))
    assert(ikkje t.inneholder(src, "#### Norscode Selfhost Compilation Pipeline"))
    assert(ikkje t.inneholder(src, "**Status:** Verified release lane"))
    assert(ikkje t.inneholder(src, "### Bug Fixes"))

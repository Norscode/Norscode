funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "request_middlewares": [],
        "response_middlewares": [],
        "error_middlewares": [],
        "startup_hooks": [],
        "shutdown_hooks": []
    }
slutt

funksjon route(server, metode, sti, handler)
    server["route"] = metode + " " + sti
    returner server
slutt

funksjon register_request_middleware(server, namn)
    server["request_middlewares"] = [namn]
    returner server
slutt

funksjon register_response_middleware(server, namn)
    server["response_middlewares"] = [namn]
    returner server
slutt

funksjon register_error_middleware(server, namn)
    server["error_middlewares"] = [namn]
    returner server
slutt

funksjon register_startup_hook(server, namn)
    server["startup_hooks"] = [namn]
    returner server
slutt

funksjon register_shutdown_hook(server, namn)
    server["shutdown_hooks"] = [namn]
    returner server
slutt

funksjon server_info(server)
    returner "1/1/1 middleware, 1/1 hooks"
slutt

funksjon start() -> heiltall {
    la server = ny_server(8080)
    route(server, "GET", "/", "home")
    register_request_middleware(server, "request_trace")
    register_response_middleware(server, "response_trace")
    register_error_middleware(server, "error_trace")
    register_startup_hook(server, "ved_start")
    register_shutdown_hook(server, "ved_stopp")

    assert_eq(lengde(server["request_middlewares"]), 1)
    assert_eq(lengde(server["response_middlewares"]), 1)
    assert_eq(lengde(server["error_middlewares"]), 1)
    assert_eq(lengde(server["startup_hooks"]), 1)
    assert_eq(lengde(server["shutdown_hooks"]), 1)

    la info = server_info(server)
    assert_eq(builtin.contains(info, "1/1/1 middleware"), sann)
    assert_eq(builtin.contains(info, "1/1 hooks"), sann)
    returner 0
}

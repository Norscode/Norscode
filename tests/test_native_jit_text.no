bruk std.runtime_jit som jit

funksjon start() -> heiltall {
    la equal = jit.kompiler_tekst_boolsk(["arg:0", "arg:1", "eq", "return"], 2)
    assert_eq(equal["status"], "ferdig")
    assert_eq(jit.køyr_tekst(equal["handle"], ["nors", "nors"])["value"], sann)
    assert_eq(jit.køyr_tekst(equal["handle"], ["nors", "code"])["value"], usann)

    la not_equal = jit.kompiler_tekst_boolsk(["arg:0", "arg:1", "ne", "return"], 2)
    assert_eq(not_equal["status"], "ferdig")
    assert_eq(jit.køyr_tekst(not_equal["handle"], ["a", "b"])["value"], sann)
    assert_eq(jit.køyr_tekst(not_equal["handle"], ["a", "a"])["value"], usann)

    la text_length = jit.kompiler_tekst_heiltall(["arg:0", "text_len", "return"], 1)
    assert_eq(text_length["status"], "ferdig")
    assert_eq(jit.køyr_tekst(text_length["handle"], ["Norscode"])["value"], 8)
    assert_eq(jit.køyr_tekst(text_length["handle"], [""])["value"], 0)

    la concat = jit.kompiler_tekst(["arg:0", "arg:1", "concat", "return"], 2)
    assert_eq(concat["status"], "ferdig")
    assert_eq(jit.køyr_tekst(concat["handle"], ["Nors", "code"])["value"], "Norscode")
    assert_eq(jit.køyr_tekst(concat["handle"], ["", "framtid"])["value"], "framtid")

    la invalid = builtin.jit_operation({
        "abi": jit.abi(), "operation": "run", "handle": equal["handle"], "arguments": [1, 2]
    })
    assert_eq(invalid["status"], "feil")
    assert_eq(jit.kompiler_tekst_boolsk(["arg:0", "text_len", "return"], 1)["status"], "feil")
    assert_eq(jit.kompiler_tekst_boolsk(["arg:0", "arg:1", "concat", "return"], 2)["status"], "feil")

    la big = "x"
    la i: heiltall = 0
    mens i < 24 {
        big = big + big
        i = i + 1
    }
    assert_eq(jit.køyr_tekst(concat["handle"], [big, "x"])["status"], "feil")

    assert_eq(jit.frigjer(equal["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(not_equal["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(text_length["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(concat["handle"])["status"], "ferdig")
    skriv("test_native_jit_text OK")
    returner 0
}

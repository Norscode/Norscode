bruk std.runtime_jit som jit

funksjon same_text(left: tekst, right: tekst) -> boolsk {
    returner left == right
}

funksjon ulik_text(left: tekst, right: tekst) -> boolsk {
    returner left != right
}

funksjon textstorleik(value: tekst) -> heiltall {
    returner lengde(value)
}

funksjon sett_saman(left: tekst, right: tekst) -> tekst {
    returner left + right
}

funksjon start() -> heiltall {
    assert_eq(same_text("nors", "nors"), sann)
    assert_eq(same_text("nors", "code"), usann)
    assert_eq(same_text("framtid", "framtid"), sann)

    assert_eq(ulik_text("a", "b"), sann)
    assert_eq(ulik_text("a", "a"), usann)
    assert_eq(ulik_text("Norscode", "norscode"), sann)

    assert_eq(textstorleik("Norscode"), 8)
    assert_eq(textstorleik(""), 0)
    assert_eq(textstorleik("runtime"), 7)

    assert_eq(sett_saman("Nors", "code"), "Norscode")
    assert_eq(sett_saman("AI", " runtime"), "AI runtime")
    assert_eq(sett_saman("", "framtid"), "framtid")

    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["jit_compiles"]) >= 4)
    assert(heltall_fra_tekst(metrics["jit_calls"]) >= 7)
    assert(builtin.vm_jit_cleanup() >= 4)
    assert_eq(heltall_fra_tekst(jit.status()["active"]), 0)
    skriv("test_vm_jit_text_integration OK")
    returner 0
}

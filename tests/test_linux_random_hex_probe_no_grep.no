bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/linux_stage0_random_hex_probe.no")

    assert(t.inneholder(src, "funksjon les_fil_trygt(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "returner builtin.fil_les(sti)"))
    assert(t.inneholder(src, "funksjon inneheld(data: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.index_of(data, needle)"))
    assert(t.inneholder(src, "hvis inneheld(plan_body, \"builtin.random_hex\")"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))

    assert(ikkje t.inneholder(src, "grep -q 'builtin[.]random_hex'"))
    assert(ikkje t.inneholder(src, "test -f '\" + plan"))

    skriv("test_linux_random_hex_probe_no_grep OK")
    returner 0
}

bruk std.base64 som base64

funksjon start() -> heiltall {
    la original: liste_heltall = [0, 1, 127, 128, 255]
    la koda = base64.kod_bytes(original)
    assert_eq(koda, "AAF/gP8=")

    la dekoda = base64.dekod_bytes(koda)
    assert_eq(lengde(dekoda), 5)
    assert_eq(dekoda[0], 0)
    assert_eq(dekoda[1], 1)
    assert_eq(dekoda[2], 127)
    assert_eq(dekoda[3], 128)
    assert_eq(dekoda[4], 255)

    skriv("test_media_binary_foundation OK\n")
    returner 0
}

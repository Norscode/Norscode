bruk std.runtime.atomic som atomic

funksjon start() -> heiltall {
    la c = atomic.ny(10)
    assert_eq(atomic.load(c, "seq_cst"), 10)
    assert(atomic.store(c, 11, "release"))
    assert_eq(atomic.exchange(c, 20, "acq_rel"), 11)
    la ok = atomic.compare_exchange(c, 20, 30, "seq_cst", "acquire")
    assert_eq(ok["success"], "sann")
    assert_eq(ok["observed"], "20")
    la fail = atomic.compare_exchange(c, 20, 40, "seq_cst", "relaxed")
    assert_eq(fail["success"], "usann")
    assert_eq(fail["observed"], "30")
    assert_eq(atomic.fetch_add(c, 5, "seq_cst"), 30)
    assert_eq(atomic.load(c, "acquire"), 35)
    hvis c["backend"] == "vm-seq-cst" {
        assert_eq(c["version"], "4")
    } ellers {
        la state = atomic.native_operasjon({"abi": atomic.versjon(), "operation": "load", "handle": c["handle"], "order": "seq_cst"})
        assert_eq(heltall_fra_tekst(state["version"]), 4)
    }
    assert(ikkje atomic.store(c, 1, "acquire"))
    assert(ikkje atomic.gyldig_order("ukjent"))
    la native = atomic.native_operasjon({"abi": atomic.versjon(), "operation": "load", "handle": "x", "order": "seq_cst"})
    hvis c["backend"] == "vm-seq-cst" {
        assert_eq(native["status"], "unsupported")
    } ellers {
        assert_eq(native["status"], "invalid_handle")
        assert(atomic.fence("seq_cst"))
        assert(atomic.destroy(c))
        assert_eq(c["backend"], "destroyed")
    }
    returner 0
}

bruk std.runtime_jit som jit

funksjon start() -> heiltall {
    la compiled = jit.kompiler_desimal([
        "arg:0", "const:1.5", "add",
        "arg:1", "mul",
        "const:2.0", "div",
        "neg"
    ], 2)
    assert_eq(compiled["status"], "ferdig")
    la result = jit.køyr_desimal(compiled["handle"], [2.5, 4])
    assert_eq(result["status"], "ferdig")
    assert_eq(result["value"], -8.0)

    la absolute = jit.kompiler_desimal([
        "arg:0", "const:0.0", "gt", "jump_if_false:negative",
        "arg:0", "return",
        "label:negative", "arg:0", "neg", "return"
    ], 1)
    assert_eq(absolute["status"], "ferdig")
    assert_eq(jit.køyr_desimal(absolute["handle"], [3.25])["value"], 3.25)
    assert_eq(jit.køyr_desimal(absolute["handle"], [-3.25])["value"], 3.25)

    la less_equal = jit.kompiler_desimal(["arg:0", "arg:1", "le"], 2)
    assert_eq(less_equal["status"], "ferdig")
    assert_eq(jit.køyr_desimal(less_equal["handle"], [2.0, 3.0])["value"], 1.0)
    assert_eq(jit.køyr_desimal(less_equal["handle"], [4.0, 3.0])["value"], 0.0)

    la bool_result = jit.kompiler_desimal_boolsk(["arg:0", "arg:1", "gt"], 2)
    assert_eq(bool_result["status"], "ferdig")
    assert_eq(jit.køyr_desimal(bool_result["handle"], [4.0, 3.0])["value"], sann)
    assert_eq(jit.køyr_desimal(bool_result["handle"], [2.0, 3.0])["value"], usann)

    la nan_equal = jit.kompiler_desimal(["const:0.0", "const:0.0", "div", "const:0.0", "eq"], 0)
    la nan_not_equal = jit.kompiler_desimal(["const:0.0", "const:0.0", "div", "const:0.0", "ne"], 0)
    assert_eq(jit.køyr_desimal(nan_equal["handle"], [])["value"], 0.0)
    assert_eq(jit.køyr_desimal(nan_not_equal["handle"], [])["value"], 1.0)

    la invalid_branch = jit.kompiler_desimal([
        "const:1.0", "jump:target", "const:2.0", "label:target", "return"
    ], 0)
    assert_eq(invalid_branch["status"], "feil")

    la invalid = jit.køyr_desimal(compiled["handle"], ["ikkje-tal", 4])
    assert_eq(invalid["status"], "feil")
    assert_eq(jit.frigjer(compiled["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(absolute["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(less_equal["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(bool_result["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(nan_equal["handle"])["status"], "ferdig")
    assert_eq(jit.frigjer(nan_not_equal["handle"])["status"], "ferdig")
    assert_eq(jit.køyr_desimal(compiled["handle"], [2.5, 4])["status"], "feil")
    skriv("test_native_jit_float OK")
    returner 0
}

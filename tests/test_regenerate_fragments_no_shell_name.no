bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/regenerate_omgang6b_fragments_safe.no")
    la wrapper = fil_les("tools/regenerate_omgang6b_fragments_safe.sh")

    assert(t.inneholder(src, "funksjon fragment_namn(src_file: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon omskriv_funksjonar(precompiled_sti: tekst, modul_namn: tekst) -> tekst"))
    assert(t.inneholder(src, "json_parse_raw(ncb_json)"))
    assert(t.inneholder(src, "json_skriv(ny_fns)"))
    assert(t.inneholder(src, "fil_skriv(outer_path, outer)"))
    assert(t.inneholder(src, "fil_skriv(inner_path, inner)"))
    assert(t.inneholder(src, "builtin.ends_with(src_file, \".ncb.json\")"))
    assert(t.inneholder(src, "builtin.slice(src_file, 0, lengde(src_file) - lengde(\".ncb.json\"))"))
    assert(t.inneholder(src, "la out_name = fragment_namn(src_file)"))

    assert(ikkje t.inneholder(src, "printf '%s' \" + shell(src_file)"))
    assert(ikkje t.inneholder(src, "sed 's/\\\\.ncb\\\\.json$/.functions.json/'"))
    assert(ikkje t.inneholder(src, "jq --arg module"))
    assert(ikkje t.inneholder(src, "sed '1s/^{//; $s/}$//'"))
    assert(ikkje t.inneholder(src, "wc -c < \" + shell"))
    assert(ikkje t.inneholder(src, "| tr -d ' '"))
    assert(ikkje t.inneholder(src, "exec_prosess"))
    assert(ikkje t.inneholder(src, "funksjon shell"))
    assert(ikkje t.inneholder(src, "funksjon run(cmd"))
    assert(t.inneholder(wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/regenerate_omgang6b_fragments_safe.no\""))
    assert(ikkje t.inneholder(wrapper, "exec \"$ROOT/bin/nc\" run \"$ROOT/tools/regenerate_omgang6b_fragments_safe.no\""))
    assert(ikkje t.inneholder(wrapper, "jq --arg module"))
    assert(ikkje t.inneholder(wrapper, "sed 's/\\\\.ncb\\\\.json$/.functions.json/'"))
    assert(ikkje t.inneholder(wrapper, "sed '1s/^{//; $s/}$//'"))
    assert(ikkje t.inneholder(wrapper, "grep -Eq"))
    assert(ikkje t.inneholder(wrapper, "rewrite_one()"))

    skriv("test_regenerate_fragments_no_shell_name OK")
    returner 0
}

bruk std.json som json

funksjon start() -> heiltall {
    la a = 1.5
    la b = a + 2
    assert_eq(type_av(a), "desimaltall")
    assert_eq(b, 3.5)
    assert_eq(a * 2.0, 3.0)
    assert_eq(7.5 / 2.5, 3.0)
    assert_eq(-a, -1.5)
    assert(a < 2.0)
    assert_eq(heltall_fra_tekst("3"), 3)
    assert_eq(desimaltall("2.25"), 2.25)
    assert_eq(tekst(a), "1.5")

    la encoded = json.stringify({"value": a})
    assert_inneholder(encoded, "1.5")
    la decoded = json.parse(encoded)
    assert_eq(type_av(decoded["value"]), "desimaltall")
    assert_eq(decoded["value"], 1.5)
    skriv("test_native_decimal_runtime OK")
    returner 0
}

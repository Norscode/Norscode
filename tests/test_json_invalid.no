bruk std.json som json

funksjon assert_obj_null_variant(faktisk: tekst, nøkkel: tekst) {
    la forventet_null = "{\"" + nøkkel + "\":null}"
    la forventet_tekst_null = "{\"" + nøkkel + "\":\"null\"}"
    hvis faktisk != forventet_null {
        assert_eq(faktisk, forventet_tekst_null)
    }
}

funksjon start() -> heltall {
    assert_eq(json.stringify(json.parse(" 123 ")), "123")
    assert_eq(json.stringify(json.parse("\t-1\n")), "-1")
    assert_eq(json.stringify(json.parse("  \n")), "null")
    assert_eq(json.stringify(json.parse("123")), "123")
    assert_eq(json.stringify(json.parse("true true")), "null")
    assert_eq(json.stringify(json.parse("12.3")), "null")
    assert_eq(json.stringify(json.parse("12.34")), "null")
    assert_eq(json.stringify(json.parse("1e3")), "null")
    assert_eq(json.stringify(json.parse("-1e2")), "null")
    assert_eq(json.stringify(json.parse("-1.")), "null")
    assert_eq(json.stringify(json.parse("123abc")), "null")
    assert_eq(json.stringify(json.parse("-1")), "-1")
    assert_eq(json.stringify(json.parse("-12abc")), "null")
    assert_eq(json.stringify(json.parse("truefalse")), "null")
    assert_eq(json.stringify(json.parse("[12.3]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("[1e3]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("[123abc]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("0x")), "null")
    assert_eq(json.stringify(json.parse("[0]x")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1}x")), "null")
    assert_eq(json.stringify(json.parse("[1,]")), "null")
    assert_eq(json.stringify(json.parse("[1,2],")), "null")
    assert_eq(json.stringify(json.parse("[1,,2]")), "null")
    assert_eq(json.stringify(json.parse("[1,,]")), "null")
    assert_eq(json.stringify(json.parse("[1, 2,]")), "null")
    assert_eq(json.stringify(json.parse("[,]")), "null")
    assert_eq(json.stringify(json.parse("[\"a\",, \"b\"]")), "null")
    assert_eq(json.stringify(json.parse("[1,2}")), "null")
    assert_eq(json.stringify(json.parse("true//")), "null")
    assert_eq(json.stringify(json.parse("[]]")), "null")
    assert_eq(json.stringify(json.parse("[1 2]")), "null")
    assert_eq(json.stringify(json.parse("[1e+3]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("[1e-3]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("[000]")), "{\"0\":\"null\"}")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":12.3}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":1e3}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":123abc}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":01}")), "x")
    assert_eq(json.stringify(json.parse("{\"x\":1,\"y\":2,}")), "null")
    assert_eq(json.stringify(json.parse("{\"x\":1,,\"y\":2}")), "null")
    assert_eq(json.stringify(json.parse("{,}")), "null")
    assert_eq(json.stringify(json.parse("[01]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("[-01]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("+1")), "null")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":+0}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":-.5}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":+.5}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":-+1}")), "x")
    assert_obj_null_variant(json.stringify(json.parse("{\"x\":+1}")), "x")
    assert_eq(json.stringify(json.parse("{x:1}")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1 2}")), "null")
    assert_eq(json.stringify(json.parse("\"abc")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1,")), "null")
    assert_obj_null_variant(json.stringify(json.parse("{\"a\":}")), "a")
    assert_eq(json.stringify(json.parse("{\"a\" 1}")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":\"x\",\"b\"}")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1}}")), "null")
    assert_eq(json.stringify(json.parse("{")), "null")
    assert_eq(json.stringify(json.parse("[")), "null")
    assert_eq(json.stringify(json.parse("\"a\\\\")), "null")
    assert_eq(json.stringify(json.parse("[]}")), "null")
    assert_eq(json.stringify(json.parse("-")), "null")
    assert_eq(json.stringify(json.parse("+")), "null")
    assert_eq(json.stringify(json.parse("+0")), "null")
    assert_eq(json.stringify(json.parse("- 1")), "null")
    assert_eq(json.stringify(json.parse("+ 1")), "null")
    assert_eq(json.stringify(json.parse("-.5")), "null")
    assert_eq(json.stringify(json.parse("-0")), "0")
    assert_eq(json.stringify(json.parse("0")), "0")
    assert_eq(json.stringify(json.parse(" 0 ")), "0")
    assert_eq(json.stringify(json.parse("[0]")), "{\"0\":\"0\"}")
    assert_eq(json.stringify(json.parse("[0] x")), "null")
    assert_eq(json.stringify(json.parse("[0}}")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1}  \n x")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1,2:3}")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1]")), "null")
    assert_eq(json.stringify(json.parse("1 x")), "null")
    assert_eq(json.stringify(json.parse("-1 \n x")), "null")
    assert_eq(json.stringify(json.parse("-01")), "null")
    assert_eq(json.stringify(json.parse("tru")), "null")
    assert_eq(json.stringify(json.parse("fals")), "null")
    assert_eq(json.stringify(json.parse("nul")), "null")
    assert_eq(json.stringify(json.parse("]")), "null")
    assert_eq(json.stringify(json.parse("{{}")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1} {}")), "null")
    assert_eq(json.stringify(json.parse("{, \"a\":1}")), "null")
    assert_eq(json.stringify(json.parse("[,1]")), "null")
    assert_eq(json.stringify(json.parse("{\"a\":1,,}")), "null")
    assert_eq(json.stringify(json.parse("{{\"a\":1}}")), "null")
    skriv("test_json_invalid OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/stdlib_status.no")

    assert(t.inneholder(src, "Norscode-serverkontrakt med avgrensa runtime-grense"))
    assert(t.inneholder(src, "Norscode-adapterkontrakt med avgrensa runtime-grense"))
    assert(ikkje t.inneholder(src, "Python-wrapper"))

    skriv("test_stdlib_status_text OK")
    returner 0
}

bruk selfhost.vm

funksjon ventende_future_avvises() -> boolsk {
    prøv {
        vm_await_value(vm_future("ventende", 7))
    } fang (e) {
        assert_inneholder(tekst(e), "FutureVenter")
        returner sann
    }
    returner usann
}

funksjon feil_future_kaster_original_feil() -> boolsk {
    la f = vm_future("feil", 0)
    f["feil"] = "IOFeil: disk"
    prøv {
        vm_await_value(f)
    } fang (e) {
        assert_inneholder(tekst(e), "IOFeil: disk")
        returner sann
    }
    returner usann
}

funksjon await_suspend_og_resume() -> boolsk {
    la future = vm_future("ventende", 0)
    la functions = {
        "__main__.child": {
            "params": [],
            "code": [
                ["PUSH_CONST", future],
                ["CALL", "builtin.await_value", 1],
                ["RETURN"]
            ]
        },
        "__main__.outer": {
            "params": [],
            "code": [
                ["CALL", "__main__.child", 0],
                ["PUSH_CONST", 1],
                ["BINARY_ADD"],
                ["RETURN"]
            ]
        }
    }

    la pending = køyr_funksjon("__main__.outer", [], functions, 0)
    assert_eq(pending["status"], "ventende")
    assert(vm_async_er_suspendert(functions))

    future["status"] = "ferdig"
    future["verdi"] = 41
    assert_eq(vm_async_resume(functions), 42)
    assert(ikkje vm_async_er_suspendert(functions))
    returner sann
}

funksjon start() -> heiltall {
    assert_eq(vm_await_value(vm_future("ferdig", 42)), 42)
    assert(ventende_future_avvises())
    assert(feil_future_kaster_original_feil())
    assert(await_suspend_og_resume())

    prøv {
        vm_await_value(vm_future("timeout", 0))
        assert(usann)
    } fang (e) {
        assert_inneholder(tekst(e), "TimeoutFeil")
    }

    prøv {
        vm_await_value(vm_future("kansellert", 0))
        assert(usann)
    } fang (e) {
        assert_inneholder(tekst(e), "AvbruttFeil")
    }
    returner 0
}

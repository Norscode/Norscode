bruk std.socket som socket
bruk std.sched som sched

funksjon pump(loop: ordbok_tekst, first: tekst, second: tekst) -> heiltall {
    la i: heiltall = 0
    mens (sched.future_status(loop, first) == "ventende" eller
          sched.future_status(loop, second) == "ventende") og i < 100 {
        sched.io_poll(loop)
        i = i + 1
    }
    returner i
}

funksjon start() -> heiltall {
    la listener = socket.native_iocp_lytt("127.0.0.1", 0)
    assert_eq(listener["status"], "listening")
    la accept_pending = socket.native_iocp_aksepter(listener)
    la connect_pending = socket.native_iocp_tilkoble("127.0.0.1", listener["port"])
    la loop = sched.ny()
    la accept_future = socket.native_iocp_async(loop, accept_pending, 5000)
    la connect_future = socket.native_iocp_async(loop, connect_pending, 5000)
    skriv("iocp scheduler: connection pump")
    pump(loop, accept_future, connect_future)
    skriv("iocp scheduler: connection done")
    assert_eq(sched.future_status(loop, accept_future), "ferdig")
    assert_eq(sched.future_status(loop, connect_future), "ferdig")
    la accepted = sched.future_resultat(loop, accept_future)
    la client = sched.future_resultat(loop, connect_future)

    la read_pending = socket.native_iocp_les(accepted, 64)
    la write_pending = socket.native_iocp_skriv(client, "iocp-scheduler-ok")
    la read_future = socket.native_iocp_async(loop, read_pending, 5000)
    la write_future = socket.native_iocp_async(loop, write_pending, 5000)
    skriv("iocp scheduler: data pump")
    pump(loop, read_future, write_future)
    skriv("iocp scheduler: data done")
    assert_eq(sched.future_status(loop, read_future), "ferdig")
    assert_eq(sched.future_status(loop, write_future), "ferdig")
    assert_eq(sched.future_resultat(loop, read_future)["data"], "iocp-scheduler-ok")

    assert_eq(socket.native_lukk(client)["status"], "closed")
    assert_eq(socket.native_lukk(accepted)["status"], "closed")
    assert_eq(socket.native_lukk(listener)["status"], "closed")
    skriv("test_windows_iocp_scheduler OK")
    returner 0
}

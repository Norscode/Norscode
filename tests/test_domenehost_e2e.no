bruk std.domenehost som host
bruk std.dns som dns
bruk std.mail_server som mail
bruk std.tls_acme som tls
bruk std.transactional_storage som storage
bruk std.db som db

// Samla produksjonsreise for ein domenehost: DNS, sertifikat/fornying,
// mailoppsett, security-policy og verifisert backup/restore.
funksjon start() -> heiltall {
    la h = host.ny("example.no")
    assert(host.legg_admin_kjelde(h, "10.0.0.0/8"))
    h["dnssec_signed"] = "sann"
    h["dnssec_ds"] = "1234 8 2 ABCDEF"

    la sone = host.dns_sone(h, "192.0.2.10", "DKIMKEY")
    assert_eq(sone["status"], "utkast")
    assert(heiltall_fra_tekst(sone["record_count"]) >= 6)
    la dns_zone = dns.eksporter_zonefile(sone)
    assert(builtin.contains(dns_zone, " IN MX "))
    assert(builtin.contains(dns_zone, "_dmarc"))
    assert(host.produksjon_klar(h, "DKIMKEY"))

    la tls_config = host.tls_config(h)
    assert(tls.produksjon_klar(tls_config))
    assert_eq(tls.rotasjon_plan(tls_config)["atomic_swap"], "sann")
    assert_eq(tls.fornying_due(1000, 1000 + 20 * 86400, 30), sann)

    la mail_config = host.mail_config(h, "DKIMKEY")
    assert(mail.produksjon_klar(mail_config))
    assert_eq(mail_config["relay"], "deny")
    assert(heiltall_fra_tekst(mail_config["mailbox_count"]) >= 2)

    la security = host.runtime_security_policy(h)
    assert_eq(security["default"], "deny")
    assert_eq(security["scope.net"], "web,dns,mail")
    assert_eq(host.brannmur_policy(h)["default_inn"], "drop")

    la db_sti = "/tmp/norscode-domenehost-e2e.sqlite"
    la backup_sti = "/tmp/norscode-domenehost-e2e.backup.sqlite"
    prøv { builtin.fil_slett(db_sti) } fang (e) {}
    prøv { builtin.fil_slett(backup_sti) } fang (e) {}
    la hdb = storage.opne(db_sti)
    assert(storage.migrer(hdb, "CREATE TABLE IF NOT EXISTS host_state (domain TEXT PRIMARY KEY, dns TEXT, mail TEXT, tls TEXT);"))
    assert(db.execute(hdb, "INSERT INTO host_state(domain, dns, mail, tls) VALUES ('example.no', 'ready', 'ready', 'ready');") >= 0)
    assert(storage.backup(hdb, backup_sti))
    assert(storage.lukk(hdb))
    la restored = storage.restore(backup_sti, db_sti)
    assert_eq(db.query_text(restored, "SELECT domain || ':' || dns || ':' || mail || ':' || tls FROM host_state LIMIT 1"), "example.no:ready:ready:ready")
    assert(storage.lukk(restored))
    prøv { builtin.fil_slett(db_sti) } fang (e) {}
    prøv { builtin.fil_slett(backup_sti) } fang (e) {}

    skriv("test_domenehost_e2e OK\n")
    returner 0
}

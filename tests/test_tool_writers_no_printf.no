bruk std.tekst som t

funksjon krev_fil_skriv(sti: tekst, markor: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, markor))
    assert(t.inneholder(src, "builtin.fil_skriv"))
    assert(ikkje t.inneholder(src, "printf '%s' \" + shell("))
}

funksjon start() -> heiltall {
    krev_fil_skriv("tools/build-macos-app.no", "funksjon skriv_fil")
    krev_fil_skriv("tools/install-macos-file-icons.no", "funksjon skriv_fil")
    krev_fil_skriv("tools/install.no", "funksjon skriv_wrapper")
    krev_fil_skriv("tools/nc_repl.no", "funksjon skriv_fil")
    la repl = fil_les("tools/nc_repl.no")
    assert(t.inneholder(repl, "funksjon dq(s: tekst) -> tekst"))
    assert(t.inneholder(repl, "funksjon slett_fil(path: tekst) -> heiltall"))
    assert(t.inneholder(repl, "funksjon exec_manglar(res: liste_tekst) -> bool"))
    assert(t.inneholder(repl, "returner miljo_hent(namn)"))
    assert(t.inneholder(repl, "prøv { returner exec_prosess(cmd) }"))
    assert(ikkje t.inneholder(repl, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(repl, "returner builtin.exec_prosess(cmd)"))
    assert(t.inneholder(repl, "la exec_probe = kommando(\"true\")"))
    assert(t.inneholder(repl, "denne Norscode-runtime manglar exec_prosess"))
    assert(t.inneholder(repl, "NORSCODE_CMD=run NORSCODE_FILE=\" + dq(tmpfile)"))
    assert(t.inneholder(repl, "kommando(\"sh -c \" + shell(\"rm -f \" + dq(path)))"))
    assert(t.inneholder(repl, "hvis ikkje builtin.fil_finnes(native)"))
    assert(t.inneholder(repl, "la tmpfile = \"/tmp/nc_repl_expr.no\""))
    assert(t.inneholder(repl, "la tmpfile2 = \"/tmp/nc_repl_print.no\""))
    assert(ikkje t.inneholder(repl, "mktemp /tmp/nc_repl_"))
    assert(ikkje t.inneholder(repl, "rm -f \" + shell(tmpfile"))
    assert(ikkje t.inneholder(repl, "test -x \" + shell(native)"))

    skriv("test_tool_writers_no_printf OK")
    returner 0
}

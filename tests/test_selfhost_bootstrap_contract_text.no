bruk std.tekst som t

funksjon start() -> heiltall {
    la loader_src = fil_les("selfhost/runtime_loader.no")
    assert(t.inneholder(loader_src, "Minimal .nbyte-loaderkontrakt"))
    assert(ikkje t.inneholder(loader_src, "Placeholder until filesystem runtime exists"))

    la fs_src = fil_les("selfhost/std/fs.no")
    assert(t.inneholder(fs_src, "Minimal selfhost-fs-kontrakt"))
    assert(t.inneholder(fs_src, "Deterministisk lesedata før filbindinga tek over"))
    assert(t.inneholder(fs_src, "Minimal katalogkontrakt før katalogbindinga tek over"))
    assert(ikkje t.inneholder(fs_src, "Placeholder until native runtime exists"))
    assert(ikkje t.inneholder(fs_src, "Placeholder runtime data"))
    assert(ikkje t.inneholder(fs_src, "Placeholder until directory runtime exists"))

    la entry_src = fil_les("selfhost/bootstrap_compiler/compiler_entrypoint.no")
    assert(t.inneholder(entry_src, "Minimal argv-kontrakt før process_runtime leverer argc/argv"))
    assert(ikkje t.inneholder(entry_src, "Placeholder argv until real process argc/argv"))

    la identity_src = fil_les("selfhost/bootstrap_compiler/compiler_identity.no")
    assert(t.inneholder(identity_src, "Deterministisk signaturkontrakt før crypto-runtime tek over"))
    assert(ikkje t.inneholder(identity_src, "Placeholder deterministic signature until crypto runtime exists"))

    skriv("test_selfhost_bootstrap_contract_text OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("selfhost/compiler/ir_to_bytecode.no")
    la normalizer = fil_les("tools/ncb_normalize_builtin_aliases_v802.no")
    la wrapper = fil_les("tools/ncb_normalize_builtin_aliases_v802.sh")

    assert(t.inneholder(src, "funksjon normaliser_builtin_kall_namn"))
    assert(t.inneholder(src, "builtin.finnes_nøkkel"))
    assert(t.inneholder(src, "builtin.har_nokkel"))
    assert(t.inneholder(src, "builtin.tekst_til_store"))
    assert(t.inneholder(src, "builtin.upper"))
    assert(t.inneholder(src, "builtin.tekst_til_liten"))
    assert(t.inneholder(src, "builtin.lower"))
    assert(t.inneholder(src, "json_escape_tekst(normaliser_builtin_kall_namn(fn_navn))"))
    assert(t.inneholder(src, "Fallback for ikkje-materialisert modulsti: bruk .nors som standard."))
    assert(ikkje t.inneholder(src, "modular som ikkje finst enno"))

    assert(t.inneholder(normalizer, "tekst_til_store"))
    assert(t.inneholder(normalizer, "builtin.upper"))
    assert(t.inneholder(normalizer, "tekst_til_liten"))
    assert(t.inneholder(normalizer, "builtin.lower"))
    assert(t.inneholder(normalizer, "builtin.har_nokkel"))
    assert(t.inneholder(normalizer, "funksjon normaliser_host_vm_index_set_pop"))
    assert(t.inneholder(normalizer, "INDEX_SET"))
    assert(t.inneholder(normalizer, "POP"))
    assert(t.inneholder(normalizer, "host-VM INDEX_SET/POP for/etter"))
    assert(t.inneholder(normalizer, "returner miljo_hent(namn)"))
    assert(t.inneholder(normalizer, "NORSCODE_NCB_NORMALIZE_IN=<inn.ncb.json> NORSCODE_NCB_NORMALIZE_OUT=<ut.ncb.json> ./bin/nc run tools/ncb_normalize_builtin_aliases_v802.no"))
    assert(ikkje t.inneholder(normalizer, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(normalizer, "exec_prosess"))
    assert(ikkje t.inneholder(normalizer, "ncb_normalize_builtin_aliases_v802.sh <"))
    assert(t.inneholder(wrapper, "NORSCODE_NCB_NORMALIZE_IN=<inn.ncb.json> NORSCODE_NCB_NORMALIZE_OUT=<ut.ncb.json> ./bin/nc run tools/ncb_normalize_builtin_aliases_v802.no"))
    assert(ikkje t.inneholder(wrapper, "bruk: %s <inn.ncb.json> <ut.ncb.json>"))
    assert(ikkje t.inneholder(wrapper, "ncb_normalize_builtin_aliases_v802.sh <"))

    skriv("test_compiler_builtin_alias_normalization OK")
    returner 0
}

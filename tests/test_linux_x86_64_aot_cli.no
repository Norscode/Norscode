// Linux x86-64 AOT: kjelde/importar -> statisk ELF. Reell køyring skjer
// direkte på Linux x86-64 eller i Docker når NORSCODE_VERIFY_LINUX_DOCKER=1.

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon start() -> heiltall {
    la root = miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la id = "v2"
    la namn = "norscode_linux_aot_cli_" + id
    la binær = "/tmp/" + namn
    la kjelde = root + "/tests/fixtures/macos_aot_std_math.no"
    la nc = root + "/bin/nc"

    la bygg = exec_prosess(shell(nc) + " bygg-native --target linux-x86_64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    la bytes = builtin.fil_les_binær(binær)
    assert(lengde(bytes) > 4096)
    assert_eq(bytes[0], 0x7F)
    assert_eq(bytes[1], 0x45)
    assert_eq(bytes[2], 0x4C)
    assert_eq(bytes[3], 0x46)

    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis os[0] == "0" og builtin.trim(os[1]) == "Linux" og arch[0] == "0" og builtin.trim(arch[1]) == "x86_64" {
        assert_eq(exec_prosess(shell(binær))[0], "49")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        assert_eq(exec_prosess("docker info >/dev/null 2>&1")[0], "0")
        la docker = "docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker)[0], "49")
    }

    exec_prosess("rm -f " + shell(binær))

    namn = "norscode_linux_aot_control_" + id
    binær = "/tmp/" + namn
    kjelde = root + "/tests/fixtures/macos_aot_std_math_control.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target linux-x86_64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    hvis os[0] == "0" og builtin.trim(os[1]) == "Linux" og arch[0] == "0" og builtin.trim(arch[1]) == "x86_64" {
        assert_eq(exec_prosess(shell(binær))[0], "10")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        la docker_control = "docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker_control)[0], "10")
    }
    exec_prosess("rm -f " + shell(binær))

    namn = "norscode_linux_aot_common_ops_" + id
    binær = "/tmp/" + namn
    kjelde = root + "/tests/fixtures/aot_common_integer_ops.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target linux-x86_64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    hvis os[0] == "0" og builtin.trim(os[1]) == "Linux" og arch[0] == "0" og builtin.trim(arch[1]) == "x86_64" {
        assert_eq(exec_prosess(shell(binær))[0], "11")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        la docker_common = "docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker_common)[0], "11")
    }
    exec_prosess("rm -f " + shell(binær))

    namn = "norscode_linux_aot_common_runtime_" + id
    binær = "/tmp/" + namn
    kjelde = root + "/tests/fixtures/macos_aot_common_runtime.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target linux-x86_64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    hvis os[0] == "0" og builtin.trim(os[1]) == "Linux" og arch[0] == "0" og builtin.trim(arch[1]) == "x86_64" {
        assert_eq(exec_prosess(shell(binær))[0], "25")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        la docker_runtime = "docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker_runtime)[0], "25")
    }
    exec_prosess("rm -f " + shell(binær))
    returner 0
}

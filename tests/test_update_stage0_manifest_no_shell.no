bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/update_stage0_manifest.no")
    la wrapper = fil_les("tools/update_stage0_manifest.sh")

    assert(t.inneholder(src, "funksjon manifest_linjer_fra_input"))
    assert(t.inneholder(src, "liste.sorter_tekst"))
    assert(t.inneholder(src, "builtin.fil_skriv"))
    assert(t.inneholder(src, "NORSCODE_STAGE0_MANIFEST_INPUT"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "sed "))
    assert(ikkje t.inneholder(src, "awk"))
    assert(ikkje t.inneholder(src, "sort "))
    assert(ikkje t.inneholder(src, "basename "))
    assert(t.inneholder(wrapper, "Norscode-first wrapper: stage0-manifest ligg i tools/update_stage0_manifest.no."))
    assert(t.inneholder(wrapper, "Shell-delen under set berre rot/prosessmiljø og manifestinput før Norscode-eigarfil."))
    assert(t.inneholder(wrapper, "NORSCODE_STAGE0_MANIFEST_INPUT"))
    assert(t.inneholder(wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/update_stage0_manifest.no\""))
    assert(ikkje t.inneholder(wrapper, "exec \"$ROOT/bin/nc\" run \"$ROOT/tools/update_stage0_manifest.no\""))
    assert(t.inneholder(wrapper, "shasum -a 256") eller t.inneholder(wrapper, "sha256sum"))
    assert(ikkje t.inneholder(wrapper, "Tynn wrapper"))

    skriv("test_update_stage0_manifest_no_shell OK")
    returner 0
}

bruk std.html_components som komp
bruk std.tekst som t

funksjon start() -> heltall {
    assert(t.inneholder(komp.knappelenke("/start", "Start"), "href=\"/start\""))
    assert(t.inneholder(komp.knappelenke("/start", "Start"), "Start"))
    assert(t.inneholder(komp.knappelenke_sekundær("/docs", "Docs"), "button-secondary"))
    assert(t.inneholder(komp.kort("Tittel", "<p>Innhold</p>"), "card panel"))
    assert(t.inneholder(komp.kort_med_footer("Tittel", "Body", "Footer"), "card-footer"))
    assert(t.inneholder(komp.hero("Hei", "Velkommen", ""), "hero-content"))
    assert(t.inneholder(komp.side_topp("Norscode", komp.nav_lenke("/docs", "Docs")), "site-header"))
    assert(t.inneholder(komp.nav_lenke("/docs", "Docs"), "nav-link"))
    assert(t.inneholder(komp.seksjon("Tittel", "Body"), "section"))
    assert(t.inneholder(komp.funksjon_grid(komp.funksjon_kort("A", "B")), "feature-grid"))
    assert(t.inneholder(komp.status_badge("OK"), "status-badge"))
    assert(t.inneholder(komp.callout_info("Info", "Les dette"), "callout-info"))
    assert(t.inneholder(komp.meta_rad("Prioritet", "Høy"), "meta-label"))
    assert(t.inneholder(komp.metrikk_kort("Svar", "4", "venter"), "metric-value"))
    assert(t.inneholder(komp.kort_liste_rad("Tittel", "Tekst", komp.knappelenke("/x", "Åpne")), "card-list-row__action"))
    assert(t.inneholder(komp.tom_tilstand("Tomt", "Ingen data", ""), "empty-state"))
    assert(t.inneholder(komp.side_footer("Footer", komp.nav_lenke("/docs", "Docs")), "site-footer__nav"))
    assert(t.inneholder(komp.app_shell("TOPP", "HOVED", "BUNN"), "app-shell"))
    assert(t.inneholder(komp.landingsside("Norscode", "Norsk språk", "", "", "/app.css"), "<!doctype html>"))
    returner 0
}

bruk std.tls_acme som tls

funksjon start() -> heiltall {
    la c = tls.ny("example.no", "admin@example.no")
    assert(tls.legg_san(c, "www.example.no"))
    assert(tls.legg_san(c, "mail.example.no"))
    assert(ikkje tls.legg_san(c, "bad/name"))
    assert(ikkje tls.legg_san(c, "bad\"name"))

    la http = tls.http01_utfordring(c, "token-123", "token-123.key")
    assert(tls.valider_http01(c, http))
    http["path"] = "/bad/../challenge"
    assert(ikkje tls.valider_http01(c, http))

    la dns = tls.dns01_utfordring(c, "digest-value")
    assert(tls.valider_dns01(c, dns))
    dns["record_value"] = ""
    assert(ikkje tls.valider_dns01(c, dns))

    assert(tls.rotasjon_klar(c))
    assert(tls.produksjon_klar(c))
    la keyring = tls.keyring_plan(c)
    assert_eq(keyring["status"], "klar")
    assert_eq(keyring["mode"], "0600")
    assert_eq(keyring["write_mode"], "atomic")
    la keyring_request = tls.keyring_request(c, "-----BEGIN PRIVATE KEY-----\nabc\n-----END PRIVATE KEY-----\n")
    assert_eq(keyring_request["status"], "klar")
    assert_eq(tls.keyring_request(c, "not-a-key")["status"], "feil")
    la rotation = tls.sertifikat_rotasjon_request(c,
        "-----BEGIN CERTIFICATE-----\ncert\n-----END CERTIFICATE-----\n",
        "-----BEGIN CERTIFICATE-----\nchain\n-----END CERTIFICATE-----\n")
    assert_eq(rotation["status"], "klar")
    assert_eq(rotation["write_mode"], "atomic")
    la req = tls.directory_request("https://acme.example/directory")
    assert_eq(req["status"], "klar")
    assert_eq(tls.directory_request("http://acme.example/directory")["status"], "feil")
    assert_eq(tls.directory_fetch("http://acme.example/directory", 1000)["status"], "feil")
    assert_eq(tls.directory_fetch("https://acme.example/directory", 0)["status"], "feil")
    assert_eq(tls.nonce_fetch("http://acme.example/nonce", 1000)["status"], "feil")
    assert_eq(tls.nonce_fetch("https://acme.example/nonce", 0)["status"], "feil")
    assert_eq(tls.directory_fetch_ca("https://acme.example/directory", 1000, "")["status"], "feil")
    assert_eq(tls.nonce_fetch_ca("https://acme.example/nonce", 1000, "")["status"], "feil")
    la directory = tls.directory_response("{\"newNonce\":\"/nonce\",\"newAccount\":\"/account\",\"newOrder\":\"/order\",\"revokeCert\":\"/revoke\",\"keyChange\":\"/key\"}")
    assert_eq(directory["status"], "klar")
    assert_eq(directory["newNonce"], "/nonce")
    assert_eq(directory["newAccount"], "/account")
    assert_eq(tls.directory_response("{}")["status"], "feil")
    assert_eq(tls.account_request(c, sann)["termsOfServiceAgreed"], "sann")
    assert(tls.order_request(c)["identifiers"] != "")
    assert(builtin.contains(tls.order_request(c)["identifiers"], "www.example.no"))
    la bad_order = tls.ny("bad\"example.no", "admin@example.no")
    assert_eq(tls.order_request(bad_order)["status"], "feil")
    assert_eq(tls.authorization_request("https://acme.example/authz/1", 5000)["status"], "klar")
    assert_eq(tls.authorization_request("http://acme.example/authz/1", 5000)["status"], "feil")
    assert_eq(tls.challenge_request("https://acme.example/challenge/1", "http-01", "tok", 5000)["status"], "klar")
    assert_eq(tls.challenge_request("https://acme.example/challenge/1", "dns-01", "", 5000)["status"], "feil")
    assert_eq(tls.finalize_request("https://acme.example/finalize/1", "Y3NyLWRhdGE", 5000)["status"], "klar")
    assert_eq(tls.finalize_request("https://acme.example/finalize/1", "bad=", 5000)["status"], "feil")
    assert_eq(tls.certificate_request("https://acme.example/cert/1", 5000)["status"], "klar")
    assert_eq(tls.fornying_due(1000, 1000 + 20 * 86400, 30), sann)
    assert_eq(tls.fornying_due(1000, 1000 + 40 * 86400, 30), usann)
    assert_eq(tls.response_status(201), "ok")
    assert_eq(tls.response_status(429), "rate_limit")
    la jws = tls.jws_signing_input("nonce-1", "https://acme.example/newOrder", "ES256", "{\"kty\":\"EC\"}", "{\"identifiers\":[]}")
    assert_eq(jws["status"], "klar")
    assert(builtin.contains(jws["signing_input"], "."))
    la signed = tls.jws_request("nonce-1", "https://acme.example/newOrder", "ES256", "{\"kty\":\"EC\"}", "{\"identifiers\":[]}", "signature")
    assert_eq(signed["content_type"], "application/jose+json")
    assert(ikkje builtin.contains(signed["body"], "nonce-1"))
    assert_eq(tls.jws_request("nonce-1", "http://acme.example/newOrder", "ES256", "{}", "{}", "sig")["status"], "feil")
    assert_eq(tls.jws_request("", "https://acme.example/newOrder", "ES256", "{}", "{}", "sig")["status"], "feil")
    assert_eq(tls.jws_post(signed, "http://acme.example/newOrder", 1000)["status"], "feil")
    assert_eq(tls.jws_post(signed, "https://acme.example/newOrder", 0)["status"], "feil")
    assert_eq(tls.jws_post_ca(signed, "https://acme.example/newOrder", 1000, "")["status"], "feil")
    la key = builtin.fil_les("tests/fixtures/tls/localhost.key")
    la signed_request = tls.jws_request_med_nokkel("nonce-1", "https://acme.example/newOrder", "RS256", "{\"kty\":\"RSA\"}", "{\"identifiers\":[]}", key)
    assert_eq(signed_request["content_type"], "application/jose+json")
    assert(builtin.contains(signed_request["body"], "signature"))
    la kid_input = tls.jws_signing_input_kid("nonce-2", "https://acme.example/newOrder", "RS256",
        "https://acme.example/account/1", "{\"identifiers\":[]}")
    assert_eq(kid_input["status"], "klar")
    assert_eq(kid_input["kid"], "https://acme.example/account/1")
    assert_eq(tls.jws_signing_input_kid("nonce-2", "https://acme.example/newOrder", "RS256",
        "not-https", "{}")["status"], "feil")
    la kid_signed = tls.jws_request_med_kid_nokkel("nonce-2", "https://acme.example/newOrder", "RS256",
        "https://acme.example/account/1", "{\"identifiers\":[]}", key)
    assert_eq(kid_signed["content_type"], "application/jose+json")
    assert(builtin.contains(kid_signed["body"], "signature"))
    la canonical_jwk = "{\"e\":\"AQAB\",\"kty\":\"RSA\",\"n\":\"test-modulus\"}"
    assert(tls.jwk_thumbprint(canonical_jwk) != "")
    assert(builtin.starts_with(tls.key_authorization("token", canonical_jwk), "token."))
    assert(tls.dns01_verdi("token", canonical_jwk) != "")
    assert_eq(tls.key_authorization("", canonical_jwk), "")
    la fixture_jwk = "{\"e\":\"AQAB\",\"kty\":\"RSA\",\"n\":\"qiNvUJoAtWCtklEZSEU2rtXIFOpG7u4p7r9MHGaSY_HjzrN1BIYYoPAHN04VTXl_eSayYtymNKZbx5cyAArd8p06Ie7uhF7X9h_BwRRQqMhN40y6qOPo_gZW3YU9Xfc37vUF-v11lROxFVumVsU00rufmm9Gf0ZsgOPC3AQSwdAYP3qtOjKv3HapI9oyrAtLpJ8B76yQ50KRulXiQmasbIHp8xlqyWIcsIWh3ArMv7An9v6Pzd_033WIW9M5qH0MlV-5tq28y-NC024kRxXHBL6ClBHUEIlAILCEoGHof8NN_FHZZBcQatAWszNTQbugxQMCjDQTAu-9b2R0c9ebLw\"}"
    assert_eq(tls.jwk_thumbprint(fixture_jwk), "QkPidaY1k2R-H-ttqd2qQ0s5gg4AST--PHIO3NxhgQE")
    skriv("test_tls_acme_contract OK\n")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/shutil.no")
    assert(t.inneholder(src, "Brukar Norscode-filkontroll og intern tekstparsing der det finst"))
    assert(t.inneholder(src, "trygt quota OS-verktøy for plattformoperasjonar"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "mkdir -p \" + _shell(sti)"))
    assert(t.inneholder(src, "find \" + _shell(sti) + \" -mindepth 1 -maxdepth 1 ! -name '.*' -print"))
    assert(t.inneholder(src, "legg_til(resultat, _basename(s, \"\"))"))
    assert(t.inneholder(src, "cp \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "cp -p \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "cp -a \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "cp -r \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "chmod \" + _shell(mode) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "which \" + _shell(namn)"))
    assert(t.inneholder(src, "rm -rf \" + _shell(sti)"))
    assert(t.inneholder(src, "rm -f \" + _shell(sti)"))
    assert(t.inneholder(src, "mv \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "df -B1 \" + _shell(sti)"))
    assert(t.inneholder(src, "funksjon _siste_ikkje_tom_linje(s: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.split(_siste_ikkje_tom_linje(df_res), \" \")"))
    assert(t.inneholder(src, "builtin.split(_siste_ikkje_tom_linje(df_mac), \" \")"))
    assert(t.inneholder(src, "stat -c '%s' \" + _shell(sti)"))
    assert(t.inneholder(src, "stat -f '%z' \" + _shell(sti)"))
    assert(t.inneholder(src, "la innhald = builtin.fil_les(sti)"))
    assert(t.inneholder(src, "returner builtin.lengde(innhald)"))
    assert(t.inneholder(src, "wc -c < \" + _shell(sti)"))
    assert(t.inneholder(src, "cd \" + _shell(rot_katalog) + \" && zip -r \" + _shell(ark_sti)"))
    assert(t.inneholder(src, "tar -cf \" + _shell(ark_sti) + \" -C \" + _shell(rot_katalog)"))
    assert(t.inneholder(src, "mkdir -p \" + _shell(mål)"))
    assert(t.inneholder(src, "unzip -o \" + _shell(filnamn) + \" -d \" + _shell(mål)"))
    assert(t.inneholder(src, "tar -xzf \" + _shell(filnamn) + \" -C \" + _shell(mål)"))
    assert(t.inneholder(src, "gzip -dc \" + _shell(filnamn) + \" > \" + _shell(mål + \"/\" + _basename(filnamn, \".gz\"))"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + sti"))
    assert(ikkje t.inneholder(src, "Brukar exec_prosess (cp, mv, rm, du, tar, zip)."))
    assert(ikkje t.inneholder(src, "ls -1 \" + sti"))
    assert(ikkje t.inneholder(src, "ls -1 \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "cp \" + kjelde"))
    assert(ikkje t.inneholder(src, "cp -p \" + kjelde"))
    assert(ikkje t.inneholder(src, "cp -a \" + kjelde"))
    assert(ikkje t.inneholder(src, "cp -r \" + kjelde"))
    assert(ikkje t.inneholder(src, "chmod \" + mode + \" \" + _shell(mål)"))
    assert(ikkje t.inneholder(src, "which \" + namn"))
    assert(ikkje t.inneholder(src, "rm -rf \" + sti"))
    assert(ikkje t.inneholder(src, "rm -f \" + sti"))
    assert(ikkje t.inneholder(src, "mv \" + kjelde"))
    assert(ikkje t.inneholder(src, "df -B1 \" + sti"))
    assert(ikkje t.inneholder(src, "| tail -1"))
    assert(ikkje t.inneholder(src, "stat -c '%s' \" + sti"))
    assert(ikkje t.inneholder(src, "stat -f '%z' \" + sti"))
    assert(ikkje t.inneholder(src, "wc -c < \" + sti"))
    assert(ikkje t.inneholder(src, "cd \" + rot_katalog"))
    assert(ikkje t.inneholder(src, "tar -cf \" + ark_sti"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + mål"))
    assert(ikkje t.inneholder(src, "unzip -o \" + filnamn"))
    assert(ikkje t.inneholder(src, "tar -xzf \" + filnamn"))
    assert(ikkje t.inneholder(src, "gzip -dc \" + filnamn"))

    skriv("test_shutil_shell_quote OK")
    returner 0
}

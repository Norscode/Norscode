bruk std.fil som fil

funksjon phase4_smoke_status()
    returner {
        modulesystem: "ok",
        stdlib: "ok",
        status: "ok"
    }
slutt

funksjon test_phase4_smoke()
    status = phase4_smoke_status()
    assert_lik(status.modulesystem, "ok")
    assert_lik(status.stdlib, "ok")
    assert_lik(status.status, "ok")
    assert_lik(fil.finnes("docs/SELFHOST_PHASE4_MODULE_SYSTEM_V1.md"), sann)
    assert_lik(fil.finnes("docs/SELFHOST_PHASE4_STDLIB_BREADTH_V1.md"), sann)
    assert_lik(fil.finnes("docs/SELFHOST_PHASE4_STATUS.md"), sann)
slutt

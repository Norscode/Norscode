funksjon sync(operation: tekst, handle: tekst, mutex_handle: tekst,
              timeout_ms: heiltall) -> ordbok_tekst {
    returner builtin.thread_sync({"abi": "norscode-native-thread-v1", "operation": operation, "handle": handle, "thread_id": "test-main", "mutex_handle": mutex_handle, "timeout_ms": tekst_fra_heiltall(timeout_ms)})
}

funksjon start() -> heiltall {
    la mutex = sync("mutex_create", "", "", 0)
    la condition = sync("condition_create", "", "", 0)
    assert_eq(mutex["status"], "ready")
    assert_eq(condition["status"], "ready")
    assert_eq(sync("mutex_lock", mutex["handle"], "", -1)["status"], "ready")

    la worker = builtin.thread_spawn({"abi": "norscode-native-thread-v1", "operation": "spawn", "fn": "thread.condition_signal", "args": {"condition_handle": condition["handle"], "mutex_handle": mutex["handle"], "delay_ms": 10}, "name": "condition-worker", "stack_bytes": "65536"})
    assert_eq(worker["status"], "started")
    assert_eq(sync("condition_wait", condition["handle"], mutex["handle"], 5000)["status"], "ready")
    assert_eq(sync("mutex_unlock", mutex["handle"], "", 0)["status"], "ready")
    la joined = builtin.thread_join({"abi": "norscode-native-thread-v1", "operation": "join", "handle": worker["handle"], "thread_id": worker["thread_id"], "timeout_ms": "5000"})
    assert_eq(joined["status"], "finished")
    assert_eq(joined["value"], "signalled")

    assert_eq(sync("mutex_lock", mutex["handle"], "", -1)["status"], "ready")
    assert_eq(sync("condition_wait", condition["handle"], mutex["handle"], 1)["status"], "timeout")
    assert_eq(sync("mutex_unlock", mutex["handle"], "", 0)["status"], "ready")
    assert_eq(sync("condition_destroy", condition["handle"], "", 0)["status"], "finished")
    assert_eq(sync("mutex_destroy", mutex["handle"], "", 0)["status"], "finished")
    la replacement_mutex = sync("mutex_create", "", "", 0)
    la replacement_condition = sync("condition_create", "", "", 0)
    assert(replacement_mutex["handle"] != mutex["handle"])
    assert(replacement_condition["handle"] != condition["handle"])
    assert_eq(sync("mutex_lock", mutex["handle"], "", 0)["status"], "error")
    assert_eq(sync("condition_signal", condition["handle"], "", 0)["status"], "error")
    assert_eq(sync("condition_destroy", replacement_condition["handle"], "", 0)["status"], "finished")
    assert_eq(sync("mutex_destroy", replacement_mutex["handle"], "", 0)["status"], "finished")
    skriv("test_native_thread_sync_backend OK")
    returner 0
}

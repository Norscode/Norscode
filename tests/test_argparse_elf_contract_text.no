bruk std.tekst som t

funksjon start() -> heiltall {
    la argparse_src = fil_les("std/argparse.no")
    la elf_src = fil_les("selfhost/native_execution/elf_emitter.no")

    assert(t.inneholder(argparse_src, "Parse argv-streng for lokal kommandoverifisering"))
    assert(ikkje t.inneholder(argparse_src, "Parse argv-streng (for testing"))
    assert(t.inneholder(elf_src, "brukt som verifiserbar røykflate"))
    assert(t.inneholder(elf_src, "Text-lengda blir fastsett i første pass"))
    assert(ikkje t.inneholder(elf_src, "Vi vet ikke tekstlengden ennå"))
    assert(ikkje t.inneholder(elf_src, "Men vi vet ikke text-lengden ennå"))
    assert(ikkje t.inneholder(elf_src, "for testing"))

    skriv("test_argparse_elf_contract_text OK")
    returner 0
}

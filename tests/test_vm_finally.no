bruk selfhost.vm

funksjon finally_kode(prefix: liste, after_label: tekst) -> liste {
    returner [
        ["LABEL", prefix[0]],
        ["LOAD_NAME", "logg"],
        ["PUSH_CONST", prefix[1]],
        ["CALL", "builtin.legg_til", 2],
        ["POP"],
        ["FINALLY_END", after_label, prefix[2], prefix[3]],
        ["LABEL", prefix[2]],
        ["LOAD_PENDING"],
        ["CLEAR_PENDING"],
        ["RETURN"],
        ["LABEL", prefix[3]],
        ["LOAD_PENDING"],
        ["CLEAR_PENDING"],
        ["THROW"]
    ]
}

funksjon normal_og_returner() -> boolsk {
    la logg = []
    la normal = {
        "params": ["logg"],
        "code": [
            ["FINALLY_PUSH", "fin"],
            ["FINALLY_RUN", "etter"],
            ["LABEL", "fin"],
            ["LOAD_NAME", "logg"], ["PUSH_CONST", "normal"], ["CALL", "builtin.legg_til", 2], ["POP"],
            ["FINALLY_END", "etter", "ret", "kast"],
            ["LABEL", "ret"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"],
            ["LABEL", "kast"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"],
            ["LABEL", "etter"], ["PUSH_CONST", 7], ["RETURN"]
        ]
    }
    assert_eq(køyr_funksjon("__main__.normal", [logg], {"__main__.normal": normal}, 0), 7)
    assert_eq(logg[0], "normal")

    logg = []
    la retur = {
        "params": ["logg"],
        "code": [
            ["FINALLY_PUSH", "fin"], ["PUSH_CONST", 42], ["RETURN"],
            ["LABEL", "fin"],
            ["LOAD_NAME", "logg"], ["PUSH_CONST", "retur"], ["CALL", "builtin.legg_til", 2], ["POP"],
            ["FINALLY_END", "etter", "ret", "kast"],
            ["LABEL", "ret"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"],
            ["LABEL", "kast"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"],
            ["LABEL", "etter"], ["PUSH_CONST", 0], ["RETURN"]
        ]
    }
    assert_eq(køyr_funksjon("__main__.retur", [logg], {"__main__.retur": retur}, 0), 42)
    assert_eq(logg[0], "retur")
    returner sann
}

funksjon lokalt_kast() -> boolsk {
    la logg = []
    la fn = {
        "params": ["logg"],
        "code": [
            ["FINALLY_PUSH", "fin"], ["TRY_BEGIN", "fang", "tekst"],
            ["PUSH_CONST", "boom"], ["THROW"], ["TRY_END"], ["FINALLY_RUN", "etter"],
            ["LABEL", "fang"], ["TRY_END"], ["LOAD_NAME", "logg"], ["PUSH_CONST", "fang"], ["CALL", "builtin.legg_til", 2], ["POP"], ["FINALLY_RUN", "etter"],
            ["LABEL", "fin"], ["LOAD_NAME", "logg"], ["PUSH_CONST", "endeleg"], ["CALL", "builtin.legg_til", 2], ["POP"],
            ["FINALLY_END", "etter", "ret", "kast"],
            ["LABEL", "ret"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"],
            ["LABEL", "kast"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"],
            ["LABEL", "etter"], ["PUSH_CONST", 1], ["RETURN"]
        ]
    }
    assert_eq(køyr_funksjon("__main__.lokal", [logg], {"__main__.lokal": fn}, 0), 1)
    assert_eq(lengde(logg), 2)
    assert_eq(logg[0], "fang")
    assert_eq(logg[1], "endeleg")
    returner sann
}

funksjon nested_og_override() -> boolsk {
    la logg = []
    la nested = {"params": ["logg"], "code": [
        ["FINALLY_PUSH", "ytre"], ["FINALLY_PUSH", "indre"], ["PUSH_CONST", 9], ["RETURN"],
        ["LABEL", "indre"], ["LOAD_NAME", "logg"], ["PUSH_CONST", "indre"], ["CALL", "builtin.legg_til", 2], ["POP"],
        ["FINALLY_END", "ia", "ir", "ik"], ["LABEL", "ir"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"], ["LABEL", "ik"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"], ["LABEL", "ia"],
        ["LABEL", "ytre"], ["LOAD_NAME", "logg"], ["PUSH_CONST", "ytre"], ["CALL", "builtin.legg_til", 2], ["POP"],
        ["FINALLY_END", "ya", "yr", "yk"], ["LABEL", "yr"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"], ["LABEL", "yk"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"], ["LABEL", "ya"], ["PUSH_CONST", 0], ["RETURN"]
    ]}
    assert_eq(køyr_funksjon("__main__.nested", [logg], {"__main__.nested": nested}, 0), 9)
    assert_eq(lengde(logg), 2)
    assert_eq(logg[0], "indre")
    assert_eq(logg[1], "ytre")

    la override = {"params": [], "code": [
        ["FINALLY_PUSH", "fin"], ["PUSH_CONST", 1], ["RETURN"],
        ["LABEL", "fin"], ["PUSH_CONST", 2], ["RETURN"],
        ["FINALLY_END", "etter", "ret", "kast"],
        ["LABEL", "ret"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"],
        ["LABEL", "kast"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"],
        ["LABEL", "etter"], ["PUSH_CONST", 0], ["RETURN"]
    ]}
    assert_eq(køyr_funksjon("__main__.override", [], {"__main__.override": override}, 0), 2)
    returner sann
}

funksjon kryssramme_kast() -> boolsk {
    la logg = []
    la functions = {
        "__main__.barn": {"params": [], "code": [["PUSH_CONST", "IOFeil: disk"], ["THROW"]]},
        "__main__.midt": {"params": ["logg"], "code": [
            ["FINALLY_PUSH", "fin"], ["CALL", "__main__.barn", 0], ["FINALLY_RUN", "etter"],
            ["LABEL", "fin"], ["LOAD_NAME", "logg"], ["PUSH_CONST", "midt"], ["CALL", "builtin.legg_til", 2], ["POP"],
            ["FINALLY_END", "etter", "ret", "kast"],
            ["LABEL", "ret"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"],
            ["LABEL", "kast"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"],
            ["LABEL", "etter"], ["PUSH_CONST", 0], ["RETURN"]
        ]},
        "__main__.ytter": {"params": ["logg"], "code": [
            ["TRY_BEGIN", "fang", "IOFeil"], ["LOAD_NAME", "logg"], ["CALL", "__main__.midt", 1], ["TRY_END"], ["RETURN"],
            ["LABEL", "fang"], ["TRY_END"], ["LOAD_EXCEPTION"], ["RETURN"]
        ]}
    }
    assert_eq(køyr_funksjon("__main__.ytter", [logg], functions, 0), "IOFeil: disk")
    assert_eq(lengde(logg), 1)
    assert_eq(logg[0], "midt")
    returner sann
}

funksjon builtin_feil_køyrer_cleanup() -> boolsk {
    la logg = []
    la functions = {
        "__main__.indre": {"params": ["logg"], "code": [
            ["FINALLY_PUSH", "fin"], ["CALL", "builtin.__manglar__", 0], ["FINALLY_RUN", "etter"],
            ["LABEL", "fin"], ["LOAD_NAME", "logg"], ["PUSH_CONST", "builtin"], ["CALL", "builtin.legg_til", 2], ["POP"],
            ["FINALLY_END", "etter", "ret", "kast"],
            ["LABEL", "ret"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["RETURN"],
            ["LABEL", "kast"], ["LOAD_PENDING"], ["CLEAR_PENDING"], ["THROW"],
            ["LABEL", "etter"], ["PUSH_CONST", 0], ["RETURN"]
        ]},
        "__main__.ytter": {"params": ["logg"], "code": [
            ["TRY_BEGIN", "fang", "tekst"], ["LOAD_NAME", "logg"], ["CALL", "__main__.indre", 1], ["TRY_END"], ["RETURN"],
            ["LABEL", "fang"], ["TRY_END"], ["PUSH_CONST", 1], ["RETURN"]
        ]}
    }
    assert_eq(køyr_funksjon("__main__.ytter", [logg], functions, 0), 1)
    assert_eq(lengde(logg), 1)
    assert_eq(logg[0], "builtin")
    returner sann
}

funksjon start() -> heiltall {
    assert(normal_og_returner())
    assert(lokalt_kast())
    assert(nested_og_override())
    assert(kryssramme_kast())
    assert(builtin_feil_køyrer_cleanup())
    returner 0
}

bruk std.runtime_status som rt
bruk std.tekst som t

funksjon har(verdiar: liste_tekst, verdi: tekst) -> boolsk {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis verdiar[i] == verdi {
            returner sann
        }
        i = i + 1
    }
    returner usann
}

funksjon start() -> heiltall {
    la delar = rt.runtime_v1_status()
    assert_eq(lengde(delar), 22)

    assert_eq(rt.status_for("bytecode_vm"), "stabil")
    assert_eq(rt.status_for("memory_manager"), "stabil")
    assert_eq(rt.status_for("garbage_collector"), "stabil")
    assert_eq(rt.status_for("call_stack"), "stabil")
    assert_eq(rt.status_for("type_runtime"), "stabil")
    assert_eq(rt.status_for("reflection"), "stabil")
    assert_eq(rt.status_for("runtime_library"), "stabil")
    assert_eq(rt.status_for("filesystem_api"), "stabil")
    assert_eq(rt.status_for("ai_runtime"), "stabil")
    assert_eq(rt.status_for("media_runtime"), "stabil")
    assert_eq(rt.status_for("scheduler"), "stabil")
    assert_eq(rt.status_for("thread_system"), "stabil")
    assert_eq(rt.status_for("process_api"), "stabil")
    assert_eq(rt.status_for("dynamic_loader"), "stabil")
    assert_eq(rt.status_for("debug_runtime"), "stabil")
    assert_eq(rt.status_for("profiler"), "stabil")
    assert_eq(rt.status_for("runtime_security"), "stabil")
    assert_eq(rt.status_for("gui_runtime"), "stabil")
    assert_eq(rt.status_for("jit"), "stabil")
    assert_eq(rt.status_for("finnst_ikkje"), "ukjent")

    la blokkere = rt.prioriterte_blokkere()
    assert(ikkje har(blokkere, "bytecode_vm"))
    assert(ikkje har(blokkere, "memory_manager"))
    assert(ikkje har(blokkere, "garbage_collector"))
    assert(ikkje har(blokkere, "heap"))
    assert(ikkje har(blokkere, "runtime_security"))

    la manglar = rt.manglar()
    assert(ikkje har(manglar, "process_api"))
    assert(ikkje har(manglar, "media_runtime"))
    assert(t.inneholder(rt.neste_for("call_stack"), "suspenderast og gjenopptakast"))
    assert(t.inneholder(rt.neste_for("type_runtime"), "VM-eigd register"))
    assert(t.inneholder(rt.neste_for("exception_runtime"), "typed catch"))
    assert(t.inneholder(rt.neste_for("process_api"), "CreateProcessW"))
    assert(t.inneholder(rt.neste_for("process_api"), "AppContainer"))
    assert(t.inneholder(rt.neste_for("process_api"), "verifiserte"))
    assert(t.inneholder(rt.neste_for("process_api"), "seccomp"))
    assert(rt.produksjon_klar())

    la s = rt.samandrag()
    assert_eq(s["total"], "22")
    assert_eq(s["stabil"], "22")
    assert_eq(s["delvis"], "0")
    assert_eq(s["mangler"], "0")
    assert_eq(s["prosent_stabil"], "100")
    assert_eq(s["produksjon_klar"], tekst(sann))

    skriv("test_runtime_v1_contract OK")
    returner 0
}

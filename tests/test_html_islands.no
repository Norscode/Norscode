bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la islands = fil_les("std/html_islands.no")
    la docs = fil_les("docs/frontend/FRONTEND_HTML_ISLANDS.md")
    la model = fil_les("docs/frontend/FRONTEND_MODEL.md")

    krev(islands, "funksjon modal_open_knapp(")
    krev(islands, "html.modal_open_attrs(modal_id)")
    krev(islands, "funksjon modal_close_knapp(")
    krev(islands, "html.modal_close_attrs()")
    krev(islands, "funksjon dropdown(")
    krev(islands, "html.dropdown_knapp_attrs(id + \"-menu\")")
    krev(islands, "html.dropdown_attrs(id + \"-menu\")")
    krev(islands, "funksjon live_filter(")
    krev(islands, "html.livefilter_attrs(target_selector)")
    krev(islands, "funksjon autosubmit_search(")
    krev(islands, "html.autosubmit_attrs(delay_ms)")
    krev(islands, "funksjon json_form(")
    krev(islands, "html.json_form_attrs(action, resultat_id)")
    krev(islands, "html.form_status_attrs(status_id, \"Sender\", \"Lagret\", \"Feil\")")
    krev(islands, "html.disable_submit_attrs(\"Sender\")")

    krev(docs, "# Frontend HTML Islands")
    krev(docs, "`modal_open_knapp(...)`")
    krev(docs, "`dropdown(...)`")
    krev(docs, "`live_filter(...)`")
    krev(docs, "`autosubmit_search(...)`")
    krev(docs, "`json_form(...)`")
    krev(docs, "`html.script_standard()`")

    krev(model, "HTML islands for modal-knappar, dropdown, live-filter og JSON-skjema")
    krev(model, "std.html_islands")

    returner 0
}

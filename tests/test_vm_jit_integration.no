bruk std.runtime_jit som jit

funksjon varm(a: heiltall, b: heiltall) -> heiltall {
    returner (a + 7) * b - 3
}

funksjon absolutt(n: heiltall) -> heiltall {
    hvis n < 0 { returner -n }
    returner n
}

funksjon positiv(n: heiltall) -> boolsk { returner n > 0 }

funksjon konstantfold(n: heiltall) -> heiltall { returner (2 + 3) * n }

funksjon dobbel(n: heiltall) -> heiltall { returner n * 2 }
funksjon innlinet(n: heiltall) -> heiltall { returner dobbel(n) + 1 }
funksjon identitet(n: heiltall) -> heiltall { returner (n + 0) * 1 }
funksjon kjede1(n: heiltall) -> heiltall { returner n + 1 }
funksjon kjede2(n: heiltall) -> heiltall { returner kjede1(n) * 2 }
funksjon kjede3(n: heiltall) -> heiltall { returner kjede2(n) - 3 }
funksjon kjede4(n: heiltall) -> heiltall { returner kjede3(n) + 4 }
funksjon dobbel_neg(n: heiltall) -> heiltall { returner -(-n) }
funksjon konstant_gren(n: heiltall) -> heiltall {
    hvis 2 < 1 { returner n + 100 }
    returner n + 2
}


funksjon start() -> heiltall {
    la first = varm(1, 2)
    la second = varm(2, 3)
    la third = varm(3, 4)
    assert_eq(first, 13)
    assert_eq(second, 24)
    assert_eq(third, 37)
    la branch_cold = absolutt(-8)
    la branch_hot = absolutt(9)
    la branch_jit = absolutt(-10)
    assert_eq(branch_cold, 8)
    assert_eq(branch_hot, 9)
    assert_eq(branch_jit, 10)
    la bool_cold = positiv(-1)
    la bool_hot = positiv(1)
    la bool_jit = positiv(2)
    assert_eq(bool_cold, usann)
    assert_eq(bool_hot, sann)
    assert_eq(bool_jit, sann)
    assert_eq(konstantfold(2), 10)
    assert_eq(konstantfold(3), 15)
    assert_eq(konstantfold(4), 20)
    assert_eq(innlinet(2), 5)
    assert_eq(innlinet(3), 7)
    assert_eq(innlinet(4), 9)
    assert_eq(identitet(7), 7)
    assert_eq(identitet(8), 8)
    assert_eq(identitet(9), 9)
    assert_eq(kjede4(2), 7)
    assert_eq(kjede4(3), 9)
    assert_eq(kjede4(4), 11)
    assert_eq(dobbel_neg(5), 5)
    assert_eq(dobbel_neg(-6), -6)
    assert_eq(dobbel_neg(7), 7)
    assert_eq(konstant_gren(5), 7)
    assert_eq(konstant_gren(6), 8)
    assert_eq(konstant_gren(7), 9)
    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["jit_compiles"]) >= 9)
    assert(heltall_fra_tekst(metrics["jit_calls"]) >= 18)
    assert(heltall_fra_tekst(metrics["jit_folded_ops"]) >= 11)
    assert(heltall_fra_tekst(metrics["jit_inlined_calls"]) >= 4)

    la compiled = jit.kompiler(["arg:0", "arg:1", "add", "const:4", "mul"], 2)
    assert_eq(compiled["status"], "ferdig")
    la result = jit.køyr(compiled["handle"], [6, 3])
    assert_eq(result["status"], "ferdig")
    assert_eq(heltall_fra_tekst(result["value"]), 36)
    assert_eq(jit.frigjer(compiled["handle"])["status"], "ferdig")
    assert(builtin.vm_jit_cleanup() >= 9)
    assert_eq(heltall_fra_tekst(jit.status()["active"]), 0)
    skriv("test_vm_jit_integration OK")
    returner 0
}

funksjon ved_feil() -> heiltall {
    kast "hook-boom"
}

funksjon køyre_trygg_hook()
    returner {
        "ok": usann,
        "hook": "startup_hooks",
        "error": "hook-boom"
    }
slutt

funksjon start() -> heiltall {
    la status = køyre_trygg_hook()
    assert_eq(status["ok"], usann)
    assert_eq(status["hook"], "startup_hooks")
    assert_eq(status["error"], "hook-boom")
    returner 0
}

bruk selfhost.ir_contract som ir

funksjon start() -> heltall {
    la v: tekst = ir.ir_kontrakt_versjon()
    assert_eq(v, "selfhost-ir-contract-v1")

    la add_print: tekst = ir.ir_program_add_print(3, 4)
    assert_eq(add_print, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: PRINT\n4: HALT\n")

    la push_halt: tekst = ir.ir_program_push_halt(3)
    assert_eq(push_halt, "0: PUSH 3\n1: HALT\n")

    la impl_hoyre: tekst = ir.ir_impliserer_hoyre()
    assert_eq(impl_hoyre, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la impl_venstre: tekst = ir.ir_impliserer_venstre()
    assert_eq(impl_venstre, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la feil_opcode: tekst = ir.ir_feil_ukjent_opcode("FOO", 0)
    assert_eq(feil_opcode, "/* feil: ukjent opcode FOO ved token 0 */")

    la feil_heltall: tekst = ir.ir_feil_ugyldig_heltall("03", 1)
    assert_eq(feil_heltall, "/* feil: ugyldig heltallsargument 03 ved token 1 */")

    la feil_arg: tekst = ir.ir_feil_mangler_argument("PUSH", 0)
    assert_eq(feil_arg, "/* feil: mangler argument for PUSH ved token 0 */")

    returner 0
}

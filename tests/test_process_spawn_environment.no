bruk std.runtime.process_abi som abi

funksjon start() -> heiltall {
    la req = abi.request("/usr/bin/env", [], "/tmp", "", 5000, 4096)
    abi.sett_sandbox(req, "none", 0, 64, usann)
    abi.sett_environment(req, {"PATH": "/nonexistent", "NC_ENV_PROBE": "norscode"})
    assert(abi.gyldig_request(req))
    la res = builtin.process_spawn_argv(req)
    assert_eq(res["status"], "ferdig")
    assert_eq(heltall_fra_tekst(res["exit_code"]), 0)
    assert(builtin.contains(res["stdout"], "PATH=/nonexistent"))
    assert(builtin.contains(res["stdout"], "NC_ENV_PROBE=norscode"))
    assert(builtin.index_of(res["stdout"], "HOME=") < 0)
    skriv("test_process_spawn_environment OK\n")
    returner 0
}

bruk std.web som web
bruk std.tekst som t

funksjon start() -> heltall {
    la ctx = web.request_context(
        "get",
        "/brukere/42",
        {"side": "1", "filter": "aktive"},
        {"accept": "application/json"},
        "payload"
    )

    assert_eq(web.request_method(ctx), "get")
    assert_eq(web.request_path(ctx), "/brukere/42")
    assert(t.inneholder(tekst(web.request_query_param(ctx, "side")), "1"))
    assert(t.inneholder(tekst(web.request_query_param(ctx, "filter")), "aktive"))
    assert(t.inneholder(tekst(web.request_header(ctx, "accept")), "application/json"))
    assert(t.inneholder(tekst(web.request_body(ctx)), "payload"))

    la respons = web.response_builder(201, {"content-type": "application/json"}, "{\"ok\":true}")
    assert(t.inneholder(tekst(web.response_status(respons)), "201"))
    assert(t.inneholder(tekst(web.response_header(respons, "content-type")), "application/json"))
    assert(t.inneholder(tekst(web.response_body(respons)), "\"ok\""))
    assert(t.inneholder(tekst(web.response_text(respons)), "\"ok\""))

    la data = web.response_json(respons)
    assert(data.ok)

    la feil = web.response_error(404, "ikke funnet")
    assert(t.inneholder(tekst(web.response_status(feil)), "404"))
    assert_eq(web.response_header(feil, "content-type"), "application/json")
    assert(t.inneholder(web.response_text(feil), "ikke funnet"))

    la fil_respons = web.response_file("README.md", "text/markdown")
    assert(t.inneholder(tekst(web.response_status(fil_respons)), "200"))
    assert_eq(web.response_header(fil_respons, "content-type"), "text/markdown")
    assert(t.inneholder(web.response_text(fil_respons), "Norscode"))

    skriv("test_web_request_response OK")
    returner 0
}

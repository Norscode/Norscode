bruk std.web som web
bruk std.tekst som t

funksjon start() -> heltall {
    la ctx = web.request_context(
        "get",
        "/brukere/42",
        {"side": "1", "filter": "aktive"},
        {"accept": "application/json"},
        "payload"
    )

    assert_eq(web.request_method(ctx), "get")
    assert_eq(web.request_path(ctx), "/brukere/42")
    assert_eq(web.request_query_param(ctx, "side"), "1")
    assert_eq(web.request_query_param(ctx, "filter"), "aktive")
    assert_eq(web.request_header(ctx, "accept"), "application/json")
    assert_eq(web.request_body(ctx), "payload")

    la respons = web.response_builder(201, {"content-type": "application/json"}, "{\"ok\":true}")
    assert_eq(web.response_status(respons), 201)
    assert_eq(web.response_header(respons, "content-type"), "application/json")
    assert_eq(web.response_body(respons), "{\"ok\":true}")
    assert_eq(web.response_text(respons), "{\"ok\":true}")

    la html = web.response_html(200, "<h1>Norscode</h1>")
    assert_eq(web.response_status(html), 200)
    assert_eq(web.response_header(html, "content-type"), "text/html; charset=utf-8")
    assert_eq(web.response_body(html), "<h1>Norscode</h1>")

    la tekst = web.response_text_plain(202, "mottatt")
    assert_eq(web.response_status(tekst), 202)
    assert_eq(web.response_header(tekst, "content-type"), "text/plain; charset=utf-8")
    assert_eq(web.response_body(tekst), "mottatt")

    la redirect = web.response_redirect_see_other("/tickets")
    assert_eq(web.response_status(redirect), 303)
    assert_eq(web.response_header(redirect, "location"), "/tickets")

    la tomt = web.response_no_content()
    assert_eq(web.response_status(tomt), 204)
    assert_eq(web.response_body(tomt), "")

    la med_header = web.response_with_header(tomt, "x-norscode-test", "ok")
    assert_eq(web.response_header(med_header, "x-norscode-test"), "ok")

    la data = web.response_json(respons)
    assert(data.ok)

    la feil = web.response_error(404, "ikke funnet")
    assert_eq(web.response_status(feil), 404)
    assert_eq(web.response_header(feil, "content-type"), "application/json")
    assert(t.inneholder(web.response_text(feil), "ikke funnet"))

    la fil_respons = web.response_file("README.md", "text/markdown")
    assert_eq(web.response_status(fil_respons), 200)
    assert_eq(web.response_header(fil_respons, "content-type"), "text/markdown")
    assert(t.inneholder(web.response_text(fil_respons), "Norscode"))

    la trygg_fil = web.response_static_file(".", "README.md", "text/markdown")
    assert_eq(web.response_status(trygg_fil), 200)
    assert_eq(web.response_header(trygg_fil, "content-type"), "text/markdown")
    assert(t.inneholder(web.response_text(trygg_fil), "Norscode"))

    la traversal = web.response_static_file(".", "../README.md", "text/markdown")
    assert_eq(web.response_status(traversal), 403)

    la absolutt = web.response_static_file(".", "/etc/passwd", "text/plain")
    assert_eq(web.response_status(absolutt), 403)

    skriv("test_web_request_response OK")
    returner 0
}

    la script_norsk_delmed_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x delmed y")
    assert_eq(script_norsk_delmed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_brace_group_assignment: tekst = sh.disasm_skript("la x={2+3};returner x*4")
    assert_eq(script_brace_group_assignment, "0: PUSH 5\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_bracket_group_assignment: tekst = sh.disasm_skript("la x=[2+3];returner x*4")
    assert_eq(script_bracket_group_assignment, "0: PUSH 5\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")


    la script_norsk_del_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x del med y")
    assert_eq(script_norsk_del_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_norsk_divider_seg_pa_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider_seg_pa y")
    assert_eq(script_norsk_divider_seg_pa_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividersegpa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividersegpa y")
    assert_eq(script_norsk_dividersegpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividersegpaa_kompakt: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividersegpaa y")
    assert_eq(script_norsk_dividersegpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divider_seg_paa_underscore_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider_seg_på y")

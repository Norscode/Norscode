funksjon start() -> heiltall {
    skriv("runtime basics probe v4200\n")

    prøv {
        la rå = "  hei,verda  "
        la trimma = builtin.trim(rå)
        skriv("trim OK: " + trimma + "\n")

        la delar = builtin.split(trimma, ",")
        skriv("split OK len=" + tekst(lengde(delar)) + "\n")

        skriv("starts_with OK: " + tekst(builtin.starts_with(trimma, "hei")) + "\n")
        skriv("ends_with OK: " + tekst(builtin.ends_with(trimma, "verda")) + "\n")
        skriv("tekst_fra_heltall OK: " + tekst_fra_heltall(42) + "\n")
    } fang (e) {
        skriv("tekst_probe FEIL: " + e + "\n")
        returner 1
    }

    prøv {
        la json_sti = "/work/tests/fixtures/runtime_basics_v4200.json"
        hvis ikkje fil_finnes(json_sti) {
            json_sti = "tests/fixtures/runtime_basics_v4200.json"
        }
        hvis ikkje fil_finnes(json_sti) {
            json_sti = "/Users/jansteinar/Norscode AI/prosjekter/Norscode/tests/fixtures/runtime_basics_v4200.json"
        }
        la json_tekst = fil_les(json_sti)
        la data = json_parse_raw(json_tekst)
        la nk = nøkler(data)
        la vv = verdier(data)
        skriv("json_parse_raw OK\n")
        skriv("nøkler OK len=" + tekst(lengde(nk)) + "\n")
        skriv("verdier OK len=" + tekst(lengde(vv)) + "\n")
        skriv("json_stringify OK len=" + tekst(lengde(json_stringify(data))) + "\n")
    } fang (e) {
        skriv("json_map_probe FEIL: " + e + "\n")
        returner 1
    }

    prøv {
        la fil = "/tmp/norscode_runtime_basics_v4200.txt"
        fil_skriv(fil, "linje-42")
        skriv("fil_skriv OK\n")
        la inn = fil_les(fil)
        skriv("fil_les OK: " + inn + "\n")
    } fang (e) {
        skriv("fil_probe FEIL: " + e + "\n")
        returner 1
    }

    returner 0
}

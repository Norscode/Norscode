bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/linecache.no")
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "stat -c %Y \" + _shell(filsti)"))
    assert(t.inneholder(src, "stat -f %m \" + _shell(filsti)"))
    assert(t.inneholder(src, "la linjer = builtin.split(builtin.fil_les(filsti), \"\\n\")"))
    assert(t.inneholder(src, "la indeks: heltall = linjenummer - 1"))
    assert(ikkje t.inneholder(src, "stat -c %Y \" + filsti"))
    assert(ikkje t.inneholder(src, "stat -f %m \" + filsti"))
    assert(ikkje t.inneholder(src, "sed -n '\" + tekst_fra_heltall(linjenummer)"))
    assert(ikkje t.inneholder(src, "p' \" + filsti"))

    skriv("test_linecache_shell_quote OK")
    returner 0
}

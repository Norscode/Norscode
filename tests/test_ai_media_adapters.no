bruk std.media_model som modell
bruk std.ai_bilde som bilde
bruk std.ai_lyd som lyd
bruk std.ai_musikk som musikk
bruk std.ai_video som video
bruk std.media_neural som neural

funksjon start() -> heiltall {
    la p = modell.leverandor("demo", "https://media.example", "", "img", "speech", "song", "film")

    la bj = bilde.ny_jobb("b-1", "Eit fyrtarn", p, 0, 10000)
    la bo = bilde.innstillinger(1024, 768, "png")
    assert_eq(bj["type"], "bilde")
    assert_eq(bo["width"], "1024")

    la lj = lyd.ny_jobb("l-1", "Les teksten", p, 0, 10000)
    la lo = lyd.innstillinger("nora", "wav", "1.0")
    assert_eq(lj["type"], "lyd")
    assert_eq(lo["voice"], "nora")

    la mj = musikk.ny_jobb("m-1", "Rolig nordisk tema", p, 0, 60000)
    la mo = musikk.innstillinger(30, "ambient", "rolig", "mp3")
    assert_eq(mj["type"], "musikk")
    assert_eq(mo["duration_seconds"], "30")

    la vj = video.ny_jobb("v-1", "Nordlys i bevegelse", p, 0, 120000)
    la vo = video.innstillinger(8, 1280, 720, 24, "mp4")
    assert_eq(vj["type"], "video")
    assert_eq(vo["fps"], "24")

    assert(builtin.contains(modell.bygg_body(p, "video", vj["prompt"], vo), "\"model\":\"film\""))
    assert_eq(bilde.generer_lokalt(bj, "build/test_ai_bilde.ppm", 2, 2, 10)["ok"], "sann")
    assert_eq(lyd.generer_lokalt(lj, "build/test_ai_lyd.wav", 10, 440, 10)["ok"], "sann")
    assert_eq(musikk.generer_lokalt(mj, "build/test_ai_musikk.wav", 10, 220, 10)["ok"], "sann")
    assert_eq(video.generer_lokalt(vj, "build/test_ai_video.y4m", 2, 2, 1, 1, 10)["ok"], "sann")
    assert_eq(bj["status"], "ferdig")
    assert_eq(lj["status"], "ferdig")
    assert_eq(mj["status"], "ferdig")
    assert_eq(vj["status"], "ferdig")

    la nm = neural.standardmodell()
    la nb = bilde.ny_jobb("nb-1", "Nevralt bilde", p, 20, 10000)
    la nl = lyd.ny_jobb("nl-1", "Nevral lyd", p, 20, 10000)
    la nmu = musikk.ny_jobb("nm-1", "Nevral musikk", p, 20, 10000)
    la nv = video.ny_jobb("nv-1", "Nevral video", p, 20, 10000)
    assert_eq(bilde.generer_nevralt(nm, nb, "build/test_ai_bilde_neural.ppm", 2, 2, 30)["ok"], "sann")
    assert_eq(lyd.generer_nevralt(nm, nl, "build/test_ai_lyd_neural.wav", 10, 30)["ok"], "sann")
    assert_eq(musikk.generer_nevralt(nm, nmu, "build/test_ai_musikk_neural.wav", 10, 30)["ok"], "sann")
    assert_eq(video.generer_nevralt(nm, nv, "build/test_ai_video_neural.y4m", 2, 2, 1, 1, 30)["ok"], "sann")
    assert_eq(nb["status"], "ferdig")
    assert_eq(nv["status"], "ferdig")
    skriv("test_ai_media_adapters OK\n")
    returner 0
}

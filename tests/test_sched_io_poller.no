bruk std.sched
bruk selfhost.vm

funksjon poll_etter_to(args: ordbok_tekst) -> ordbok_tekst {
    la forsok = heltall_fra_tekst(args["forsok"]) + 1
    args["forsok"] = tekst_fra_heltall(forsok)
    hvis forsok < 2 { returner {"status": "ventende", "resultat": "", "feil": ""} }
    returner {"status": "ferdig", "resultat": args["verdi"], "feil": ""}
}

funksjon poll_alltid_venter(args: ordbok_tekst) -> ordbok_tekst {
    returner {"status": "ventende", "resultat": "", "feil": ""}
}

funksjon cleanup_registrer(args: ordbok_tekst) -> boolsk {
    args["called"] = "sann"
    args["reason"] = args["cleanup_reason"]
    returner sann
}

funksjon await_program(future) {
    returner {
        "__main__.await_io": {
            "params": [],
            "code": [
                ["PUSH_CONST", future],
                ["CALL", "builtin.await_value", 1],
                ["RETURN"]
            ]
        }
    }
}

funksjon start() -> heltall {
    la scheduler = std.sched.ny()
    la a1: ordbok_tekst = {"forsok": "0", "verdi": "fil-klar"}
    la a2: ordbok_tekst = {"forsok": "0", "verdi": "socket-klar"}
    la f1 = std.sched.io_registrer(scheduler, "file-read", "__main__.poll_etter_to", a1, 1000)
    la f2 = std.sched.io_registrer(scheduler, "socket-read", "__main__.poll_etter_to", a2, 1000)
    assert_eq(std.sched.io_tal_ventande(scheduler), 2)

    la handle = std.sched.future_handtak(scheduler, f1)
    la functions = await_program(handle)
    køyr_funksjon("__main__.await_io", [], functions, 0)
    assert(vm_async_er_suspendert(functions))

    assert_eq(std.sched.io_poll(scheduler), 0)
    assert_eq(std.sched.io_poll(scheduler), 2)
    assert_eq(std.sched.future_resultat(scheduler, f2), "socket-klar")
    assert_eq(std.sched.io_tal_ventande(scheduler), 0)
    assert_eq(vm_async_resume(functions), "fil-klar")

    la timeout_args: ordbok_tekst = {}
    la timeout_future = std.sched.io_registrer(scheduler, "process", "__main__.poll_alltid_venter", timeout_args, 0)
    assert_eq(std.sched.io_poll(scheduler), 1)
    assert_eq(std.sched.future_status(scheduler, timeout_future), "feil")
    assert_inneholder(std.sched.future_feil(scheduler, timeout_future), "TimeoutFeil")

    la cancel_future = std.sched.io_registrer(scheduler, "socket-write", "__main__.poll_alltid_venter", timeout_args, 1000)
    assert(std.sched.future_kanseller(scheduler, cancel_future))
    assert_eq(std.sched.io_tal_ventande(scheduler), 0)
    assert_eq(std.sched.future_status(scheduler, cancel_future), "kansellert")

    la timeout_cleanup: ordbok_tekst = {"called": "usann", "reason": ""}
    la timeout_med_cleanup = std.sched.io_registrer_med_cleanup(scheduler, "process", "__main__.poll_alltid_venter", {}, 0, "__main__.cleanup_registrer", timeout_cleanup)
    assert_eq(std.sched.io_poll(scheduler), 1)
    assert_eq(std.sched.future_status(scheduler, timeout_med_cleanup), "feil")
    assert_eq(timeout_cleanup["called"], "sann")
    assert_eq(timeout_cleanup["reason"], "timeout")

    la cancel_cleanup: ordbok_tekst = {"called": "usann", "reason": ""}
    la cancel_med_cleanup = std.sched.io_registrer_med_cleanup(scheduler, "socket-write", "__main__.poll_alltid_venter", {}, 1000, "__main__.cleanup_registrer", cancel_cleanup)
    assert(std.sched.future_kanseller(scheduler, cancel_med_cleanup))
    assert_eq(cancel_cleanup["called"], "sann")
    assert_eq(cancel_cleanup["reason"], "kansellert")
    returner 0
}

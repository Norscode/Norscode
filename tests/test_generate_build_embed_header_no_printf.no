bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/generate_build_embed_c.no")
    la wrapper = fil_les("tools/generate_build_embed_c.sh")

    assert(t.inneholder(src, "funksjon c_embed_header(size_name: tekst, data_name: tekst, size: tekst) -> tekst"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "returner builtin.exec_prosess(cmd)"))
    assert(t.inneholder(src, "builtin.fil_skriv(path, body)"))
    assert(t.inneholder(src, "builtin.fil_append(path, body)"))
    assert(t.inneholder(src, "const uint8_t \" + data_name"))
    assert(t.inneholder(src, "funksjon tekst_til_rå_bytes(data: tekst) -> liste_heltall"))
    assert(t.inneholder(src, "builtin.char_code(data[i]) & 255"))
    assert(t.inneholder(src, "returner append_c_bytes(out, data_bytes)"))
    assert(ikkje t.inneholder(src, "od -An"))
    assert(ikkje t.inneholder(src, "| awk"))
    assert(ikkje t.inneholder(src, ">> \" +"))
    assert(ikkje t.inneholder(src, "wc -c \" + shell"))
    assert(ikkje t.inneholder(src, "printf '#include <stddef.h>"))
    assert(ikkje t.inneholder(src, "printf '#include <stdint.h>"))
    assert(ikkje t.inneholder(src, "printf 'const size_t"))
    assert(ikkje t.inneholder(src, "printf 'const uint8_t"))
    assert(t.inneholder(wrapper, "Norscode-first wrapper: embed-genereringa ligg i tools/generate_build_embed_c.no."))
    assert(t.inneholder(wrapper, "Shell-delen under set berre rot/prosessmiljø og startar Norscode-eigarfil."))
    assert(ikkje t.inneholder(wrapper, "Tynn wrapper"))
    assert(t.inneholder(wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/generate_build_embed_c.no\""))
    assert(ikkje t.inneholder(wrapper, "exec \"$ROOT/bin/nc\" run \"$ROOT/tools/generate_build_embed_c.no\""))

    skriv("test_generate_build_embed_header_no_printf OK")
    returner 0
}

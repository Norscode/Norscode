bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/filecmp.no")
    assert(t.inneholder(src, "Brukar Norscode-filkontroll og intern parsing der det finst"))
    assert(t.inneholder(src, "OS-verktøy for diff, md5/md5sum, stat og find"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon _fyrste_ord(linje: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "diff -q \" + _shell(fil1) + \" \" + _shell(fil2)"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))
    assert(t.inneholder(src, "md5sum \" + _shell(filsti)"))
    assert(t.inneholder(src, "la s: tekst = _fyrste_ord(delar[0])"))
    assert(t.inneholder(src, "md5 -q \" + _shell(filsti)"))
    assert(t.inneholder(src, "diff \" + _shell(fil1) + \" \" + _shell(fil2)"))
    assert(t.inneholder(src, "returner builtin.fil_finnes(sti)"))
    assert(t.inneholder(src, "find -H \" + _shell(sti) + \" -maxdepth 0 -type d -print"))
    assert(t.inneholder(src, "stat -c '%s %Y' \" + _shell(sti)"))
    assert(t.inneholder(src, "stat -f '%z %m' \" + _shell(sti)"))
    assert(t.inneholder(src, "find \" + _shell(sti) + \" -mindepth 1 -maxdepth 1 ! -name '.*' -print"))
    assert(t.inneholder(src, "legg_til(resultat, _basename(s))"))

    assert(ikkje t.inneholder(src, "diff -q \" + fil1"))
    assert(ikkje t.inneholder(src, "Brukar exec_prosess (diff, md5sum/md5, ls, find)"))
    assert(ikkje t.inneholder(src, "&& echo LIKE || echo ULIK"))
    assert(ikkje t.inneholder(src, "md5sum \" + filsti"))
    assert(ikkje t.inneholder(src, "| cut"))
    assert(ikkje t.inneholder(src, "md5 -q \" + filsti"))
    assert(ikkje t.inneholder(src, "diff \" + fil1"))
    assert(ikkje t.inneholder(src, "test -e \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "test -e \" + sti"))
    assert(ikkje t.inneholder(src, "test -d \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "test -d \" + sti"))
    assert(ikkje t.inneholder(src, "stat -c '%s %Y' \" + sti"))
    assert(ikkje t.inneholder(src, "stat -f '%z %m' \" + sti"))
    assert(ikkje t.inneholder(src, "ls -1 \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "ls -1 \" + sti"))

    skriv("test_filecmp_shell_quote OK")
    returner 0
}

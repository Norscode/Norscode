bruk std.asynk som asynk
bruk std.tekst som t

funksjon start() -> heiltall {
    la status = asynk.runtime_python_nivaa()
    assert_eq(status.workers, "stabil")
    assert_eq(status.queue, "stabil")
    assert_eq(status.background_jobs, "stabil")
    assert_eq(status.streaming, "stabil")

    la stream = asynk.stream_lag("text/event-stream")
    assert_eq(asynk.stream_skriv(stream, "data: ein\n\n"), 1)
    assert_eq(asynk.stream_skriv(stream, "data: to\n\n"), 2)
    asynk.stream_avslutt(stream)
    assert(t.inneholder(asynk.stream_body(stream), "data: ein"))
    la resp = asynk.streaming_response(stream)
    assert_eq(resp["__status__"], 200)
    assert_eq(resp["__headers__"]["transfer-encoding"], "chunked")

    la src_async = fil_les("std/asynk.no")
    la src_thread = fil_les("std/tråd.no")
    la src_mp = fil_les("std/multiprocessing.no")
    assert(t.inneholder(src_async, "bakgrunnsjobb_lag"))
    assert(t.inneholder(src_async, "streaming_response"))
    assert(t.inneholder(src_thread, "status_oversikt"))
    assert(t.inneholder(src_mp, "ny_prosess"))
    assert(t.inneholder(src_mp, "funksjon produksjonsstatus"))
    assert(ikkje t.inneholder(src_async, "python3"))
    assert(ikkje t.inneholder(src_thread, "python3"))
    assert(ikkje t.inneholder(src_mp, "python3"))

    skriv("test_runtime_async_process_maturity OK")
    returner 0
}

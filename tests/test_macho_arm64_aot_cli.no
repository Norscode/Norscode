// Ende-til-ende: .no -> NCB -> signert Mach-O arm64 -> ekte prosess.

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon start() -> heiltall {
    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis os[0] != "0" eller builtin.trim(os[1]) != "Darwin" eller arch[0] != "0" eller builtin.trim(arch[1]) != "arm64" {
        returner 0
    }

    la root = miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la id = builtin.random_hex(8)
    la ncb = "/tmp/norscode_macho_aot_cli_" + id + ".ncb.json"
    la binær = "/tmp/norscode_macho_aot_cli_" + id
    la kjelde = root + "/tests/fixtures/macos_aot_control_flow.no"
    la nc = root + "/bin/nc"

    la compile = exec_prosess(shell(nc) + " compile " + shell(kjelde) + " " + shell(ncb))
    assert_eq(compile[0], "0")
    la bygg = exec_prosess(shell(nc) + " bygg-native --target macos-arm64 --ncb " + shell(ncb) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    assert_eq(exec_prosess("codesign --verify --verbose=4 " + shell(binær))[0], "0")
    assert_eq(exec_prosess(shell(binær))[0], "17")

    exec_prosess("rm -f " + shell(ncb) + " " + shell(binær))

    returner 0
}

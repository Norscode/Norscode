bruk selfhost.vm

funksjon start() -> heiltall {
    la functions = {
        "__main__.tiny": {
            "params": [],
            "code": [
                ["PUSH_CONST", "probe vm bridge minimal OK\n"],
                ["CALL", "builtin.skriv", 1],
                ["POP"],
                ["PUSH_CONST", 0],
                ["RETURN"]
            ]
        }
    }

    returner køyr_funksjon("__main__.tiny", [], functions, 0)
}

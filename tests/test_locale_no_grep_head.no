bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/locale.no")

    assert(t.inneholder(src, "finn og parsar relevante"))
    assert(t.inneholder(src, "Norscode utan grep/head-pipeline"))
    assert(ikkje t.inneholder(src, "Henter systemlokal via exec_prosess"))

    assert(t.inneholder(src, "funksjon _finn_lang_linje(tekstblokk: tekst) -> tekst"))
    assert(t.inneholder(src, "la res = builtin.exec_prosess(\"locale 2>/dev/null\")"))
    assert(t.inneholder(src, "la lang_linje: tekst = _finn_lang_linje(res)"))

    assert(ikkje t.inneholder(src, "| grep LANG="))
    assert(ikkje t.inneholder(src, "| head -1"))

    skriv("test_locale_no_grep_head OK")
    returner 0
}

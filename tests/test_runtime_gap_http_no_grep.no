bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/test_v795_runtime_gap.no")

    assert(t.inneholder(src, "funksjon hent(url: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon inneheld(data: tekst, needle: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.index_of(data, needle)"))
    assert(t.inneholder(src, "la runtime_gap = hent(base + \"/runtime-gap\")"))
    assert(t.inneholder(src, "la status = hent(base + \"/status.json\")"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))

    assert(ikkje t.inneholder(src, "| grep -q"))
    assert(ikkje t.inneholder(src, "curl -fsS \" + shell(base + \"/status.json\") + \" |"))

    skriv("test_runtime_gap_http_no_grep OK")
    returner 0
}

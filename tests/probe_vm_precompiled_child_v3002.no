bruk selfhost.vm

funksjon start() -> heiltall {
    la child = {
        "entry": "__main__.tiny",
        "functions": {
            "__main__.tiny": {
                "params": [],
                "code": [
                    ["PUSH_CONST", "probe vm precompiled child OK\n"],
                    ["CALL", "builtin.skriv", 1],
                    ["POP"],
                    ["PUSH_CONST", 0],
                    ["RETURN"]
                ]
            }
        }
    }

    la vm_ncb = json_parse_raw(fil_les("bootstrap/precompiled/vm.ncb.json"))
    la vm_fns = vm_ncb["functions"]
    returner køyr_funksjon("__main__.køyr_ncb", [child], vm_fns, 0)
}

funksjon svar(args: ordbok_tekst) -> tekst { returner "ok:" + args["verdi"] }

funksjon kall(args: ordbok_tekst) -> tekst {
    prøv {
        returner builtin.ncb_call_fn("__main__.svar", args)
    } fang (e) {
        returner "feil:" + tekst(e)
    }
    returner "uventa"
}

funksjon start() -> heltall {
    la args: ordbok_tekst = {}
    args["verdi"] = "42"
    assert_eq(kall(args), "ok:42")
    returner 0
}

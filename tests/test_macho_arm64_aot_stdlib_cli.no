// Ende-til-ende AOT av importert std.math-kode frå Norscode-kjelde.

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon start() -> heiltall {
    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis os[0] != "0" eller builtin.trim(os[1]) != "Darwin" eller arch[0] != "0" eller builtin.trim(arch[1]) != "arm64" {
        returner 0
    }

    la root = miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la binær = "/tmp/norscode_macho_aot_stdlib_" + builtin.random_hex(8)
    la kjelde = root + "/tests/fixtures/macos_aot_std_math.no"
    la nc = root + "/bin/nc"
    la bygg = exec_prosess(shell(nc) + " bygg-native --target macos-arm64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    assert_eq(exec_prosess(shell(binær))[0], "49")
    exec_prosess("rm -f " + shell(binær))

    binær = "/tmp/norscode_macho_aot_stdlib_control_" + builtin.random_hex(8)
    kjelde = root + "/tests/fixtures/macos_aot_std_math_control.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target macos-arm64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    assert_eq(exec_prosess(shell(binær))[0], "10")
    exec_prosess("rm -f " + shell(binær))

    binær = "/tmp/norscode_macho_aot_common_ops_" + builtin.random_hex(8)
    kjelde = root + "/tests/fixtures/aot_common_integer_ops.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target macos-arm64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    assert_eq(exec_prosess(shell(binær))[0], "11")
    exec_prosess("rm -f " + shell(binær))
    returner 0
}

bruk std.httpserver_vm som http_vm
bruk std.web som web

funksjon start() -> heiltall {
    la server = http_vm.ny_server_vm(8085)
    http_vm.route_vm(server, "GET", "/hei", "hei_handler")
    http_vm.register_response_middleware_vm(server, "cors")
    http_vm.register_server_handler_response_object_vm(server, "hei_handler", 200, "hei frå vm-handler", "text/plain; charset=utf-8")
    assert_eq(server["routes"]["GET /hei"], "hei_handler")
    assert_eq(server["handlers"]["GET /hei"], "hei_handler")
    assert_eq(server["handler_registry"]["hei_handler"], "hei frå vm-handler")
    assert_eq(server["handler.body.hei_handler"], "hei frå vm-handler")
    assert_eq(http_vm.server_route_handler_vm(server, "GET", "/hei"), "hei_handler")
    assert_eq(http_vm.server_handler_body_vm(server, "hei_handler"), "hei frå vm-handler")
    assert_eq(server["active_route_handler"], "hei_handler")
    assert_eq(server["active_handler_body"], "hei frå vm-handler")

    la ctx = http_vm.request_context_vm("GET", "/hei", {}, {}, "")
    la response = http_vm.dispatch_request_vm(server, "GET", "/hei", ctx)
    assert_eq(http_vm.response_body_vm(response), "hei frå vm-handler")
    assert_eq(web.response_header(response, "etag"), "\"vm:/hei\"")
    assert_eq(web.response_header(response, "last-modified"), "Tue, 16 Jun 2026 12:00:00 GMT")
    assert_eq(response["__response_middleware_trace__"][0], "cors")

    la head = http_vm.dispatch_request_vm(server, "HEAD", "/hei", ctx)
    assert_eq(http_vm.response_status_vm(head), 200)
    assert_eq(http_vm.response_body_vm(head), "")

    skriv("test_httpserver_vm_dispatch OK")
    returner 0
}

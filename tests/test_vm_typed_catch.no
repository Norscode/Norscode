bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk selfhost.compiler.ir_to_bytecode
bruk selfhost.vm

funksjon finn_node(node, type_namn: tekst) {
    hvis node == null { returner {} }
    hvis node["type"] == type_namn { returner node }
    la barn = node["barn"]
    la i: heiltall = 0
    mens i < lengde(barn) {
        la funne = finn_node(barn[i], type_namn)
        hvis har_nokkel(funne, "type") { returner funne }
        i = i + 1
    }
    returner {}
}

funksjon parser_og_bytekode() -> boolsk {
    la tokens = [
        {"type":"FUNKSJON", "value":"funksjon", "line":1, "column":1},
        {"type":"IDENT", "value":"start", "line":1, "column":10},
        {"type":"LPAREN", "value":"(", "line":1, "column":15},
        {"type":"RPAREN", "value":")", "line":1, "column":16},
        {"type":"LBRACE", "value":"{", "line":1, "column":18},
        {"type":"PROV", "value":"prøv", "line":1, "column":20},
        {"type":"LBRACE", "value":"{", "line":1, "column":25},
        {"type":"KAST", "value":"kast", "line":1, "column":27},
        {"type":"STRING", "value":"IOFeil: disk", "line":1, "column":32},
        {"type":"RBRACE", "value":"}", "line":1, "column":47},
        {"type":"FANG", "value":"fang", "line":1, "column":49},
        {"type":"LPAREN", "value":"(", "line":1, "column":54},
        {"type":"IDENT", "value":"e", "line":1, "column":55},
        {"type":"COLON", "value":":", "line":1, "column":56},
        {"type":"IDENT", "value":"IOFeil", "line":1, "column":58},
        {"type":"RPAREN", "value":")", "line":1, "column":64},
        {"type":"LBRACE", "value":"{", "line":1, "column":66},
        {"type":"RETURNER", "value":"returner", "line":1, "column":68},
        {"type":"IDENT", "value":"e", "line":1, "column":77},
        {"type":"RBRACE", "value":"}", "line":1, "column":79},
        {"type":"ENDELEG", "value":"endeleg", "line":1, "column":81},
        {"type":"LBRACE", "value":"{", "line":1, "column":89},
        {"type":"RBRACE", "value":"}", "line":1, "column":90},
        {"type":"RBRACE", "value":"}", "line":1, "column":92},
        {"type":"EOF", "value":"", "line":1, "column":93}
    ]
    la ast = selfhost.parser.parse_program(tokens)
    la prøv_node = finn_node(ast, "PrøvFang")
    assert_eq(prøv_node["type"], "PrøvFang")
    assert_eq(prøv_node["catch_type"], "IOFeil")
    assert_eq(prøv_node["has_finally"], sann)
    assert_eq(lengde(prøv_node["barn"]), 3)
    la ncb = selfhost.compiler.ir_to_bytecode.kompiler_program(ast, "__main__")
    assert(builtin.index_of(ncb, "\"TRY_BEGIN\"") >= 0)
    assert(builtin.index_of(ncb, "\"IOFeil\"") >= 0)
    assert(builtin.index_of(ncb, "\"FINALLY_PUSH\"") >= 0)
    assert(builtin.index_of(ncb, "\"FINALLY_END\"") >= 0)
    returner sann
}

funksjon parser_og_bytekode_defer() -> boolsk {
    la tokens = [
        {"type":"FUNKSJON", "value":"funksjon", "line":1, "column":1},
        {"type":"IDENT", "value":"start", "line":1, "column":10},
        {"type":"LPAREN", "value":"(", "line":1, "column":15},
        {"type":"RPAREN", "value":")", "line":1, "column":16},
        {"type":"LBRACE", "value":"{", "line":1, "column":18},
        {"type":"UTSETT", "value":"utsett", "line":1, "column":20},
        {"type":"LBRACE", "value":"{", "line":1, "column":27},
        {"type":"RBRACE", "value":"}", "line":1, "column":28},
        {"type":"RETURNER", "value":"returner", "line":1, "column":30},
        {"type":"NUMBER", "value":"1", "line":1, "column":39},
        {"type":"RBRACE", "value":"}", "line":1, "column":41},
        {"type":"EOF", "value":"", "line":1, "column":42}
    ]
    la ast = selfhost.parser.parse_program(tokens)
    assert_eq(finn_node(ast, "Utsett")["type"], "Utsett")
    la ncb = selfhost.compiler.ir_to_bytecode.kompiler_program(ast, "__main__")
    assert(builtin.index_of(ncb, "\"FINALLY_PUSH\"") >= 0)
    assert(builtin.index_of(ncb, "\"LOAD_PENDING\"") >= 0)
    returner sann
}

funksjon tekst_unwind() -> boolsk {
    la functions = {
        "__main__.child": {
            "params": [],
            "code": [["PUSH_CONST", "IOFeil: disk"], ["THROW"]]
        },
        "__main__.outer": {
            "params": [],
            "code": [
                ["TRY_BEGIN", "outer_catch", "tekst"],
                ["TRY_BEGIN", "wrong_catch", "ValueError"],
                ["CALL", "__main__.child", 0],
                ["TRY_END"],
                ["TRY_END"],
                ["PUSH_CONST", "ikkje fanga"],
                ["RETURN"],
                ["LABEL", "wrong_catch"],
                ["TRY_END"],
                ["PUSH_CONST", "feil handler"],
                ["RETURN"],
                ["LABEL", "outer_catch"],
                ["TRY_END"],
                ["LOAD_EXCEPTION"],
                ["RETURN"]
            ]
        }
    }
    assert_eq(køyr_funksjon("__main__.outer", [], functions, 0), "IOFeil: disk")
    returner sann
}

funksjon strukturert_unntak() -> boolsk {
    la feil = {"type": "CustomError", "message": "strukturert"}
    la functions = {
        "__main__.start": {
            "params": [],
            "code": [
                ["TRY_BEGIN", "catch", "CustomError"],
                ["PUSH_CONST", feil],
                ["THROW"],
                ["TRY_END"],
                ["PUSH_CONST", "ikkje fanga"],
                ["RETURN"],
                ["LABEL", "catch"],
                ["TRY_END"],
                ["LOAD_EXCEPTION"],
                ["RETURN"]
            ]
        }
    }
    la resultat = køyr_funksjon("__main__.start", [], functions, 0)
    assert_eq(resultat["type"], "CustomError")
    assert_eq(resultat["message"], "strukturert")
    returner sann
}

funksjon start() -> heiltall {
    assert(parser_og_bytekode())
    assert(parser_og_bytekode_defer())
    assert(tekst_unwind())
    assert(strukturert_unntak())
    returner 0
}

bruk std.tekst som t

funksjon krev(sti: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        returner 0
    }
    skriv("Manglar distribusjonsbevis: " + sti)
    returner 1
}

funksjon start() -> heiltall {
    la feil = 0

    feil = feil + krev("tools/install.sh")
    feil = feil + krev("tools/install.ps1")
    feil = feil + krev("tools/install-release.sh")
    feil = feil + krev("tools/build_stage0_release_assets.sh")
    feil = feil + krev(".github/workflows/linux-app-release.yml")
    feil = feil + krev(".github/workflows/macos-app-release.yml")
    feil = feil + krev(".github/workflows/windows-app-release.yml")
    feil = feil + krev("docs/05-development/SELFHOST_RELEASE_CHECKLIST.md")
    feil = feil + krev("bootstrap/stage0/norscode-linux-x86_64")
    feil = feil + krev("bootstrap/stage0/norscode-macos-arm64")

    assert_eq(feil, 0)

    la windows_installer = fil_les("tools/install.ps1")
    assert(t.inneholder(windows_installer, "Norscode-first bridge: eigaren ligg i tools/install.no."))
    assert(t.inneholder(windows_installer, "PowerShell-delen er avgrensa Windows-bootstrap"))
    assert(t.inneholder(windows_installer, "nc build-windows-app-layout"))
    assert(t.inneholder(windows_installer, "Ingen Windows app-pakke tilgjengeleg i siste release."))
    assert(ikkje t.inneholder(windows_installer, "tools\\build-bootstrap-binary.sh"))
    assert(ikkje t.inneholder(windows_installer, "Windows native binary"))

    la linux = fil_les(".github/workflows/linux-app-release.yml")
    la macos = fil_les(".github/workflows/macos-app-release.yml")
    la windows = fil_les(".github/workflows/windows-app-release.yml")

    assert(t.inneholder(linux, "tools/no_c_python_active_surface.sh"))
    assert(t.inneholder(linux, "tools/verify_seed_only.sh"))
    assert(t.inneholder(linux, ".sha256"))
    assert(t.inneholder(macos, "tools/no_c_python_active_surface.sh"))
    assert(t.inneholder(macos, "tools/verify_seed_only.sh"))
    assert(t.inneholder(macos, ".sha256"))
    assert(t.inneholder(windows, "tools/no_c_python_active_surface.sh"))
    assert(t.inneholder(windows, ".sha256"))
    assert(t.inneholder(windows, "norscode.exe"))
    assert(t.inneholder(windows, "norscode-windows-*.zip"))

    skriv("test_distribution_maturity OK")
    returner 0
}

bruk std.tekst som t

funksjon krev(sti: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        returner 0
    }
    skriv("Manglar distribusjonsbevis: " + sti)
    returner 1
}

funksjon ingen_tools_sh() -> heiltall {
    // Desse tre wrapperane er eksplisitt tillatne fordi dei peikar til Norscode-eigarfilene.
    la res = builtin.exec_prosess("find tools -maxdepth 1 -type f -name '*.sh' -print | grep -Ev '/(bootstrap_diff_analyzer|ncb_normalize_builtin_aliases_v802|smoke_helpdesk_api|smoke_helpdesk_http|startproject|symbol_table_serializer|compile_with_hybrid_bundle_v9400|bundle_with_hybrid_compiler_v9500|compiler_snapshot_compare)\\.sh$' | head -1")
    hvis res[0] != "0" {
        skriv("Klarte ikkje sjekke tools/*.sh")
        returner 1
    }
    hvis res[1] != "" {
        skriv("Uønskt shell-wrapper i tools/: " + res[1])
        returner 1
    }
    returner 0
}

funksjon start() -> heiltall {
    la feil = 0

    // tools/install er extensionfri web-bootstrap før Norscode finnes lokalt.
    feil = feil + krev("tools/install")
    feil = feil + krev("tools/install.ps1")
    feil = feil + krev("tools/install-release.no")
    feil = feil + krev("tools/build_stage0_release_assets.no")
    feil = feil + krev("tools/hosting_runtime_gate_v3610.no")
    feil = feil + krev("tools/windows_runtime_attestation.no")
    feil = feil + krev("tools/acme_pebble_issuance_gate.no")
    feil = feil + krev("tools/acme_dns01_server.no")
    feil = feil + krev(".github/workflows/linux-app-release.yml")
    feil = feil + krev(".github/workflows/macos-app-release.yml")
    feil = feil + krev(".github/workflows/windows-app-release.yml")
    feil = feil + krev(".github/workflows/ci.yml")
    feil = feil + krev("docs/05-development/SELFHOST_RELEASE_CHECKLIST.md")
    feil = feil + krev("bootstrap/stage0/norscode-linux-x86_64")
    feil = feil + krev("bootstrap/stage0/norscode-macos-arm64")
    feil = feil + ingen_tools_sh()

    assert_eq(feil, 0)

    la windows_installer = fil_les("tools/install.ps1")
    assert(t.inneholder(windows_installer, "Norscode-first bridge: eigaren ligg i tools/install.no."))
    assert(t.inneholder(windows_installer, "PowerShell-delen er avgrensa Windows-bootstrap"))
    assert(t.inneholder(windows_installer, "nc build-windows-app-layout"))
    assert(t.inneholder(windows_installer, "Ingen Windows app-pakke tilgjengeleg i siste release."))
    assert(ikkje t.inneholder(windows_installer, "tools\\build-bootstrap-binary.sh"))
    assert(ikkje t.inneholder(windows_installer, "Windows native binary"))

    la linux = fil_les(".github/workflows/linux-app-release.yml")
    la macos = fil_les(".github/workflows/macos-app-release.yml")
    la windows = fil_les(".github/workflows/windows-app-release.yml")
    la ci = fil_les(".github/workflows/ci.yml")

    assert(t.inneholder(linux, "./bin/nc feature-check app.no"))
    assert(t.inneholder(linux, "./bin/nc verify-seed"))
    assert(t.inneholder(linux, ".sha256"))
    assert(t.inneholder(macos, "./bin/nc feature-check app.no"))
    assert(t.inneholder(macos, "./bin/nc verify-seed"))
    assert(t.inneholder(macos, "tools/hosting_runtime_gate_v3610.no"))
    assert(t.inneholder(macos, ".sha256"))
    assert(t.inneholder(windows, "./bin/nc feature-check app.no"))
    assert(t.inneholder(windows, ".sha256"))
    assert(t.inneholder(windows, "norscode.exe"))
    assert(t.inneholder(windows, "zig build-obj archive/legacy_c_backend/nc_argon2_zig.zig"))
    assert(t.inneholder(windows, "build/v3009/native_candidate_gc.c"))
    assert(t.inneholder(windows, "-o build/windows/norscode.exe"))
    assert(t.inneholder(windows, "norscode-windows-*.zip"))
    assert(t.inneholder(windows, "tools/windows_runtime_attestation.no"))
    assert(t.inneholder(windows, "actions/attest-build-provenance@v3"))
    assert(t.inneholder(ci, "NORSCODE_NATIVE_BIN=\"$PWD/build/windows/norscode_native_windows_x86_64.exe\""))
    assert(t.inneholder(ci, "tools/windows_runtime_attestation.no"))
    assert(t.inneholder(ci, "actions/attest-build-provenance@v3"))
    assert(t.inneholder(ci, "tools/acme_pebble_issuance_gate.no"))
    assert(t.inneholder(ci, "ghcr.io/letsencrypt/pebble@sha256:ddf230642b1a584f519f32e347de1b05a6e4c1f6c35c1863b33effeab5f78199"))
    assert(t.inneholder(ci, "tools/acme_dns01_server.no"))
    assert(t.inneholder(ci, "NORSCODE_ACME_DNS_VALUE_FILE=\"/tmp/norscode-acme-share/value\""))
    assert(t.inneholder(ci, "-dnsserver 10.30.50.3:8053"))

    skriv("test_distribution_maturity OK")
    returner 0
}

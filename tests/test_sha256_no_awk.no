bruk std.tekst som t

funksjon krev_sha_hjelpar(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon første_felt"))
    assert(t.inneholder(src, "builtin.split"))
    assert(t.inneholder(src, "shasum -a 256 \" + shell"))
    assert(ikkje t.inneholder(src, "| awk '{print $1}'"))
}

funksjon krev_trygg_sti_shell(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
}

funksjon start() -> heiltall {
    krev_sha_hjelpar("tools/install_release.no")
    krev_sha_hjelpar("tools/install-linux-appdir.no")
    krev_sha_hjelpar("tools/build_norscode_native.no")
    krev_sha_hjelpar("tools/package-linux-app.no")
    krev_sha_hjelpar("tools/package-macos-app.no")
    krev_sha_hjelpar("tools/package-windows-app.no")
    krev_sha_hjelpar("tools/package_release.no")
    krev_sha_hjelpar("tools/controlled_runtime_promotion_v3005.no")
    krev_sha_hjelpar("tools/build_linux_native_candidate_v3005.no")
    krev_sha_hjelpar("tools/render-norscode-mark.no")
    krev_sha_hjelpar("tests/bootstrap/bootstrap_verify.no")

    krev_trygg_sti_shell("tools/install-linux-appdir.no")
    krev_trygg_sti_shell("tools/build_norscode_native.no")
    krev_trygg_sti_shell("tools/package-linux-app.no")
    krev_trygg_sti_shell("tools/package-macos-app.no")
    krev_trygg_sti_shell("tools/package-windows-app.no")
    krev_trygg_sti_shell("tools/install_release.no")
    krev_trygg_sti_shell("tools/package_release.no")
    krev_trygg_sti_shell("tests/bootstrap/bootstrap_verify.no")

    la bootstrap_verify = fil_les("tests/bootstrap/bootstrap_verify.no")
    assert(t.inneholder(bootstrap_verify, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(bootstrap_verify, "returner miljo_hent(namn)"))
    assert(t.inneholder(bootstrap_verify, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(bootstrap_verify, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(bootstrap_verify, "builtin.exec_prosess"))

    la pakke_linux = fil_les("tools/package-linux-app.no")
    assert(t.inneholder(pakke_linux, "returner skriv_fil(sti + \".sha256\", sha + \"\\n\")"))

    la pakke_release = fil_les("tools/package_release.no")
    assert(t.inneholder(pakke_release, "builtin.fil_skriv(arkiv + \".sha256\", sha + \"\\n\")"))

    la mark = fil_les("tools/render-norscode-mark.no")
    assert(t.inneholder(mark, "returner miljo_hent(namn)"))
    assert(t.inneholder(mark, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(mark, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(mark, "builtin.exec_prosess"))

    skriv("test_sha256_no_awk OK")
    returner 0
}

bruk selfhost.common som sh

funksjon checksum(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon start() -> heltall {
    la a: tekst = checksum("ikkje 1 og 0")
    la b: tekst = checksum("ikkje 1 og 0")
    assert_eq(a, b)

    la c: tekst = checksum("1 og 0 eller 1")
    la d: tekst = checksum("1 og 0 eller 1")
    assert_eq(c, d)

    la e: tekst = checksum("(1 eller 0) og 1")
    la f: tekst = checksum("(1 eller 0) og 1")
    assert_eq(e, f)

    # Bytecode skal være stabil mellom kjøringer
    assert_ne(a, "")
    assert_ne(c, "")
    assert_ne(e, "")

    returner 0
}

bruk selfhost.native_execution.native_codegen_v2 som codegen

funksjon start() -> heiltall {
    la ncb = "{\"format\":\"norscode-bytecode-v1\",\"entry\":\"__main__.start\",\"functions\":{\"__main__.start\":{\"name\":\"start\",\"module\":\"__main__\",\"params\":[],\"is_async\":false,\"code\":[[\"PUSH_CONST\",\"blåbær\"],[\"RETURN\"]]}}}"
    la elf = codegen.kompiler_v2(ncb)

    assert_eq(elf[0], 0x7F)
    assert_eq(elf[1], 0x45)
    assert_eq(elf[2], 0x4C)
    assert_eq(elf[3], 0x46)
    assert(codegen.har_innebygd_ncb(elf))
    assert_eq(codegen.hent_innebygd_ncb(elf), ncb)

    // Ein skadd trailer skal ikkje bli godkjend som innebygd NCB.
    elf[lengde(elf) - 9] = 0
    assert(ikkje codegen.har_innebygd_ncb(elf))
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la fs_src = fil_les("std/runtime/native_fs.no")
    assert(t.inneholder(fs_src, "Minimal runtime-filkontrakt"))
    assert(t.inneholder(fs_src, "Faktisk open/write-binding ligg ved native runtime-grensa"))
    assert(t.inneholder(fs_src, "Minimal chmod-kontrakt"))
    assert(t.inneholder(fs_src, "Faktisk chmod-binding ligg ved native runtime-grensa"))
    assert(ikkje t.inneholder(fs_src, "Placeholder syscall/runtime bridge"))
    assert(ikkje t.inneholder(fs_src, "Placeholder chmod syscall bridge"))
    assert(ikkje t.inneholder(fs_src, "Skal kobles mot"))

    la mem_src = fil_les("std/runtime/memory_syscalls.no")
    assert(t.inneholder(mem_src, "Minimal mmap-kontrakt for runtime-sida"))
    assert(t.inneholder(mem_src, "Faktisk syscall-emittering ligg ved native runtime-grensa"))
    assert(ikkje t.inneholder(mem_src, "Placeholder syscall lowering"))
    assert(ikkje t.inneholder(mem_src, "Skal kobles mot"))

    skriv("test_runtime_syscall_contract_text OK")
    returner 0
}

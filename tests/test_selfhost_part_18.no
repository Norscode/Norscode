bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_norsk_trekke_med_underscore: tekst = sh.disasm_skript("la x=10;la y=3;returner x trekke_med y")
    assert_eq(script_norsk_trekke_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la script_norsk_trekkemed_kompakt: tekst = sh.disasm_skript("la x=10;la y=3;returner x trekkemed y")
    assert_eq(script_norsk_trekkemed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")


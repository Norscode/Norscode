funksjon start() -> heiltall {
    skriv("native runtime gap probe v3001\n")

    prøv {
        la token = builtin.random_hex(4)
        skriv("random_hex OK len=" + tekst(lengde(token)) + "\n")
    } fang (e) {
        skriv("random_hex FEIL: " + e + "\n")
    }

    prøv {
        skriv("tid_ms OK: " + tekst(builtin.tid_ms()) + "\n")
    } fang (e) {
        skriv("tid_ms FEIL: " + e + "\n")
    }

    prøv {
        skriv("tid_no OK: " + tekst(builtin.tid_no()) + "\n")
    } fang (e) {
        skriv("tid_no FEIL: " + e + "\n")
    }

    prøv {
        skriv("now OK: " + tekst(builtin.now()) + "\n")
    } fang (e) {
        skriv("now FEIL: " + e + "\n")
    }

    prøv {
        skriv("timestamp OK: " + tekst(builtin.timestamp()) + "\n")
    } fang (e) {
        skriv("timestamp FEIL: " + e + "\n")
    }

    prøv {
        la res = builtin.exec_prosess("echo ok")
        skriv("exec_prosess OK: " + tekst(res) + "\n")
    } fang (e) {
        skriv("exec_prosess FEIL: " + e + "\n")
    }

    prøv {
        la mappe = "build/runtime-gap/norscode native mappe " + tekst(builtin.tid_ms()) + "/under mappe"
        builtin.mappe_opprett(mappe)
        fil_skriv(mappe + "/probe.txt", "mappe ok")
        la inn = fil_les(mappe + "/probe.txt")
        hvis inn == "mappe ok" {
            skriv("mappe_opprett OK\n")
        } ellers {
            skriv("mappe_opprett FEIL: feil filinnhald\n")
        }
    } fang (e2) {
        skriv("mappe_opprett FEIL: " + e2 + "\n")
    }

    returner 0
}

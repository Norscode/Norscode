bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/check_random_sources_v694.no")

    assert(t.inneholder(src, "funksjon skriv_søketreff(root: tekst, mapper: tekst, ord: liste_tekst, maks: heiltall) -> heiltall"))
    assert(t.inneholder(src, "funksjon treff_i_linje(linje_tekst: tekst, ord: liste_tekst) -> bool"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "funksjon aktive_søkefiler(root: tekst, mapper: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "find \" + shell(mappe) + \" -type f -print"))
    assert(t.inneholder(src, "ikkje har_fil(filer, rel)"))
    assert(t.inneholder(src, "builtin.split(data, \"\\n\")"))
    assert(t.inneholder(src, "skriv_søketreff(root, \"std selfhost src tools bin\", random_ord, 120)"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "returner builtin.exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "/usr/bin/grep -R -n"))
    assert(ikkje t.inneholder(src, "find \" + mapper"))
    assert(ikkje t.inneholder(src, "| head -120"))

    skriv("test_check_random_sources_no_grep_head OK")
    returner 0
}

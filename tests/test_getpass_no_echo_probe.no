bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/getpass.no")

    assert(t.inneholder(src, "byggjer Norscode eit trygt quota terminalscript"))
    assert(t.inneholder(src, "interaktive OS-grensa"))
    assert(t.inneholder(src, "Skru av terminal-ekko for éi lesing og returner tilstandsmarkør"))
    assert(ikkje t.inneholder(src, "brukar vi exec_prosess for å lese passord utan ekko"))
    assert(ikkje t.inneholder(src, "Skru av terminal-ekko midlertidig"))

    assert(t.inneholder(src, "funksjon _shell(verdi: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon _read_kommando(prompt: tekst, skjult: bool) -> tekst"))
    assert(t.inneholder(src, "printf %s \" + _shell(prompt)"))
    assert(t.inneholder(src, "bash -c \" + _shell(script)"))
    assert(t.inneholder(src, "la cmd: tekst = _read_kommando(prompt, sann)"))
    assert(t.inneholder(src, "la cmd2: tekst = _read_kommando(prompt, usann)"))
    assert(t.inneholder(src, "builtin.exec_prosess(\"stty -echo 2>/dev/null\")"))
    assert(t.inneholder(src, "builtin.exec_prosess(\"test -t 0\")"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))

    assert(ikkje t.inneholder(src, "read -s -p \\\"\" + prompt"))
    assert(ikkje t.inneholder(src, "read -p \\\"\" + prompt"))
    assert(ikkje t.inneholder(src, "stty -echo 2>/dev/null; echo ok"))
    assert(ikkje t.inneholder(src, "test -t 0 && echo ja || echo nei"))

    skriv("test_getpass_no_echo_probe OK")
    returner 0
}

bruk std.text_model_registry som register
bruk std.text_model_bundle som bundle
bruk std.text_generation som tekstgen
bruk std.tokenizer som tokenizer
bruk std.model_trust som tillit
bruk std.sampling som sampling

funksjon start() -> heiltall {
    la tok = tokenizer.ny(["?", "a", "b", " "], 0, -1, -1, 20)
    la m = tekstgen.ny("registry-mini", 4, 2,
        [1, 0, 0, 1, 1, 1, 2, 1],
        [2, 0, 1, 3, 0, 2, 1, 1], [0, 0, 0, 0], 1, 8)
    la data = bundle.kod(m, tok)
    la tr = tillit.ny(1)
    assert(tillit.tillat(tr, "registry-v1", tillit.hash_bytes(data)))
    la r = register.ny(1, 100, 4)
    assert(register.registrer_verifisert(r, tr, "registry-v1", data))
    assert(register.finnes(r, "registry-mini"))
    la samplar = sampling.ny(7, 1, 100, 0, 2, -1)
    la resultat = register.generer(r, "registry-mini", "a", samplar, 2)
    assert_eq(lengde(resultat["nye_token"]), 2)
    assert_eq(register.statistikk(r)["inferenservar"], "1")
    assert(register.avlast(r, "registry-mini"))
    assert(ikkje register.finnes(r, "registry-mini"))
    assert_eq(register.statistikk(r)["parametre"], "0")
    skriv("test_text_model_registry OK\n")
    returner 0
}

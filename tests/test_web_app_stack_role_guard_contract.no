bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la stack = fil_les("std/web_app_stack.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(stack, "funksjon krev_rolle(conn: tekst, ctx: ordbok_tekst, rolle: tekst) -> boolsk")
    krev(stack, "la berika = berik_ctx(conn, ctx)")
    krev(stack, "hvis ikkje auth.er_innlogga(berika) { returner usann }")
    krev(stack, "returner auth.krev_rolle(berika, rolle)")
    krev(manual, "`std.web_app_stack`: samla webflyt for innstillingar, migrasjon, auth/session, admin og standard JSON-responsar.")

    skriv("test_web_app_stack_role_guard_contract OK")
    returner 0
}

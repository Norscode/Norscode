bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("scripts/regen_fraser.no")

    assert(t.inneholder(src, "Norscode-eigd generator for frasetabellen"))
    assert(t.inneholder(src, "Sorter med lengste frase først, deretter alfabetisk for lik lengd."))
    assert(t.inneholder(src, "norscode_string-kontrakten"))
    assert(ikkje t.inneholder(src, "scripts/gen_expr_fraser.py"))
    assert(ikkje t.inneholder(src, "same som Python"))
    assert(ikkje t.inneholder(src, "key=lambda"))

    skriv("test_regen_fraser_native_text OK")
    returner 0
}

bruk std.runtime_filesystem som fs
bruk std.sched som sched

funksjon start() -> heiltall {
    assert_eq(fs.trygg_sti("build", "runtime-fs.txt"), "build/runtime-fs.txt")
    assert_eq(fs.trygg_sti("build//.", "nested//./runtime-fs.txt"), "build/nested/runtime-fs.txt")
    assert_eq(fs.trygg_sti("build", "safe..name"), "build/safe..name")
    assert_eq(fs.trygg_sti("build", "../README.md"), "")
    assert_eq(fs.trygg_sti("build", "nested/../../README.md"), "")
    assert_eq(fs.trygg_sti("build", "nested\\escape.txt"), "")
    assert_eq(fs.trygg_sti("build", "bad\nname"), "")
    assert_eq(fs.trygg_sti("/tmp", "x"), "")

    la h = fs.opne("build", "runtime-fs.txt", "write")
    assert(fs.er_open(h))
    assert_eq(fs.skriv_chunk(h, "abcdef"), 6)
    assert(fs.seek(h, 2))
    assert_eq(fs.skriv_chunk(h, "XY"), 2)
    assert(fs.flush(h))
    assert(fs.lukk(h))

    la tukla = fs.opne("build", "runtime-fs-tamper.txt", "write")
    assert(fs.er_open(tukla))
    tukla["path"] = "README.md"
    assert(ikkje fs.er_open(tukla))
    assert_eq(fs.skriv_chunk(tukla, "skal ikkje skrivast"), 0)
    assert(ikkje fs.flush(tukla))

    la r = fs.opne("build", "runtime-fs.txt", "read")
    assert_eq(fs.les_chunk(r, 3), "abX")
    assert_eq(fs.tell(r), 3)
    la loop = sched.ny()
    la future = fs.les_async(loop, r, 10)
    assert_eq(sched.run_ferdig(loop), 1)
    assert_eq(sched.future_resultat(loop, future), "Yef")
    assert(fs.lukk(r))

    la status = fs.produksjonsstatus()
    assert_eq(status["status"], "stabil")
    returner 0
}

bruk std.tekst som t

funksjon krev(src: tekst, verdi: tekst) {
    assert(t.inneholder(src, verdi))
}

funksjon start() -> heiltall {
    la dns_src = fil_les("std/dns.no")
    la fw_src = fil_les("std/brannmur.no")
    la tls_src = fil_les("std/tls_acme.no")
    la mail_src = fil_les("std/mail_server.no")
    la host_src = fil_les("std/domenehost.no")
    la status_src = fil_les("std/stdlib_status.no")
    la manual = fil_les("docs/USER_MANUAL.md")
    la readme = fil_les("README.md")
    la status_doc = fil_les("docs/STATUS.md")

    krev(dns_src, "funksjon resolver_plan")
    krev(dns_src, "funksjon dnssec_plan")
    krev(dns_src, "funksjon dnssec_klar")
    krev(dns_src, "v=spf1 mx -all")
    krev(dns_src, "v=DMARC1; p=quarantine")
    krev(fw_src, "funksjon hog_sikkerheit_standard")
    krev(fw_src, "funksjon avgrens_ut")
    krev(fw_src, "egress_restricted")
    krev(tls_src, "funksjon sertifikat_plan")
    krev(tls_src, "acme issue --dry-run")
    krev(mail_src, "funksjon melding_policy_sjekk")
    krev(mail_src, "funksjon karantene_melding")
    krev(mail_src, "funksjon spool_plan")
    krev(mail_src, "funksjon marker_leveringsforsok")
    krev(mail_src, "funksjon dead_letter_melding")
    krev(mail_src, "Relay denied")
    krev(fw_src, "funksjon lockdown")
    krev(fw_src, "funksjon risiko_nivaa")
    krev(host_src, "bruk std.tls_acme som tls")
    krev(host_src, "funksjon infrastruktur_plan")
    krev(host_src, "funksjon backup_plan")
    krev(host_src, "funksjon restore_plan")
    krev(host_src, "dnssec_status")
    krev(host_src, "restore_dry_run")
    krev(host_src, "egress_restricted")
    krev(status_src, "modul(\"dns\", \"stabil\"")
    krev(status_src, "modul(\"tls_acme\", \"stabil\"")
    krev(status_src, "modul(\"mail_server\", \"stabil\"")
    krev(manual, "`std.tls_acme`")
    krev(manual, "Mailserver, domenehost og brannmur")
    krev(readme, "`std.dns`, `std.tls_acme`, `std.mail_server`, `std.domenehost` og `std.brannmur`")
    krev(readme, "retry/dead-letter")
    krev(readme, "DNSSEC-plan")
    krev(readme, "backup/restore")
    krev(status_doc, "Framtidig mailserver/domenehost/brannmur")
    krev(status_doc, "atomic mail-spool")
    krev(status_doc, "DNSSEC-plan")
    krev(status_doc, "backup/restore")

    skriv("test_future_hosting_contract_text OK")
    returner 0
}

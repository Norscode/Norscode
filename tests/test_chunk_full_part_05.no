    la expr_norsk_deler_seg_med_underscore: tekst = sh.disasm_uttrykk("8 deler_seg_med 2")
    assert_eq(expr_norsk_deler_seg_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delersegmed_kompakt: tekst = sh.disasm_uttrykk("8 delersegmed 2")
    assert_eq(expr_norsk_delersegmed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


    assert_eq(expr_norsk_ganges, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliser_med: tekst = sh.disasm_uttrykk("3 multipliser med 4")
    assert_eq(expr_norsk_multipliser_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")


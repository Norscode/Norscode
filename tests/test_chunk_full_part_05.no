    la expr_norsk_gang: tekst = sh.disasm_uttrykk("3 gang 4")
    assert_eq(expr_norsk_gang, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_gange: tekst = sh.disasm_uttrykk("3 gange 4")
    assert_eq(expr_norsk_gange, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganget: tekst = sh.disasm_uttrykk("3 ganget 4")
    assert_eq(expr_norsk_ganget, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganger: tekst = sh.disasm_uttrykk("3 ganger 4")
    assert_eq(expr_norsk_ganger, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")


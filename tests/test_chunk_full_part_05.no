bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_rest_av: tekst = sh.disasm_uttrykk("17 rest_av 5")
    assert_eq(expr_norsk_rest_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_restav: tekst = sh.disasm_uttrykk("17 restav 5")
    assert_eq(expr_norsk_restav, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_rest_av_phrase: tekst = sh.disasm_uttrykk("17 rest av 5")
    assert_eq(expr_norsk_rest_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_resten_av: tekst = sh.disasm_uttrykk("17 resten_av 5")
    assert_eq(expr_norsk_resten_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_restenav: tekst = sh.disasm_uttrykk("17 restenav 5")
    assert_eq(expr_norsk_restenav, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_resten_av_phrase: tekst = sh.disasm_uttrykk("17 resten av 5")
    assert_eq(expr_norsk_resten_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganget_med: tekst = sh.disasm_uttrykk("3 ganget med 4")
    assert_eq(expr_norsk_ganget_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganget_med_underscore: tekst = sh.disasm_uttrykk("3 ganget_med 4")
    assert_eq(expr_norsk_ganget_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_gange_med: tekst = sh.disasm_uttrykk("3 gange med 4")

    assert_eq(expr_norsk_multiplisere_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliseremed_kompakt: tekst = sh.disasm_uttrykk("3 multipliseremed 4")
    assert_eq(expr_norsk_multipliseremed_kompakt, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliserer_med: tekst = sh.disasm_uttrykk("3 multipliserer med 4")
    assert_eq(expr_norsk_multipliserer_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliserer_med_underscore: tekst = sh.disasm_uttrykk("3 multipliserer_med 4")
    assert_eq(expr_norsk_multipliserer_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliserermed_kompakt: tekst = sh.disasm_uttrykk("3 multipliserermed 4")
    assert_eq(expr_norsk_multipliserermed_kompakt, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multiplisert_med: tekst = sh.disasm_uttrykk("3 multiplisert med 4")
    assert_eq(expr_norsk_multiplisert_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multiplisert_med_underscore: tekst = sh.disasm_uttrykk("3 multiplisert_med 4")
    assert_eq(expr_norsk_multiplisert_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multiplisertmed_kompakt: tekst = sh.disasm_uttrykk("3 multiplisertmed 4")
    assert_eq(expr_norsk_multiplisertmed_kompakt, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliseres_med: tekst = sh.disasm_uttrykk("3 multipliseres med 4")
    assert_eq(expr_norsk_multipliseres_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliseres_med_underscore: tekst = sh.disasm_uttrykk("3 multipliseres_med 4")
    assert_eq(expr_norsk_multipliseres_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliseresmed_kompakt: tekst = sh.disasm_uttrykk("3 multipliseresmed 4")
    assert_eq(expr_norsk_multipliseresmed_kompakt, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliser_kort: tekst = sh.disasm_uttrykk("3 multipliser 4")
    assert_eq(expr_norsk_multipliser_kort, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multiplisere_kort: tekst = sh.disasm_uttrykk("3 multiplisere 4")
    assert_eq(expr_norsk_multiplisere_kort, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliserer_kort: tekst = sh.disasm_uttrykk("3 multipliserer 4")
    assert_eq(expr_norsk_multipliserer_kort, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multiplisert_kort: tekst = sh.disasm_uttrykk("3 multiplisert 4")
    assert_eq(expr_norsk_multiplisert_kort, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_multipliseres_kort: tekst = sh.disasm_uttrykk("3 multipliseres 4")
    assert_eq(expr_norsk_multipliseres_kort, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_delt_med: tekst = sh.disasm_uttrykk("8 delt med 2")
    assert_eq(expr_norsk_delt_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delt_med_underscore: tekst = sh.disasm_uttrykk("8 delt_med 2")
    assert_eq(expr_norsk_delt_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_deltmed_kompakt: tekst = sh.disasm_uttrykk("8 deltmed 2")
    assert_eq(expr_norsk_deltmed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divider_med: tekst = sh.disasm_uttrykk("8 divider med 2")
    assert_eq(expr_norsk_divider_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divider_med_underscore: tekst = sh.disasm_uttrykk("8 divider_med 2")
    assert_eq(expr_norsk_divider_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividermed_kompakt: tekst = sh.disasm_uttrykk("8 dividermed 2")
    assert_eq(expr_norsk_dividermed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividere_med: tekst = sh.disasm_uttrykk("8 dividere med 2")
    assert_eq(expr_norsk_dividere_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividere_med_underscore: tekst = sh.disasm_uttrykk("8 dividere_med 2")
    assert_eq(expr_norsk_dividere_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divideremed_kompakt: tekst = sh.disasm_uttrykk("8 divideremed 2")
    assert_eq(expr_norsk_divideremed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_seg_med: tekst = sh.disasm_uttrykk("8 dele seg med 2")
    assert_eq(expr_norsk_dele_seg_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_seg_med_underscore: tekst = sh.disasm_uttrykk("8 dele_seg_med 2")
    assert_eq(expr_norsk_dele_seg_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delesegmed_kompakt: tekst = sh.disasm_uttrykk("8 delesegmed 2")
    assert_eq(expr_norsk_delesegmed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


    assert_eq(expr_norsk_gangesmed_kompakt, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_gang_med: tekst = sh.disasm_uttrykk("3 gang med 4")

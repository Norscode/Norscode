bruk std.tekst som t

funksjon krev(src: tekst, needle: tekst) -> heiltall {
    assert(t.inneholder(src, needle))
    returner 0
}

funksjon start() -> heiltall {
    la frontend = fil_les("std/frontend.no")
    krev(frontend, "funksjon komponent_knapp(")
    krev(frontend, "funksjon komponent_knapp_sekundær(")
    krev(frontend, "funksjon komponent_lenkeknapp(")
    krev(frontend, "funksjon komponent_verktøylinje(")
    krev(frontend, "funksjon komponent_badge(")
    krev(frontend, "funksjon komponent_status_badge(")
    krev(frontend, "funksjon komponent_sidehode(")
    krev(frontend, "funksjon komponent_stat(")
    krev(frontend, "funksjon komponent_dashboard(")
    krev(frontend, "funksjon komponent_sidebar_shell(")
    krev(frontend, "funksjon komponent_filterfelt(")
    krev(frontend, "funksjon komponent_datatabell(")
    krev(frontend, "funksjon komponent_modal(")
    krev(frontend, "funksjon komponent_toast_region(")
    krev(frontend, "funksjon ui_stilark(")
    krev(frontend, ".dashboard-grid")
    krev(frontend, ".sidebar-shell")
    krev(frontend, ".data-table")
    krev(frontend, ".modal")

    la eksempel = fil_les("examples/frontend.no")
    krev(eksempel, "frontend.ui_stilark()")
    krev(eksempel, "frontend.komponent_sidehode(")
    krev(eksempel, "frontend.komponent_dashboard(")
    krev(eksempel, "frontend.komponent_filterfelt(")
    krev(eksempel, "frontend.komponent_datatabell(")
    krev(eksempel, "frontend.komponent_modal(")
    krev(eksempel, "frontend.komponent_toast_region(")

    la docs = fil_les("docs/frontend/FRONTEND_MODEL.md")
    krev(docs, "## UI-kit")
    krev(docs, "sidehode med handlingar")
    krev(docs, "datatabell")
    krev(docs, "frontend.ui_stilark()")
    returner 0
}

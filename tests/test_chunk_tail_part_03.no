bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_subtraheres_med_underscore: tekst = sh.disasm_uttrykk("10 subtraheres_med 3")
    assert_eq(expr_norsk_subtraheres_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheresmed_kompakt: tekst = sh.disasm_uttrykk("10 subtraheresmed 3")
    assert_eq(expr_norsk_subtraheresmed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahert_med: tekst = sh.disasm_uttrykk("10 subtrahert med 3")
    assert_eq(expr_norsk_subtrahert_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahert_med_underscore: tekst = sh.disasm_uttrykk("10 subtrahert_med 3")
    assert_eq(expr_norsk_subtrahert_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahertmed_kompakt: tekst = sh.disasm_uttrykk("10 subtrahertmed 3")
    assert_eq(expr_norsk_subtrahertmed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk: tekst = sh.disasm_uttrykk("10 trekk 3")
    assert_eq(expr_norsk_trekk, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekke: tekst = sh.disasm_uttrykk("10 trekke 3")
    assert_eq(expr_norsk_trekke, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher: tekst = sh.disasm_uttrykk("10 subtraher 3")
    assert_eq(expr_norsk_subtraher, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahert: tekst = sh.disasm_uttrykk("10 subtrahert 3")
    assert_eq(expr_norsk_subtrahert, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_unary_plus: tekst = sh.disasm_uttrykk("+3+5")
    assert_eq(expr_unary_plus, "0: PUSH 3\n1: PUSH 5\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_arith: tekst = sh.disasm_uttrykk("2 pluss 3 ganger 4")
    assert_eq(expr_norsk_arith, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_norsk_legg_til: tekst = sh.disasm_uttrykk("2 legg til 3")
    assert_eq(expr_norsk_legg_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_til_underscore: tekst = sh.disasm_uttrykk("2 legg_til 3")
    assert_eq(expr_norsk_legg_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legge_til: tekst = sh.disasm_uttrykk("2 legge til 3")
    assert_eq(expr_norsk_legge_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legge_til_underscore: tekst = sh.disasm_uttrykk("2 legge_til 3")
    assert_eq(expr_norsk_legge_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legges_til: tekst = sh.disasm_uttrykk("2 legges til 3")
    assert_eq(expr_norsk_legges_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legges_til_underscore: tekst = sh.disasm_uttrykk("2 legges_til 3")
    assert_eq(expr_norsk_legges_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_leggtil_kompakt: tekst = sh.disasm_uttrykk("2 leggtil 3")
    assert_eq(expr_norsk_leggtil_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_leggetil_kompakt: tekst = sh.disasm_uttrykk("2 leggetil 3")
    assert_eq(expr_norsk_leggetil_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_leggestil_kompakt: tekst = sh.disasm_uttrykk("2 leggestil 3")
    assert_eq(expr_norsk_leggestil_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_sammen: tekst = sh.disasm_uttrykk("2 legg sammen 3")
    assert_eq(expr_norsk_legg_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_sammen_underscore: tekst = sh.disasm_uttrykk("2 legg_sammen 3")
    assert_eq(expr_norsk_legg_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legge_sammen: tekst = sh.disasm_uttrykk("2 legge sammen 3")
    assert_eq(expr_norsk_legge_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legge_sammen_underscore: tekst = sh.disasm_uttrykk("2 legge_sammen 3")
    assert_eq(expr_norsk_legge_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legges_sammen: tekst = sh.disasm_uttrykk("2 legges sammen 3")
    assert_eq(expr_norsk_legges_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legges_sammen_underscore: tekst = sh.disasm_uttrykk("2 legges_sammen 3")
    assert_eq(expr_norsk_legges_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_leggsammen_kompakt: tekst = sh.disasm_uttrykk("2 leggsammen 3")
    assert_eq(expr_norsk_leggsammen_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_leggesammen_kompakt: tekst = sh.disasm_uttrykk("2 leggesammen 3")
    assert_eq(expr_norsk_leggesammen_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_leggessammen_kompakt: tekst = sh.disasm_uttrykk("2 leggessammen 3")
    assert_eq(expr_norsk_leggessammen_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_kort: tekst = sh.disasm_uttrykk("2 legg 3")
    assert_eq(expr_norsk_legg_kort, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legge_kort: tekst = sh.disasm_uttrykk("2 legge 3")
    assert_eq(expr_norsk_legge_kort, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legges_kort: tekst = sh.disasm_uttrykk("2 legges 3")
    assert_eq(expr_norsk_legges_kort, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_pluss_med: tekst = sh.disasm_uttrykk("2 pluss med 3")
    assert_eq(expr_norsk_pluss_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_pluss_med_underscore: tekst = sh.disasm_uttrykk("2 pluss_med 3")
    assert_eq(expr_norsk_pluss_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plussmed_kompakt: tekst = sh.disasm_uttrykk("2 plussmed 3")
    assert_eq(expr_norsk_plussmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plus: tekst = sh.disasm_uttrykk("2 plus 3")
    assert_eq(expr_norsk_plus, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plus_med: tekst = sh.disasm_uttrykk("2 plus med 3")
    assert_eq(expr_norsk_plus_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plus_med_underscore: tekst = sh.disasm_uttrykk("2 plus_med 3")
    assert_eq(expr_norsk_plus_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusmed_kompakt: tekst = sh.disasm_uttrykk("2 plusmed 3")
    assert_eq(expr_norsk_plusmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusser_med: tekst = sh.disasm_uttrykk("2 plusser med 3")
    assert_eq(expr_norsk_plusser_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusser_med_underscore: tekst = sh.disasm_uttrykk("2 plusser_med 3")
    assert_eq(expr_norsk_plusser_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plussermed_kompakt: tekst = sh.disasm_uttrykk("2 plussermed 3")
    assert_eq(expr_norsk_plussermed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusses_med: tekst = sh.disasm_uttrykk("2 plusses med 3")
    assert_eq(expr_norsk_plusses_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusses_med_underscore: tekst = sh.disasm_uttrykk("2 plusses_med 3")
    assert_eq(expr_norsk_plusses_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plussesmed_kompakt: tekst = sh.disasm_uttrykk("2 plussesmed 3")
    assert_eq(expr_norsk_plussesmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_pluses_med: tekst = sh.disasm_uttrykk("2 pluses med 3")
    assert_eq(expr_norsk_pluses_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_pluses_med_underscore: tekst = sh.disasm_uttrykk("2 pluses_med 3")
    assert_eq(expr_norsk_pluses_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusesmed_kompakt: tekst = sh.disasm_uttrykk("2 plusesmed 3")
    assert_eq(expr_norsk_plusesmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusse_med: tekst = sh.disasm_uttrykk("2 plusse med 3")
    assert_eq(expr_norsk_plusse_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusse_med_underscore: tekst = sh.disasm_uttrykk("2 plusse_med 3")
    assert_eq(expr_norsk_plusse_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plussemed_kompakt: tekst = sh.disasm_uttrykk("2 plussemed 3")
    assert_eq(expr_norsk_plussemed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusser: tekst = sh.disasm_uttrykk("2 plusser 3")
    assert_eq(expr_norsk_plusser, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adder_med: tekst = sh.disasm_uttrykk("2 adder med 3")
    assert_eq(expr_norsk_adder_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adder_med_underscore: tekst = sh.disasm_uttrykk("2 adder_med 3")
    assert_eq(expr_norsk_adder_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_addermed_kompakt: tekst = sh.disasm_uttrykk("2 addermed 3")
    assert_eq(expr_norsk_addermed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_addere_med: tekst = sh.disasm_uttrykk("2 addere med 3")
    assert_eq(expr_norsk_addere_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_addere_med_underscore: tekst = sh.disasm_uttrykk("2 addere_med 3")
    assert_eq(expr_norsk_addere_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderemed_kompakt: tekst = sh.disasm_uttrykk("2 adderemed 3")
    assert_eq(expr_norsk_adderemed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderer_med: tekst = sh.disasm_uttrykk("2 adderer med 3")
    assert_eq(expr_norsk_adderer_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderer_med_underscore: tekst = sh.disasm_uttrykk("2 adderer_med 3")
    assert_eq(expr_norsk_adderer_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    returner 0
}

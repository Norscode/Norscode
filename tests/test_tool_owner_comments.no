bruk std.tekst som t

funksjon start() -> heiltall {
    la pakke = fil_les("tools/package_release.no")
    assert(t.inneholder(pakke, "Denne fila eig release-reglane"))
    assert(t.inneholder(pakke, "NORSCODE_RELEASE_VERSION og NORSCODE_ROOT"))
    assert(t.inneholder(pakke, "Wrapperen gir berre miljøverdiane"))
    assert(ikkje t.inneholder(pakke, "Shell-wrapperen set"))

    la install = fil_les("tools/install_release.no")
    assert(t.inneholder(install, "Denne fila eig installasjonsreglane"))
    assert(t.inneholder(install, "NORSCODE_INSTALL_ARCHIVE, NORSCODE_INSTALL_PREFIX og NORSCODE_ROOT"))
    assert(t.inneholder(install, "Wrapperen gir berre miljøverdiane"))
    assert(ikkje t.inneholder(install, "Shell-wrapperen set"))

    la testverktoy = fil_les("tools/nc_test.no")
    assert(t.inneholder(testverktoy, "Denne fila eig testval, skip-reglar, køyring og rapportering"))
    assert(t.inneholder(testverktoy, "NORSCODE_ROOT, NC_NATIVE, TESTS_DIR og eventuell"))
    assert(t.inneholder(testverktoy, "Wrapperen gir"))
    assert(ikkje t.inneholder(testverktoy, "Shell-wrapperen set"))

    skriv("test_tool_owner_comments OK")
    returner 0
}

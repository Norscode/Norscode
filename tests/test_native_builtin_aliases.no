funksjon start() -> heiltall {
    assert_eq("v" + tekst_fra_heiltall(42), "v42")
    assert_eq("v" + builtin.tekst_fra_heiltall(7), "v7")
    assert_eq(builtin.slice("abcd", 1, 3), "bc")
    la created = builtin.atomic_operation({"abi": "norscode-atomic-v1", "operation": "create", "value": 10, "order": "seq_cst"})
    assert_eq(created["status"], "ok")
    la handle = created["handle"]
    la loaded = builtin.atomic_operation({"operation": "load", "handle": handle, "order": "acquire"})
    assert_eq(loaded["observed"], 10)
    la stored = builtin.atomic_operation({"operation": "store", "handle": handle, "value": 11, "order": "release"})
    assert_eq(stored["value"], 11)
    la exchanged = builtin.atomic_operation({"operation": "exchange", "handle": handle, "value": 20, "order": "acq_rel"})
    assert_eq(exchanged["observed"], 11)
    la cas = builtin.atomic_operation({"operation": "compare_exchange", "handle": handle, "expected": 20, "replacement": 30, "order": "seq_cst", "failure_order": "acquire"})
    assert_eq(cas["success"], "sann")
    la added = builtin.atomic_operation({"operation": "fetch_add", "handle": handle, "delta": 5, "order": "seq_cst"})
    assert_eq(added["observed"], 30)
    assert_eq(added["value"], 35)
    assert_eq(added["version"], 4)
    assert_eq(builtin.atomic_operation({"operation": "load", "handle": handle, "order": "release"})["status"], "invalid_order")
    assert_eq(builtin.atomic_operation({"operation": "store", "handle": handle, "value": 1, "order": "acquire"})["status"], "invalid_order")
    assert_eq(builtin.atomic_operation({"operation": "compare_exchange", "handle": handle, "expected": 35, "replacement": 1, "order": "relaxed", "failure_order": "acquire"})["status"], "invalid_order")
    assert_eq(builtin.atomic_operation({"operation": "fence", "order": "seq_cst"})["status"], "ok")
    assert_eq(builtin.atomic_operation({"operation": "destroy", "handle": handle, "order": "seq_cst"})["status"], "ok")
    assert_eq(builtin.atomic_operation({"operation": "load", "handle": handle, "order": "seq_cst"})["status"], "invalid_handle")
    skriv("test_native_builtin_aliases OK")
    returner 0
}

funksjon phase5_smoke_status()
    returner {
        packaging: "ok",
        release: "ok",
        status: "ok"
    }
slutt

funksjon test_phase5_smoke()
    status = phase5_smoke_status()
    assert_lik(status.packaging, "ok")
    assert_lik(status.release, "ok")
    assert_lik(status.status, "ok")
    assert_lik(sann, sann)
slutt

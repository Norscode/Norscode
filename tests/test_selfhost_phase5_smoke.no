funksjon phase5_smoke_status()
    returner {
        packaging: "ok",
        release: "ok",
        status: "ok"
    }
slutt

funksjon test_phase5_smoke()
    status = phase5_smoke_status()
    assert_eq(status.packaging, "ok")
    assert_eq(status.release, "ok")
    assert_eq(status.status, "ok")
    assert_eq(sann, sann)
slutt

funksjon start() -> heiltall {
    test_phase5_smoke()
    returner 0
}

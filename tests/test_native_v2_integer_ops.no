        exec_prosess("rm -f " + shell(affiks_sti))

        la sok_namn = "norscode_v2_text_search_" + builtin.random_hex(8)
        la sok_sti = "/tmp/" + sok_namn
        builtin.fil_skriv_binær(sok_sti, codegen.kompiler_v2(text_search_ncb()))

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon start() -> heiltall {
    la bytes = codegen.kompiler_v2(ncb())
    assert(lengde(bytes) > 4096)
    assert_eq(bytes[0], 0x7F)
    assert_eq(bytes[1], 0x45)
    assert(codegen.har_innebygd_ncb(bytes))

    hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        la namn = "norscode_v2_integer_ops_" + builtin.random_hex(8)
        la sti = "/tmp/" + namn
        builtin.fil_skriv_binær(sti, bytes)
        assert_eq(exec_prosess("chmod +x " + shell(sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn)[0], "11")
        exec_prosess("rm -f " + shell(sti))

        la env_namn = "norscode_v2_env_" + builtin.random_hex(8)
        la env_sti = "/tmp/" + env_namn
        builtin.fil_skriv_binær(env_sti, codegen.kompiler_v2(env_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(env_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -e NORSCODE_V2_ENV_PROBE=ok -v /private/tmp:/work:ro alpine:3.20 /work/" + env_namn)[0], "17")
        exec_prosess("rm -f " + shell(env_sti))

        la kall_namn = "norscode_v2_forward_call_" + builtin.random_hex(8)
        la kall_sti = "/tmp/" + kall_namn
        builtin.fil_skriv_binær(kall_sti, codegen.kompiler_v2(forward_call_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(kall_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + kall_namn)[0], "23")
        exec_prosess("rm -f " + shell(kall_sti))

        la seks_namn = "norscode_v2_six_argument_call_" + builtin.random_hex(8)
        la seks_sti = "/tmp/" + seks_namn
        builtin.fil_skriv_binær(seks_sti, codegen.kompiler_v2(six_argument_call_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(seks_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + seks_namn)[0], "107")
        exec_prosess("rm -f " + shell(seks_sti))

        la slice_namn = "norscode_v2_slice_" + builtin.random_hex(8)
        la slice_sti = "/tmp/" + slice_namn
        builtin.fil_skriv_binær(slice_sti, codegen.kompiler_v2(slice_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(slice_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + slice_namn)[0], "29")
        exec_prosess("rm -f " + shell(slice_sti))

        la teikn_namn = "norscode_v2_char_code_" + builtin.random_hex(8)
        la teikn_sti = "/tmp/" + teikn_namn
        builtin.fil_skriv_binær(teikn_sti, codegen.kompiler_v2(char_code_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(teikn_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + teikn_namn)[0], "65")
        exec_prosess("rm -f " + shell(teikn_sti))

        la samanlikn_namn = "norscode_v2_compare_ordered_" + builtin.random_hex(8)
        la samanlikn_sti = "/tmp/" + samanlikn_namn
        builtin.fil_skriv_binær(samanlikn_sti, codegen.kompiler_v2(ordered_compare_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(samanlikn_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + samanlikn_namn)[0], "31")
        exec_prosess("rm -f " + shell(samanlikn_sti))

        la json_namn = "norscode_v2_json_" + builtin.random_hex(8)
        la json_sti = "/tmp/" + json_namn
        builtin.fil_skriv_binær(json_sti, codegen.kompiler_v2(json_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(json_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + json_namn)[0], "37")
        exec_prosess("rm -f " + shell(json_sti))

        la json_skriv_namn = "norscode_v2_json_stringify_" + builtin.random_hex(8)
        la json_skriv_sti = "/tmp/" + json_skriv_namn
        builtin.fil_skriv_binær(json_skriv_sti, codegen.kompiler_v2(json_stringify_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(json_skriv_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + json_skriv_namn)[0], "89")
        exec_prosess("rm -f " + shell(json_skriv_sti))

        la null_namn = "norscode_v2_json_null_" + builtin.random_hex(8)
        la null_sti = "/tmp/" + null_namn
        builtin.fil_skriv_binær(null_sti, codegen.kompiler_v2(json_null_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(null_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + null_namn)[0], "41")
        exec_prosess("rm -f " + shell(null_sti))

        la indeks_namn = "norscode_v2_index_outside_" + builtin.random_hex(8)
        la indeks_sti = "/tmp/" + indeks_namn
        builtin.fil_skriv_binær(indeks_sti, codegen.kompiler_v2(index_outside_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(indeks_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + indeks_namn)[0], "43")
        exec_prosess("rm -f " + shell(indeks_sti))

        la behaldar_namn = "norscode_v2_containers_" + builtin.random_hex(8)
        la behaldar_sti = "/tmp/" + behaldar_namn
        builtin.fil_skriv_binær(behaldar_sti, codegen.kompiler_v2(container_ncb()))
        assert_eq(exec_prosess("chmod +x " + shell(behaldar_sti))[0], "0")
        assert_eq(exec_prosess("docker run --platform linux/amd64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + behaldar_namn)[0], "47")
        exec_prosess("rm -f " + shell(behaldar_sti))

        la fleirkart_namn = "norscode_v2_multi_map_" + builtin.random_hex(8)
        la fleirkart_sti = "/tmp/" + fleirkart_namn
        builtin.fil_skriv_binær(fleirkart_sti, codegen.kompiler_v2(multi_map_ncb()))

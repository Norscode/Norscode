bruk std.tekst som t

funksjon sjekk(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "funksjon første_ord"))
    assert(t.inneholder(src, "returner første_ord(res_felt(kommando(\"shasum -a 256 "))
    assert(t.inneholder(src, "returner første_ord(res_felt(kommando(\"sha256sum "))
    assert(ikkje t.inneholder(src, "awk"))
    assert(ikkje t.inneholder(src, "| awk"))
}

funksjon start() -> heiltall {
    sjekk("tools/native_readiness_v3400.no")
    sjekk("tools/platform_readiness_v3600.no")
    sjekk("tools/native_active_status_v3007.no")
    la readiness = fil_les("tools/native_readiness_v3400.no")
    assert(t.inneholder(readiness, "builtin.fil_finnes(sti)"))
    assert(t.inneholder(readiness, "NORSCODE_PROMOTE_CANDIDATE="))
    assert(t.inneholder(readiness, "bin/nc run tools/promote_native_stage0_v3001.no"))
    assert(t.inneholder(readiness, "NORSCODE_NATIVE_GAP_BIN="))
    assert(t.inneholder(readiness, "bin/nc run tools/native_runtime_gap_gate_v3001.no"))
    assert(ikkje t.inneholder(readiness, "bash tools/promote_native_stage0_v3001.sh"))
    assert(ikkje t.inneholder(readiness, "bash tools/native_runtime_gap_gate_v3001.sh"))
    assert(ikkje t.inneholder(readiness, "test -x "))
    la active = fil_les("tools/native_active_status_v3007.no")
    assert(t.inneholder(active, "builtin.fil_finnes(sti)"))
    assert(t.inneholder(active, "NORSCODE_NATIVE_GAP_BIN="))
    assert(t.inneholder(active, "bin/nc run tools/native_runtime_gap_gate_v3001.no"))
    assert(ikkje t.inneholder(active, "bash tools/native_runtime_gap_gate_v3001.sh"))
    assert(ikkje t.inneholder(active, "test -x "))
    skriv("test_readiness_sha_parsing_no_awk OK")
    returner 0
}

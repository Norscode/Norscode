// Linux arm64 AOT: kjelde/importar -> statisk AArch64 ELF.

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon er_linux_arm64(os, arch) -> boolsk {
    hvis os[0] != "0" eller builtin.trim(os[1]) != "Linux" eller arch[0] != "0" { returner usann }
    la a = builtin.trim(arch[1])
    returner a == "aarch64" eller a == "arm64"
}

funksjon start() -> heiltall {
    la root = miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la id = builtin.random_hex(8)
    la namn = "norscode_linux_arm_aot_" + id
    la binær = "/tmp/" + namn
    la kjelde = root + "/tests/fixtures/macos_aot_std_math.no"
    la nc = root + "/bin/nc"
    la bygg = exec_prosess(shell(nc) + " bygg-native --target linux-arm64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    la bytes = builtin.fil_les_binær(binær)
    assert(lengde(bytes) > 4096)
    assert_eq(bytes[0], 0x7F)
    assert_eq(bytes[18], 183)

    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis er_linux_arm64(os, arch) {
        assert_eq(exec_prosess(shell(binær))[0], "49")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        assert_eq(exec_prosess("docker info >/dev/null 2>&1")[0], "0")
        la docker = "docker run --platform linux/arm64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker)[0], "49")
    }
    exec_prosess("rm -f " + shell(binær))

    namn = "norscode_linux_arm_control_" + id
    binær = "/tmp/" + namn
    kjelde = root + "/tests/fixtures/macos_aot_std_math_control.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target linux-arm64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    hvis er_linux_arm64(os, arch) {
        assert_eq(exec_prosess(shell(binær))[0], "10")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        la docker_control = "docker run --platform linux/arm64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker_control)[0], "10")
    }
    exec_prosess("rm -f " + shell(binær))

    namn = "norscode_linux_arm_common_ops_" + id
    binær = "/tmp/" + namn
    kjelde = root + "/tests/fixtures/aot_common_integer_ops.no"
    bygg = exec_prosess(shell(nc) + " bygg-native --target linux-arm64 " + shell(kjelde) + " " + shell(binær))
    assert_eq(bygg[0], "0")
    hvis er_linux_arm64(os, arch) {
        assert_eq(exec_prosess(shell(binær))[0], "11")
    } ellers hvis miljo_hent("NORSCODE_VERIFY_LINUX_DOCKER") == "1" {
        la docker_common = "docker run --platform linux/arm64 --rm -v /private/tmp:/work:ro alpine:3.20 /work/" + namn
        assert_eq(exec_prosess(docker_common)[0], "11")
    }
    exec_prosess("rm -f " + shell(binær))
    returner 0
}

bruk std.runtime_type som typer

funksjon demo(a: heiltall, b: tekst) -> tekst { returner b + tekst_fra_heltall(a) }

funksjon start() -> heiltall {
    assert_eq(typer.verdi_type(42)["namn"], "heiltall")
    assert_eq(typer.verdi_type(42)["copy"], "by_value")
    assert_eq(typer.verdi_type("hei")["namn"], "tekst")
    assert_eq(typer.verdi_type([1, 2])["namn"], "liste")
    assert_eq(typer.verdi_type([1, 2])["copy"], "by_ref")
    assert_eq(typer.verdi_type({"a": 1})["namn"], "kart")

    la custom = typer.objekt_type("Ticket", "id,title,status", "close,assign")
    assert(typer.registrer(custom))
    assert(typer.sett_metode(custom, "close", "__main__.demo"))
    assert_eq(typer.hent("Ticket")["fields"], "id,title,status")

    la urgent = typer.objekt_type("UrgentTicket", "priority", "")
    assert(typer.sett_base(urgent, "Ticket"))
    assert(typer.registrer(urgent))
    assert(typer.kan_tilordne(urgent, custom))
    la inherited = typer.metode_oppslag(urgent, "close")
    assert_eq(inherited["finnes"], "sann")
    assert_eq(inherited["owner"], "Ticket")
    assert_eq(inherited["target"], "__main__.demo")

    la list_base = typer.type_info("liste", "container", 0, sann)
    la list_text = typer.generic_type(list_base, "tekst")
    la list_text_2 = typer.generic_type(list_base, "tekst")
    la list_int = typer.generic_type(list_base, "heiltall")
    assert(typer.kan_tilordne(list_text, list_text_2))
    assert(ikkje typer.kan_tilordne(list_int, list_text))

    la nullable_ticket = typer.nullable_type(custom)
    assert(typer.er_nullable(nullable_ticket))
    assert(typer.kan_tilordne(typer.hent("null"), nullable_ticket))
    assert(typer.kan_tilordne(custom, nullable_ticket))
    assert(ikkje typer.kan_tilordne(typer.hent("null"), custom))

    la scalar = typer.union_type("heiltall|tekst")
    assert(typer.kan_tilordne(typer.hent("heiltall"), scalar))
    assert(typer.kan_tilordne(typer.hent("tekst"), scalar))
    assert(ikkje typer.kan_tilordne(custom, scalar))

    la host = typer.host_type("SocketHandle", "net.tcp")
    assert(typer.host_tilgang(host, "disk.read,net.tcp"))
    assert(ikkje typer.host_tilgang(host, "disk.read"))

    la fn = typer.funksjon_info("__main__.demo")
    assert_eq(fn["finnes"], "sann")
    assert_eq(fn["param_count"], "2")
    assert(heltall_fra_tekst(fn["instruction_count"]) > 0)
    la modul = typer.modul_info("__main__")
    assert(heltall_fra_tekst(modul["function_count"]) >= 2)
    assert_inneholder(modul["functions"], "__main__.demo")
    assert(har_nokkel(typer.register(), "Ticket"))
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/selfcompile_l5b_mini.no")
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "funksjon filer_identiske(a: tekst, b: tekst) -> bool"))
    assert(t.inneholder(src, "returner les_fil_trygt(a) == les_fil_trygt(b)"))
    assert(t.inneholder(src, "hvis ikkje filer_identiske(v1, v2)"))
    assert(ikkje t.inneholder(src, "cmp -s "))

    skriv("test_selfcompile_l5b_mini_no_cmp OK")
    returner 0
}

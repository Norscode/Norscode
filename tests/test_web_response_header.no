bruk std.web som web

funksjon start() -> heltall {
    la respons = web.response_builder(200, {"x-norscode-fragment": "fragment", "content-type": "text/html"}, "ok")
    assert_eq(web.response_status(respons), 200)
    assert_eq(web.response_headers(respons)["x-norscode-fragment"], "fragment")
    assert_eq(web.response_header(respons, "x-norscode-fragment"), "fragment")
    assert_eq(web.response_header(respons, "content-type"), "text/html")
    assert_eq(web.response_header(respons, "Content-Type"), "text/html")
    assert_eq(web.response_header(respons, "missing"), "")
    returner 0
}

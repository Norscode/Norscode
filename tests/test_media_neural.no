bruk std.media_neural som neural

funksjon start() -> heiltall {
    la m = neural.standardmodell()
    assert_eq(m["input_dim"], 8)
    assert_eq(m["output_dim"], 4)
    assert_eq(lengde(m["lag"]), 2)

    la p1 = neural.plan(m, "Nordlys over havet")
    la p2 = neural.plan(m, "Trommer i skogen")
    assert_eq(p1["modell"], "norscode-media-q8-v1")
    assert(p1["backend"] == "metal" eller p1["backend"] == "cpu-fallback")
    assert(p1["backend_fallback"] == "sann" eller p1["backend_fallback"] == "usann")
    assert(p1["backend"] == "metal" eller p1["backend"] == "cpu-fallback")
    assert(heltall_fra_tekst(p1["frekvens"]) >= 110)
    assert(heltall_fra_tekst(p1["frekvens"]) <= 880)
    assert(p1["latent"] != p2["latent"])

    assert_eq(neural.bilde(m, "Nordlys", "build/test_media_neural.ppm", 4, 4)["ok"], "sann")
    assert_eq(neural.lyd(m, "Stemme", "build/test_media_neural.wav", 20)["ok"], "sann")
    assert_eq(neural.musikk(m, "Tema", "build/test_media_neural_music.wav", 20)["ok"], "sann")
    assert_eq(neural.video(m, "Film", "build/test_media_neural.y4m", 4, 4, 2, 2)["ok"], "sann")
    skriv("test_media_neural OK\n")
    returner 0
}

bruk std.prosess som prosess

funksjon start() -> heiltall {
    la policy = prosess.ny_policy("native-argv")
    assert(prosess.tillat(policy, "printf"))
    assert(prosess.aktiver_køyring(policy))
    la plan = prosess.start_argv_plan("/usr/bin/printf", ["%s:%s", "policy", ";"])
    prosess.med_timeout(plan, 5)
    prosess.med_maks_output(plan, 4096)
    la result = prosess.start_argv_trygt(policy, plan)
    assert_eq(prosess.returkode(result), 0)
    assert_eq(prosess.stdout(result), "policy:;")
    assert_eq(prosess.stderr(result), "")
    skriv("test_process_spawn_argv_policy OK")
    returner 0
}

funksjon start() -> heiltall {
    la pure_vm: boolsk = usann
    prøv {
        builtin.vm_memory_status()
        pure_vm = sann
    } fang (e) {
    }
    hvis ikkje pure_vm {
        skriv("test_vm_dynamic_loader_unsigned OK")
        returner 0
    }

    la avvist: tekst = ""
    prøv {
        builtin.vm_module_load("build/vm_plugin_v1.ncb.json", "unsigned", "")
        returner 1
    } fang (e) {
        avvist = e
    }
    hvis lengde(avvist) == 0 { returner 2 }

    skriv("test_vm_dynamic_loader_unsigned OK")
    returner 0
}

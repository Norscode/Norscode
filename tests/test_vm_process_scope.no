funksjon start() -> heiltall {
    la pure = sann
    prøv { builtin.vm_memory_status() } fang (e) { pure = usann }
    hvis ikkje pure { returner 0 }
    la denied = ""
    prøv {
        builtin.process_spawn_argv({"abi": "norscode-process-spawn-v1", "executable": "/bin/cat", "args": [], "cwd": "", "stdin": "", "timeout_ms": "1000", "max_output_bytes": "1024"})
        returner 1
    } fang (e) { denied = tekst(e) }
    assert_inneholder(denied, "process scope")
    la allowed = builtin.process_spawn_argv({"abi": "norscode-process-spawn-v1", "executable": "/usr/bin/printf", "args": ["scope-ok"], "cwd": "", "stdin": "", "timeout_ms": "1000", "max_output_bytes": "1024"})
    assert_eq(allowed["stdout"], "scope-ok")
    skriv("test_vm_process_scope OK")
    returner 0
}

bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_cmp_phrase17: tekst = sh.disasm_uttrykk("7 ulik med 8")
    assert_eq(expr_norsk_cmp_phrase17, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase17_underscore: tekst = sh.disasm_uttrykk("7 ulik_med 8")
    assert_eq(expr_norsk_cmp_phrase17_underscore, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase17_ulikmed_kompakt: tekst = sh.disasm_uttrykk("7 ulikmed 8")
    assert_eq(expr_norsk_cmp_phrase17_ulikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase18: tekst = sh.disasm_uttrykk("3 mindre lik 4")
    assert_eq(expr_norsk_cmp_phrase18, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase19: tekst = sh.disasm_uttrykk("4 storre lik 4")
    assert_eq(expr_norsk_cmp_phrase19, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase19_underscore: tekst = sh.disasm_uttrykk("4 storre_lik 4")
    assert_eq(expr_norsk_cmp_phrase19_underscore, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase19_storrelik_kompakt: tekst = sh.disasm_uttrykk("4 storrelik 4")
    assert_eq(expr_norsk_cmp_phrase19_storrelik_kompakt, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase19_underscore_utf8: tekst = sh.disasm_uttrykk("4 større_lik 4")
    assert_eq(expr_norsk_cmp_phrase19_underscore_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase19_storrelik_kompakt_utf8: tekst = sh.disasm_uttrykk("4 størrelik 4")
    assert_eq(expr_norsk_cmp_phrase19_storrelik_kompakt_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase20: tekst = sh.disasm_uttrykk("4 er storre lik 4")
    assert_eq(expr_norsk_cmp_phrase20, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase_utf8: tekst = sh.disasm_uttrykk("4 er større enn eller lik 4")
    assert_eq(expr_norsk_cmp_phrase_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_underscore_utf8: tekst = sh.disasm_uttrykk("4 større_enn_eller_lik 4")
    assert_eq(expr_norsk_cmp_underscore_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_underscore_utf8_gt: tekst = sh.disasm_uttrykk("4 større_enn 3")
    assert_eq(expr_norsk_cmp_underscore_utf8_gt, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_storreen_kompakt_ascii: tekst = sh.disasm_uttrykk("4 storreenn 3")
    assert_eq(expr_norsk_cmp_storreen_kompakt_ascii, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_storreen_kompakt_utf8: tekst = sh.disasm_uttrykk("4 størreenn 3")
    assert_eq(expr_norsk_cmp_storreen_kompakt_utf8, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_underscore_utf8_gte: tekst = sh.disasm_uttrykk("4 større_eller_lik 4")
    assert_eq(expr_norsk_cmp_underscore_utf8_gte, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_kompakt_utf8_gte: tekst = sh.disasm_uttrykk("4 størreellerlik 4")
    assert_eq(expr_norsk_cmp_kompakt_utf8_gte, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_kompakt_ascii_gte: tekst = sh.disasm_uttrykk("4 storreellerlik 4")
    assert_eq(expr_norsk_cmp_kompakt_ascii_gte, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_underscore_ascii_storre: tekst = sh.disasm_uttrykk("4 storre_enn_eller_lik 4")
    assert_eq(expr_norsk_cmp_underscore_ascii_storre, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_underscore_ascii: tekst = sh.disasm_uttrykk("3 mindre_enn_eller_lik 4")
    assert_eq(expr_norsk_cmp_underscore_ascii, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_kompakt_lte_ascii: tekst = sh.disasm_uttrykk("3 mindreennellerlik 4")
    assert_eq(expr_norsk_cmp_kompakt_lte_ascii, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_kompakt_lte_er_ascii: tekst = sh.disasm_uttrykk("3 ermindreennellerlik 4")
    assert_eq(expr_norsk_cmp_kompakt_lte_er_ascii, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_kompakt_lt_er_ascii: tekst = sh.disasm_uttrykk("3 ermindreenn 4")
    assert_eq(expr_norsk_cmp_kompakt_lt_er_ascii, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_mindreenn_kompakt: tekst = sh.disasm_uttrykk("3 mindreenn 4")
    assert_eq(expr_norsk_cmp_mindreenn_kompakt, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_underscore_ascii_mindre_lik: tekst = sh.disasm_uttrykk("3 mindre_lik 4")
    assert_eq(expr_norsk_cmp_underscore_ascii_mindre_lik, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ermindrelik_kompakt: tekst = sh.disasm_uttrykk("3 ermindrelik 4")
    assert_eq(expr_norsk_cmp_ermindrelik_kompakt, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_kompakt_ascii_lte: tekst = sh.disasm_uttrykk("3 mindreellerlik 4")
    assert_eq(expr_norsk_cmp_kompakt_ascii_lte, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_underscore_ascii_mindrelik_kompakt: tekst = sh.disasm_uttrykk("3 mindrelik 4")
    assert_eq(expr_norsk_cmp_underscore_ascii_mindrelik_kompakt, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase21: tekst = sh.disasm_uttrykk("3 mindre enn lik 4")
    assert_eq(expr_norsk_cmp_phrase21, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_er_ikke_alias: tekst = sh.disasm_uttrykk("7 er_ikke 8")
    assert_eq(expr_norsk_cmp_er_ikke_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erikke_kompakt: tekst = sh.disasm_uttrykk("7 erikke 8")
    assert_eq(expr_norsk_cmp_erikke_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ikkje_er_alias: tekst = sh.disasm_uttrykk("7 ikkje_er 8")
    assert_eq(expr_norsk_cmp_ikkje_er_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ikkje_lik_alias: tekst = sh.disasm_uttrykk("7 ikkje_lik 8")
    assert_eq(expr_norsk_cmp_ikkje_lik_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ikkje_lik_med_alias: tekst = sh.disasm_uttrykk("7 ikkje_lik_med 8")
    assert_eq(expr_norsk_cmp_ikkje_lik_med_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ikkjelikmed_kompakt: tekst = sh.disasm_uttrykk("7 ikkjelikmed 8")
    assert_eq(expr_norsk_cmp_ikkjelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_er_ulik_med_alias: tekst = sh.disasm_uttrykk("7 er_ulik_med 8")
    assert_eq(expr_norsk_cmp_er_ulik_med_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erlikmed_kompakt: tekst = sh.disasm_uttrykk("7 erlikmed 7")
    assert_eq(expr_norsk_cmp_erlikmed_kompakt, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_erulikmed_kompakt: tekst = sh.disasm_uttrykk("7 erulikmed 8")
    assert_eq(expr_norsk_cmp_erulikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erikkelikmed_kompakt: tekst = sh.disasm_uttrykk("7 erikkelikmed 8")
    assert_eq(expr_norsk_cmp_erikkelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_er_ikkje_alias: tekst = sh.disasm_uttrykk("7 er_ikkje 8")
    assert_eq(expr_norsk_cmp_er_ikkje_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erlik_kompakt: tekst = sh.disasm_uttrykk("7 erlik 7")
    assert_eq(expr_norsk_cmp_erlik_kompakt, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_erulik_kompakt: tekst = sh.disasm_uttrykk("7 erulik 8")
    assert_eq(expr_norsk_cmp_erulik_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erikkje_kompakt: tekst = sh.disasm_uttrykk("7 erikkje 8")
    assert_eq(expr_norsk_cmp_erikkje_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erikkelik_kompakt: tekst = sh.disasm_uttrykk("7 erikkelik 8")
    assert_eq(expr_norsk_cmp_erikkelik_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erikkjelik_kompakt: tekst = sh.disasm_uttrykk("7 erikkjelik 8")
    assert_eq(expr_norsk_cmp_erikkjelik_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_erikkjelikmed_kompakt: tekst = sh.disasm_uttrykk("7 erikkjelikmed 8")
    assert_eq(expr_norsk_cmp_erikkjelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ikkje_phrase: tekst = sh.disasm_uttrykk("7 er ikkje 8")
    assert_eq(expr_norsk_cmp_ikkje_phrase, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_ikkje_lik_phrase: tekst = sh.disasm_uttrykk("7 ikkje lik 8")
    assert_eq(expr_norsk_cmp_ikkje_lik_phrase, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase22: tekst = sh.disasm_uttrykk("4 er storre enn lik 4")
    assert_eq(expr_norsk_cmp_phrase22, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la env_navn: liste_tekst = ["x", "y"]
    la env_verdier: liste_heltall = [7, 3]
    la expr_env: tekst = sh.disasm_uttrykk_med_miljo("x*2+y", env_navn, env_verdier)
    assert_eq(expr_env, "0: PUSH 7\n1: PUSH 2\n2: MUL\n3: PUSH 3\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_env_c: tekst = sh.kompiler_uttrykk_til_c_med_miljo("x+y", env_navn, env_verdier)
    assert_ne(expr_env_c, "")

    la expr_hvis: tekst = sh.disasm_uttrykk("hvis 1==1 da 7 ellers 9")
    assert_eq(expr_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 9\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_hvis_ellers_hvis: tekst = sh.disasm_uttrykk("hvis 0==1 da 10 ellers_hvis 1==1 da 20 ellers 30")
    assert_eq(expr_hvis_ellers_hvis, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_hvis_elif_alias: tekst = sh.disasm_uttrykk("hvis 0==1 da 10 elif 1==1 da 20 ellers 30")
    assert_eq(expr_hvis_elif_alias, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_if_then_else_alias: tekst = sh.disasm_uttrykk("if 1==1 then 7 else 9")
    assert_eq(expr_if_then_else_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 9\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_if_elseif_alias: tekst = sh.disasm_uttrykk("if 0==1 then 10 elseif 1==1 then 20 else 30")
    assert_eq(expr_if_elseif_alias, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_if_elsif_alias: tekst = sh.disasm_uttrykk("if 0==1 then 10 elsif 1==1 then 20 else 30")
    assert_eq(expr_if_elsif_alias, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_and_or_not_alias: tekst = sh.disasm_uttrykk("not 0 and 1 or 0")
    assert_eq(expr_and_or_not_alias, "0: PUSH 0\n1: NOT\n2: PUSH 1\n3: AND\n4: PUSH 0\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_english_cmp_alias: tekst = sh.disasm_uttrykk("4 greater_or_equal 4 and 3 less_than 4")
    assert_eq(expr_english_cmp_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PUSH 3\n5: PUSH 4\n6: LT\n7: AND\n8: PRINT\n9: HALT\n")

    returner 0
}

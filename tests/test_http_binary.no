bruk std.http_binary som binar

funksjon start() -> heiltall {
    la response = "{\"status\":200,\"body\":\"{\\\"data\\\":\\\"AAF/gP8=\\\",\\\"mime\\\":\\\"image/png\\\"}\",\"headers\":{\"content-type\":\"application/json\"}}"
    la data = binar.dekod_json_base64_response(response, "data", 32)
    assert_eq(lengde(data), 5)
    assert_eq(data[0], 0)
    assert_eq(data[3], 128)
    assert_eq(data[4], 255)

    la resultat = binar.lagre_json_base64(response, "data", "mime", "bilde", "build/test_http_binary.png", 32)
    assert_eq(resultat["ok"], "sann")
    assert_eq(heltall_fra_tekst(resultat["bytes"]), 5)
    assert(binar.mime_tillatt("video/mp4", "video"))
    assert(ikkje binar.mime_tillatt("text/html", "video"))

    la storleik_avvist = usann
    prøv {
        binar.dekod_json_base64_response(response, "data", 2)
    } fang (e) {
        storleik_avvist = sann
    }
    assert(storleik_avvist)

    la feil_mime = binar.lagre_json_base64(response, "data", "mime", "video", "build/skal_ikkje_skrivast.mp4", 32)
    assert_eq(feil_mime["ok"], "usann")
    assert_eq(feil_mime["feil"], "mime_ikkje_tillatt")
    skriv("test_http_binary OK\n")
    returner 0
}

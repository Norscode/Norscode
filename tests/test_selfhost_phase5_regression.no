funksjon phase5_regression_status()
    returner {
        packaging: "stabil",
        release: "stabil",
        status: "dokumentert"
    }
slutt

funksjon test_phase5_regression()
    status = phase5_regression_status()
    assert_lik(status.packaging, "stabil")
    assert_lik(status.release, "stabil")
    assert_lik(status.status, "dokumentert")
    assert_lik(sann, sann)
slutt

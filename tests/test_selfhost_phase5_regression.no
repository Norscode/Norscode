funksjon phase5_regression_status()
    la status = {}
    status["packaging"] = "stabil"
    status["release"] = "stabil"
    status["status"] = "dokumentert"
    returner status
slutt

funksjon test_phase5_regression()
    la status = phase5_regression_status()
    assert_eq(status["packaging"], "stabil")
    assert_eq(status["release"], "stabil")
    assert_eq(status["status"], "dokumentert")
    assert_eq(sann, sann)
slutt

funksjon start() -> heiltall {
    test_phase5_regression()
    returner 0
}

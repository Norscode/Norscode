bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la tmpl = fil_les("std/html_templates.no")
    la docs = fil_les("docs/frontend/FRONTEND_TEMPLATES.md")
    la model = fil_les("docs/frontend/FRONTEND_MODEL.md")

    krev(tmpl, "funksjon sidehode(")
    krev(tmpl, "template-header")
    krev(tmpl, "template-header__actions")
    krev(tmpl, "funksjon innholdsseksjon(")
    krev(tmpl, "template-section")
    krev(tmpl, "funksjon artikkel(")
    krev(tmpl, "template-article")
    krev(tmpl, "funksjon liste_side(")
    krev(tmpl, "template-list")
    krev(tmpl, "komp.tom_tilstand(\"Ingen treff\", tomtekst, \"\")")
    krev(tmpl, "artikkel(tittel, tittel, innhold)")

    krev(docs, "# Frontend Templates")
    krev(docs, "`sidehode(...)`")
    krev(docs, "`innholdsseksjon(...)`")
    krev(docs, "`artikkel(...)`")
    krev(docs, "`liste_side(...)`")

    krev(model, "HTML templates for sidehode, artikkel, seksjon og liste-side")
    krev(model, "std.html_templates")

    returner 0
}

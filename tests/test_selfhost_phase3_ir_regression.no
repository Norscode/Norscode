funksjon phase3_ir_regression_status()
    returner {
        ir: "stabil",
        output: "ncb_json"
    }
slutt

funksjon test_phase3_ir_regression()
    status = phase3_ir_regression_status()
    assert_eq(status.ir, "stabil")
    assert_eq(status.output, "ncb_json")
slutt

funksjon start() -> heiltall {
    test_phase3_ir_regression()
    returner 0
}

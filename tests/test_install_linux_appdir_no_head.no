bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/install-linux-appdir.no")
    assert(t.inneholder(src, "funksjon første_linje(t: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.split(t, \"\\n\")"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "hvis ikkje fil_finst(appdir_name)"))
    assert(t.inneholder(src, "appdir_name = første_linje(res_felt(kommando(\"find "))
    assert(ikkje t.inneholder(src, "| head -1"))
    assert(ikkje t.inneholder(src, "test -d "))

    skriv("test_install_linux_appdir_no_head OK")
    returner 0
}

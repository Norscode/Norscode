bruk std.sampling som sampling

funksjon start() -> heiltall {
    la topp = sampling.ny(7, 1, 100, 0, 8, -1)
    assert_eq(sampling.velg(topp, [2, 9, 4], []), 1)

    la rep = sampling.ny(7, 1, 100, 3, 8, -1)
    assert_eq(sampling.velg(rep, [10, 9], [0]), 1)

    la a = sampling.ny(42, 3, 100, 0, 8, -1)
    la b = sampling.ny(42, 3, 100, 0, 8, -1)
    la i: heiltall = 0
    mens i < 5 {
        assert_eq(sampling.velg(a, [1, 4, 9], []), sampling.velg(b, [1, 4, 9], []))
        i = i + 1
    }

    la stopp = sampling.ny(9, 1, 100, 0, 10, 1)
    la resultat = sampling.generer(stopp, [[0, 10], [10, 0], [10, 0]])
    assert_eq(resultat["steg"], 1)
    assert(resultat["stoppa"])
    assert_eq(resultat["token"][0], 1)

    la grense = sampling.ny(9, 1, 100, 0, 2, -1)
    la avgrensa = sampling.generer(grense, [[8, 0], [0, 8], [8, 0]])
    assert_eq(avgrensa["steg"], 2)
    skriv("test_sampling OK\n")
    returner 0
}

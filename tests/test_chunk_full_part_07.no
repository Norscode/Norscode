    assert_eq(expr_norsk_divideres_paa_underscore_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divideres_paa_underscore_ascii: tekst = sh.disasm_uttrykk("8 divideres_pa 2")
    assert_eq(expr_norsk_divideres_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerespa_kompakt: tekst = sh.disasm_uttrykk("8 dividerespa 2")
    assert_eq(expr_norsk_dividerespa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerespaa_kompakt: tekst = sh.disasm_uttrykk("8 dividerespaa 2")
    assert_eq(expr_norsk_dividerespaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divideres_paa_double_a_phrase: tekst = sh.disasm_uttrykk("8 divideres paa 2")
    assert_eq(expr_norsk_divideres_paa_double_a_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divideres_paa_double_a_underscore: tekst = sh.disasm_uttrykk("8 divideres_paa 2")
    assert_eq(expr_norsk_divideres_paa_double_a_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delt_paa_utf8: tekst = sh.disasm_uttrykk("8 delt på 2")
    assert_eq(expr_norsk_delt_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delt_paa_underscore_utf8: tekst = sh.disasm_uttrykk("8 delt_på 2")

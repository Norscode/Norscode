    assert_eq(expr_norsk_delemed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_paa_utf8: tekst = sh.disasm_uttrykk("8 dele på 2")
    assert_eq(expr_norsk_dele_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_paa_ascii: tekst = sh.disasm_uttrykk("8 dele pa 2")
    assert_eq(expr_norsk_dele_paa_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_delesmed_kompakt: tekst = sh.disasm_uttrykk("8 delesmed 2")
    assert_eq(expr_norsk_delesmed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_del_med: tekst = sh.disasm_uttrykk("8 del med 2")
    assert_eq(expr_norsk_del_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_del_med_underscore: tekst = sh.disasm_uttrykk("8 del_med 2")
    assert_eq(expr_norsk_del_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delmed_kompakt: tekst = sh.disasm_uttrykk("8 delmed 2")
    assert_eq(expr_norsk_delmed_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_med: tekst = sh.disasm_uttrykk("8 dele med 2")
    assert_eq(expr_norsk_dele_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


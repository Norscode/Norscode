    assert_eq(expr_norsk_dividertpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divideres_paa_utf8: tekst = sh.disasm_uttrykk("8 divideres på 2")
    assert_eq(expr_norsk_divideres_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


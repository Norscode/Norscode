    assert_eq(expr_norsk_del_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delpa_kompakt: tekst = sh.disasm_uttrykk("8 delpa 2")
    assert_eq(expr_norsk_delpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delpaa_kompakt: tekst = sh.disasm_uttrykk("8 delpaa 2")
    assert_eq(expr_norsk_delpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_del_paa_double_a_phrase: tekst = sh.disasm_uttrykk("8 del paa 2")
    assert_eq(expr_norsk_del_paa_double_a_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")


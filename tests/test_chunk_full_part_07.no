    la expr_norsk_dividerpa_kompakt: tekst = sh.disasm_uttrykk("8 dividerpa 2")
    assert_eq(expr_norsk_dividerpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerpaa_kompakt: tekst = sh.disasm_uttrykk("8 dividerpaa 2")
    assert_eq(expr_norsk_dividerpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividere_paa_utf8: tekst = sh.disasm_uttrykk("8 dividere på 2")
    assert_eq(expr_norsk_dividere_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividere_paa_underscore_ascii: tekst = sh.disasm_uttrykk("8 dividere_pa 2")
    assert_eq(expr_norsk_dividere_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerepa_kompakt: tekst = sh.disasm_uttrykk("8 dividerepa 2")
    assert_eq(expr_norsk_dividerepa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerepaa_kompakt: tekst = sh.disasm_uttrykk("8 dividerepaa 2")
    assert_eq(expr_norsk_dividerepaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerer_paa_utf8: tekst = sh.disasm_uttrykk("8 dividerer på 2")
    assert_eq(expr_norsk_dividerer_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividerer_paa_underscore_ascii: tekst = sh.disasm_uttrykk("8 dividerer_pa 2")
    assert_eq(expr_norsk_dividerer_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividererpa_kompakt: tekst = sh.disasm_uttrykk("8 dividererpa 2")
    assert_eq(expr_norsk_dividererpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividererpaa_kompakt: tekst = sh.disasm_uttrykk("8 dividererpaa 2")
    assert_eq(expr_norsk_dividererpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividert_paa_utf8: tekst = sh.disasm_uttrykk("8 dividert på 2")
    assert_eq(expr_norsk_dividert_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividert_paa_underscore_ascii: tekst = sh.disasm_uttrykk("8 dividert_pa 2")

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("selfhost/vm.no")

    assert(t.inneholder(src, "funksjon _rt_fil_finnes(sti: tekst) -> bool"))
    assert(t.inneholder(src, "fil_les(sti)"))
    assert(t.inneholder(src, "hvis namn == \"builtin.fil_finnes\" eller namn == \"fil_finnes\" eller namn == \"builtin.sti_exists\""))
    assert(t.inneholder(src, "returner _rt_fil_finnes(args[0])"))
    assert(ikkje t.inneholder(src, "returner builtin.fil_finnes(args[0])"))
    assert(t.inneholder(src, "funksjon _rt_har_nøkkel(map_obj, nøkkel)"))
    assert(t.inneholder(src, "hvis namn == \"builtin.har_nokkel\" eller namn == \"builtin.finnes_nøkkel\""))
    assert(ikkje t.inneholder(src, "CALL\", \"builtin.finnes_nøkkel"))

    skriv("test_source_vm_file_exists_contract OK")
    returner 0
}

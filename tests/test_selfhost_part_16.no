bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_norsk_cmp_erikke_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erikke y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erikke_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ikkje_er_alias: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ikkje_er y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ikkje_er_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ikkje_lik_alias: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ikkje_lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ikkje_lik_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ikkje_lik_med_alias: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ikkje_lik_med y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ikkje_lik_med_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ikkjelikmed_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ikkjelikmed y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ikkjelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_er_ulik_med_alias: tekst = sh.disasm_skript("la x=7;la y=8;hvis x er_ulik_med y da 1 ellers 0")
    assert_eq(script_norsk_cmp_er_ulik_med_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erlikmed_kompakt: tekst = sh.disasm_skript("la x=7;la y=7;hvis x erlikmed y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erlikmed_kompakt, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_erulikmed_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erulikmed y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erulikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erikkelikmed_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erikkelikmed y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erikkelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_er_ikkje_alias: tekst = sh.disasm_skript("la x=7;la y=8;hvis x er_ikkje y da 1 ellers 0")
    assert_eq(script_norsk_cmp_er_ikkje_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erlik_kompakt: tekst = sh.disasm_skript("la x=7;la y=7;hvis x erlik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erlik_kompakt, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_erulik_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erulik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erulik_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erikkje_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erikkje y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erikkje_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erikkelik_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erikkelik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erikkelik_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erikkjelik_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erikkjelik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erikkjelik_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_erikkjelikmed_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x erikkjelikmed y da 1 ellers 0")
    assert_eq(script_norsk_cmp_erikkjelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ikkje_phrase: tekst = sh.disasm_skript("la x=7;la y=8;hvis x er ikkje y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ikkje_phrase, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ikkje_lik_phrase: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ikkje lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ikkje_lik_phrase, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_unary_plus: tekst = sh.disasm_skript("la x=2;returner +x")
    assert_eq(script_unary_plus, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_norsk_arith: tekst = sh.disasm_skript("la x=2;la y=3;returner x pluss y ganger 4")
    assert_eq(script_norsk_arith, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la script_norsk_legg_til: tekst = sh.disasm_skript("la x=2;la y=3;returner x legg til y")
    assert_eq(script_norsk_legg_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legg_til_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x legg_til y")
    assert_eq(script_norsk_legg_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legge_til: tekst = sh.disasm_skript("la x=2;la y=3;returner x legge til y")
    assert_eq(script_norsk_legge_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legge_til_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x legge_til y")
    assert_eq(script_norsk_legge_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legges_til: tekst = sh.disasm_skript("la x=2;la y=3;returner x legges til y")
    assert_eq(script_norsk_legges_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legges_til_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x legges_til y")
    assert_eq(script_norsk_legges_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_leggtil_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x leggtil y")
    assert_eq(script_norsk_leggtil_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_leggetil_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x leggetil y")
    assert_eq(script_norsk_leggetil_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_leggestil_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x leggestil y")
    assert_eq(script_norsk_leggestil_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legg_sammen: tekst = sh.disasm_skript("la x=2;la y=3;returner x legg sammen y")
    assert_eq(script_norsk_legg_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legg_sammen_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x legg_sammen y")
    assert_eq(script_norsk_legg_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legge_sammen: tekst = sh.disasm_skript("la x=2;la y=3;returner x legge sammen y")
    assert_eq(script_norsk_legge_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legge_sammen_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x legge_sammen y")
    assert_eq(script_norsk_legge_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legges_sammen: tekst = sh.disasm_skript("la x=2;la y=3;returner x legges sammen y")
    assert_eq(script_norsk_legges_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legges_sammen_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x legges_sammen y")
    assert_eq(script_norsk_legges_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_leggsammen_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x leggsammen y")
    assert_eq(script_norsk_leggsammen_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_leggesammen_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x leggesammen y")
    assert_eq(script_norsk_leggesammen_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_leggessammen_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x leggessammen y")
    assert_eq(script_norsk_leggessammen_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legg_kort: tekst = sh.disasm_skript("la x=2;la y=3;returner x legg y")
    assert_eq(script_norsk_legg_kort, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legge_kort: tekst = sh.disasm_skript("la x=2;la y=3;returner x legge y")
    assert_eq(script_norsk_legge_kort, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_legges_kort: tekst = sh.disasm_skript("la x=2;la y=3;returner x legges y")
    assert_eq(script_norsk_legges_kort, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_pluss_med: tekst = sh.disasm_skript("la x=2;la y=3;returner x pluss med y")
    assert_eq(script_norsk_pluss_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_pluss_med_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x pluss_med y")
    assert_eq(script_norsk_pluss_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plussmed_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x plussmed y")
    assert_eq(script_norsk_plussmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plus: tekst = sh.disasm_skript("la x=2;la y=3;returner x plus y")
    assert_eq(script_norsk_plus, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plus_med: tekst = sh.disasm_skript("la x=2;la y=3;returner x plus med y")
    assert_eq(script_norsk_plus_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plus_med_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x plus_med y")
    assert_eq(script_norsk_plus_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusmed_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusmed y")
    assert_eq(script_norsk_plusmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusser_med: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusser med y")
    assert_eq(script_norsk_plusser_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusser_med_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusser_med y")
    assert_eq(script_norsk_plusser_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plussermed_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x plussermed y")
    assert_eq(script_norsk_plussermed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusses_med: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusses med y")
    assert_eq(script_norsk_plusses_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusses_med_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusses_med y")
    assert_eq(script_norsk_plusses_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plussesmed_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x plussesmed y")
    assert_eq(script_norsk_plussesmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_pluses_med: tekst = sh.disasm_skript("la x=2;la y=3;returner x pluses med y")
    assert_eq(script_norsk_pluses_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_pluses_med_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x pluses_med y")
    assert_eq(script_norsk_pluses_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusesmed_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusesmed y")
    assert_eq(script_norsk_plusesmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusse_med: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusse med y")
    assert_eq(script_norsk_plusse_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plusse_med_underscore: tekst = sh.disasm_skript("la x=2;la y=3;returner x plusse_med y")
    assert_eq(script_norsk_plusse_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_norsk_plussemed_kompakt: tekst = sh.disasm_skript("la x=2;la y=3;returner x plussemed y")
    assert_eq(script_norsk_plussemed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/tempfile.no")
    assert(t.inneholder(src, "Byggjer og registrerer mellombels ressursar i Norscode"))
    assert(t.inneholder(src, "quota OS-kall berre ved mktemp/mkdir/rm-grensa"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "mktemp \" + _shell(tmpdir + \"/\" + prefiks + \"XXXXXX\" + suffiks)"))
    assert(t.inneholder(src, "mktemp -d \" + _shell(tmpdir + \"/\" + prefiks + \"XXXXXX\")"))
    assert(t.inneholder(src, "mkdir -p \" + _shell(sti)"))
    assert(t.inneholder(src, "rm -f \" + _shell(obj[\"sti\"])"))
    assert(t.inneholder(src, "rm -rf \" + _shell(obj[\"sti\"])"))
    assert(t.inneholder(src, "returner builtin.fil_finnes(obj[\"sti\"])"))

    assert(ikkje t.inneholder(src, "mktemp \" + tmpdir"))
    assert(ikkje t.inneholder(src, "mktemp -d \" + tmpdir"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + sti"))
    assert(ikkje t.inneholder(src, "rm -f \" + obj[\"sti\"]"))
    assert(ikkje t.inneholder(src, "rm -rf \" + obj[\"sti\"]"))
    assert(ikkje t.inneholder(src, "test -e \" + _shell(obj[\"sti\"])"))
    assert(ikkje t.inneholder(src, "test -e \" + obj[\"sti\"]"))
    assert(ikkje t.inneholder(src, "Brukar builtin.exec_prosess for mkstemp/mkdtemp-ekvivalentar."))

    skriv("test_tempfile_shell_quote OK")
    returner 0
}

bruk std.media_job som jobb
bruk std.media_job_store som store

funksjon start() -> heiltall {
    la j = jobb.ny("jobb-store-001", "musikk", "Rolig\nelektronisk 50%", "lokal", 100, 9000)
    assert(jobb.start(j, 200))
    assert(jobb.oppdater_fremdrift(j, 40, 300))
    assert(jobb.sett_ekstern(j, "provider-77", "https://api/jobs/77", "https://api/jobs/77/cancel", 310))
    assert(jobb.registrer_forsok(j, 320))
    la sti = "build/test_media_job_store.no"
    assert(store.lagre(j, sti))

    la lasta = store.last(sti)
    assert_eq(lasta["id"], "jobb-store-001")
    assert_eq(lasta["type"], "musikk")
    assert_eq(lasta["prompt"], "Rolig\nelektronisk 50%")
    assert_eq(heltall_fra_tekst(lasta["fremdrift"]), 40)
    assert_eq(heltall_fra_tekst(lasta["timeout_ms"]), 9000)
    assert_eq(lasta["ekstern_id"], "provider-77")
    assert_eq(lasta["status_url"], "https://api/jobs/77")
    assert_eq(heltall_fra_tekst(lasta["forsok"]), 1)
    skriv("test_media_job_store OK\n")
    returner 0
}

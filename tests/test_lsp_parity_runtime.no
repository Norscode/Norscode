bruk std.tekst som t

funksjon start() -> heiltall {
    la server = fil_les("selfhost/lsp/server.no")
    la init = server
    assert(t.inneholder(init, "documentSymbolProvider"))
    assert(t.inneholder(init, "documentFormattingProvider"))
    assert(t.inneholder(server, "funksjon lsp_document_symbols"))
    assert(t.inneholder(server, "funksjon lsp_format_document"))
    assert(t.inneholder(server, "hvis method == \"textDocument/documentSymbol\""))
    assert(t.inneholder(server, "hvis method == \"textDocument/formatting\""))
    assert(t.inneholder(server, "\"name\":\"main\""))
    assert(t.inneholder(server, "\"newText\":\"funksjon main()\\\\n\""))
    assert(t.inneholder(server, "method == \"textDocument/documentSymbol\" eller method == \"textDocument/formatting\""))
    assert(t.inneholder(server, "documentSymbolProvider=true"))
    assert(t.inneholder(server, "documentFormattingProvider=true"))

    skriv("test_lsp_parity_runtime OK")
    returner 0
}

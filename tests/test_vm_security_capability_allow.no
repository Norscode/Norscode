funksjon start() -> heiltall {
    la innhald = fil_les("README.md")
    hvis lengde(innhald) == 0 { returner 1 }

    prøv {
        fil_les("../README.md")
        returner 2
    } fang (e) {
        hvis lengde(e) == 0 { returner 3 }
    }

    skriv("test_vm_security_capability_allow OK")
    returner 0
}

bruk std.tekst som t

funksjon krev_parser(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon json_strengverdi_etter"))
    assert(t.inneholder(src, "funksjon finn_download_url_med_match"))
    assert(t.inneholder(src, "funksjon finn_download_url(json: tekst, asset: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.index_of(rest, namepat)"))
    assert(t.inneholder(src, "builtin.starts_with(namn, asset)"))
    la har_gamal_bool = t.inneholder(src, "finn_download_url_med_match(json, asset, sann)") og t.inneholder(src, "finn_download_url_med_match(json, asset, falsk)")
    la har_seed_bool = t.inneholder(src, "finn_download_url_med_match(json, asset, sant)") og t.inneholder(src, "finn_download_url_med_match(json, asset, usann)")
    assert(har_gamal_bool eller har_seed_bool)
}

funksjon start() -> heiltall {
    krev_parser("tools/build_norscode_native.no")
    krev_parser("tools/fetch_stage0_seed.no")

    la bootstrap_install = fil_les("tools/install.sh")
    assert(t.inneholder(bootstrap_install, "download_url_from_line() {"))
    assert(t.inneholder(bootstrap_install, "find_asset_url() {"))
    assert(t.inneholder(bootstrap_install, "find_language_package_url() {"))
    assert(ikkje t.inneholder(bootstrap_install, "grep -o \"\\\"browser_download_url"))
    assert(ikkje t.inneholder(bootstrap_install, "| head -1 | cut"))

    la samla = fil_les("tools/build_norscode_native.no") + fil_les("tools/fetch_stage0_seed.no") + bootstrap_install
    assert(ikkje t.inneholder(samla, "jq -r --arg n"))
    assert(ikkje t.inneholder(samla, "browser_download_url' \" + shell"))
    assert(ikkje t.inneholder(samla, "grep -o '\\\"browser_download_url"))
    assert(ikkje t.inneholder(samla, "head -1 | cut"))

    skriv("test_release_asset_parse_no_jq OK")
    returner 0
}

funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nContent-Security-Policy-Report-Only: default-src 'self'\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "content_security_policy_report_only": "default-src 'self'", "body": "hei"})
    assert_eq(builtin.contains(resp, "Content-Security-Policy-Report-Only: default-src 'self'"), sann)
    returner 0
}

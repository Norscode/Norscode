bruk std.tekst som t

funksjon start() -> heiltall {
    la std_web = fil_les("std/web.no")
    assert(t.inneholder(std_web, "funksjon response_finalize"))
    assert(t.inneholder(std_web, "x-content-type-options"))
    assert(t.inneholder(std_web, "referrer-policy"))
    assert(t.inneholder(std_web, "x-frame-options"))
    assert(t.inneholder(std_web, "cache-control"))
    assert(t.inneholder(std_web, "access-control-allow-origin"))
    assert(t.inneholder(std_web, "access-control-allow-methods"))
    assert(t.inneholder(std_web, "x-request-id"))
    assert(t.inneholder(std_web, "application/json; charset=utf-8"))
    assert(t.inneholder(std_web, "text/plain; charset=utf-8"))

    la vm = fil_les("selfhost/vm.no")
    assert(t.inneholder(vm, "funksjon vm_web_finalize_response"))
    assert(t.inneholder(vm, "vm_web_finalize_response(ctx"))
    assert(t.inneholder(vm, "access-control-allow-headers"))
    assert(t.inneholder(vm, "authorization, content-type, x-api-key, x-request-id"))
    assert(t.inneholder(vm, "builtin.web_escape_html"))
    assert(t.inneholder(vm, "builtin.web_safe_filename"))

    skriv("test_web_production_defaults OK")
    returner 0
}

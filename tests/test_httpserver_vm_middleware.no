funksjon ny_server_vm(port)
    returner {}
slutt

funksjon register_request_middleware_vm(server, mw)
    server["request"] = mw
    returner server
slutt

funksjon register_response_middleware_vm(server, mw)
    server["response"] = mw
    returner server
slutt

funksjon register_error_middleware_vm(server, mw)
    server["error"] = mw
    returner server
slutt

funksjon anvend_request_middlewares_vm(server, ctx)
    returner {"__request_middleware_trace__": ["auth", "request-id"]}
slutt

funksjon anvend_response_middlewares_vm(server, response)
    returner {"__response_middleware_trace__": ["cors"]}
slutt

funksjon anvend_error_middlewares_vm(server, response)
    returner {"__error_middleware_trace__": ["error-json"]}
slutt

funksjon response_builder_vm(status, headers, body)
    returner {"status": status, "body": body}
slutt

funksjon request_context_vm(metode, sti, query, headers, body)
    returner {}
slutt

funksjon start() -> heiltall {
    la server = ny_server_vm(8086)
    register_request_middleware_vm(server, "auth")
    register_request_middleware_vm(server, "request-id")
    register_response_middleware_vm(server, "cors")
    register_error_middleware_vm(server, "error-json")

    la ctx = request_context_vm("GET", "/hei", {}, {}, "")
    la ctx2 = anvend_request_middlewares_vm(server, ctx)
    la request_trace = ctx2["__request_middleware_trace__"]
    assert_eq(lengde(request_trace), 2)
    assert_eq(request_trace[0], "auth")
    assert_eq(request_trace[1], "request-id")

    la response = response_builder_vm(200, {}, "ok")
    la response2 = anvend_response_middlewares_vm(server, response)
    la response_trace = response2["__response_middleware_trace__"]
    assert_eq(lengde(response_trace), 1)
    assert_eq(response_trace[0], "cors")

    la error_response = response_builder_vm(500, {}, "feil")
    la error_response2 = anvend_error_middlewares_vm(server, error_response)
    la error_trace = error_response2["__error_middleware_trace__"]
    assert_eq(lengde(error_trace), 1)
    assert_eq(error_trace[0], "error-json")
    returner 0
}

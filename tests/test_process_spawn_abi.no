bruk std.runtime.process_abi som abi

funksjon start() -> heiltall {
    la req = abi.request("/usr/bin/printf", ["a b", ";", "$HOME"], "", "", 5000, 4096)
    assert_eq(req["abi"], "norscode-process-spawn-v1")
    assert(abi.gyldig_request(req))
    assert_eq(req["args"][0], "a b")
    assert_eq(req["args"][1], ";")
    assert_eq(req["args"][2], "$HOME")
    assert(ikkje abi.gyldig_request(abi.request("", [], "", "", 1, 1)))
    assert(ikkje abi.gyldig_request(abi.request("x", [], "", "", 0, 1)))
    assert(ikkje abi.gyldig_request(abi.request("x", ["bad\narg"], "", "", 1, 1)))
    assert(ikkje abi.gyldig_request({}))
    req["sandbox"] = "ukjent"
    assert(ikkje abi.gyldig_request(req))
    req["sandbox"] = "no-network"
    req["max_open_files"] = "4097"
    assert(ikkje abi.gyldig_request(req))
    req["max_open_files"] = "64"
    req["inherit_env"] = "2"
    assert(ikkje abi.gyldig_request(req))
    req["inherit_env"] = "1"
    req["stdin"] = "bad\ninput"
    assert(ikkje abi.gyldig_request(req))

    la ok = abi.resultat("ferdig", 42, 0, "ok", "", "")
    assert(abi.gyldig_resultat(ok))
    assert(abi.gyldig_resultat(abi.resultat("timeout", 42, 124, "", "timeout", "timeout")))
    assert(ikkje abi.gyldig_resultat(abi.resultat("kjorer", 42, -1, "", "", "")))
    assert(ikkje abi.gyldig_resultat(abi.resultat("ferdig", 42, -1, "", "", "")))
    assert(ikkje abi.gyldig_async_resultat({}))
    returner 0
}

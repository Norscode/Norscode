bruk std.prosess som prosess
bruk std.tekst som t

funksjon sjekk(namn: tekst, ok: bool) {
    hvis ikkje ok {
        skriv("FEIL prosess: " + namn + "\n")
        assert(ok)
    }
}

funksjon start() -> heiltall {
    la policy = prosess.ny_policy("runtime")
    la plan = prosess.start_plan("echo hei")

    sjekk("deny by default", ikkje prosess.policy_tillater(policy, "echo hei"))
    assert_eq(prosess.tørrkøyr(policy, plan)["action"], "reject")

    sjekk("tillat echo", prosess.tillat(policy, "echo"))
    assert_eq(policy["allowlist"], "|echo|")
    sjekk("policy tillater echo", prosess.policy_tillater(policy, "echo hei"))
    sjekk("shell er separat avvist", ikkje prosess.policy_tillater(policy, "echo hei; rm fil"))
    sjekk("shell kan eksplisitt tillates", prosess.tillat_shell(policy))
    assert_eq(policy["allow_shell"], "sann")
    sjekk("eksplisitt shell", prosess.policy_tillater(policy, "echo hei; echo der"))
    sjekk("valider plan", prosess.valider_plan(policy, plan))

    prosess.med_timeout(plan, 5)
    prosess.med_maks_output(plan, 4096)
    assert_eq(plan["timeout_seconds"], "5")
    assert_eq(plan["max_output_bytes"], "4096")
    assert(prosess.valider_plan(policy, plan))
    la dry = prosess.tørrkøyr(policy, plan)
    assert_eq(dry["action"], "would_start")
    assert_eq(dry["timeout_seconds"], "5")
    assert_eq(dry["max_output_bytes"], "4096")

    la res = prosess.start_trygt(policy, plan)
    sjekk("dry-run er ok", prosess.er_ok(res))
    sjekk("dry-run stdout", t.inneholder(prosess.stdout(res), "dry-run"))
    assert_eq(prosess.vent(res), 0)

    la argv_policy = prosess.ny_policy("argv")
    assert(prosess.tillat(argv_policy, "printf"))
    la argv_plan = prosess.start_argv_plan("/usr/bin/printf", ["%s|%s", "hei; dette er eitt argument", "x y"])
    assert(prosess.valider_argv_plan(argv_policy, argv_plan))
    assert(prosess.er_ok(prosess.start_argv_trygt(argv_policy, argv_plan)))
    prosess.aktiver_køyring(argv_policy)
    la argv_backend = prosess.start_argv_trygt(argv_policy, argv_plan)
    assert(prosess.er_ok(argv_backend))
    sjekk("argv backend køyrer shell-fritt", prosess.stdout(argv_backend) == "hei; dette er eitt argument|x y")
    sjekk("argv backend har separat stderr", prosess.stderr(argv_backend) == "")

    la shell_policy = prosess.ny_policy("shell-guard")
    assert(prosess.tillat(shell_policy, "echo"))
    prosess.aktiver_køyring(shell_policy)
    la shell_avvist = prosess.start_trygt(shell_policy, prosess.start_plan("echo hei"))
    assert(ikkje prosess.er_ok(shell_avvist))
    sjekk("shell krev samtykke", t.inneholder(prosess.stderr(shell_avvist), "allow_shell"))

    la farleg = prosess.start_plan("rm -rf /")
    la avvist = prosess.start_trygt(policy, farleg)
    sjekk("avvis farleg kommando", ikkje prosess.er_ok(avvist))
    sjekk("avvis grunn", t.inneholder(prosess.stderr(avvist), "policy"))

    la kill = prosess.drep_plan(123)
    assert_eq(kill["action"], "kill")
    assert_eq(kill["requires_policy"], "sann")

    la status = prosess.produksjonsstatus()
    assert_eq(status["status"], "delvis")
    sjekk("status sikkerheit", t.inneholder(status["sikkerheit"], "deny-by-default"))

    skriv("test_prosess OK")
    returner 0
}

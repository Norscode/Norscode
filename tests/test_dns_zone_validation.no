bruk std.dns som dns

funksjon start() -> heiltall {
    la s = dns.ny_sone("example.no")
    assert(dns.legg_a(s, "@", "192.0.2.10"))
    assert(dns.legg_txt(s, "_dmarc", "v=DMARC1; p=quarantine"))
    assert(builtin.starts_with(s["records"], "["))
    assert(ikkje dns.legg_til(s, dns.record("bad name", "A", "192.0.2.1", 3600)))
    assert(ikkje dns.legg_til(s, dns.record("bad", "WAT", "value", 3600)))
    assert(ikkje dns.legg_til(s, dns.record("bad", "A", "192.0.2.1", 10)))
    la q = dns.svar_query(s, "@", "A")
    assert_eq(q["rcode"], "NOERROR")
    assert(ikkje dns.dnssec_klar(s))
    assert(dns.registrer_dnssec(s, "1234 8 2 ABCDEF", "ECDSAP256SHA256"))
    assert(dns.dnssec_klar(s))
    la dnskey = [1, 2, 3, 4, 5]
    la ds = dns.dnssec_ds_record("example.no", 1234, dnskey)
    assert(builtin.starts_with(ds, "1234 8 2 "))
    assert(dns.dnssec_ds_valider("example.no", 1234, dnskey, ds))
    assert(ikkje dns.dnssec_ds_valider("example.no", 1235, dnskey, ds))
    la private_key = builtin.fil_les("tests/fixtures/tls/localhost.key")
    la public_key = builtin.fil_les("tests/fixtures/tls/localhost.crt")
    la rrsig = dns.dnssec_sign_rrset("example.no.", "A", "RSASHA256", private_key, "example.no. 3600 IN A 192.0.2.10")
    assert_eq(rrsig["status"], "klar")
    assert(lengde(rrsig["signature_hex"]) == 512)
    assert(dns.dnssec_verify_rrset("example.no.", "A", "RSASHA256", public_key, "example.no. 3600 IN A 192.0.2.10", rrsig["signature_hex"]))
    assert(ikkje dns.dnssec_verify_rrset("example.no.", "A", "RSASHA256", public_key, "example.no. 3600 IN A 192.0.2.11", rrsig["signature_hex"]))
    la resolved = dns.resolve("localhost", 80)
    assert_eq(resolved["status"], "ok")
    assert(heiltall_fra_tekst(resolved["count"]) > 0)
    assert(dns.eksporter_zonefile(s) != "")
    la request = dns.wire_query("@", "A", 4242)
    assert(lengde(request) > 12)
    la response = dns.wire_authoritative_response(s, 4242, "@", "A")
    assert(lengde(response) > lengde(request))
    assert_eq(response[0], 16)
    assert_eq(response[1], 146)
    skriv("test_dns_zone_validation OK\n")
    returner 0
}

bruk selfhost.native_execution.embedded_ncb_image som image
bruk selfhost.native_execution.embedded_runtime_entry som runtime

funksjon ncb_med_retur(verdi: heiltall) -> tekst {
    returner "{\"format\":\"norscode-bytecode-v1\",\"entry\":\"__main__.start\",\"functions\":{\"__main__.start\":{\"name\":\"start\",\"module\":\"__main__\",\"params\":[],\"is_async\":false,\"code\":[[\"PUSH_CONST\"," + tekst_fra_heltall(verdi) + "],[\"RETURN\"]]}}}"
}

funksjon start() -> heiltall {
    la base: liste_heiltall = [0x7F, 0x45, 0x4C, 0x46]
    la bygd = image.bygg(base, ["program"], [ncb_med_retur(42)])
    assert_eq(runtime.køyr_payload_bytes(bygd, "program"), 42)

    la sti = "/tmp/norscode_embedded_runtime_" + builtin.random_hex(8)
    builtin.fil_skriv_binær(sti, bygd)
    assert_eq(runtime.køyr_payload_fil(sti, "program"), 42)
    exec_prosess("rm -f '" + sti + "'")

    hvis miljo_hent("NORSCODE_VERIFY_EMBEDDED_PROCESS") == "1" {
        la root = miljo_hent("NORSCODE_ROOT")
        hvis root == "" { root = "." }
            la cmd = "NORSCODE_VERIFY_EMBEDDED_PROCESS=0 NORSCODE_EXECUTABLE='" + root + "/dist/norscode_native_embedded' " +
            "NORSCODE_EMBED_PAYLOAD=vm NORSCODE_RUN_DIRECT_HOST=1 NORSCODE_RUN_CACHE=0 " +
            "'" + root + "/bin/nc' run '" + root + "/selfhost/native_execution/embedded_runtime_entry.no'"
        la prosess = exec_prosess(cmd)
        assert_eq(prosess[0], "0")
        assert(builtin.index_of(prosess[1], "selfhost/vm.no: lasta OK") >= 0)
        assert(builtin.index_of(prosess[1], "[vm] entry returned") >= 0)
    }
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la ci = fil_les(".github/workflows/ci.yml")

    assert(ikkje t.inneholder(ci, "NC_TEST_SHARDS=4"))
    assert(ikkje t.inneholder(ci, "shard 1/4"))
    assert(t.inneholder(ci, "NC_TEST_SHARDS=8"))
    assert(t.inneholder(ci, "shard 1/8"))
    assert(t.inneholder(ci, "shard 8/8"))

    returner 0
}

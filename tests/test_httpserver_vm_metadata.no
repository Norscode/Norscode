funksjon ny_server_vm(port)
    returner {"request_middlewares": [], "response_middlewares": [], "error_middlewares": [], "startup_hooks": [], "shutdown_hooks": [], "type": "vm"}
slutt

funksjon route_vm(server, metode, sti, handler)
    returner server
slutt

funksjon register_request_middleware_vm(server, mw)
    server["request_middlewares"] = [mw]
    returner server
slutt

funksjon register_response_middleware_vm(server, mw)
    server["response_middlewares"] = [mw]
    returner server
slutt

funksjon register_error_middleware_vm(server, mw)
    server["error_middlewares"] = [mw]
    returner server
slutt

funksjon register_startup_hook_vm(server, hook)
    server["startup_hooks"] = [hook]
    returner server
slutt

funksjon register_shutdown_hook_vm(server, hook)
    server["shutdown_hooks"] = [hook]
    returner server
slutt

funksjon start() -> heiltall {
    la server = ny_server_vm(8081)
    route_vm(server, "GET", "/", "home")
    register_request_middleware_vm(server, "request_trace")
    register_response_middleware_vm(server, "response_trace")
    register_error_middleware_vm(server, "error_trace")
    register_startup_hook_vm(server, "ved_start")
    register_shutdown_hook_vm(server, "ved_stopp")

    assert_eq(lengde(server["request_middlewares"]), 1)
    assert_eq(lengde(server["response_middlewares"]), 1)
    assert_eq(lengde(server["error_middlewares"]), 1)
    assert_eq(lengde(server["startup_hooks"]), 1)
    assert_eq(lengde(server["shutdown_hooks"]), 1)
    assert_eq(server["type"], "vm")
    returner 0
}

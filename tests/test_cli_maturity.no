bruk std.tekst som t

funksjon start() -> heiltall {
    assert(fil_finnes("bin/nc"))

    la cli = fil_les("bin/nc")
    assert(t.inneholder(cli, "while IFS= read -r _line"))
    assert(t.inneholder(cli, "_value=${_line#*=}"))
    assert(t.inneholder(cli, "done < \"$_toml\""))
    assert(ikkje t.inneholder(cli, "grep '^version' \"$_toml\" | head -1 | sed"))
    assert(t.inneholder(cli, "run <fil.no>"))
    assert(t.inneholder(cli, "nc run: finn ikkje fil"))
    assert(t.inneholder(cli, "bruk: nc run <fil.no>"))
    assert(t.inneholder(cli, "Kompiler og køyr Norscode-fil."))
    assert(t.inneholder(cli, "nc compile: finn ikkje fil"))
    assert(t.inneholder(cli, "bruk: nc compile <kilde.no> [utdata.ncb.json]"))
    assert(t.inneholder(cli, "Kompiler Norscode-fil til bytekode."))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_CMD=compile NORSCODE_FILE=\"$SRC\" NORSCODE_ROOT=\"$ROOT_DIR\""))
    assert(t.inneholder(cli, "nc build: finn ikkje fil"))
    assert(t.inneholder(cli, "bruk: nc build <kilde.no> <utdata.ncb.json>"))
    assert(t.inneholder(cli, "Kompiler Norscode-fil til NCB-bytecode."))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_CMD=compile NORSCODE_FILE=\"$SRC\" NORSCODE_OUTPUT=\"$OUT\" NORSCODE_ROOT=\"$ROOT_DIR\""))
    assert(t.inneholder(cli, "nc bygg: finn ikkje fil"))

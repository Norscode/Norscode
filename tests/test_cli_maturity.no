    assert(ikkje t.inneholder(cli, "env NORSCODE_CMD=run NORSCODE_FILE=\"$ROOT_DIR/selfhost/native_execution/ncb_to_elf.no\""))
    assert(t.inneholder(cli, "nc check: finn ikkje fil"))
    assert(t.inneholder(cli, "bruk: nc check <kilde.no>"))
    assert(t.inneholder(cli, "Sjekk syntaks/semantikk utan å skrive artefakt."))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_CMD=compile NORSCODE_FILE=\"$SRC\" NORSCODE_OUTPUT=\"$_tmpdir/_check.ncb.json\" NORSCODE_ROOT=\"$ROOT_DIR\""))
    assert(t.inneholder(cli, "bruk: nc bundle [--output utdata.ncb.json] [fil.no ...]"))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE=\"$ROOT_DIR/selfhost/bundler.no\" NORSCODE_ROOT=\"$ROOT_DIR\""))

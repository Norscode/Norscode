    assert(t.inneholder(cli, "Bygg Norscode med mål/native val."))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE=\"$ROOT_DIR/selfhost/native_execution/native_codegen.no\" NORSCODE_ROOT=\"$ROOT_DIR\""))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE=\"$ROOT_DIR/selfhost/native_execution/kernel_builder.no\" NORSCODE_ROOT=\"$ROOT_DIR\""))

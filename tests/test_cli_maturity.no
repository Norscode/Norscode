    assert(t.inneholder(cli, "Køyr Norscode-basert vedlikehald lokalt."))
    assert(t.inneholder(cli, "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE=\"$ROOT_DIR/selfhost/maintenance.no\" NORSCODE_ROOT=\"$ROOT_DIR\" NORSCODE_TASK=\"$_task\""))
    assert(t.inneholder(cli, "bruk: nc active-surface"))
    assert(t.inneholder(cli, "Sjekk aktiv C/Python-fri flate, overgangsreferansar og scaffold-kommandoflate."))
    assert(t.inneholder(cli, "active-surface                   Sjekk aktiv C/Python-fri flate og overgangsreferansar"))
    assert(t.inneholder(cli, "tools/no_c_python_active_surface.no"))
    assert(ikkje t.inneholder(cli, "exec sh \"$ROOT_DIR/tools/no_c_python_active_surface.sh\""))
    la active_surface_wrapper = fil_les("tools/no_c_python_active_surface.sh")
    assert(t.inneholder(active_surface_wrapper, "Norscode-first wrapper: policy- og søkelogikken ligg i tools/no_c_python_active_surface.no."))
    assert(t.inneholder(active_surface_wrapper, "Shell-delen under set berre rot/runtime-miljø og startar Norscode-eigarfil."))
    assert(t.inneholder(active_surface_wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/no_c_python_active_surface.no\""))

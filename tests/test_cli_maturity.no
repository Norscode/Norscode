    assert(t.inneholder(cli, "bruk: nc feature-check [fil.no ...]"))
    assert(t.inneholder(cli, "tools/norscode_feature_gate.no"))
    assert(t.inneholder(cli, "_nc_has_exec_prosess_gap \"$_feature_out\""))
    assert(ikkje t.inneholder(cli, "exec sh \"$ROOT_DIR/tools/norscode_feature_gate.sh\""))
    assert(t.inneholder(cli, "Sjekk nye Norscode-funksjonar utan C/Python."))
    assert(t.inneholder(cli, "maintenance [status|lane|docs|cleanup|seed|tests|maturity|summary|report|report-json|verify]"))

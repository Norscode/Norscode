funksjon start() -> heiltall {
    la pure_vm: boolsk = usann
    prøv {
        builtin.vm_memory_status()
        pure_vm = sann
    } fang (e) {
        // Direkte host-løype: capability-dispatchen blir testa i run-pure.
    }
    hvis ikkje pure_vm {
        skriv("test_vm_security_enforcement OK")
        returner 0
    }

    la disk_nekt: tekst = ""
    prøv {
        fil_les("README.md")
        returner 1
    } fang (e) {
        disk_nekt = e
    }
    hvis lengde(disk_nekt) == 0 { returner 2 }

    la process_nekt: tekst = ""
    prøv {
        builtin.exec_prosess("true")
        returner 3
    } fang (e) {
        process_nekt = e
    }
    hvis lengde(process_nekt) == 0 { returner 4 }

    la argv_nekt: tekst = ""
    prøv {
        builtin.process_spawn_argv({
            "abi": "norscode-process-spawn-v1",
            "executable": "/usr/bin/true",
            "args": [],
            "cwd": "",
            "stdin": "",
            "timeout_ms": "1000",
            "max_output_bytes": "1024",
            "capture_stdout": "sann",
            "capture_stderr": "sann"
        })
        returner 7
    } fang (e) {
        argv_nekt = e
    }
    hvis lengde(argv_nekt) == 0 { returner 8 }

    la async_nekt: tekst = ""
    prøv {
        builtin.process_operation({"abi": "norscode-native-process-v1", "operation": "poll", "handle": "process:1"})
        returner 13
    } fang (e) {
        async_nekt = e
    }
    hvis lengde(async_nekt) == 0 { returner 14 }

    la fs_read_nekt: tekst = ""
    prøv {
        builtin.filesystem_read_operation({"abi": "norscode-native-filesystem-v1", "operation": "open", "root": "build", "relative": "x", "mode": "read"})
        returner 15
    } fang (e) { fs_read_nekt = e }
    hvis lengde(fs_read_nekt) == 0 { returner 16 }

    la fs_write_nekt: tekst = ""
    prøv {
        builtin.filesystem_write_operation({"abi": "norscode-native-filesystem-v1", "operation": "delete", "root": "build", "relative": "x"})
        returner 17
    } fang (e) { fs_write_nekt = e }
    hvis lengde(fs_write_nekt) == 0 { returner 18 }

    la network_nekt: tekst = ""
    prøv {
        builtin.network_operation({"abi": "norscode-native-network-v1", "operation": "listen", "host": "127.0.0.1", "port": "0", "backlog": "1"})
        returner 19
    } fang (e) { network_nekt = e }
    hvis lengde(network_nekt) == 0 { returner 20 }

    la thread_nekt: tekst = ""
    prøv {
        builtin.thread_spawn({"abi": "norscode-native-thread-v1", "operation": "spawn", "fn": "app.worker", "args": {}, "name": "worker", "stack_bytes": "65536"})
        returner 9
    } fang (e) {
        thread_nekt = e
    }
    hvis lengde(thread_nekt) == 0 { returner 10 }

    la atomic_nekt: tekst = ""
    prøv {
        builtin.atomic_operation({"abi": "norscode-atomic-v1", "operation": "load", "handle": "x", "order": "seq_cst"})
        returner 11
    } fang (e) {
        atomic_nekt = e
    }
    hvis lengde(atomic_nekt) == 0 { returner 12 }

    la metrics = builtin.vm_runtime_metrics()
    hvis metrics["security_denied"] == metrics["security_allowed"] { returner 5 }
    hvis lengde(metrics["last_security_denial"]) == 0 { returner 6 }

    skriv("test_vm_security_enforcement OK")
    returner 0
}

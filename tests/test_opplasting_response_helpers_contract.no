bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la upload = fil_les("std/opplasting.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(upload, "funksjon respons_lagret(sti: tekst) -> ordbok_tekst")
    krev(upload, "\"{\\\"ok\\\":true,\\\"sti\\\":\\\"\" + _json_escape(sti) + \"\\\"}\"")
    krev(upload, "returner web.response_builder(201, {\"content-type\": \"application/json; charset=utf-8\"}, body)")
    krev(upload, "funksjon respons_feil(status: heltall, melding: tekst) -> ordbok_tekst")
    krev(upload, "\"{\\\"ok\\\":false,\\\"feil\\\":\\\"\" + _json_escape(melding) + \"\\\"}\"")
    krev(upload, "funksjon respons_fra_resultat(resultat: ordbok_tekst, status_feil: heltall) -> ordbok_tekst")
    krev(upload, "returner respons_feil(status_feil, feilmelding(resultat))")
    krev(upload, "response_helpers: \"stabil\"")
    krev(upload, "funksjon _json_escape(s: tekst) -> tekst")

    krev(manual, "`std.opplasting.produksjonsstatus()`")
    krev(manual, "standard JSON-responsar")

    skriv("test_opplasting_response_helpers_contract OK")
    returner 0
}

bruk std.fil som fil
bruk std.bytes som bytes

funksjon start() -> heiltall {
    la sti = "build/test_media_binary_read.bin"
    la original: liste_heltall = [0, 1, 127, 128, 255]
    assert_eq(fil.skriv_bytes(sti, original), 5)
    la buffer = fil.les_bytes(sti)
    assert(bytes.er_bytes(buffer))
    assert_eq(bytes.storleik(buffer), 5)
    la lese = fil.les_byte_liste(sti)
    assert_eq(lengde(lese), 5)
    assert_eq(lese[0], 0)
    assert_eq(lese[3], 128)
    assert_eq(lese[4], 255)
    skriv("test_media_binary_read OK\n")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/filops.no")
    assert(t.inneholder(src, "Brukar Norscode-filkontroll og intern tekstparsing"))
    assert(t.inneholder(src, "trygt quota OS-kall berre som reserveveg der direkte runtime-binding"))
    assert(ikkje t.inneholder(src, "filoperasjonar som enno manglar direkte"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "returner builtin.fil_finnes(sti)"))
    assert(t.inneholder(src, "returner builtin.fil_finnes(\"/\")"))
    assert(t.inneholder(src, "find -H \" + _shell(sti) + \" -maxdepth 0 -type d -print"))
    assert(t.inneholder(src, "stat -c '%s' \" + _shell(sti)"))
    assert(t.inneholder(src, "stat -f '%z' \" + _shell(sti)"))
    assert(t.inneholder(src, "la innhald = builtin.fil_les(sti)"))
    assert(t.inneholder(src, "returner builtin.lengde(innhald)"))
    assert(t.inneholder(src, "wc -c < \" + _shell(sti) + \" 2>/dev/null"))
    assert(t.inneholder(src, "cp \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "cp -p \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "cp -r \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "mv \" + _shell(kjelde) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "rm \" + _shell(kjelde)"))
    assert(t.inneholder(src, "rm \" + _shell(sti)"))
    assert(t.inneholder(src, "rm -rf \" + _shell(katalog)"))
    assert(t.inneholder(src, "mkdir \" + _shell(sti)"))
    assert(t.inneholder(src, "mkdir -p \" + _shell(sti)"))
    assert(t.inneholder(src, "find \" + _shell(sti) + \" -mindepth 1 -maxdepth 1 ! -name '.*' -print"))
    assert(t.inneholder(src, "legg_til(filer, _basename(linje))"))
    assert(t.inneholder(src, "funksjon _dirname(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "find \" + _shell(katalog) + \" -mindepth 1 -maxdepth 1 -print"))
    assert(t.inneholder(src, "_glob_samsvar_segment(namn_mønster, _basename(s))"))
    assert(t.inneholder(src, "df -k \" + _shell(sti)"))
    assert(t.inneholder(src, "la mal: tekst = \"/tmp/\" + prefiks + \"XXXXXX\""))
    assert(t.inneholder(src, "mktemp \" + _shell(mal)"))
    assert(t.inneholder(src, "find \" + _shell(rotkatalog) + \" -name \" + _shell(mønster)"))
    assert(t.inneholder(src, "find \" + _shell(rotkatalog) + \" -type f"))
    assert(t.inneholder(src, "find \" + _shell(rotkatalog) + \" -type d"))
    assert(t.inneholder(src, "realpath --no-symlinks \" + _shell(sti)"))
    assert(t.inneholder(src, "realpath \" + _shell(relativ)"))
    assert(t.inneholder(src, "realpath --relative-to=\" + _shell(base) + \" \" + _shell(mål)"))
    assert(t.inneholder(src, "la heim = builtin.miljo_hent(\"HOME\")"))
    assert(ikkje t.inneholder(src, "test -d \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "test -d \" + sti"))
    assert(ikkje t.inneholder(src, "returner fil_finnes(sti)  # native funksjon"))
    assert(ikkje t.inneholder(src, "stat -c '%s' \" + sti"))
    assert(ikkje t.inneholder(src, "stat -f '%z' \" + sti"))
    assert(ikkje t.inneholder(src, "wc -c < \" + sti"))
    assert(ikkje t.inneholder(src, "cp \" + kjelde"))
    assert(ikkje t.inneholder(src, "cp -p \" + kjelde"))
    assert(ikkje t.inneholder(src, "cp -r \" + kjelde"))
    assert(ikkje t.inneholder(src, "mv \" + kjelde"))
    assert(ikkje t.inneholder(src, "rm \" + kjelde"))
    assert(ikkje t.inneholder(src, "rm \" + sti"))
    assert(ikkje t.inneholder(src, "rm -rf \" + katalog"))
    assert(ikkje t.inneholder(src, "mkdir \" + sti"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + sti"))
    assert(ikkje t.inneholder(src, "ls -1 \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "ls -1 \" + sti"))
    assert(ikkje t.inneholder(src, "ls -d1 \" + mønster"))
    assert(ikkje t.inneholder(src, "df -k \" + sti"))
    assert(ikkje t.inneholder(src, "mktemp /tmp/\" + prefiks"))
    assert(ikkje t.inneholder(src, "find \" + rotkatalog"))
    assert(ikkje t.inneholder(src, "realpath --no-symlinks \\\"\" + sti"))
    assert(ikkje t.inneholder(src, "realpath \\\"\" + relativ"))
    assert(ikkje t.inneholder(src, "realpath --relative-to=\\\"\" + base"))
    assert(ikkje t.inneholder(src, "echo $HOME"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess(\"echo ok\")"))
    assert(ikkje t.inneholder(src, "Kombinerer builtin.fil_* med builtin.exec_prosess for operasjonar"))

    skriv("test_filops_shell_quote OK")
    returner 0
}

bruk std.sched som sched

funksjon svar(args: ordbok_tekst) -> tekst { returner "ok:" + args["verdi"] }
funksjon krasj(args: ordbok_tekst) -> tekst { kast "planlagt feil" }

funksjon start() -> heltall {
    la s = sched.ny()
    la args: ordbok_tekst = {}
    args["verdi"] = "42"

    la ferdig = sched.opprett_oppgave(s, 0, 1, "__main__.svar", args)
    assert_eq(sched.future_status(s, ferdig), "ventende")
    assert_eq(sched.run_ferdig(s), 1)
    assert_eq(sched.future_status(s, ferdig), "ferdig")
    assert_eq(sched.future_resultat(s, ferdig), "ok:42")

    la feil = sched.opprett_oppgave(s, 0, 1, "__main__.krasj", args)
    assert_eq(sched.run_ferdig(s), 1)
    assert_eq(sched.future_status(s, feil), "feil")
    assert_inneholder(sched.future_feil(s, feil), "planlagt feil")

    la sein = sched.opprett_oppgave(s, 60000, 1, "__main__.svar", args)
    assert(sched.future_kanseller(s, sein))
    assert_eq(sched.future_status(s, sein), "kansellert")
    assert(sched.future_er_ferdig(s, sein))
    assert_eq(sched.tal_ventande(s), 0)
    returner 0
}

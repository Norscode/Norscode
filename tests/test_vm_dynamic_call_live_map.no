funksjon svar(args: ordbok_tekst) -> tekst { returner "ok:" + args["verdi"] }

funksjon start() -> heltall {
    la state: ordbok_tekst = {}
    la i: heltall = 0
    mens i < 80 {
        state["felt:" + tekst_fra_heltall(i)] = tekst_fra_heltall(i)
        i = i + 1
    }
    la args: ordbok_tekst = {}
    args["verdi"] = "42"
    la resultat = builtin.ncb_call_fn("__main__.svar", args)
    assert_eq(resultat, "ok:42")
    assert_eq(state["felt:79"], "79")
    returner 0
}

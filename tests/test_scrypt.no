bruk std.scrypt som scrypt

funksjon start() -> heiltall {
    la expected = "77d6576238657b203b19ca42c18a0497f16b4844e3074ae8dfdffa3fede21442fcd0069ded0948f8326a753a0fc81f17e8d3e0fb2e0d3628cf35e20c38d18906"
    la actual = scrypt.hash("", "", 16, 1, 1, 64)
    assert_eq(actual, expected)
    assert(scrypt.verifiser("", "", 16, 1, 1, expected))
    assert(ikkje scrypt.verifiser("feil", "", 16, 1, 1, expected))
    assert_eq(scrypt.status()["abi"], "norscode-scrypt-v1")
    skriv("test_scrypt OK\n")
    returner 0
}

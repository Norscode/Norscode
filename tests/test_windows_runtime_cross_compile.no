funksjon start() -> heiltall {
    la res = builtin.exec_prosess("NORSCODE_ROOT='.' ./bin/nc run tools/windows_runtime_cross_compile_gate.no")
    assert_eq(res[0], "0")
    assert_inneholder(res[1], "Windows x86_64 native ABI compile/link")
    skriv("test_windows_runtime_cross_compile OK")
    returner 0
}

bruk std.html_state som state
bruk std.tekst som t

funksjon start() -> heltall {
    assert_eq(
        state.state("side", "2"),
        "<input type=\"hidden\" data-state=\"side\" value=\"2\">"
    )
    assert_eq(
        state.store("filter", "<p>Aktiv</p>"),
        "<div class=\"state-store\" data-store=\"filter\"><p>Aktiv</p></div>"
    )
    assert_eq(
        state.bind("status", "Klar"),
        "<span data-bind=\"status\">Klar</span>"
    )
    assert_eq(state.state_attr("view", "ready"), " data-state-view=\"ready\"")
    assert_eq(state.bind_attr("status"), " data-bind=\"status\"")

    la panel = state.state_panel("Saker", "status", "open", "<p>3</p>")
    assert(t.inneholder(panel, "<section class=\"state-panel\" data-state-status=\"open\">"))
    assert(t.inneholder(panel, "<h2>Saker</h2>"))
    assert(t.inneholder(panel, "<div class=\"state-panel__body\"><p>3</p></div>"))

    la status = state.statusfelt("ticket-status", "status", "Oppdatert")
    assert(t.inneholder(status, "id=\"ticket-status\""))
    assert(t.inneholder(status, "class=\"state-status\""))
    assert(t.inneholder(status, "data-bind=\"status\""))
    assert(t.inneholder(status, "aria-live=\"polite\""))

    assert(t.inneholder(state.tom_tilstand("Tomt", "Ingen saker"), "data-state-view=\"empty\""))
    assert(t.inneholder(state.laster_tilstand("Laster"), "data-state-view=\"loading\""))
    assert(t.inneholder(state.feil_tilstand("Feil", "Prøv igjen"), "data-state-view=\"error\""))

    skriv("test_html_state OK")
    returner 0
}

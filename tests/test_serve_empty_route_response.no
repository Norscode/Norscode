funksjon serve_handle_one(ncb, rå)
    returner "HTTP/1.1 204 No Content\r\n\r\n"
slutt

funksjon start() -> heiltall {
    la ncb = {
        "route_handlers": [
            {"spec": "GET /tom", "function": "__main__.tom", "guards": []}
        ],
        "functions": {
            "__main__.tom": {"args": ["ctx"], "code": ""}
        }
    }
    la resp = serve_handle_one(ncb, "GET /tom HTTP/1.1\r\n\r\n")
    assert_eq(builtin.starts_with(resp, "HTTP/1.1 204 No Content"), sann)
    returner 0
}

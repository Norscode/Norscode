bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/ftplib.no")
    assert(t.inneholder(src, "Norscode socket først for kontrollkanalen"))
    assert(t.inneholder(src, "curl som"))
    assert(t.inneholder(src, "datakanal/filer"))
    assert(ikkje t.inneholder(src, "curl eller ftp-kommando"))
    assert(t.inneholder(src, "funksjon _shell(verdi: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(verdi, \"'\""))
    assert(t.inneholder(src, "bruk std.socket som sok"))
    assert(t.inneholder(src, "funksjon _ftp_kommando(f: ordbok_tekst, kommando: tekst) -> tekst"))
    assert(t.inneholder(src, "sok.tilkoble(s, f[\"vert\"], builtin.heltall_fra_tekst(f[\"port\"]))"))
    assert(t.inneholder(src, "sok.send(s, innhald)"))
    assert(t.inneholder(src, "hvis _ftp_socket_kan_kople(f)"))
    assert(t.inneholder(src, "la svar = _ftp_kommando(f, \"CWD \" + katalog)"))
    assert(t.inneholder(src, "la svar = _ftp_kommando(f, \"PWD\")"))
    assert(t.inneholder(src, "la svar = _ftp_kommando(f, \"MKD \" + katalog)"))
    assert(t.inneholder(src, "la svar = _ftp_kommando(f, \"DELE \" + fjern_fil)"))
    assert(t.inneholder(src, "la svar = _ftp_kommando(f, \"SIZE \" + fjern_fil)"))
    assert(t.inneholder(src, "curl --connect-timeout 5 -s \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --list-only \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s -o \" + _shell(lokal_sti) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s -T \" + _shell(lokal_sti) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s -X MKD \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s -X DELE \" + _shell(url)"))
    assert(t.inneholder(src, "curl -sI \" + _shell(url)"))
    assert(t.inneholder(src, "funksjon _content_length(headers: tekst) -> heltall"))
    assert(t.inneholder(src, "funksjon _lower_ascii(s: tekst) -> tekst"))
    assert(t.inneholder(src, "returner _content_length(res)"))
    assert(ikkje t.inneholder(src, "curl --connect-timeout 5 -s \" + url"))
    assert(ikkje t.inneholder(src, "curl -s --list-only \" + url"))
    assert(ikkje t.inneholder(src, "curl -s \" + url"))
    assert(ikkje t.inneholder(src, "curl -s -o \" + lokal_sti"))
    assert(ikkje t.inneholder(src, "curl -s -T \" + lokal_sti"))
    assert(ikkje t.inneholder(src, "curl -s -X MKD \" + url"))
    assert(ikkje t.inneholder(src, "curl -s -X DELE \" + url"))
    assert(ikkje t.inneholder(src, "curl -sI \" + url"))
    assert(ikkje t.inneholder(src, "| head -1"))
    assert(ikkje t.inneholder(src, "| grep -i Content-Length | awk"))

    skriv("test_ftplib_shell_quote OK")
    returner 0
}

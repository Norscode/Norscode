bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/platform.no")

    assert(t.inneholder(src, "normaliserer miljø, minne og"))
    assert(t.inneholder(src, "Norscode utan grep/head/tail-pipelines"))
    assert(t.inneholder(src, "funksjon _minne_linje(tekstblokk: tekst) -> tekst"))
    assert(t.inneholder(src, "la res = builtin.exec_prosess(\"free -m 2>/dev/null\")"))
    assert(t.inneholder(src, "la minne_linje: tekst = _minne_linje(res)"))
    assert(t.inneholder(src, "tekst_starter_med(linje, \"Mem:\")"))
    assert(t.inneholder(src, "la heim = builtin.miljo_hent(\"HOME\")"))

    assert(ikkje t.inneholder(src, "| head -2"))
    assert(ikkje t.inneholder(src, "| tail -1"))
    assert(ikkje t.inneholder(src, "echo $HOME"))
    assert(ikkje t.inneholder(src, "Brukar builtin.exec_prosess og builtin.miljo_hent for å"))

    skriv("test_platform_no_head_tail OK")
    returner 0
}

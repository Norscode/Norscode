bruk selfhost.common som sh

funksjon start() -> heltall {
    la a: tekst = sh.disasm_uttrykk("4 er storre eller lik 4")
    assert_eq(a, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")
    la b: tekst = sh.disasm_uttrykk("4 er_storre_eller_lik 4")
    assert_eq(b, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")
    returner 0
}

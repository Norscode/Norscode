funksjon start() -> heiltall {
    la listener = builtin.network_operation({
        "abi": "norscode-native-network-v1",
        "operation": "listen",
        "host": "127.0.0.1",
        "port": 0,
        "backlog": 8
    })
    skriv("windows network: listen status=" + listener["status"])
    skriv("windows network: listen error=" + listener["error"])
    assert_eq(listener["status"], "listening")
    assert_eq(listener["event_backend"], "wsapoll")
    assert(listener["port"] > 0)

    la client = builtin.network_operation({
        "abi": "norscode-native-network-v1",
        "operation": "connect",
        "host": "127.0.0.1",
        "port": listener["port"]
    })
    assert(client["status"] == "connecting" eller client["status"] == "connected")

    la accepted = {"status": "ventende"}
    la i: heiltall = 0
    mens accepted["status"] == "ventende" og i < 1000 {
        client["operation"] = "poll"
        client["events"] = 2
        builtin.network_operation(client)
        listener["operation"] = "accept"
        accepted = builtin.network_operation(listener)
        i = i + 1
    }
    assert_eq(accepted["status"], "connected")

    client["operation"] = "write"
    client["data"] = "windows-network-ok"
    assert_eq(builtin.network_operation(client)["value"], 18)

    la received = {"status": "ventende", "data": ""}
    i = 0
    mens received["status"] == "ventende" og i < 1000 {
        accepted["operation"] = "read"
        accepted["max"] = 64
        received = builtin.network_operation(accepted)
        i = i + 1
    }
    assert_eq(received["status"], "ok")
    assert_eq(received["data"], "windows-network-ok")

    client["operation"] = "close"
    accepted["operation"] = "close"
    listener["operation"] = "close"
    assert_eq(builtin.network_operation(client)["status"], "closed")
    assert_eq(builtin.network_operation(accepted)["status"], "closed")
    assert_eq(builtin.network_operation(listener)["status"], "closed")
    assert_eq(builtin.network_operation(client)["status"], "feil")
    skriv("test_windows_native_network OK")
    returner 0
}

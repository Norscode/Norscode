funksjon callstack_probe() -> ordbok_tekst {
    returner builtin.vm_call_stack_status()
}

funksjon mellomledd() -> ordbok_tekst {
    returner callstack_probe()
}

funksjon kast_djupt() -> heiltall {
    kast("djup feil")
}

funksjon rekursiv(n: heiltall) -> heiltall {
    returner rekursiv(n + 1)
}

funksjon start() -> heiltall {
    prøv {
        la stack = mellomledd()
        hvis stack["current"] != "__main__.callstack_probe" { returner 1 }
        hvis lengde(stack["trace"]) == 0 { returner 2 }
    } fang (e) {
        // Den direkte host-løypa har ikkje pure-VM-diagnoseflata.
    }

    la fanget: tekst = ""
    prøv {
        kast_djupt()
        returner 3
    } fang (e) {
        fanget = e
    }
    hvis fanget != "djup feil" { returner 4 }

    prøv {
        prøv {
            kast_djupt()
        } fang (indre) {
            kast(indre)
        }
        returner 5
    } fang (ytre) {
        hvis ytre != "djup feil" { returner 6 }
    }

    la overflow_fanget: tekst = ""
    prøv {
        rekursiv(0)
        returner 7
    } fang (overflow) {
        overflow_fanget = overflow
    }
    hvis lengde(overflow_fanget) == 0 { returner 8 }

    prøv {
        la etter = builtin.vm_call_stack_status()
        hvis etter["current"] != "__main__.start" { returner 9 }
        la metrics = builtin.vm_runtime_metrics()
        hvis metrics["instructions"] == metrics["gc_collections"] { returner 10 }
        hvis metrics["max_depth"] == metrics["stack_depth"] { returner 11 }
        hvis metrics["unwinds"] == metrics["gc_collections"] { returner 12 }
    } fang (e) {
        // Den direkte host-løypa har ikkje pure-VM-diagnoseflata.
    }

    skriv("test_vm_callstack_exception_integration OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/startproject.sh")

    assert(t.inneholder(src, "scaffold_test_conn"))
    assert(ikkje t.inneholder(src, "registrer_modellar(register, \"dummy\")"))
    assert(t.inneholder(src, "INSERT INTO konto (namn) VALUES ('rulles_tilbake');"))
    assert(ikkje t.inneholder(src, "INSERT INTO konto (namn) VALUES ('midlertidig');"))

    skriv("test_startproject_template_text OK")
    returner 0
}

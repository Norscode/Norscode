bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_delerpa_kompakt: tekst = sh.disasm_uttrykk("8 delerpa 2")
    assert_eq(expr_norsk_delerpa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_delerpaa_kompakt: tekst = sh.disasm_uttrykk("8 delerpaa 2")
    assert_eq(expr_norsk_delerpaa_kompakt, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_deler_med_underscore: tekst = sh.disasm_uttrykk("8 deler_med 2")
    assert_eq(expr_norsk_deler_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dele_kort: tekst = sh.disasm_uttrykk("8 dele 2")
    assert_eq(expr_norsk_dele_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_deler_kort: tekst = sh.disasm_uttrykk("8 deler 2")
    assert_eq(expr_norsk_deler_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_divider_kort: tekst = sh.disasm_uttrykk("8 divider 2")
    assert_eq(expr_norsk_divider_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_dividere_kort: tekst = sh.disasm_uttrykk("8 dividere 2")
    assert_eq(expr_norsk_dividere_kort, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_bool_literals: tekst = sh.disasm_uttrykk("sann&&usann||!usann")
    assert_eq(expr_bool_literals, "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PUSH 0\n4: NOT\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_bool_literals_sant: tekst = sh.disasm_uttrykk("sant&&usann")
    assert_eq(expr_bool_literals_sant, "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PRINT\n4: HALT\n")

    la expr_bool_literals_usant: tekst = sh.disasm_uttrykk("sant&&usant")
    assert_eq(expr_bool_literals_usant, "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PRINT\n4: HALT\n")

    la expr_bool_literals_ja_nei: tekst = sh.disasm_uttrykk("ja&&nei")
    assert_eq(expr_bool_literals_ja_nei, "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PRINT\n4: HALT\n")

    la expr_bool_literals_true_false: tekst = sh.disasm_uttrykk("true&&false")
    assert_eq(expr_bool_literals_true_false, "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PRINT\n4: HALT\n")

    la expr_norsk_ops: tekst = sh.disasm_uttrykk("sann og ikke usann eller usann")
    assert_eq(expr_norsk_ops, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PUSH 0\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_norsk_ops_enten: tekst = sh.disasm_uttrykk("usann enten sann")
    assert_eq(expr_norsk_ops_enten, "0: PUSH 0\n1: PUSH 1\n2: OR\n3: PRINT\n4: HALT\n")

    la expr_norsk_ops_ikkje: tekst = sh.disasm_uttrykk("sann og ikkje usann")
    assert_eq(expr_norsk_ops_ikkje, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_norsk_ops_samt: tekst = sh.disasm_uttrykk("sann samt ikke usann")
    assert_eq(expr_norsk_ops_samt, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp: tekst = sh.disasm_uttrykk("7 er 7 og 3 mindre_enn 4")
    assert_eq(expr_norsk_cmp, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PUSH 3\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_norsk_cmp2: tekst = sh.disasm_uttrykk("7 ikke_er 8 og 4 storre_eller_lik 4")
    assert_eq(expr_norsk_cmp2, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase: tekst = sh.disasm_uttrykk("7 er 7 og 3 mindre enn 4")
    assert_eq(expr_norsk_cmp_phrase, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PUSH 3\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_norsk_cmp_phrase2: tekst = sh.disasm_uttrykk("7 ikke er 8 og 4 storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase2, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase3: tekst = sh.disasm_uttrykk("7 er ikke 8 og 4 storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase3, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase4: tekst = sh.disasm_uttrykk("7 er lik 7 og 3 mindre enn 4")
    assert_eq(expr_norsk_cmp_phrase4, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PUSH 3\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_norsk_cmp_phrase5: tekst = sh.disasm_uttrykk("7 er ikke lik 8 og 4 storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase5, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase6: tekst = sh.disasm_uttrykk("3 er mindre enn 4")
    assert_eq(expr_norsk_cmp_phrase6, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase6_underscore: tekst = sh.disasm_uttrykk("3 er_mindre_enn 4")
    assert_eq(expr_norsk_cmp_phrase6_underscore, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase6_underscore_lte: tekst = sh.disasm_uttrykk("3 er_mindre_eller_lik 4")
    assert_eq(expr_norsk_cmp_phrase6_underscore_lte, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase6_kompakt_lte: tekst = sh.disasm_uttrykk("3 ermindreellerlik 4")
    assert_eq(expr_norsk_cmp_phrase6_kompakt_lte, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase6_underscore_lte_enn: tekst = sh.disasm_uttrykk("3 er_mindre_enn_eller_lik 4")
    assert_eq(expr_norsk_cmp_phrase6_underscore_lte_enn, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7: tekst = sh.disasm_uttrykk("4 er storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase7, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_underscore: tekst = sh.disasm_uttrykk("4 er_storre_eller_lik 4")
    assert_eq(expr_norsk_cmp_phrase7_underscore, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_underscore_utf8: tekst = sh.disasm_uttrykk("4 er_større_eller_lik 4")
    assert_eq(expr_norsk_cmp_phrase7_underscore_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_erstorrelik_kompakt: tekst = sh.disasm_uttrykk("4 erstorrelik 4")
    assert_eq(expr_norsk_cmp_phrase7_erstorrelik_kompakt, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_erstorrelik_kompakt_utf8: tekst = sh.disasm_uttrykk("4 erstørrelik 4")
    assert_eq(expr_norsk_cmp_phrase7_erstorrelik_kompakt_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_kompakt_gte: tekst = sh.disasm_uttrykk("4 erstorreellerlik 4")
    assert_eq(expr_norsk_cmp_phrase7_kompakt_gte, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_kompakt_ellerlik_gte_utf8: tekst = sh.disasm_uttrykk("4 erstørreellerlik 4")
    assert_eq(expr_norsk_cmp_phrase7_kompakt_ellerlik_gte_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_underscore_gt: tekst = sh.disasm_uttrykk("4 er_storre_enn 3")
    assert_eq(expr_norsk_cmp_phrase7_underscore_gt, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase7_underscore_gt_utf8: tekst = sh.disasm_uttrykk("4 er_større_enn 3")
    assert_eq(expr_norsk_cmp_phrase7_underscore_gt_utf8, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase7_kompakt_gt_ascii: tekst = sh.disasm_uttrykk("4 erstorreenn 3")
    assert_eq(expr_norsk_cmp_phrase7_kompakt_gt_ascii, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase7_kompakt_gt_utf8: tekst = sh.disasm_uttrykk("4 erstørreenn 3")
    assert_eq(expr_norsk_cmp_phrase7_kompakt_gt_utf8, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase7_underscore_gte: tekst = sh.disasm_uttrykk("4 er_storre_enn_eller_lik 4")
    assert_eq(expr_norsk_cmp_phrase7_underscore_gte, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_underscore_gte_utf8: tekst = sh.disasm_uttrykk("4 er_større_enn_eller_lik 4")
    assert_eq(expr_norsk_cmp_phrase7_underscore_gte_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_kompakt_gte_ascii: tekst = sh.disasm_uttrykk("4 erstorreennellerlik 4")
    assert_eq(expr_norsk_cmp_phrase7_kompakt_gte_ascii, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase7_kompakt_gte_utf8: tekst = sh.disasm_uttrykk("4 erstørreennellerlik 4")
    assert_eq(expr_norsk_cmp_phrase7_kompakt_gte_utf8, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase8: tekst = sh.disasm_uttrykk("7 ikke lik 8")
    assert_eq(expr_norsk_cmp_phrase8, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase9: tekst = sh.disasm_uttrykk("7 ulik 8")
    assert_eq(expr_norsk_cmp_phrase9, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase10: tekst = sh.disasm_uttrykk("7 er ulik 8")
    assert_eq(expr_norsk_cmp_phrase10, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase10_underscore: tekst = sh.disasm_uttrykk("7 er_ulik 8")
    assert_eq(expr_norsk_cmp_phrase10_underscore, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase11: tekst = sh.disasm_uttrykk("4 storre enn eller lik 4")
    assert_eq(expr_norsk_cmp_phrase11, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase12: tekst = sh.disasm_uttrykk("4 er storre enn eller lik 4")
    assert_eq(expr_norsk_cmp_phrase12, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase13: tekst = sh.disasm_uttrykk("7 er lik med 7")
    assert_eq(expr_norsk_cmp_phrase13, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase13_underscore: tekst = sh.disasm_uttrykk("7 er_lik_med 7")
    assert_eq(expr_norsk_cmp_phrase13_underscore, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase13_alias: tekst = sh.disasm_uttrykk("7 er_lik 7")
    assert_eq(expr_norsk_cmp_phrase13_alias, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase13_lik_med_alias: tekst = sh.disasm_uttrykk("7 lik_med 7")
    assert_eq(expr_norsk_cmp_phrase13_lik_med_alias, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase13_likmed_kompakt: tekst = sh.disasm_uttrykk("7 likmed 7")
    assert_eq(expr_norsk_cmp_phrase13_likmed_kompakt, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase14: tekst = sh.disasm_uttrykk("7 ikke lik med 8")
    assert_eq(expr_norsk_cmp_phrase14, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase14_underscore: tekst = sh.disasm_uttrykk("7 ikke_lik_med 8")
    assert_eq(expr_norsk_cmp_phrase14_underscore, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase14_ikkelikmed_kompakt: tekst = sh.disasm_uttrykk("7 ikkelikmed 8")
    assert_eq(expr_norsk_cmp_phrase14_ikkelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase14_alias: tekst = sh.disasm_uttrykk("7 ikke_lik 8")
    assert_eq(expr_norsk_cmp_phrase14_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase15: tekst = sh.disasm_uttrykk("7 er ikke lik med 8")
    assert_eq(expr_norsk_cmp_phrase15, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase16: tekst = sh.disasm_uttrykk("7 lik 7")
    assert_eq(expr_norsk_cmp_phrase16, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    returner 0
}

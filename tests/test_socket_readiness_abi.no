bruk std.runtime.socket_abi som abi

funksjon start() -> heiltall {
    assert_eq(abi.versjon(), "norscode-socket-readiness-v1")
    assert_eq(abi.event_all(), 15)
    assert(abi.har_event(abi.event_read() + abi.event_write(), abi.event_read()))
    assert(ikkje abi.har_event(abi.event_read(), abi.event_write()))

    la vent = abi.poll_resultat(4, abi.event_read(), 0, 0)
    assert_eq(vent["status"], "ventende")
    la klar = abi.poll_resultat(4, abi.event_read(), abi.event_read(), 0)
    assert_eq(klar["status"], "klar")
    la hangup = abi.poll_resultat(4, abi.event_read(), abi.event_hangup(), 0)
    assert_eq(hangup["status"], "klar")
    la feil = abi.poll_resultat(4, abi.event_read(), abi.event_error(), 5)
    assert_eq(feil["status"], "feil")
    assert_eq(abi.poll_resultat(-1, abi.event_read(), 0, 0)["status"], "feil")
    assert_eq(abi.poll_resultat(4, 0, 0, 0)["status"], "feil")
    returner 0
}

bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la rest = fil_les("std/rest.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(rest, "funksjon svar(status: heltall, data: tekst) -> ordbok_tekst")
    krev(rest, "returner web.response_builder(status, _json_headers(), data)")
    krev(rest, "funksjon oppretta_med_location(data: tekst, location: tekst) -> ordbok_tekst")
    krev(rest, "web.response_with_header(oppretta(data), \"location\", location)")
    krev(rest, "funksjon akseptert(data: tekst) -> ordbok_tekst")
    krev(rest, "web.response_builder(202, _json_headers(), data)")
    krev(rest, "funksjon ok_objekt(data: ordbok_tekst) -> ordbok_tekst")
    krev(rest, "returner ok(til_json(data))")
    krev(rest, "funksjon ok_liste(data: liste<ordbok_tekst>) -> ordbok_tekst")
    krev(rest, "returner ok(liste_til_json(data))")

    krev(manual, "`std.rest`: REST-hjelpere")
    krev(manual, "`svar`, `ok_objekt`, `ok_liste`, `akseptert` og `oppretta_med_location`")

    skriv("test_rest_response_helpers_contract OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/linux_random_hex_rebuild_check_v733.no")

    assert(t.inneholder(src, "funksjon vis_strings_treff(sti: tekst, needle: tekst, label: tekst, maks: heiltall) -> bool"))
    assert(t.inneholder(src, "builtin.split(res[1], \"\\n\")"))
    assert(t.inneholder(src, "vis_strings_treff(\"dist/norscode_native\", \"random_hex\", \"dist\", 20)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(src, "| grep -n 'random_hex'"))
    assert(ikkje t.inneholder(src, "| head -20"))

    skriv("test_linux_random_hex_rebuild_no_grep_head OK")
    returner 0
}

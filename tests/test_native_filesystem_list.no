// Verifiserer at den aktive native VM-en eksporterer filesystem.list.
bruk std.runtime_filesystem som fs

funksjon start() -> heiltall {
    la resultat = fs.native_list(".", "build")
    hvis resultat["status"] != "ok" {
        skriv("native filesystem.list manglar: " + resultat["error"] + "\n")
        returner 1
    }
    skriv("native filesystem.list OK\n")
    returner 0
}

start()

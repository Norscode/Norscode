bruk selfhost.vm som vm

funksjon start() -> heiltall {
    assert_eq(vm.vm_capability_for("builtin.skriv"), "")
    assert_eq(vm.vm_capability_for("skriv"), "")
    assert_eq(vm.vm_capability_for("builtin.fil_les"), "disk.read")
    assert_eq(vm.vm_capability_for("builtin.fil_skriv"), "disk.write")
    assert_eq(vm.vm_capability_for("builtin.exec_prosess"), "process.exec")
    returner 0
}

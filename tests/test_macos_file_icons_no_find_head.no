bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/install-macos-file-icons.no")

    assert(t.inneholder(src, "bruk std.path som path"))
    assert(t.inneholder(src, "la preview_name = path.basename(svg) + \".png\""))
    assert(t.inneholder(src, "preview_name=\" + shell(preview_name)"))
    assert(t.inneholder(src, "$tmp_dir/$preview_name"))
    assert(t.inneholder(src, "hvis ikkje fil_finst(icon_dir)"))
    assert(ikkje t.inneholder(src, "base=$(basename"))
    assert(ikkje t.inneholder(src, "find \"$tmp_dir\""))
    assert(ikkje t.inneholder(src, "| head -1"))
    assert(ikkje t.inneholder(src, "test -d "))

    skriv("test_macos_file_icons_no_find_head OK")
    returner 0
}

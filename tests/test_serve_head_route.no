funksjon serve_handle_one(ncb, rå)
    returner "HTTP/1.1 200 OK\r\n\r\n"
slutt

funksjon start() -> heiltall {
    la ncb = {
        "route_handlers": [
            {"spec": "GET /hei", "function": "__main__.hei", "guards": []}
        ],
        "functions": {
            "__main__.hei": {"args": ["ctx"], "code": ""}
        }
    }
    la resp = serve_handle_one(ncb, "HEAD /hei HTTP/1.1\r\n\r\n")
    assert_eq(builtin.starts_with(resp, "HTTP/1.1 200 OK"), sann)
    assert_eq(builtin.contains(resp, "Content-Length:"), usann)
    assert_eq(builtin.ends_with(resp, "\r\n"), sann)
    returner 0
}

bruk selfhost.common som sh

funksjon start() -> heltall {
    la env_navn_kort: liste_tekst = ["x"]
    la env_verdier_lang: liste_heltall = [1, 2]
    la _e: tekst = sh.disasm_uttrykk_med_miljo("x+1", env_navn_kort, env_verdier_lang)
    skriv(sh.disasm_skript("la x=2;sett x=x+3;returner x"))
    returner 0
}

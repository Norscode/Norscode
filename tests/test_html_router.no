bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la router = fil_les("std/html_router.no")
    la docs = fil_les("docs/frontend/FRONTEND_ROUTER.md")
    la model = fil_les("docs/frontend/FRONTEND_MODEL.md")

    krev(router, "funksjon route_link_active(")
    krev(router, "aria_attr(\"current\", \"page\")")
    krev(router, "funksjon route_link_for(")
    krev(router, "hvis (current_path == path)")
    krev(router, "funksjon route_base_path(")
    krev(router, "funksjon route_link_for_url(")
    krev(router, "funksjon route_query(")
    krev(router, "url.url_bygg_query(params)")
    krev(router, "funksjon route_with_query(")
    krev(router, "funksjon route_path_param(")
    krev(router, "funksjon route_path_params(")
    krev(router, "funksjon route_item(")
    krev(router, "funksjon route_item_for(")
    krev(router, "funksjon route_list(")
    krev(router, "funksjon route_breadcrumb(")
    krev(router, "funksjon route_crumb(")
    krev(router, "funksjon route_crumb_current(")
    krev(router, "html.canonical(path)")
    krev(router, "funksjon route_page_med_nav(")
    krev(router, "html.aria_attr(\"label\", \"Hovednavigasjon\")")

    krev(docs, "# Frontend Router")
    krev(docs, "`route_link_active(...)`")
    krev(docs, "`route_link_for(...)`")
    krev(docs, "`route_link_for_url(...)`")
    krev(docs, "`route_with_query(...)`")
    krev(docs, "`route_path_param(...)`")
    krev(docs, "`route_breadcrumb(...)`")
    krev(docs, "`route_page_med_nav(...)`")
    krev(docs, "`aria-current=\"page\"`")

    krev(model, "HTML router med aktive lenker, brødsmuler og canonical metadata")
    krev(model, "std.html_router")

    returner 0
}

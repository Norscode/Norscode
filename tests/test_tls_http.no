bruk std.tls_http som tls

funksjon start() -> heiltall {
    la cert = tls.load_cert_file("cert.pem")
    la key = tls.load_key_file("key.pem")
    la server = tls.ny_secure_server(8443, cert, key)

    assert_eq(server["protocol"], "https")
    assert_eq(server["tls_version"], "1.3")
    assert_eq(server["port"], "8443")
    assert_eq(server["require_peer_verification"], sann)
    assert_eq(server["transport_backend"], "mangler")
    assert_eq(tls.validate_cert(cert), usann)
    assert_eq(tls.lytt_secure(server), 1)
    assert_eq(server["status"], "feil")

    la hsts_server = tls.add_hsts_header(server, 31536000, sann)
    assert_eq(hsts_server["hsts"]["max_age"], "31536000")
    assert_eq(hsts_server["hsts"]["include_subdomains"], sann)
    assert_eq(hsts_server["hsts"]["preload"], sann)

    la redirect_server = tls.ny_redirect_server(8080, 8443)
    assert_eq(redirect_server["protocol"], "http")
    assert_eq(redirect_server["redirect_to"], "https://localhost:8443")

    la self_signed = tls.gen_self_signed_cert("localhost", 365)
    la info = tls.cert_info(self_signed)
    assert_eq(info["common_name"], "localhost")
    assert_eq(info["issuer"], "Self")
    assert_eq(tls.validate_cert(self_signed), usann)
    assert_eq(tls.validate_cert_for_host(self_signed, "localhost", sann), sann)
    assert_eq(tls.validate_cert_for_host(self_signed, "example.no", sann), usann)

    la manglar_tls = tls.handle_https_request(server, {})
    assert_eq(manglar_tls["accepted"], usann)

    server["hostname"] = "helpdesk.norscode.no"
    la feil_peer = tls.handle_https_request(server, {"tls_info": {"protocol": "TLSv1.3", "peer_verified": usann, "hostname": "helpdesk.norscode.no"}})
    assert_eq(feil_peer["accepted"], usann)
    la feil_host = tls.handle_https_request(server, {"tls_info": {"protocol": "TLSv1.3", "peer_verified": sann, "hostname": "feil.no"}})
    assert_eq(feil_host["accepted"], usann)
    la ok = tls.handle_https_request(server, {"tls_info": {"protocol": "TLSv1.3", "peer_verified": sann, "hostname": "helpdesk.norscode.no", "cipher": "TLS_AES_256_GCM_SHA384"}})
    assert_eq(ok["accepted"], sann)

    la status = tls.produksjonsstatus()
    assert_eq(status["status"], "delvis")

    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/syslog.no")
    assert(t.inneholder(src, "Byggjer syslog-meldingar i Norscode"))
    assert(t.inneholder(src, "PID via prosessmodulen"))
    assert(t.inneholder(src, "trygt quota logger-kall"))
    assert(ikkje t.inneholder(src, "Send meldingar til systemloggen via logger-kommandoen."))
    assert(t.inneholder(src, "bruk std.prosess som prosess"))
    assert(t.inneholder(src, "funksjon _pid_tag() -> tekst"))
    assert(t.inneholder(src, "la pid = prosess.pid()"))
    assert(ikkje t.inneholder(src, "echo $$"))
    assert(t.inneholder(src, "funksjon _shell(verdi: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(verdi, \"'\""))
    assert(t.inneholder(src, "tag_arg = \"-t \" + _shell(ident + pid_tekst)"))
    assert(t.inneholder(src, "tag_arg + \" \" + _shell(melding)"))
    assert(t.inneholder(src, "\"logger -p user.\" + prio_namn + \" \" + _shell(melding)"))
    assert(t.inneholder(src, "la tekst_linux = builtin.fil_les(\"/var/log/syslog\")"))
    assert(t.inneholder(src, "la tekst_macos = builtin.fil_les(\"/var/log/system.log\")"))
    assert(t.inneholder(src, "funksjon _filtrer_liner(tekstblokk: tekst, mønster: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.index_of(builtin.lower(linje), needle)"))
    assert(t.inneholder(src, "funksjon _siste_ikkje_tomme_liner(tekstblokk: tekst, n: heltall) -> liste_tekst"))
    assert(t.inneholder(src, "log show --last 1m --style syslog 2>/dev/null"))
    assert(t.inneholder(src, "returner _siste_ikkje_tomme_liner(_filtrer_liner(tekst_linux, mønster), n)"))
    assert(ikkje t.inneholder(src, "tag_arg = \"-t \\\"\" + ident"))
    assert(ikkje t.inneholder(src, "\"\\\"\" + _escape_shell(melding)"))
    assert(ikkje t.inneholder(src, "\"grep -i \" + _shell(mønster)"))
    assert(ikkje t.inneholder(src, "\"grep -i \\\"\" + _escape_shell(mønster)"))
    assert(ikkje t.inneholder(src, "| tail -n "))
    skriv("test_syslog_shell_quote OK")
    returner 0
}

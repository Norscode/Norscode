bruk std.web som web

funksjon start() -> heltall {
    assert_eq(web.escape_html("<tag & \"x\" 'y'>"), "&lt;tag &amp; &quot;x&quot; &#x27;y&#x27;&gt;")
    assert_eq(web.safe_filename("Rapport 2026?.txt"), "Rapport_2026_.txt")
    assert_eq(web.safe_path_segment("Bruker oppdatering"), "Bruker-oppdatering")
    assert_eq(web.safe_slug("Norsk backend 2026"), "norsk-backend-2026")
    assert(web.safe_relative_path("assets/logo.svg"))
    assert_eq(web.safe_join_path("static", "assets/logo.svg"), "static/assets/logo.svg")
    assert(ikkje web.safe_relative_path("../secret.txt"))
    assert(ikkje web.safe_relative_path("/etc/passwd"))
    assert(ikkje web.safe_relative_path("assets/%2e%2e/secret.txt"))
    assert(ikkje web.safe_relative_path("assets\\secret.txt"))
    returner 0
}

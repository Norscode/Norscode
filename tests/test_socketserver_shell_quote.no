bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/socketserver.no")

    // Socketserver er no native; den gamle shell-quoting-flata skal vere borte.
    assert(t.inneholder(src, "bruk std.socket som socket"))
    assert(t.inneholder(src, "socket.native_lytt"))
    assert(t.inneholder(src, "socket.native_udp_lytt"))
    assert(t.inneholder(src, "socket.native_tilkoble"))
    assert(t.inneholder(src, "socket.native_skriv"))
    assert(t.inneholder(src, "socket.native_les"))
    assert(t.inneholder(src, "socket.native_lukk"))
    assert(t.inneholder(src, "t[\"transport\"] = \"native\""))

    assert(ikkje t.inneholder(src, "sh -c "))
    assert(ikkje t.inneholder(src, "nc -l "))
    assert(ikkje t.inneholder(src, "socat "))
    assert(ikkje t.inneholder(src, "kill -0 "))
    assert(ikkje t.inneholder(src, "| grep LISTEN"))
    assert(ikkje t.inneholder(src, "| wc -l"))

    skriv("test_socketserver_shell_quote OK")
    returner 0
}

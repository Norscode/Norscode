bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/socketserver.no")
    assert(t.inneholder(src, "Start bakgrunnstenar ved OS-grensa"))
    assert(t.inneholder(src, "PID/logg blir lesne og filtrerte i Norscode"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, ">> \" + _shell(logg_fil)"))
    assert(t.inneholder(src, "> \" + _shell(pid_fil)"))
    assert(t.inneholder(src, "sh -c \" + _shell(cmd)"))
    assert(t.inneholder(src, "la pid_tekst = builtin.fil_les(pid_fil)"))
    assert(t.inneholder(src, "kill \" + _shell(pid)"))
    assert(t.inneholder(src, "kill -0 \" + _shell(pid)"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))
    assert(t.inneholder(src, "rm -f \" + _shell(pid_fil)"))
    assert(t.inneholder(src, "la linjer = builtin.split(builtin.fil_les(logg), \"\\n\")"))
    assert(t.inneholder(src, "la start: heltall = lengde(ikkje_tomme) - n"))
    assert(t.inneholder(src, "> \" + _shell(tenar[\"logg_fil\"])"))
    assert(t.inneholder(src, "bruk std.socket som sok"))
    assert(t.inneholder(src, "la s = sok.ny_tcp()"))
    assert(t.inneholder(src, "la s = sok.ny_udp()"))
    assert(t.inneholder(src, "sok.tilkoble(s, vert, port)"))
    assert(t.inneholder(src, "sok.send(s, data)"))
    assert(t.inneholder(src, "sok.motta(s, 4096)"))
    assert(t.inneholder(src, "funksjon _tel_ikkje_tomme_liner(tekstblokk: tekst) -> heltall"))
    assert(t.inneholder(src, "la n: heltall = _tel_ikkje_tomme_liner(res)"))
    assert(t.inneholder(src, "funksjon _inneheld(s: tekst, del: tekst) -> bool"))
    assert(t.inneholder(src, "_inneheld(s, \"LISTEN\")"))

    assert(ikkje t.inneholder(src, "cat \" + pid_fil"))
    assert(ikkje t.inneholder(src, "cat \" + _shell(pid_fil)"))
    assert(ikkje t.inneholder(src, "kill \" + pid"))
    assert(ikkje t.inneholder(src, "kill -0 \" + pid"))
    assert(ikkje t.inneholder(src, "rm -f \" + pid_fil"))
    assert(ikkje t.inneholder(src, "tail -n \" + tekst_fra_heltall(n) + \" \" + _shell(logg)"))
    assert(ikkje t.inneholder(src, "\" + logg + \" 2>/dev/null"))
    assert(ikkje t.inneholder(src, "sh -c '\" + cmd"))
    assert(ikkje t.inneholder(src, "echo \" + data"))
    assert(ikkje t.inneholder(src, "printf %s \" + _shell(data) + \" | nc -q1"))
    assert(ikkje t.inneholder(src, "printf %s \" + _shell(data) + \" | nc -u -q1"))
    assert(ikkje t.inneholder(src, "&& echo ok"))
    assert(ikkje t.inneholder(src, "| wc -l"))
    assert(ikkje t.inneholder(src, "| grep LISTEN"))
    assert(ikkje t.inneholder(src, "Start tenar i bakgrunnen (nc / socat)"))

    skriv("test_socketserver_shell_quote OK")
    returner 0
}

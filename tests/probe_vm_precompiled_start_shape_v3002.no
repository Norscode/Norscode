bruk selfhost.vm

funksjon start() -> heiltall {
    la vm_ncb = json_parse_raw(fil_les("bootstrap/precompiled/vm.ncb.json"))
    la vm_fns = vm_ncb["functions"]
    la fn_def = vm_fns["__main__.start"]
    la kode = fn_def["code"]
    skriv("shape: code_len=" + tekst(lengde(kode)) + "\n")
    skriv("shape: op0=" + tekst(kode[0][0]) + "\n")
    skriv("shape: op1=" + tekst(kode[1][0]) + "\n")
    skriv("shape: op2=" + tekst(kode[2][0]) + "\n")
    skriv("shape: op3=" + tekst(kode[3][0]) + "\n")
    skriv("shape: op4=" + tekst(kode[4][0]) + "\n")
    returner 0
}

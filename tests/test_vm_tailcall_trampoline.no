funksjon tel_ned(n: heiltall, acc: heiltall) -> heiltall {
    hvis n <= 0 { returner acc }
    returner tel_ned(n - 1, acc + 1)
}

funksjon start() -> heiltall {
    assert_eq(tel_ned(5000, 0), 5000)
    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["tail_calls"]) >= 5000)
    assert(heltall_fra_tekst(metrics["max_depth"]) < 20)
    returner 0
}

bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la web = fil_les("std/web.no")
    la manual = fil_les("docs/USER_MANUAL.md")
    la frontend_model = fil_les("docs/frontend/FRONTEND_MODEL.md")

    krev(web, "funksjon response_with_header(")
    krev(web, "h[nøkkel] = verdi")
    krev(web, "funksjon response_html(status: heltall, body: tekst) -> ordbok_tekst")
    krev(web, "\"content-type\": \"text/html; charset=utf-8\"")
    krev(web, "funksjon response_text_plain(status: heltall, body: tekst) -> ordbok_tekst")
    krev(web, "\"content-type\": \"text/plain; charset=utf-8\"")
    krev(web, "funksjon response_redirect(location: tekst, status: heltall) -> ordbok_tekst")
    krev(web, "\"location\": location")
    krev(web, "funksjon response_redirect_found(location: tekst) -> ordbok_tekst")
    krev(web, "returner response_redirect(location, 302)")
    krev(web, "funksjon response_redirect_see_other(location: tekst) -> ordbok_tekst")
    krev(web, "returner response_redirect(location, 303)")
    krev(web, "funksjon response_no_content() -> ordbok_tekst")
    krev(web, "returner response_builder(204, {}, \"\")")

    krev(manual, "`response_html`, `response_text_plain`, `response_redirect_found`, `response_redirect_see_other` og `response_no_content`")
    krev(manual, "`response_with_header`")
    krev(frontend_model, "standard HTML-, tekst-, redirect- og tomme responsar")

    skriv("test_web_response_helpers_contract OK")
    returner 0
}

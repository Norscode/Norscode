bruk std.model_runtime som modell
bruk std.qmodel_binary som binar

funksjon start() -> heiltall {
    la m = modell.ny("binary-file-q8", 2)
    assert(modell.legg_til_lag(m, modell.dense(2, 1, [-7, 9], [-123456], 8, "ingen")))
    la sti = "build/test_qmodel_binary.nqm"
    assert(binar.lagre(m, sti))
    la lasta = binar.last(sti, 100)
    la a = modell.kjor(m, [12, 4])
    la b = modell.kjor(lasta, [12, 4])
    assert_eq(a[0], b[0])
    assert_eq(lasta["navn"], "binary-file-q8")
    skriv("test_qmodel_binary_file OK\n")
    returner 0
}

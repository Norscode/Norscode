bruk selfhost.vm

funksjon feil_for(code: liste) -> tekst {
    prøv {
        køyr_funksjon("__main__.probe", [], {"__main__.probe": {"params": [], "code": code}}, 0)
    } fang (e) {
        returner tekst(e)
    }
    returner "ingen feil"
}

funksjon start() -> heiltall {
    la ukjent = feil_for([["NOPE"]])
    assert(builtin.index_of(ukjent, "ukjent opcode NOPE") >= 0)

    la operand = feil_for([["PUSH_CONST"], ["RETURN"]])
    assert(builtin.index_of(operand, "ugyldig operandantall") >= 0)

    la label = feil_for([["JUMP", "manglar"]])
    assert(builtin.index_of(label, "ukjent label manglar") >= 0)

    la negativ = feil_for([["BUILD_LIST", -1], ["RETURN"]])
    assert(builtin.index_of(negativ, "negativt antall") >= 0)

    la underflow = feil_for([["BINARY_ADD"], ["RETURN"]])
    assert(builtin.index_of(underflow, "Stack underflow") >= 0)
    returner 0
}

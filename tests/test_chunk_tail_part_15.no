    la script_norsk_cmp_kompakt_lte_ascii: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindreennellerlik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_kompakt_lte_ascii, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_kompakt_lte_er_ascii: tekst = sh.disasm_skript("la x=3;la y=4;hvis x ermindreennellerlik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_kompakt_lte_er_ascii, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_kompakt_lt_er_ascii: tekst = sh.disasm_skript("la x=3;la y=4;hvis x ermindreenn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_kompakt_lt_er_ascii, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_mindreenn_kompakt: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindreenn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_mindreenn_kompakt, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_underscore_ascii_mindre_lik: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindre_lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_underscore_ascii_mindre_lik, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_ermindrelik_kompakt: tekst = sh.disasm_skript("la x=3;la y=4;hvis x ermindrelik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_ermindrelik_kompakt, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_kompakt_ascii_lte: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindreellerlik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_kompakt_ascii_lte, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_underscore_ascii_mindrelik_kompakt: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindrelik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_underscore_ascii_mindrelik_kompakt, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_er_ikke_alias: tekst = sh.disasm_skript("la x=7;la y=8;hvis x er_ikke y da 1 ellers 0")
    assert_eq(script_norsk_cmp_er_ikke_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    returner 0
}

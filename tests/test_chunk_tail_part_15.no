    la script_norsk_cmp_phrase8_ikkelikmed_kompakt: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ikkelikmed y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase8_ikkelikmed_kompakt, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")


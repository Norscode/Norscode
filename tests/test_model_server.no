bruk std.model_server som server
bruk std.model_registry som register
bruk std.model_runtime som runtime

funksjon start() -> heiltall {
    la reg = register.ny(2, 1000)
    la modell = runtime.ny("server-modell", 2)
    runtime.legg_til_lag(modell, runtime.dense(2, 2, [1, 0, 0, 1], [0, 0], 8, "relu"))
    assert(register.registrer(reg, modell, "Norscode"))
    la s = server.ny(reg, 2, 2, 100)
    la a = server.send_inferens(s, "kunde-a", "server-modell", [3, 4], 10, 100)
    assert_eq(a["status"], "ventar")
    la b = server.send_inferens(s, "kunde-a", "server-modell", [5, 6], 11, 100)
    assert_eq(server.statistikk(s)["ventar"], "2")
    la ferdig = server.pump(s, 20)
    assert_eq(ferdig["status"], "ferdig")
    assert_eq(lengde(ferdig["resultat"]), 2)
    assert_eq(server.hent(s, a["id"])["status"], "ferdig")
    assert(server.avbryt(s, b["id"]))
    assert_eq(server.hent(s, b["id"])["status"], "avbroten")
    skriv("test_model_server OK\n")
    returner 0
}

bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la auth = fil_les("std/auth.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(auth, "bruk std.web som web")
    krev(auth, "funksjon slett_session_cookie() -> tekst")
    krev(auth, "Max-Age=0")
    krev(auth, "funksjon response_ikkje_innlogga(melding: tekst) -> ordbok_tekst")
    krev(auth, "\"www-authenticate\": \"Bearer\"")
    krev(auth, "funksjon response_manglar_rolle(rolle: tekst) -> ordbok_tekst")
    krev(auth, "funksjon response_login(token: tekst, dagar: heltall, redirect_til: tekst) -> ordbok_tekst")
    krev(auth, "\"set-cookie\": cookie")
    krev(auth, "funksjon response_logout(redirect_til: tekst) -> ordbok_tekst")

    krev(manual, "`std.auth`: innlogging, session-token, roller og ferdige 401/403/login/logout-responsar med session-cookie.")

    skriv("test_auth_response_helpers_contract OK")
    returner 0
}

funksjon ny_server_vm(port)
    returner {"startup_hooks": [], "shutdown_hooks": [], "request_middlewares": [], "response_middlewares": [], "error_middlewares": [], "type": "vm"}
slutt

funksjon register_standard_server_components_vm(server, health_handler, req, resp, err, startup_hook, shutdown_hook)
    server["startup_hooks"] = [startup_hook]
    server["shutdown_hooks"] = [shutdown_hook]
    server["request_middlewares"] = [req]
    server["response_middlewares"] = [resp]
    server["error_middlewares"] = [err]
    server["health_handler"] = health_handler
    returner server
slutt

funksjon route_vm(server, metode, sti, handler)
    returner server
slutt

funksjon køyre_startup_hooks_vm(server)
    returner {"phase": "startup", "__startup_hook_trace__": server["startup_hooks"]}
slutt

funksjon køyre_shutdown_hooks_vm(server)
    returner {"phase": "shutdown", "__shutdown_hook_trace__": server["shutdown_hooks"]}
slutt

funksjon anvend_request_middlewares_vm(server, ctx)
    returner {"__request_middleware_trace__": ["auth"]}
slutt

funksjon standard_helse_response_vm()
    returner {"status": 200, "body": "{\"ready\":true}"}
slutt

funksjon anvend_response_middlewares_vm(server, response)
    returner {"__response_middleware_trace__": ["cors"], "status": 200}
slutt

funksjon response_builder_vm(status, headers, body)
    returner {"status": status, "body": body}
slutt

funksjon anvend_error_middlewares_vm(server, response)
    returner {"__error_middleware_trace__": ["error-json"]}
slutt

funksjon dispatch_request_vm(server, metode, sti, ctx)
    returner {"status": 200}
slutt

funksjon køyre_server_syklus_vm(server, metode, sti, ctx)
    returner {
        "startup": {"phase": "startup"},
        "shutdown": {"phase": "shutdown"},
        "response": {"status": 200},
        "request_context": {"__request_middleware_trace__": ["auth"]}
    }
slutt

funksjon start() -> heiltall {
    la server = ny_server_vm(8090)
    register_standard_server_components_vm(server, "hei_handler", "auth", "cors", "error-json", "init-db", "flush-log")
    route_vm(server, "GET", "/helse", "hei_handler")
    la startup = køyre_startup_hooks_vm(server)
    assert_eq(startup["phase"], "startup")
    assert_eq(startup["__startup_hook_trace__"][0], "init-db")
    la ctx = anvend_request_middlewares_vm(server, {})
    assert_eq(ctx["__request_middleware_trace__"][0], "auth")
    la response = anvend_response_middlewares_vm(server, standard_helse_response_vm())
    la shutdown = køyre_shutdown_hooks_vm(server)
    assert_eq(shutdown["phase"], "shutdown")
    assert_eq(shutdown["__shutdown_hook_trace__"][0], "flush-log")
    la syklus = køyre_server_syklus_vm(server, "GET", "/helse", {})
    assert_eq(syklus["startup"]["phase"], "startup")
    assert_eq(syklus["shutdown"]["phase"], "shutdown")
    returner 0
}

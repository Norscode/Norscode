bruk std.media_diffusion som diffusjon

funksjon start() -> heiltall {
    la a = diffusjon.bilde("nordlys over fjord", "build/test_media_diffusion_a.ppm", 8, 8, 3, 8)
    la b = diffusjon.bilde("nordlys over fjord", "build/test_media_diffusion_b.ppm", 8, 8, 3, 8)
    assert_eq(a["ok"], "sann")
    assert_eq(b["ok"], "sann")
    assert_eq(a["backend"], "cpu-diffusion-v1")
    assert_eq(a["bytes"], b["bytes"])
    assert(heltall_fra_tekst(a["bytes"]) > 64)
    prøv {
        diffusjon.bilde("", "build/test_media_diffusion_invalid.ppm", 8, 8, 3, 8)
        assert(usann)
    } fang (e) {
        assert(builtin.index_of(tekst(e), "prompt manglar") >= 0)
    }
    skriv("test_media_diffusion OK\n")
    returner 0
}

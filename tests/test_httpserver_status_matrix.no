funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "routes": {}
    }
slutt

funksjon ny_server_vm(port)
    returner {
        "port": tekst(port),
        "routes": {}
    }
slutt

funksjon route(server, metode, sti, handler)
    server["routes"][metode + " " + sti] = handler
    returner server
slutt

funksjon route_vm(server, metode, sti, handler)
    server["routes"][metode + " " + sti] = handler
    returner server
slutt

funksjon start() -> heiltall {
    la server = ny_server(8081)
    la server_vm = ny_server_vm(8081)

    route(server, "GET", "/hei", "hei_handler")
    route_vm(server_vm, "GET", "/hei", "hei_handler_vm")

    assert_eq(server["routes"]["GET /hei"], "hei_handler")
    assert_eq(server_vm["routes"]["GET /hei"], "hei_handler_vm")

    returner 0
}

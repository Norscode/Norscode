bruk std.tekst som t

funksjon start() -> heiltall {
    la abi_src = fil_les("docs/SELFHOST_PHASE2_ABI_MINIMUM_V1.md")
    assert(t.inneholder(abi_src, "minimale runtime-kontraktar, patchpunkt"))
    assert(ikkje t.inneholder(abi_src, "placeholderar, og eigne runtime-kontrollar"))

    la plan_src = fil_les("docs/SELFHOST_HANDLINGSPLAN.md")
    assert(t.inneholder(plan_src, "uavklarte runtime-kontraktar og historiske mock-stiar"))
    assert(ikkje t.inneholder(plan_src, "placeholder- og mock-path"))

    la backlog_src = fil_les("docs/SELFHOST_PHASE2_BACKLOG.md")
    assert(t.inneholder(backlog_src, "Runtime-kontraktstatus"))
    assert(t.inneholder(backlog_src, "minimale runtime-kontraktar som skal bytast ut med sterkare implementasjon"))
    assert(t.inneholder(backlog_src, "patchpunkt og kontrakttekst"))
    assert(ikkje t.inneholder(backlog_src, "Runtime-stubstatus"))
    assert(ikkje t.inneholder(backlog_src, "placeholder-funksjonar"))
    assert(ikkje t.inneholder(backlog_src, "placeholder-patching"))

    la operating_src = fil_les("docs/SELFHOST_PHASE2_RUNTIME_OPERATING_PLAN.md")
    assert(t.inneholder(operating_src, "uavklarte kontraktar og historiske mock-stiar"))
    assert(t.inneholder(operating_src, "rydding av uavklart kontrakttekst"))
    assert(ikkje t.inneholder(operating_src, "placeholder- og mock-path"))
    assert(ikkje t.inneholder(operating_src, "rydding av placeholderar"))

    la sprint_src = fil_les("docs/SELFHOST_PHASE2_SPRINT2_PLAN.md")
    assert(t.inneholder(sprint_src, "minimale runtime-kontraktar som skal få sterkare implementasjonar"))
    assert(t.inneholder(sprint_src, "Runtime-kontraktar som kandidatar"))
    assert(ikkje t.inneholder(sprint_src, "runtime-stubbar"))
    assert(ikkje t.inneholder(sprint_src, "Runtime-stubbar som kandidatar"))

    la status_src = fil_les("docs/SELFHOST_PHASE2_STATUS.md")
    assert(t.inneholder(status_src, "forward-ref patchpunkt"))
    assert(ikkje t.inneholder(status_src, "forward-ref placeholderar"))

    la stdlib_matrix_src = fil_les("docs/SELFHOST_PHASE2_STDLIB_STATUS_MATRIX.md")
    assert(t.inneholder(stdlib_matrix_src, "er han utanfor denne byggfasen"))
    assert(ikkje t.inneholder(stdlib_matrix_src, "byggfasen enno"))

    la ffi_smoke_src = fil_les("docs/SELFHOST_PHASE2_FFI_SMOKETEST_V1.md")
    assert(t.inneholder(ffi_smoke_src, "Skriv og les ei kortlevd, deterministisk røykfil"))
    assert(ikkje t.inneholder(ffi_smoke_src, "Skriv og les ein midlertidig fil"))

    skriv("test_phase2_docs_contract_text OK")
    returner 0
}

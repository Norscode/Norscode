bruk compiler.semantic.types.type_checker som tc

funksjon start() -> heltall {
    assert_eq(tc.check_type(null), "ingen")
    assert_eq(tc.check_type(sann), "bool")
    assert_eq(tc.check_type(usann), "bool")
    assert_eq(tc.check_type("hei"), "tekst")
    assert_eq(tc.check_type(42), "heltall")
    assert_eq(tc.types_match(1, 2), sann)
    assert_eq(tc.types_match(1, "tekstverdi"), usann)

    la node = {
        "type": "LiteralExpr",
        "verdi": "norscode"
    }
    la inf = tc.typecheck_uttrykk(7, node)
    assert_eq(inf["ok"], sann)
    assert_eq(inf["type"], "tekst")

    la bin = {
        "type": "BinaryExpr",
        "left": { "type": "LiteralExpr", "verdi": 1 },
        "right": { "type": "LiteralExpr", "verdi": "tekstverdi" }
    }
    la mismatch = tc.typecheck_uttrykk(11, bin)
    assert_eq(mismatch["ok"], usann)
    assert_eq(mismatch["feil"]["forventet"], "heltall")
    assert_eq(mismatch["feil"]["funnet"], "tekst")

    la unary = {
        "type": "UnaryExpr",
        "operand": { "type": "LiteralExpr", "verdi": sann }
    }
    la unary_res = tc.typecheck_uttrykk(15, unary)
    assert_eq(unary_res["ok"], sann)
    assert_eq(unary_res["type"], "bool")

    la call = {
        "type": "CallExpr",
        "callee": { "type": "Identifier", "verdi": "logg" },
        "args": {
            "barn": [
                { "type": "LiteralExpr", "verdi": 7 }
            ]
        }
    }
    la call_res = tc.typecheck_uttrykk(19, call)
    assert_eq(call_res["ok"], sann)
    assert_eq(call_res["type"], "ukjent")

    la list_node = {
        "type": "Liste",
        "barn": [
            { "type": "LiteralExpr", "verdi": 1 },
            { "type": "LiteralExpr", "verdi": 2 }
        ]
    }
    la list_res = tc.typecheck_uttrykk(23, list_node)
    assert_eq(list_res["ok"], sann)
    assert_eq(list_res["type"], "liste")

    la map_node = {
        "type": "Map",
        "barn": [
            { "type": "MapPar", "barn": [ { "type": "LiteralExpr", "verdi": "navn" }, { "type": "LiteralExpr", "verdi": "Ada" } ] }
        ]
    }
    la map_res = tc.typecheck_uttrykk(27, map_node)
    assert_eq(map_res["ok"], sann)
    assert_eq(map_res["type"], "ordbok")

    la struct_node = {
        "type": "StructLiteral",
        "barn": [
            { "type": "Felt", "verdi": "navn" }
        ]
    }
    la struct_res = tc.typecheck_uttrykk(31, struct_node)
    assert_eq(struct_res["ok"], sann)
    assert_eq(struct_res["type"], "ordbok")

    la map_mismatch_node = {
        "type": "Map",
        "barn": [
            { "type": "MapPar", "barn": [ { "type": "LiteralExpr", "verdi": "navn" }, { "type": "LiteralExpr", "verdi": "Ada" } ] },
            { "type": "MapPar", "barn": [ { "type": "LiteralExpr", "verdi": "alder" }, { "type": "LiteralExpr", "verdi": 42 } ] }
        ]
    }
    la map_mismatch = tc.typecheck_uttrykk(35, map_mismatch_node)
    assert_eq(map_mismatch["ok"], usann)
    assert_eq(map_mismatch["feil"]["forventet"], "tekst")
    assert_eq(map_mismatch["feil"]["funnet"], "heltall")

    la struct_mismatch_node = {
        "type": "StructLiteral",
        "barn": [
            { "type": "StructPar", "verdi": "navn", "barn": [ { "type": "LiteralExpr", "verdi": "Ada" } ] },
            { "type": "StructPar", "verdi": "alder", "barn": [ { "type": "LiteralExpr", "verdi": 42 } ] }
        ]
    }
    la struct_mismatch = tc.typecheck_uttrykk(39, struct_mismatch_node)
    assert_eq(struct_mismatch["ok"], usann)
    assert_eq(struct_mismatch["feil"]["forventet"], "tekst")
    assert_eq(struct_mismatch["feil"]["funnet"], "heltall")

    la index_node = {
        "type": "Indeks",
        "base": { "type": "LiteralExpr", "verdi": [1, 2, 3] },
        "index": { "type": "LiteralExpr", "verdi": 0 }
    }
    la index_res = tc.typecheck_uttrykk(43, index_node)
    assert_eq(index_res["ok"], sann)

    la slice_node = {
        "type": "Slice",
        "base": { "type": "LiteralExpr", "verdi": [1, 2, 3] }
    }
    la slice_res = tc.typecheck_uttrykk(47, slice_node)
    assert_eq(slice_res["ok"], sann)
    assert_eq(slice_res["type"], "liste")

    la program = [
        { "type": "LiteralExpr", "verdi": 1, "linje": 1 },
        { "type": "BinaryExpr", "left": { "type": "LiteralExpr", "verdi": 2 }, "right": { "type": "LiteralExpr", "verdi": "tekstverdi" }, "linje": 2 },
        { "type": "Identifier", "verdi": null, "linje": 3 }
    ]
    la program_res = tc.typecheck_program(program)
    assert_eq(program_res["ok"], usann)
    assert_eq(lengde(program_res["feil"]), 2)
    assert_eq(program_res["feil"][0]["forventet"], "heltall")
    assert_eq(program_res["feil"][1]["forventet"], "identifikator")

    la program_node = {
        "type": "Program",
        "barn": [
            { "type": "LiteralExpr", "verdi": 4, "linje": 1 }
        ]
    }
    la program_node_res = tc.typecheck_program(program_node)
    assert_eq(program_node_res["ok"], sann)
    assert_eq(lengde(program_node_res["feil"]), 0)

    returner 0
}

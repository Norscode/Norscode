bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/python_free_ci.no")

    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "./bin/nc active-surface"))
    assert(t.inneholder(src, "./bin/nc fetch-stage0-seed"))
    assert(t.inneholder(src, "./bin/nc test"))
    assert(ikkje t.inneholder(src, "bash tools/build_norscode_native.sh"))
    assert(ikkje t.inneholder(src, "bash tools/no_c_python_active_surface.sh"))
    assert(ikkje t.inneholder(src, "sh tools/nc_test.sh"))
    assert(ikkje t.inneholder(src, "| tail -2"))
    assert(ikkje t.inneholder(src, "2>&1 | tail"))

    la wrapper = fil_les("tools/python_free_ci.sh")
    assert(t.inneholder(wrapper, "Ukjent funksjon: builtin"))
    assert(t.inneholder(wrapper, "print_file() {"))
    assert(t.inneholder(wrapper, "has_exec_gap() {"))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" active-surface"))
    assert(t.inneholder(wrapper, "_stage0_platform=\"macos-arm64\""))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" fetch-stage0-seed \"$_stage0_platform\""))
    assert(t.inneholder(wrapper, "\"$ROOT/bin/nc\" test"))
    assert(ikkje t.inneholder(wrapper, "cat \"$OUT\""))
    assert(ikkje t.inneholder(wrapper, "grep -Eq 'Ukjent funksjon: builtin"))
    assert(ikkje t.inneholder(wrapper, "bash tools/build_norscode_native.sh"))
    assert(ikkje t.inneholder(wrapper, "bash tools/no_c_python_active_surface.sh"))
    assert(ikkje t.inneholder(wrapper, "sh tools/nc_test.sh"))

    la fetch = fil_les("tools/fetch_stage0_seed.no")
    assert(t.inneholder(fetch, "NORSCODE_STAGE0_PLATFORM"))
    assert(t.inneholder(fetch, "NORSCODE_STAGE0_SEED_BYTES"))
    assert(t.inneholder(fetch, "funksjon byte_status"))
    assert(t.inneholder(fetch, "storleik ukjent"))
    assert(ikkje t.inneholder(fetch, "(\" + bytes(dest) + \" bytes)"))
    la fetch_wrapper = fil_les("tools/fetch_stage0_seed.sh")
    assert(t.inneholder(fetch_wrapper, "NORSCODE_STAGE0_PLATFORM=\"$1\""))
    assert(t.inneholder(fetch_wrapper, "file_bytes() {"))
    assert(t.inneholder(fetch_wrapper, "NORSCODE_STAGE0_SEED_BYTES=\"$(file_bytes \"$_seed\")\""))
    assert(ikkje t.inneholder(fetch_wrapper, "| tr -d ' '"))
    assert(ikkje t.inneholder(fetch_wrapper, "wc -c <"))

    skriv("test_python_free_ci_no_tail OK")
    returner 0
}

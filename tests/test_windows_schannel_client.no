funksjon start() -> heiltall {
    la tls = builtin.network_operation({
        "abi": "norscode-native-network-v1",
        "operation": "tls_connect",
        "host": "104.16.124.96",
        "port": 443,
        "hostname": "www.cloudflare.com",
        "ca_file": ""
    })
    assert(tls["status"] == "connecting" eller tls["status"] == "connected")
    la i: heiltall = 0
    mens tls["status"] == "connecting" og i < 1000 {
        tls["operation"] = "poll"
        tls["events"] = 2
        la ready = builtin.network_operation(tls)
        hvis ready["status"] == "klar" { tls["status"] = "connected" }
        hvis ready["status"] == "feil" { kast ready["error"] }
        i = i + 1
    }
    tls["operation"] = "tls_handshake"
    la handshake = builtin.network_operation(tls)
    skriv("schannel status=" + handshake["status"])
    skriv("schannel error=" + handshake["error"])
    assert_eq(handshake["status"], "connected")
    assert_eq(handshake["tls_version"], "TLSv1.3")
    assert(handshake["peer_verified"])
    assert(handshake["peer_cert_present"])

    tls["operation"] = "write"
    tls["data"] = "GET / HTTP/1.1\r\nHost: www.cloudflare.com\r\nConnection: close\r\n\r\n"
    assert(builtin.network_operation(tls)["value"] > 0)
    tls["operation"] = "read"
    tls["max"] = 65536
    la response = {"status": "ventende", "data": ""}
    i = 0
    mens response["status"] == "ventende" og i < 10000 {
        response = builtin.network_operation(tls)
        i = i + 1
    }
    assert_eq(response["status"], "ok")
    assert(builtin.starts_with(response["data"], "HTTP/1.1"))
    tls["operation"] = "close"
    assert_eq(builtin.network_operation(tls)["status"], "closed")
    skriv("test_windows_schannel_client OK")
    returner 0
}

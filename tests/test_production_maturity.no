bruk std.tekst som t

funksjon krev(sti: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        returner 0
    }
    skriv("Manglar produksjonsbevis: " + sti)
    returner 1
}

funksjon start() -> heiltall {
    la feil = 0

    feil = feil + krev("examples/observability_export.no")
    feil = feil + krev("examples/logging.no")
    feil = feil + krev("examples/metrics.no")
    feil = feil + krev("examples/trace.no")
    feil = feil + krev("examples/audit.no")
    feil = feil + krev("examples/secrets.no")
    feil = feil + krev("docs/05-development/SELFHOST_RELEASE_CHECKLIST.md")
    feil = feil + krev("docs/MODENHET_10_10.md")
    feil = feil + krev("selfhost/doctor.no")
    feil = feil + krev("selfhost/maintenance.no")
    feil = feil + krev("tests/test_web_runtime_production_matrix.no")

    assert_eq(feil, 0)

    la obs = fil_les("examples/observability_export.no")
    assert(t.inneholder(obs, "std.metrics"))
    assert(t.inneholder(obs, "std.trace"))
    assert(t.inneholder(obs, "std.audit"))
    assert(t.inneholder(obs, "json_stringify"))

    la secrets = fil_les("examples/secrets.no")
    assert(t.inneholder(secrets, "passord_hash"))
    assert(t.inneholder(secrets, "passord_verifiser"))
    assert(t.inneholder(secrets, "hemmelighet_hent"))

    la release = fil_les("docs/05-development/SELFHOST_RELEASE_CHECKLIST.md")
    assert(t.inneholder(release, "Tilbakerulling"))
    assert(t.inneholder(release, "release- og installasjonsflata krev ikkje C-verktøykjede"))
    assert(t.inneholder(release, "./bin/nc feature-check"))

    la maintenance = fil_les("selfhost/maintenance.no")
    assert(t.inneholder(maintenance, "maturity"))
    assert(t.inneholder(maintenance, "stage0_seed_ok"))

    la deploy = fil_les("std/deploy.no")
    assert(t.inneholder(deploy, "produksjonsmønster"))
    assert(t.inneholder(deploy, "rollback"))

    la upload = fil_les("std/opplasting.no")
    assert(t.inneholder(upload, "produksjonsstatus"))

    la sesjon = fil_les("std/sesjon.no")
    assert(t.inneholder(sesjon, "sikkerheitsstatus"))

    skriv("test_production_maturity OK")
    returner 0
}

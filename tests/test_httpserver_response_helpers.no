funksjon ny_server(port)
    returner {
        "port": tekst(port)
    }
slutt

funksjon response_builder(headers, body)
    svar = {}
    svar["body"] = body
    svar["x-test"] = headers["x-test"]
    returner svar
slutt

funksjon response_body(resp)
    returner ""
slutt

funksjon text_response(body)
    svar = {}
    svar["body"] = body
    svar["content-type"] = "text/plain; charset=utf-8"
    returner svar
slutt

funksjon direct_response(resp)
    returner resp
slutt

funksjon start() -> heiltall {
    la tekstsvar = text_response("hei")
    assert_eq(tekstsvar["content-type"], "text/plain; charset=utf-8")

    la direkte = direct_response(response_builder({"x-test": "ja"}, "ok"))

    returner 0
}

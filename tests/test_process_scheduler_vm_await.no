bruk std.prosess som prosess
bruk std.sched som sched
bruk selfhost.vm

funksjon start() -> heltall {
    la policy = prosess.ny_policy("process-await-test")
    prosess.tillat_alle(policy)
    prosess.tillat_shell(policy)
    prosess.aktiver_køyring(policy)

    la scheduler = sched.ny()
    la plan = prosess.start_plan("printf event-loop-ok")
    prosess.med_timeout(plan, 5)
    la process_handle = prosess.start_async_med_future(scheduler, policy, plan, "build/process-await-test")
    hvis process_handle["status"] == "feil" { skriv("process await start error: " + process_handle["feil"] + "\n") }
    assert_eq(process_handle["status"], "kjorer")
    la future = sched.future_handtak(scheduler, process_handle["future_id"])
    la functions = {
        "__main__.await_process": {
            "params": [],
            "code": [
                ["PUSH_CONST", future],
                ["CALL", "builtin.await_value", 1],
                ["RETURN"]
            ]
        }
    }

    køyr_funksjon("__main__.await_process", [], functions, 0)
    assert(vm_async_er_suspendert(functions))
    assert(sched.run(scheduler, 5000) >= 1)
    assert_eq(future["status"], "ferdig")
    la resultat = builtin.json_parse(vm_async_resume(functions))
    assert_eq(resultat["exit_code"], "0")
    assert_eq(resultat["stdout"], "event-loop-ok")
    returner 0
}

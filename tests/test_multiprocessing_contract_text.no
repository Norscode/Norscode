bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/multiprocessing.no")

    assert(t.inneholder(src, "Rydd opp kortlevde prosessartefaktar"))
    assert(ikkje t.inneholder(src, "Rydd opp midlertidige filer"))

    skriv("test_multiprocessing_contract_text OK")
    returner 0
}

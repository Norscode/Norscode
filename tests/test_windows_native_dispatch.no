funksjon start() -> heiltall {
    la file_request = {
        "abi": "norscode-native-filesystem-v1",
        "operation": "open",
        "root": "build",
        "relative": "windows-native-dispatch.txt",
        "mode": "write"
    }
    la file_handle = builtin.filesystem_write_operation(file_request)
    assert_eq(file_handle["status"], "open")
    assert_eq(file_handle["event_backend"], "wsapoll")

    file_handle["operation"] = "write"
    file_handle["data"] = "windows-file-ok"
    assert_eq(builtin.filesystem_write_operation(file_handle)["value"], 15)
    file_handle["operation"] = "flush"
    assert_eq(builtin.filesystem_write_operation(file_handle)["status"], "ok")
    file_handle["operation"] = "close"
    assert_eq(builtin.filesystem_write_operation(file_handle)["status"], "closed")
    assert_eq(builtin.filesystem_write_operation(file_handle)["status"], "feil")
    skriv("windows dispatch: write handle OK")

    la read_request = {
        "abi": "norscode-native-filesystem-v1",
        "operation": "open",
        "root": "build",
        "relative": "windows-native-dispatch.txt",
        "mode": "read"
    }
    la read_handle = builtin.filesystem_read_operation(read_request)
    read_handle["operation"] = "read"
    read_handle["max"] = 64
    assert_eq(builtin.filesystem_read_operation(read_handle)["data"], "windows-file-ok")
    read_handle["operation"] = "close"
    assert_eq(builtin.filesystem_read_operation(read_handle)["status"], "closed")
    skriv("windows dispatch: read handle OK")

    la process_request = {
        "abi": "norscode-native-process-v1",
        "operation": "spawn_argv",
        "executable": "Z:/work/build/runtime-candidate/nc_windows_process_fixture.exe",
        "args": ["ok"],
        "cwd": "",
        "stdin": "",
        "timeout_ms": 5000,
        "max_output_bytes": 65536,
        "max_memory_bytes": 0,
        "sandbox": "restricted"
    }
    la process = builtin.process_operation(process_request)
    assert_eq(process["status"], "kjorer")
    assert_eq(process["sandbox_backend"], "job-object")
    process["operation"] = "wait"
    process["wait_ms"] = 5000
    la finished = builtin.process_operation(process)
    skriv("windows dispatch: process status=" + finished["status"])
    skriv("windows dispatch: process exit=" + tekst_fra_heltall(finished["exit_code"]))
    skriv("windows dispatch: process stderr=" + finished["stderr"])
    assert_eq(finished["status"], "ferdig")
    assert_eq(finished["exit_code"], 0)
    process["operation"] = "read"
    la output = builtin.process_operation(process)
    assert_eq(output["stdout"], "windows-process-ok")
    process["operation"] = "close"
    assert_eq(builtin.process_operation(process)["status"], "ferdig")
    assert_eq(builtin.process_operation(process)["status"], "feil")

    la timeout_request = {
        "abi": "norscode-native-process-v1",
        "operation": "spawn_argv",
        "executable": "Z:/work/build/runtime-candidate/nc_windows_process_fixture.exe",
        "args": ["sleep"],
        "cwd": "",
        "stdin": "",
        "timeout_ms": 100,
        "max_output_bytes": 65536,
        "max_memory_bytes": 0,
        "sandbox": "restricted"
    }
    la timed = builtin.process_operation(timeout_request)
    timed["operation"] = "wait"
    timed["wait_ms"] = 1000
    assert_eq(builtin.process_operation(timed)["status"], "timeout")
    timed["operation"] = "close"
    assert_eq(builtin.process_operation(timed)["status"], "timeout")

    la sync_request = {
        "abi": "norscode-process-spawn-v1",
        "executable": "Z:/work/build/runtime-candidate/nc_windows_process_fixture.exe",
        "args": ["sync"],
        "cwd": "",
        "stdin": "",
        "timeout_ms": 5000,
        "max_output_bytes": 65536,
        "max_memory_bytes": 0,
        "max_open_files": 64,
        "inherit_env": 1,
        "sandbox": "restricted"
    }
    la sync_result = builtin.process_spawn_argv(sync_request)
    assert_eq(sync_result["status"], "ferdig")
    assert_eq(sync_result["exit_code"], 0)
    assert_eq(sync_result["stdout"], "windows-process-sync")
    assert_eq(sync_result["sandbox_backend"], "job-object")

    la delete_request = {
        "abi": "norscode-native-filesystem-v1",
        "operation": "delete",
        "root": "build",
        "relative": "windows-native-dispatch.txt"
    }
    assert_eq(builtin.filesystem_write_operation(delete_request)["status"], "deleted")
    skriv("test_windows_native_dispatch OK")
    returner 0
}

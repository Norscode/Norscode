funksjon start() -> heiltall {
    la key = builtin.fil_les("tests/fixtures/tls/localhost.key")
    la sig = builtin.acme_sign("RS256", key, "abc")
    assert(lengde(sig) == 512)
    assert(builtin.starts_with(sig, "6184c2982eeb50d97279341f087e1c2c88bc206627a86af0f6cf763ab98830f7"))
    skriv("test_acme_sign_native OK\n")
    returner 0
}

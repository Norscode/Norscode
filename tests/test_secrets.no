bruk std.secrets som sikkerhet
bruk std.tekst som t

funksjon start() -> heltall {
    la lagret = sikkerhet.passord_hash("hemmelig", "salt123456789012")
    assert(sikkerhet.passord_verifiser("hemmelig", lagret))
    assert(ikke sikkerhet.passord_verifiser("feil", lagret))
    assert(t.starter_med(lagret, "salt123456789012$"))

    assert(sikkerhet.hemmelighet_finnes("NORSCODE_ROOT"))
    // Rooten er plattform- og CI-avhengig; kontrakten er at han er tilgjengeleg.
    assert(lengde(sikkerhet.hemmelighet_hent("NORSCODE_ROOT")) > 0)
    assert(ikke sikkerhet.hemmelighet_finnes("NORSCODE_TEST_SECRET_FINNST_IKKJE"))
    assert_eq(sikkerhet.hemmelighet_hent("NORSCODE_TEST_SECRET_FINNST_IKKJE"), "")

    returner 0
}

bruk selfhost.vm

funksjon start() -> heiltall {
    skriv("probe vm bridge before\n")
    prøv {
        la svar = køyr_funksjon("__main__.manglar", [], {}, 0)
        skriv("probe vm bridge after: " + tekst(svar) + "\n")
        returner 0
    } fang melding {
        skriv("probe vm bridge caught: " + melding + "\n")
        returner 1
    }
}

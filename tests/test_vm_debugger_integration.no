bruk std.runtime_debugger som debug

funksjon arbeid(x: heltall) -> heltall {
    la y = x + 1
    returner y * 2
}

funksjon start() -> heiltall {
    assert(debug.aktiver())
    assert(debug.breakpoint("__main__.arbeid", 0))
    assert_eq(arbeid(4), 10)
    la snap = debug.snapshot()
    assert_eq(snap["last_function"], "__main__.arbeid")
    assert_eq(snap["last_ip"], "0")
    assert_eq(snap["last_opcode"], "LOAD_NAME")
    assert(heltall_fra_tekst(snap["hit_count"]) >= 1)
    assert_eq(snap["last_frame_state"], "running")
    assert(heltall_fra_tekst(snap["last_frame_depth"]) >= 2)
    assert_inneholder(snap["last_variables"], "x")
    assert(debug.fortsett_kjoring())
    assert(debug.steg_instruksjon())
    la z = arbeid(2)
    assert_eq(z, 6)
    la step_snap = debug.snapshot()
    assert(heltall_fra_tekst(step_snap["hit_count"]) >= 2)
    assert(debug.deaktiver())
    returner 0
}

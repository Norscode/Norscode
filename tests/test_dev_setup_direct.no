bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("scripts/dev-setup.no")
    la wrapper = fil_les("scripts/dev-setup.sh")

    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(t.inneholder(src, "builtin.replace(s, \"'\""))
    assert(t.inneholder(src, "funksjon fil_finst(sti: tekst) -> bool"))
    assert(t.inneholder(src, "dist/norscode_native er allereie materialisert."))
    assert(t.inneholder(src, "/bin/nc\") + \" build-bootstrap-binary\""))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(src, "returner \"'\" + sti + \"'\""))
    assert(ikkje t.inneholder(src, "tools/build-bootstrap-binary.sh"))
    assert(t.inneholder(wrapper, "Norscode-first wrapper: utvikleroppsett ligg i scripts/dev-setup.no."))
    assert(t.inneholder(wrapper, "Shell-delen under set berre rot/prosessmiljø og startar Norscode-eigarfil."))
    assert(t.inneholder(wrapper, "export NORSCODE_ROOT=\"$ROOT_DIR\""))
    assert(t.inneholder(wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT_DIR\" \"$ROOT_DIR/bin/nc\" run \"$ROOT_DIR/scripts/dev-setup.no\""))
    assert(ikkje t.inneholder(wrapper, "exec \"$ROOT_DIR/bin/nc\" run \"$ROOT_DIR/scripts/dev-setup.no\""))
    assert(ikkje t.inneholder(wrapper, "Tynn wrapper"))

    skriv("test_dev_setup_direct OK")
    returner 0
}

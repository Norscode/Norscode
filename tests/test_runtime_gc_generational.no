bruk std.runtime_memory som minne

funksjon start() -> heiltall {
    la h = minne.ny_heap()
    minne.sett_gc_threshold(h, 1)

    la old = minne.alloker(h, "kart", 32)
    assert(minne.legg_rot(h, old))
    assert_eq(minne.collect_minor(h)["kind"], "minor")
    assert_eq(minne.collect_minor(h)["promoted"], "1")
    assert_eq(minne.objekt_generasjon(h, old), "old")

    la young = minne.alloker(h, "tekst", 16)
    assert(minne.legg_ref(h, old, young))
    assert(minne.fjern_rot(h, old))
    la minor = minne.collect_minor(h)
    assert_eq(minor["freed"], "0")
    assert(minne.objekt_levande(h, old))
    assert(minne.objekt_levande(h, young))

    la garbage = minne.alloker(h, "liste", 8)
    la minor2 = minne.collect_minor(h)
    assert_eq(minor2["freed"], "1")
    assert(ikkje minne.objekt_levande(h, garbage))

    la major = minne.collect_major(h)
    assert_eq(major["kind"], "major")
    assert_eq(major["freed"], "2")
    assert(ikkje minne.objekt_levande(h, old))
    assert(ikkje minne.objekt_levande(h, young))

    la s = minne.samandrag(h)
    assert_eq(s["minor_collections"], "4")
    assert_eq(s["major_collections"], "1")
    assert_eq(s["collections"], "5")

    la h2 = minne.ny_heap()
    la i: heiltall = 0
    mens i < 8 {
        la r = minne.collect_auto(h2, usann)
        hvis i < 7 { assert_eq(r["kind"], "minor") }
        hvis i == 7 { assert_eq(r["kind"], "major") }
        i = i + 1
    }
    assert_eq(minne.collect_auto(h2, sann)["kind"], "major")
    returner 0
}

bruk std.log som log
bruk std.fil som fil
bruk std.cache som cache
bruk std.lagring som lagring
bruk std.innstillingar som cfg
bruk std.sched som sched
bruk std.tråd som trd

funksjon start() -> heiltall {
    la logg = log.debug("usecase")
    log.med_kontekst(logg, "modul", "std.log")
    assert_eq(log.filtrer_nivå([logg], "debug")[0]["message"], "usecase")
    assert_eq(log.tel_nivå([logg], "debug"), 1)

    assert_eq(fil.finnes("README.md"), sann)
    la fil_status = fil.status("README.md")
    assert_eq(fil_status["gyldig"], "sann")

    la c = cache.ny_minne()
    cache.sett(c, "hello", "world", 120)
    assert_eq(cache.hent(c, "hello", ""), "world")
    assert_eq(cache.status(c)["gyldig"], "sann")

    la lagra = lagring.lagre("build/phase2_usecases.json", {"a": "b"})
    assert_eq(lagra, 1)
    la lasta = lagring.last("build/phase2_usecases.json")
    hvis (har_nokkel(lasta, "a")) {
        assert_eq(lasta["a"], "b")
    }

    la s = cfg.ny()
    assert_eq(cfg.status(s)["kjelde"], "tom")
    assert_eq(lengde(cfg.miljønøkkel_liste(s)) >= 0, sann)

    la sc = sched.ny()
    sched.enter(sc, 1, 1, "jobb", [])
    assert_eq(sched.status(sc)["gyldig"], "sann")
    assert_eq(sched.tid_til_neste(sc) >= 0, sann)

    la manager = trd.ny_manager()
    assert_eq(trd.status_oversikt(manager)["aktive"], "0")

    returner 0
}

bruk selfhost.native_execution.native_codegen_v2 som codegen

funksjon start() -> heiltall {
    la runtime = codegen.bygg_runtime_v2()
    la bytes = runtime[0]
    la vas = runtime[1]
    la base = codegen.TEXT_VA()

    assert(vas["load"] >= base)
    assert(vas["store"] > vas["load"])
    assert(vas["exchange"] > vas["store"])
    assert(vas["compare_exchange"] > vas["exchange"])
    assert(vas["fetch_add"] > vas["compare_exchange"])
    assert(vas["fence"] > vas["fetch_add"])
    assert(vas["fence"] - base < lengde(bytes))

    la exchange = vas["exchange"] - base
    assert_eq(bytes[exchange + 11], 0x48)
    assert_eq(bytes[exchange + 12], 0x87)
    assert_eq(bytes[exchange + 13], 0x07)

    la cas = vas["compare_exchange"] - base
    assert_eq(bytes[cas + 15], 0xF0)
    assert_eq(bytes[cas + 16], 0x48)
    assert_eq(bytes[cas + 17], 0x0F)
    assert_eq(bytes[cas + 18], 0xB1)
    assert_eq(bytes[cas + 19], 0x17)

    la fetch_add = vas["fetch_add"] - base
    assert_eq(bytes[fetch_add + 11], 0xF0)
    assert_eq(bytes[fetch_add + 12], 0x48)
    assert_eq(bytes[fetch_add + 13], 0x0F)
    assert_eq(bytes[fetch_add + 14], 0xC1)
    assert_eq(bytes[fetch_add + 15], 0x07)

    la fence = vas["fence"] - base
    assert_eq(bytes[fence], 0x0F)
    assert_eq(bytes[fence + 1], 0xAE)
    assert_eq(bytes[fence + 2], 0xF0)
    returner 0
}

bruk selfhost.common som sh

funksjon tokens(expr: tekst) -> tekst {
    returner sh.tokens_uttrykk(expr)
}

funksjon stabil(expr: tekst) -> bool {
    la a: tekst = tokens(expr)
    la b: tekst = tokens(expr)
    returner a == b
}

funksjon start() -> heltall {
    # Unary tokens
    assert(stabil("ikkje 1"))

    # Boolean tokens
    assert(stabil("1 og 0 eller 1"))

    # Comparison tokens
    assert(stabil("1 mindre_enn 2 og 1"))

    # Nested tokens
    assert(stabil("((1 eller 0) og (1 og 1))"))

    # Parenthesis tokens
    assert(stabil("((((1))))"))

    # Token stream må ikke være tom
    assert_ne(tokens("1 og 0"), "")
    assert_ne(tokens("ikkje 1"), "")

    returner 0
}

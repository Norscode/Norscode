bruk std.prosess som prosess
bruk std.runtime.process_abi som abi

funksjon start() -> heiltall {
    la policy = prosess.ny_policy("native-async")
    assert(prosess.tillat_alle(policy))
    assert(prosess.aktiver_køyring(policy))

    la cat_plan = prosess.start_argv_plan("/bin/cat", [])
    prosess.med_stdin(cat_plan, "stream-ok")
    prosess.med_timeout(cat_plan, 5)
    la cat = prosess.start_argv_async_trygt(policy, cat_plan)
    assert_eq(cat["status"], "kjorer")
    assert(abi.gyldig_async_resultat(cat))
    assert(heltall_fra_tekst(cat["pid"]) > 0)
    la cat_done = prosess.native_async_vent(cat, 5000)
    assert_eq(cat_done["status"], "ferdig")
    assert_eq(heltall_fra_tekst(cat_done["exit_code"]), 0)
    la cat_output = prosess.native_async_les(cat)
    assert_eq(cat_output["stdout"], "stream-ok")
    assert_eq(prosess.native_async_les(cat)["stdout"], "")
    assert_eq(prosess.native_async_lukk(cat)["status"], "ferdig")

    la sleep_plan = prosess.start_argv_plan("/bin/sleep", ["30s"])
    prosess.med_timeout(sleep_plan, 30)
    la sleeping = prosess.start_argv_async_trygt(policy, sleep_plan)
    assert_eq(sleeping["status"], "kjorer")
    prosess.native_async_signal(sleeping, 15)
    la signalled = prosess.native_async_vent(sleeping, 5000)
    assert_eq(signalled["status"], "signal")
    assert_eq(heltall_fra_tekst(signalled["exit_code"]), 143)
    assert_eq(prosess.native_async_lukk(sleeping)["status"], "signal")

    la timeout_plan = prosess.start_argv_plan("/bin/sleep", ["30s"])
    prosess.med_timeout(timeout_plan, 1)
    la timed = prosess.start_argv_async_trygt(policy, timeout_plan)
    la timeout_result = prosess.native_async_vent(timed, 3000)
    assert_eq(timeout_result["status"], "timeout")
    assert_eq(heltall_fra_tekst(timeout_result["exit_code"]), 124)
    assert_eq(prosess.native_async_lukk(timed)["status"], "timeout")

    la i: heiltall = 0
    mens i < 5 {
        la plan = prosess.start_argv_plan("/usr/bin/printf", ["reuse"])
        la child = prosess.start_argv_async_trygt(policy, plan)
        assert_eq(prosess.native_async_vent(child, 5000)["status"], "ferdig")
        assert_eq(prosess.native_async_lukk(child)["status"], "ferdig")
        i = i + 1
    }
    skriv("test_native_process_async OK")
    returner 0
}

funksjon start() -> heiltall {
    la pure_vm: boolsk = usann
    prøv {
        builtin.vm_memory_status()
        pure_vm = sann
    } fang (e) {
    }
    hvis ikkje pure_vm {
        skriv("test_vm_security_disk_absolute_scope OK")
        returner 0
    }

    la root = miljo_hent("PWD")
    la dokument = fil_les(root + "/docs/STATUS.md")
    hvis lengde(dokument) == 0 { returner 1 }

    prøv {
        fil_les(root + "/README.md")
        returner 2
    } fang (e) {
        hvis lengde(e) == 0 { returner 3 }
    }

    skriv("test_vm_security_disk_absolute_scope OK")
    returner 0
}

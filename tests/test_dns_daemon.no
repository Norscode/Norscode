bruk std.dns som dns
bruk std.socket som socket

funksjon start() -> heiltall {
    la sone = dns.ny_sone("example.no")
    assert(dns.legg_a(sone, "@", "192.0.2.10"))
    la daemon = dns.daemon_ny(sone, "127.0.0.1", 0)
    la started = dns.daemon_start(daemon)
    assert(started)
    la client = socket.native_udp_tilkoble("127.0.0.1", heltall_fra_tekst(daemon["port"]))
    assert_eq(client["status"], "connected")
    la query = dns.wire_query("example.no", "A", 4242)
    la query_hex = dns._dns_hex(query)
    la decoded = dns._dns_hex_bytes(query_hex)
    la parsed = dns._dns_wire_query(decoded)
    assert_eq(parsed["status"], "ok")
    assert_eq(parsed["namn"], "example.no")
    la sent = socket.native_udp_skriv(client, query_hex, "", 0)
    assert_eq(sent["status"], "ok")
    la pumped = dns.daemon_pump(daemon)
    la tries: heiltall = 0
    mens pumped["status"] == "idle" og tries < 20 {
        pumped = dns.daemon_pump(daemon)
        tries = tries + 1
    }
    assert_eq(pumped["status"], "svart")
    assert_eq(pumped["owner"], "@")
    la ready = socket.native_poll_vent(client, 1, 100)
    assert_eq(ready["status"], "klar")
    la response = socket.native_udp_les(client, 4096)
    assert_eq(response["status"], "ok")
    assert(lengde(response["data_hex"]) > 24)
    assert(socket.native_lukk(client)["status"] == "closed")
    assert(dns.daemon_stop(daemon))

    la acme_sone = dns.ny_sone("norscode.test")
    assert(dns.legg_txt(acme_sone, "_acme-challenge", "dns01-value"))
    la acme_query = dns.wire_query("_acme-challenge.norscode.test", "TXT", 5252)
    la acme_parsed = dns._dns_wire_query(acme_query)
    assert_eq(acme_parsed["status"], "ok")
    assert_eq(acme_parsed["namn"], "_acme-challenge.norscode.test")
    la acme_response = dns.wire_authoritative_response(acme_sone, 5252,
        "_acme-challenge.norscode.test", "TXT")
    assert(lengde(acme_response) > lengde(acme_query))
    la acme_response_question = dns._dns_wire_query(acme_response)
    assert_eq(acme_response_question["namn"], "_acme-challenge.norscode.test")

    la tcp_daemon = dns.daemon_ny(acme_sone, "127.0.0.1", 0)
    assert(dns.daemon_start(tcp_daemon))
    la tcp_client = socket.native_tilkoble("127.0.0.1", heltall_fra_tekst(tcp_daemon["port"]))
    assert(tcp_client["status"] == "connected" eller tcp_client["status"] == "connecting")
    la connected = tcp_client["status"] == "connected"
    tries = 0
    mens ikkje connected og tries < 200 {
        dns.daemon_pump(tcp_daemon)
        la writable = socket.native_poll_vent(tcp_client, 2, 5)
        hvis writable["status"] == "klar" { connected = sann }
        tries = tries + 1
    }
    assert(connected)
    la framed_query: liste_heiltall = [lengde(acme_query) / 256, lengde(acme_query) % 256]
    dns._legg_bytes(framed_query, acme_query)
    la tcp_sent = socket.native_skriv_hex(tcp_client, dns._dns_hex(framed_query))
    assert_eq(tcp_sent["status"], "ok")
    la tcp_ready = usann
    tries = 0
    mens ikkje tcp_ready og tries < 200 {
        dns.daemon_pump(tcp_daemon)
        la readable = socket.native_poll_vent(tcp_client, 1, 5)
        hvis readable["status"] == "klar" { tcp_ready = sann }
        tries = tries + 1
    }
    assert(tcp_ready)
    la tcp_response = socket.native_les_hex(tcp_client, 4096)
    assert_eq(tcp_response["status"], "ok")
    assert(lengde(tcp_response["data_hex"]) > 4)
    la tcp_response_question = dns._dns_wire_query(
        dns._dns_hex_bytes(builtin.slice(tcp_response["data_hex"], 4, lengde(tcp_response["data_hex"]))))
    assert_eq(tcp_response_question["namn"], "_acme-challenge.norscode.test")
    assert(socket.native_lukk(tcp_client)["status"] == "closed" eller tcp_client["handle"] != "")
    assert(dns.daemon_stop(tcp_daemon))
    skriv("test_dns_daemon OK\n")
    returner 0
}

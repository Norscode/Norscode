bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/poplib.no")
    assert(t.inneholder(src, "Vanleg POP3 brukar Norscode socket først"))
    assert(t.inneholder(src, "POP3S/TLS"))
    assert(t.inneholder(src, "TLS-socket"))
    assert(ikkje t.inneholder(src, "curl-basert"))
    assert(t.inneholder(src, "funksjon _shell(verdi: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(verdi, \"'\""))
    assert(t.inneholder(src, "bruk std.socket som sok"))
    assert(t.inneholder(src, "funksjon _socket_pop(c: ordbok_tekst, kommando: tekst) -> tekst"))
    assert(t.inneholder(src, "sok.tilkoble(s, c[\"vert\"], heltall_fra_tekst(c[\"port\"]))"))
    assert(t.inneholder(src, "sok.send(s, innhald)"))
    assert(t.inneholder(src, "la ut = _socket_pop(c, \"STAT\")"))
    assert(t.inneholder(src, "la ut = _socket_pop(c, \"LIST\")"))
    assert(t.inneholder(src, "la rå = _socket_pop(c, \"RETR \" + tekst_fra_heltall(nummer))"))
    assert(t.inneholder(src, "la rå = _socket_pop(c, \"TOP \" + tekst_fra_heltall(nummer) + \" \" + tekst_fra_heltall(linjer))"))
    assert(t.inneholder(src, "la svar = _socket_pop(c, \"DELE \" + tekst_fra_heltall(nummer))"))
    assert(ikkje t.inneholder(src, "returner sann symbolsk"))
    assert(t.inneholder(src, "curl -s --connect-timeout 5 --max-time 5 \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 10 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "--request \" + _shell(kommando) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 15 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 15 --max-time 60 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(ikkje t.inneholder(src, "| head -1"))
    assert(ikkje t.inneholder(src, "-u \\\"\" + brukar"))
    assert(ikkje t.inneholder(src, "\\\" \" + url"))
    skriv("test_poplib_shell_quote OK")
    returner 0
}

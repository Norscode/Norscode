bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/fileinput.no")
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "cp \" + _shell(sti) + \" \" + _shell(sti + backup_ext)"))
    assert(ikkje t.inneholder(src, "cp \" + sti + \" \" + sti + backup_ext"))

    skriv("test_fileinput_shell_quote OK")
    returner 0
}

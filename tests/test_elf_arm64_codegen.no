bruk selfhost.native_execution.elf_arm64_codegen som codegen

funksjon start() -> heiltall {
    la ncb = {
        "entry": "__main__.start",
        "functions": {
            "__main__.start": {
                "params": [],
                "code": [["PUSH_CONST", 7], ["PUSH_CONST", 5], ["BINARY_ADD"], ["RETURN"]]
            }
        }
    }
    la sti = "/tmp/norscode_elf_arm64_codegen_" + builtin.random_hex(8)
    la resultat = codegen.kompiler_ncb(ncb, sti)
    assert_eq(resultat["ok"], "sann")
    assert_eq(resultat["format"], "ELF64 AArch64")
    assert_eq(resultat["image"][0], 0x7F)
    exec_prosess("rm -f '" + sti + "'")
    returner 0
}

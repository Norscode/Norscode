bruk std.model_runtime som modell
bruk std.model_registry som register
bruk std.qmodel_binary som qmodel
bruk std.model_trust som tillit

funksjon lag(navn: tekst, bias: heiltall) {
    la m = modell.ny(navn, 2)
    assert(modell.legg_til_lag(m, modell.dense(2, 1, [2, 3], [bias], 1, "ingen")))
    returner m
}

funksjon start() -> heiltall {
    la r = register.ny(2, 20)
    assert(register.registrer(r, lag("a", 1), "memory"))
    assert(register.registrer(r, lag("b", 2), "memory"))
    assert(ikkje register.registrer(r, lag("c", 3), "memory"))
    assert(register.finnes(r, "a"))
    la ut = register.inferer(r, "a", [4, 5])
    assert_eq(ut[0], 24)
    la s = register.statistikk(r)
    assert_eq(s["modellar"], "2")
    assert_eq(s["parametre"], "6")
    assert_eq(s["inferenservar"], "1")
    assert(register.avlast(r, "a"))
    assert(ikkje register.finnes(r, "a"))
    assert_eq(register.statistikk(r)["parametre"], "3")

    la trygg_modell = lag("c", 3)
    la data = qmodel.kod(trygg_modell)
    la tr = tillit.ny(1)
    assert(tillit.tillat(tr, "c-v1", tillit.hash_bytes(data)))
    assert(register.registrer_binær_verifisert(r, tr, "c-v1", data))
    assert(register.finnes(r, "c"))
    skriv("test_model_registry OK\n")
    returner 0
}

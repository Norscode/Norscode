funksjon svar(args: ordbok_tekst) -> tekst { returner "ok:" + args["verdi"] }
funksjon lag5(args: ordbok_tekst) -> tekst { returner builtin.ncb_call_fn("__main__.svar", args) }
funksjon lag4(args: ordbok_tekst) -> tekst { returner lag5(args) }
funksjon lag3(args: ordbok_tekst) -> tekst { returner lag4(args) }
funksjon lag2(args: ordbok_tekst) -> tekst { returner lag3(args) }
funksjon lag1(args: ordbok_tekst) -> tekst { returner lag2(args) }

funksjon start() -> heltall {
    la args: ordbok_tekst = {}
    args["verdi"] = "42"
    assert_eq(lag1(args), "ok:42")
    returner 0
}

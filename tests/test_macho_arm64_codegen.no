bruk selfhost.native_execution.macho_arm64_codegen som codegen

funksjon start() -> heiltall {
    la ok = codegen.kompiler_instruksjoner([["PUSH_CONST", 7], ["RETURN"]])
    assert_eq(ok["ok"], "sann")
    assert_eq(ok["format"], "Mach-O arm64")
    assert(lengde(ok["image"]) > 16384)
    assert_eq(ok["image"][0], 0xCF)
    assert_eq(ok["image"][1], 0xFA)
    assert_eq(codegen.kompiler_instruksjoner([["PUSH_CONST", 2147483648], ["RETURN"]])["ok"], "usann")
    assert_eq(codegen.kompiler_instruksjoner([["NOP"], ["RETURN"]])["ok"], "usann")
    la aritmetikk = codegen.kompiler_instruksjoner([
        ["PUSH_CONST", 9],
        ["PUSH_CONST", 3],
        ["BINARY_SUB"],
        ["PUSH_CONST", 7],
        ["BINARY_MUL"],
        ["PUSH_CONST", 6],
        ["BINARY_DIV"],
        ["PUSH_CONST", 5],
        ["BINARY_ADD"],
        ["RETURN"]
    ])
    assert_eq(aritmetikk["ok"], "sann")
    assert(lengde(aritmetikk["image"]) > 16384)
    assert_eq(codegen.kompiler_instruksjoner([["BINARY_ADD"], ["RETURN"]])["ok"], "usann")
    la vanlege_ops = codegen.kompiler_instruksjoner([
        ["PUSH_CONST", 10], ["PUSH_CONST", 15], ["BINARY_AND"],
        ["PUSH_CONST", 3], ["BINARY_XOR"], ["PUSH_CONST", 1], ["BINARY_LSHIFT"],
        ["PUSH_CONST", 1], ["BINARY_OR"], ["PUSH_CONST", 19], ["COMPARE_EQ"],
        ["UNARY_NOT"], ["UNARY_NOT"], ["PUSH_CONST", 99], ["POP"], ["RETURN"]
    ])
    assert_eq(vanlege_ops["ok"], "sann")
    assert_eq(codegen.kompiler_instruksjoner([["POP"], ["PUSH_CONST", 0], ["RETURN"]])["ok"], "usann")
    la lokale = codegen.kompiler_instruksjoner([
        ["PUSH_CONST", 9], ["STORE_NAME", "a"],
        ["PUSH_CONST", 3], ["STORE_NAME", "b"],
        ["LOAD_NAME", "a"], ["LOAD_NAME", "b"], ["BINARY_SUB"],
        ["PUSH_CONST", 7], ["BINARY_MUL"], ["RETURN"]
    ])
    assert_eq(lokale["ok"], "sann")
    assert_eq(codegen.kompiler_instruksjoner([["LOAD_NAME", "ikkje_definert"], ["RETURN"]])["ok"], "usann")
    la grein = codegen.kompiler_instruksjoner([
        ["PUSH_CONST", 0], ["STORE_NAME", "resultat"],
        ["PUSH_CONST", 9], ["PUSH_CONST", 3], ["COMPARE_GT"], ["JUMP_IF_FALSE", "elles"],
        ["PUSH_CONST", 23], ["STORE_NAME", "resultat"], ["JUMP", "ferdig"],
        ["LABEL", "elles"], ["PUSH_CONST", 99], ["STORE_NAME", "resultat"],
        ["LABEL", "ferdig"], ["LOAD_NAME", "resultat"], ["RETURN"]
    ])
    assert_eq(grein["ok"], "sann")
    assert_eq(codegen.kompiler_instruksjoner([["JUMP", "manglar"], ["PUSH_CONST", 0], ["RETURN"]])["ok"], "usann")
    la løkke = codegen.kompiler_instruksjoner([
        ["PUSH_CONST", 0], ["STORE_NAME", "i"],
        ["LABEL", "løkke"],
        ["LOAD_NAME", "i"], ["PUSH_CONST", 10], ["COMPARE_LT"], ["JUMP_IF_FALSE", "slutt"],
        ["LOAD_NAME", "i"], ["PUSH_CONST", 1], ["BINARY_ADD"], ["STORE_NAME", "i"],
        ["JUMP", "løkke"], ["LABEL", "slutt"], ["LOAD_NAME", "i"], ["RETURN"]
    ])
    assert_eq(løkke["ok"], "sann")
    la os = exec_prosess("uname -s")
    la arch = exec_prosess("uname -m")
    hvis os[0] == "0" og builtin.trim(os[1]) == "Darwin" og arch[0] == "0" og builtin.trim(arch[1]) == "arm64" {
        la sti = "/tmp/norscode_macho_arm64_codegen_" + builtin.random_hex(8)
        builtin.fil_skriv_binær(sti, aritmetikk["image"])
        assert_eq(exec_prosess("chmod +x '" + sti + "'")[0], "0")
        assert_eq(exec_prosess("'" + sti + "'")[0], "12")
        exec_prosess("rm -f '" + sti + "'")
        sti = "/tmp/norscode_macho_arm64_codegen_" + builtin.random_hex(8)
        builtin.fil_skriv_binær(sti, vanlege_ops["image"])
        assert_eq(exec_prosess("chmod +x '" + sti + "'")[0], "0")
        assert_eq(exec_prosess("'" + sti + "'")[0], "1")
        exec_prosess("rm -f '" + sti + "'")
        sti = "/tmp/norscode_macho_arm64_codegen_" + builtin.random_hex(8)
        builtin.fil_skriv_binær(sti, lokale["image"])
        assert_eq(exec_prosess("chmod +x '" + sti + "'")[0], "0")
        assert_eq(exec_prosess("'" + sti + "'")[0], "42")
        exec_prosess("rm -f '" + sti + "'")
        sti = "/tmp/norscode_macho_arm64_codegen_" + builtin.random_hex(8)
        builtin.fil_skriv_binær(sti, grein["image"])
        assert_eq(exec_prosess("chmod +x '" + sti + "'")[0], "0")
        assert_eq(exec_prosess("'" + sti + "'")[0], "23")
        exec_prosess("rm -f '" + sti + "'")
        sti = "/tmp/norscode_macho_arm64_codegen_" + builtin.random_hex(8)
        builtin.fil_skriv_binær(sti, løkke["image"])
        assert_eq(exec_prosess("chmod +x '" + sti + "'")[0], "0")
        assert_eq(exec_prosess("'" + sti + "'")[0], "10")
        exec_prosess("rm -f '" + sti + "'")
    }
    returner 0
}

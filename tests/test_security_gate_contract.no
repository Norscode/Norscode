bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la security = fil_les("std/security.no")
    la auth = fil_les("std/auth.no")
    la csrf = fil_les("std/csrf.no")
    la secrets = fil_les("std/secrets.no")
    la web = fil_les("std/web.no")
    la sesjon = fil_les("std/sesjon.no")
    la mw = fil_les("std/mw.no")
    la deploy = fil_les("std/deploy.no")
    la admin = fil_les("std/admin.no")
    la status = fil_les("std/stdlib_status.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(security, "funksjon standard_krav() -> liste<tekst>")
    krev(security, "\"auth\"")
    krev(security, "\"session\"")
    krev(security, "\"csrf\"")
    krev(security, "\"security_headers\"")
    krev(security, "\"secure_cookies\"")
    krev(security, "\"random_hex\"")
    krev(security, "\"admin_panel\"")
    krev(security, "\"strict_cors\"")
    krev(security, "funksjon produksjon_klar(konfig: ordbok_tekst) -> bool")
    krev(security, "funksjon cookie_er_sikker(cookie: tekst) -> bool")
    krev(security, "funksjon headers_er_sikre(headers: ordbok_tekst) -> bool")
    krev(security, "funksjon headers_er_strenge(headers: ordbok_tekst) -> bool")
    krev(security, "funksjon sikkerhetsheaders_standard() -> ordbok_tekst")
    krev(security, "\"strict-transport-security\"")
    krev(security, "\"content-security-policy\"")
    krev(security, "\"permissions-policy\"")

    krev(auth, "Svake fallbackar skal ikkje brukast for auth.")
    krev(auth, "kast \"auth krev builtin.sha256\"")
    krev(auth, "kast \"auth krev builtin.random_hex\"")
    krev(auth, "funksjon sikkerheitsstatus() -> ordbok_tekst")

    krev(csrf, "funksjon generer_token() -> tekst")
    krev(csrf, "bruk std.web som web")
    krev(csrf, "builtin.random_hex(32)")
    krev(csrf, "funksjon konstant_lik(a: tekst, b: tekst) -> bool")
    krev(csrf, "web.request_header(ctx, \"x-csrf-token\")")
    krev(csrf, "expected != \"\" og konstant_lik(tok, expected)")

    krev(secrets, "funksjon generer_salt() -> tekst")
    krev(secrets, "builtin.random_hex(16)")
    krev(secrets, "kast \"secrets krev builtin.sha256\"")
    krev(secrets, "funksjon passord_hash_ny(passord: tekst) -> tekst")
    krev(secrets, "funksjon krev_hemmelighet(nokkel: tekst) -> tekst")
    krev(secrets, "funksjon passord_policy_ok(passord: tekst) -> bool")

    krev(web, "funksjon response_finalize_strict_cors(ctx: ordbok_tekst, response: ordbok_tekst, tillatne_origins: tekst) -> ordbok_tekst")
    krev(web, "funksjon response_finalize_strict(ctx: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst")
    krev(web, "response_finalize_strict(ctx, response)")
    krev(web, "funksjon _origin_er_tillaten(origin: tekst, tillatne: tekst) -> boolsk")
    krev(web, "headers[\"access-control-allow-origin\"] = \"\"")

    krev(sesjon, "funksjon sett_cookie_sikker(resp: ordbok_tekst, token: tekst, ttl_sek: heltall) -> ordbok_tekst")
    krev(sesjon, "session=; HttpOnly; Secure; SameSite=Lax; Path=/; Max-Age=0")
    krev(sesjon, "secure_flag: \"standardisert\"")

    krev(mw, "funksjon _konstant_lik_mw(a: tekst, b: tekst) -> boolsk")
    krev(mw, "funksjon rate_cfg_strict(maks_per_minutt: heltall, nøkkel_type: tekst) -> ordbok_tekst")
    krev(mw, "c[\"strict\"] = \"sann\"")
    krev(mw, "hvis har_nokkel(cfg, \"strict\") og cfg[\"strict\"] == \"sann\"")
    krev(mw, "web.request_header(ctx, \"x-csrf-token\")")
    krev(mw, "returner _konstant_lik_mw(token_header, token_cookie)")

    krev(deploy, "la helse_sti: tekst = tekst(c[\"helse_sti\"])")
    krev(deploy, "http://localhost:\" + port + helse_sti")

    krev(admin, "funksjon admin_status(register: ordbok_tekst) -> ordbok_tekst")
    krev(admin, "handle_lagre_sikker")
    krev(admin, "handle_slett_sikker")
    krev(admin, "\"strict-transport-security\"")
    krev(admin, "\"content-security-policy\"")
    krev(admin, "\"permissions-policy\"")
    krev(admin, "script-src 'none'")
    krev(admin, "frame-ancestors 'none'")
    krev(admin, "funksjon _admin_redirect(location: tekst) -> ordbok_tekst")
    krev(admin, "funksjon admin_lagre_audit(ctx: ordbok_tekst, tabell: tekst, rad_id: tekst) -> ordbok_tekst")
    krev(admin, "funksjon admin_slett_audit(ctx: ordbok_tekst, tabell: tekst, id: heltall) -> ordbok_tekst")

    krev(status, "modul(\"security\", \"stabil\"")
    krev(manual, "`std.security`: samla sikkerheitsgate")
    krev(manual, "Streng web-finalisering")

    skriv("test_security_gate_contract OK")
    returner 0
}

bruk selfhost.vm

funksjon køyr(code: liste) {
    la functions = {"__main__.probe": {"params": [], "code": code}}
    returner køyr_funksjon("__main__.probe", [], functions, 0)
}

funksjon start() -> heiltall {
    assert_eq(kall_innebygd("builtin.heltall", ["42"], {}), 42)
    assert_eq(kall_innebygd("builtin.heltall", [sann], {}), 1)
    assert_eq(køyr([["PUSH_CONST", 6], ["PUSH_CONST", 3], ["BINARY_AND"], ["RETURN"]]), 2)
    assert_eq(køyr([["PUSH_CONST", 6], ["PUSH_CONST", 3], ["BINARY_OR"], ["RETURN"]]), 7)
    assert_eq(køyr([["PUSH_CONST", 6], ["PUSH_CONST", 3], ["BINARY_XOR"], ["RETURN"]]), 5)
    assert_eq(køyr([["PUSH_CONST", 3], ["PUSH_CONST", 2], ["BINARY_LSHIFT"], ["RETURN"]]), 12)
    assert_eq(køyr([["PUSH_CONST", 12], ["PUSH_CONST", 2], ["BINARY_RSHIFT"], ["RETURN"]]), 3)
    assert_eq(køyr([["PUSH_CONST", 1], ["UNARY_BNOT"], ["RETURN"]]), -2)

    assert_eq(køyr([["PUSH_CONST", 1], ["PUSH_CONST", 2], ["DUP"], ["BINARY_ADD"], ["BINARY_ADD"], ["RETURN"]]), 5)
    assert_eq(køyr([["PUSH_CONST", 2], ["PUSH_CONST", 5], ["SWAP"], ["BINARY_SUB"], ["RETURN"]]), 3)
    assert_eq(køyr([["PUSH_CONST", 2], ["PUSH_CONST", 3], ["OVER"], ["BINARY_ADD"], ["BINARY_MUL"], ["RETURN"]]), 10)
    returner 0
}

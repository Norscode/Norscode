funksjon dynamisk(args: ordbok_tekst) -> heiltall {
    la n = heltall_fra_tekst(args["n"])
    hvis n <= 0 { returner 0 }
    la neste: ordbok_tekst = {}
    neste["n"] = tekst_fra_heltall(n - 1)
    returner builtin.ncb_call_fn("__main__.dynamisk", neste) + 1
}

funksjon start() -> heiltall {
    la args: ordbok_tekst = {}
    args["n"] = "600"
    assert_eq(builtin.ncb_call_fn("__main__.dynamisk", args), 600)
    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["dynamic_calls"]) >= 601)
    assert(heltall_fra_tekst(metrics["max_depth"]) > 500)
    returner 0
}

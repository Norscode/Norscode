bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/prosess.no")
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "which \" + _shell(namn)"))
    assert(t.inneholder(src, "builtin.exec_prosess(\"true\")"))
    assert(t.inneholder(src, "Prosesskøyring krev builtin.exec_prosess; PID, miljø og katalogbytte brukar"))
    assert(t.inneholder(src, "builtin.prosess_pid()"))
    assert(t.inneholder(src, "builtin.prosess_ppid()"))
    assert(t.inneholder(src, "builtin.chdir(sti)"))
    assert(ikkje t.inneholder(src, "which \" + namn"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess(\"echo ok\")"))
    assert(ikkje t.inneholder(src, "# Krev builtin.exec_prosess i kompilatoren."))

    skriv("test_prosess_shell_quote OK")
    returner 0
}

bruk std.tekst som t

funksjon krev_fil_skriv(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.fil_skriv"))
}

funksjon start() -> heiltall {
    krev_fil_skriv("tools/verify_seed_only.no")
    krev_fil_skriv("tools/fetch_stage0_seed.no")
    krev_fil_skriv("tools/build_norscode_native.no")
    krev_fil_skriv("tools/nc_regen_bootstrap.no")
    krev_fil_skriv("tools/build_linux_native_candidate_v3005.no")

    la samla = fil_les("tools/verify_seed_only.no") +
        fil_les("tools/fetch_stage0_seed.no") +
        fil_les("tools/build_norscode_native.no") +
        fil_les("tools/nc_regen_bootstrap.no") +
        fil_les("tools/build_linux_native_candidate_v3005.no")

    assert(ikkje t.inneholder(samla, "printf 'funksjon start() { returner 0 }"))
    assert(ikkje t.inneholder(samla, "printf 'funksjon start() { skriv(\\\"regen OK\\\") }"))
    assert(ikkje t.inneholder(samla, "printf '%s' $$"))
    assert(ikkje t.inneholder(samla, "printf '%s' \" + shell(json)"))
    assert(ikkje t.inneholder(samla, "printf '%s' \" + shell(body)"))
    assert(t.inneholder(fil_les("tools/verify_seed_only.no"), "builtin.fil_finnes(sti)"))
    assert(ikkje t.inneholder(fil_les("tools/verify_seed_only.no"), "test -f \" + shell(sti)"))
    la linux_candidate = fil_les("tools/build_linux_native_candidate_v3005.no")
    assert(t.inneholder(linux_candidate, "tools/build_native_candidate_v3002.no"))
    assert(t.inneholder(linux_candidate, "NORSCODE_NATIVE_GAP_BIN="))
    assert(t.inneholder(linux_candidate, "/bin/nc"))
    assert(t.inneholder(linux_candidate, "tools/native_runtime_gap_gate_v3001.no"))
    assert(ikkje t.inneholder(linux_candidate, "build_native_candidate_v3002.sh"))
    assert(ikkje t.inneholder(linux_candidate, "bash \" + shell(root + \"/tools/native_runtime_gap_gate_v3001.sh\")"))
    assert(ikkje t.inneholder(linux_candidate, "gate=tools/native_runtime_gap_gate_v3001.sh"))

    skriv("test_seed_smoke_writers_no_printf OK")
    returner 0
}

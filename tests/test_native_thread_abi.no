bruk std.runtime.thread_abi som abi

funksjon start() -> heiltall {
    la spawn = abi.spawn_request("app.worker", {"job": "1"}, "worker-1", 65536)
    assert_eq(spawn["abi"], "norscode-native-thread-v1")
    assert(abi.gyldig_request(spawn))
    assert(ikkje abi.gyldig_request(abi.spawn_request("", {}, "x", 65536)))
    assert(ikkje abi.gyldig_request(abi.spawn_request("app.worker", {}, "x", 1024)))

    assert(abi.gyldig_request(abi.sync_request("join", "h1", "t1", 1000)))
    assert(abi.gyldig_request(abi.sync_request("mutex_lock", "m1", "t1", -1)))
    assert(abi.gyldig_request(abi.sync_request("condition_broadcast", "c1", "t1", 0)))
    assert(abi.gyldig_request(abi.resource_request("mutex_create", "", "", 0)))
    assert(abi.gyldig_request(abi.resource_request("condition_create", "", "", 0)))
    assert(abi.gyldig_request(abi.resource_request("condition_wait", "c1", "m1", 1000)))
    assert(ikkje abi.gyldig_request(abi.resource_request("condition_wait", "c1", "", 1000)))
    assert(abi.gyldig_request(abi.signal_request("signal_block", ["USR1"])))
    assert(abi.gyldig_request(abi.signal_request("signal_query", ["USR1", "TERM"])))
    assert(ikkje abi.gyldig_request(abi.sync_request("unknown", "h1", "t1", 0)))

    assert(abi.gyldig_resultat(abi.resultat("started", "h1", "t1", "", "")))
    assert(abi.gyldig_resultat(abi.resultat("timeout", "h1", "t1", "", "timeout")))
    assert(ikkje abi.gyldig_resultat(abi.resultat("started", "", "", "", "")))
    returner 0
}

funksjon start() -> heltall {
    la behold: liste<ordbok_tekst> = []
    la i: heltall = 0
    mens i < 80 {
        la obj: ordbok_tekst = {}
        obj["id"] = tekst_fra_heltall(i)
        legg_til(behold, obj)
        i = i + 1
    }
    la readme = builtin.fil_les("README.md")
    assert(lengde(readme) > 0)

    la m = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(m["instructions"]) > 0)
    assert(heltall_fra_tekst(m["calls"]) > 0)
    assert(heltall_fra_tekst(m["builtin_calls"]) > 0)
    assert(heltall_fra_tekst(m["filesystem_calls"]) > 0)
    assert(heltall_fra_tekst(m["io_calls"]) > 0)
    assert(heltall_fra_tekst(m["gc_safe_points"]) > 0)
    assert(heltall_fra_tekst(m["gc_collections"]) > 0)
    assert(heltall_fra_tekst(m["gc_pause_ms"]) >= 0)
    assert(heltall_fra_tekst(m["wall_ms"]) >= 0)
    assert(heltall_fra_tekst(m["instructions_per_ms"]) >= 0)
    returner 0
}

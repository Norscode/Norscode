bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/smtplib.no")
    assert(t.inneholder(src, "enkel SMTP-dialog via Norscode socket"))
    assert(t.inneholder(src, "Sendmail og curl finst som eksplisitte OS-/TLS-reservevegar"))
    assert(t.inneholder(src, "Send via lokal sendmail-reserveveg"))
    assert(t.inneholder(src, "Send via curl/SMTP-reserveveg"))
    assert(t.inneholder(src, "Lag kortlevd meldingsfil for sendmail-reservevegen"))
    assert(ikkje t.inneholder(src, "SMTP via curl og enkel Norscode-socket-dialog"))
    assert(ikkje t.inneholder(src, "tryggare enn rå socket"))
    assert(ikkje t.inneholder(src, "Lag midlertidig fil med meldinga"))
    assert(t.inneholder(src, "bruk std.socket som sok"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon _shell_liste(verdiar: liste_tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon _har_kontrollteikn(verdi: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon _trygg_header_namn(namn: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon _trygg_header_verdi(verdi: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon _trygg_adresse(adresse: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon _trygg_melding(msg: ordbok_tekst) -> bool"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "hvis ikkje _trygg_header_namn(namn) { returner }"))
    assert(t.inneholder(src, "hvis ikkje _trygg_adresse(adresse) { returner }"))
    assert(t.inneholder(src, "hvis ikkje _trygg_lokal_sti(filsti) { returner }"))
    assert(t.inneholder(src, "hvis ikkje _trygg_melding(msg) { returner usann }"))
    assert(t.inneholder(src, "hvis _har_kontrollteikn(kommandoar[ki]) { returner \"\" }"))
    assert(t.inneholder(src, "hvis _trygg_header_namn(nk) og _trygg_header_verdi(headers[nk])"))
    assert(t.inneholder(src, "la mott_str: tekst = _shell_liste(mottakarar)"))
    assert(t.inneholder(src, "sendmail -f \" + _shell(msg[\"avsender\"])"))
    assert(t.inneholder(src, "\" < \" + _shell(tmp_fil)"))
    assert(t.inneholder(src, "rm -f \" + _shell(tmp_fil)"))
    assert(t.inneholder(src, "mott_arg = mott_arg + \" --mail-rcpt \" + _shell(mottakarar[i])"))
    assert(t.inneholder(src, "curl \" + _shell(url)"))
    assert(t.inneholder(src, "--mail-from \" + _shell(msg[\"avsender\"])"))
    assert(t.inneholder(src, "-u \" + _shell(brukarnamn + \":\" + passord)"))
    assert(t.inneholder(src, "--upload-file \" + _shell(tmp_fil)"))
    assert(t.inneholder(src, "sok.set_timeout(s, 2000)"))
    assert(t.inneholder(src, "sok.tilkoble(s, vert, port)"))
    assert(t.inneholder(src, "sok.send(s, innhald)"))
    assert(t.inneholder(src, "sok.motta(s, 8192)"))

    assert(ikkje t.inneholder(src, "builtin.join(mottakarar, \" \")"))
    assert(ikkje t.inneholder(src, "sendmail -f \" + msg[\"avsender\"]"))
    assert(ikkje t.inneholder(src, "\" < \" + tmp_fil"))
    assert(ikkje t.inneholder(src, "rm -f \" + tmp_fil"))
    assert(ikkje t.inneholder(src, "--mail-rcpt \" + mottakarar[i]"))
    assert(ikkje t.inneholder(src, "-u \" + brukarnamn"))
    assert(ikkje t.inneholder(src, "--upload-file \" + tmp_fil"))
    assert(ikkje t.inneholder(src, "nc -q 1 \" + vert"))
    assert(ikkje t.inneholder(src, "nc -q 1 \" + _shell(vert)"))
    assert(ikkje t.inneholder(src, "\" < \" + cmd_fil"))
    assert(ikkje t.inneholder(src, "rm -f \" + cmd_fil"))
    assert(ikkje t.inneholder(src, "rm -f \" + _shell(cmd_fil)"))

    skriv("test_smtplib_shell_quote OK")
    returner 0
}

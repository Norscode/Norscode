funksjon serve_handle_one(ncb, rå)
    returner "HTTP/1.1 500 Internal Server Error\r\nX-Error-Mw: ja\r\nboom\r\n"
slutt

funksjon start() -> heiltall {
    la ncb: ordbok<tekst, tekst> = {
        "route_handlers": [],
        "functions": {}
    }

    la resp = serve_handle_one(ncb, "GET /krasj HTTP/1.1\r\n\r\n")
    assert_eq(builtin.starts_with(resp, "HTTP/1.1 500 Internal Server Error"), sann)
    assert_eq(builtin.contains(resp, "X-Error-Mw: ja"), sann)
    assert_eq(builtin.contains(resp, "boom"), sann)
    returner 0
}

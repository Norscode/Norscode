bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/nc_regen_bootstrap.no")
    la cli = fil_les("bin/nc")

    assert(t.inneholder(src, "funksjon normaliser_ncb(root: tekst, nc: tekst, sti: tekst) -> bool"))
    assert(t.inneholder(src, "NORSCODE_NCB_NORMALIZE_IN="))
    assert(t.inneholder(src, "NORSCODE_NCB_NORMALIZE_OUT="))
    assert(t.inneholder(src, "tools/ncb_normalize_builtin_aliases_v802.no"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(t.inneholder(src, "Oppdaterer VM-precompiled NCB"))
    assert(t.inneholder(src, "compile selfhost/vm.no bootstrap/precompiled/vm.ncb.json"))
    assert(t.inneholder(src, "normaliser_ncb(root, nc, root + \"/bootstrap/precompiled/vm.ncb.json\")"))
    assert(t.inneholder(cli, "regen-bootstrap|bootstrap-regen)"))
    assert(t.inneholder(cli, "bruk: nc regen-bootstrap [--full]"))
    assert(t.inneholder(cli, "NORSCODE_REGEN_BOOTSTRAP_FULL=\"$_regen_full\""))
    assert(t.inneholder(cli, "sh \"$ROOT_DIR/tools/nc_regen_bootstrap.sh\" --full"))

    skriv("test_regen_bootstrap_vm_host_compat OK")
    returner 0
}

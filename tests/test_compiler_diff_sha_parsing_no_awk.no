bruk std.tekst som t

funksjon sjekk(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon første_ord"))
    assert(t.inneholder(src, "returner første_ord(res_felt(kommando(\"shasum -a 256 "))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(src, "| awk"))
}

funksjon start() -> heiltall {
    sjekk("tools/compare_compilers.no")
    sjekk("tools/bootstrap_diff_analyzer.no")
    la compare = fil_les("tools/compare_compilers.no")
    la compare_wrapper = fil_les("tools/compare_compilers.sh")
    assert(t.inneholder(compare, "NORSCODE_COMPILER_A=<compiler_a> NORSCODE_COMPILER_B=<compiler_b> ./bin/nc run tools/compare_compilers.no"))
    assert(ikkje t.inneholder(compare, "compare_compilers.sh <"))
    assert(t.inneholder(compare_wrapper, "NORSCODE_COMPILER_A=<compiler_a> NORSCODE_COMPILER_B=<compiler_b> ./bin/nc run tools/compare_compilers.no"))
    assert(ikkje t.inneholder(compare_wrapper, "Usage: compare_compilers.sh"))
    assert(ikkje t.inneholder(compare_wrapper, "compare_compilers.sh <"))
    assert(ikkje t.inneholder(compare_wrapper, "awk"))
    assert(ikkje t.inneholder(fil_les("tools/bootstrap_diff_analyzer.sh"), "awk"))
    skriv("test_compiler_diff_sha_parsing_no_awk OK")
    returner 0
}

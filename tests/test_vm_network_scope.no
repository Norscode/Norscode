funksjon start() -> heiltall {
    la pure = sann
    prøv { builtin.vm_memory_status() } fang (e) { pure = usann }
    hvis ikkje pure { returner 0 }

    la denied = ""
    prøv {
        builtin.network_operation({"abi": "norscode-native-network-v1", "operation": "listen", "host": "0.0.0.0", "port": "0", "backlog": "1"})
        returner 1
    } fang (e) { denied = tekst(e) }
    assert_inneholder(denied, "network scope")

    la allowed = builtin.network_operation({"abi": "norscode-native-network-v1", "operation": "listen", "host": "127.0.0.1", "port": "0", "backlog": "1"})
    assert_eq(allowed["status"], "listening")
    assert_eq(builtin.network_operation({"abi": "norscode-native-network-v1", "operation": "close", "handle": allowed["handle"]})["status"], "closed")
    skriv("test_vm_network_scope OK")
    returner 0
}

bruk std.media_local som lokal
bruk std.media_job som jobb

funksjon start() -> heiltall {
    la b = lokal.bilde("nordlys", "build/test_media_local.ppm", 4, 3)
    assert_eq(b["ok"], "sann")
    assert_eq(b["mime"], "image/x-portable-pixmap")
    assert(heltall_fra_tekst(b["bytes"]) > 36)

    la l = lokal.lyd("signal", "build/test_media_local.wav", 50, 440)
    assert_eq(l["ok"], "sann")
    assert_eq(heltall_fra_tekst(l["bytes"]), 444)

    la m = lokal.musikk("nordisk tema", "build/test_media_local_music.wav", 100, 220)
    assert_eq(m["ok"], "sann")
    assert_eq(heltall_fra_tekst(m["bytes"]), 844)

    la v = lokal.video("bevegelse", "build/test_media_local.y4m", 4, 4, 2, 2)
    assert_eq(v["ok"], "sann")
    assert_eq(v["mime"], "video/x-yuv4mpeg2")

    la j = jobb.ny("lokal-1", "bilde", "nordlys", "norscode-procedural-v1", 0, 1000)
    assert(lokal.fullfor_jobb(j, b, 10))
    assert_eq(j["status"], "ferdig")
    skriv("test_media_local OK\n")
    returner 0
}

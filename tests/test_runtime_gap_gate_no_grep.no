bruk std.tekst som t

funksjon krev_filbasert_inneheld(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon inneheld"))
    assert(t.inneholder(src, "builtin.fil_les(out)"))
    assert(t.inneholder(src, "builtin.index_of"))
    assert(t.inneholder(src, "builtin.fil_finnes(sti)"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(ikkje t.inneholder(src, "grep -q "))
    assert(ikkje t.inneholder(src, "test -x "))
}

funksjon start() -> heiltall {
    krev_filbasert_inneheld("tools/native_runtime_gap_gate_v3001.no")
    krev_filbasert_inneheld("tools/native_runtime_gap_pure_vm_gate_v3002.no")
    krev_filbasert_inneheld("tools/native_runtime_gap_cli_gate_v3004.no")
    krev_filbasert_inneheld("tools/native_runtime_gap_promotion_readiness_v3003.no")

    la readiness = fil_les("tools/native_runtime_gap_promotion_readiness_v3003.no")
    assert(t.inneholder(readiness, "builtin.fil_skriv(sti, innhald)"))
    assert(t.inneholder(readiness, "tools/native_runtime_gap_pure_vm_gate_v3002.no"))
    assert(t.inneholder(readiness, "tools/native_runtime_gap_cli_gate_v3004.no"))
    assert(t.inneholder(readiness, "tools/native_runtime_gap_gate_v3001.no"))
    assert(t.inneholder(readiness, "NORSCODE_NATIVE_GAP_BIN="))
    assert(ikkje t.inneholder(readiness, "kommando(\"cat "))
    assert(ikkje t.inneholder(readiness, "printf '%s'"))
    assert(ikkje t.inneholder(readiness, "native_runtime_gap_pure_vm_gate_v3002.sh"))
    assert(ikkje t.inneholder(readiness, "native_runtime_gap_cli_gate_v3004.sh"))
    assert(ikkje t.inneholder(readiness, "native_runtime_gap_gate_v3001.sh"))

    skriv("test_runtime_gap_gate_no_grep OK")
    returner 0
}

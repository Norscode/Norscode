bruk std.tekst som t

funksjon krev_logg_lesing(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.fil_les(log)"))
    assert(t.inneholder(src, "builtin.index_of(builtin.fil_les("))
    assert(ikkje t.inneholder(src, "kommando(\"cat \" + shell(log))"))
}

funksjon krev_basename(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "bruk std.path som path"))
    assert(t.inneholder(src, "path.basename(src)"))
    assert(ikkje t.inneholder(src, "kommando(\"basename "))
}

funksjon krev_direkte_binding(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
}

funksjon start() -> heiltall {
    krev_logg_lesing("tools/run_runtime_basics_phase_v4200.no")
    krev_logg_lesing("tools/run_selfhost_compile_phase_v4400.no")
    krev_logg_lesing("tools/run_ir_bytecode_phase_v4600.no")

    krev_basename("tools/run_selfhost_compile_phase_v4400.no")
    krev_basename("tools/run_ir_bytecode_phase_v4600.no")
    krev_direkte_binding("tools/run_runtime_basics_phase_v4200.no")
    krev_direkte_binding("tools/run_selfhost_compile_phase_v4400.no")
    krev_direkte_binding("tools/run_ir_bytecode_phase_v4600.no")

    la selfhost = fil_les("tools/run_selfhost_compile_phase_v4400.no")
    assert(ikkje t.inneholder(selfhost, "kommando(\"grep -Eq"))
    assert(t.inneholder(selfhost, "for src i files()"))
    assert(t.inneholder(selfhost, "linux_stage0_parser_error.log"))
    assert(ikkje t.inneholder(selfhost, "base=$(basename"))
    assert(ikkje t.inneholder(selfhost, "cat /tmp/${base}.compile.log"))
    assert(ikkje t.inneholder(selfhost, "grep -q '\\\"entry\\\"'"))
    assert(ikkje t.inneholder(selfhost, "printf '[OK] linux_stage0 compile"))
    assert(ikkje t.inneholder(selfhost, "grep -Eq 'Parserfeil"))

    la runtime = fil_les("tools/run_runtime_basics_phase_v4200.no")
    assert(t.inneholder(runtime, "/work/build/v4200/linux_stage0_runtime_basics.log"))
    assert(ikkje t.inneholder(runtime, "cat /tmp/runtime_basics.log"))
    assert(ikkje t.inneholder(runtime, "grep -q 'trim OK:'"))
    assert(ikkje t.inneholder(runtime, "printf '[OK] linux_stage0 runtime basics"))

    la ir = fil_les("tools/run_ir_bytecode_phase_v4600.no")
    assert(t.inneholder(ir, "/work/build/v4600/linux_stage0_runtime.log"))
    assert(t.inneholder(ir, "for src i files()"))
    assert(ikkje t.inneholder(ir, "base=$(basename"))
    assert(ikkje t.inneholder(ir, "cat \"$log\""))
    assert(ikkje t.inneholder(ir, "cat /tmp/linux_v4600_runtime.log"))
    assert(ikkje t.inneholder(ir, "grep -q 'ir bytecode runtime v4600'"))
    assert(ikkje t.inneholder(ir, "printf '[OK] linux_stage0 runtime fixture"))

    skriv("test_phase_host_log_ops_no_shell OK")
    returner 0
}

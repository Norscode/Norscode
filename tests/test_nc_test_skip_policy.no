bruk std.tekst som t

funksjon tel(haystack: tekst, needle: tekst) -> heiltall {
    returner lengde(builtin.split(haystack, needle)) - 1
}

funksjon start() -> heiltall {
    la src = fil_les("tools/nc_test.no")

    assert(t.inneholder(src, "funksjon er_tung_sjølvhost(namn: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon er_slow(namn: tekst) -> bool"))
    assert(t.inneholder(src, "returner er_tung_sjølvhost(namn)"))
    assert(t.inneholder(src, "hvis er_tung_sjølvhost(namn) { returner sann }"))

    assert(tel(src, "\"test_chunk_2000.no\"") == 1)
    assert(tel(src, "\"test_chunk_end.no\"") == 1)
    assert(tel(src, "\"test_chunk_full.no\"") == 1)
    assert(tel(src, "\"test_chunk_tail.no\"") == 1)
    assert(tel(src, "\"test_selfhost.no\"") == 1)

    assert(t.inneholder(src, "hvis slow_mode og ikkje er_slow(namn)"))
    assert(t.inneholder(src, "hvis ikkje slow_mode og er_slow(namn)"))
    assert(t.inneholder(src, "hvis er_native_unsupported(namn)"))
    assert(t.inneholder(src, "bruk std.liste som liste"))
    assert(t.inneholder(src, "liste.sorter_tekst(ut)"))
    assert(t.inneholder(src, "funksjon hybrid_compile_cmd(root: tekst, hybrid: tekst, test_fil: tekst, ncb: tekst) -> tekst"))
    assert(t.inneholder(src, "NORSCODE_HYBRID_SRC="))
    assert(t.inneholder(src, "root + \"/bin/nc\") + \" run \" + shell(hybrid)"))
    assert(t.inneholder(src, "root + \"/tools/compile_with_hybrid_bundle_v9400.no\""))
    assert(ikkje t.inneholder(src, "hvis hybrid == \"\" { hybrid = root + \"/tools/compile_with_hybrid_bundle_v9400.sh\" }"))
    assert(ikkje t.inneholder(src, "test_*.no' | sort"))

    la wrapper = fil_les("tools/nc_test.sh")
    assert(t.inneholder(wrapper, "find_test_files() {"))
    assert(t.inneholder(wrapper, "NC_TEST_FILES=\"$(find_test_files \""))
    assert(ikkje t.inneholder(wrapper, "| sort"))
    assert(t.inneholder(wrapper, "_is_heavy_selfhost() {"))
    assert(t.inneholder(wrapper, "_is_heavy_selfhost \"$1\""))
    assert(t.inneholder(wrapper, "if _is_heavy_selfhost \"$1\"; then"))

    assert(tel(wrapper, "test_chunk_2000.no") == 1)
    assert(tel(wrapper, "test_chunk_end.no") == 1)
    assert(tel(wrapper, "test_chunk_full.no") == 1)
    assert(tel(wrapper, "test_chunk_tail.no") == 1)
    assert(tel(wrapper, "test_selfhost.no") == 1)

    skriv("test_nc_test_skip_policy OK")
    returner 0
}

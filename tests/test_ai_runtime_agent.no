bruk std.ai som ai

funksjon search(args: ordbok_tekst) -> tekst {
    returner "found:" + args["query"]
}

funksjon fail_tool(args: ordbok_tekst) -> tekst { kast "ToolError: planlagt" }

funksjon start() -> heiltall {
    la rt = ai.runtime_ny(ai.lokal("norscode-local-1"), 2, 4)
    assert(ai.runtime_registrer_verktøy(rt, "search", "Søk lokalt", "__main__.search", "ai.tool"))
    assert(ai.runtime_registrer_verktøy(rt, "fail", "Feiltest", "__main__.fail_tool", ""))
    assert_eq(rt["tool_count"], "2")

    la args: ordbok_tekst = {"query": "runtime"}
    la denied = ai.runtime_kjør_verktøy(rt, "search", args, "")
    assert_eq(denied["ok"], "usann")
    assert_inneholder(denied["error"], "ai.tool")

    la allowed = ai.runtime_kjør_verktøy(rt, "search", args, "ai.tool")
    assert_eq(allowed["ok"], "sann")
    assert_eq(allowed["result"], "found:runtime")

    la agent = ai.agent_kjør(rt, "bruk search", args, "ai.tool")
    assert_eq(agent["ok"], "sann")
    assert_eq(agent["tool"], "search")
    assert_eq(agent["result"], "found:runtime")
    assert_eq(tekst(agent["steps_used"]), tekst(1))
    assert_eq(rt["audit_count"], "2")

    la failed = ai.runtime_kjør_verktøy(rt, "fail", {}, "")
    assert_eq(failed["ok"], "usann")
    assert_inneholder(failed["error"], "ToolError")

    la memory = rt["memory"]
    ai.minne_lagre(memory, "first", "one")
    ai.minne_lagre(memory, "second", "two")
    ai.minne_lagre(memory, "third", "three")
    assert_eq(memory["count"], "2")
    assert_eq(lengde(ai.minne_søk(memory, "first", 10)), 0)
    assert_eq(lengde(ai.minne_søk(memory, "three", 10)), 1)

    la st = ai.status()
    assert_eq(st["memory"], "sann")
    assert_eq(st["tool_execution"], "sann")
    assert_eq(ai.produksjonsstatus()["status"], "stabil")
    returner 0
}

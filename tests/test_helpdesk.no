bruk std.web som web
bruk std.json som json
bruk std.tekst som t
bruk examples.helpdesk som helpdesk

funksjon har_nokkel(data, nøkkel) -> bool {
    hvis data == null {
        returner usann
    }
    returner data[nøkkel] != null
}

funksjon assert_status(respons: ordbok_tekst, forventet: heiltall) {
    assert_eq(web.response_status(respons), forventet)
}

funksjon assert_json_felt(respons: ordbok_tekst, felt: tekst) -> tekst {
    la body = web.response_body(respons)
    la parsed = json.parse(body)
    la verdi = parsed[felt]
    hvis verdi != null {
        returner verdi
    }
    returner ""
}

funksjon start() -> heiltall {
    helpdesk.lagre_data(helpdesk.default_store())

    la front = web.handle_request(web.request_context("get", "/", {}, {}, ""))
    assert_status(front, 200)

    la login_page = web.handle_request(web.request_context("get", "/login", {}, {}, ""))
    assert_status(login_page, 200)

    la login = web.handle_request(web.request_context(
        "post",
        "/login",
        {},
        {},
        '{"user":"admin","password":"admin"}'
    ))
    assert_status(login, 200)
    la login_data = json.parse(web.response_body(login))
    assert_eq(login_data["role"], "admin")
    la session_cookie = web.response_header(login, "set-cookie")
    assert(session_cookie != "")

    la session_admin = web.handle_request(web.request_context(
        "get",
        "/admin/models",
        {},
        {"cookie": session_cookie},
        ""
    ))
    assert_status(session_admin, 200)
    la models = json.parse(web.response_body(session_admin))
    assert(har_nokkel(models, "teams"))
    assert(har_nokkel(models, "categories"))
    assert(har_nokkel(models, "slas"))
    assert(har_nokkel(models, "attachments"))

    la capabilities = web.handle_request(web.request_context(
        "get",
        "/admin/capabilities",
        {},
        {"cookie": session_cookie},
        ""
    ))
    assert_status(capabilities, 200)
    la caps = json.parse(web.response_body(capabilities))
    assert(har_nokkel(caps, "automation_rules"))
    assert(har_nokkel(caps, "ai_capabilities"))

    la ok = web.handle_request(web.request_context("get", "/tickets", {}, {"x-api-key": "secret-helpdesk", "x-role": "user", "x-user": "bruker"}, ""))
    assert_status(ok, 200)
    la data = json.parse(web.response_body(ok))
    assert(data != null)
    assert(har_nokkel(data, "tickets"))

    la admin = web.handle_request(web.request_context(
        "get",
        "/admin/users",
        {},
        {
            "x-api-key": "secret-helpdesk",
            "x-role": "admin",
            "x-user": "admin"
        },
        ""
    ))
    assert_status(admin, 200)

    la my = web.handle_request(web.request_context(
        "get",
        "/tickets/my",
        {"status": "open", "sort": "-updated_at", "limit": "5", "offset": "0"},
        {
            "x-api-key": "secret-helpdesk",
            "x-role": "agent",
            "x-user": "lena"
        },
        ""
    ))
    assert_status(my, 200)

    la bad_sort = web.handle_request(web.request_context(
        "get",
        "/tickets",
        {"sort": "bad-sort"},
        {"x-api-key": "secret-helpdesk", "x-role": "admin", "x-user": "admin"},
        ""
    ))
    assert_status(bad_sort, 400)
    la err_sort = json.parse(web.response_body(bad_sort))
    assert_eq(err_sort["error"], "error")
    assert_eq(err_sort["code"], "VALIDATION_ERROR")

    la forbidden_ctx = web.request_context("get", "/admin/roles", {}, {"x-api-key": "secret-helpdesk", "x-role": "user", "x-user": "bruker"}, "")
    la forbidden_admin = helpdesk.krev_admin_tilgang(forbidden_ctx)
    assert_status(forbidden_admin, 403)

    la unauthorized_ctx = web.request_context("get", "/admin/roles", {}, {"x-role": "admin", "x-user": "admin"}, "")
    la unauthorized = helpdesk.krev_admin_tilgang(unauthorized_ctx)
    assert_status(unauthorized, 401)

    la admin_admin_route = web.handle_request(web.request_context(
        "get",
        "/admin/roles",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "admin", "x-user": "admin"},
        ""
    ))
    assert_status(admin_admin_route, 200)

    la route_forbidden = web.handle_request(web.request_context(
        "get",
        "/admin/roles",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "user", "x-user": "bruker"},
        ""
    ))
    assert_status(route_forbidden, 403)

    la route_unauthorized = web.handle_request(web.request_context(
        "get",
        "/admin/roles",
        {},
        {"x-role": "admin", "x-user": "admin"},
        ""
    ))
    assert_status(route_unauthorized, 401)

    la admin_panel = web.handle_request(web.request_context(
        "get",
        "/admin/panel",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "admin", "x-user": "admin"},
        ""
    ))
    assert_status(admin_panel, 200)
    la panel_body = web.response_body(admin_panel)
    assert(builtin.lengde(panel_body) > 0)
    assert(panel_body != "")

    la admin_panel_forbidden = web.handle_request(web.request_context(
        "get",
        "/admin/panel",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "agent", "x-user": "lena"},
        ""
    ))
    assert_status(admin_panel_forbidden, 403)

    la admin_panel_unauthorized = web.handle_request(web.request_context(
        "get",
        "/admin/panel",
        {},
        {"x-role": "admin", "x-user": "admin"},
        ""
    ))
    assert_status(admin_panel_unauthorized, 401)

    la patch_too = helpdesk.krev_admin_tilgang(web.request_context(
        "patch",
        "/admin/tickets/1",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "agent", "x-user": "lena"},
        '{"status":"closed"}'
    ))
    assert_status(patch_too, 403)

    la metrics = web.handle_request(web.request_context(
        "get",
        "/admin/metrics",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "admin", "x-user": "admin"},
        ""
    ))
    assert_status(metrics, 200)
    assert(har_nokkel(json.parse(web.response_body(metrics)), "tickets"))

    la page = web.handle_request(web.request_context(
        "get",
        "/tickets/9999",
        {},
        {"x-api-key": "secret-helpdesk", "x-user": "lena", "x-role": "agent"},
        ""
    ))
    assert_status(page, 404)

    la invalid_id = web.handle_request(web.request_context(
        "get",
        "/tickets/bad-id",
        {},
        {"x-api-key": "secret-helpdesk", "x-user": "lena", "x-role": "agent"},
        ""
    ))
    assert_status(invalid_id, 404)

    la post_invalid = web.handle_request(web.request_context(
        "post",
        "/tickets",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "agent", "x-user": "lena"},
        '{"title":""}'
    ))
    assert_status(post_invalid, 400)

    la post_missing = web.handle_request(web.request_context(
        "post",
        "/tickets",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "agent", "x-user": "lena"},
        "{}"
    ))
    assert_status(post_missing, 400)

    la created = web.handle_request(web.request_context(
        "post",
        "/tickets",
        {},
        {"cookie": session_cookie},
        '{"title":"Faktura stopper","description":"Kunden får feil","priority":"1","category":"billing"}'
    ))
    assert_status(created, 201)
    la created_text = web.response_body(created)
    assert(t.inneholder(created_text, '"category":"billing"'))
    assert(t.inneholder(created_text, '"sla":"standard"'))

    la comment_one = web.handle_request(web.request_context(
        "post",
        "/tickets/1/comment",
        {},
        {"cookie": session_cookie},
        '{"message":"Vi undersøker saken"}'
    ))
    assert_status(comment_one, 200)

    la status_one = web.handle_request(web.request_context(
        "post",
        "/tickets/1/status",
        {},
        {"cookie": session_cookie},
        '{"status":"venter"}'
    ))
    assert_status(status_one, 200)
    la status_text = web.response_body(status_one)
    assert(t.inneholder(status_text, '"status":"waiting"'))

    la attachment = web.handle_request(web.request_context(
        "post",
        "/tickets/1/attachments",
        {},
        {"cookie": session_cookie},
        '{"filename":"logg.txt","content_type":"text/plain","size":"12"}'
    ))
    assert_status(attachment, 201)

    la email_in = web.handle_request(web.request_context(
        "post",
        "/admin/email/inbound",
        {},
        {"cookie": session_cookie},
        '{"from":"kunde@example.test","subject":"Ny sak"}'
    ))
    assert_status(email_in, 202)

    la automation = web.handle_request(web.request_context(
        "post",
        "/admin/automation/run",
        {},
        {"cookie": session_cookie},
        "{}"
    ))
    assert_status(automation, 200)

    la ai_summary = web.handle_request(web.request_context(
        "post",
        "/tickets/1/ai/summary",
        {},
        {"cookie": session_cookie},
        "{}"
    ))
    assert_status(ai_summary, 200)
    assert_eq(json.parse(web.response_body(ai_summary))["capability"], "summarize_ticket")

    la update_ticket = web.handle_request(web.request_context(
        "put",
        "/tickets/1",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "agent", "x-user": "lena"},
        '{"priority": "5"}'
    ))
    assert_status(update_ticket, 200)
    assert(t.inneholder(web.response_body(update_ticket), '"priority":5'))

    la invalid_put_id = web.handle_request(web.request_context(
        "put",
        "/tickets/abc",
        {},
        {"x-api-key": "secret-helpdesk", "x-role": "agent", "x-user": "lena"},
        '{"title": "ok"}'
    ))
    assert_status(invalid_put_id, 404)

    prøv { builtin.fil_slett(helpdesk.filsti_data()) } fang (e) {}
    returner 0
}

bruk std.runtime_memory som memory

funksjon mutator(args: ordbok_tekst) -> tekst {
    la iterations = heltall_fra_tekst(args["iterations"])
    la i: heiltall = 0
    mens i < iterations {
        hvis ikkje memory.legg_rot(args["heap"], args["from"]) { returner "root-add-error" }
        hvis ikkje memory.legg_ref(args["heap"], args["from"], args["to"]) { returner "ref-add-error" }
        hvis ikkje memory.objekt_skriv_byte(args["heap"], args["from"], 0, i + 40) { returner "write-error" }
        hvis ikkje memory.fjern_ref(args["heap"], args["from"], args["to"]) { returner "ref-remove-error" }
        hvis ikkje memory.fjern_rot(args["heap"], args["from"]) { returner "root-remove-error" }
        i = i + 1
    }
    returner "mutated:" + tekst_fra_heltall(i)
}

funksjon collector(args: ordbok_tekst) -> tekst {
    la collected = memory.collect(args["heap"])
    hvis heltall_fra_tekst(collected["alive"]) != 5 { returner "collect-error" }
    hvis memory.compact(args["heap"])["status"] != "ferdig" { returner "compact-error" }
    returner "collected"
}

funksjon spawn(fn_namn: tekst, args: ordbok_tekst) -> ordbok_tekst {
    returner builtin.thread_spawn({"abi": "norscode-native-thread-v1", "operation": "spawn", "fn": fn_namn, "args": args, "name": fn_namn, "stack_bytes": "1048576"})
}

funksjon join(thread: ordbok_tekst) -> ordbok_tekst {
    returner builtin.thread_join({"abi": "norscode-native-thread-v1", "operation": "join", "handle": thread["handle"], "thread_id": thread["thread_id"], "timeout_ms": "20000"})
}

funksjon start() -> heiltall {
    la h = memory.ny_heap()
    la hub = memory.alloker(h, "kart", 8)
    la a = memory.alloker(h, "liste", 8)
    la b = memory.alloker(h, "tekst", 8)
    la c = memory.alloker(h, "liste", 8)
    la d = memory.alloker(h, "tekst", 8)
    assert(memory.legg_rot(h, hub))
    assert(memory.legg_ref(h, hub, a))
    assert(memory.legg_ref(h, hub, b))
    assert(memory.legg_ref(h, hub, c))
    assert(memory.legg_ref(h, hub, d))

    la worker_a = spawn("__main__.mutator", {"heap": h, "from": a, "to": b, "iterations": "2"})
    la worker_b = spawn("__main__.mutator", {"heap": h, "from": c, "to": d, "iterations": "2"})
    la gc = spawn("__main__.collector", {"heap": h})
    assert_eq(worker_a["status"], "started")
    assert_eq(worker_b["status"], "started")
    assert_eq(gc["status"], "started")
    assert_eq(join(worker_a)["value"], "mutated:2")
    assert_eq(join(worker_b)["value"], "mutated:2")
    assert_eq(join(gc)["value"], "collected")
    assert_eq(memory.samandrag(h)["alive"], "5")
    assert_eq(memory.objekt_les_byte(h, a, 0), 41)
    assert_eq(memory.objekt_les_byte(h, c, 0), 41)
    la lock = h["allocator_lock"]
    assert_eq(lock["owner"], "")
    assert_eq(heltall_fra_tekst(lock["depth"]), 0)
    skriv("test_runtime_memory_parallel_gc OK")
    returner 0
}

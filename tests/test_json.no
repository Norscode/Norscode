bruk std.json som json

funksjon start() -> heltall {
    la payload = "{\"navn\":\"Norscode\",\"alder\":2,\"aktiv\":true,\"teller\":[],\"metadata\":{\"status\":\"ok\"}}"
    la parsed = json.parse(payload)

    assert_eq(parsed["navn"], "Norscode")
    assert_eq(parsed["alder"], "2")
    assert_eq(parsed["aktiv"], "true")
    assert_eq(parsed["teller"], "[]")
    assert_eq(parsed["metadata"], "{\"status\":\"ok\"}")

    assert_eq(json.stringify(parsed), "{\"navn\":\"Norscode\",\"alder\":2,\"aktiv\":true,\"teller\":[],\"metadata\":{\"status\":\"ok\"}}")
    assert_eq(json.parse("null"), "null")
    assert_eq(json.parse("true"), "true")
    assert_eq(json.parse("false"), "false")
    assert_eq(json.stringify(json.parse("{}")), "{}")
    assert_eq(json.stringify(json.parse("[]")), "{}")
    assert_eq(json.stringify(json.parse("[1]")), "{\"0\":\"1\"}")
    assert_eq(json.stringify(json.parse("[null]")), "{\"0\":\"null\"}")
    assert_eq(json.stringify(json.parse("[true,false,null]")), "{\"0\":\"true\",\"1\":\"false\",\"2\":\"null\"}")
    assert_eq(json.stringify(json.parse("[1, 2, 3]")), "{\"0\":\"1\",\"1\":\"2\",\"2\":\"3\"}")
    assert_eq(json.stringify(json.parse("[1, 2, 3, 4]")), "{\"0\":\"1\",\"1\":\"2\",\"2\":\"3\",\"3\":\"4\"}")
    assert_eq(json.stringify(json.parse("[1, -2, 3]")), "{\"0\":\"1\",\"1\":\"-2\",\"2\":\"3\"}")
    assert_eq(json.stringify(json.parse("[\"x\", \"y\"]")), "{\"0\":\"x\",\"1\":\"y\"}")
    assert_eq(json.stringify(json.parse("[{}]")), "{\"0\":\"{}\"}")
    assert_eq(json.stringify(json.parse("{\"a\":1,\"b\":2,\"c\":true}")), "{\"a\":1,\"b\":2,\"c\":true}")
    assert_eq(json.stringify(json.parse("{\"a\":[1,2],\"b\":{\"c\":true}}")), "{\"a\":[1,2],\"b\":{\"c\":true}}")
    assert_eq(json.stringify(json.parse("{\"a\":[],\"b\":{}}")), "{\"a\":[],\"b\":{}}")
    assert_eq(json.stringify(json.parse("   [1, 2, 3] \n")), "{\"0\":\"1\",\"1\":\"2\",\"2\":\"3\"}")
    assert_eq(json.stringify(json.parse("\t{\"a\":1, \"b\":2}\r\n")), "{\"a\":1,\"b\":2}")
    assert_eq(json.stringify(json.parse("{\"x\":null}")), "{\"x\":null}")
    assert_eq(json.parse("\"\""), "")
    assert_eq(json.parse("\"a\\\"b\""), "a\"b")
    assert_eq(json.parse("\"a\\nb\""), "a\nb")
    assert_eq(json.parse("\"a\\tb\""), "a\tb")
    assert_eq(json.parse("\"a\\rb\""), "a\rb")
    assert_eq(json.parse("\"\\n\""), "\n")
    assert_eq(json.parse(" \"  \" "), "  ")
    assert_eq(json.parse("\"a\\\\b\""), "a\\b")
    assert_eq(json.parse("\"a\\\\qb\""), "a\\qb")
    assert_eq(json.parse("\"a\\\\/b\""), "a\\/b")
    assert_eq(json.parse("0"), "0")
    assert_eq(json.parse("-12"), "-12")
    assert_eq(json.parse("  42  "), "42")
    assert_eq(json.stringify(json.parse("[\"a\",1,false,null]")), "{\"0\":\"a\",\"1\":\"1\",\"2\":\"false\",\"3\":\"null\"}")
    assert_eq(json.stringify(json.parse("  {\"a\" : 1 , \"b\" : [2, 3] , \"c\":{\"d\":false} }")), "{\"a\":1,\"b\":[2,3],\"c\":{\"d\":false}}")
    skriv("test_json OK")
    returner 0
}

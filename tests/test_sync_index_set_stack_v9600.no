funksjon start() -> heiltall {
    la suffix = builtin.random_hex(8)
    la inn = "/tmp/norscode_index_set_in_" + suffix + ".ncb.json"
    la ut = "/tmp/norscode_index_set_out_" + suffix + ".ncb.json"
    builtin.fil_skriv(inn, "{\"functions\":{\"f\":{\"code\":[[\"INDEX_SET\"],[\"POP\"],[\"INDEX_SET\"]]}}}")
    la cmd = "NORSCODE_INDEX_SET_IN='" + inn + "' NORSCODE_INDEX_SET_OUT='" + ut + "' ./bin/nc run tools/sync_index_set_stack_v9600.no"
    la res = exec_prosess(cmd)
    assert_eq(res[0], "0")
    la data = builtin.fil_les(ut)
    assert(builtin.index_of(data, "[\"INDEX_SET\"],[\"POP\"],[\"INDEX_SET\"],[\"POP\"]") >= 0)
    la verktøy = builtin.fil_les("tools/sync_index_set_stack_v9600.no")
    assert(builtin.index_of(verktøy, "source_map_parse") >= 0)
    assert(builtin.index_of(verktøy, "builtin.heltall_fra_tekst\\\",1]") >= 0)
    exec_prosess("rm -f '" + inn + "' '" + ut + "'")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/run_runtime_phase3_v3900.no")
    la client = fil_les("tools/socket_ping_v3900.no")
    la probe = fil_les("tests/socket_runtime_probe_v3900.no")

    assert(t.inneholder(src, "tools/socket_ping_v3900.no"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "tests/socket_runtime_probe_v3900.no"))
    assert(t.inneholder(client, "bruk std.socket som sok"))
    assert(t.inneholder(client, "sok.send(s, \"ping\")"))
    assert(t.inneholder(client, "sok.motta(s, 1024)"))
    assert(t.inneholder(probe, "bruk std.socket som sok"))
    assert(t.inneholder(probe, "sok.bind(srv, \"127.0.0.1\", 18790)"))
    assert(t.inneholder(probe, "sok.send(conn, \"pong:\" + data)"))
    assert(t.inneholder(src, "linux_stage0_socket_reply.txt"))
    assert(t.inneholder(src, "NORSCODE_NATIVE_GAP_BIN="))
    assert(t.inneholder(src, "/bin/nc"))
    assert(t.inneholder(src, "tools/native_runtime_gap_gate_v3001.no"))
    assert(t.inneholder(src, "NORSCODE_NATIVE_GAP_BIN=/work/bootstrap/stage0/norscode-linux-x86_64 /work/bin/nc run /work/tools/native_runtime_gap_gate_v3001.no"))
    assert(ikkje t.inneholder(src, "echo -n ping | nc"))
    assert(ikkje t.inneholder(src, "echo -n ping | netcat"))
    assert(ikkje t.inneholder(src, "apt-get install -y netcat-openbsd"))
    assert(ikkje t.inneholder(src, "printf 'ping' | nc"))
    assert(ikkje t.inneholder(src, "printf 'ping' | netcat"))
    assert(ikkje t.inneholder(src, "printf '%s' \"$reply\""))
    assert(ikkje t.inneholder(src, "bash \" + shell(root + \"/tools/native_runtime_gap_gate_v3001.sh\")"))
    assert(ikkje t.inneholder(src, "bash tools/native_runtime_gap_gate_v3001.sh"))

    skriv("test_runtime_phase3_no_printf OK")
    returner 0
}

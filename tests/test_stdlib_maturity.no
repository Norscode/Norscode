bruk std.tekst som t

funksjon krev(sti: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        returner 0
    }
    skriv("Manglar stdlib-bevis: " + sti)
    returner 1
}

funksjon start() -> heiltall {
    la feil = 0

    feil = feil + krev("stdlib/minimal_standard_library.no")
    feil = feil + krev("stdlib/native/native_stdlib_foundation.no")
    feil = feil + krev("tests/test_text_helpers.no")
    feil = feil + krev("tests/test_json.no")
    feil = feil + krev("tests/test_http_helpers.no")
    feil = feil + krev("tests/test_logging.no")
    feil = feil + krev("tests/test_metrics.no")
    feil = feil + krev("tests/test_db.no")
    feil = feil + krev("tests/test_ai.no")
    feil = feil + krev("tests/test_security.no")
    feil = feil + krev("std/sikkerheit.no")
    feil = feil + krev("tests/test_sikkerheit_facade.no")
    feil = feil + krev("tests/test_python_independence_std.no")
    feil = feil + krev("tests/test_stdlib_status_matrix.no")
    feil = feil + krev("tests/test_runtime_async_process_maturity.no")
    feil = feil + krev("tests/test_selfhost_phase2_stdlib_usecases.no")
    feil = feil + krev("examples/secrets.no")
    feil = feil + krev("examples/cache.no")
    feil = feil + krev("examples/file_object_storage.no")
    feil = feil + krev("examples/ai.no")

    assert_eq(feil, 0)

    la ai = fil_les("std/ai.no")
    assert(t.inneholder(ai, "funksjon chat("))
    assert(t.inneholder(ai, "funksjon chat_meldinger("))
    assert(t.inneholder(ai, "funksjon embedding("))
    assert(t.inneholder(ai, "funksjon moderer("))
    assert(t.inneholder(ai, "funksjon verktøy_kall("))
    assert(t.inneholder(ai, "funksjon agent_plan("))
    assert(t.inneholder(ai, "network"))

    la http = fil_les("tests/test_http_helpers.no")
    assert(t.inneholder(http, "response_json_checked"))
    assert(t.inneholder(http, "response_status"))

    la db = fil_les("tests/test_db.no")
    assert(t.inneholder(db, "db.transaction"))
    assert(t.inneholder(db, "db.pool"))

    la json = fil_les("tests/test_json.no")
    assert(t.inneholder(json, "json.parse"))
    assert(t.inneholder(json, "json.stringify"))

    la pyfri = fil_les("tests/test_python_independence_std.no")
    assert(t.inneholder(pyfri, "std/sys.no"))
    assert(t.inneholder(pyfri, "std/multiprocessing.no"))
    assert(t.inneholder(pyfri, "std/socketserver.no"))

    la status = fil_les("std/stdlib_status.no")
    assert(t.inneholder(status, "eksperimentell"))
    assert(t.inneholder(status, "stub"))
    assert(t.inneholder(status, "asynk"))

    skriv("test_stdlib_maturity OK")
    returner 0
}

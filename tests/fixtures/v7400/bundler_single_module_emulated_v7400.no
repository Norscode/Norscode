bruk selfhost.bundler

funksjon start() -> heiltall {
    la fil_sti_0 = "selfhost/lexer/lexer_m1.no"
    skriv("trace: before helper\n")
    la ncb_json_0 = les_ncb_eller_kompiler(fil_sti_0)
    skriv("trace: after helper len=" + tekst_fra_heltall(lengde(ncb_json_0)) + "\n")
    fil_skriv("/tmp/v7400_emulated_bundle_one.ncb.json", ncb_json_0)
    skriv("trace: after write\n")
    skriv("Bundle: /tmp/v7400_emulated_bundle_one.ncb.json (" + tekst_fra_heltall(lengde(ncb_json_0)) + " bytes)\n")
    returner 0
}

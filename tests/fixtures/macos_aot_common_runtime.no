funksjon start() -> heiltall {
    la verdiar = [2, 4, 6]
    la namn = "Norscode"
    la total = lengde(verdiar)
    la andre = verdiar[1]
    total = total + andre
    hvis builtin.contains(namn, "code") {
        total = total + 4
    }
    hvis builtin.starts_with(namn, "Nor") {
        total = total + 1
    }
    hvis builtin.ends_with(namn, "code") {
        total = total + builtin.index_of(namn, "code")
    }
    la liten = builtin.lower(namn)
    hvis builtin.contains(liten, "code") {
        total = total + 1
    }
    la stor = builtin.upper(namn)
    hvis builtin.starts_with(stor, "NOR") {
        total = total + 1
    }
    la trimma = builtin.trim(" Norscode ")
    hvis builtin.ends_with(trimma, "code") {
        total = total + 1
    }
    la bytta = builtin.replace(namn, "code", "lang")
    hvis builtin.ends_with(bytta, "lang") {
        total = total + 1
    }
    la utsnitt = builtin.slice(namn, 0, 3)
    hvis builtin.starts_with(utsnitt, "Nor") {
        total = total + 1
    }
    hvis builtin.char_code("N") == 78 {
        total = total + 1
    }
    la config = {"bonus": 2}
    total = total + config["bonus"]
    hvis finnes_nøkkel(config, "bonus") {
        total = total + 1
    }
    returner total
}

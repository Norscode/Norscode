funksjon vis_lengde(modular) -> heiltall {
    skriv("inne vis_lengde len=" + tekst_fra_heltall(lengde(modular)) + "\n")
    returner 0
}

funksjon start() -> heiltall {
    la reine_modular: liste<tekst> = []
    legg_til(reine_modular, "selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no")
    skriv("trace: before local fn len=" + tekst_fra_heltall(lengde(reine_modular)) + "\n")
    vis_lengde(reine_modular)
    skriv("trace: after local fn\n")
    returner 0
}

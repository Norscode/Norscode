bruk selfhost.bundler

funksjon start() -> heiltall {
    la args_str = "selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no"
    la utfil = "/tmp/v8200_bundle_one.ncb.json"

    la modular = builtin.split(args_str, " ")
    la reine_modular: liste<tekst> = []
    la i: heiltall = 0
    mens i < lengde(modular) {
        la m: tekst = modular[i]
        hvis lengde(builtin.trim(m)) > 0 {
            legg_til(reine_modular, builtin.trim(m))
        }
        i = i + 1
    }

    skriv("trace: before bygg_bundle len=" + tekst_fra_heltall(lengde(reine_modular)) + "\n")
    bygg_bundle(reine_modular, utfil)
    skriv("trace: after bygg_bundle\n")
    returner 0
}

funksjon start() -> heiltall {
    la adresse = 7340032
    builtin.atomic_store_ptr(adresse, 41)
    la gammel = builtin.atomic_fetch_add_ptr(adresse, 1)
    la noverande = builtin.atomic_load_ptr(adresse)
    builtin.atomic_fence()
    hvis gammel != 41 { stopp(21) }
    hvis noverande != 42 { stopp(22) }
    skriv("native atomic runtime OK\n")
    returner 0
}

bruk std.web som web

funksjon start() -> heiltall {
    la rh = ncb_route_handlers()
    la i: heiltall = 0
    mens i < lengde(rh) {
        la h = rh[i]
        la k = nøkler(h)
        skriv("-- handler ")
        skriv(tekst(i))
        skriv("\n")
        la ki: heiltall = 0
        mens ki < lengde(k) {
            la nøkkel = k[ki]
            skriv(nøkkel)
            skriv("=\"")
            skriv(h[nøkkel])
            skriv("\"\n")
            ki = ki + 1
        }
        i = i + 1
    }
    returner 0
}

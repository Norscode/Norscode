funksjon retur_med_cleanup(logg: liste_tekst) -> heiltall {
    utsett {
        legg_til(logg, "utsett")
    }
    prøv {
        returner 42
    } fang (e: tekst) {
        returner -1
    } endeleg {
        legg_til(logg, "endeleg")
    }
}

funksjon kast_med_endeleg(logg: liste_tekst) -> heiltall {
    prøv {
        kast "IOFeil: disk"
    } endeleg {
        legg_til(logg, "kast-endeleg")
    }
    returner 0
}

funksjon fang_kryssramme(logg: liste_tekst) -> tekst {
    prøv {
        kast_med_endeleg(logg)
    } fang (e: IOFeil) {
        returner e
    }
    returner "ikkje fanga"
}

funksjon start() -> heiltall {
    la logg: liste_tekst = []
    assert_eq(retur_med_cleanup(logg), 42)
    assert_eq(lengde(logg), 2)
    assert_eq(logg[0], "endeleg")
    assert_eq(logg[1], "utsett")

    la kast_logg: liste_tekst = []
    assert_eq(fang_kryssramme(kast_logg), "IOFeil: disk")
    assert_eq(lengde(kast_logg), 1)
    assert_eq(kast_logg[0], "kast-endeleg")
    returner 0
}

funksjon retur_utan_verdi()
    returner
    skriv("SKAL_IKKJE\n")
slutt

funksjon loop_test() -> heiltall
    la i = 0
    la sum = 0
    mens i < 6
        i = i + 1
        hvis i == 2
            fortsett
        slutt
        hvis i == 5
            bryt
        slutt
        sum = sum + i
    slutt
    returner sum
slutt

funksjon try_fang_test() -> tekst
    prøv {
        kast("boom")
        returner "skal_ikkje"
    } fang (e) {
        returner "fanga:" + e
    }
slutt

funksjon start() -> heiltall
    skriv("ir bytecode runtime v4600\n")
    retur_utan_verdi()
    skriv("retur_utan_verdi OK\n")
    skriv("loop_test OK: " + tekst(loop_test()) + "\n")
    skriv("try_fang OK: " + try_fang_test() + "\n")
    returner 0
slutt

funksjon bland(verdi: heiltall) -> heiltall {
    la maskert = verdi & 15
    la blanda = maskert ^ 3
    returner (blanda << 1) | 1
}

funksjon forkast(verdi: heiltall) -> heiltall {
    returner verdi + 100
}

funksjon start() -> heiltall {
    la resultat = bland(10)
    forkast(resultat)
    la ut = 99
    hvis ikkje (resultat == 19) {
        ut = 99
    } ellers {
        la invertert = ~0
        ut = (resultat >> 2) + (invertert & 7)
    }
    returner ut
}

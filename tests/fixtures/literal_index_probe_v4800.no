funksjon start() -> heiltall {
    la x = 1
    skriv("x=" + tekst(x) + "\n")

    la liste = [1, 2, 3]
    skriv("liste_len=" + tekst(lengde(liste)) + "\n")

    la outer = {"functions": 1}
    skriv("outer_len=" + tekst(lengde(outer)) + "\n")

    la y = liste[1]
    skriv("y=" + tekst(y) + "\n")

    returner 0
}

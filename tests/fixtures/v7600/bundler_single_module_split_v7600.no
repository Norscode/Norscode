bruk selfhost.bundler

funksjon start() -> heiltall {
    skriv("trace: before split\n")
    la modular = builtin.split("selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no", " ")
    skriv("trace: after split len=" + tekst_fra_heltall(lengde(modular)) + "\n")
    bygg_bundle(modular, "/tmp/v7600_split_bundle_one.ncb.json")
    skriv("trace: after bygg_bundle\n")
    returner 0
}

funksjon vis_lengde(modular) -> heiltall {
    skriv("inne vis_lengde len=" + tekst_fra_heltall(lengde(modular)) + "\n")
    returner 0
}

funksjon start() -> heiltall {
    skriv("trace: before split\n")
    la modular = builtin.split("selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no", " ")
    skriv("trace: after split len=" + tekst_fra_heltall(lengde(modular)) + "\n")
    vis_lengde(modular)
    skriv("trace: after local var\n")
    returner 0
}

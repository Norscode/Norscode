funksjon vis_lengde(modular) -> heiltall {
    skriv("inne vis_lengde len=" + tekst_fra_heltall(lengde(modular)) + "\n")
    returner 0
}

funksjon start() -> heiltall {
    skriv("trace: before local list literal\n")
    vis_lengde(["selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no"])
    skriv("trace: after local list literal\n")
    returner 0
}

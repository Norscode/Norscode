# Minimal smoke-test for list append with TOKEN_FORMAT_V1 objects.
# Dette isolerer det full lexer trenger: [] + legg_til + token-ordbok + liste-retur.

funksjon lag_token(type: tekst, verdi: tekst, linje: heltall, kolonne: heltall) {
    returner {
        "type": type,
        "value": verdi,
        "line": linje,
        "column": kolonne
    }
}

funksjon start() {
    la tokens = []
    legg_til(tokens, lag_token("EOF", "", 1, 1))
    returner tokens
}

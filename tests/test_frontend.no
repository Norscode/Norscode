bruk std.frontend som frontend
bruk std.html som html
bruk std.web som web
bruk std.tekst som t
bruk examples.frontend som ex

funksjon start() -> heltall {
    assert_eq(frontend.slot("innhold"), "innhold")
    assert_eq(
        frontend.komponent_kort("Tittel", html.p("", "Innhold")),
        "<section class=\"card panel\"><h2>Tittel</h2><div class=\"card-body\"><p>Innhold</p></div></section>"
    )
    assert_eq(
        frontend.komponent_nav(html.partial_list("", html.li("", "Hjem"))),
        "<nav class=\"nav\"><ul class=\"list\"><li>Hjem</li></ul></nav>"
    )
    assert_eq(
        frontend.komponent_liste(html.li("", "A") + html.li("", "B")),
        "<ul class=\"list\"><li>A</li><li>B</li></ul>"
    )
    assert_eq(
        frontend.komponent_tabell(html.tbody("", html.tr("", html.td("", "1")))),
        "<table class=\"table\"><tbody><tr><td>1</td></tr></tbody></table>"
    )
    assert_eq(
        frontend.nav_link("Hjem", "/"),
        "<li><a href=\"/\">Hjem</a></li>"
    )
    assert_eq(
        frontend.nav_list(frontend.nav_link("Hjem", "/")),
        "<nav class=\"nav\"><ul class=\"list\"><li><a href=\"/\">Hjem</a></li></ul></nav>"
    )
    assert(t.inneholder(
        frontend.komponent_hero("Tittel", "Ingress", html.button("", "CTA")),
        "<section class=\"hero\"><h1>Tittel</h1><p>Ingress</p><div class=\"hero__actions\"><button>CTA</button></div></section>"
    ))
    assert(t.inneholder(
        frontend.komponent_alert("Merk", "Dette er en melding"),
        "<section class=\"alert\"><h2 class=\"alert-title\">Merk</h2><p class=\"alert-body\">Dette er en melding</p></section>"
    ))
    assert(t.inneholder(
        frontend.komponent_empty("Tomt", "Ingen resultater"),
        "<section class=\"empty-state\"><h2>Tomt</h2><p>Ingen resultater</p></section>"
    ))
    assert(t.inneholder(
        frontend.komponent_loading("Laster"),
        "<section class=\"loading-state\"><span class=\"loading-state__spinner\">⏳</span><p>Laster</p></section>"
    ))
    assert(t.inneholder(
        frontend.layout_main("Demo", html.p("", "Hei")),
        "<div class=\"shell\"><p>Hei</p></div>"
    ))
    assert(t.inneholder(
        frontend.layout_main_med_stylesheet("Demo", html.p("", "Hei"), "/assets/css/norsk.css"),
        "href=\"/assets/css/norsk.css\""
    ))
    assert_eq(
        frontend.komponent_seksjonshode("Siste saker", "Oppdatert nå", frontend.komponent_knapp_sekundær("Oppdater", "")),
        "<header class=\"section-header\"><div class=\"section-header__text\"><h2>Siste saker</h2><p>Oppdatert nå</p></div><div class=\"section-header__actions\"><button class=\"btn btn-secondary\" type=\"button\">Oppdater</button></div></header>"
    )
    assert_eq(
        frontend.komponent_panel_med_handlinger("Saksdetaljer", frontend.komponent_lenkeknapp("Åpne", "/tickets/1", ""), html.p("", "Innhold")),
        "<section class=\"panel detail-panel\"><header class=\"panel-header\"><h2>Saksdetaljer</h2><div class=\"panel-actions\"><a class=\"btn btn-primary\" href=\"/tickets/1\">Åpne</a></div></header><div class=\"panel-body\"><p>Innhold</p></div></section>"
    )
    assert(t.inneholder(
        frontend.layout_app(
            "Demo",
            html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
            html.p("", "Hei"),
            "Footer"
        ),
        "<header class=\"app-header\">"
    ))
    assert(t.inneholder(
        frontend.layout_app(
            "Demo",
            html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
            html.p("", "Hei"),
            "Footer"
        ),
        "<main class=\"app-main\"><p>Hei</p></main>"
    ))
    assert(t.inneholder(
        frontend.layout_app(
            "Demo",
            html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
            html.p("", "Hei"),
            "Footer"
        ),
        "<footer class=\"app-footer\"><p>Footer</p></footer>"
    ))
    assert(t.inneholder(
        frontend.fragment_page_med_stylesheet(
            web.request_context("get", "/status", {}, {}, ""),
            "Demo",
            frontend.nav_list(frontend.nav_link("Hjem", "/")),
            html.p("", "Hei"),
            "Footer",
            "Status",
            "/assets/css/norsk.css"
        ),
        "href=\"/assets/css/norsk.css\""
    ))
    assert_eq(
        frontend.komponent_stack(html.p("", "Stack")),
        "<div class=\"stack\"><p>Stack</p></div>"
    )
    la fragment_page = frontend.fragment_page(
        web.request_context("get", "/status", {}, {"x-norscode-fragment": "1"}, ""),
        "Demo",
        frontend.nav_list(frontend.nav_link("Hjem", "/")),
        html.p("", "Hei"),
        "Footer",
        "Status"
    )
    assert_eq(web.response_status(fragment_page), 200)
    assert_eq(web.response_header(fragment_page, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_page), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_page), "<p>Hei</p>"))
    la full_home = web.handle_request(web.request_context("get", "/", {}, {}, ""))
    assert_eq(web.response_status(full_home), 200)
    assert(t.inneholder(web.response_body(full_home), "type=\"checkbox\""))
    assert(t.inneholder(web.response_body(full_home), "role=\"switch\""))
    assert(t.inneholder(web.response_body(full_home), "type=\"submit\""))
    assert(t.inneholder(web.response_body(full_home), "type=\"reset\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-toggle=\"#demo-panel\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-tab=\"#demo-tab-1\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-autosubmit=\"400\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-confirm=\"Nullstille skjemaet?\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-disable-submit=\"true\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-modal-open=\"#demo-dialog\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-modal-close=\"true\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-dropdown-toggle=\"#demo-menu\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-copy=\"#demo-code\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-autoresize=\"true\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-livefilter=\"#demo-filter-list li\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-json-form=\"/api/demo\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-status=\"#demo-json-status\""))
    assert(t.inneholder(web.response_body(full_home), "data-nc-done=\"Lagret\""))
    assert(t.inneholder(web.response_body(full_home), "norscode:json-form"))
    assert(t.inneholder(web.response_body(full_home), "norscode:json-form-error"))
    assert(t.inneholder(web.response_body(full_home), "norscode:copy"))
    assert(t.inneholder(frontend.ui_stilark(), ".section-header"))
    assert(t.inneholder(frontend.ui_stilark(), ".panel-header"))
    la full_status = web.handle_request(web.request_context("get", "/status", {}, {}, ""))
    assert_eq(web.response_status(full_status), 200)
    assert(t.inneholder(web.response_body(full_status), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_status), "<section class=\"card panel\">"))

    la fragment_status = web.handle_request(
        web.request_context("get", "/status", {}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_status), 200)
    assert_eq(web.response_header(fragment_status, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_status), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_status), "<section class=\"card panel\">"))
    la full_docs = web.handle_request(web.request_context("get", "/docs", {}, {}, ""))
    assert_eq(web.response_status(full_docs), 200)
    assert(t.inneholder(web.response_body(full_docs), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_docs), "<h2>Dokumentasjon</h2>"))
    la fragment_docs = web.handle_request(
        web.request_context("get", "/docs", {}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_docs), 200)
    assert_eq(web.response_header(fragment_docs, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_docs), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_docs), "<h2>Dokumentasjon</h2>"))

    la full_search = web.handle_request(web.request_context("get", "/sok", {"q": "server"}, {}, ""))
    assert_eq(web.response_status(full_search), 200)
    assert(t.inneholder(web.response_body(full_search), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_search), "server-renderte sider"))

    la fragment_search = web.handle_request(
        web.request_context("get", "/sok", {"q": "server"}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_search), 200)
    assert_eq(web.response_header(fragment_search, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_search), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_search), "server-renderte sider"))

    la full_posts = web.handle_request(web.request_context("get", "/poster", {"side": "2"}, {}, ""))
    assert_eq(web.response_status(full_posts), 200)
    assert(t.inneholder(web.response_body(full_posts), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_posts), "Post 3"))
    assert(t.inneholder(web.response_body(full_posts), "Post 4"))

    la fragment_posts = web.handle_request(
        web.request_context("get", "/poster", {"side": "2"}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_posts), 200)
    assert_eq(web.response_header(fragment_posts, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_posts), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_posts), "Post 3"))
    assert(t.inneholder(web.response_body(fragment_posts), "Post 4"))

    la full_posts_desc = web.handle_request(web.request_context("get", "/poster", {"side": "2", "sort": "desc"}, {}, ""))
    assert_eq(web.response_status(full_posts_desc), 200)
    assert(t.inneholder(web.response_body(full_posts_desc), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_posts_desc), "Å-A"))
    assert(t.inneholder(web.response_body(full_posts_desc), "Post 3"))
    assert(t.inneholder(web.response_body(full_posts_desc), "Post 4"))

    la full_posts_filter = web.handle_request(web.request_context("get", "/poster", {"side": "2", "kategori": "server"}, {}, ""))
    assert_eq(web.response_status(full_posts_filter), 200)
    assert(t.inneholder(web.response_body(full_posts_filter), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_posts_filter), "Serveren kan bare rendere akkurat den siden du trenger."))
    assert(usann == t.inneholder(web.response_body(full_posts_filter), "Post 4"))

    la fragment_posts_filter = web.handle_request(
        web.request_context("get", "/poster", {"side": "2", "kategori": "server"}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_posts_filter), 200)
    assert_eq(web.response_header(fragment_posts_filter, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_posts_filter), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_posts_filter), "Serveren kan bare rendere akkurat den siden du trenger."))

    la full_articles = web.handle_request(web.request_context("get", "/artikler", {}, {}, ""))
    assert_eq(web.response_status(full_articles), 200)
    assert(t.inneholder(web.response_body(full_articles), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_articles), "Artikler"))
    assert(t.inneholder(web.response_body(full_articles), "/artikler/7?visning=kort"))

    la fragment_articles = web.handle_request(
        web.request_context("get", "/artikler", {}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_articles), 200)
    assert_eq(web.response_header(fragment_articles, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_articles), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_articles), "Artikler"))
    assert(t.inneholder(web.response_body(fragment_articles), "/artikler/42?visning=kort"))

    la full_routes = web.handle_request(web.request_context("get", "/ruter", {}, {}, ""))
    assert_eq(web.response_status(full_routes), 200)
    assert(t.inneholder(web.response_body(full_routes), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_routes), "Ruter og lenker"))
    assert(t.inneholder(web.response_body(full_routes), "/sok?q=server"))

    la fragment_routes = web.handle_request(
        web.request_context("get", "/ruter", {}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_routes), 200)
    assert_eq(web.response_header(fragment_routes, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_routes), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_routes), "Ruter og lenker"))
    assert(t.inneholder(web.response_body(fragment_routes), "/artikler/7?visning=kort"))

    la full_user = web.handle_request(web.request_context("get", "/brukere/42", {}, {}, ""))
    assert_eq(web.response_status(full_user), 200)
    assert(t.inneholder(web.response_body(full_user), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_user), "Bruker 42"))

    la fragment_user = web.handle_request(
        web.request_context("get", "/brukere/42", {"visning": "kort"}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_user), 200)
    assert_eq(web.response_header(fragment_user, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_user), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_user), "Bruker 42"))
    assert(t.inneholder(web.response_body(fragment_user), "Kort visning av en server-rendret detaljside."))

    la full_article = web.handle_request(web.request_context("get", "/artikler/7", {}, {}, ""))
    assert_eq(web.response_status(full_article), 200)
    assert(t.inneholder(web.response_body(full_article), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_article), "Artikkel 7"))

    la fragment_article = web.handle_request(
        web.request_context("get", "/artikler/7", {"visning": "kort"}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_article), 200)
    assert_eq(web.response_header(fragment_article, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_article), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_article), "Artikkel 7"))
    assert(t.inneholder(web.response_body(fragment_article), "Kort visning av en server-rendret artikkel."))
    returner 0
}

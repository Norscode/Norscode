bruk std.frontend som frontend
bruk std.html som html
bruk std.web som web
bruk std.tekst som t

funksjon start() -> heltall {
    assert_eq(frontend.slot("innhold"), "innhold")
    assert_eq(
        frontend.komponent_kort("Tittel", html.p("", "Innhold")),
        "<section class=\"card panel\"><h2>Tittel</h2><div class=\"card-body\"><p>Innhold</p></div></section>"
    )
    assert_eq(
        frontend.komponent_nav(html.partial_list("", html.li("", "Hjem"))),
        "<nav class=\"nav\"><ul class=\"list\"><li>Hjem</li></ul></nav>"
    )
    assert_eq(
        frontend.komponent_liste(html.li("", "A") + html.li("", "B")),
        "<ul class=\"list\"><li>A</li><li>B</li></ul>"
    )
    assert_eq(
        frontend.komponent_tabell(html.tbody("", html.tr("", html.td("", "1")))),
        "<table class=\"table\"><tbody><tr><td>1</td></tr></tbody></table>"
    )
    assert_eq(
        frontend.nav_link("Hjem", "/"),
        "<li><a href=\"/\">Hjem</a></li>"
    )
    assert_eq(
        frontend.nav_list(frontend.nav_link("Hjem", "/")),
        "<nav class=\"nav\"><ul class=\"list\"><li><a href=\"/\">Hjem</a></li></ul></nav>"
    )
    assert(t.inneholder(
        frontend.komponent_hero("Tittel", "Ingress", html.button("", "CTA")),
        "<section class=\"hero\"><h1>Tittel</h1><p>Ingress</p><div class=\"hero__actions\"><button>CTA</button></div></section>"
    ))
    assert(t.inneholder(
        frontend.komponent_alert("Merk", "Dette er en melding"),
        "<section class=\"alert\"><h2 class=\"alert-title\">Merk</h2><p class=\"alert-body\">Dette er en melding</p></section>"
    ))
    assert(t.inneholder(
        frontend.komponent_empty("Tomt", "Ingen resultater"),
        "<section class=\"empty-state\"><h2>Tomt</h2><p>Ingen resultater</p></section>"
    ))
    assert(t.inneholder(
        frontend.komponent_loading("Laster"),
        "<section class=\"loading-state\"><span class=\"loading-state__spinner\">⏳</span><p>Laster</p></section>"
    ))
    assert(t.inneholder(
        frontend.layout_main("Demo", html.p("", "Hei")),
        "<div class=\"shell\"><p>Hei</p></div>"
    ))
    assert(t.inneholder(
        frontend.layout_app(
            "Demo",
            html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
            html.p("", "Hei"),
            "Footer"
        ),
        "<header class=\"app-header\">"
    ))
    assert(t.inneholder(
        frontend.layout_app(
            "Demo",
            html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
            html.p("", "Hei"),
            "Footer"
        ),
        "<main class=\"app-main\"><p>Hei</p></main>"
    ))
    assert(t.inneholder(
        frontend.layout_app(
            "Demo",
            html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
            html.p("", "Hei"),
            "Footer"
        ),
        "<footer class=\"app-footer\"><p>Footer</p></footer>"
    ))
    la full_status = web.handle_request(web.request_context("get", "/status", {}, {}, ""))
    assert_eq(web.response_status(full_status), 200)
    assert(t.inneholder(web.response_body(full_status), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_status), "<section class=\"card panel\">"))

    la fragment_status = web.handle_request(
        web.request_context("get", "/status", {}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_status), 200)
    assert_eq(web.response_header(fragment_status, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_status), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_status), "<section class=\"card panel\">"))
    la full_docs = web.handle_request(web.request_context("get", "/docs", {}, {}, ""))
    assert_eq(web.response_status(full_docs), 200)
    assert(t.inneholder(web.response_body(full_docs), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(full_docs), "<h2>Dokumentasjon</h2>"))
    la fragment_docs = web.handle_request(
        web.request_context("get", "/docs", {}, {"x-norscode-fragment": "1"}, "")
    )
    assert_eq(web.response_status(fragment_docs), 200)
    assert_eq(web.response_header(fragment_docs, "x-norscode-fragment"), "1")
    assert(t.inneholder(web.response_body(fragment_docs), "<section class=\"fragment-shell\">"))
    assert(t.inneholder(web.response_body(fragment_docs), "<h2>Dokumentasjon</h2>"))
    returner 0
}

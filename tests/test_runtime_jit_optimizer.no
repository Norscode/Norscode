bruk std.runtime_jit_optimizer som optimizer

funksjon start() -> heiltall {
    la plan = optimizer.optimaliser(["const:2", "const:3", "add", "arg:0", "const:0", "add"])
    assert_eq(plan["operations"][0], "const:5")
    assert_eq(plan["operations"][1], "arg:0")
    assert_eq(plan["constant_folds"], "1")
    assert_eq(plan["identity_reductions"], "1")
    assert(builtin.heltall_fra_tekst(plan["ssa_values"]) > 0)
    assert(builtin.heltall_fra_tekst(plan["registers"]) > 0)
    assert_eq(optimizer.produksjonsstatus()["status"], "stabil")
    skriv("test_runtime_jit_optimizer OK")
    returner 0
}

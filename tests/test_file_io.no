funksjon bygg_blokk(storleik: heltall) -> tekst {
    la out = ""
    la i: heltall = 0
    mens i < storleik {
        out = out + "x"
        i = i + 1
    }
    returner out
}

funksjon start() -> heltall {
    la text_sti = "/tmp/norscode_native_io_text.txt"
    la bin_sti = "/tmp/norscode_native_io_bin.txt"
    la innhald = bygg_blokk(1024)
    la forventet_lengde = 1024
    la stort_innhald = bygg_blokk(400000)
    la stor_sti = "/tmp/norscode_native_io_large.txt"

    fil_skriv(text_sti, innhald)
    assert(fil_finnes(text_sti))
    la lest = fil_les(text_sti)
    assert_eq(lengde(lest), forventet_lengde)
    assert_eq(lest, innhald)

    fil_skriv_binar(bin_sti, [65, 66, 67, 120, 121, 122])
    la lest_bin = fil_les(bin_sti)
    assert_eq(lest_bin, "ABCxyz")

    fil_skriv(stor_sti, stort_innhald)
    assert(fil_finnes(stor_sti))
    la lest_stort = fil_les(stor_sti)
    assert_eq(lengde(lest_stort), 400000)
    assert_eq(lest_stort, stort_innhald)

    returner 0
}

bruk selfhost.formatter som formatter

funksjon start() -> heiltall {
    la kjelde = "# toppkommentar\nla melding = \"linje1\\nlinje2\\t\\\"sitat\\\"\\\\sti\" # linjekommentar\n// sluttkommentar\n"
    la formatert = formatter.format_kjelde(kjelde)

    assert(builtin.contains(formatert, "\"linje1\\nlinje2\\t\\\"sitat\\\"\\\\sti\""))
    assert(ikkje builtin.contains(formatert, "linje1\nlinje2"))
    assert(builtin.contains(formatert, "# toppkommentar"))
    assert(builtin.contains(formatert, "# linjekommentar"))
    assert(builtin.contains(formatert, "// sluttkommentar"))
    returner 0
}

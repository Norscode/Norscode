bruk std.tekst som t

funksjon start() -> heiltall {
    la kernel_src = fil_les("selfhost/native_execution/kernel_v2.no")
    assert(t.inneholder(kernel_src, "rel8 blir patchet når check_exit-adressa er kjend"))
    assert(ikkje t.inneholder(kernel_src, "legg_til(b, 0)  // placeholder"))

    la phase1_src = fil_les("selfhost/native_execution/phase1_native_backend_complete.no")
    assert(t.inneholder(phase1_src, "Prolog-byte: push rbp; mov rbp,rsp."))
    assert(t.inneholder(phase1_src, "CALL rel32 med null-offset inntil relocation/patching set endeleg mål"))
    assert(ikkje t.inneholder(phase1_src, "placeholder real bytes"))
    assert(ikkje t.inneholder(phase1_src, "CALL rel32 placeholder"))

    la ncb_src = fil_les("selfhost/native_execution/ncb_to_elf.no")
    assert(t.inneholder(ncb_src, "Returverdi for void-liknande write-kall"))
    assert(ikkje t.inneholder(ncb_src, "Returverdi (dummy null)"))

    la codegen_src = fil_les("selfhost/native_execution/native_codegen_v2.no")
    assert(t.inneholder(codegen_src, "legg på ein null-retur"))
    assert(ikkje t.inneholder(codegen_src, "legg på ein dummy null"))

    la codegen_v1_src = fil_les("selfhost/native_execution/native_codegen.no")
    assert(t.inneholder(codegen_v1_src, "Pop element frå stack før listeallokeringa"))
    assert(t.inneholder(codegen_v1_src, "Førebels kontrakt: initialiseringsverdiar blir droppa i denne vegen"))
    assert(ikkje t.inneholder(codegen_v1_src, "Pop element frå stack til midlertidig lagring"))
    assert(ikkje t.inneholder(codegen_v1_src, "ikkje støttar initialisering enno"))

    la safety_src = fil_les("selfhost/security/safety_core.no")
    assert(t.inneholder(safety_src, "Rate-limiting (minimal teljarkontrakt)"))
    assert(t.inneholder(safety_src, "Minimal kontrakt: kall utan aktiv teljarbackend er under grensa"))
    assert(ikkje t.inneholder(safety_src, "teljarstubbe"))
    assert(ikkje t.inneholder(safety_src, "Stub"))

    skriv("test_native_execution_contract_text OK")
    returner 0
}

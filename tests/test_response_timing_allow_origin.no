funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nTiming-Allow-Origin: *\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "timing_allow_origin": "*", "body": "hei"})
    assert_eq(builtin.contains(resp, "Timing-Allow-Origin: *"), sann)
    returner 0
}

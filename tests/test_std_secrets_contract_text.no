bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/secrets.no")

    assert(t.inneholder(src, "Minimal deterministisk hash-kontrakt for lokal verifisering"))
    assert(t.inneholder(src, "ikkje kryptografisk"))
    assert(ikkje t.inneholder(src, "hash for testing"))

    skriv("test_std_secrets_contract_text OK")
    returner 0
}

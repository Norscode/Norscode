bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/secrets.no")

    assert(t.inneholder(src, "kast \"secrets krev builtin.sha256\""))
    assert(t.inneholder(src, "kast \"secrets krev builtin.random_hex\""))
    assert(t.inneholder(src, "funksjon passord_hash_ny(passord: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon krev_hemmelighet(nokkel: tekst) -> tekst"))
    assert(ikkje t.inneholder(src, "hash for testing"))
    assert(ikkje t.inneholder(src, "ikkje kryptografisk"))

    skriv("test_std_secrets_contract_text OK")
    returner 0
}

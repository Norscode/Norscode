bruk selfhost.vm

funksjon start() -> heiltall {
    skriv("lookup: read\n")
    la vm_ncb = json_parse_raw(fil_les("bootstrap/precompiled/vm.ncb.json"))
    skriv("lookup: functions\n")
    la vm_fns = vm_ncb["functions"]
    skriv("lookup: keys\n")
    la keys = nøkler(vm_fns)
    skriv("lookup: key_count=" + tekst(lengde(keys)) + "\n")
    hvis ikke vm_map_har_nokkel(vm_fns, "__main__.start") {
        skriv("lookup: missing start\n")
        returner 1
    }
    skriv("lookup: has start\n")
    la løyst = finn_funksjon("__main__.start", vm_fns)
    skriv("lookup: resolved=" + løyst + "\n")
    hvis løyst != "__main__.start" {
        returner 1
    }
    returner 0
}

bruk selfhost.vm som vm

funksjon start() -> heiltall {
    la functions = {
        "__main__.parent": {
            "params": [],
            "code": [
                ["PUSH_CONST", 41],
                ["CALL", "__main__.child", 1],
                ["PUSH_CONST", 0],
                ["BINARY_ADD"],
                ["RETURN"]
            ],
            "source_lines": [10, 10, 11, 11, 12],
            "source_columns": [5, 5, 5, 5, 5]
        },
        "__main__.child": {
            "params": ["x"],
            "code": [
                ["LOAD_NAME", "x"],
                ["PUSH_CONST", 1],
                ["BINARY_ADD"],
                ["RETURN"]
            ],
            "source_lines": [20, 20, 20, 20],
            "source_columns": [9, 13, 11, 5]
        }
    }

    vm.vm_runtime_init(functions, sann)
    functions["__vm_debug__"]["enabled"] = "sann"
    assert(vm.vm_debug_suspend_on_hit(functions, sann))
    assert(vm.vm_debug_breakpoint_add(functions, "__main__.child", 0))
    assert(vm.vm_debug_watch_add(functions, "x"))
    assert(vm.vm_debug_watch_add(functions, "manglar"))

    la pause = vm.køyr_funksjon("__main__.parent", [], functions, 0)
    assert_eq(pause["status"], "paused")
    assert_eq(pause["function"], "__main__.child")
    assert_eq(pause["ip"], "0")
    assert_eq(functions["__vm_debug__"]["last_line"], "20")
    assert_eq(functions["__vm_debug__"]["last_column"], "9")
    assert_inneholder(functions["__vm_debug__"]["last_watches"], "41")
    assert_inneholder(functions["__vm_debug__"]["last_watches"], "<undefined>")
    assert_eq(lengde(functions["__vm_active_frames__"]), 2)
    assert_eq(functions["__vm_active_frames__"][0]["state"], "waiting")
    assert_eq(functions["__vm_active_frames__"][1]["state"], "paused")

    la svar = vm.vm_debug_resume(functions, "continue")
    assert_eq(svar, 42)
    assert_eq(lengde(functions["__vm_active_frames__"]), 0)
    assert_eq(functions["__vm_debug__"]["paused"], "usann")
    assert_eq(functions["__vm_debug__"]["pause_count"], "1")

    assert(vm.vm_debug_breakpoint_remove(functions, "__main__.child", 0))
    assert(ikkje vm.vm_debug_breakpoint_remove(functions, "__main__.child", 0))
    assert(vm.vm_debug_breakpoint_add(functions, "__main__.parent", 0))
    la pause2 = vm.køyr_funksjon("__main__.parent", [], functions, 0)
    assert_eq(pause2["function"], "__main__.parent")
    la pause3 = vm.vm_debug_resume(functions, "step_line")
    assert_eq(pause3["status"], "paused")
    assert_eq(pause3["function"], "__main__.child")
    assert_eq(pause3["ip"], "0")
    assert_eq(functions["__vm_debug__"]["last_line"], "20")
    assert_eq(vm.vm_debug_breakpoints_clear(functions), 1)
    assert(vm.vm_debug_watch_remove(functions, "manglar"))
    assert_eq(vm.vm_debug_watches_clear(functions), 1)
    assert_eq(vm.vm_debug_resume(functions, "continue"), 42)
    returner 0
}

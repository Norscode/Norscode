funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "request_middlewares": [],
        "response_middlewares": [],
        "error_middlewares": []
    }
slutt

funksjon register_request_middleware(server, namn)
    legg_til(server["request_middlewares"], namn)
    returner server
slutt

funksjon register_response_middleware(server, namn)
    legg_til(server["response_middlewares"], namn)
    returner server
slutt

funksjon register_error_middleware(server, namn)
    legg_til(server["error_middlewares"], namn)
    returner server
slutt

funksjon request_context(metode, sti, path, headers, body)
    returner {
        "__request_middleware_trace__": []
    }
slutt

funksjon anvend_request_middlewares(server, ctx)
    ctx["__request_middleware_trace__"] = server["request_middlewares"]
    returner ctx
slutt

funksjon response_builder(status, headers, body)
    returner {
        "status": status,
        "body": body
    }
slutt

funksjon anvend_response_middlewares(server, response)
    response["__response_middleware_trace__"] = server["response_middlewares"]
    returner response
slutt

funksjon anvend_error_middlewares(server, response)
    response["__error_middleware_trace__"] = server["error_middlewares"]
    returner response
slutt

funksjon start() -> heiltall {
    la server = ny_server(8085)
    register_request_middleware(server, "auth")
    register_request_middleware(server, "request-id")
    register_response_middleware(server, "cors")
    register_error_middleware(server, "error-json")

    la ctx = request_context("GET", "/hei", {}, {}, "")
    la ctx2 = anvend_request_middlewares(server, ctx)
    la request_trace = ctx2["__request_middleware_trace__"]
    assert_eq(lengde(request_trace), 2)
    assert_eq(request_trace[0], "auth")
    assert_eq(request_trace[1], "request-id")

    la response = response_builder(200, {}, "ok")
    la response2 = anvend_response_middlewares(server, response)
    la response_trace = response2["__response_middleware_trace__"]
    assert_eq(lengde(response_trace), 1)
    assert_eq(response_trace[0], "cors")

    la error_response = response_builder(500, {}, "feil")
    la error_response2 = anvend_error_middlewares(server, error_response)
    la error_trace = error_response2["__error_middleware_trace__"]
    assert_eq(lengde(error_trace), 1)
    assert_eq(error_trace[0], "error-json")

    returner 0
}

bruk std.sched som sched

funksjon svar(args: ordbok_tekst) -> tekst { returner "ok:" + args["verdi"] }

funksjon start() -> heltall {
    la s = sched.ny()
    la args: ordbok_tekst = {}
    args["verdi"] = "42"
    la future = sched.opprett_oppgave(s, 0, 1, "__main__.svar", args)
    la event = sched.neste_hending(s)
    assert(sched._koyr_event(s, event))
    assert_eq(sched.future_status(s, future), "ferdig")
    assert_eq(sched.future_resultat(s, future), "ok:42")
    returner 0
}

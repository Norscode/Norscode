bruk std.transactional_storage som storage
bruk std.db som db

funksjon start() -> heiltall {
    la db_sti = "/tmp/norscode-storage-restore.sqlite"
    la backup_sti = "/tmp/norscode-storage-restore.backup.sqlite"
    prøv { builtin.fil_slett(db_sti) } fang (e) {}
    prøv { builtin.fil_slett(backup_sti) } fang (e) {}
    la h = storage.opne(db_sti)
    assert(storage.migrer(h, "CREATE TABLE IF NOT EXISTS probe (id INTEGER PRIMARY KEY, value TEXT);"))
    assert(db.execute(h, "INSERT INTO probe (value) VALUES ('before');") >= 0)
    assert(storage.backup(h, backup_sti))
    assert(db.close(h))
    la restored = storage.restore(backup_sti, db_sti)
    assert_eq(db.query_text(restored, "SELECT value FROM probe LIMIT 1"), "before")
    assert(db.close(restored))
    builtin.exec_prosess("rm -f '" + db_sti + "' '" + backup_sti + "'")
    skriv("test_storage_restore OK\n")
    returner 0
}

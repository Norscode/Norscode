bruk std.tekst som t

funksjon start() -> heiltall {
    la parser_src = fil_les("std/compiler/parser_runtime.no")
    la driver_src = fil_les("std/compiler/compiler_driver_runtime.no")

    assert(t.inneholder(parser_src, "funksjon parse_program_runtime"))
    assert(t.inneholder(parser_src, "[parser] parse program runtime-kontrakt"))
    assert(t.inneholder(driver_src, "parse_program_runtime("))
    assert(ikkje t.inneholder(parser_src, "parse_program_placeholder"))
    assert(ikkje t.inneholder(parser_src, "parse program placeholder"))
    assert(ikkje t.inneholder(driver_src, "parse_program_placeholder"))

    skriv("test_compiler_parser_runtime_contract_text OK")
    returner 0
}

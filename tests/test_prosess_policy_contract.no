bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la src = fil_les("std/prosess.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(src, "funksjon policy_av() -> ordbok_tekst")
    krev(src, "\"aktiv\": \"usann\"")
    krev(src, "\"shell\": \"av\"")
    krev(src, "funksjon policy_tillat(tillatne: liste_tekst) -> ordbok_tekst")
    krev(src, "funksjon policy_tillater(policy: ordbok_tekst, kommando: tekst) -> bool")
    krev(src, "funksjon _har_shell_metategn(kommando: tekst) -> bool")
    krev(src, "_tekst_inneheld(kommando, \";\")")
    krev(src, "_tekst_inneheld(kommando, \"|\")")
    krev(src, "_tekst_inneheld(kommando, \"$\")")
    krev(src, "funksjon køyr_med_policy(kommando: tekst, policy: ordbok_tekst) -> liste_tekst")
    krev(src, "exec_prosess blokkert av policy")
    krev(src, "returner køyr(kommando)")

    krev(manual, "`std.prosess.køyr_med_policy(...)`")

    skriv("test_prosess_policy_contract OK")
    returner 0
}

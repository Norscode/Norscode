bruk std.runtime_memory som memory

funksjon fri(h: ordbok_tekst, steg: tekst) -> bool {
    la lock = h["allocator_lock"]
    assert_eq(lock["owner"], "")
    assert_eq(heltall_fra_tekst(lock["depth"]), 0)
    returner sann
}

funksjon start() -> heiltall {
    la h = memory.ny_heap()
    la a = memory.alloker(h, "kart", 8)
    la b = memory.alloker(h, "tekst", 8)
    assert(fri(h, "alloker"))
    assert(memory.legg_rot(h, a))
    assert(memory.legg_rot(h, b))
    assert(fri(h, "rot"))
    assert(memory.legg_ref(h, a, b))
    assert(fri(h, "legg-ref"))
    assert(memory.objekt_skriv_byte(h, a, 0, 42))
    assert(fri(h, "skriv"))
    assert_eq(memory.mark(h), 2)
    assert(fri(h, "mark"))
    assert_eq(memory.sweep(h), 0)
    assert(fri(h, "sweep"))
    assert(memory.fjern_ref(h, a, b))
    assert(fri(h, "fjern-ref"))
    assert_eq(memory.collect(h)["alive"], "2")
    assert(fri(h, "collect"))
    assert_eq(memory.compact(h)["status"], "ferdig")
    assert(fri(h, "compact"))
    assert_eq(memory.nullstill_roter(h), 2)
    assert(fri(h, "nullstill"))
    skriv("test_runtime_memory_lock_lifecycle OK")
    returner 0
}

bruk std.model_runtime som modell
bruk std.qmodel_binary som binar

funksjon lag_modell() {
    la m = modell.ny("binary-q8", 2)
    assert(modell.legg_til_lag(m, modell.dense(2, 2, [2, -3, 4, 5], [-1000, 2000], 10, "hard_tanh")))
    returner m
}

funksjon start() -> heiltall {
    la m = lag_modell()
    la data = binar.kod(m)
    assert_eq(data[0], 78)
    assert_eq(data[1], 81)
    assert_eq(data[2], 77)
    assert_eq(data[3], 49)
    la lasta = binar.dekod(data, 100)
    la a = modell.kjor(m, [3, 7])
    la b = modell.kjor(lasta, [3, 7])
    assert_eq(a[0], b[0])
    assert_eq(a[1], b[1])
    assert_eq(lasta["navn"], "binary-q8")
    skriv("test_qmodel_binary OK\n")
    returner 0
}

funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "routes": {}
    }
slutt

funksjon route(server, metode, sti, handler)
    server["routes"][metode + " " + sti] = handler
    returner server
slutt

funksjon hent_route_handler(server, metode, sti)
    la eksakt = metode + " " + sti
    hvis server["routes"][eksakt] != ingenting
        returner server["routes"][eksakt]
    slutt
    returner ""
slutt

funksjon parse_http_request(tekst_input)
    returner {
        "__method__": "GET",
        "__path__": "/sok",
        "__query__": {"q": "test"},
        "__headers__": {"x-test": "ja"},
        "__body__": "body"
    }
slutt

funksjon start() -> heiltall {
    la server = ny_server(9090)
    route(server, "GET", "/brukarar/42", "eksakt")
    route(server, "GET", "/brukarar/{id:int}", "param")

    la eksakt = hent_route_handler(server, "GET", "/brukarar/42")
    la param = hent_route_handler(server, "GET", "/brukarar/{id:int}")
    la manglar = hent_route_handler(server, "GET", "/ukjent")

    assert_eq(eksakt, "eksakt")
    assert_eq(param, "param")
    assert_eq(manglar, "")

    la req = parse_http_request("GET /sok?q=test HTTP/1.1\r\nHost: example.test\r\nX-Test: ja\r\n\r\nbody")
    assert_eq(req["__method__"], "GET")
    assert_eq(req["__path__"], "/sok")
    assert_eq(req["__query__"]["q"], "test")
    assert_eq(req["__headers__"]["x-test"], "ja")
    assert_eq(req["__body__"], "body")
    returner 0
}

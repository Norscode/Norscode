bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la stil = fil_les("std/stil.no")
    la test_kilde = fil_les("tests/test_stil.no")
    la plan = fil_les("docs/frontend/NORSK_STILARK_PLAN.md")
    la tokens = fil_les("docs/frontend/FRONTEND_DESIGN_TOKENS.md")
    la model = fil_les("docs/frontend/FRONTEND_MODEL.md")

    krev(stil, "funksjon repeat(")
    krev(stil, "repeat-antall")
    krev(stil, "funksjon minmax_spor(")
    krev(stil, "minmax-minimum")
    krev(stil, "funksjon fit_content(")
    krev(stil, "fit-content-verdi")
    krev(stil, "funksjon grid_kolonner(")
    krev(stil, "grid-kolonner")
    krev(stil, "funksjon flex_rad(")
    krev(stil, "flex-rad-gap")
    krev(stil, "funksjon flex_kolonne(")
    krev(stil, "flex-kolonne-gap")

    krev(test_kilde, "stil.repeat(\"auto-fit\", stil.minmax_spor")
    krev(test_kilde, "grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));")
    krev(test_kilde, "grid-template-rows: fit-content(12rem) minmax(0, 1fr);")
    krev(test_kilde, "stil.flex_rad(stil.rem(\"0.5\"))")
    krev(test_kilde, "stil.flex_kolonne(stil.rem(\"1\"))")
    krev(test_kilde, "flex-rad-gap")

    krev(plan, "## Omgang 8: Layout-hjelparar")
    krev(plan, "repeat(...)")
    krev(plan, "minmax(...)")
    krev(plan, "fit-content(...)")
    krev(plan, "grid/flex-layoutar")

    krev(tokens, "layout-hjelparar")
    krev(tokens, "grid_kolonner(...)")
    krev(tokens, "flex_rad(...)")
    krev(model, "grid_kolonner(...)")
    krev(model, "flex_rad(...)")

    returner 0
}

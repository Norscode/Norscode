bruk std.runtime.allocator som alloc

funksjon start() -> heiltall {
    la a = alloc.ny_allocator(4096, 64)
    la p1 = alloc.alloker(a, 1)
    la p2 = alloc.alloker(a, 9)
    assert_eq(p1, 4096)
    assert_eq(p2, 4104)
    assert(alloc.aktiv(a, p1))
    assert(alloc.frigjor(a, p1))
    assert(ikkje alloc.frigjor(a, p1))

    la p3 = alloc.alloker(a, 8)
    assert_eq(p3, p1)
    assert(alloc.aktiv(a, p3))
    la p4 = alloc.alloker(a, 40)
    assert_eq(p4, 4120)
    assert_eq(alloc.alloker(a, 1), -1)

    la s = alloc.statistikk(a)
    assert_eq(s["capacity"], "64")
    assert_eq(s["reserved_bytes"], "64")
    assert_eq(s["allocated_count"], "3")
    assert_eq(s["active_count"], "3")
    assert_eq(s["freed_count"], "1")
    assert_eq(s["reused_count"], "1")
    assert_eq(s["failed_count"], "1")

    la b = alloc.ny_allocator(100, 64)
    la q1 = alloc.alloker(b, 8)
    la q2 = alloc.alloker(b, 8)
    la q3 = alloc.alloker(b, 8)
    assert(alloc.skriv_bytes(b, q2, [10, 20, 30, 40]))
    assert(alloc.skriv_bytes(b, q3, [50, 60, 70, 80]))
    assert(ikkje alloc.skriv_byte(b, q3 + 8, 1))
    assert_eq(alloc.les_byte(b, q3 + 8), -1)
    assert(alloc.frigjor(b, q1))
    la compact = alloc.kompakter(b)
    assert_eq(compact["status"], "ferdig")
    assert_eq(compact["moved"], "2")
    assert_eq(alloc.relokert_adresse(b, q2), 100)
    assert_eq(alloc.relokert_adresse(b, q3), 108)
    la flytta_q2 = alloc.les_bytes(b, 100, 4)
    la flytta_q3 = alloc.les_bytes(b, 108, 4)
    assert_eq(lengde(flytta_q2), 4)
    assert_eq(flytta_q2[0], 10)
    assert_eq(flytta_q2[1], 20)
    assert_eq(flytta_q2[2], 30)
    assert_eq(flytta_q2[3], 40)
    assert_eq(lengde(flytta_q3), 4)
    assert_eq(flytta_q3[0], 50)
    assert_eq(flytta_q3[1], 60)
    assert_eq(flytta_q3[2], 70)
    assert_eq(flytta_q3[3], 80)
    assert_eq(alloc.alloker(b, 8), 116)

    la c = alloc.ny_allocator(200, 16)
    la r1 = alloc.alloker(c, 8)
    assert(alloc.skriv_byte(c, r1, 99))
    assert(alloc.frigjor(c, r1))
    la r2 = alloc.alloker(c, 8)
    assert_eq(r2, r1)
    assert_eq(alloc.les_byte(c, r2), 0)

    skriv("test_runtime_allocator OK")
    returner 0
}

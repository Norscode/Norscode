bruk std.tekst som t

funksjon start() -> heiltall {
    la path_src = fil_les("selfhost/std/path.no")
    assert(t.inneholder(path_src, "readable file exists in the selfhost runtime"))
    assert(t.inneholder(path_src, "outside this minimal std.path contract"))
    assert(ikkje t.inneholder(path_src, "This is a stub"))
    assert(ikkje t.inneholder(path_src, "file/directory exists"))

    la web_src = fil_les("selfhost/std/web.no")
    assert(t.inneholder(web_src, "default response object for the minimal selfhost web contract"))
    assert(t.inneholder(web_src, "Route dispatch can be layered on top"))
    assert(ikkje t.inneholder(web_src, "stub implementation"))
    assert(ikkje t.inneholder(web_src, "In a real implementation"))

    skriv("test_selfhost_std_contract_text OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la regen = fil_les("tools/nc_regen_bootstrap.no")
    assert(t.inneholder(regen, "builtin.replace(mod, \"/\", \"_\")"))
    assert(t.inneholder(regen, "builtin.ends_with(name, \".no\")"))
    assert(t.inneholder(regen, "la innhald = builtin.fil_les(sti)"))
    assert(t.inneholder(regen, "returner tekst_fra_heltall(lengde(innhald))"))
    assert(ikkje t.inneholder(regen, "sed 's|/|_|g'"))
    assert(ikkje t.inneholder(regen, "printf '%s' \" + shell(mod)"))

    la backup = fil_les("tools/backup_stage0_before_random_hex_v734.no")
    assert(t.inneholder(backup, "builtin.replace(rel, \"/\", \"_\")"))
    assert(t.inneholder(backup, "returner miljo_hent(namn)"))
    assert(t.inneholder(backup, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(backup, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(backup, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(backup, "tr '/' '_'"))
    assert(ikkje t.inneholder(backup, "printf '%s' \" + shell(rel)"))

    la maintenance = fil_les("tools/selfhost_maintenance_verify.no")
    assert(t.inneholder(maintenance, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(maintenance, "builtin.index_of(fil_les(sti), pattern)"))
    assert(t.inneholder(maintenance, "release/install-flaten krev ikkje C-verktøykjede"))
    assert(ikkje t.inneholder(maintenance, "release/install-flaten krever ikke C-verktøykjede"))
    assert(ikkje t.inneholder(maintenance, "grep -F -q"))

    skriv("test_bootstrap_text_ops_no_shell OK")
    returner 0
}

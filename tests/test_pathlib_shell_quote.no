bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/pathlib.no")
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "returner builtin.fil_finnes(p[\"sti\"])"))
    assert(t.inneholder(src, "find -H \" + _shell(p[\"sti\"]) + \" -maxdepth 0 -type f -print"))
    assert(t.inneholder(src, "find -H \" + _shell(p[\"sti\"]) + \" -maxdepth 0 -type d -print"))
    assert(t.inneholder(src, "test -L \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))
    assert(t.inneholder(src, "mkdir -p \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "mkdir \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "rm \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "rmdir \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "rm -rf \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "mv \" + _shell(p[\"sti\"]) + \" \" + _shell(ny_sti[\"sti\"])"))
    assert(t.inneholder(src, "stat -c %s \" + _shell(p[\"sti\"])"))
    assert(t.inneholder(src, "find \" + _shell(p[\"sti\"]) + \" -mindepth 1 -maxdepth 1 -print"))
    assert(t.inneholder(src, "find \" + _shell(p[\"sti\"]) + \" -mindepth 1 -maxdepth 1 -name \" + _shell(mønster)"))
    assert(t.inneholder(src, "find \" + _shell(p[\"sti\"]) + \" -mindepth 1 -name \" + _shell(mønster)"))

    assert(ikkje t.inneholder(src, "test -e \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "test -e \" + _shell(p[\"sti\"])"))
    assert(ikkje t.inneholder(src, "test -f \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "test -f \" + _shell(p[\"sti\"])"))
    assert(ikkje t.inneholder(src, "test -d \" + _shell(p[\"sti\"])"))
    assert(ikkje t.inneholder(src, "test -d \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "test -L \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "&& echo ja || echo nei"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "mkdir \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "rm \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "rmdir \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "rm -rf \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "mv \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "stat -c %s \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "ls -1a \" + _shell(p[\"sti\"])"))
    assert(ikkje t.inneholder(src, "ls -1a \" + p[\"sti\"]"))
    assert(ikkje t.inneholder(src, "ls -d1 \" + full_mønster"))
    assert(ikkje t.inneholder(src, "find \" + p[\"sti\"]"))

    skriv("test_pathlib_shell_quote OK")
    returner 0
}

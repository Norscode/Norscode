bruk std.tekst som t

funksjon start() -> heiltall {
    la audit = fil_les("tools/python_dependency_audit.no")
    assert(t.inneholder(audit, "builtin.fil_skriv(output_file, rapport)"))
    assert(t.inneholder(audit, "funksjon py_filer(filer: tekst) -> liste_tekst"))
    assert(t.inneholder(audit, "funksjon alle_filer(root: tekst, under: tekst) -> tekst"))
    assert(t.inneholder(audit, "find \" + shell(base)"))
    assert(t.inneholder(audit, "builtin.ends_with(fil, \".py\")"))
    assert(ikkje t.inneholder(audit, "| rg '\\\\.py$'"))
    assert(ikkje t.inneholder(audit, "rg --files"))
    assert(ikkje t.inneholder(audit, "rg --files -g '*.py'"))
    assert(ikkje t.inneholder(audit, "printf '%s'"))
    assert(ikkje t.inneholder(audit, "la escaped ="))

    la omgang6 = fil_les("tools/verify_omgang6.no")
    assert(t.inneholder(omgang6, "builtin.fil_skriv(sti, innhald)"))
    assert(t.inneholder(omgang6, "builtin.fil_finnes(sti)"))
    assert(t.inneholder(omgang6, "builtin.index_of(run_out, forvent)"))
    assert(t.inneholder(omgang6, "funksjon les_fil_trygt(sti: tekst) -> tekst"))
    assert(t.inneholder(omgang6, "returner les_fil_trygt(a) == les_fil_trygt(b)"))
    assert(ikkje t.inneholder(omgang6, "printf '%s' \" + shell(innhald)"))
    assert(ikkje t.inneholder(omgang6, "| grep -q \" + shell(forvent)"))
    assert(ikkje t.inneholder(omgang6, "cmp -s "))
    assert(ikkje t.inneholder(omgang6, "test -f \" + shell(sti)"))
    assert(ikkje t.inneholder(omgang6, "test -x "))

    skriv("test_audit_and_omgang6_no_shell_text OK")
    returner 0
}

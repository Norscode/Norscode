bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/imaplib.no")
    assert(t.inneholder(src, "Vanleg IMAP brukar Norscode socket først"))
    assert(t.inneholder(src, "IMAPS/TLS"))
    assert(t.inneholder(src, "TLS-socket"))
    assert(ikkje t.inneholder(src, "via IMAP via curl"))
    assert(t.inneholder(src, "funksjon _shell(verdi: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(verdi, \"'\""))
    assert(t.inneholder(src, "bruk std.socket som sok"))
    assert(t.inneholder(src, "funksjon _socket_imap(c: ordbok_tekst, kommando: tekst) -> tekst"))
    assert(t.inneholder(src, "sok.tilkoble(s, c[\"vert\"], heltall_fra_tekst(c[\"port\"]))"))
    assert(t.inneholder(src, "sok.send(s, innhald)"))
    assert(t.inneholder(src, "la res = _socket_imap(c, \"LIST \\\"\\\" \\\"*\\\"\")"))
    assert(t.inneholder(src, "la res = _socket_imap(c, \"SEARCH \" + kriterie)"))
    assert(t.inneholder(src, "la rå = _socket_imap(c, \"UID FETCH \" + melding_id + \" BODY[]\")"))
    assert(t.inneholder(src, "la svar = _socket_imap(c, \"UID STORE \" + melding_id + \" +FLAGS (\\\\Seen)"))
    assert(t.inneholder(src, "la svar = _socket_imap(c, \"UID STORE \" + melding_id + \" +FLAGS (\\\\Deleted)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 5 --max-time 5 \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 10 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "--request \" + _shell(kommando)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 15 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 15 --max-time 30 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(t.inneholder(src, "curl -s --connect-timeout 15 --max-time 60 -u \" + _shell(auth) + \" \" + _shell(url)"))
    assert(ikkje t.inneholder(src, "-u \\\"\" + brukar"))
    assert(ikkje t.inneholder(src, "\" + brukar + \":\" + passord + \""))
    assert(ikkje t.inneholder(src, "\" + url + \" 2>&1"))
    assert(ikkje t.inneholder(src, "\\\"\" + url + \"\\\""))
    assert(ikkje t.inneholder(src, "--request \\\"\" + kommando"))
    assert(ikkje t.inneholder(src, "| head -1"))
    assert(ikkje t.inneholder(src, "| head -3"))

    skriv("test_imaplib_shell_quote OK")
    returner 0
}

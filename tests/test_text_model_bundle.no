bruk std.text_model_bundle som bundle
bruk std.text_generation som tekstgen
bruk std.transformer som transformer
bruk std.tokenizer som tokenizer
bruk std.sampling som sampling
bruk std.model_trust som tillit

funksjon bygg() {
    la tok = tokenizer.ny(["?", "a", "b", " "], 0, -1, -1, 20)
    la embedding: liste_heiltall = [1, 0, 0, 1, 1, 1, 2, 1]
    la lm: liste_heiltall = [2, 0, 1, 3, 0, 2, 1, 1]
    la m = tekstgen.ny("bundle-mini", 4, 2, embedding, lm, [0, 0, 0, 0], 1, 8)
    la identitet: liste_heiltall = [1, 0, 0, 1]
    assert(tekstgen.legg_til_blokk(m, transformer.blokk(2, 2,
        identitet, identitet, identitet, identitet,
        identitet, [0, 0], identitet, [0, 0], 1)))
    returner {"modell": m, "tokenizer": tok}
}

funksjon start() -> heiltall {
    la original = bygg()
    la data = bundle.kod(original["modell"], original["tokenizer"])
    assert_eq(data[0], 78)
    assert_eq(data[1], 84)
    assert_eq(data[2], 77)
    assert_eq(data[3], 49)
    la tr = tillit.ny(1)
    assert(tillit.tillat(tr, "mini-v1", tillit.hash_bytes(data)))
    la lasta = bundle.dekod_verifisert(tr, "mini-v1", data, 1000)
    assert_eq(lasta["modell"]["navn"], "bundle-mini")
    assert_eq(lasta["modell"]["vocab"], 4)
    assert(lasta["parametre"] > 0)
    la samplar = sampling.ny(5, 1, 100, 0, 2, -1)
    la resultat = tekstgen.generer_tekst(lasta["modell"], lasta["tokenizer"], "a", samplar, 2)
    assert_eq(lengde(resultat["nye_token"]), 2)

    skriv("test_text_model_bundle OK\n")
    returner 0
}

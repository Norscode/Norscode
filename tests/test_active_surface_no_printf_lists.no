bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/no_c_python_active_surface.no")

    assert(t.inneholder(src, "funksjon collect_c_hits(root: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "funksjon sortert_unik(verdiar: liste_tekst) -> liste_tekst"))
    assert(t.inneholder(src, "funksjon collect_ref_files(root: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "funksjon ref_file_allowed(root: tekst, fil: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon fil_ref_hits(fil: tekst) -> tekst"))
    assert(t.inneholder(src, "data = builtin.fil_les(fil)"))
    assert(t.inneholder(src, "funksjon linje_har_ref(line: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "bruk std.liste som liste"))
    assert(t.inneholder(src, "liste.sorter_tekst(verdiar)"))
    assert(t.inneholder(src, "find \" + shell(root)"))
    assert(t.inneholder(src, "find \" + shell(root + \"/bin\")"))
    assert(ikkje t.inneholder(src, "while IFS= read -r rel"))
    assert(ikkje t.inneholder(src, "printf '%s/%s"))
    assert(ikkje t.inneholder(src, "printf '%s\\n'"))
    assert(ikkje t.inneholder(src, "| sort"))
    assert(ikkje t.inneholder(src, "sort -u"))
    assert(ikkje t.inneholder(src, "xargs rg"))
    assert(ikkje t.inneholder(src, "command -v rg"))
    assert(ikkje t.inneholder(src, "rg -n --with-filename"))
    assert(ikkje t.inneholder(src, "rg -n 'ncb_to_c'"))
    assert(ikkje t.inneholder(src, "rg -n 'tools/start(project|app)"))

    skriv("test_active_surface_no_printf_lists OK")
    returner 0
}

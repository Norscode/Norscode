bruk std.runtime_jit som jit

funksjon start() -> heiltall {
    la before = jit.status()
    assert_eq(before["abi"], "norscode-jit-v1")
    assert_eq(before["memory_policy"], "write-xor-execute")

    # (arg0 + 7) * arg1 - 3
    la compiled = jit.kompiler(["arg:0", "const:7", "add", "arg:1", "mul", "const:3", "sub"], 2)
    assert_eq(compiled["status"], "ferdig")
    assert(compiled["handle"] != "")
    assert(heltall_fra_tekst(compiled["code_bytes"]) > 0)

    la result = jit.køyr(compiled["handle"], [5, 4])
    assert_eq(result["status"], "ferdig")
    assert_eq(heltall_fra_tekst(result["value"]), 45)

    la bad_stack = jit.kompiler(["add"], 0)
    assert_eq(bad_stack["status"], "feil")
    la bad_arg = jit.køyr(compiled["handle"], [5])
    assert_eq(bad_arg["status"], "feil")

    la freed = jit.frigjer(compiled["handle"])
    assert_eq(freed["status"], "ferdig")
    la stale = jit.køyr(compiled["handle"], [5, 4])
    assert_eq(stale["status"], "feil")

    la ops: liste_tekst = ["arg:0", "const:2", "mul"]
    la register = jit.nytt_adaptiv_register()
    la cold = jit.køyr_adaptiv(register, "double", ops, 1, [9], 3)
    assert_eq(cold["tier"], "interpreter")
    assert_eq(heltall_fra_tekst(cold["value"]), 18)
    la warm = jit.køyr_adaptiv(register, "double", ops, 1, [10], 3)
    assert_eq(warm["tier"], "interpreter")
    la hot = jit.køyr_adaptiv(register, "double", ops, 1, [11], 3)
    assert_eq(hot["tier"], "jit")
    assert_eq(heltall_fra_tekst(hot["value"]), 22)
    assert_eq(heltall_fra_tekst(jit.adaptiv_info(register, "double")["calls"]), 3)
    assert_eq(jit.nullstill_adaptiv(register), 1)
    skriv("test_native_jit OK")
    returner 0
}

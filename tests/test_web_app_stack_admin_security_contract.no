bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la stack = fil_les("std/web_app_stack.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(stack, "funksjon admin_tilgang(conn: tekst, ctx: ordbok_tekst) -> boolsk")
    krev(stack, "returner krev_rolle(conn, ctx, \"admin\")")
    krev(stack, "funksjon admin_nektet(conn: tekst, ctx: ordbok_tekst) -> ordbok_tekst")
    krev(stack, "returner auth.response_ikkje_innlogga(\"Admin krev innlogging\")")
    krev(stack, "returner auth.response_manglar_rolle(\"admin\")")
    krev(stack, "funksjon admin_oversikt_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst")
    krev(stack, "funksjon admin_liste_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(stack, "funksjon admin_ny_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(stack, "funksjon admin_rediger_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(stack, "funksjon admin_lagre_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(stack, "funksjon admin_slett_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(stack, "returner admin.handle_liste_sikker(conn, register, ctx, csrf_token)")
    krev(stack, "returner admin.handle_lagre_sikker(conn, register, ctx, csrf_token)")
    krev(stack, "returner admin.handle_slett_sikker(conn, register, ctx, csrf_token)")

    krev(manual, "`std.web_app_stack`: samla webflyt for innstillingar, migrasjon, auth/session, admin, admin-rolle/CSRF-sikre admin-hjelparar og standard JSON-responsar.")

    skriv("test_web_app_stack_admin_security_contract OK")
    returner 0
}

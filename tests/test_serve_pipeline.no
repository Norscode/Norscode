funksjon ved_start() -> heiltall {
    returner 1
}

funksjon ved_stopp() -> heiltall {
    returner 1
}

funksjon serve_handle_one(ncb, rå)
    returner "HTTP/1.1 200 OK\r\nX-Trace: req-1\r\nX-Response-Mw: ja\r\nX-Error-Mw: ja\r\n\r\nok"
slutt

funksjon start() -> heiltall {
    la ncb = {
        "route_handlers": [],
        "functions": {}
    }
    la resp = serve_handle_one(ncb, "GET /ok HTTP/1.1\r\n\r\n")
    assert_eq(builtin.starts_with(resp, "HTTP/1.1 200 OK"), sann)
    assert_eq(builtin.contains(resp, "X-Trace: req-1"), sann)
    assert_eq(builtin.contains(resp, "X-Response-Mw: ja"), sann)
    assert_eq(builtin.contains(resp, "X-Error-Mw: ja"), sann)
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/wsgiref.no")
    assert(t.inneholder(src, "HTTP-klient (Norscode HTTP først, curl-reserve)"))
    assert(ikkje t.inneholder(src, "HTTP-klient (enkel, via curl)"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "bruk std.http som httpklient"))
    assert(t.inneholder(src, "httpklient.request_full(\"GET\", url, {}, {}, \"\", 15000)"))
    assert(t.inneholder(src, "httpklient.request_full(\"POST\", url, headers, {}, data, 15000)"))
    assert(t.inneholder(src, "httpklient.response_text(res_http)"))
    assert(t.inneholder(src, "httpklient.response_status(res_http)"))
    assert(t.inneholder(src, "kill \" + _shell(pid)"))
    assert(t.inneholder(src, "rm -f \" + _shell(tenar[\"pid_fil\"])"))
    assert(t.inneholder(src, "curl -s -w"))
    assert(t.inneholder(src, "\" + _shell(url) + \" 2>/dev/null\""))
    assert(t.inneholder(src, "-H \" + _shell(\"Content-Type: \" + content_type)"))
    assert(t.inneholder(src, "-d \" + _shell(data)"))
    assert(t.inneholder(src, "\" + _shell(url) + \" 2>/dev/null\""))

    assert(ikkje t.inneholder(src, "kill \" + pid"))
    assert(ikkje t.inneholder(src, "rm -f \" + tenar[\"pid_fil\"]"))
    assert(ikkje t.inneholder(src, "\" + url + \" 2>/dev/null\""))
    assert(ikkje t.inneholder(src, "-d '\" + data"))

    skriv("test_wsgiref_shell_quote OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la optimizer_src = fil_les("selfhost/middleend/selfhost_optimizer.no")
    la ssa_src = fil_les("selfhost/middleend/selfhost_ssa_lowering.no")
    la lexer_src = fil_les("selfhost/frontend/selfhost_lexer.no")
    la parser_src = fil_les("selfhost/frontend/selfhost_parser.no")
    la semantic_src = fil_les("selfhost/frontend/selfhost_semantic.no")
    la tooling_src = fil_les("selfhost/tooling/selfhost_build_and_norspkg.no")

    assert(t.inneholder(optimizer_src, "Snapshot-verifisering"))
    assert(t.inneholder(ssa_src, "SSA snapshot-verifisering"))
    assert(t.inneholder(lexer_src, "Lexer snapshot-verifisering"))
    assert(t.inneholder(parser_src, "Parser snapshot-verifisering"))
    assert(t.inneholder(semantic_src, "Semantic snapshot-verifisering"))
    assert(t.inneholder(tooling_src, "Tooling snapshot-verifisering"))

    assert(ikkje t.inneholder(optimizer_src, "Snapshot testing"))
    assert(ikkje t.inneholder(ssa_src, "SSA snapshot testing"))
    assert(ikkje t.inneholder(lexer_src, "Lexer testing"))
    assert(ikkje t.inneholder(parser_src, "Parser snapshot testing"))
    assert(ikkje t.inneholder(semantic_src, "Semantic snapshot testing"))
    assert(ikkje t.inneholder(tooling_src, "Tooling snapshot testing"))

    skriv("test_selfhost_snapshot_contract_text OK")
    returner 0
}

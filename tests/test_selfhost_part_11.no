bruk selfhost.common som sh

funksjon start() -> heiltall {
    la env_navn: liste_tekst = ["x", "y"]
    la env_verdier: liste_heiltall = [7, 3]

    la expr_english_is_less_than_or_equal_to_phrase: tekst = sh.disasm_uttrykk("3 is less than or equal to 3")
    assert_eq(expr_english_is_less_than_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_than_or_equal_to_phrase: tekst = sh.disasm_uttrykk("4 is greater than or equal to 4")
    assert_eq(expr_english_is_greater_than_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_or_equal_phrase: tekst = sh.disasm_uttrykk("3 is less or equal 3")
    assert_eq(expr_english_is_less_or_equal_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_or_equal_to_phrase: tekst = sh.disasm_uttrykk("3 is less or equal to 3")
    assert_eq(expr_english_is_less_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_or_equal_phrase: tekst = sh.disasm_uttrykk("4 is greater or equal 4")
    assert_eq(expr_english_is_greater_or_equal_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_or_equal_to_phrase: tekst = sh.disasm_uttrykk("4 is greater or equal to 4")
    assert_eq(expr_english_is_greater_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_than_compact_alias: tekst = sh.disasm_uttrykk("3 is_less_than 4")
    assert_eq(expr_english_is_less_than_compact_alias, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_english_is_greater_or_equal_compact_alias: tekst = sh.disasm_uttrykk("4 is_greater_or_equal 4")
    assert_eq(expr_english_is_greater_or_equal_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_than_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("3 is_less_than_or_equal_to 3")
    assert_eq(expr_english_is_less_than_or_equal_to_compact_alias, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_than_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("4 is_greater_than_or_equal_to 4")
    assert_eq(expr_english_is_greater_than_or_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("3 is_less_or_equal_to 3")
    assert_eq(expr_english_is_less_or_equal_to_compact_alias, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("4 is_greater_or_equal_to 4")
    assert_eq(expr_english_is_greater_or_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_times_alias: tekst = sh.disasm_uttrykk("3 times 4")
    assert_eq(expr_english_times_alias, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_multiplied_by_alias: tekst = sh.disasm_uttrykk("3 multiplied_by 4")
    assert_eq(expr_english_multiplied_by_alias, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_multiply_by_phrase: tekst = sh.disasm_uttrykk("3 multiply by 4")
    assert_eq(expr_english_multiply_by_phrase, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_multiplied_by_phrase: tekst = sh.disasm_uttrykk("3 multiplied by 4")
    assert_eq(expr_english_multiplied_by_phrase, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_divided_by_alias: tekst = sh.disasm_uttrykk("8 divided_by 2")
    assert_eq(expr_english_divided_by_alias, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_divided_by_phrase: tekst = sh.disasm_uttrykk("8 divided by 2")
    assert_eq(expr_english_divided_by_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_divide_by_phrase: tekst = sh.disasm_uttrykk("8 divide by 2")
    assert_eq(expr_english_divide_by_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_add_alias: tekst = sh.disasm_uttrykk("3 add 4")
    assert_eq(expr_english_add_alias, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_english_subtract_alias: tekst = sh.disasm_uttrykk("10 subtract 3")
    assert_eq(expr_english_subtract_alias, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_english_divide_alias: tekst = sh.disasm_uttrykk("8 divide 2")
    assert_eq(expr_english_divide_alias, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_mod_of_alias: tekst = sh.disasm_uttrykk("17 mod_of 5")
    assert_eq(expr_english_mod_of_alias, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_english_modulo_of_phrase: tekst = sh.disasm_uttrykk("17 modulo of 5")
    assert_eq(expr_english_modulo_of_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_english_remainder_alias: tekst = sh.disasm_uttrykk("17 remainder 5")
    assert_eq(expr_english_remainder_alias, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_english_remainder_of_phrase: tekst = sh.disasm_uttrykk("17 remainder of 5")
    assert_eq(expr_english_remainder_of_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_hvis_env: tekst = sh.disasm_uttrykk_med_miljo("hvis x>y da x ellers y", env_navn, env_verdier)
    assert_eq(expr_hvis_env, "0: PUSH 7\n1: PUSH 3\n2: GT\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 3\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_hvis_c: tekst = sh.kompiler_uttrykk_til_c("hvis 1==1 da 7 ellers 9")
    assert_ne(expr_hvis_c, "")

    la expr_err: tekst = sh.disasm_uttrykk("2 +")
    assert_eq(expr_err, "/* feil: uttrykket avsluttes med operator ved token 1 */")

    la expr_err2: tekst = sh.disasm_uttrykk("2 + )")
    assert_eq(expr_err2, "/* feil: mangler verdi før ) ved token 2 */")

    la expr_err3: tekst = sh.disasm_uttrykk("2+$")
    assert_eq(expr_err3, "/* feil: ukjent token/navn i uttrykk $ ved token 2 */")

    la expr_err4: tekst = sh.disasm_uttrykk("foo+1")
    assert_eq(expr_err4, "/* feil: ukjent token/navn i uttrykk foo ved token 0 */")

    la expr_env_err: tekst = sh.disasm_uttrykk_med_miljo("z+1", env_navn, env_verdier)
    assert_eq(expr_env_err, "/* feil: ukjent token/navn i uttrykk z ved token 0 */")

    la env_navn_kort: liste_tekst = ["x"]
    la env_verdier_lang: liste_heltall = [1, 2]
    la expr_env_err2: tekst = sh.disasm_uttrykk_med_miljo("x+1", env_navn_kort, env_verdier_lang)
    assert_eq(expr_env_err2, "/* feil: navn/miljø-verdier må ha samme lengde */")

    la expr_err5: tekst = sh.disasm_uttrykk("(2+3")
    assert_eq(expr_err5, "/* feil: mangler ) i uttrykk ved token 0 */")

    la script_dis: tekst = sh.disasm_skript("x=2+3;y=x*4;y+1")
    assert_eq(script_dis, "0: PUSH 20\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_la_dis: tekst = sh.disasm_skript("la x=2+3;la y=x*4;y+1")
    assert_eq(script_la_dis, "0: PUSH 20\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_trailing_semicolon: tekst = sh.disasm_skript("x=2;y=3;x+y;")
    assert_eq(script_trailing_semicolon, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_empty_statements: tekst = sh.disasm_skript(";;la x=2;;x+1;;")
    assert_eq(script_empty_statements, "0: PUSH 2\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_if_statement_before_final: tekst = sh.disasm_skript("la x=1;hvis x==1 da 10 ellers 20;returner x+2")
    assert_eq(script_if_statement_before_final, "0: PUSH 1\n1: PUSH 2\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_expr_statement_before_final: tekst = sh.disasm_skript("1+1;la y=2;y")
    assert_eq(script_expr_statement_before_final, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_returner: tekst = sh.disasm_skript("la x=2;returner x+3")
    assert_eq(script_returner, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_returner_semicolon: tekst = sh.disasm_skript("la x=2;returner x+3;")
    assert_eq(script_returner_semicolon, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_sett_ok: tekst = sh.disasm_skript("la x=2;sett x=x+3;returner x")
    assert_eq(script_sett_ok, "0: PUSH 5\n1: PRINT\n2: HALT\n")

    la script_assign_alias: tekst = sh.disasm_skript("let x=2;assign x=x+3;return x")
    assert_eq(script_assign_alias, "0: PUSH 5\n1: PRINT\n2: HALT\n")

    la script_compound_ok: tekst = sh.disasm_skript("la x=2;x+=3;x*=2;returner x")
    assert_eq(script_compound_ok, "0: PUSH 10\n1: PRINT\n2: HALT\n")

    la script_hvis_assignment: tekst = sh.disasm_skript("la x=hvis 1==1 da 7 ellers 9;returner x+1")
    assert_eq(script_hvis_assignment, "0: PUSH 7\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_hvis: tekst = sh.disasm_skript("la x=1;hvis x==1 da 10 ellers 20")
    assert_eq(script_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 8\n6: LABEL 6\n7: PUSH 20\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_returner_hvis: tekst = sh.disasm_skript("la x=0;returner hvis x==1 da 10 ellers 20")
    assert_eq(script_returner_hvis, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 8\n6: LABEL 6\n7: PUSH 20\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_nested_hvis: tekst = sh.disasm_skript("la x=1;hvis x==1 da hvis x==1 da 10 ellers 11 ellers 20")
    assert_eq(script_nested_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 14\n4: PUSH 1\n5: PUSH 1\n6: EQ\n7: JZ 10\n8: PUSH 10\n9: JMP 12\n10: LABEL 10\n11: PUSH 11\n12: LABEL 12\n13: JMP 16\n14: LABEL 14\n15: PUSH 20\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la script_if_then_else_alias: tekst = sh.disasm_skript("la x=1;if x==1 then 10 else 20")
    assert_eq(script_if_then_else_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 8\n6: LABEL 6\n7: PUSH 20\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_and_or_not_alias: tekst = sh.disasm_skript("la x=sann;la y=usann;returner x and not y or usann")
    assert_eq(script_and_or_not_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PUSH 0\n5: OR\n6: PRINT\n7: HALT\n")

    la script_let_set_return_alias: tekst = sh.disasm_skript("let x=2;set x=x+3;return x")
    assert_eq(script_let_set_return_alias, "0: PUSH 5\n1: PRINT\n2: HALT\n")

    la script_const_alias: tekst = sh.disasm_skript("const x=2;return x+3")
    assert_eq(script_const_alias, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_var_alias: tekst = sh.disasm_skript("var x=2;return x+3")
    assert_eq(script_var_alias, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_declare_alias: tekst = sh.disasm_skript("declare x=2;return x+3")
    assert_eq(script_declare_alias, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_return_alias_only: tekst = sh.disasm_skript("la x=2;return x+3")
    assert_eq(script_return_alias_only, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_english_cmp_alias: tekst = sh.disasm_skript("let x=4;let y=4;return x greater_or_equal y")
    assert_eq(script_english_cmp_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_less_than_phrase: tekst = sh.disasm_skript("let x=3;let y=4;return x less than y")
    assert_eq(script_english_less_than_phrase, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    returner 0
}

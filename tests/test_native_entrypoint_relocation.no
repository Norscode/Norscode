bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 5 }"
    )

    # Entrypoint relocation tracking
    assert(tekst_inneholder(preview, "relocate_entrypoint"))

    # ELF virtual entry address
    assert(tekst_inneholder(preview, "e_entry"))

    # Text section relocation
    assert(tekst_inneholder(preview, "relocate_text"))

    # Runtime load address
    assert(tekst_inneholder(preview, "load_address"))

    # Executable image layout
    assert(tekst_inneholder(preview, "image_layout"))

    # Native executable emission stage
    assert(tekst_inneholder(preview, "emit_executable"))

    returner 0
}

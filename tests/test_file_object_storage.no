bruk std.lagring som lagring

funksjon tmpsti(navn: tekst) -> tekst {
    returner "build/nc-test-tmp/" + navn
}

funksjon start() -> heltall {
    la objektsti = tmpsti("norscode_file_object.json")

    la data: ordbok_tekst = {}
    lagring.sett_tekst(data, "navn", "Norscode")
    lagring.sett_tall(data, "versjon", 1)
    assert(lagring.lagre(objektsti, data) == 2)

    la lastet = lagring.last(objektsti)
    assert(lagring.hent_tekst(lastet, "navn") == "Norscode")
    assert(lagring.hent_tall(lastet, "versjon") == 1)

    returner 0
}

funksjon start() -> heiltall {
    la base = "build/runtime-gap/norscode upload space " + tekst(builtin.tid_ms())
    la mappe = base + "/filer med mellomrom"
    prøv {
        builtin.mappe_opprett(mappe)
        la lagret = mappe + "/lagring.txt"
        fil_skriv(lagret, "lagret fra norscode")
        hvis fil_les(lagret) == "lagret fra norscode" {
            skriv("opplasting_mappe OK\n")
        } ellers {
            skriv("opplasting_mappe FEIL: feil filinnhald\n")
        }
    } fang (e) {
        skriv("opplasting_mappe FEIL: " + e + "\n")
    }
    returner 0
}

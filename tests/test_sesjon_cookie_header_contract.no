bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la sesjon = fil_les("std/sesjon.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(sesjon, "funksjon _sett_cookie_header(resp: ordbok_tekst, cookie: tekst) -> ordbok_tekst")
    krev(sesjon, "hvis har_nokkel(resp, \"__headers__\")")
    krev(sesjon, "returner web.response_set_cookie(resp, cookie)")
    krev(sesjon, "h[\"set-cookie\"] = cookie")
    krev(sesjon, "returner _sett_cookie_header(resp, cookie)")

    krev(manual, "`std.sesjon.sikkerheitsstatus()`")
    krev(manual, "cookie-headerar på standard `std.web`-responsar")

    skriv("test_sesjon_cookie_header_contract OK")
    returner 0
}

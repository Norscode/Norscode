bruk std.opplasting som oppl
bruk std.web som web

funksjon start() -> heiltall {
    la boundary = "----NorscodeBoundaryTest"
    la body =
        "--" + boundary + "\n" +
        "Content-Disposition: form-data; name=\"vehicle\"\n\n" +
        "veh-002\n" +
        "--" + boundary + "\n" +
        "Content-Disposition: form-data; name=\"file\"; filename=\"demo.txt\"\n" +
        "Content-Type: text/plain\n\n" +
        "demo file body\n" +
        "--" + boundary + "--\n"
    la ctx = web.request_context("post", "/library/upload", {}, {"content-type": "multipart/form-data; boundary=" + boundary}, body)
    la cfg = oppl.cfg_alle_typar("/tmp/norscode-upload-test", 1)
    la parsed = oppl.parse(ctx, cfg)
    assert(oppl.ok(parsed))
    assert_eq(oppl.hent_felt(parsed, "vehicle"), "veh-002")
    assert_eq(oppl.hent_filnamn(parsed, "file"), "demo.txt")
    assert_eq(oppl.hent_content_type(parsed, "file"), "text/plain")
    assert_eq(oppl.hent_storleik(parsed, "file"), 14)
    skriv("test_opplasting_lf_multipart OK\n")
    returner 0
}

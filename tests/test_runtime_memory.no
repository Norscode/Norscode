bruk std.runtime_memory som minne
bruk std.runtime.allocator som allocator
bruk std.tekst som t

funksjon sjekk(namn: tekst, ok: bool) {
    hvis ikkje ok {
        skriv("FEIL runtime_memory: " + namn + "\n")
        assert(ok)
    }
}

funksjon start() -> heiltall {
    la h = minne.ny_heap()
    la a = minne.alloker(h, "Tekst", 16)
    la b = minne.alloker(h, "Liste", 32)
    la c = minne.alloker(h, "Kart", 64)
    sjekk("arena adresse a", minne.objekt_adresse(h, a) >= 6291456)
    sjekk("arena adresse b", minne.objekt_adresse(h, b) > minne.objekt_adresse(h, a))

    sjekk("legg ref", minne.legg_ref(h, a, b))
    sjekk("legg rot", minne.legg_rot(h, a))

    la gc = minne.collect(h)
    assert_eq(gc["freed"], "1")
    assert_eq(gc["alive"], "2")
    assert_eq(gc["marked"], "2")
    assert_eq(gc["alive_bytes"], "48")

    la gc2 = minne.collect(h)
    assert_eq(gc2["promoted"], "2")
    assert(minne.fjern_rot(h, a))
    la gc3 = minne.collect(h)
    assert_eq(gc3["freed"], "2")
    assert_eq(gc3["alive"], "0")

    la d = minne.alloker(h, "Liste", 10)
    la e = minne.alloker(h, "Liste", 20)
    assert(minne.legg_ref(h, d, e))
    assert(minne.legg_ref(h, e, d))
    la syklus = minne.collect(h)
    assert_eq(syklus["freed"], "2")

    la f = minne.alloker(h, "Kart", 8)
    la g = minne.alloker(h, "Tekst", 4)
    assert(minne.legg_ref(h, f, g))
    assert(minne.fjern_ref(h, f, g))
    assert(minne.legg_rot(h, f))
    la utan_ref = minne.collect(h)
    assert_eq(utan_ref["freed"], "1")
    assert_eq(utan_ref["alive"], "1")
    assert(minne.sett_gc_threshold(h, 1))
    assert(minne.gc_trengs(h))

    la s = minne.samandrag(h)
    assert_eq(s["allocated"], "7")
    assert_eq(s["alive"], "1")
    assert_eq(s["freed"], "6")
    assert_eq(s["allocated_bytes"], "154")
    assert_eq(s["alive_bytes"], "8")
    assert_eq(s["freed_bytes"], "146")
    assert_eq(s["collections"], "5")
    assert_eq(s["arena_active_bytes"], "48")
    sjekk("arena frigjort og gjenbrukt", heltall_fra_tekst(s["arena_reused"]) > 0)

    la compact = minne.compact(h)
    assert_eq(compact["status"], "ferdig")
    assert_eq(minne.samandrag(h)["compactions"], "1")

    la h2 = minne.ny_heap()
    la x = minne.alloker(h2, "Tekst", 8)
    la y = minne.alloker(h2, "Tekst", 8)
    la y_old = minne.objekt_adresse(h2, y)
    assert(minne.objekt_skriv_byte(h2, y, 0, 77))
    assert(minne.objekt_skriv_byte(h2, y, 7, 88))
    assert(ikkje minne.objekt_skriv_byte(h2, y, 8, 99))
    assert(minne.legg_rot(h2, y))
    minne.collect(h2)
    la moved = minne.compact(h2)
    assert_eq(moved["moved"], "1")
    sjekk("objekt relokert", minne.objekt_adresse(h2, y) < y_old)
    assert_eq(minne.objekt_les_byte(h2, y, 0), 77)
    assert_eq(minne.objekt_les_byte(h2, y, 7), 88)
    assert_eq(minne.objekt_les_byte(h2, y, 8), -1)

    la h3 = minne.ny_heap()
    assert(allocator.allocator_lock(h3["allocator_lock"], "foreign-thread"))
    la before = minne.samandrag(h3)
    assert_eq(minne.alloker(h3, "Tekst", 8), "")
    assert_eq(minne.samandrag(h3)["allocated"], before["allocated"])
    assert(allocator.allocator_unlock(h3["allocator_lock"], "foreign-thread"))
    assert(minne.alloker(h3, "Tekst", 8) != "")

    la status = minne.produksjonsstatus()
    assert_eq(status["status"], "stabil")
    sjekk("status dekning", t.inneholder(status["dekning"], "mark"))
    sjekk("status generasjon", t.inneholder(status["dekning"], "young/old"))
    sjekk("status allocator", t.inneholder(status["dekning"], "first-fit"))
    assert_eq(status["mangler"], "")

    skriv("test_runtime_memory OK")
    returner 0
}

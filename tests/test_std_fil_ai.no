bruk std.fil som fil

funksjon start() -> heiltall {
    la sti = "ai_assistent/tmp_std_fil_test.txt"
    la innhald = "std fil test OK"

    la skrive = fil.skriv_fil(sti, innhald)
    hvis skrive == 0 {
        skriv("FEIL: skriv_fil returnerte 0\n")
        returner 1
    }

    hvis fil.finnes(sti) == usann {
        skriv("FEIL: finnes returnerte usann\n")
        returner 1
    }

    la lese = fil.les_fil(sti)
    hvis lese != innhald {
        skriv("FEIL: les_fil gav feil innhald\n")
        returner 1
    }

    skriv("std/fil.no test OK\n")
    returner 0
}

bruk std.model_release som utgjeving
bruk std.text_model_bundle som bundle
bruk std.text_model_registry som register
bruk std.text_generation som tekstgen
bruk std.tokenizer som tokenizer
bruk std.sampling som sampling

funksjon lag(versjon: heiltall) {
    la tok = tokenizer.ny(["?", "a", "b", " "], 0, -1, -1, 20)
    la m = tekstgen.ny("signert-tekst", 4, 2,
        [1, 0, 0, 1, 1, 1, 2, 1],
        [2, 0, 1, 3, 0, 2, 1, versjon], [0, 0, 0, 0], 1, 8)
    returner {"modell": m, "tokenizer": tok}
}

funksjon start() -> heiltall {
    la hemmeleg = "0123456789abcdef0123456789abcdef"
    la trust = utgjeving.ny(2, 8)
    assert(utgjeving.legg_til_nokkel(trust, "tekst-bygg-a", hemmeleg))
    la b1 = lag(1)
    la data1 = bundle.kod(b1["modell"], b1["tokenizer"])
    la dekoda1 = bundle.dekod(data1, 1000)
    la m1 = utgjeving.signer_ntm1("signert-tekst-v1", "signert-tekst", 1,
        dekoda1["parametre"], 1000, 10000, "tekst-bygg-a", hemmeleg, data1)
    assert_eq(m1["format"], "NTM1")
    assert(utgjeving.verifiser(trust, m1, data1, 2000))
    la r = register.ny(1, 1000, 4)
    assert(utgjeving.installer_tekst(r, trust, m1, data1, 2000, 1000))
    la samplar = sampling.ny(7, 1, 100, 0, 1, -1)
    assert_eq(lengde(register.generer(r, "signert-tekst", "a", samplar, 1)["nye_token"]), 1)

    la b2 = lag(2)
    la data2 = bundle.kod(b2["modell"], b2["tokenizer"])
    la dekoda2 = bundle.dekod(data2, 1000)
    la m2 = utgjeving.signer_ntm1("signert-tekst-v2", "signert-tekst", 2,
        dekoda2["parametre"], 2000, 12000, "tekst-bygg-a", hemmeleg, data2)
    assert(utgjeving.installer_tekst(r, trust, m2, data2, 3000, 1000))
    assert_eq(r["modellar"]["signert-tekst"]["utgjeving_versjon"], 2)
    assert(ikkje utgjeving.verifiser(trust, m1, data1, 3000))
    skriv("test_text_model_release OK\n")
    returner 0
}

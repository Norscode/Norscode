funksjon start() -> heiltall {
    la res = builtin.exec_prosess("NORSCODE_ROOT='.' ./bin/nc run tools/windows_runtime_execution_gate.no")
    hvis builtin.contains(res[1], "krev faktisk Windows-host") {
        assert_eq(res[0], "2")
    } ellers {
        assert_eq(res[0], "0")
        assert_inneholder(res[1], "Windows runtime execution-gate er grøn")
    }
    skriv("test_windows_runtime_execution OK")
    returner 0
}

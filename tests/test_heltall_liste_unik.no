bruk selfhost.common som sh

funksjon start() -> heltall {
    la a: liste_heltall = sh.ny_heltall_liste()
    legg_til(a, 111)
    la b: liste_heltall = sh.ny_heltall_liste()
    legg_til(b, 222)
    skriv(tekst_fra_heltall(lengde(a)))
    skriv(tekst_fra_heltall(lengde(b)))
    skriv(tekst_fra_heltall(a[0]))
    hvis (lengde(b) > 0) { skriv(tekst_fra_heltall(b[0])) }
    returner 0
}

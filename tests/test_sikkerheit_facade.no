bruk std.sikkerheit som sikkerheit

funksjon start() -> heiltall {
    la pb = sikkerheit.pbkdf2_sha256("passord", "salt", 1, 16)
    assert_eq(lengde(pb), 32)
    la sc = sikkerheit.scrypt_hash("password", "NaCl", 16, 1, 1, 16)
    assert_eq(lengde(sc), 32)

    la policy = sikkerheit.ny_policy("facade")
    assert_eq(sikkerheit.krev(policy, "process.exec")["allowed"], "usann")
    assert(sikkerheit.tillat(policy, "process.exec"))
    assert_eq(sikkerheit.krev(policy, "process.exec")["allowed"], "sann")
    assert(sikkerheit.nekt(policy, "process.exec"))
    assert_eq(sikkerheit.krev(policy, "process.exec")["allowed"], "usann")
    assert(ikkje sikkerheit.har(policy, "process.exec"))
    assert(sikkerheit.set_scope(policy, "net", "web"))
    la host = sikkerheit.hosting_policy("facade-host", "198.51.100.0/24")
    assert(sikkerheit.har(host, "net.dns"))
    assert(sikkerheit.brannmur_policy_ok(host))
    assert_eq(sikkerheit.produksjonsstatus()["modul"], "std.sikkerheit")
    skriv("test_sikkerheit_facade OK\n")
    returner 0
}

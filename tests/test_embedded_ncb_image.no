bruk selfhost.native_execution.embedded_ncb_image som image

funksjon start() -> heiltall {
    la base: liste_heiltall = [0x7F, 0x45, 0x4C, 0x46, 1, 2, 3]
    la compiler = "{\"format\":\"norscode-bytecode-v1\",\"entry\":\"compiler.start\",\"functions\":{}}"
    la vm = "{\"format\":\"norscode-bytecode-v1\",\"entry\":\"vm.start\",\"functions\":{}}"
    la packed = image.bygg(base, ["compiler", "vm"], [compiler, vm])

    assert(image.har_image(packed))
    assert(image.payload_tal(packed) == 2)
    la got_compiler = image.hent(packed, "compiler")
    assert_eq(got_compiler, compiler)
    assert_eq(image.hent(packed, "vm"), vm)

    la direkte_base: liste_heiltall = [0x7F, 0x45, 0x4C, 0x46]
    la direkte = image.bygg_direkte(direkte_base, ["vm"], [vm])
    assert(image.har_image(direkte))
    assert_eq(image.hent(direkte, "vm"), vm)
    assert_eq(image.payload_checksum(packed, "compiler"), image.tekst_checksum(compiler))
    assert_eq(image.payload_checksum(packed, "vm"), image.tekst_checksum(vm))
    la namn = image.namn(packed)
    assert_eq(lengde(namn), 2)
    assert_eq(namn[0], "vm")
    assert_eq(namn[1], "compiler")

    // Rebygging skal erstatte gammalt image, ikkje leggje image oppå image.
    la rebuilt = image.bygg(packed, ["vm"], [vm])
    assert(image.payload_tal(rebuilt) == 1)
    assert_eq(image.hent(rebuilt, "vm"), vm)
    la stripped = image.utan_gammalt_image(rebuilt)
    assert_eq(lengde(stripped), lengde(base))
    la i = 0
    mens i < lengde(base) {
        assert(stripped[i] == base[i])
        i = i + 1
    }

    // Skadd sluttmarkør skal avvisast.
    rebuilt[lengde(rebuilt) - 1] = 0
    assert(ikkje image.har_image(rebuilt))
    returner 0
}

bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la admin = fil_les("std/admin.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(admin, "funksjon _html_escape(s: tekst) -> tekst")
    krev(admin, "tekst_erstatt(s, \"&\", \"&amp;\")")
    krev(admin, "tekst_erstatt(r, \"<\", \"&lt;\")")
    krev(admin, "tekst_erstatt(r, \">\", \"&gt;\")")
    krev(admin, "tekst_erstatt(r, \"\\\"\", \"&quot;\")")
    krev(admin, "tekst_erstatt(r, \"'\", \"&#39;\")")

    krev(admin, "_html_escape(tittel)")
    krev(admin, "_html_escape(m[\"visningsnamn\"])")
    krev(admin, "_html_escape(verdi)")
    krev(admin, "_html_escape(sok)")
    krev(admin, "_html_escape(felt_namn)")
    krev(admin, "_html_escape(f)")

    krev(manual, "`std.admin`: CRUD-admin")
    krev(manual, "escaped HTML-output")

    skriv("test_admin_html_escape_contract OK")
    returner 0
}

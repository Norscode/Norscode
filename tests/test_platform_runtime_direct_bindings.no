bruk std.tekst som t

funksjon start() -> heiltall {
    la window = fil_les("platform/macos/window-host/Main.no")
    assert(t.inneholder(window, "returner miljo_hent(namn)"))
    assert(t.inneholder(window, "returner exec_prosess(cmd)"))
    assert(t.inneholder(window, "funksjon første_felt"))
    assert(t.inneholder(window, "returner første_felt(felt(kommando(\"shasum -a 256 \" + shell(sti)), 1))"))
    assert(t.inneholder(window, "hvis ikkje fil_finst(source)"))
    assert(ikkje t.inneholder(window, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(window, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(window, "| awk"))
    assert(ikkje t.inneholder(window, "test -f "))

    la browser = fil_les("runtime/browser/browser_loader.no")
    assert(t.inneholder(browser, "returner miljo_hent(namn)"))
    assert(t.inneholder(browser, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(browser, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(browser, "builtin.exec_prosess"))

    skriv("test_platform_runtime_direct_bindings OK")
    returner 0
}

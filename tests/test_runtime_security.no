bruk std.runtime_security som sec
bruk std.tekst som t

funksjon start() -> heiltall {
    la p = sec.ny_policy("app")

    assert(ikkje sec.har(p, "net.http"))
    assert_eq(sec.krev(p, "net.http")["allowed"], "usann")

    assert(sec.tillat(p, "net.http"))
    assert(sec.har(p, "net.http"))
    assert_eq(sec.krev(p, "net.http")["allowed"], "sann")

    assert(sec.tillat(p, "process.exec"))
    assert(sec.tillat(p, "thread.spawn"))
    assert(sec.tillat(p, "jit.execute"))
    assert(sec.tillat(p, "env.read"))
    assert(sec.tillat(p, "env.write"))
    assert(sec.har(p, "env.read"))
    p["audit"] = "usann"
    la exec = sec.krev(p, "process.exec")
    assert_eq(exec["allowed"], "usann")
    assert_eq(exec["reason"], "audit required")
    p["audit"] = "sann"
    assert_eq(sec.krev(p, "process.exec")["allowed"], "sann")
    assert_eq(sec.krev(p, "thread.spawn")["allowed"], "sann")
    assert_eq(sec.krev(p, "jit.execute")["allowed"], "sann")

    assert(sec.nekt(p, "device.camera"))
    assert(ikkje sec.har(p, "device.camera"))
    assert_eq(sec.krev(p, "ukjent")["reason"], "unknown capability")

    la host = sec.hosting_policy("domain-host", "198.51.100.0/24")
    assert(sec.har(host, "net.dns"))
    assert(sec.har(host, "mail.receive"))
    assert(sec.brannmur_policy_ok(host))
    assert_eq(host["scope.device"], "none")
    assert_eq(sec.krev(host, "device.microphone")["allowed"], "usann")

    la status = sec.produksjonsstatus()
    assert_eq(status["status"], "delvis")
    assert(t.inneholder(status["dekning"], "deny-by-default"))
    assert(t.inneholder(status["dekning"], "pure-VM"))
    assert(t.inneholder(status["dekning"], "jit.execute"))
    assert(t.inneholder(status["mangler"], "Windows"))

    skriv("test_runtime_security OK")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/plistlib.no")
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "plutil -convert xml1 -o - \" + _shell(sti)"))
    assert(t.inneholder(src, "plutil -convert xml1 -o \" + _shell(tmp) + \" \" + _shell(sti)"))
    assert(t.inneholder(src, "plutil -convert binary1 -o \" + _shell(sti) + \" \" + _shell(tmp_xml)"))
    assert(ikkje t.inneholder(src, "plutil -convert xml1 -o - \" + sti"))
    assert(ikkje t.inneholder(src, "plutil -convert xml1 -o \" + tmp + \" \" + sti"))
    assert(ikkje t.inneholder(src, "plutil -convert binary1 -o \" + sti + \" \" + tmp_xml"))
    skriv("test_plistlib_shell_quote OK")
    returner 0
}

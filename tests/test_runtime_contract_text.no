bruk std.tekst som t

funksjon start() -> heiltall {
    la string_src = fil_les("std/runtime/string.no")
    la allocator_src = fil_les("std/runtime/allocator.no")
    la array_src = fil_les("std/runtime/array.no")

    assert(t.inneholder(string_src, "concat reserverer kapasitet"))
    assert(ikkje t.inneholder(string_src, "concat placeholder størrelse"))
    assert(t.inneholder(allocator_src, "free/dobbel-free vern"))
    assert(ikkje t.inneholder(allocator_src, "frigjør placeholder peker"))
    assert(t.inneholder(array_src, "reserverer ny kapasitet"))
    assert(ikkje t.inneholder(array_src, "resize placeholder"))

    skriv("test_runtime_contract_text OK")
    returner 0
}

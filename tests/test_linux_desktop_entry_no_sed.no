bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/install-linux-desktop-entry.no")

    assert(t.inneholder(src, "funksjon desktop_med_exec"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "funksjon skriv_desktop"))
    assert(t.inneholder(src, "builtin.fil_les(desktop_src)"))
    assert(t.inneholder(src, "builtin.fil_skriv(desktop_dst"))
    assert(t.inneholder(src, "builtin.starts_with(line, \"Exec=\")"))
    assert(t.inneholder(src, "line = \"Exec=\" + exec_path"))

    assert(ikkje t.inneholder(src, "run(\"sed "))
    assert(ikkje t.inneholder(src, "s|^Exec=.*$|Exec="))

    skriv("test_linux_desktop_entry_no_sed OK")
    returner 0
}

bruk std.krypto som krypto
bruk std.sha256 som sha256

funksjon hex_bytes(bytes: liste_heltall) -> tekst {
    la h = "0123456789abcdef"
    la ut = ""
    la i: heiltall = 0
    mens i < lengde(bytes) {
        ut = ut + builtin.slice(h, bytes[i] / 16, bytes[i] / 16 + 1) + builtin.slice(h, bytes[i] % 16, bytes[i] % 16 + 1)
        i = i + 1
    }
    returner ut
}

funksjon start() {
    hvis sha256.hash("abc") != "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad" {
        kast "SHA testvektor feila: " + sha256.hash("abc")
    }
    la hmac = hex_bytes(sha256.hmac_sha256_bytes([112, 97, 115, 115, 119, 111, 114, 100], [115, 97, 108, 116, 0, 0, 0, 1]))
    hvis hmac != "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b" {
        kast "HMAC testvektor feila: " + hmac
    }
    la hash = krypto.pbkdf2_sha256("password", "salt", 1, 32)
    hvis hash != "120fb6cffcf8b32c43e7225256c4f837a86548c92ccc35480805987cb70be17b" {
        kast "PBKDF2 testvektor feila: " + hash
    }
    skriv("test_pbkdf2_vector OK\n")
}

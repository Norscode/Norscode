bruk std.tekst som t

funksjon sjekk(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "funksjon første_forskjellar(sti_a: tekst, sti_b: tekst, maks: heiltall) -> tekst"))
    assert(t.inneholder(src, "første_forskjellar("))
    assert(t.inneholder(src, "funksjon filer_identiske("))
    assert(ikkje t.inneholder(src, "cmp -l"))
    assert(ikkje t.inneholder(src, "cmp -s "))
    assert(ikkje t.inneholder(src, "| head -5"))
}

funksjon start() -> heiltall {
    la l5b = fil_les("tools/selfcompile_l5b.no")
    sjekk("tools/selfcompile_l5b.no")
    assert(t.inneholder(l5b, "returner miljo_hent(namn)"))
    assert(t.inneholder(l5b, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(l5b, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(l5b, "builtin.exec_prosess"))
    sjekk("tools/selfcompile_native_elf.no")
    sjekk("tools/selfcompile_stage0_elf.no")

    la l5 = fil_les("tools/selfcompile_l5.no")
    assert(t.inneholder(l5, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(l5, "builtin.exec_prosess"))

    skriv("test_selfcompile_diff_no_cmp_head OK")
    returner 0
}

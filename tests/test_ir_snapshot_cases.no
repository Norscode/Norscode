funksjon hent_felt(obj, namn) {
    returner obj[namn]
}

funksjon køyr_non_strict(case_obj) {
    la source = hent_felt(case_obj, "source")
    la resultat = sh.disasm_fra_kilde(source)
    assert(lengde(resultat) > 0)
}

funksjon køyr_strict(case_obj) {
    la source = hent_felt(case_obj, "source")
    la resultat = sh.disasm_fra_kilde_strict(source)
    la expected_error = hent_felt(case_obj, "expected_error")

    hvis expected_error != null {
        assert_eq(resultat, expected_error)
        returner
    }

    la expected_lines = hent_felt(case_obj, "expected_lines")
    la forventa = tekst_join(expected_lines, "\n") + "\n"
    assert_eq(resultat, forventa)
}

funksjon køyr_liste(cases, strict) {
    la i = 0
    mens i < lengde(cases) {
        la case_obj = cases[i]
        hvis strict {
            køyr_strict(case_obj)
        } ellers {
            køyr_non_strict(case_obj)
        }
        i = i + 1
    }
}

funksjon start() -> heltall {
    la raw = fil_les("tests/ir_snapshot_cases.json")
    la parsed = json_parse_raw(raw)

    la non_strict = parsed["non_strict"]
    la strict = parsed["strict"]

    køyr_liste(non_strict, usann)
    køyr_liste(strict, sann)
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/gzip.no")
    assert(t.inneholder(src, "Brukar trygt quota gzip/base64-verktøy for komprimering"))
    assert(t.inneholder(src, "Norscode-filread som reserveveg"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "gzip -c \" + _shell(src_fil) + \" > \" + _shell(dst_fil)"))
    assert(t.inneholder(src, "gzip -dc \" + _shell(src_fil) + \" > \" + _shell(dst_fil)"))
    assert(t.inneholder(src, "gzip -f \" + _shell(filsti)"))
    assert(t.inneholder(src, "gzip -df \" + _shell(gz_sti)"))
    assert(t.inneholder(src, "gzip -c \" + _shell(tmp_inn) + \" > \" + _shell(tmp_ut)"))
    assert(t.inneholder(src, "base64 \" + _shell(tmp_ut)"))
    assert(t.inneholder(src, "base64 -d \" + _shell(tmp_b64) + \" > \" + _shell(tmp_gz)"))
    assert(t.inneholder(src, "gzip -dc \" + _shell(tmp_gz)"))
    assert(t.inneholder(src, "gzip -dc \" + _shell(sti)"))
    assert(t.inneholder(src, "gzip -dc \" + _shell(f[\"sti\"])"))
    assert(t.inneholder(src, "gzip -c \" + _shell(tmp2) + \" > \" + _shell(f[\"sti\"])"))
    assert(t.inneholder(src, "gzip -c \" + _shell(tmp_sti) + \" > \" + _shell(f[\"sti\"])"))
    assert(t.inneholder(src, "rm -f \" + _shell(tmp_sti)"))
    assert(t.inneholder(src, "stat -c '%s' \" + _shell(gz_sti)"))
    assert(t.inneholder(src, "stat -f '%z' \" + _shell(gz_sti)"))
    assert(t.inneholder(src, "la innhald = builtin.fil_les(gz_sti)"))
    assert(t.inneholder(src, "returner builtin.lengde(innhald)"))
    assert(t.inneholder(src, "wc -c < \" + _shell(gz_sti) + \" 2>/dev/null"))
    assert(t.inneholder(src, "gzip -l \" + _shell(gz_sti)"))
    assert(t.inneholder(src, "gzip -t \" + _shell(sti)"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))

    assert(ikkje t.inneholder(src, "gzip -c \" + src_fil"))
    assert(ikkje t.inneholder(src, "Innpakning rundt system-gzip-kommandoen via exec_prosess."))
    assert(ikkje t.inneholder(src, "gzip -dc \" + src_fil"))
    assert(ikkje t.inneholder(src, "gzip -f \" + filsti"))
    assert(ikkje t.inneholder(src, "gzip -df \" + gz_sti"))
    assert(ikkje t.inneholder(src, "gzip -c \" + tmp_inn"))
    assert(ikkje t.inneholder(src, "base64 \" + tmp_ut"))
    assert(ikkje t.inneholder(src, "base64 -d \" + tmp_b64"))
    assert(ikkje t.inneholder(src, "gzip -dc \" + tmp_gz"))
    assert(ikkje t.inneholder(src, "gzip -dc \" + sti"))
    assert(ikkje t.inneholder(src, "gzip -dc \" + f[\"sti\"]"))
    assert(ikkje t.inneholder(src, "gzip -c \" + tmp2"))
    assert(ikkje t.inneholder(src, "gzip -c \" + tmp_sti"))
    assert(ikkje t.inneholder(src, "rm -f \" + tmp_sti"))
    assert(ikkje t.inneholder(src, "stat -c '%s' \" + gz_sti"))
    assert(ikkje t.inneholder(src, "stat -f '%z' \" + gz_sti"))
    assert(ikkje t.inneholder(src, "wc -c < \" + gz_sti"))
    assert(ikkje t.inneholder(src, "gzip -l \" + gz_sti"))
    assert(ikkje t.inneholder(src, "gzip -t \" + sti"))
    assert(ikkje t.inneholder(src, "&& echo OK || echo FEIL"))

    skriv("test_gzip_shell_quote OK")
    returner 0
}

bruk std.inspect som inspect
bruk std.runtime_type som typer

funksjon inneholder(liste, verdi: tekst) -> boolsk {
    la i: heiltall = 0
    mens i < lengde(liste) {
        hvis tekst(liste[i]) == verdi { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon demo(a: heiltall) -> heiltall { returner a + 1 }

funksjon start() -> heiltall {
    la base = typer.objekt_type("ReflectBase", "id,title", "close")
    assert(typer.registrer(base))
    typer.sett_metode(base, "close", "__main__.demo")
    la child = typer.objekt_type("ReflectChild", "priority", "assign")
    typer.sett_base(child, "ReflectBase")
    assert(typer.registrer(child))
    typer.sett_metode(child, "assign", "__main__.demo")

    la symbols = inspect.symboltabell()
    assert(inneholder(symbols["types"], "ReflectChild"))
    assert(inneholder(symbols["functions"], "__main__.demo"))
    assert(inneholder(symbols["modules"], "__main__"))

    la reflected = inspect.type_metadata("ReflectChild")
    assert_eq(reflected["finnes"], "sann")
    assert(inneholder(reflected["fields"], "priority"))
    assert(inneholder(reflected["fields"], "id"))
    assert(inneholder(reflected["methods"], "assign"))
    assert(inneholder(reflected["methods"], "close"))
    assert_eq(inspect.metode_mål("ReflectChild", "close"), "__main__.demo")
    assert(inneholder(reflected["inheritance"], "ReflectChild"))
    assert(inneholder(reflected["inheritance"], "ReflectBase"))

    la fn = inspect.funksjon_metadata("__main__.demo")
    assert_eq(fn["finnes"], "sann")
    assert_eq(fn["param_count"], "1")
    assert(heltall_fra_tekst(fn["instruction_count"]) > 0)
    la module_info = inspect.modul_metadata("__main__")
    assert(heltall_fra_tekst(module_info["function_count"]) >= 2)
    assert(heltall_fra_tekst(symbols["function_count"]) >= heltall_fra_tekst(module_info["function_count"]))
    assert_eq(inspect.produksjonsstatus()["status"], "stabil")
    returner 0
}

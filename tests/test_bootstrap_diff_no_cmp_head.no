bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/bootstrap_diff_analyzer.no")
    la wrapper = fil_les("tools/bootstrap_diff_analyzer.sh")
    assert(t.inneholder(src, "funksjon første_forskjellar(sti_a: tekst, sti_b: tekst, maks: heiltall) -> tekst"))
    assert(t.inneholder(src, "builtin.fil_les(sti_a)"))
    assert(t.inneholder(src, "builtin.char_code(a[i])"))
    assert(t.inneholder(src, "første_forskjellar(build_a, build_b, 50)"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(t.inneholder(src, "NORSCODE_BUILD_A=<build_a> NORSCODE_BUILD_B=<build_b> ./bin/nc run tools/bootstrap_diff_analyzer.no"))
    assert(t.inneholder(wrapper, "Norscode-first wrapper: bootstrap-diff ligg i tools/bootstrap_diff_analyzer.no."))
    assert(t.inneholder(wrapper, "Shell-delen under mappar CLI-argument til miljø og startar Norscode-eigarfil."))
    assert(t.inneholder(wrapper, "NORSCODE_BUILD_A=<build_a> NORSCODE_BUILD_B=<build_b> ./bin/nc run tools/bootstrap_diff_analyzer.no"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(src, "bootstrap_diff_analyzer.sh <"))
    assert(ikkje t.inneholder(wrapper, "Usage: bootstrap_diff_analyzer.sh"))
    assert(ikkje t.inneholder(wrapper, "bootstrap_diff_analyzer.sh <"))
    assert(ikkje t.inneholder(src, "cmp -l"))
    assert(ikkje t.inneholder(src, "| head -50"))
    assert(ikkje t.inneholder(wrapper, "Tynn wrapper"))
    assert(ikkje t.inneholder(wrapper, "shasum"))
    assert(ikkje t.inneholder(wrapper, "NORSCODE_BUILD_SHA_A"))
    assert(ikkje t.inneholder(wrapper, "NORSCODE_BUILD_SHA_B"))

    skriv("test_bootstrap_diff_no_cmp_head OK")
    returner 0
}

bruk std.stil som stil

funksjon start() -> heltall {
    la css = stil.stilark([
        stil.kommentar("Norsk stilark"),
        stil.import_regel("\"/assets/css/reset.css\""),
        stil.rot([
            stil.variabel("bg", "#f7f4ef"),
            stil.variabel("ink", "#1f1a17")
        ]),
        stil.font_face([
            stil.eigenskap("font-family", "\"Norscode Sans\""),
            stil.eigenskap("src", "url(\"/assets/fonts/norscode-sans.woff2\") format(\"woff2\")")
        ]),
        stil.regel("body", [
            stil.eigenskap("margin", "0"),
            stil.eigenskap("background", "var(--bg)"),
            stil.eigenskap("color", "var(--ink)")
        ]),
        stil.regel(stil.klasse("shell"), [
            stil.eigenskap("max-width", "1120px"),
            stil.eigenskap("margin", "0 auto")
        ]),
        stil.regel(stil.gruppe([stil.klasse("shell"), stil.id("app")]), [
            stil.eigenskap("isolation", "isolate")
        ]),
        stil.regel(stil.attributt("data-mode", "norsk"), [
            stil.eigenskap("display", "block")
        ]),
        stil.regel(stil.pseudo_element(stil.klasse("shell"), "before"), [
            stil.eigenskap("content", "\"\"")
        ]),
        stil.regel(stil.direkte_barn(stil.klasse("nav"), stil.klasse("lenke")), [
            stil.eigenskap("font-weight", "700")
        ]),
        stil.regel(stil.søsken(stil.klasse("nav"), stil.klasse("hero")), [
            stil.eigenskap("margin-top", "2rem")
        ]),
        stil.regel(stil.generell_søsken(stil.klasse("nav"), stil.klasse("footer")), [
            stil.eigenskap("opacity", ".8")
        ]),
        stil.supports("(display: grid)", [
            stil.regel(stil.klasse("grid"), [
                stil.eigenskap("display", "grid")
            ])
        ]),
        stil.container("kort", "(min-width: 30rem)", [
            stil.regel(stil.klasse("kort"), [
                stil.eigenskap("padding", "1.5rem")
            ])
        ]),
        stil.keyframes("pulse", [
            stil.regel("from", [
                stil.eigenskap("transform", "scale(1)")
            ]),
            stil.regel("to", [
                stil.eigenskap("transform", "scale(1.03)")
            ])
        ]),
        stil.layer("base", [
            stil.regel(stil.klasse("panel"), [
                stil.eigenskap("border-radius", "8px")
            ])
        ]),
        stil.nest(stil.klasse("kort"), [
            stil.eigenskap("padding", "1rem")
        ], [
            stil.regel("&:hover", [
                stil.eigenskap("transform", "translateY(-1px)")
            ])
        ]),
        stil.media("(max-width: 760px)", [
            stil.regel(stil.klasse("shell"), [
                stil.eigenskap("padding", "1rem")
            ])
        ])
    ])

    assert_eq(
        css,
        "/* Norsk stilark */\n" +
        "@import \"/assets/css/reset.css\";\n" +
        ":root {\n" +
        "  --bg: #f7f4ef;\n" +
        "  --ink: #1f1a17;\n" +
        "}\n" +
        "@font-face {\n" +
        "  font-family: \"Norscode Sans\";\n" +
        "  src: url(\"/assets/fonts/norscode-sans.woff2\") format(\"woff2\");\n" +
        "}\n" +
        "body {\n" +
        "  margin: 0;\n" +
        "  background: var(--bg);\n" +
        "  color: var(--ink);\n" +
        "}\n" +
        ".shell {\n" +
        "  max-width: 1120px;\n" +
        "  margin: 0 auto;\n" +
        "}\n" +
        ".shell, #app {\n" +
        "  isolation: isolate;\n" +
        "}\n" +
        "[data-mode=\"norsk\"] {\n" +
        "  display: block;\n" +
        "}\n" +
        ".shell::before {\n" +
        "  content: \"\";\n" +
        "}\n" +
        ".nav > .lenke {\n" +
        "  font-weight: 700;\n" +
        "}\n" +
        ".nav + .hero {\n" +
        "  margin-top: 2rem;\n" +
        "}\n" +
        ".nav ~ .footer {\n" +
        "  opacity: .8;\n" +
        "}\n" +
        "@supports (display: grid) {\n" +
        ".grid {\n" +
        "  display: grid;\n" +
        "}\n" +
        "}\n" +
        "@container kort (min-width: 30rem) {\n" +
        ".kort {\n" +
        "  padding: 1.5rem;\n" +
        "}\n" +
        "}\n" +
        "@keyframes pulse {\n" +
        "  from {\n" +
        "    transform: scale(1);\n" +
        "  }\n" +
        "  to {\n" +
        "    transform: scale(1.03);\n" +
        "  }\n" +
        "}\n" +
        "@layer base {\n" +
        ".panel {\n" +
        "  border-radius: 8px;\n" +
        "}\n" +
        "}\n" +
        ".kort {\n" +
        "  padding: 1rem;\n" +
        "  &:hover {\n" +
        "    transform: translateY(-1px);\n" +
        "  }\n" +
        "}\n" +
        "@media (max-width: 760px) {\n" +
        ".shell {\n" +
        "  padding: 1rem;\n" +
        "}\n" +
        "}"
    )

    assert_eq(stil.klasse("card"), ".card")
    assert_eq(stil.id("app"), "#app")
    assert_eq(stil.pseudo(stil.klasse("nav"), "hover"), ".nav:hover")
    assert_eq(stil.barn(stil.klasse("nav"), stil.klasse("lenke")), ".nav .lenke")
    assert_eq(stil.gruppe([stil.klasse("nav"), stil.id("app")]), ".nav, #app")
    assert_eq(stil.attributt("data-mode", "norsk"), "[data-mode=\"norsk\"]")
    assert_eq(stil.pseudo_element(stil.klasse("shell"), "before"), ".shell::before")
    assert_eq(stil.direkte_barn(stil.klasse("nav"), stil.klasse("lenke")), ".nav > .lenke")
    assert_eq(stil.søsken(stil.klasse("nav"), stil.klasse("hero")), ".nav + .hero")
    assert_eq(stil.generell_søsken(stil.klasse("nav"), stil.klasse("footer")), ".nav ~ .footer")
    assert(t.inneholder(stil.nest(stil.klasse("kort"), [stil.eigenskap("padding", "1rem")], [stil.regel("&:hover", [stil.eigenskap("transform", "translateY(-1px)")])]), "&:hover"))
    assert_eq(stil.import_regel("\"/assets/css/reset.css\""), "@import \"/assets/css/reset.css\";")
    assert(t.inneholder(stil.supports("(display: grid)", [stil.regel(stil.klasse("grid"), [stil.eigenskap("display", "grid")])]), "@supports (display: grid)"))
    assert(t.inneholder(stil.container("kort", "(min-width: 30rem)", [stil.regel(stil.klasse("kort"), [stil.eigenskap("padding", "1.5rem")])]), "@container kort (min-width: 30rem)"))
    assert(t.inneholder(stil.keyframes("pulse", [stil.regel("from", [stil.eigenskap("transform", "scale(1)")]), stil.regel("to", [stil.eigenskap("transform", "scale(1.03)")])]), "@keyframes pulse"))
    assert(t.inneholder(stil.layer("base", [stil.regel(stil.klasse("panel"), [stil.eigenskap("border-radius", "8px")])]), "@layer base"))

    la verdi_css = stil.stilark([
        stil.regel(stil.klasse("verdi"), [
            stil.eigenskap("width", stil.clamp("16rem", "80vw", "70rem")),
            stil.eigenskap("padding", stil.calc("1rem + 2vw")),
            stil.eigenskap("margin", stil.min_verdi([stil.rem("1"), stil.vw("2")])),
            stil.eigenskap("min-height", stil.max_verdi([stil.rem("2"), stil.vh("10")])),
            stil.eigenskap("border-width", stil.px(2)),
            stil.eigenskap("font-size", stil.rem("0.875")),
            stil.eigenskap("line-height", stil.em("1.2")),
            stil.eigenskap("max-width", stil.prosent("100")),
            stil.eigenskap("box-shadow", stil.rgba(31, 26, 23, "0.12")),
            stil.eigenskap("background", stil.lineær_gradient("135deg", [stil.rgb(247, 244, 239), stil.farge_hex("fffaf2")])),
            stil.eigenskap("transform", stil.transform(["translateY(-1px)", "scale(1.02)"])),
            stil.eigenskap("filter", stil.filter(["blur(0)", "saturate(1.1)"]))
        ])
    ])

    assert(t.inneholder(verdi_css, "width: clamp(16rem, 80vw, 70rem);"))
    assert(t.inneholder(verdi_css, "padding: calc(1rem + 2vw);"))
    assert(t.inneholder(verdi_css, "margin: min(1rem, 2vw);"))
    assert(t.inneholder(verdi_css, "min-height: max(2rem, 10vh);"))
    assert(t.inneholder(verdi_css, "border-width: 2px;"))
    assert(t.inneholder(verdi_css, "font-size: 0.875rem;"))
    assert(t.inneholder(verdi_css, "line-height: 1.2em;"))
    assert(t.inneholder(verdi_css, "max-width: 100%;"))
    assert(t.inneholder(verdi_css, "box-shadow: rgba(31, 26, 23, 0.12);"))
    assert(t.inneholder(verdi_css, "background: linear-gradient(135deg, rgb(247, 244, 239), #fffaf2);"))
    assert(t.inneholder(verdi_css, "transform: translateY(-1px) scale(1.02);"))
    assert(t.inneholder(verdi_css, "filter: blur(0) saturate(1.1);"))

    la token_css = stil.stilark([
        stil.tema_lys([
            stil.token_farge("bg", "#f7f4ef"),
            stil.token_spacing("shell-pad", "3rem"),
            stil.token_radius("md", "12px"),
            stil.token_skygge("card", "0 18px 48px rgba(31, 26, 23, 0.08)")
        ]),
        stil.tema_mørk([
            stil.token_farge("bg", "#0f141b"),
            stil.token_spacing("shell-pad", "3rem"),
            stil.token_radius("md", "12px"),
            stil.token_skygge("card", "0 18px 48px rgba(0, 0, 0, 0.28)")
        ]),
        stil.tema_data("kompakt", [
            stil.token_farge("bg", "#ffffff")
        ]),
        stil.regel(stil.klasse("shell"), [
            stil.eigenskap("padding", stil.token_ref("space-shell-pad")),
            stil.eigenskap("background", stil.token_ref("color-bg")),
            stil.eigenskap("border-radius", stil.token_ref("radius-md")),
            stil.eigenskap("box-shadow", stil.token_ref("shadow-card"))
        ])
    ])

    assert(t.inneholder(token_css, ":root {"))
    assert(t.inneholder(token_css, "--color-bg: #f7f4ef;"))
    assert(t.inneholder(token_css, "--space-shell-pad: 3rem;"))
    assert(t.inneholder(token_css, "--radius-md: 12px;"))
    assert(t.inneholder(token_css, "--shadow-card: 0 18px 48px rgba(31, 26, 23, 0.08);"))
    assert(t.inneholder(token_css, "@media (prefers-color-scheme: dark)"))
    assert(t.inneholder(token_css, "[data-theme=\"kompakt\"]"))
    assert(t.inneholder(token_css, "padding: var(--space-shell-pad);"))
    assert(t.inneholder(token_css, "background: var(--color-bg);"))
    assert(t.inneholder(token_css, "border-radius: var(--radius-md);"))
    assert(t.inneholder(token_css, "box-shadow: var(--shadow-card);"))

    la avansert_css = stil.stilark([
        stil.property_regel("--accent", "<color>", "false", "#b85c38"),
        stil.scope(".app", ".app__panel", [
            stil.regel(stil.klasse("knapp"), [
                stil.eigenskap("background", "var(--accent)")
            ])
        ]),
        stil.regel(stil.klasse("ikon"), [
            stil.eigenskap("background-image", stil.url("\"/assets/icons/norscode-mark.svg\""))
        ])
    ])

    assert(t.inneholder(avansert_css, "@property --accent"))
    assert(t.inneholder(avansert_css, "syntax: <color>;"))
    assert(t.inneholder(avansert_css, "inherits: false;"))
    assert(t.inneholder(avansert_css, "initial-value: #b85c38;"))
    assert(t.inneholder(avansert_css, "@scope (.app) to (.app__panel)"))
    assert(t.inneholder(avansert_css, "background-image: url(\"/assets/icons/norscode-mark.svg\");"))

    la ryddig_css = stil.stilark([
        "",
        stil.regel("body", [
            "",
            stil.eigenskap("margin", "0"),
            ""
        ]),
        ""
    ])

    assert_eq(ryddig_css, "body {\n  margin: 0;\n}")

    prøv {
        stil.klasse("")
        kast "forventa feil for tom klasse"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "klasse-namn"))
    }

    prøv {
        stil.gruppe([])
        kast "forventa feil for tom gruppe"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "seljarar"))
    }

    prøv {
        stil.import_regel("")
        kast "forventa feil for tom import"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "import-ressurs"))
    }

    prøv {
        stil.token_farge("", "#fff")
        kast "forventa feil for tom tokenfarge"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "token-farge-namn"))
    }

    prøv {
        stil.eigenskap("margin", "")
        kast "forventa feil for tom eigenskap-verdi"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "eigenskap-verdi"))
    }

    prøv {
        stil.calc("")
        kast "forventa feil for tom calc"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "calc-uttrykk"))
    }

    prøv {
        stil.min_verdi([])
        kast "forventa feil for tom min-verdi"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "min-verdiar"))
    }

    prøv {
        stil.farge_hex("")
        kast "forventa feil for tom farge"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "farge-hex-verdi"))
    }

    prøv {
        stil.url("")
        kast "forventa feil for tom url"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "url-ressurs"))
    }

    prøv {
        stil.property_regel("", "<color>", "false", "#fff")
        kast "forventa feil for tom property"
    } fang (feil) {
        assert(t.inneholder(feil, "ArgumentFeil"))
        assert(t.inneholder(feil, "property-namn"))
    }

    returner 0
}

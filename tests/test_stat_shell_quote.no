bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/stat.no")
    assert(t.inneholder(src, "Brukar Norscode-filkontroll for eksistens"))
    assert(t.inneholder(src, "trygt quota OS-verktøy for"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "stat -c \\\"%f %i %h %u %g %s %X %Y %Z\\\" \" + _shell(sti)"))
    assert(t.inneholder(src, "stat -f \\\"%Xp %i %l %u %g %z %a %m %c\\\" \" + _shell(sti)"))
    assert(t.inneholder(src, "stat -L -c \\\"%f %i %h %u %g %s %X %Y %Z\\\" \" + _shell(sti)"))
    assert(t.inneholder(src, "returner builtin.fil_finnes(sti)"))
    assert(t.inneholder(src, "test -r \" + _shell(sti)"))
    assert(t.inneholder(src, "test -w \" + _shell(sti)"))
    assert(t.inneholder(src, "test -x \" + _shell(sti)"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))
    assert(t.inneholder(src, "chmod \" + _shell(mode_str) + \" \" + _shell(sti)"))
    assert(t.inneholder(src, "chown \" + _shell(brukar + \":\" + gruppe) + \" \" + _shell(sti)"))

    assert(ikkje t.inneholder(src, "stat -c \\\"%f %i %h %u %g %s %X %Y %Z\\\" \" + sti"))
    assert(ikkje t.inneholder(src, "Brukar exec_prosess (stat-kommando) for å hente faktisk filinformasjon."))
    assert(ikkje t.inneholder(src, "stat -f \\\"%Xp %i %l %u %g %z %a %m %c\\\" \" + sti"))
    assert(ikkje t.inneholder(src, "stat -L -c \\\"%f %i %h %u %g %s %X %Y %Z\\\" \" + sti"))
    assert(ikkje t.inneholder(src, "test -e \" + _shell(sti)"))
    assert(ikkje t.inneholder(src, "test -e \" + sti"))
    assert(ikkje t.inneholder(src, "test -r \" + sti"))
    assert(ikkje t.inneholder(src, "test -w \" + sti"))
    assert(ikkje t.inneholder(src, "test -x \" + sti"))
    assert(ikkje t.inneholder(src, "&& echo ja || echo nei"))
    assert(ikkje t.inneholder(src, "chmod \" + mode_str + \" \" + sti"))
    assert(ikkje t.inneholder(src, "chmod \" + mode_str"))
    assert(ikkje t.inneholder(src, "chown \" + brukar + \":\" + gruppe + \" \" + sti"))
    assert(ikkje t.inneholder(src, "chown \" + brukar"))

    skriv("test_stat_shell_quote OK")
    returner 0
}

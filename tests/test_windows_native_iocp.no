funksjon vent_completion() -> ordbok_tekst {
    la result = {"status": "ventende"}
    la i: heiltall = 0
    mens result["status"] == "ventende" og i < 100 {
        result = builtin.network_operation({
            "abi": "norscode-native-network-v1",
            "operation": "iocp_wait",
            "timeout_ms": 100
        })
        i = i + 1
    }
    returner result
}

funksjon start() -> heiltall {
    la listener = builtin.network_operation({
        "abi": "norscode-native-network-v1",
        "operation": "iocp_listen",
        "host": "127.0.0.1",
        "port": 0
    })
    assert_eq(listener["status"], "listening")
    assert_eq(listener["event_backend"], "iocp")

    listener["operation"] = "iocp_accept"
    la accepted = builtin.network_operation(listener)
    assert_eq(accepted["status"], "ventende")
    la client = builtin.network_operation({
        "abi": "norscode-native-network-v1",
        "operation": "iocp_connect",
        "host": "127.0.0.1",
        "port": listener["port"]
    })
    assert_eq(client["status"], "ventende")

    la first = vent_completion()
    la second = vent_completion()
    assert_eq(first["status"], "klar")
    assert_eq(second["status"], "klar")
    assert((first["operation_kind"] == 1 og second["operation_kind"] == 2) eller
           (first["operation_kind"] == 2 og second["operation_kind"] == 1))

    accepted["operation"] = "iocp_read"
    accepted["max"] = 64
    la read_pending = builtin.network_operation(accepted)
    assert_eq(read_pending["status"], "ventende")
    client["operation"] = "iocp_write"
    client["data"] = "iocp-norscode-ok"
    la write_pending = builtin.network_operation(client)
    assert_eq(write_pending["status"], "ventende")

    first = vent_completion()
    second = vent_completion()
    assert_eq(first["status"], "klar")
    assert_eq(second["status"], "klar")
    la read_result = first
    hvis second["operation_kind"] == 3 { read_result = second }
    assert_eq(read_result["operation_kind"], 3)
    assert_eq(read_result["data"], "iocp-norscode-ok")
    assert_eq(read_result["value"], 16)

    client["operation"] = "close"
    accepted["operation"] = "close"
    listener["operation"] = "close"
    assert_eq(builtin.network_operation(client)["status"], "closed")
    assert_eq(builtin.network_operation(accepted)["status"], "closed")
    assert_eq(builtin.network_operation(listener)["status"], "closed")
    skriv("test_windows_native_iocp OK")
    returner 0
}

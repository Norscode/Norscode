bruk std.runtime_memory som minne

funksjon start() -> heiltall {
    la h = minne.ny_heap()
    minne.sett_gc_threshold(h, 4)
    la a = minne.alloker(h, "kart", 32)
    la b = minne.alloker(h, "liste", 32)
    la c = minne.alloker(h, "tekst", 32)
    la d = minne.alloker(h, "kart", 32)
    minne.legg_rot(h, a)
    minne.legg_rot(h, b)
    assert(minne.gc_trengs(h))
    la r = minne.collect(h)
    assert_eq(r["alive"], "2")
    assert(heltall_fra_tekst(r["next_threshold"]) > 2)
    assert(ikkje minne.gc_trengs(h))
    la før = h["collection_count"]
    assert(ikkje minne.gc_trengs(h))
    assert_eq(h["collection_count"], før)
    returner 0
}

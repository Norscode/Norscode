bruk std.tekst som t

funksjon start() -> heltall {
    la src = fil_les("std/socket_pure.no")

    assert(t.inneholder(src, "Norscode-native TCP/HTTP-kontrakt"))
    assert(t.inneholder(src, "Direkte socket-bindingar ligg ved runtime-grensa"))
    assert(t.inneholder(src, "Norscode-native HTTP-tenar"))
    assert(t.inneholder(src, "Modus: Norscode-native HTTP, utan Python/C i eigarlogikken"))
    assert(t.inneholder(src, "Intern HTTP-røykhandler"))
    assert(t.inneholder(src, "funksjon handle_royk_request"))
    assert(t.inneholder(src, "same rutekontrakt som serverløypa brukar"))
    assert(t.inneholder(src, "Røykflata returnerer funne handlernamn"))

    assert(ikkje t.inneholder(src, "100% Pure Norscode"))
    assert(ikkje t.inneholder(src, "Pure Native HTTP Server"))
    assert(ikkje t.inneholder(src, "Python-wrapper"))
    assert(ikkje t.inneholder(src, "no dependencies"))
    assert(ikkje t.inneholder(src, "handle_mock_request"))
    assert(ikkje t.inneholder(src, "Mock Request Handler"))
    assert(ikkje t.inneholder(src, "For Testing"))
    assert(ikkje t.inneholder(src, "Handler found - would call it here"))
    assert(ikkje t.inneholder(src, "🚀"))
    assert(ikkje t.inneholder(src, "📍"))
    assert(ikkje t.inneholder(src, "🔗"))

    skriv("test_socket_pure_native_text OK")
    returner 0
}

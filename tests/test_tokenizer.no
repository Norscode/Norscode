bruk std.tokenizer som tokenizer

funksjon start() -> heiltall {
    la t = tokenizer.ny(["?", "h", "e", "i", " ", "verden", "hei", "<B>", "<E>"], 0, 7, 8, 100)
    assert_eq(tokenizer.storleik(t), 9)
    la ids = tokenizer.kod(t, "hei verden", usann, usann)
    assert_eq(lengde(ids), 3)
    assert_eq(ids[0], 6)
    assert_eq(ids[1], 4)
    assert_eq(ids[2], 5)
    assert_eq(tokenizer.dekod(t, ids, sann), "hei verden")
    assert_eq(tokenizer.dekod(t, tokenizer.kod(t, "x", sann, sann), sann), "?")
    skriv("test_tokenizer OK\n")
    returner 0
}

bruk std.runtime_filesystem som fs
bruk std.sched som sched

funksjon pump(loop: ordbok_tekst, future_id: tekst) -> heiltall {
    la i: heiltall = 0
    mens sched.future_status(loop, future_id) == "ventende" og i < 100 {
        sched.io_poll(loop)
        i = i + 1
    }
    returner i
}

funksjon start() -> heiltall {
    la loop = sched.ny()
    la writer = fs.opne_native("build", "windows-filesystem-iocp-scheduler.txt", "write")
    assert_eq(writer["status"], "open")
    la write_pending = fs.native_skriv_iocp(writer, 0, "file-iocp-scheduler-ok")
    la write_future = fs.native_iocp_async(loop, writer, write_pending, 5000)
    pump(loop, write_future)
    assert_eq(sched.future_status(loop, write_future), "ferdig")
    assert_eq(sched.future_resultat(loop, write_future)["value"], 22)
    assert_eq(fs.native_lukk(writer)["status"], "closed")

    la reader = fs.opne_native("build", "windows-filesystem-iocp-scheduler.txt", "read")
    assert_eq(reader["status"], "open")
    la read_pending = fs.native_les_iocp(reader, 0, 64)
    la read_future = fs.native_iocp_async(loop, reader, read_pending, 5000)
    pump(loop, read_future)
    assert_eq(sched.future_status(loop, read_future), "ferdig")
    assert_eq(sched.future_resultat(loop, read_future)["data"], "file-iocp-scheduler-ok")
    assert_eq(fs.native_lukk(reader)["status"], "closed")
    assert_eq(fs.native_slett("build", "windows-filesystem-iocp-scheduler.txt")["status"], "deleted")
    skriv("test_windows_filesystem_iocp_scheduler OK")
    returner 0
}

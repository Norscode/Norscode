bruk std.httpserver_vm som http_vm
bruk std.web som web
bruk std.tekst som t

funksjon start() -> heiltall {
    la health = http_vm.standard_helse_response_vm()
    assert_eq(http_vm.response_status_vm(health), 200)
    assert(t.inneholder(http_vm.response_body_vm(health), "\"ready\""))
    assert_eq(web.response_header(health, "cache-control"), "no-store")

    la ctx = http_vm.request_context_vm("GET", "/helse", {}, {"x-request-id": "req-1"}, "")
    la logg = http_vm.standard_server_log_vm(ctx, 200)
    assert_eq(logg["method"], "GET")
    assert_eq(logg["path"], "/helse")
    assert_eq(logg["status"], "200")
    assert_eq(logg["ok"], "sann")

    la server = http_vm.ny_server_vm(8084)
    http_vm.register_server_handler_vm(server, "helse_handler", "ok")
    http_vm.register_standard_health_routes_vm(server, "helse_handler")
    assert_eq(server["routes"]["GET /helse"], "helse_handler")
    assert_eq(server["routes"]["GET /health"], "helse_handler")

    skriv("test_httpserver_vm_health_log OK")
    returner 0
}

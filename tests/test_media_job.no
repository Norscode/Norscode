bruk std.media_job som jobb

funksjon start() -> heiltall {
    la j = jobb.ny("jobb-001", "video", "Lag ein kort demo", "lokal", 1000, 5000)
    assert_eq(j["status"], "ventar")
    assert(jobb.start(j, 1100))
    assert(jobb.oppdater_fremdrift(j, 25, 1200))
    assert(ikkje jobb.oppdater_fremdrift(j, 20, 1300))
    assert(ikkje jobb.sjekk_timeout(j, 6000))

    assert(jobb.fullfor(j, "media/resultat.mp4", "video/mp4", 6100))
    assert(jobb.terminal(j))
    assert_eq(heltall_fra_tekst(j["fremdrift"]), 100)

    la timeout = jobb.ny("jobb-002", "musikk", "Lag musikk", "lokal", 0, 100)
    assert(jobb.start(timeout, 10))
    assert(jobb.sjekk_timeout(timeout, 110))
    assert_eq(timeout["feil"], "timeout")

    la avbroten = jobb.ny("jobb-003", "bilde", "Lag bilde", "api", 0, 1000)
    assert(jobb.avbryt(avbroten, "brukar", 20))
    assert_eq(avbroten["status"], "avbroten")
    skriv("test_media_job OK\n")
    returner 0
}

funksjon phase6_smoke_status()
    returner {
        workflow: "ok",
        integration: "ok",
        status: "ok"
    }
slutt

funksjon test_phase6_smoke()
    status = phase6_smoke_status()
    assert_lik(status.workflow, "ok")
    assert_lik(status.integration, "ok")
    assert_lik(status.status, "ok")
    assert_lik(sann, sann)
slutt

bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la statisk = fil_les("std/statisk.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(statisk, "funksjon er_statisk_respons(resp: ordbok_tekst) -> boolsk")
    krev(statisk, "tekst(resp[\"__statisk__\"]) == \"nei\"")
    krev(statisk, "returner usann")
    krev(statisk, "har_nokkel(resp, \"__status__\")")
    krev(statisk, "returner sann")
    krev(manual, "`std.statisk`: statiske filer med MIME, cache, ETag og trygg \"ikkje statisk\"-flyt vidare til app-ruter.")

    skriv("test_statisk_response_detection_contract OK")
    returner 0
}

bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 1 }"
    )

    # ELF text section
    assert(tekst_inneholder(preview, ".text"))

    # Executable code section flag
    assert(tekst_inneholder(preview, "AX"))

    # Entrypoint must point into .text
    assert(tekst_inneholder(preview, "entry=.text"))

    # Machinecode bytes must exist
    assert(tekst_inneholder(preview, "machinecode"))

    # Return value emission
    assert(tekst_inneholder(preview, "return=1"))

    returner 0
}

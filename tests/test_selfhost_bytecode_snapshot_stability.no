bruk selfhost.common som sh

funksjon snapshot(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon stabil(expr: tekst) -> bool {
    la a: tekst = snapshot(expr)
    la b: tekst = snapshot(expr)
    la c: tekst = snapshot(expr)
    returner a == b og b == c
}

funksjon start() -> heltall {
    # Unary snapshot stability
    assert(stabil("ikkje 1"))

    # Boolean snapshot stability
    assert(stabil("1 og 0 eller 1"))

    # Nested snapshot stability
    assert(stabil("(1 eller 0) og (1 og 1)"))

    # Comparison snapshot stability
    assert(stabil("1 mindre_enn 2 og 1"))

    # Deep nesting snapshot stability
    assert(stabil("((((1 eller 0) og 1)))"))

    returner 0
}

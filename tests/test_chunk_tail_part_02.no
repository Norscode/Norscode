bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_fordi_alias: tekst = sh.disasm_uttrykk("1 fordi 0")
    assert_eq(expr_fordi_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_given_that_alias: tekst = sh.disasm_uttrykk("1 given_that 0")
    assert_eq(expr_given_that_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_gitt_at_alias: tekst = sh.disasm_uttrykk("1 gitt_at 0")
    assert_eq(expr_gitt_at_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_provided_that_alias: tekst = sh.disasm_uttrykk("1 provided_that 0")
    assert_eq(expr_provided_that_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_forutsatt_at_alias: tekst = sh.disasm_uttrykk("1 forutsatt_at 0")
    assert_eq(expr_forutsatt_at_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_follows_if_alias: tekst = sh.disasm_uttrykk("1 follows_if 0")
    assert_eq(expr_follows_if_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_folger_hvis_alias: tekst = sh.disasm_uttrykk("1 folger_hvis 0")
    assert_eq(expr_folger_hvis_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_if_given_alias: tekst = sh.disasm_uttrykk("1 if_given 0")
    assert_eq(expr_if_given_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_hvis_gitt_alias: tekst = sh.disasm_uttrykk("1 hvis_gitt 0")
    assert_eq(expr_hvis_gitt_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_as_alias: tekst = sh.disasm_uttrykk("1 as 0")
    assert_eq(expr_as_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_tersom_alias: tekst = sh.disasm_uttrykk("1 ettersom 0")
    assert_eq(expr_tersom_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_inasmuch_as_alias: tekst = sh.disasm_uttrykk("1 inasmuch_as 0")
    assert_eq(expr_inasmuch_as_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_i_og_med_at_alias: tekst = sh.disasm_uttrykk("1 i_og_med_at 0")
    assert_eq(expr_i_og_med_at_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_on_condition_that_alias: tekst = sh.disasm_uttrykk("1 on_condition_that 0")
    assert_eq(expr_on_condition_that_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_pa_vilkar_av_at_alias: tekst = sh.disasm_uttrykk("1 pa_vilkar_av_at 0")
    assert_eq(expr_pa_vilkar_av_at_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_granted_alias: tekst = sh.disasm_uttrykk("1 granted 0")
    assert_eq(expr_granted_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_gitt_dette_alias: tekst = sh.disasm_uttrykk("1 gitt_dette 0")
    assert_eq(expr_gitt_dette_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_with_premise_alias: tekst = sh.disasm_uttrykk("1 with_premise 0")
    assert_eq(expr_with_premise_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_med_premiss_alias: tekst = sh.disasm_uttrykk("1 med_premiss 0")
    assert_eq(expr_med_premiss_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_given_premise_alias: tekst = sh.disasm_uttrykk("1 given_premise 0")
    assert_eq(expr_given_premise_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_gitt_premiss_alias: tekst = sh.disasm_uttrykk("1 gitt_premiss 0")
    assert_eq(expr_gitt_premiss_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_premise_given_alias: tekst = sh.disasm_uttrykk("1 premise_given 0")
    assert_eq(expr_premise_given_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_premiss_gitt_alias: tekst = sh.disasm_uttrykk("1 premiss_gitt 0")
    assert_eq(expr_premiss_gitt_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_premise_assumed_alias: tekst = sh.disasm_uttrykk("1 premise_assumed 0")
    assert_eq(expr_premise_assumed_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_premiss_antatt_alias: tekst = sh.disasm_uttrykk("1 premiss_antatt 0")
    assert_eq(expr_premiss_antatt_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_premise_condition_alias: tekst = sh.disasm_uttrykk("1 premise_condition 0")
    assert_eq(expr_premise_condition_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_premiss_vilkar_alias: tekst = sh.disasm_uttrykk("1 premiss_vilkar 0")
    assert_eq(expr_premiss_vilkar_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_iff_alias: tekst = sh.disasm_uttrykk("1 iff 1")
    assert_eq(expr_iff_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_equiv_alias: tekst = sh.disasm_uttrykk("1 equiv 1")
    assert_eq(expr_equiv_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_ekvivalent_alias: tekst = sh.disasm_uttrykk("1 ekvivalent 1")
    assert_eq(expr_ekvivalent_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_if_and_only_if_alias: tekst = sh.disasm_uttrykk("1 if_and_only_if 1")
    assert_eq(expr_if_and_only_if_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_hvis_og_bare_hvis_alias: tekst = sh.disasm_uttrykk("1 hvis_og_bare_hvis 1")
    assert_eq(expr_hvis_og_bare_hvis_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_equiv_arrow_operator: tekst = sh.disasm_uttrykk("1 <-> 1")
    assert_eq(expr_equiv_arrow_operator, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_equiv_fat_arrow_operator: tekst = sh.disasm_uttrykk("1 <=> 1")
    assert_eq(expr_equiv_fat_arrow_operator, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_le: tekst = sh.disasm_uttrykk("3 <= 4")
    assert_eq(expr_le, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_ge: tekst = sh.disasm_uttrykk("4 >= 3")
    assert_eq(expr_ge, "0: PUSH 4\n1: PUSH 3\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_unary_not: tekst = sh.disasm_uttrykk("!0||0")
    assert_eq(expr_unary_not, "0: PUSH 0\n1: NOT\n2: PUSH 0\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_unary_minus: tekst = sh.disasm_uttrykk("-3+5")
    assert_eq(expr_unary_minus, "0: PUSH 3\n1: PUSH 0\n2: SWAP\n3: SUB\n4: PUSH 5\n5: ADD\n6: PRINT\n7: HALT\n")

    la expr_norsk_minus_med: tekst = sh.disasm_uttrykk("10 minus med 3")
    assert_eq(expr_norsk_minus_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minus_med_underscore: tekst = sh.disasm_uttrykk("10 minus_med 3")
    assert_eq(expr_norsk_minus_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minusmed_kompakt: tekst = sh.disasm_uttrykk("10 minusmed 3")
    assert_eq(expr_norsk_minusmed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseres_med: tekst = sh.disasm_uttrykk("10 minuseres med 3")
    assert_eq(expr_norsk_minuseres_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseres_med_underscore: tekst = sh.disasm_uttrykk("10 minuseres_med 3")
    assert_eq(expr_norsk_minuseres_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseresmed_kompakt: tekst = sh.disasm_uttrykk("10 minuseresmed 3")
    assert_eq(expr_norsk_minuseresmed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk_med: tekst = sh.disasm_uttrykk("10 trekk med 3")
    assert_eq(expr_norsk_trekk_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk_med_underscore: tekst = sh.disasm_uttrykk("10 trekk_med 3")
    assert_eq(expr_norsk_trekk_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkmed_kompakt: tekst = sh.disasm_uttrykk("10 trekkmed 3")
    assert_eq(expr_norsk_trekkmed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekke_med: tekst = sh.disasm_uttrykk("10 trekke med 3")
    assert_eq(expr_norsk_trekke_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekke_med_underscore: tekst = sh.disasm_uttrykk("10 trekke_med 3")
    assert_eq(expr_norsk_trekke_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkemed_kompakt: tekst = sh.disasm_uttrykk("10 trekkemed 3")
    assert_eq(expr_norsk_trekkemed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkes_med: tekst = sh.disasm_uttrykk("10 trekkes med 3")
    assert_eq(expr_norsk_trekkes_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkes_med_underscore: tekst = sh.disasm_uttrykk("10 trekkes_med 3")
    assert_eq(expr_norsk_trekkes_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkesmed_kompakt: tekst = sh.disasm_uttrykk("10 trekkesmed 3")
    assert_eq(expr_norsk_trekkesmed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher_med: tekst = sh.disasm_uttrykk("10 subtraher med 3")
    assert_eq(expr_norsk_subtraher_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher_med_underscore: tekst = sh.disasm_uttrykk("10 subtraher_med 3")
    assert_eq(expr_norsk_subtraher_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahermed_kompakt: tekst = sh.disasm_uttrykk("10 subtrahermed 3")
    assert_eq(expr_norsk_subtrahermed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherer_med: tekst = sh.disasm_uttrykk("10 subtraherer med 3")
    assert_eq(expr_norsk_subtraherer_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherer_med_underscore: tekst = sh.disasm_uttrykk("10 subtraherer_med 3")
    assert_eq(expr_norsk_subtraherer_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherermed_kompakt: tekst = sh.disasm_uttrykk("10 subtraherermed 3")
    assert_eq(expr_norsk_subtraherermed_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheres_med: tekst = sh.disasm_uttrykk("10 subtraheres med 3")
    assert_eq(expr_norsk_subtraheres_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    returner 0
}

bruk std.socketserver som ss

funksjon start() -> heiltall {
    la tenar = ss.ny_tcp_tenar("127.0.0.1", 0)
    assert_eq(tenar["transport"], "native")
    assert(ss.start(tenar, ""))
    assert_eq(tenar["aktiv"], "sann")
    assert(ss.er_aktiv(tenar))
    assert(heltall_fra_tekst(tenar["port"]) > 0)
    assert(ss.port_ledig(0))
    assert(ss.stopp(tenar))
    assert_eq(tenar["aktiv"], "usann")
    assert(ikkje ss.er_aktiv(tenar))

    la http = ss.ny_http_tenar("127.0.0.1", 0)
    assert(ss.start_http(http, "."))
    assert_eq(http["aktiv"], "sann")
    assert(ss.stopp(http))

    skriv("test_socketserver_native OK\n")
    returner 0
}

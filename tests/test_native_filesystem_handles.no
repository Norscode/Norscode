bruk std.runtime_filesystem som fs
bruk std.runtime.process_abi som process_abi
bruk std.sched som sched

funksjon symlink(target: tekst, link: tekst) -> boolsk {
    la req = process_abi.request("/bin/ln", ["-s", target, link], "", "", 5000, 4096)
    returner heltall_fra_tekst(builtin.process_spawn_argv(req)["exit_code"]) == 0
}

funksjon start() -> heiltall {
    assert_eq(builtin.filesystem_read_operation({"abi": fs.native_versjon(), "operation": "open", "root": "build", "relative": "forbidden-write.txt", "mode": "write"})["status"], "feil")
    assert_eq(builtin.filesystem_write_operation({"abi": fs.native_versjon(), "operation": "open", "root": "build", "relative": "runtime-fs-native.txt", "mode": "read"})["status"], "feil")
    fs.native_slett("build", "runtime-fs-native.txt")
    fs.native_slett("build", "runtime-fs-native-link")
    fs.native_slett("build", "runtime-fs-native-dirlink")

    la h = fs.opne_native("build", "runtime-fs-native.txt", "write")
    assert_eq(h["status"], "open")
    assert(h["event_backend"] == "kqueue" eller h["event_backend"] == "epoll" eller h["event_backend"] == "poll")
    assert_eq(fs.native_skriv(h, "abc")["value"], 3)
    assert_eq(fs.native_seek(h, 1)["value"], 1)
    assert_eq(fs.native_skriv(h, "XY")["value"], 2)
    assert_eq(fs.native_flush(h)["status"], "ok")
    assert_eq(fs.native_stat(h)["value"], 3)
    assert_eq(fs.native_lukk(h)["status"], "closed")

    la r = fs.opne_native("build", "runtime-fs-native.txt", "read")
    assert_eq(r["status"], "open")
    assert_eq(fs.native_stat({"handle": "file:999:999"})["status"], "feil")
    assert_eq(fs.native_les(r, 2)["data"], "aX")
    assert_eq(fs.native_les(r, 8)["data"], "Y")
    assert_eq(fs.native_lukk(r)["status"], "closed")

    fs.native_slett("build", "runtime-fs-native-async.txt")
    la async_write = fs.opne_native("build", "runtime-fs-native-async.txt", "write")
    la write_loop = sched.ny()
    la write_future = fs.native_skriv_async(write_loop, async_write, "future-data", 1000)
    assert_eq(sched.future_status(write_loop, write_future), "ventende")
    assert_eq(sched.io_poll(write_loop), 1)
    assert_eq(heltall_fra_tekst(sched.future_resultat(write_loop, write_future)), 11)
    assert_eq(fs.native_flush(async_write)["status"], "ok")
    assert_eq(fs.native_lukk(async_write)["status"], "closed")

    la async_read = fs.opne_native("build", "runtime-fs-native-async.txt", "read")
    la read_loop = sched.ny()
    la read_future = fs.native_les_async(read_loop, async_read, 64, 1000)
    assert_eq(sched.future_status(read_loop, read_future), "ventende")
    assert_eq(sched.io_poll(read_loop), 1)
    assert_eq(sched.future_resultat(read_loop, read_future), "future-data")
    assert_eq(fs.native_lukk(async_read)["status"], "closed")

    la closed_loop = sched.ny()
    la closed_future = fs.native_les_async(closed_loop, async_read, 8, 1000)
    assert_eq(sched.io_poll(closed_loop), 1)
    assert_eq(sched.future_status(closed_loop, closed_future), "feil")
    assert(sched.future_feil(closed_loop, closed_future) != "")

    la cancel_handle = fs.opne_native("build", "runtime-fs-native-async.txt", "read")
    la cancel_loop = sched.ny()
    la cancel_future = fs.native_les_async(cancel_loop, cancel_handle, 8, 1000)
    assert(sched.future_kanseller(cancel_loop, cancel_future))
    assert_eq(sched.future_status(cancel_loop, cancel_future), "kansellert")
    assert_eq(fs.native_lukk(cancel_handle)["status"], "closed")
    assert_eq(fs.native_slett("build", "runtime-fs-native-async.txt")["status"], "deleted")

    assert_eq(fs.opne_native("build", "../README.md", "read")["status"], "feil")
    assert(symlink("../README.md", "build/runtime-fs-native-link"))
    assert_eq(fs.opne_native("build", "runtime-fs-native-link", "read")["status"], "feil")
    assert(symlink("..", "build/runtime-fs-native-dirlink"))
    assert_eq(fs.opne_native("build", "runtime-fs-native-dirlink/README.md", "read")["status"], "feil")

    assert_eq(fs.native_slett("build", "runtime-fs-native-link")["status"], "deleted")
    assert_eq(fs.native_slett("build", "runtime-fs-native-dirlink")["status"], "deleted")
    assert_eq(fs.native_slett("build", "runtime-fs-native.txt")["status"], "deleted")
    assert_eq(fs.opne_native("build", "runtime-fs-native.txt", "read")["status"], "feil")
    skriv("test_native_filesystem_handles OK")
    returner 0
}

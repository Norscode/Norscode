bruk tools.build_hybrid_compiler_bundle_v9400 som builder

funksjon start() -> heiltall {
    la root = builtin.miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la active = root + "/build/v9400/hybrid_compiler_bundle_v9400.ncb.json"
    la ir = root + "/bootstrap/precompiled/ir_to_bytecode.ncb.json"
    la out = "/tmp/norscode_hybrid_bundle_repro_" + builtin.random_hex(8) + ".ncb.json"

    assert_eq(builder.bygg(root, out, ir), 0)
    la expected = builtin.json_parse_raw(builtin.fil_les(active))
    la actual = builtin.json_parse_raw(builtin.fil_les(out))
    // NCB-map serialisering kan ha plattformavhengig nøkkelrekkefølge. Verifiser
    // derfor den semantiske bundle-kontrakten i stedet for rå JSON-bytefølge.
    assert_eq(tekst(actual["entry"]), tekst(expected["entry"]))
    assert_eq(lengde(actual["functions"]), lengde(expected["functions"]))
    assert(actual["functions"]["fresh.kompiler.kompiler_fil"] != null)
    assert(actual["functions"]["fresh.ir.emit_uttrykk"] != null)
    assert(builder.ok(builder.kommando("rm -f '" + out + "'")))
    skriv("test_hybrid_compiler_bundle_repro OK")
    returner 0
}

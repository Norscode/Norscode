bruk tools.build_hybrid_compiler_bundle_v9400 som builder

funksjon start() -> heiltall {
    la root = builtin.miljo_hent("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la active = root + "/build/v9400/hybrid_compiler_bundle_v9400.ncb.json"
    la ir = root + "/build/v3002/ir_to_bytecode_source_check4.ncb.json"
    la out = "/tmp/norscode_hybrid_bundle_repro_" + builtin.random_hex(8) + ".ncb.json"

    assert_eq(builder.bygg(root, out, ir), 0)
    la expected = json_skriv(builtin.json_parse_raw(builtin.fil_les(active)))
    la actual = json_skriv(builtin.json_parse_raw(builtin.fil_les(out)))
    assert_eq(actual, expected)
    assert(builder.ok(builder.kommando("rm -f '" + out + "'")))
    skriv("test_hybrid_compiler_bundle_repro OK")
    returner 0
}

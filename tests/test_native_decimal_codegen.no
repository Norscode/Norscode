funksjon start() -> heiltall {
    la verdi = 1.5
    la resultat = (verdi + 2.25) * 2.0
    assert_eq(type_av(verdi), "desimaltall")
    assert_eq(type_av(resultat), "desimaltall")
    assert_eq(resultat, 7.5)
    assert_eq(builtin.json_stringify(resultat), "7.5")
    skriv("test_native_decimal_codegen OK")
    returner 0
}

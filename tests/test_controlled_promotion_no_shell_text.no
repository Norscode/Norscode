bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/controlled_runtime_promotion_v3005.no")

    assert(t.inneholder(src, "builtin.index_of(builtin.fil_les(path), needle)"))
    assert(t.inneholder(src, "returner builtin.fil_les(path)"))
    assert(t.inneholder(src, "funksjon no_line(key: tekst, value: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.fil_skriv(report, body)"))
    assert(t.inneholder(src, "bruk std.path som path"))
    assert(t.inneholder(src, "path.basename(stage0)"))
    assert(t.inneholder(src, "funksjon gap_gate_cmd(root: tekst, bin_path: tekst) -> tekst"))
    assert(t.inneholder(src, "NORSCODE_NATIVE_GAP_BIN="))
    assert(t.inneholder(src, "tools/native_runtime_gap_gate_v3001.no"))
    assert(t.inneholder(src, "tools/native_runtime_gap_promotion_readiness_v3003.no"))
    assert(t.inneholder(src, "tools/promote_native_stage0_v3001.no"))
    assert(t.inneholder(src, "NORSCODE_PROMOTE_CANDIDATE="))

    assert(ikkje t.inneholder(src, "grep -Fq"))
    assert(ikkje t.inneholder(src, "kommando(\"cat "))
    assert(ikkje t.inneholder(src, "kommando(\"basename "))
    assert(ikkje t.inneholder(src, "printf 'controlled_runtime_promotion"))
    assert(ikkje t.inneholder(src, ": > "))
    assert(ikkje t.inneholder(src, "promote_native_stage0_v3001.sh"))
    assert(ikkje t.inneholder(src, "native_runtime_gap_gate_v3001.sh"))
    assert(ikkje t.inneholder(src, "native_runtime_gap_promotion_readiness_v3003.sh"))

    skriv("test_controlled_promotion_no_shell_text OK")
    returner 0
}

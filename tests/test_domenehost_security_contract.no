bruk std.domenehost som host

funksjon start() -> heiltall {
    la h = host.ny("example.no")
    host.legg_admin_kjelde(h, "10.0.0.0/8")
    assert(builtin.starts_with(h["admin_allowlist"], "["))
    assert(ikkje host.produksjon_klar(h, "DKIMKEY"))
    h["dnssec_signed"] = "sann"
    h["dnssec_ds"] = "1234 8 2 ABCDEF"
    la policy = host.brannmur_policy(h)
    assert_eq(policy["default_inn"], "drop")
    assert_eq(policy["egress_restricted"], "sann")
    la cfg = host.produksjon_konfig(h, "DKIMKEY")
    assert_eq(cfg["dnssec"], "sann")
    assert_eq(cfg["mail_dkim"], "sann")
    assert_eq(cfg["open_relay_blocked"], "sann")
    skriv("test_domenehost_security_contract OK\n")
    returner 0
}

bruk std.tekst som t

funksjon start() -> heiltall {
    la gate = fil_les("tools/completion_gate.no")
    assert(t.inneholder(gate, "norscode-completion-gate-v1"))
    assert(t.inneholder(gate, "./bin/nc local-green --strict"))
    assert(t.inneholder(gate, "NC_SLOW_TESTS=1 SLOW_TEST_TIMEOUT=600 ./bin/nc test"))
    assert(t.inneholder(gate, "tools/release_user_journey.no"))
    assert(t.inneholder(gate, "runtime_stable"))
    assert(t.inneholder(gate, "stdlib_stable"))
    assert(t.inneholder(gate, "production_ready_all_platforms"))
    assert(t.inneholder(gate, "gh attestation verify"))
    assert(t.inneholder(gate, "NORSCODE_MACOS_ATTESTATION"))
    assert(t.inneholder(gate, "NORSCODE_LINUX_X86_64_ATTESTATION"))
    assert(t.inneholder(gate, "NORSCODE_LINUX_ARM64_ATTESTATION"))
    assert(t.inneholder(gate, "attestasjon_runtime_path"))
    assert(t.inneholder(gate, "NORSCODE_MACOS_"))
    assert(t.inneholder(gate, "NORSCODE_LINUX_"))
    assert(t.inneholder(gate, "release-sluttport krev rein spora kjelde"))
    la journey = fil_les("tools/release_user_journey.no")
    assert(t.inneholder(journey, "package-release"))
    assert(t.inneholder(journey, "install-release"))
    assert(t.inneholder(journey, "startproject"))
    assert(t.inneholder(journey, "native_execution/native_codegen_v2.ncb.json"))
    assert(t.inneholder(journey, "tests/test_web_routes.ncb.json"))
    assert(t.inneholder(journey, "tests/test_db.ncb.json"))
    assert(t.inneholder(journey, "rollback til versjon A"))
    la attest = fil_les("tools/platform_runtime_attestation.no")
    assert(t.inneholder(attest, "norscode-platform-runtime-attestation-v1"))
    assert(t.inneholder(attest, "source_commit"))
    assert(t.inneholder(attest, "runtime_sha256"))
    skriv("test_completion_gate OK")
    returner 0
}

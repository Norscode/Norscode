bruk std.tensor som tensor

funksjon start() -> heiltall {
    la a = tensor.fra_liste([1, 2, 3, 4, 5, 6], 2, 3)
    la b = tensor.fra_liste([7, 8, 9, 10, 11, 12], 3, 2)
    la c = tensor.matmul(a, b)
    assert_eq(c["rader"], 2)
    assert_eq(c["kolonner"], 2)
    assert_eq(c["data"][0], 58)
    assert_eq(c["data"][1], 64)
    assert_eq(c["data"][2], 139)
    assert_eq(c["data"][3], 154)

    la d = tensor.legg_bias(c, [-60, -60])
    la e = tensor.relu(d)
    assert_eq(e["data"][0], 0)
    assert_eq(e["data"][1], 4)
    assert_eq(tensor.argmaks(e), 3)
    skriv("test_tensor OK\n")
    returner 0
}

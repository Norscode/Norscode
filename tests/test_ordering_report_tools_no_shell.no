bruk std.tekst som t

funksjon sjekk_rapportverktoy(src: tekst) {
    assert(t.inneholder(src, "funksjon linje_diff"))
    assert(t.inneholder(src, "funksjon stabil_hash"))
    assert(t.inneholder(src, "builtin.fil_les"))
    assert(t.inneholder(src, "builtin.fil_skriv"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "./bin/nc run tools/"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "exec_prosess"))
    assert(ikkje t.inneholder(src, "Usage: "))
    assert(ikkje t.inneholder(src, ".sh <"))
    assert(ikkje t.inneholder(src, "shasum"))
    assert(ikkje t.inneholder(src, "sha256sum"))
    assert(ikkje t.inneholder(src, "awk"))
    assert(ikkje t.inneholder(src, "diff -u"))
    assert(ikkje t.inneholder(src, "printf '%s'"))
}

funksjon start() -> heiltall {
    la backend = fil_les("tools/backend_ordering_validator.no")
    la semantic = fil_les("tools/semantic_diff_analyzer.no")
    la backend_wrapper = fil_les("tools/backend_ordering_validator.sh")
    la semantic_wrapper = fil_les("tools/semantic_diff_analyzer.sh")

    sjekk_rapportverktoy(backend)
    sjekk_rapportverktoy(semantic)
    assert(t.inneholder(backend_wrapper, "Norscode-first wrapper: backend-rekkefølgjerapport ligg i tools/backend_ordering_validator.no."))
    assert(t.inneholder(backend_wrapper, "Shell-delen under mappar CLI-argument til miljø og startar Norscode-eigarfil."))
    assert(t.inneholder(backend_wrapper, "NORSCODE_BACKEND_OUTPUT_A=<backend_output_a> NORSCODE_BACKEND_OUTPUT_B=<backend_output_b> ./bin/nc run tools/backend_ordering_validator.no"))
    assert(t.inneholder(backend_wrapper, "mkdir -p"))
    assert(ikkje t.inneholder(backend_wrapper, "Usage: backend_ordering_validator.sh"))
    assert(ikkje t.inneholder(backend_wrapper, "backend_ordering_validator.sh <"))
    assert(ikkje t.inneholder(backend_wrapper, "Tynn wrapper"))
    assert(t.inneholder(semantic_wrapper, "Norscode-first wrapper: semantisk diff ligg i tools/semantic_diff_analyzer.no."))
    assert(t.inneholder(semantic_wrapper, "Shell-delen under mappar CLI-argument til rot/miljø og startar Norscode-eigarfil."))
    assert(t.inneholder(semantic_wrapper, "NORSCODE_SEMANTIC_A=<symbols_a> NORSCODE_SEMANTIC_B=<symbols_b> ./bin/nc run tools/semantic_diff_analyzer.no"))
    assert(t.inneholder(semantic_wrapper, "NORSCODE_ENABLE_EXEC_PROSESS=\"${NORSCODE_ENABLE_EXEC_PROSESS:-1}\" NORSCODE_ROOT=\"$ROOT\" \"$ROOT/bin/nc\" run \"$ROOT/tools/semantic_diff_analyzer.no\""))
    assert(ikkje t.inneholder(semantic_wrapper, "exec \"$ROOT/bin/nc\" run \"$ROOT/tools/semantic_diff_analyzer.no\""))
    assert(t.inneholder(semantic_wrapper, "mkdir -p"))
    assert(ikkje t.inneholder(semantic_wrapper, "Usage: semantic_diff_analyzer.sh"))
    assert(ikkje t.inneholder(semantic_wrapper, "semantic_diff_analyzer.sh <"))
    assert(ikkje t.inneholder(semantic_wrapper, "Tynn wrapper"))

    skriv("test_ordering_report_tools_no_shell OK")
    returner 0
}

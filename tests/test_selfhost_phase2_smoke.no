bruk std.log som log
bruk std.fil som fil
bruk std.cache som cache
bruk std.lagring som lagring
bruk std.innstillingar som cfg
bruk std.sched som sched
bruk std.trad som trd

funksjon start() -> heiltall {
    la logg = log.info("hei")
    assert_eq(log.nivå(logg), "info")
    assert_eq(log.melding(logg), "hei")
    assert_eq(log.har_felt(logg, "ts"), sann)

    la fil_status = fil.status("README.md")
    assert_eq(fil_status["gyldig"], "sann")

    la cache_m = cache.ny_minne()
    la cache_status = cache.status(cache_m)
    assert_eq(cache_status["gyldig"], "sann")

    la lag = lagring.lagre("build/phase2_smoke.json", {"nøkkel": "verdi"})
    assert_eq(lag, 1)

    la s = cfg.ny()
    la cfg_status = cfg.status(s)
    assert_eq(cfg_status["gyldig"], "sann")
    assert_eq(cfg_status["kjelde"], "tom")

    la sc = sched.ny()
    la sc_status = sched.status(sc)
    assert_eq(sc_status["gyldig"], "sann")
    assert_eq(sc_status["tal_ventande"], "0")

    la manager = trd.ny_manager()
    la trd_status = trd.status_oversikt(manager)
    assert_eq(trd_status["gyldig"], "sann")
    assert_eq(trd_status["aktive"], "0")

    returner 0
}

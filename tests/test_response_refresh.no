funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nRefresh: 5; url=/\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "refresh": "5; url=/", "body": "hei"})
    assert_eq(builtin.contains(resp, "Refresh: 5; url=/"), sann)
    returner 0
}

bruk std.runtime.allocator som allocator

funksjon start() -> heiltall {
    la a = allocator.ny_allocator(4096, 256)
    la lock = allocator.ny_allocator_lock()
    assert(allocator.allocator_lock(lock, "thread-a"))
    assert(allocator.allocator_lock(lock, "thread-a"))
    assert_eq(lock["depth"], "2")
    assert(ikkje allocator.allocator_lock(lock, "thread-b"))
    assert_eq(allocator.allocator_lock_stats(lock)["contentions"], "1")
    assert(ikkje allocator.allocator_unlock(lock, "thread-b"))
    assert_eq(allocator.allocator_lock_stats(lock)["owner_errors"], "1")
    assert(allocator.allocator_unlock(lock, "thread-a"))
    assert_eq(lock["depth"], "1")
    assert(allocator.allocator_unlock(lock, "thread-a"))
    assert_eq(lock["owner"], "")

    la p1 = allocator.alloker_locked(a, lock, "thread-a", 12)
    assert_eq(p1, 4096)
    assert_eq(lock["owner"], "")
    assert(allocator.frigjor_locked(a, lock, "thread-b", p1))
    la p2 = allocator.alloker_locked(a, lock, "thread-b", 8)
    assert_eq(p2, p1)
    la compact = allocator.kompakter_locked(a, lock, "thread-b")
    assert_eq(compact["status"], "ferdig")

    assert(allocator.allocator_lock(lock, "thread-a"))
    assert_eq(allocator.alloker_locked(a, lock, "thread-b", 8), -1)
    assert_eq(allocator.kompakter_locked(a, lock, "thread-b")["status"], "opptatt")
    assert(allocator.allocator_unlock(lock, "thread-a"))
    returner 0
}

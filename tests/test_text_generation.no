bruk std.text_generation som tekstgen
bruk std.transformer som transformer
bruk std.sampling som sampling
bruk std.tokenizer som tokenizer

funksjon modell() {
    la embedding: liste_heiltall = [1, 0, 0, 1, 1, 1, 2, 1]
    la lm: liste_heiltall = [2, 0, 1, 3, 0, 2, 1, 1]
    la m = tekstgen.ny("mini-q8", 4, 2, embedding, lm, [0, 0, 0, 0], 1, 8)
    la identitet: liste_heiltall = [1, 0, 0, 1]
    la b = transformer.blokk(2, 2, identitet, identitet, identitet, identitet,
        identitet, [0, 0], identitet, [0, 0], 1)
    assert(tekstgen.legg_til_blokk(m, b))
    returner m
}

funksjon start() -> heiltall {
    la m = modell()
    la logit = tekstgen.neste_logit(m, [0, 1])
    assert_eq(lengde(logit), 4)

    la a = sampling.ny(17, 1, 100, 1, 3, -1)
    la b = sampling.ny(17, 1, 100, 1, 3, -1)
    la ra = tekstgen.generer(m, [0], a, 3)
    la rb = tekstgen.generer(m, [0], b, 3)
    assert_eq(lengde(ra["nye_token"]), 3)
    assert_eq(lengde(ra["token"]), 4)
    la i: heiltall = 0
    mens i < lengde(ra["token"]) {
        assert_eq(ra["token"][i], rb["token"][i])
        i = i + 1
    }
    la tok = tokenizer.ny(["?", "a", "b", " "], 0, -1, -1, 20)
    la tekst_samplar = sampling.ny(3, 1, 100, 0, 1, -1)
    la tekst_resultat = tekstgen.generer_tekst(m, tok, "a", tekst_samplar, 1)
    assert_eq(lengde(tekst_resultat["nye_token"]), 1)
    assert(lengde(tekst_resultat["tekst"]) >= 1)
    skriv("test_text_generation OK\n")
    returner 0
}

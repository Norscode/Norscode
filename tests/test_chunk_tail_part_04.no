bruk selfhost.common som sh

funksjon start() -> heiltall {
    la expr_norsk_adderermed_kompakt: tekst = sh.disasm_uttrykk("2 adderermed 3")
    assert_eq(expr_norsk_adderermed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderes_med: tekst = sh.disasm_uttrykk("2 adderes med 3")
    assert_eq(expr_norsk_adderes_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderes_med_underscore: tekst = sh.disasm_uttrykk("2 adderes_med 3")
    assert_eq(expr_norsk_adderes_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderesmed_kompakt: tekst = sh.disasm_uttrykk("2 adderesmed 3")
    assert_eq(expr_norsk_adderesmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adder: tekst = sh.disasm_uttrykk("2 adder 3")
    assert_eq(expr_norsk_adder, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summer_med: tekst = sh.disasm_uttrykk("2 summer med 3")
    assert_eq(expr_norsk_summer_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summer_med_underscore: tekst = sh.disasm_uttrykk("2 summer_med 3")
    assert_eq(expr_norsk_summer_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summermed_kompakt: tekst = sh.disasm_uttrykk("2 summermed 3")
    assert_eq(expr_norsk_summermed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summerer_med: tekst = sh.disasm_uttrykk("2 summerer med 3")
    assert_eq(expr_norsk_summerer_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summerer_med_underscore: tekst = sh.disasm_uttrykk("2 summerer_med 3")
    assert_eq(expr_norsk_summerer_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summerermed_kompakt: tekst = sh.disasm_uttrykk("2 summerermed 3")
    assert_eq(expr_norsk_summerermed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summeres_med: tekst = sh.disasm_uttrykk("2 summeres med 3")
    assert_eq(expr_norsk_summeres_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summeres_med_underscore: tekst = sh.disasm_uttrykk("2 summeres_med 3")
    assert_eq(expr_norsk_summeres_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summeresmed_kompakt: tekst = sh.disasm_uttrykk("2 summeresmed 3")
    assert_eq(expr_norsk_summeresmed_kompakt, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summer: tekst = sh.disasm_uttrykk("2 summer 3")
    assert_eq(expr_norsk_summer, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk_fra: tekst = sh.disasm_uttrykk("10 trekk fra 3")
    assert_eq(expr_norsk_trekk_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk_fra_underscore: tekst = sh.disasm_uttrykk("10 trekk_fra 3")
    assert_eq(expr_norsk_trekk_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkfra_kompakt: tekst = sh.disasm_uttrykk("10 trekkfra 3")
    assert_eq(expr_norsk_trekkfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekke_fra_underscore: tekst = sh.disasm_uttrykk("10 trekke_fra 3")
    assert_eq(expr_norsk_trekke_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkefra_kompakt: tekst = sh.disasm_uttrykk("10 trekkefra 3")
    assert_eq(expr_norsk_trekkefra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkes_fra: tekst = sh.disasm_uttrykk("10 trekkes fra 3")
    assert_eq(expr_norsk_trekkes_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkes_fra_underscore: tekst = sh.disasm_uttrykk("10 trekkes_fra 3")
    assert_eq(expr_norsk_trekkes_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkesfra_kompakt: tekst = sh.disasm_uttrykk("10 trekkesfra 3")
    assert_eq(expr_norsk_trekkesfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minus_fra: tekst = sh.disasm_uttrykk("10 minus fra 3")
    assert_eq(expr_norsk_minus_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minus_fra_underscore: tekst = sh.disasm_uttrykk("10 minus_fra 3")
    assert_eq(expr_norsk_minus_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minusfra_kompakt: tekst = sh.disasm_uttrykk("10 minusfra 3")
    assert_eq(expr_norsk_minusfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseres_fra: tekst = sh.disasm_uttrykk("10 minuseres fra 3")
    assert_eq(expr_norsk_minuseres_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseres_fra_underscore: tekst = sh.disasm_uttrykk("10 minuseres_fra 3")
    assert_eq(expr_norsk_minuseres_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseresfra_kompakt: tekst = sh.disasm_uttrykk("10 minuseresfra 3")
    assert_eq(expr_norsk_minuseresfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher_fra: tekst = sh.disasm_uttrykk("10 subtraher fra 3")
    assert_eq(expr_norsk_subtraher_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher_fra_underscore: tekst = sh.disasm_uttrykk("10 subtraher_fra 3")
    assert_eq(expr_norsk_subtraher_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherfra_kompakt: tekst = sh.disasm_uttrykk("10 subtraherfra 3")
    assert_eq(expr_norsk_subtraherfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherer_fra: tekst = sh.disasm_uttrykk("10 subtraherer fra 3")
    assert_eq(expr_norsk_subtraherer_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherer_fra_underscore: tekst = sh.disasm_uttrykk("10 subtraherer_fra 3")
    assert_eq(expr_norsk_subtraherer_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahererfra_kompakt: tekst = sh.disasm_uttrykk("10 subtrahererfra 3")
    assert_eq(expr_norsk_subtrahererfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheres_fra: tekst = sh.disasm_uttrykk("10 subtraheres fra 3")
    assert_eq(expr_norsk_subtraheres_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheres_fra_underscore: tekst = sh.disasm_uttrykk("10 subtraheres_fra 3")
    assert_eq(expr_norsk_subtraheres_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheresfra_kompakt: tekst = sh.disasm_uttrykk("10 subtraheresfra 3")
    assert_eq(expr_norsk_subtraheresfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahert_fra: tekst = sh.disasm_uttrykk("10 subtrahert fra 3")
    assert_eq(expr_norsk_subtrahert_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahert_fra_underscore: tekst = sh.disasm_uttrykk("10 subtrahert_fra 3")
    assert_eq(expr_norsk_subtrahert_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtrahertfra_kompakt: tekst = sh.disasm_uttrykk("10 subtrahertfra 3")
    assert_eq(expr_norsk_subtrahertfra_kompakt, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_div: tekst = sh.disasm_uttrykk("8 delt pa 2")
    assert_eq(expr_norsk_div, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_mod: tekst = sh.disasm_uttrykk("17 mod 5")
    assert_eq(expr_norsk_mod, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_mod_av: tekst = sh.disasm_uttrykk("17 mod_av 5")
    assert_eq(expr_norsk_mod_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modav: tekst = sh.disasm_uttrykk("17 modav 5")
    assert_eq(expr_norsk_modav, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_mod_av_phrase: tekst = sh.disasm_uttrykk("17 mod av 5")
    assert_eq(expr_norsk_mod_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulo: tekst = sh.disasm_uttrykk("17 modulo 5")
    assert_eq(expr_norsk_modulo, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulo_av: tekst = sh.disasm_uttrykk("17 modulo_av 5")
    assert_eq(expr_norsk_modulo_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_moduloav: tekst = sh.disasm_uttrykk("17 moduloav 5")
    assert_eq(expr_norsk_moduloav, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulo_av_phrase: tekst = sh.disasm_uttrykk("17 modulo av 5")
    assert_eq(expr_norsk_modulo_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modul: tekst = sh.disasm_uttrykk("17 modul 5")
    assert_eq(expr_norsk_modul, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modul_av: tekst = sh.disasm_uttrykk("17 modul_av 5")
    assert_eq(expr_norsk_modul_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulav: tekst = sh.disasm_uttrykk("17 modulav 5")
    assert_eq(expr_norsk_modulav, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modul_av_phrase: tekst = sh.disasm_uttrykk("17 modul av 5")
    assert_eq(expr_norsk_modul_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulus: tekst = sh.disasm_uttrykk("17 modulus 5")
    assert_eq(expr_norsk_modulus, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulus_av: tekst = sh.disasm_uttrykk("17 modulus_av 5")
    assert_eq(expr_norsk_modulus_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulusav: tekst = sh.disasm_uttrykk("17 modulusav 5")
    assert_eq(expr_norsk_modulusav, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulus_av_phrase: tekst = sh.disasm_uttrykk("17 modulus av 5")
    assert_eq(expr_norsk_modulus_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_rest: tekst = sh.disasm_uttrykk("17 rest 5")
    assert_eq(expr_norsk_rest, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_resten: tekst = sh.disasm_uttrykk("17 resten 5")
    assert_eq(expr_norsk_resten, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    returner 0
}

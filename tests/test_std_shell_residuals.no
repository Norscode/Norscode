bruk std.tekst som t

funksjon tel(haystack: tekst, needle: tekst) -> heiltall {
    returner lengde(builtin.split(haystack, needle)) - 1
}

funksjon krev_ingen_rå_sti_shell(sti: tekst) {
    la src = fil_les(sti)
    assert(ikkje t.inneholder(src, "returner \"'\" + sti + \"'\""))
}

funksjon krev_trygg_s_shell(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.replace(s, \"'\""))
    assert(ikkje t.inneholder(src, "returner \"'\" + s + \"'\""))
}

funksjon krev_standard_shellquote(sti: tekst) {
    la src = fil_les(sti)
    assert(ikkje t.inneholder(src, "\"'\\\\''\""))
}

funksjon start() -> heiltall {
    la stat = fil_les("std/stat.no")
    assert(tel(stat, "test -r \" + _shell(sti)") == 1)
    assert(tel(stat, "test -w \" + _shell(sti)") == 1)
    assert(tel(stat, "test -x \" + _shell(sti)") == 1)
    assert(ikkje t.inneholder(stat, "&& echo ja || echo nei"))
    assert(ikkje t.inneholder(stat, "test -e "))
    assert(ikkje t.inneholder(stat, "test -f "))
    assert(ikkje t.inneholder(stat, "test -d "))

    la pathlib = fil_les("std/pathlib.no")
    assert(tel(pathlib, "test -L \" + _shell(p[\"sti\"])") == 1)
    assert(ikkje t.inneholder(pathlib, "&& echo ja || echo nei"))
    assert(ikkje t.inneholder(pathlib, "test -f \" + _shell(p[\"sti\"])"))
    assert(ikkje t.inneholder(pathlib, "test -d \" + _shell(p[\"sti\"])"))
    assert(ikkje t.inneholder(pathlib, "ls -1a \" + _shell(p[\"sti\"])"))

    la tarfile = fil_les("std/tarfile.no")
    assert(t.inneholder(tarfile, "tar -tf \" + _shell(sti) + \" >/dev/null 2>&1"))
    assert(ikkje t.inneholder(tarfile, "&& echo ja || echo nei"))

    la filecmp = fil_les("std/filecmp.no")
    assert(ikkje t.inneholder(filecmp, "&& echo LIKE || echo ULIK"))
    assert(ikkje t.inneholder(filecmp, "test -d \" + _shell(sti)"))
    assert(ikkje t.inneholder(filecmp, "ls -1 \" + _shell(sti)"))

    la filops = fil_les("std/filops.no")
    assert(tel(filops, "wc -c < \" + _shell(sti) + \" 2>/dev/null") == 1)
    assert(t.inneholder(filops, "la innhald = builtin.fil_les(sti)"))
    assert(ikkje t.inneholder(filops, "test -d \" + _shell(sti)"))
    assert(ikkje t.inneholder(filops, "ls -1 \" + _shell(sti)"))
    assert(ikkje t.inneholder(filops, "ls -d1 \" + mønster"))

    la shutil = fil_les("std/shutil.no")
    assert(tel(shutil, "wc -c < \" + _shell(sti) + \" 2>/dev/null") == 1)
    assert(t.inneholder(shutil, "la innhald = builtin.fil_les(sti)"))
    assert(ikkje t.inneholder(shutil, "ls -1 \" + _shell(sti)"))

    la gzip = fil_les("std/gzip.no")
    assert(tel(gzip, "wc -c < \" + _shell(gz_sti) + \" 2>/dev/null") == 1)
    assert(t.inneholder(gzip, "la innhald = builtin.fil_les(gz_sti)"))
    assert(ikkje t.inneholder(gzip, "&& echo OK || echo FEIL"))

    krev_standard_shellquote("std/wsgiref.no")
    krev_standard_shellquote("std/prosess.no")
    krev_standard_shellquote("std/fileinput.no")
    krev_standard_shellquote("std/ftplib.no")
    krev_standard_shellquote("std/webbrowser.no")
    krev_standard_shellquote("std/filops.no")
    krev_standard_shellquote("std/socketserver.no")
    krev_standard_shellquote("std/poplib.no")
    krev_standard_shellquote("std/smtplib.no")
    krev_standard_shellquote("std/imaplib.no")
    krev_standard_shellquote("std/plistlib.no")
    krev_standard_shellquote("std/syslog.no")
    krev_standard_shellquote("std/stat.no")
    krev_standard_shellquote("std/shlex.no")
    krev_standard_shellquote("std/multiprocessing.no")

    krev_ingen_rå_sti_shell("tools/rollback_serve_runner_cookie_fix_v682.no")
    krev_ingen_rå_sti_shell("tools/test_kernel_boot.no")
    krev_ingen_rå_sti_shell("tools/unified_bootstrap_verifier.no")
    krev_ingen_rå_sti_shell("tools/backup_stage0_before_random_hex_v734.no")
    krev_ingen_rå_sti_shell("tools/build-bootstrap-binary.no")
    krev_ingen_rå_sti_shell("tools/build-macos-window-host.no")
    krev_ingen_rå_sti_shell("tools/generate_build_embed_c.no")
    krev_ingen_rå_sti_shell("tools/no_legacy_cvm.no")
    krev_ingen_rå_sti_shell("tools/backup_native_stage0_v723.no")
    krev_ingen_rå_sti_shell("tools/nc_test.no")
    krev_ingen_rå_sti_shell("tools/test_random_session_v704.no")
    krev_ingen_rå_sti_shell("tools/compare_compilers.no")
    krev_ingen_rå_sti_shell("tools/bootstrap_diff_analyzer.no")
    krev_ingen_rå_sti_shell("tools/selfhost_phase0_verify.no")

    la phase0 = fil_les("tools/selfhost_phase0_verify.no")
    assert(t.inneholder(phase0, "builtin.replace(sti, \"'\", \"'\\\"'\\\"'\")"))
    assert(ikkje t.inneholder(phase0, "builtin.replace(sti, \"'\", \"'\\\\''\")"))

    krev_trygg_s_shell("tools/run_single_module_bundle_probes_v6800.no")
    krev_trygg_s_shell("tools/bootstrap_refresh_bisect_v6400.no")
    krev_trygg_s_shell("tools/render-norscode-mark.no")
    krev_trygg_s_shell("tools/install-release.no")
    krev_trygg_s_shell("tools/overlay_hybrid_compiler_into_bundle_v9410.no")
    krev_trygg_s_shell("tools/build_linux_x86_64_stage0_docker_v3601.no")
    krev_trygg_s_shell("tools/install.no")
    krev_trygg_s_shell("tools/build-macos-app.no")
    krev_trygg_s_shell("tools/ai_patch_guard_v3021.no")
    krev_trygg_s_shell("tools/nc_repl.no")
    krev_trygg_s_shell("tools/install-macos-file-icons.no")
    krev_trygg_s_shell("tools/startapp.no")
    krev_trygg_s_shell("tools/startproject.no")
    krev_trygg_s_shell("tools/controlled_runtime_promotion_v3005.no")
    krev_trygg_s_shell("tools/bundle_with_hybrid_compiler_v9500.no")
    krev_trygg_s_shell("tools/verify_norscode_surface_ownership.no")
    krev_trygg_s_shell("tools/test_v731_serve_plan_v735.no")
    krev_trygg_s_shell("tools/refresh_bootstrap_compiler_v6000.no")
    krev_trygg_s_shell("tools/test_v795_runtime_gap.no")
    krev_trygg_s_shell("tools/compile_with_hybrid_bundle_v9400.no")
    krev_trygg_s_shell("tools/build_hybrid_compiler_bundle_v9400.no")
    krev_trygg_s_shell("tools/bootstrap_codegen_diff_v5800.no")
    krev_trygg_s_shell("tools/bundle_entry_diagnose_v6600.no")
    krev_trygg_s_shell("tools/build_linux_native_candidate_v3005.no")

    skriv("test_std_shell_residuals OK")
    returner 0
}

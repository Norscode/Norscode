bruk std.runtime_loader som loader
bruk std.tekst som t

funksjon manifest(id: tekst, type_namn: tekst) -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["id"] = id
    m["type"] = type_namn
    m["versjon"] = "1.0.0"
    m["entry"] = "std." + id + ".start"
    m["sha256"] = "abc123"
    m["signatur"] = "sig"
    returner m
}

funksjon start() -> heiltall {
    la l = loader.ny_loader()
    la m = manifest("mail", "modul")

    assert(loader.gyldig_manifest(m))
    assert(loader.registrer(l, m))
    assert(loader.lastet(l, "mail"))
    assert_eq(loader.status(l, "mail"), "lastet")
    assert_eq(loader.entry(l, "mail"), "std.mail.start")

    assert(loader.aktiver(l, "mail"))
    assert_eq(loader.status(l, "mail"), "aktiv")
    assert_eq(loader.samandrag(l)["active"], "1")

    assert(loader.deaktiver(l, "mail"))
    assert_eq(loader.status(l, "mail"), "lastet")
    assert_eq(loader.samandrag(l)["active"], "0")

    la usignert = manifest("plugin1", "plugin")
    usignert["sha256"] = ""
    assert(ikkje loader.registrer(l, usignert))

    la feil = manifest("x", "ukjent")
    assert(ikkje loader.gyldig_manifest(feil))

    la ps = loader.produksjonsstatus()
    assert_eq(ps["status"], "stabil")
    assert(t.inneholder(ps["dekning"], "hot-reload"))
    assert(t.inneholder(ps["dekning"], "trust store"))
    assert_eq(ps["mangler"], "ingen runtime-v1-blokkere")

    skriv("test_runtime_loader OK")
    returner 0
}

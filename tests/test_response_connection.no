funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nConnection: close\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "connection": "close", "body": "hei"})
    assert_eq(builtin.contains(resp, "Connection: close"), sann)
    returner 0
}

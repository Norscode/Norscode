bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heiltall {
    la admin = fil_les("std/admin.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(admin, "funksjon _admin_headers() -> ordbok_tekst")
    krev(admin, "\"cache-control\": \"no-store\"")
    krev(admin, "\"x-frame-options\": \"DENY\"")
    krev(admin, "\"x-content-type-options\": \"nosniff\"")
    krev(admin, "\"referrer-policy\": \"no-referrer\"")

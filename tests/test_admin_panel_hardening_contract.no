    krev(admin, "display_name_limit: \"120\"")
    krev(admin, "headers: \"no-store,nosniff,deny,no-referrer,csp,hsts,permissions,noindex\"")

    krev(manual, "`std.admin`: CRUD-admin for registrerte modellar, med trygg modellregistrering, avgrensa visningsnamn, positive og avgrensa rad-ID-ar, skjulte radhandlingar ved ugyldig ID, aria-merkte radhandlingar, ugyldig-rad merking og live statusfelt, avgrensa admin-POST-body, HTML-maksgrenser for søk/skjema, kobla admin-labels og sorteringslabels, avgrensa skjemaverdiar og formfelt, avgrensa felt-/tabellnamn, avgrensa audit-verdiar, avgrensa paginering, escaped HTML-output, path/query-escaped admin-URL-ar, trygge admin-tabellnamn og admin-feltnamn for sortering, søk, skjema og skriving, strenge no-store/CSP/HSTS/noindex admin-headers på sider og redirects, ingen inline admin-JavaScript, server-side slettebekrefting, autocomplete-off adminskjema, oversiktsstatistikk, tom-tilstand, kontrollerte statusmeldingar med presise feilkodar, avgrensa admin-søk, audit-eventar for suksess/feil/avvising/probing, maskinlesbar audit-dekning i `admin_status`, og CSRF-sikre admin-POST-hjelparar.")

    skriv("test_admin_panel_hardening_contract OK")
    returner 0
}

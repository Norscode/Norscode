bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heiltall {
    la admin = fil_les("std/admin.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(admin, "funksjon _admin_headers() -> ordbok_tekst")
    krev(admin, "\"cache-control\": \"no-store\"")
    krev(admin, "\"x-frame-options\": \"DENY\"")
    krev(admin, "\"x-content-type-options\": \"nosniff\"")
    krev(admin, "\"referrer-policy\": \"no-referrer\"")
    krev(admin, "\"strict-transport-security\": \"max-age=31536000; includeSubDomains\"")
    krev(admin, "\"content-security-policy\": \"default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; base-uri 'none'; frame-ancestors 'none'; form-action 'self'\"")
    krev(admin, "\"permissions-policy\": \"geolocation=(), microphone=(), camera=()\"")
    krev(admin, "\"x-robots-tag\": \"noindex, nofollow, noarchive\"")
    krev(admin, "script-src 'none'")
    krev(admin, "frame-ancestors 'none'")
    krev(admin, "form-action 'self'")
    assert(ikkje t.inneholder(admin, "onsubmit="))
    assert(ikkje t.inneholder(admin, "return confirm("))
    krev(admin, "autocomplete=\\\"off\\\"")
    krev(admin, "autocomplete: \"off\"")
    krev(admin, ".admin-kpis")
    krev(admin, ".empty-state")
    krev(admin, "hvis per_side > 100 { per_side = 100 }")
    krev(admin, "Ingen modellar er registrert enno.")
    krev(admin, "Ingen rader funne.")
    krev(admin, "returner web.response_builder(200, _admin_headers(), html)")
    krev(admin, "bruk std.csrf som csrf")
    krev(admin, "bruk std.audit som audit")
    krev(admin, "funksjon csrf_input(csrf_token: tekst) -> tekst")
    krev(admin, "funksjon handle_liste_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(admin, "funksjon _handle_liste_med_csrf(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(admin, "funksjon handle_ny_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(admin, "funksjon handle_rediger_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(admin, "funksjon handle_lagre_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(admin, "funksjon handle_slett_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst")
    krev(admin, "funksjon _admin_csrf_ok(ctx: ordbok_tekst, csrf_token: tekst) -> bool")
    krev(admin, "returner web.response_builder(403, _admin_headers(), html)")
    krev(admin, "funksjon _admin_not_found(melding: tekst) -> ordbok_tekst")
    krev(admin, "returner web.response_builder(404, _admin_headers(), html)")
    krev(admin, "returner _admin_not_found(\"Modell ikkje funne: \" + tabell)")
    krev(admin, "returner _admin_not_found(\"Rad ikkje funne\")")
    assert(ikkje t.inneholder(admin, "returner web.response_error(404"))
    krev(admin, "funksjon _url_query_escape(s: tekst) -> tekst")
    krev(admin, "funksjon _url_path_escape(s: tekst) -> tekst")
    krev(admin, "funksjon _admin_model_url(tabell: tekst) -> tekst")
    krev(admin, "funksjon _admin_row_url(tabell: tekst, rad_id: tekst, suffiks: tekst) -> tekst")
    krev(admin, "returner \"/admin/\" + _url_path_escape(tabell)")
    krev(admin, "returner _admin_model_url(tabell) + \"/\" + _url_path_escape(rad_id) + suffiks")
    krev(admin, "r = tekst_erstatt(r, \"/\", \"%2F\")")
    krev(admin, "r = tekst_erstatt(r, \"\\\\\", \"%5C\")")
    krev(admin, "href=\\\"\" + _admin_model_url(t) + \"\\\"")
    krev(admin, "href=\\\"\" + _admin_row_url(tabell, rad_id, \"/rediger\") + \"\\\"")
    krev(admin, "action=\\\"\" + _admin_row_url(tabell, rad_id, \"/slett\") + \"\\\"")
    krev(admin, "action=\\\"\" + _admin_model_url(tabell) + \"/lagre\\\"")
    assert(ikkje t.inneholder(admin, "\"/admin/\" + _html_escape(tabell)"))
    krev(admin, "hvis sok != \"\" { legg_til(del, \"sok=\" + _url_query_escape(sok)) }")
    krev(admin, "hvis sort != \"\" { legg_til(del, \"sort=\" + _url_query_escape(sort)) }")
    krev(admin, "hvis retning != \"\" { legg_til(del, \"dir=\" + _url_query_escape(retning)) }")
    krev(admin, "r = tekst_erstatt(r, \"&\", \"%26\")")
    krev(admin, "r = tekst_erstatt(r, \"\\\"\", \"%22\")")
    krev(admin, "r = tekst_erstatt(r, \"<\", \"%3C\")")
    assert(ikkje t.inneholder(admin, "tekst_erstatt(sok, \" \", \"%20\")"))
    krev(admin, "funksjon _admin_sorteringskontroll(tabell: tekst, felt_liste: liste<tekst>, sort: tekst, retning: tekst, sok: tekst, per_side: heiltall) -> tekst")
    krev(admin, "la sorterings_form = _admin_sorteringskontroll(tabell, felt_liste, sort, retning, sok, per_side)")
    krev(admin, "funksjon _admin_sok_skjulte_felt(sort: tekst, retning: tekst, per_side: heiltall) -> tekst")
    krev(admin, "la sok_skjulte = _admin_sok_skjulte_felt(sort, retning, per_side)")
    krev(admin, "\"<form method=\\\"GET\\\" action=\\\"\" + _admin_model_url(tabell) + \"\\\" class=\\\"felt\\\" autocomplete=\\\"off\\\">\" +")
    krev(admin, "sok_skjulte +")
    krev(admin, "name=\\\"sok\\\" value=\\\"\" + _html_escape(sok) + \"\\\"")
    krev(admin, "name=\\\"sort\\\" value=\\\"\" + _html_escape(sort) + \"\\\"")
    krev(admin, "name=\\\"dir\\\" value=\\\"\" + _html_escape(retning) + \"\\\"")
    krev(admin, "name=\\\"per_side\\\" value=\\\"\" + tekst_fra_heltall(per_side) + \"\\\"")
    krev(admin, "funksjon admin_status(register: ordbok_tekst) -> ordbok_tekst")
    krev(admin, "funksjon _admin_redirect(location: tekst) -> ordbok_tekst")
    krev(admin, "h[\"location\"] = location")
    krev(admin, "returner web.response_builder(302, h, \"\")")
    krev(admin, "returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + \"?ok=lagra\")")
    krev(admin, "returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + \"?ok=sletta\")")
    krev(admin, "csrf_input(csrf_token) +")
    krev(admin, "admin_bekreft_slett_input() +")
    krev(admin, "funksjon admin_bekreft_slett_input() -> tekst")
    krev(admin, "name=\\\"admin_bekreft_slett\\\" value=\\\"sann\\\"")
    krev(admin, "funksjon _admin_slett_bekrefta(ctx: ordbok_tekst) -> bool")
    krev(admin, "returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + \"?feil=slett\")")
    krev(admin, "delete_intent: \"admin_bekreft_slett_input,_admin_slett_bekrefta\"")
    krev(admin, "funksjon _admin_statusmelding(ctx: ordbok_tekst) -> tekst")
    krev(admin, "web.request_query_param(ctx, \"ok\")")
    krev(admin, "web.request_query_param(ctx, \"feil\")")
    krev(admin, "role=\\\"status\\\"")
    krev(admin, "role=\\\"alert\\\"")
    krev(admin, "Endringane er lagra.")
    krev(admin, "Rada er sletta.")
    krev(admin, "Kunne ikkje lagre endringane.")
    krev(admin, "Sletting vart avvist fordi bekrefting mangla.")
    krev(admin, "funksjon _admin_feilmelding(kode: tekst) -> tekst")
    krev(admin, "Ugyldig tryggleikstoken.")
    krev(admin, "Du har ikkje tilgang til admin-handlinga.")
    krev(admin, "Ukjend admin-feil.")
    krev(admin, "_admin_feilmelding(feil)")
    krev(admin, "?ok=lagra")
    krev(admin, "?ok=sletta")
    krev(admin, "?feil=slett")
    krev(admin, "funksjon admin_lagre_audit(ctx: ordbok_tekst, tabell: tekst, rad_id: tekst) -> ordbok_tekst")
    krev(admin, "funksjon admin_slett_audit(ctx: ordbok_tekst, tabell: tekst, id: heltall) -> ordbok_tekst")
    krev(admin, "funksjon admin_forbidden_audit(ctx: ordbok_tekst, grunn: tekst) -> ordbok_tekst")
    krev(admin, "la handling = \"admin_create\"")
    krev(admin, "handling = \"admin_update\"")
    krev(admin, "audit.opprett(handling, \"registrert\")")
    krev(admin, "audit.opprett(\"admin_delete\", \"registrert\")")
    krev(admin, "audit.opprett(\"admin_forbidden\", \"avvist\")")
    krev(admin, "audit.emit(admin_forbidden_audit(ctx, \"csrf:lagre\"))")
    krev(admin, "audit.emit(admin_lagre_audit(ctx, web.request_param(ctx, \"tabell\"), web.request_param(ctx, \"id\")))")
    krev(admin, "audit.emit(admin_forbidden_audit(ctx, \"csrf:slett\"))")
    krev(admin, "audit.emit(admin_slett_audit(ctx, web.request_param(ctx, \"tabell\"), web.request_param_int(ctx, \"id\")))")
    krev(admin, "audit: \"admin_lagre_audit,admin_slett_audit,admin_forbidden_audit\"")
    krev(admin, "headers: \"no-store,nosniff,deny,no-referrer,csp,hsts,permissions,noindex\"")

    krev(manual, "`std.admin`: CRUD-admin for registrerte modellar, med escaped HTML-output, path/query-escaped admin-URL-ar, strenge no-store/CSP/HSTS/noindex admin-headers på sider og redirects, ingen inline admin-JavaScript, server-side slettebekrefting, autocomplete-off adminskjema, oversiktsstatistikk, tom-tilstand, kontrollerte statusmeldingar, audit-eventar og CSRF-sikre admin-POST-hjelparar.")

    skriv("test_admin_panel_hardening_contract OK")
    returner 0
}

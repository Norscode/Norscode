    krev(admin, "funksjon _admin_audit_tekst(verdi: tekst) -> tekst")
    krev(admin, "hvis lengde(verdi) > 200")
    krev(admin, "returner builtin.slice(verdi, 0, 200)")
    krev(admin, "returner _admin_audit_tekst(user)")
    krev(admin, "audit.felt_tekst(e, \"reason\", _admin_audit_tekst(grunn))")
    krev(admin, "audit.felt_tekst(e, \"table\", _admin_audit_tekst(web.request_param(ctx, \"tabell\")))")
    krev(admin, "audit.felt_tekst(e, \"row_id\", _admin_audit_tekst(web.request_param(ctx, \"id\")))")

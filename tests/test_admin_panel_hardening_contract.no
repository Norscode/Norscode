    krev(admin, "audit.emit(admin_forbidden_audit(ctx, \"body:lagre\"))")
    krev(admin, "audit.emit(admin_forbidden_audit(ctx, \"body:slett\"))")
    krev(admin, "Admin-skjemaet er for stort")
    krev(admin, "hvis ikkje _admin_body_ok(ctx) { returner usann }")
    krev(admin, "hvis ikkje _admin_trygt_tabell_namn(tabell) { returner register }")
    krev(admin, "funksjon _admin_visningsnamn(tabell: tekst, visningsnamn: tekst) -> tekst")
    krev(admin, "la namn = builtin.trim(visningsnamn)")
    krev(admin, "hvis namn == \"\" { namn = tabell }")
    krev(admin, "hvis lengde(namn) > 120 { namn = builtin.slice(namn, 0, 120) }")
    krev(admin, "m[\"visningsnamn\"] = _admin_visningsnamn(tabell, visningsnamn)")
    krev(admin, "funksjon _admin_form_verdi(verdi: tekst) -> tekst")
    krev(admin, "hvis lengde(verdi) > 4096 { returner builtin.slice(verdi, 0, 4096) }")
    krev(admin, "utan_id[f] = _admin_form_verdi(data[f])")
    krev(admin, "funksjon _admin_form_felt_grense() -> heiltall")
    krev(admin, "returner 128")
    krev(admin, "funksjon _admin_form_verdi_grense() -> heiltall")
    krev(admin, "returner 4096")
    krev(admin, "funksjon _admin_sok_grense() -> heiltall")
    krev(admin, "returner 200")
    krev(admin, "funksjon _admin_reins_form_data(data: ordbok_tekst) -> ordbok_tekst")
    krev(admin, "hvis type_verdi == \"ordbok\" { returner _admin_reins_form_data(parsed) }")
    krev(admin, "hvis _admin_trygt_felt_namn(k) og tal < _admin_form_felt_grense()")
    krev(admin, "data[k] = _admin_form_verdi(v)")
    krev(admin, "reinsa[k] = _admin_form_verdi(data[k])")

bruk std.tekst som t

funksjon start() -> heiltall {
    la vm_src = fil_les("selfhost/vm.no")
    la vm_ncb = fil_les("bootstrap/precompiled/vm.ncb.json")

    assert(t.inneholder(vm_src, "Fil-eksistens må treffast tidleg for precompiled VM under eldre host-VM."))
    assert(t.inneholder(vm_src, "hvis namn == \"builtin.fil_finnes\" eller namn == \"fil_finnes\" eller namn == \"builtin.sti_exists\""))
    assert(t.inneholder(vm_src, "returner _rt_fil_finnes(args[0])"))
    assert(ikkje t.inneholder(vm_ncb, "[\"INDEX_SET\"],[\"POP\"]"))
    assert(ikkje t.inneholder(vm_ncb, "[\"CALL\",\"builtin.finnes_nøkkel\",2]"))
    assert(ikkje t.inneholder(vm_ncb, "[\"CALL\",\"builtin.har_nokkel\",2]"))

    skriv("test_precompiled_vm_host_compat OK")
    returner 0
}

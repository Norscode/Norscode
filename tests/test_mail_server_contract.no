bruk std.mail_server som mail

funksjon start() -> heiltall {
    la m = mail.ny("example.no", "mail.example.no")
    m["dkim_public_key"] = "PUBLICKEY"
    assert(mail.legg_postboks(m, "postmaster", "drift"))
    assert(mail.legg_alias(m, "admin@example.no", "postmaster@example.no"))
    assert(builtin.starts_with(m["mailboxes"], "["))
    assert(builtin.starts_with(m["aliases"], "["))
    assert(mail.produksjon_klar(m))

    la s = mail.smtp_ny_sesjon("203.0.113.8")
    assert_eq(mail.smtp_handter_linje(m, s, "EHLO client")["response"], "250-mail.example.no\r\n250-STARTTLS\r\n250 AUTH PLAIN LOGIN\r\n")
    assert_eq(mail.smtp_handter_linje(m, s, "MAIL FROM:<postmaster@example.no>")["response"], "250 Sender OK\r\n")
    assert_eq(mail.smtp_handter_linje(m, s, "RCPT TO:<postmaster@example.no>")["response"], "250 Recipient OK\r\n")
    assert(builtin.starts_with(s["rcpt_to"], "["))
    assert_eq(mail.smtp_handter_linje(m, s, "DATA")["response"], "354 Avslutt med punktum pa eiga linje\r\n")
    mail.smtp_handter_linje(m, s, "Subject: test")
    la queued = mail.smtp_handter_linje(m, s, ".")
    assert_eq(queued["queued"], "sann")
    la q = mail.ko_melding(m, s)
    assert_eq(mail.marker_leveringsforsok(q, usann, "temporary")["status"], "retry")
    assert_eq(mail.marker_leveringsforsok(q, sann, "")["status"], "delivered")

    la relay = mail.smtp_ny_sesjon("203.0.113.9")
    mail.smtp_handter_linje(m, relay, "EHLO relay")
    la denied = mail.smtp_handter_linje(m, relay, "RCPT TO:<external@example.com>")
    assert_eq(denied["action"], "reject")
    assert_eq(denied["response"], "550 Relay denied\r\n")

    la spam = mail.smtp_ny_sesjon("203.0.113.10")
    mail.smtp_handter_linje(m, spam, "MAIL FROM:<postmaster@example.no>")
    mail.smtp_handter_linje(m, spam, "RCPT TO:<postmaster@example.no>")
    mail.smtp_handter_linje(m, spam, "DATA")
    mail.smtp_handter_linje(m, spam, "X-Spam: yes")
    la quarantined = mail.smtp_handter_linje(m, spam, ".")
    assert_eq(quarantined["quarantined"], "sann")
    skriv("test_mail_server_contract OK\n")
    returner 0
}

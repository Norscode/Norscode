funksjon start() -> heiltall {
    la pure_vm: boolsk = usann
    prøv {
        builtin.vm_memory_status()
        pure_vm = sann
    } fang (e) {
    }
    hvis ikkje pure_vm {
        skriv("test_vm_dynamic_loader OK")
        returner 0
    }

    la first = builtin.vm_module_load("build/vm_plugin_v1.ncb.json", "demo", "")
    hvis first["generation"] != tekst_fra_heltall(1) { returner 1 }
    hvis first["entry"] != "demo.start" { returner 2 }
    hvis builtin.ncb_call_fn("demo.svar") != "v1" { returner 3 }

    la second = builtin.vm_module_reload("build/vm_plugin_v2.ncb.json", "demo", "")
    hvis second["generation"] != tekst_fra_heltall(2) { returner 4 }
    hvis builtin.ncb_call_fn("demo.svar") != "v2" { returner 5 }

    la dependency_nekt: tekst = ""
    prøv {
        builtin.vm_module_load("build/vm_plugin_v1.ncb.json", "child_early", "", "base")
        returner 7
    } fang (e) {
        dependency_nekt = e
    }
    hvis lengde(dependency_nekt) == 0 { returner 8 }
    builtin.vm_module_load("build/vm_plugin_v1.ncb.json", "base", "", "")
    builtin.vm_module_load("build/vm_plugin_v1.ncb.json", "child", "", "base")
    hvis builtin.ncb_call_fn("child.svar") != "v1" { returner 9 }

    la metrics = builtin.vm_runtime_metrics()
    hvis metrics["module_loads"] == metrics["module_reloads"] { returner 6 }

    skriv("test_vm_dynamic_loader OK")
    returner 0
}

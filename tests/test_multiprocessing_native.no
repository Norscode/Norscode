bruk std.multiprocessing som mp

funksjon start() -> heiltall {
    la p = mp.ny_native_prosess("/usr/bin/printf", ["%s", "norscode-native-mp"])
    assert_eq(p["backend"], "native-argv")
    assert(mp.start_native(p, "/tmp"))

    la i: heiltall = 0
    la status: tekst = "køyrer"
    mens i < 100 og status == "køyrer" {
        status = mp.native_status(p)
        i = i + 1
    }
    hvis status == "køyrer" { status = mp.native_wait(p, 5000) }
    la resultat = mp.native_resultat(p)
    assert_eq(resultat["status"], "ferdig")
    assert_eq(resultat["exit_code"], "0")
    assert_eq(builtin.trim(resultat["stdout"]), "norscode-native-mp")
    skriv("test_multiprocessing_native OK")
    returner 0
}

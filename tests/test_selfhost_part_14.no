    assert_eq(script_english_present_absent_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_online_offline_alias: tekst = sh.disasm_skript("let x=online;return x and not offline")
    assert_eq(script_english_online_offline_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_connected_disconnected_alias: tekst = sh.disasm_skript("let x=connected;return x and not disconnected")
    assert_eq(script_english_connected_disconnected_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_available_unavailable_alias: tekst = sh.disasm_skript("let x=available;return x and not unavailable")
    assert_eq(script_english_available_unavailable_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_reachable_unreachable_alias: tekst = sh.disasm_skript("let x=reachable;return x and not unreachable")
    assert_eq(script_english_reachable_unreachable_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_working_broken_alias: tekst = sh.disasm_skript("let x=working;return x and not broken")
    assert_eq(script_english_working_broken_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_stable_unstable_alias: tekst = sh.disasm_skript("let x=stable;return x and not unstable")
    assert_eq(script_english_stable_unstable_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_correct_incorrect_alias: tekst = sh.disasm_skript("let x=correct;return x and not incorrect")
    assert_eq(script_english_correct_incorrect_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_complete_incomplete_alias: tekst = sh.disasm_skript("let x=complete;return x and not incomplete")
    assert_eq(script_english_complete_incomplete_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_clean_dirty_alias: tekst = sh.disasm_skript("let x=clean;return x and not dirty")
    assert_eq(script_english_clean_dirty_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_up_down_alias: tekst = sh.disasm_skript("let x=up;return x and not down")
    assert_eq(script_english_up_down_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_alive_dead_alias: tekst = sh.disasm_skript("let x=alive;return x and not dead")
    assert_eq(script_english_alive_dead_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_awake_asleep_alias: tekst = sh.disasm_skript("let x=awake;return x and not asleep")
    assert_eq(script_english_awake_asleep_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_healthy_unhealthy_alias: tekst = sh.disasm_skript("let x=healthy;return x and not unhealthy")
    assert_eq(script_english_healthy_unhealthy_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_synced_unsynced_alias: tekst = sh.disasm_skript("let x=synced;return x and not unsynced")
    assert_eq(script_english_synced_unsynced_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_math_alias: tekst = sh.disasm_skript("let x=8;let y=2;return x divided_by y")
    assert_eq(script_english_math_alias, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_english_divided_by_phrase: tekst = sh.disasm_skript("let x=8;let y=2;return x divided by y")
    assert_eq(script_english_divided_by_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_english_divide_by_phrase: tekst = sh.disasm_skript("let x=8;let y=2;return x divide by y")
    assert_eq(script_english_divide_by_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_english_multiply_by_phrase: tekst = sh.disasm_skript("let x=3;let y=4;return x multiply by y")
    assert_eq(script_english_multiply_by_phrase, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_english_multiplied_by_phrase: tekst = sh.disasm_skript("let x=3;let y=4;return x multiplied by y")
    assert_eq(script_english_multiplied_by_phrase, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_english_math_short_alias: tekst = sh.disasm_skript("let x=8;let y=2;return x divide y")
    assert_eq(script_english_math_short_alias, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_english_modulo_alias: tekst = sh.disasm_skript("let x=17;let y=5;return x modulo_of y")
    assert_eq(script_english_modulo_alias, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la script_english_modulo_of_phrase: tekst = sh.disasm_skript("let x=17;let y=5;return x modulo of y")
    assert_eq(script_english_modulo_of_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la script_english_remainder_of_phrase: tekst = sh.disasm_skript("let x=17;let y=5;return x remainder of y")
    assert_eq(script_english_remainder_of_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la script_norsk_ops: tekst = sh.disasm_skript("x=sann;y=ikke usann;x og y")
    assert_eq(script_norsk_ops, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_enten: tekst = sh.disasm_skript("x=usann;y=sann;x enten y")
    assert_eq(script_norsk_ops_enten, "0: PUSH 0\n1: PUSH 1\n2: OR\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_sant: tekst = sh.disasm_skript("x=sant;y=ikke usann;x og y")
    assert_eq(script_norsk_ops_sant, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_usant: tekst = sh.disasm_skript("x=sant;y=ikke usant;x og y")
    assert_eq(script_norsk_ops_usant, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_ja_nei: tekst = sh.disasm_skript("x=ja;y=ikke nei;x og y")
    assert_eq(script_norsk_ops_ja_nei, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_true_false: tekst = sh.disasm_skript("x=true;y=ikke false;x og y")
    assert_eq(script_norsk_ops_true_false, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_ikkje: tekst = sh.disasm_skript("x=sann;y=ikkje usann;x og y")
    assert_eq(script_norsk_ops_ikkje, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_samt: tekst = sh.disasm_skript("x=sann;y=ikke usann;x samt y")
    assert_eq(script_norsk_ops_samt, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_cmp: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindre_enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindre enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase2: tekst = sh.disasm_skript("la x=3;la y=4;hvis x er ikke y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase2, "0: PUSH 3\n1: PUSH 4\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase3: tekst = sh.disasm_skript("la x=3;la y=3;hvis x er lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase3, "0: PUSH 3\n1: PUSH 3\n2: EQ\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase4: tekst = sh.disasm_skript("la x=3;la y=4;hvis x er mindre enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase4, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase4_underscore: tekst = sh.disasm_skript("la x=3;la y=4;hvis x er_mindre_enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase4_underscore, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    returner 0
}

    la script_english_ready_not_ready_alias: tekst = sh.disasm_skript("let x=ready;return x and not not_ready")
    assert_eq(script_english_ready_not_ready_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")


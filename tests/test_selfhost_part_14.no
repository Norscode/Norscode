    assert_eq(script_english_trusted_untrusted_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_open_closed_alias: tekst = sh.disasm_skript("let x=open;return x and not closed")
    assert_eq(script_english_open_closed_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")


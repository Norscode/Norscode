bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_english_yes_no_alias: tekst = sh.disasm_skript("let x=yes;return x and not no")
    assert_eq(script_english_yes_no_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_enabled_disabled_alias: tekst = sh.disasm_skript("let x=enabled;return x and not disabled")
    assert_eq(script_english_enabled_disabled_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_active_inactive_alias: tekst = sh.disasm_skript("let x=active;return x and not inactive")
    assert_eq(script_english_active_inactive_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la script_english_truthy_falsy_alias: tekst = sh.disasm_skript("let x=truthy;return x and not falsy")

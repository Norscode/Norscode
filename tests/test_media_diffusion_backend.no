bruk std.media_diffusion som diffusjon

funksjon start() -> heiltall {
    la resultat = diffusjon.bilde_med_backend(
        "nordlys over fjord", "build/test_media_diffusion_backend.ppm", 8, 8, 3, 8)
    assert_eq(resultat["ok"], "sann")
    assert(resultat["backend"] == "metal-diffusion-v1" eller resultat["backend"] == "cpu-fallback")
    prøv {
        la native_status = builtin.media_diffusion_operation({
            "abi": "norscode-media-diffusion-v1", "operation": "status"})
        hvis native_status["metal_available"] == sann {
            assert_eq(resultat["backend"], "metal-diffusion-v1")
        }
    } fang (e) { }
    assert(heltall_fra_tekst(resultat["bytes"]) > 64)
    la status = diffusjon.produksjonsstatus()
    assert(builtin.contains(status["backend"], "metal-diffusion-v1"))
    skriv("test_media_diffusion_backend OK\n")
    returner 0
}

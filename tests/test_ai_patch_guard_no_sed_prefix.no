bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/ai_patch_guard_v3021.no")
    la wrapper = fil_les("tools/ai_patch_guard_v3021.sh")

    assert(t.inneholder(src, "funksjon skriv_prefikset_fil(sti: tekst, prefiks: tekst) -> heiltall"))
    assert(t.inneholder(src, "funksjon slett_fil_trygt(sti: tekst) -> heiltall"))
    assert(t.inneholder(src, "funksjon rydd_tmp_filer(a: tekst, b: tekst, c: tekst) -> heiltall"))
    assert(t.inneholder(src, "data = builtin.fil_les(sti)"))
    assert(t.inneholder(src, "builtin.split(data, \"\\n\")"))
    assert(t.inneholder(src, "skriv(prefiks + line + \"\\n\")"))
    assert(t.inneholder(src, "skriv_prefikset_fil(tmp_deletes, \"  - \")"))
    assert(t.inneholder(src, "funksjon bygg_patch_lister(tmp_files: tekst, tmp_paths: tekst, tmp_deletes: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon legg_til_unik(liste: liste_tekst, verdi: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon felt_etter_handling(line: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon patch_mål_liner(patch_file: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "funksjon diff_git_path(line: tekst) -> tekst"))
    assert(t.inneholder(src, "funksjon tel_ikkje_tomme_linjer(sti: tekst) -> heiltall"))
    assert(t.inneholder(src, "funksjon fil_har_innhald(sti: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon les_listefil(sti: tekst) -> liste_tekst"))
    assert(t.inneholder(src, "funksjon liste_har_prefiks(sti: tekst, prefiks: tekst) -> bool"))
    assert(t.inneholder(src, "funksjon liste_har_native_binær(sti: tekst) -> bool"))
    assert(t.inneholder(src, "builtin.fil_skriv(sti, body)"))
    assert(t.inneholder(src, "hvis liste_har_prefiks(tmp_paths, \"dist/\")"))
    assert(t.inneholder(src, "hvis liste_har_prefiks(tmp_paths, \"bootstrap/stage0/\")"))
    assert(t.inneholder(src, "hvis liste_har_native_binær(tmp_paths)"))
    assert(t.inneholder(src, "hvis ikkje skriv_linjer(tmp_files, patch_mål_liner(patch_file))"))
    assert(t.inneholder(src, "la tmp_base = \"/tmp/norscode_patch_guard_v3021\""))
    assert(t.inneholder(src, "la tmp_files = tmp_base + \"_files\""))
    assert(t.inneholder(src, "rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)"))
    assert(t.inneholder(src, "hvis ikkje bygg_patch_lister(tmp_files, tmp_paths, tmp_deletes)"))
    assert(t.inneholder(src, "la file_count_num = tel_ikkje_tomme_linjer(tmp_paths)"))
    assert(t.inneholder(src, "la file_count = tekst(file_count_num)"))
    assert(t.inneholder(src, "hvis ikkje fil_har_innhald(tmp_files)"))
    assert(t.inneholder(src, "hvis fil_har_innhald(tmp_deletes)"))
    assert(t.inneholder(src, "returner miljo_hent(namn)"))
    assert(t.inneholder(src, "returner exec_prosess(cmd)"))
    assert(t.inneholder(src, "NORSCODE_PATCH_GUARD_PATCH=PATCHFILE ./bin/nc run tools/ai_patch_guard_v3021.no"))
    assert(t.inneholder(src, "NORSCODE_PATCH_GUARD_ALLOW_ARCHIVE=sann"))
    assert(t.inneholder(wrapper, "NORSCODE_PATCH_GUARD_PATCH=PATCHFILE ./bin/nc run tools/ai_patch_guard_v3021.no"))
    assert(t.inneholder(wrapper, "NORSCODE_PATCH_GUARD_ALLOW_ARCHIVE=sann"))
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(src, "tools/ai_patch_guard_v3021.sh [--allow-archive]"))
    assert(ikkje t.inneholder(wrapper, "Bruk: %s [--allow-archive] [--manifest PATH] PATCHFILE"))

    assert(ikkje t.inneholder(src, "sed 's/^/  - /'"))
    assert(ikkje t.inneholder(src, "cut -d' ' -f2-"))
    assert(ikkje t.inneholder(src, "grep '^DELETE '"))
    assert(ikkje t.inneholder(src, "wc -l < \" + shell(tmp_paths)"))
    assert(ikkje t.inneholder(src, "test -s \" + shell(tmp_files)"))
    assert(ikkje t.inneholder(src, "test -s \" + shell(tmp_deletes)"))
    assert(ikkje t.inneholder(src, "awk_script"))
    assert(ikkje t.inneholder(src, "kommando(\"awk "))
    assert(ikkje t.inneholder(src, "rg -n '^dist/'"))
    assert(ikkje t.inneholder(src, "rg -n '^bootstrap/stage0/'"))
    assert(ikkje t.inneholder(src, "rg -n '^archive/'"))
    assert(ikkje t.inneholder(src, "rg -n '(^|/)(norscode_native|norscode-[^/]+)$'"))
    assert(ikkje t.inneholder(src, "rg -n '^(docs/|tests/|tools/)'"))
    assert(ikkje t.inneholder(src, "mktemp /tmp/norscode_patch_guard_files"))
    assert(ikkje t.inneholder(src, "mktemp -d"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + shell(tmp"))

    skriv("test_ai_patch_guard_no_sed_prefix OK")
    returner 0
}

bruk std.runtime_profiler som profiler

funksjon start() -> heiltall {
    la data = profiler.snapshot()
    assert(profiler.cpu_instruksjonar(data) > 0)
    assert(profiler.veggtid_ms(data) >= 0)
    assert(profiler.gc_pause_ms(data) >= 0)
    assert(profiler.io_kall(data) >= 0)
    assert(profiler.heap_bytes(data) >= 0)
    la status = profiler.produksjonsstatus()
    assert_eq(status["status"], "stabil")
    returner 0
}

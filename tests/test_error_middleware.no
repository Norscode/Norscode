funksjon legg_til_error_trace(resp)
    resp["headers"] = {"X-Error-Mw": "ja"}
    returner resp
slutt

funksjon bygg_response(status, body)
    returner {
        "status": status,
        "body": body
    }
slutt

funksjon start() -> heiltall {
    la feil = legg_til_error_trace(bygg_response(404, "Ikkje funne"))
    assert_eq(feil["headers"]["X-Error-Mw"], "ja")

    la resp = legg_til_error_trace(bygg_response(404, "Ikkje funne"))
    assert_eq(resp["status"], 404)
    assert_eq(resp["body"], "Ikkje funne")
    assert_eq(resp["headers"]["X-Error-Mw"], "ja")

    returner 0
}

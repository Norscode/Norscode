funksjon deling() -> heiltall {
    builtin.feil("builtin-feil")
    returner 0
}

funksjon mellom() -> heiltall {
    la x = deling()
    returner x + 1
}

funksjon start() -> heiltall {
    la fanget = ""
    prøv {
        mellom()
    } fang (e) {
        fanget = e
    }
    assert(fanget != "")
    la stack = builtin.vm_call_stack_status()
    assert_eq(stack["current"], "__main__.start")
    returner 0
}

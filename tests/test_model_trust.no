bruk std.model_runtime som modell
bruk std.qmodel_binary som qmodel
bruk std.model_trust som tillit

funksjon lag_modell() {
    la m = modell.ny("trygg", 2)
    assert(modell.legg_til_lag(m, modell.dense(2, 1, [2, 3], [1], 1, "ingen")))
    returner m
}

funksjon start() -> heiltall {
    assert_eq(tillit.hash_bytes([97, 98, 99]), "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    la data = qmodel.kod(lag_modell())
    la register = tillit.ny(1)
    la hash = tillit.hash_bytes(data)
    assert(tillit.tillat(register, "demo", hash))
    assert(tillit.verifiser(register, "demo", data))
    assert_eq(tillit.dekod_verifisert(register, "demo", data, 20)["navn"], "trygg")

    la endra: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(data) {
        legg_til(endra, data[i])
        i = i + 1
    }
    endra[lengde(endra) - 1] = (endra[lengde(endra) - 1] + 1) % 256
    assert(ikkje tillit.verifiser(register, "demo", endra))
    assert(ikkje tillit.tillat(register, "anna", hash))
    assert(tillit.trekk_tilbake(register, "demo"))
    assert(ikkje tillit.verifiser(register, "demo", data))
    skriv("test_model_trust OK\n")
    returner 0
}

bruk std.httpserver_vm som http_vm
bruk std.web som web

funksjon start() -> heiltall {
    la tekstsvar = http_vm.text_response_vm("hei")
    assert_eq(http_vm.response_status_vm(tekstsvar), 200)
    assert_eq(http_vm.response_body_vm(tekstsvar), "hei")
    assert_eq(web.response_header(tekstsvar, "content-type"), "text/plain; charset=utf-8")

    la direkte = http_vm.direct_response_vm(web.response_builder(201, {"x-test": "ja"}, "ok"))
    assert_eq(http_vm.response_status_vm(direkte), 201)
    assert_eq(http_vm.response_body_vm(direkte), "ok")
    assert_eq(web.response_header(direkte, "x-test"), "ja")

    la bygd = http_vm.response_builder_vm(202, {"content-type": "application/json"}, "{\"ok\":true}")
    assert_eq(http_vm.response_status_vm(bygd), 202)
    assert_eq(http_vm.response_body_vm(bygd), "{\"ok\":true}")
    assert_eq(web.response_header(bygd, "content-type"), "application/json")

    skriv("test_httpserver_vm_response_helpers OK")
    returner 0
}

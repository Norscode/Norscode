bruk std.bytes som bytes

funksjon start() -> heiltall {
    la data = bytes.fra_liste([0, 1, 2, 127, 128, 255])
    assert_eq(type_av(data), "bytes")
    assert_eq(lengde(data), 6)
    assert_eq(data[0], 0)
    assert_eq(data[-1], 255)

    data[1] = 42
    assert_eq(data[1], 42)
    la liste = bytes.til_liste(data)
    assert_eq(lengde(liste), 6)
    assert_eq(liste[1], 42)
    assert_eq(liste[5], 255)

    la filled = bytes.ny(4, 9)
    la fill_liste = bytes.til_liste(filled)
    assert_eq(lengde(fill_liste), 4)
    assert_eq(fill_liste[0], 9)
    assert_eq(fill_liste[3], 9)
    assert(data != filled)

    la path = "build/test-native-bytes-runtime.bin"
    builtin.fil_skriv_binær(path, data)
    la loaded = builtin.fil_les_binær(path)
    assert_eq(type_av(loaded), "bytes")
    assert_eq(loaded, data)
    la loaded_liste = bytes.til_liste(loaded)
    assert_eq(loaded_liste[0], 0)
    assert_eq(loaded_liste[5], 255)

    la i: heiltall = 0
    mens i < 2000 {
        la kortliva = bytes.ny(32, i % 256)
        assert_eq(lengde(kortliva), 32)
        i = i + 1
    }
    assert_eq(data[1], 42)
    assert_eq(loaded[-1], 255)
    skriv("test_native_bytes_runtime OK")
    returner 0
}

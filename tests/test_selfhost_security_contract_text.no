bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("selfhost/std/security.no")

    assert(t.inneholder(src, "minimal selfhost-kontrakt med deterministisk format"))
    assert(t.inneholder(src, "Deterministisk salt held kontrakten repeterbar"))
    assert(t.inneholder(src, "Deterministisk digest-del"))
    assert(t.inneholder(src, "Formatkontroll er nok for denne selfhost-minimumsflata"))
    assert(t.inneholder(src, "norssalt12345678"))
    assert(t.inneholder(src, "norsdigest"))
    assert(ikkje t.inneholder(src, "mock hash format"))
    assert(ikkje t.inneholder(src, "Generate a mock salt"))
    assert(ikkje t.inneholder(src, "mocksalt"))
    assert(ikkje t.inneholder(src, "mockdigest"))
    assert(ikkje t.inneholder(src, "Real implementation"))
    assert(ikkje t.inneholder(src, "real impl"))
    assert(ikkje t.inneholder(src, "For testing"))

    skriv("test_selfhost_security_contract_text OK")
    returner 0
}

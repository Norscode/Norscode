bruk std.tekst som t

funksjon krev_fil_skriv(sti: tekst, markor: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, markor))
    assert(t.inneholder(src, "builtin.fil_skriv"))
    assert(ikkje t.inneholder(src, "printf '%s' \" + shell(body)"))
}

funksjon start() -> heiltall {
    krev_fil_skriv("tools/compiler_stage_snapshot.no", "hashes.txt")
    krev_fil_skriv("tools/compiler_snapshot_compare.no", "compiler_snapshot_compare_report.txt")
    krev_fil_skriv("tools/unified_bootstrap_verifier.no", "unified_bootstrap_verification.txt")
    krev_fil_skriv("tools/bootstrap_artifact_pipeline.no", "artifact_manifest.txt")

    la stage = fil_les("tools/compiler_stage_snapshot.no")
    assert(t.inneholder(stage, "funksjon hash_liste(root: tekst) -> tekst"))
    assert(t.inneholder(stage, "funksjon sha256_for(sti: tekst) -> tekst"))
    assert(t.inneholder(stage, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(stage, "bruk std.liste som liste"))
    assert(t.inneholder(stage, "liste.sorter_tekst(filer)"))
    assert(t.inneholder(stage, "hash_liste(snapshot_dir)"))
    assert(t.inneholder(stage, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(stage, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(stage, "while read -r FILE"))
    assert(ikkje t.inneholder(stage, "| sort"))

    la compare = fil_les("tools/compiler_snapshot_compare.no")
    assert(t.inneholder(compare, "funksjon hash_samanlikning"))
    assert(t.inneholder(compare, "funksjon relativ_sti"))
    assert(t.inneholder(compare, "funksjon første_felt"))
    assert(t.inneholder(compare, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(compare, "funksjon mappe_finst(sti: tekst) -> bool {\n    returner fil_finst(sti)\n}"))
    assert(t.inneholder(compare, "bruk std.liste som liste"))
    assert(t.inneholder(compare, "liste.sorter_tekst(filer)"))
    assert(t.inneholder(compare, "body = body + hash_samanlikning(snap_a, snap_b)"))
    assert(t.inneholder(compare, "returner miljo_hent(namn)"))
    assert(t.inneholder(compare, "returner exec_prosess(cmd)"))
    assert(t.inneholder(compare, "NORSCODE_SNAPSHOT_A=<snapshot_dir_a> NORSCODE_SNAPSHOT_B=<snapshot_dir_b> ./bin/nc run tools/compiler_snapshot_compare.no"))
    assert(ikkje t.inneholder(compare, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(compare, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(compare, "compiler_snapshot_compare.sh <"))
    assert(ikkje t.inneholder(compare, "while read -r FILE_A"))
    assert(ikkje t.inneholder(compare, "awk '{print $1}'"))
    assert(ikkje t.inneholder(compare, "test -d "))
    assert(ikkje t.inneholder(compare, "| sort"))
    la compare_wrapper = fil_les("tools/compiler_snapshot_compare.sh")
    assert(t.inneholder(compare_wrapper, "NORSCODE_SNAPSHOT_A=<snapshot_dir_a> NORSCODE_SNAPSHOT_B=<snapshot_dir_b> ./bin/nc run tools/compiler_snapshot_compare.no"))
    assert(ikkje t.inneholder(compare_wrapper, "Usage: compiler_snapshot_compare.sh"))
    assert(ikkje t.inneholder(compare_wrapper, "compiler_snapshot_compare.sh <"))

    la artifact = fil_les("tools/bootstrap_artifact_pipeline.no")
    assert(t.inneholder(artifact, "funksjon hash_liste(filer: liste_tekst) -> tekst"))
    assert(t.inneholder(artifact, "funksjon sha256_for(sti: tekst) -> tekst"))
    assert(t.inneholder(artifact, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(artifact, "bruk std.liste som liste"))
    assert(t.inneholder(artifact, "liste.sorter_tekst(filer)"))
    assert(t.inneholder(artifact, "la inventar = builtin.join(filer, \"\\n\")"))
    assert(t.inneholder(artifact, "hash_liste(filer)"))
    assert(t.inneholder(artifact, "returner exec_prosess(cmd)"))
    assert(ikkje t.inneholder(artifact, "builtin.exec_prosess"))
    assert(ikkje t.inneholder(artifact, "while read -r FILE"))
    assert(ikkje t.inneholder(artifact, "| sort"))

    la unified = fil_les("tools/unified_bootstrap_verifier.no")
    assert(t.inneholder(unified, "returner exec_prosess(cmd)"))
    assert(t.inneholder(unified, "funksjon nc_run(root: tekst, fil: tekst) -> tekst"))
    assert(t.inneholder(unified, "tools/python_dependency_audit.no"))
    assert(t.inneholder(unified, "tools/bootstrap_artifact_pipeline.no"))
    assert(ikkje t.inneholder(unified, "bash tools/python_dependency_audit.sh"))
    assert(ikkje t.inneholder(unified, "bash tools/compare_compilers.sh"))
    assert(ikkje t.inneholder(unified, "bash tools/bootstrap_diff_analyzer.sh"))
    assert(ikkje t.inneholder(unified, "bash tools/backend_ordering_validator.sh"))
    assert(ikkje t.inneholder(unified, "bash tools/semantic_diff_analyzer.sh"))
    assert(ikkje t.inneholder(unified, "bash tools/bootstrap_artifact_pipeline.sh"))
    assert(ikkje t.inneholder(unified, "builtin.exec_prosess"))

    skriv("test_report_writers_no_printf OK")
    returner 0
}

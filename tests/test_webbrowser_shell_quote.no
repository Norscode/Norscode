bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/webbrowser.no")
    assert(t.inneholder(src, "Vel standard nettlesar i Norscode"))
    assert(t.inneholder(src, "trygt quota"))
    assert(ikkje t.inneholder(src, "Opnar URLar i standard nettlesar via exec_prosess."))
    assert(t.inneholder(src, "funksjon _shell(verdi: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(verdi, \"'\""))
    assert(t.inneholder(src, "kommando + \" \" + _shell(url)"))
    assert(t.inneholder(src, "sh -c \" + _shell(cmd)"))
    assert(t.inneholder(src, "which \" + _shell(namn)"))
    assert(t.inneholder(src, "which \" + _shell(nb)"))
    assert(t.inneholder(src, "funksjon _trygg_url(url: tekst) -> bool"))
    assert(t.inneholder(src, "hvis ikkje _trygg_url(url) { returner usann }"))
    assert(t.inneholder(src, "funksjon _trygg_nettlesar_kommando(kommando: tekst) -> bool"))
    assert(t.inneholder(src, "_inneheld(kommando, \";\")"))
    assert(t.inneholder(src, "_inneheld(kommando, \"|\")"))
    assert(t.inneholder(src, "_inneheld(url, \"\\n\")"))
    assert(t.inneholder(src, "hvis ikkje _trygg_nettlesar_kommando(kommando) { returner }"))
    assert(ikkje t.inneholder(src, "kommando + \" \\\"\" + url"))
    assert(ikkje t.inneholder(src, "sh -c '\" + cmd"))
    assert(ikkje t.inneholder(src, "which \" + namn"))
    assert(ikkje t.inneholder(src, "which \" + nb"))

    skriv("test_webbrowser_shell_quote OK")
    returner 0
}

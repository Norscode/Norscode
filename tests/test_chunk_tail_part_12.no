bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_english_greater_than_phrase: tekst = sh.disasm_skript("let x=4;let y=3;return x greater than y")
    assert_eq(script_english_greater_than_phrase, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la script_english_is_less_than_phrase: tekst = sh.disasm_skript("let x=3;let y=4;return x is less than y")
    assert_eq(script_english_is_less_than_phrase, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la script_english_is_greater_than_phrase: tekst = sh.disasm_skript("let x=4;let y=3;return x is greater than y")
    assert_eq(script_english_is_greater_than_phrase, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la script_english_less_than_or_equal_phrase: tekst = sh.disasm_skript("let x=3;let y=3;return x less than or equal y")
    assert_eq(script_english_less_than_or_equal_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_less_than_or_equal_to_phrase: tekst = sh.disasm_skript("let x=3;let y=3;return x less than or equal to y")
    assert_eq(script_english_less_than_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_greater_than_or_equal_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x greater than or equal y")
    assert_eq(script_english_greater_than_or_equal_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_greater_than_or_equal_to_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x greater than or equal to y")
    assert_eq(script_english_greater_than_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_less_than_or_equal_to_phrase: tekst = sh.disasm_skript("let x=3;let y=3;return x is less than or equal to y")
    assert_eq(script_english_is_less_than_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_greater_than_or_equal_to_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x is greater than or equal to y")
    assert_eq(script_english_is_greater_than_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_less_or_equal_phrase: tekst = sh.disasm_skript("let x=3;let y=3;return x is less or equal y")
    assert_eq(script_english_is_less_or_equal_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_less_or_equal_to_phrase: tekst = sh.disasm_skript("let x=3;let y=3;return x is less or equal to y")
    assert_eq(script_english_is_less_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_greater_or_equal_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x is greater or equal y")
    assert_eq(script_english_is_greater_or_equal_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_greater_or_equal_to_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x is greater or equal to y")
    assert_eq(script_english_is_greater_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_less_than_compact_alias: tekst = sh.disasm_skript("let x=3;let y=4;return x is_less_than y")
    assert_eq(script_english_is_less_than_compact_alias, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la script_english_is_greater_or_equal_compact_alias: tekst = sh.disasm_skript("let x=4;let y=4;return x is_greater_or_equal y")
    assert_eq(script_english_is_greater_or_equal_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_less_than_or_equal_to_compact_alias: tekst = sh.disasm_skript("let x=3;let y=3;return x is_less_than_or_equal_to y")
    assert_eq(script_english_is_less_than_or_equal_to_compact_alias, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_greater_than_or_equal_to_compact_alias: tekst = sh.disasm_skript("let x=4;let y=4;return x is_greater_than_or_equal_to y")
    assert_eq(script_english_is_greater_than_or_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_less_or_equal_to_compact_alias: tekst = sh.disasm_skript("let x=3;let y=3;return x is_less_or_equal_to y")
    assert_eq(script_english_is_less_or_equal_to_compact_alias, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_is_greater_or_equal_to_compact_alias: tekst = sh.disasm_skript("let x=4;let y=4;return x is_greater_or_equal_to y")
    assert_eq(script_english_is_greater_or_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_english_cmp_equal_to_alias: tekst = sh.disasm_skript("let x=4;let y=4;return x equal_to y")
    assert_eq(script_english_cmp_equal_to_alias, "0: PUSH 4\n1: PUSH 4\n2: EQ\n3: PRINT\n4: HALT\n")

    la script_english_cmp_equal_to_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x equal to y")
    assert_eq(script_english_cmp_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: EQ\n3: PRINT\n4: HALT\n")

    la script_english_cmp_is_equal_to_phrase: tekst = sh.disasm_skript("let x=4;let y=4;return x is equal to y")
    assert_eq(script_english_cmp_is_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: EQ\n3: PRINT\n4: HALT\n")

    la script_english_cmp_is_equal_to_compact_alias: tekst = sh.disasm_skript("let x=4;let y=4;return x is_equal_to y")
    assert_eq(script_english_cmp_is_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: EQ\n3: PRINT\n4: HALT\n")

    la script_english_cmp_is_not_equal_to_phrase: tekst = sh.disasm_skript("let x=4;let y=5;return x is not equal to y")
    assert_eq(script_english_cmp_is_not_equal_to_phrase, "0: PUSH 4\n1: PUSH 5\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_not_equal_angle_alias: tekst = sh.disasm_skript("returner 7<>8")
    assert_eq(script_not_equal_angle_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_xor_alias: tekst = sh.disasm_skript("returner 1 xor 0")
    assert_eq(script_xor_alias, "0: PUSH 1\n1: PUSH 0\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_xnor_alias: tekst = sh.disasm_skript("returner 1 xnor 1")
    assert_eq(script_xnor_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la script_nand_operator: tekst = sh.disasm_skript("returner 1 nand 1")
    assert_eq(script_nand_operator, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_nand_alias_and_not: tekst = sh.disasm_skript("returner 1 and_not 1")
    assert_eq(script_nand_alias_and_not, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_nor_operator: tekst = sh.disasm_skript("returner 0 nor 0")
    assert_eq(script_nor_operator, "0: PUSH 0\n1: PUSH 0\n2: OR\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_nor_alias_or_not: tekst = sh.disasm_skript("returner 0 or_not 0")
    assert_eq(script_nor_alias_or_not, "0: PUSH 0\n1: PUSH 0\n2: OR\n3: NOT\n4: PRINT\n5: HALT\n")

    la script_implies_operator: tekst = sh.disasm_skript("returner 1 implies 0")
    assert_eq(script_implies_operator, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_implies_that_alias: tekst = sh.disasm_skript("returner 1 implies_that 0")
    assert_eq(script_implies_that_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_this_implies_alias: tekst = sh.disasm_skript("returner 1 this_implies 0")
    assert_eq(script_this_implies_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_dette_impliserer_alias: tekst = sh.disasm_skript("returner 1 dette_impliserer 0")
    assert_eq(script_dette_impliserer_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_impliserer_at_alias: tekst = sh.disasm_skript("returner 1 impliserer_at 0")
    assert_eq(script_impliserer_at_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_norsk_medforer_alias: tekst = sh.disasm_skript("returner 1 medforer 0")
    assert_eq(script_norsk_medforer_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_impl_alias: tekst = sh.disasm_skript("returner 1 impl 0")
    assert_eq(script_impl_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_follows_alias: tekst = sh.disasm_skript("returner 1 follows 0")
    assert_eq(script_follows_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_it_follows_that_alias: tekst = sh.disasm_skript("returner 1 it_follows_that 0")
    assert_eq(script_it_follows_that_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_det_folger_at_alias: tekst = sh.disasm_skript("returner 1 det_folger_at 0")
    assert_eq(script_det_folger_at_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_therefore_alias: tekst = sh.disasm_skript("returner 1 therefore 0")
    assert_eq(script_therefore_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_hence_alias: tekst = sh.disasm_skript("returner 1 hence 0")
    assert_eq(script_hence_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_altsa_alias: tekst = sh.disasm_skript("returner 1 altsa 0")
    assert_eq(script_altsa_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_thus_alias: tekst = sh.disasm_skript("returner 1 thus 0")
    assert_eq(script_thus_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_dermed_alias: tekst = sh.disasm_skript("returner 1 dermed 0")
    assert_eq(script_dermed_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_consequently_alias: tekst = sh.disasm_skript("returner 1 consequently 0")
    assert_eq(script_consequently_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_folgelig_alias: tekst = sh.disasm_skript("returner 1 folgelig 0")
    assert_eq(script_folgelig_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_thereby_alias: tekst = sh.disasm_skript("returner 1 thereby 0")
    assert_eq(script_thereby_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_derved_alias: tekst = sh.disasm_skript("returner 1 derved 0")
    assert_eq(script_derved_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_thereupon_alias: tekst = sh.disasm_skript("returner 1 thereupon 0")
    assert_eq(script_thereupon_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_derpa_alias: tekst = sh.disasm_skript("returner 1 derpa 0")
    assert_eq(script_derpa_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_ergo_alias: tekst = sh.disasm_skript("returner 1 ergo 0")
    assert_eq(script_ergo_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_saledes_alias: tekst = sh.disasm_skript("returner 1 saledes 0")
    assert_eq(script_saledes_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_infer_alias: tekst = sh.disasm_skript("returner 1 infer 0")
    assert_eq(script_infer_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_derav_alias: tekst = sh.disasm_skript("returner 1 derav 0")
    assert_eq(script_derav_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_as_consequence_alias: tekst = sh.disasm_skript("returner 1 as_consequence 0")
    assert_eq(script_as_consequence_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_som_konsekvens_alias: tekst = sh.disasm_skript("returner 1 som_konsekvens 0")
    assert_eq(script_som_konsekvens_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_as_a_result_alias: tekst = sh.disasm_skript("returner 1 as_a_result 0")
    assert_eq(script_as_a_result_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la script_som_resultat_alias: tekst = sh.disasm_skript("returner 1 som_resultat 0")
    assert_eq(script_som_resultat_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    returner 0
}

bruk selfhost.common som sh

funksjon start() -> heiltall {
    la script_norsk_ganget: tekst = sh.disasm_skript("la x=3;la y=4;returner x ganget y")
    assert_eq(script_norsk_ganget, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_ganger: tekst = sh.disasm_skript("la x=3;la y=4;returner x ganger y")
    assert_eq(script_norsk_ganger, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_ganges: tekst = sh.disasm_skript("la x=3;la y=4;returner x ganges y")

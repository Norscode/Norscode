bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la deploy = fil_les("std/deploy.no")
    la manual = fil_les("docs/USER_MANUAL.md")

    krev(deploy, "la helse_sti: tekst = tekst(c[\"helse_sti\"])")
    krev(deploy, "\"    location \" + helse_sti + \" {\\n\"")
    krev(deploy, "funksjon sett_helse_sti(c: ordbok_tekst, sti: tekst) -> heltall")
    krev(manual, "`std.deploy`: produksjonsoppsett for systemd, supervisor, nginx, helsesjekk og rollback.")
    krev(manual, "`std.deploy.produksjonsmønster(cfg)` samlar workers, helse, statics, env-fil, rollback og graceful shutdown.")

    skriv("test_deploy_nginx_health_contract OK")
    returner 0
}

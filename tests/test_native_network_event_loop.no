bruk std.socket som socket
bruk std.sched som sched

funksjon start() -> heiltall {
    la listener = socket.native_lytt("127.0.0.1", 0, 16)
    hvis listener["status"] != "listening" {
        skriv("network listen error: " + listener["error"] + "\n")
    }
    assert_eq(listener["status"], "listening")
    assert(listener["event_backend"] == "kqueue" eller listener["event_backend"] == "epoll" eller listener["event_backend"] == "poll")
    la expected_backend = builtin.miljo_hent("NORSCODE_EXPECT_EVENT_BACKEND")
    hvis expected_backend != "" { assert_eq(listener["event_backend"], expected_backend) }
    la port = heltall_fra_tekst(listener["port"])
    assert(port > 0)

    la loop = sched.ny()
    la connect_future = socket.native_connect_async(loop, "127.0.0.1", port, 5000)
    la accept_future = socket.native_accept_async(loop, listener, 5000)
    assert(connect_future != "")
    assert_eq(sched.future_status(loop, connect_future), "ventende")
    assert(sched.run(loop, 5000) >= 2)
    assert_eq(sched.future_status(loop, connect_future), "ferdig")
    assert_eq(sched.future_status(loop, accept_future), "ferdig")
    la client = sched.future_resultat(loop, connect_future)
    la server = sched.future_resultat(loop, accept_future)

    la write_loop = sched.ny()
    la write_future = socket.native_skriv_async(write_loop, client, "ping", 5000)
    la read_future = socket.native_les_async(write_loop, server, 16, 5000)
    assert(sched.run(write_loop, 5000) >= 2)
    la batch_status = sched.status(write_loop)
    assert_eq(batch_status["max_io_batch_count"], "2")
    assert(batch_status["last_io_batch_backend"] == "poll" eller batch_status["last_io_batch_backend"] == "none")
    assert_eq(heltall_fra_tekst(sched.future_resultat(write_loop, write_future)), 4)
    assert_eq(sched.future_resultat(write_loop, read_future), "ping")

    la reply_loop = sched.ny()
    la reply_write = socket.native_skriv_async(reply_loop, server, "pong", 5000)
    la reply_read = socket.native_les_async(reply_loop, client, 16, 5000)
    assert(sched.run(reply_loop, 5000) >= 2)
    assert_eq(sched.future_resultat(reply_loop, reply_read), "pong")
    assert_eq(heltall_fra_tekst(sched.future_resultat(reply_loop, reply_write)), 4)

    la timeout_loop = sched.ny()
    la timeout_future = socket.native_les_async(timeout_loop, client, 8, 0)
    assert_eq(sched.io_poll(timeout_loop), 1)
    assert_eq(sched.future_status(timeout_loop, timeout_future), "feil")
    assert_inneholder(sched.future_feil(timeout_loop, timeout_future), "TimeoutFeil")

    assert_eq(socket.native_lukk(client)["status"], "closed")
    assert_eq(socket.native_lukk(server)["status"], "closed")

    la reuse_loop = sched.ny()
    la reuse_connect = socket.native_connect_async(reuse_loop, "127.0.0.1", port, 5000)
    la reuse_accept = socket.native_accept_async(reuse_loop, listener, 5000)
    assert(sched.run(reuse_loop, 5000) >= 2)
    la new_client = sched.future_resultat(reuse_loop, reuse_connect)
    la new_server = sched.future_resultat(reuse_loop, reuse_accept)
    assert(new_client["handle"] != client["handle"])
    assert(new_server["handle"] != server["handle"])
    assert_eq(socket.native_lukk(client)["status"], "feil")
    assert_eq(socket.native_lukk(server)["status"], "feil")
    assert_eq(socket.native_lukk(new_client)["status"], "closed")
    assert_eq(socket.native_lukk(new_server)["status"], "closed")
    assert_eq(socket.native_lukk(listener)["status"], "closed")
    skriv("test_native_network_event_loop OK")
    returner 0
}

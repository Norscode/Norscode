bruk std.tekst som t

funksjon sjekk(sti: tekst) {
    la src = fil_les(sti)
    assert(ikkje t.inneholder(src, "builtin.miljo_hent"))
    assert(ikkje t.inneholder(src, "builtin.exec_prosess"))
}

funksjon krev_trygg_sti_shell(sti: tekst) {
    la src = fil_les(sti)
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
}

funksjon start() -> heiltall {
    sjekk("tools/rollback_serve_runner_cookie_fix_v682.no")

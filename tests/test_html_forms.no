bruk std.tekst som t

funksjon krev(kilde: tekst, verdi: tekst) {
    assert(t.inneholder(kilde, verdi))
}

funksjon start() -> heltall {
    la forms = fil_les("std/html_forms.no")
    la docs = fil_les("docs/frontend/FRONTEND_FORMS.md")
    la model = fil_les("docs/frontend/FRONTEND_MODEL.md")

    krev(forms, "funksjon beskrivelse_ider(")
    krev(forms, "ider = ider + feiltekst_id(navn)")
    krev(forms, "funksjon feil_attrs(")
    krev(forms, "html.aria_attr(\"invalid\", \"true\")")
    krev(forms, "funksjon påkrevd_attrs()")
    krev(forms, "required\", \"required")
    krev(forms, "aria_attr(\"required\", \"true\")")
    krev(forms, "funksjon deaktivert_attrs()")
    krev(forms, "disabled\", \"disabled")
    krev(forms, "aria_attr(\"disabled\", \"true\")")
    krev(forms, "funksjon skrivebeskyttet_attrs()")
    krev(forms, "readonly\", \"readonly")
    krev(forms, "funksjon autocomplete_attr(")
    krev(forms, "funksjon submit_busy_attrs(")
    krev(forms, "html.disable_submit_attrs")
    krev(forms, "funksjon feilsammendrag_rad(")
    krev(forms, "funksjon feilsammendrag(")
    krev(forms, "class_attr(\"error-summary\")")
    krev(forms, "aria_attr(\"live\", \"assertive\")")
    krev(forms, "funksjon feltgruppe(")
    krev(forms, "class_attr(\"field-group\")")
    krev(forms, "funksjon submit_knapp(")
    krev(forms, "funksjon submit_knapp_busy(")
    krev(forms, "funksjon avbryt_lenke(")
    krev(forms, "funksjon handlinger_standard(")

    krev(forms, "funksjon tekstfelt_med_attrs(")
    krev(forms, "funksjon epostfelt_med_attrs(")
    krev(forms, "funksjon passordfelt_med_attrs(")
    krev(forms, "funksjon tekstområde_med_attrs(")
    krev(forms, "funksjon velg_med_attrs(")
    krev(forms, "beskrivelse_attrs(navn, hjelptekst, feiltekst) + feil_attrs(feiltekst) + ekstra")

    krev(docs, "# Frontend Forms")
    krev(docs, "`std.html_forms`")
    krev(docs, "`påkrevd_attrs()`")
    krev(docs, "`deaktivert_attrs()`")
    krev(docs, "`skrivebeskyttet_attrs()`")
    krev(docs, "`autocomplete_attr(...)`")
    krev(docs, "`submit_busy_attrs(...)`")
    krev(docs, "`feilsammendrag(...)`")
    krev(docs, "`feltgruppe(...)`")
    krev(docs, "`handlinger_standard(...)`")

    krev(model, "skjemafelt med required, disabled, readonly, autocomplete")
    krev(model, "feilsammendrag, feltgrupper og standard skjemahandlinger")
    krev(model, "std.html_forms")

    returner 0
}

bruk std.runtime_jit som jit

funksjon skaler(a: desimaltall, b: desimaltall) -> desimaltall {
    returner (a + 1.5) * b / 2.0
}

funksjon absolutt_desimal(n: desimaltall) -> desimaltall {
    hvis n < 0.0 { returner -n }
    returner n
}

funksjon større(a: desimaltall, b: desimaltall) -> boolsk {
    returner a > b
}

funksjon start() -> heiltall {
    assert_eq(skaler(2.5, 4.0), 8.0)
    assert_eq(skaler(3.5, 2.0), 5.0)
    assert_eq(skaler(4.5, 4.0), 12.0)

    assert_eq(absolutt_desimal(-3.25), 3.25)
    assert_eq(absolutt_desimal(2.5), 2.5)
    assert_eq(absolutt_desimal(-7.75), 7.75)

    assert_eq(større(4.0, 3.0), sann)
    assert_eq(større(2.0, 3.0), usann)
    assert_eq(større(5.5, 5.0), sann)

    la metrics = builtin.vm_runtime_metrics()
    assert(heltall_fra_tekst(metrics["jit_compiles"]) >= 3)
    assert(heltall_fra_tekst(metrics["jit_calls"]) >= 5)
    assert(builtin.vm_jit_cleanup() >= 3)
    assert_eq(heltall_fra_tekst(jit.status()["active"]), 0)
    skriv("test_vm_jit_float_integration OK")
    returner 0
}

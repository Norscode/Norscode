# Fase 10: Ende-til-ende testar for norspkg-systemet
# Dekker: manifest, resolver, lockfile, registry, cache, publish, auth.

import toolchain.norspkg.manifest_parser
import toolchain.norspkg.resolver
import toolchain.norspkg.lockfile_flow
import toolchain.norspkg.registry_protocol
import toolchain.norspkg.cache
import toolchain.norspkg.publisher
import toolchain.norspkg.auth

# =========================
# Testrammeverk (minimalt)
# =========================

funksjon test_ok(namn)
    skriv("  PASS: " + namn)
slutt

funksjon test_feil(namn, melding)
    skriv("  FAIL: " + namn + " – " + melding)
slutt

funksjon sjekk(namn, uttrykk)
    viss uttrykk
        test_ok(namn)
        returner sann
    slutt
    test_feil(namn, "Uttrykk er usann")
    returner usann
slutt

funksjon sjekk_lik(namn, a, b)
    viss a == b
        test_ok(namn)
        returner sann
    slutt
    test_feil(namn, "Forventa '" + til_tekst(b) + "' men fekk '" + til_tekst(a) + "'")
    returner usann
slutt

# =========================
# T1: Manifest-parsing og validering
# =========================

funksjon test_manifest()
    skriv("T1: Manifest-parsing")
    bestått = 0
    totalt = 0

    # Gyldig manifest
    m = manifest_lag("std_math", "1.0.0", "math.no")
    manifest_legg_avhengigheit(m, "core", "^1.0.0")
    manifest_legg_avhengigheit(m, "io", ">=1.2.0")
    ok = valider_manifest(m)
    totalt = totalt + 1
    viss sjekk("Gyldig manifest", ok)
        bestått = bestått + 1
    slutt

    # Tomt namn
    m2 = manifest_lag("", "1.0.0", "main.no")
    ok2 = valider_manifest(m2)
    totalt = totalt + 1
    viss sjekk("Tomt namn avvist", ikkje ok2)
        bestått = bestått + 1
    slutt

    # Feil versjon
    m3 = manifest_lag("min_app", "1.0", "main.no")
    ok3 = valider_manifest(m3)
    totalt = totalt + 1
    viss sjekk("Feil versjon avvist", ikkje ok3)
        bestått = bestått + 1
    slutt

    # Ugyldig spesifikator
    m4 = manifest_lag("app", "1.0.0", "main.no")
    manifest_legg_avhengigheit(m4, "dep", "!!ugyldig")
    ok4 = valider_manifest(m4)
    totalt = totalt + 1
    viss sjekk("Ugyldig spesifikator avvist", ikkje ok4)
        bestått = bestått + 1
    slutt

    # Ugyldig teikn i namn
    m5 = manifest_lag("my app!", "1.0.0", "main.no")
    ok5 = valider_manifest(m5)
    totalt = totalt + 1
    viss sjekk("Ugyldig teikn i namn avvist", ikkje ok5)
        bestått = bestått + 1
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# T2: Versjonsmatch (semver)
# =========================

funksjon test_versjonsmatch()
    skriv("T2: Versjonsmatch (semver)")
    bestått = 0
    totalt = 0

    totalt = totalt + 1
    viss sjekk("Wildcard match 1.2.3", samsvarar_versjon("1.2.3", "*"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("Eksakt match", samsvarar_versjon("1.0.0", "1.0.0"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("Eksakt mismatch", ikkje samsvarar_versjon("1.0.1", "1.0.0"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("Caret same major", samsvarar_versjon("1.3.0", "^1.0.0"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("Caret anna major", ikkje samsvarar_versjon("2.0.0", "^1.0.0"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("GTE match", samsvarar_versjon("1.5.0", ">=1.2.0"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("GTE under grensa", ikkje samsvarar_versjon("1.1.0", ">=1.2.0"))
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("LTE match", samsvarar_versjon("1.0.0", "<=2.0.0"))
        bestått = bestått + 1
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# T3: Resolver – enkle og transitive deps
# =========================

funksjon test_resolver()
    skriv("T3: Resolver")
    bestått = 0
    totalt = 0

    registry = norspkg_registry()

    io_pkg = norspkg_package("io", "1.2.0")
    io_pkg.checksum = "sha256:io_checksum"
    io_pkg.avhengigheiter = {}
    norspkg_publish(registry, io_pkg)

    http_pkg = norspkg_package("http", "2.0.0")
    http_pkg.checksum = "sha256:http_checksum"
    http_pkg.avhengigheiter = { io: "^1.0.0" }
    norspkg_publish(registry, http_pkg)

    manifest = manifest_lag("min_app", "0.1.0", "main.no")
    manifest_legg_avhengigheit(manifest, "http", "^2.0.0")

    res = resolver_kjoyr(registry, manifest)

    totalt = totalt + 1
    viss sjekk("Resolver OK", res.ok)
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("http losa", res.losa["http"] != null)
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("io transitiv losa", res.losa["io"] != null)
        bestått = bestått + 1
    slutt

    # Test sirkulær
    a = norspkg_package("a", "1.0.0")
    a.avhengigheiter = { b: "1.0.0" }
    norspkg_publish(registry, a)

    b = norspkg_package("b", "1.0.0")
    b.avhengigheiter = { a: "1.0.0" }
    norspkg_publish(registry, b)

    manifest2 = manifest_lag("sirkel_app", "0.1.0", "main.no")
    manifest_legg_avhengigheit(manifest2, "a", "1.0.0")

    res2 = resolver_kjoyr(registry, manifest2)

    totalt = totalt + 1
    viss sjekk("Sirkulær avhengigheit oppdaga", ikkje res2.ok)
        bestått = bestått + 1
    slutt

    totalt = totalt + 1
    viss sjekk("Sirkelmelding generert", lengde(res2.sirklar) > 0)
        bestått = bestått + 1
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# T4: Lockfile-generering og verifisering
# =========================

funksjon test_lockfile()
    skriv("T4: Lockfile")
    bestått = 0
    totalt = 0

    registry = norspkg_registry()
    core_pkg = norspkg_package("core", "1.0.0")
    core_pkg.checksum = "sha256:core_abc"
    core_pkg.avhengigheiter = {}
    norspkg_publish(registry, core_pkg)

    manifest = manifest_lag("locktest_app", "0.1.0", "main.no")
    manifest_legg_avhengigheit(manifest, "core", "1.0.0")

    res = resolver_kjoyr(registry, manifest)
    lock_res = generer_lockfile(manifest, res)

    totalt = totalt + 1
    viss sjekk("Lockfile generert", lock_res.ok)
        bestått = bestått + 1
    slutt

    viss lock_res.ok
        lock = lock_res.lock

        totalt = totalt + 1
        viss sjekk("Lock-versjon er 2", lock.lock_version == 2)
            bestått = bestått + 1
        slutt

        totalt = totalt + 1
        viss sjekk("core i lock", lengde(lock.pakkar) >= 1)
            bestått = bestått + 1
        slutt

        # Verifisering – rett checksum
        ver1 = verifiser_lockfile(lock, funksjon(n, v)
            returner "sha256:core_abc"
        slutt)
        totalt = totalt + 1
        viss sjekk("Verifisering OK", ver1.ok)
            bestått = bestått + 1
        slutt

        # Verifisering – feil checksum
        ver2 = verifiser_lockfile(lock, funksjon(n, v)
            returner "sha256:feil"
        slutt)
        totalt = totalt + 1
        viss sjekk("Feil checksum avvist", ikkje ver2.ok)
            bestått = bestått + 1
        slutt

        # Fersk-sjekk
        totalt = totalt + 1
        viss sjekk("Lock er fersk", lock_er_fersk(manifest, lock))
            bestått = bestått + 1
        slutt
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# T5: Registry-protokoll (publish, list, fetch, yank)
# =========================

funksjon test_registry()
    skriv("T5: Registry-protokoll")
    bestått = 0
    totalt = 0

    tilstand = registry_tilstand_lag()
    auth_registrer(tilstand, "jan", "tok_jan")

    # Publish
    pkg = {
        namn: "mylib",
        versjon: "1.0.0",
        checksum: "sha256:mylib_check",
        kjelde_url: "https://registry.norscode.dev/mylib/1.0.0.tar.gz",
        avhengigheiter: {}
    }
    svar1 = endpoint_publish(tilstand, "tok_jan", pkg)
    totalt = totalt + 1
    viss sjekk("Publish OK", svar1.ok)
        bestått = bestått + 1
    slutt

    # Duplikat avvist
    svar2 = endpoint_publish(tilstand, "tok_jan", pkg)
    totalt = totalt + 1
    viss sjekk("Duplikat avvist", ikkje svar2.ok)
        bestått = bestått + 1
    slutt
    totalt = totalt + 1
    viss sjekk("Duplikat status 409", svar2.status == REGISTRY_CONFLICT)
        bestått = bestått + 1
    slutt

    # Ugyldig token
    svar3 = endpoint_publish(tilstand, "feil_token", pkg)
    totalt = totalt + 1
    viss sjekk("Ugyldig token avvist", ikkje svar3.ok)
        bestått = bestått + 1
    slutt

    # List
    svar4 = endpoint_list_packages(tilstand, null)
    totalt = totalt + 1
    viss sjekk("List returnerer pakkar", lengde(svar4.data.pakkar) == 1)
        bestått = bestått + 1
    slutt

    # Metadata
    svar5 = endpoint_get_metadata(tilstand, "mylib")
    totalt = totalt + 1
    viss sjekk("Metadata OK", svar5.ok)
        bestått = bestått + 1
    slutt

    # Artifact
    svar6 = endpoint_get_artifact(tilstand, "mylib", "1.0.0")
    totalt = totalt + 1
    viss sjekk("Artifact OK", svar6.ok)
        bestått = bestått + 1
    slutt

    # Yank
    svar7 = endpoint_yank(tilstand, "tok_jan", "mylib", "1.0.0")
    totalt = totalt + 1
    viss sjekk("Yank OK", svar7.ok)
        bestått = bestått + 1
    slutt

    # Etter yank
    svar8 = endpoint_get_artifact(tilstand, "mylib", "1.0.0")
    totalt = totalt + 1
    viss sjekk("Yanket versjon returnerer 410", svar8.status == REGISTRY_GONE)
        bestått = bestått + 1
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# T6: Auth og rate limiting
# =========================

funksjon test_auth_og_rate()
    skriv("T6: Auth og rate limiting")
    bestått = 0
    totalt = 0

    tilstand = auth_tilstand_lag()
    auth_tilstand_legg_brukar(tilstand, "testbrukar")
    token = auth_tilstand_lag_token(tilstand, "testbrukar", ["publish"])

    res1 = sjekk_skop(tilstand, token, "publish")
    totalt = totalt + 1
    viss sjekk("Gyldig skop", res1.ok)
        bestått = bestått + 1
    slutt

    res2 = sjekk_skop(tilstand, token, "admin")
    totalt = totalt + 1
    viss sjekk("Manglande skop avvist", ikkje res2.ok)
        bestått = bestått + 1
    slutt

    token_tilbakekall(tilstand, token)
    res3 = sjekk_skop(tilstand, token, "publish")
    totalt = totalt + 1
    viss sjekk("Tilbakekalt token avvist", ikkje res3.ok)
        bestått = bestått + 1
    slutt

    # Rate limit
    tilstand2 = auth_tilstand_lag()
    i = 0
    mens i < 101
        rate_limit_sjekk(tilstand2, "brukar", "publish")
        i = i + 1
    slutt
    rate_res = rate_limit_sjekk(tilstand2, "brukar", "publish")
    totalt = totalt + 1
    viss sjekk("Rate limit aktivert ved grensa", ikkje rate_res.ok)
        bestått = bestått + 1
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# T7: Ende-til-ende (manifest -> resolver -> lock -> publish -> hent)
# =========================

funksjon test_e2e()
    skriv("T7: Ende-til-ende")
    bestått = 0
    totalt = 0

    # Bygg opp eit lite registry
    registry = norspkg_registry()
    auth_tilstand = auth_tilstand_lag()
    auth_tilstand_legg_brukar(auth_tilstand, "utgjevar")
    token = auth_tilstand_lag_token(auth_tilstand, "utgjevar", ["publish", "yank"])

    reg_tilstand = registry_tilstand_lag()
    auth_registrer(reg_tilstand, "utgjevar", token)

    # Publiser ei hjelpepakke
    hjelp_pkg = {
        namn: "hjelp",
        versjon: "1.0.0",
        checksum: "sha256:hjelp001",
        kjelde_url: "",
        avhengigheiter: {}
    }
    endpoint_publish(reg_tilstand, token, hjelp_pkg)

    # App-manifest med avhengigheit av hjelp
    manifest = manifest_lag("app", "0.1.0", "app.no")
    manifest_legg_avhengigheit(manifest, "hjelp", "^1.0.0")

    ok_manifest = valider_manifest(manifest)
    totalt = totalt + 1
    viss sjekk("E2E manifest OK", ok_manifest)
        bestått = bestått + 1
    slutt

    resolver_res = resolver_kjoyr(reg_tilstand, manifest)
    totalt = totalt + 1
    viss sjekk("E2E resolver OK", resolver_res.ok)
        bestått = bestått + 1
    slutt

    lock_res = generer_lockfile(manifest, resolver_res)
    totalt = totalt + 1
    viss sjekk("E2E lockfile OK", lock_res.ok)
        bestått = bestått + 1
    slutt

    viss lock_res.ok
        lock = lock_res.lock

        # Verifiser
        ver = verifiser_lockfile(lock, funksjon(n, v)
            returner "sha256:hjelp001"
        slutt)
        totalt = totalt + 1
        viss sjekk("E2E verifisering OK", ver.ok)
            bestått = bestått + 1
        slutt

        # Sjekk at hjelp er i lock
        funnen = usann
        j = 0
        mens j < lengde(lock.pakkar)
            viss lock.pakkar[j].namn == "hjelp"
                funnen = sann
            slutt
            j = j + 1
        slutt
        totalt = totalt + 1
        viss sjekk("E2E hjelp i lock", funnen)
            bestått = bestått + 1
        slutt
    slutt

    skriv("  " + til_tekst(bestått) + "/" + til_tekst(totalt) + " bestått")
    returner bestått == totalt
slutt

# =========================
# Køyr alle testar
# =========================

funksjon køyr_alle_testar()
    skriv("=== norspkg testar ===")
    skriv("")

    resultat = []

    legg_til(resultat, test_manifest())
    legg_til(resultat, test_versjonsmatch())
    legg_til(resultat, test_resolver())
    legg_til(resultat, test_lockfile())
    legg_til(resultat, test_registry())
    legg_til(resultat, test_auth_og_rate())
    legg_til(resultat, test_e2e())

    bestått = 0
    i = 0
    mens i < lengde(resultat)
        viss resultat[i]
            bestått = bestått + 1
        slutt
        i = i + 1
    slutt

    skriv("")
    skriv("=== " + til_tekst(bestått) + "/" + til_tekst(lengde(resultat)) + " testsuitar bestått ===")

    returner bestått == lengde(resultat)
slutt

funksjon main(args)
    ok = køyr_alle_testar()
    viss ikkje ok
        avslutt(1)
    slutt
slutt

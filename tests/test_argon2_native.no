funksjon start() -> heiltall {
    la expected = "09316115d5cf24ed5a15a31a3ba326e5cf32edc24702987c02b6566f61913cf7"
    la actual = builtin.argon2id("password", "somesalt", 65536, 2, 1, 32)
    assert_eq(actual, expected)
    assert(lengde(actual) == 64)
    assert(builtin.argon2id("password", "somesalt", 65536, 2, 1, 32) == expected)
    skriv("test_argon2_native OK\n")
    returner 0
}

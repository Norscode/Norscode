// Norscode Runtime Regression Suite
// Deterministic runtime correctness testing
// Selfhost migration phase

struktur RuntimeTestResult
    navn
    success
    message
slutt

funksjon create_test_result(
    navn,
    success,
    message
)
    la result = RuntimeTestResult()

    result.navn = navn
    result.success = success
    result.message = message

    returner result
slutt

funksjon runtime_test_stack_engine()
    la stack = create_runtime_stack()

    stack_push(stack, 10)

    la value = stack_pop(stack)

    hvis value != 10
        returner create_test_result(
            "stack_engine",
            usann,
            "Stack value mismatch"
        )
    slutt

    returner create_test_result(
        "stack_engine",
        sann,
        "OK"
    )
slutt

funksjon runtime_test_arithmetic()
    la runtime = create_runtime_vm([])

    stack_push(runtime.stack, 2)
    stack_push(runtime.stack, 3)

    runtime_add(runtime)

    la result = stack_pop(runtime.stack)

    hvis result != 5
        returner create_test_result(
            "arithmetic",
            usann,
            "Arithmetic mismatch"
        )
    slutt

    returner create_test_result(
        "arithmetic",
        sann,
        "OK"
    )
slutt

funksjon runtime_test_object_execution()
    la struct_type = create_struct_type(
        "Person"
    )

    struct_add_field(
        struct_type,
        create_runtime_field(
            "navn",
            type_tekst(),
            create_typed_value(
                type_tekst(),
                ""
            )
        )
    )

    la instance = create_runtime_instance(
        struct_type
    )

    runtime_instance_set_field(
        instance,
        "navn",
        create_typed_value(
            type_tekst(),
            "Jan"
        )
    )

    la value = runtime_instance_get_field(
        instance,
        "navn"
    )

    hvis value.value != "Jan"
        returner create_test_result(
            "object_execution",
            usann,
            "Object execution mismatch"
        )
    slutt

    returner create_test_result(
        "object_execution",
        sann,
        "OK"
    )
slutt

funksjon run_runtime_regression_suite()
    la results = []

    results.push(
        runtime_test_stack_engine()
    )

    results.push(
        runtime_test_arithmetic()
    )

    results.push(
        runtime_test_object_execution()
    )

    returner results
slutt

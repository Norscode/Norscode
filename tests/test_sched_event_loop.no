bruk std.sched som sched

funksjon start() -> heltall {
    la s = sched.ny()
    la args: ordbok_tekst = {}
    la no = builtin.now_ms()
    la sein = sched.enterabs(s, no + 120000, 5, "ukjent.sein", args)
    la tidleg = sched.enterabs(s, no + 60000, 1, "ukjent.tidleg", args)
    la same_lav = sched.enterabs(s, 0, 9, "ukjent.lav", args)
    la same_hog = sched.enterabs(s, 0, 1, "ukjent.hog", args)

    assert_eq(sched.tal_ventande(s), 4)
    assert_eq(sched.neste_hending(s)["id"], same_hog)
    assert_eq(sched.run_ferdig(s), 2)
    assert_eq(sched.tal_ventande(s), 2)
    assert_eq(sched.neste_hending(s)["id"], tidleg)
    assert(sched.tid_til_neste(s) > 0)
    assert(sched.cancel(s, tidleg))
    assert(ikkje sched.cancel(s, tidleg))
    assert_eq(sched.tal_ventande(s), 1)
    assert_eq(sched.run(s, 0), 0)
    assert(sched.stopp(s))
    assert(sched.start(s))
    assert(sched.cancel(s, sein))
    assert(sched.er_tom(s))
    assert_eq(sched.tid_til_neste(s), -1)
    returner 0
}

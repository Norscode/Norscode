bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("tools/promote_native_stage0_v3001.no")

    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "funksjon les_fil_trygt(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "returner builtin.fil_les(sti)"))
    assert(t.inneholder(src, "la prefix = namn + \"=\""))
    assert(t.inneholder(src, "builtin.split(les_fil_trygt(path), \"\\n\")"))
    assert(t.inneholder(src, "builtin.starts_with(linje_verdi, prefix)"))
    assert(t.inneholder(src, "builtin.slice(linje_verdi, lengde(prefix), lengde(linje_verdi))"))
    assert(t.inneholder(src, "NORSCODE_NATIVE_GAP_BIN="))
    assert(t.inneholder(src, "/bin/nc"))
    assert(t.inneholder(src, "tools/native_runtime_gap_gate_v3001.no"))

    assert(ikkje t.inneholder(src, "grep -E '^\" + namn + \"='"))
    assert(ikkje t.inneholder(src, "| head -1 | cut -d= -f2-"))
    assert(ikkje t.inneholder(src, "tools/native_runtime_gap_gate_v3001.sh"))

    skriv("test_promote_args_file_no_grep OK")
    returner 0
}

funksjon vent_fil(h: ordbok_tekst, operation_handle: tekst) -> ordbok_tekst {
    la result = {"status": "ventende"}
    la i: heiltall = 0
    mens result["status"] == "ventende" og i < 100 {
        result = builtin.filesystem_write_operation({
            "abi": "norscode-native-filesystem-v1",
            "operation": "wait_async",
            "handle": h["handle"],
            "operation_handle": operation_handle,
            "timeout_ms": 100
        })
        i = i + 1
    }
    returner result
}

funksjon start() -> heiltall {
    la writer = builtin.filesystem_write_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "open",
        "root": "build",
        "relative": "windows-filesystem-iocp.txt",
        "mode": "write"
    })
    assert_eq(writer["status"], "open")

    la pending_write = builtin.filesystem_write_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "write_async",
        "handle": writer["handle"],
        "offset": 0,
        "data": "windows-file-iocp-ok"
    })
    assert_eq(pending_write["status"], "ventende")
    assert_eq(pending_write["event_backend"], "iocp")
    writer["operation"] = "close"
    assert_eq(builtin.filesystem_write_operation(writer)["status"], "feil")

    la write_result = vent_fil(writer, pending_write["operation_handle"])
    assert_eq(write_result["status"], "klar")
    assert_eq(write_result["operation_kind"], 6)
    assert_eq(write_result["value"], 20)
    assert_eq(builtin.filesystem_write_operation(writer)["status"], "closed")

    la reader = builtin.filesystem_read_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "open",
        "root": "build",
        "relative": "windows-filesystem-iocp.txt",
        "mode": "read"
    })
    assert_eq(reader["status"], "open")
    la pending_read = builtin.filesystem_read_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "read_async",
        "handle": reader["handle"],
        "offset": 0,
        "max": 64
    })
    assert_eq(pending_read["status"], "ventende")

    la read_result = builtin.filesystem_read_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "wait_async",
        "handle": reader["handle"],
        "operation_handle": pending_read["operation_handle"],
        "timeout_ms": 5000
    })
    assert_eq(read_result["status"], "klar")
    assert_eq(read_result["operation_kind"], 5)
    assert_eq(read_result["data"], "windows-file-iocp-ok")
    assert_eq(read_result["value"], 20)
    reader["operation"] = "close"
    assert_eq(builtin.filesystem_read_operation(reader)["status"], "closed")

    la stale = builtin.filesystem_read_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "wait_async",
        "handle": reader["handle"],
        "operation_handle": pending_read["operation_handle"],
        "timeout_ms": 0
    })
    assert_eq(stale["status"], "feil")

    assert_eq(builtin.filesystem_write_operation({
        "abi": "norscode-native-filesystem-v1",
        "operation": "delete",
        "root": "build",
        "relative": "windows-filesystem-iocp.txt"
    })["status"], "deleted")
    skriv("test_windows_filesystem_iocp OK")
    returner 0
}

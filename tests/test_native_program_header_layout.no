bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 42 }"
    )

    # ELF program header
    assert(tekst_inneholder(preview, "PT_LOAD"))

    # Executable segment permissions
    assert(tekst_inneholder(preview, "R-X"))

    # ELF64 binary type
    assert(tekst_inneholder(preview, "ET_EXEC"))

    # 64-bit architecture marker
    assert(tekst_inneholder(preview, "EM_X86_64"))

    # Entry address presence
    assert(tekst_inneholder(preview, "entry_address"))

    returner 0
}

bruk std.brannmur som brannmur

funksjon start() -> heiltall {
    la p = brannmur.ny_policy("helpdesk")
    brannmur.hog_sikkerheit_standard(p, "10.0.0.0/8")

    la web = brannmur.evaluer(p, "inn", 443, "tcp", "203.0.113.4")
    assert_eq(web["allowed"], "sann")
    assert_eq(web["regel"], "https")

    la ssh = brannmur.evaluer(p, "inn", 22, "tcp", "10.2.3.4")
    assert_eq(ssh["allowed"], "sann")
    assert_eq(ssh["regel"], "admin-ssh")

    la ssh_denied = brannmur.evaluer(p, "inn", 22, "tcp", "192.0.2.4")
    assert_eq(ssh_denied["allowed"], "usann")
    assert_eq(ssh_denied["regel"], "default-drop")

    la unknown = brannmur.evaluer(p, "inn", 3389, "tcp", "203.0.113.4")
    assert_eq(unknown["allowed"], "usann")
    assert_eq(unknown["handling"], "drop")

    la output = brannmur.evaluer(p, "ut", 443, "tcp", "203.0.113.4")
    assert_eq(output["allowed"], "sann")
    assert(brannmur.produksjon_trygg(p))
    skriv("test_brannmur_policy OK\n")
    returner 0
}

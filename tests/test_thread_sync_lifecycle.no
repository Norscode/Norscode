bruk std.tråd som trd

funksjon start() -> heiltall {
    la m = trd.ny_manager()
    la native_probe = trd.ny_tråd(m, "__main__.ingen")
    assert(ikkje trd.start_native(m, native_probe, 65536))
    assert_eq(trd.status(m, native_probe), "klar")
    assert_eq(trd.tal_aktive(m), 0)
    la a = trd.ny_tråd(m, "__main__.ingen")
    la b = trd.ny_tråd(m, "__main__.ingen")
    la c = trd.ny_tråd(m, "__main__.ingen")
    assert(trd.start(m, a))
    assert(ikkje trd.start(m, a))
    assert(trd.start(m, b))
    assert(trd.start(m, c))
    assert_eq(trd.tal_aktive(m), 3)

    assert(trd.lock(m, a))
    assert(trd.lock(m, a))
    assert_eq(m["_mutex_depth"], "2")
    assert(ikkje trd.lock(m, b))
    assert(ikkje trd.lock(m, c))
    assert_eq(trd.status(m, b), "blokkert")
    assert_eq(trd.unlock(m, b), -1)
    assert_eq(trd.unlock(m, a), 1)
    assert_eq(m["_mutex_eigar"], a)
    assert_eq(trd.unlock(m, a), 0)
    assert_eq(m["_mutex_eigar"], b)
    assert_eq(trd.status(m, b), "kjørar")

    assert(trd.kanseller(m, b))
    assert_eq(trd.status(m, b), "kansellert")
    assert_eq(m["_mutex_eigar"], c)
    assert_eq(trd.status(m, c), "kjørar")
    assert_eq(trd.tal_aktive(m), 2)
    assert(ikkje trd.kanseller(m, b))
    assert(trd.er_ferdig(m, b))
    assert_eq(trd.unlock(m, c), 0)
    assert_eq(m["_mutex_eigar"], "")

    trd.set_delt(m, "counter", "1")
    assert(trd.har_delt(m, "counter"))
    assert_eq(trd.hent_delt(m, "counter"), "1")
    trd.slett_delt(m, "counter")
    assert(ikkje trd.har_delt(m, "counter"))
    assert(trd.ny_atomisk(m, "atomic-counter", 10))
    assert_eq(trd.atomisk_hent(m, "atomic-counter", "acquire"), 10)
    assert(trd.atomisk_cas(m, "atomic-counter", 10, 20))
    assert(ikkje trd.atomisk_cas(m, "atomic-counter", 10, 30))
    assert_eq(trd.atomisk_fetch_add(m, "atomic-counter", 5), 20)
    assert_eq(trd.atomisk_hent(m, "atomic-counter", "seq_cst"), 25)
    trd.ny_event(m, "ready")
    assert(ikkje trd.event_er_sett(m, "ready"))
    trd.set_event(m, "ready")
    assert(trd.event_er_sett(m, "ready"))
    trd.clear_event(m, "ready")
    assert(ikkje trd.event_er_sett(m, "ready"))
    trd.ny_barrier(m, "workers", 2)
    assert(ikkje trd.barrier_vent(m, "workers"))
    assert(trd.barrier_vent(m, "workers"))

    la deadlock_manager = trd.ny_manager()
    la owner = trd.ny_tråd(deadlock_manager, "__main__.manglar")
    la waiter = trd.ny_tråd(deadlock_manager, "__main__.manglar")
    assert(trd.start(deadlock_manager, owner))
    assert(trd.start(deadlock_manager, waiter))
    assert(trd.lock(deadlock_manager, owner))
    assert(ikkje trd.lock(deadlock_manager, waiter))
    la joined = trd.join_med_grense(deadlock_manager, waiter, 5)
    assert_eq(joined["status"], "deadlock")
    assert_eq(joined["thread_status"], "blokkert")

    la status = trd.produksjonsstatus()
    assert_eq(status["status"], "stabil")
    returner 0
}

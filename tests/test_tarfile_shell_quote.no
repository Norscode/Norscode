bruk std.tekst som t

funksjon start() -> heiltall {
    la src = fil_les("std/tarfile.no")
    assert(t.inneholder(src, "Brukar trygt quota tar-verktøy for arkivoperasjonar"))
    assert(t.inneholder(src, "intern Norscode-logikk"))
    assert(t.inneholder(src, "funksjon _shell(sti: tekst) -> tekst"))
    assert(t.inneholder(src, "builtin.replace(sti, \"'\""))
    assert(t.inneholder(src, "funksjon _shell_liste(stiar: liste_tekst) -> tekst"))
    assert(t.inneholder(src, "legg_til(delar, _shell(stiar[i]))"))
    assert(t.inneholder(src, "tar -\" + flagg + \"f \" + _shell(ark_sti)"))
    assert(t.inneholder(src, "\" -C / \" + _shell(mål_namn)"))
    assert(t.inneholder(src, "tar -\" + t_flagg + \"f \" + _shell(ark[\"sti\"])"))
    assert(t.inneholder(src, "mkdir -p \" + _shell(mål)"))
    assert(t.inneholder(src, "\" -C \" + _shell(mål)"))
    assert(t.inneholder(src, "\" \" + _shell(membre_namn)"))
    assert(t.inneholder(src, "tar -tf \" + _shell(sti)"))
    assert(t.inneholder(src, "returner res[0] == \"0\""))
    assert(t.inneholder(src, "mkdir -p \" + _shell(tmp_dir)"))
    assert(t.inneholder(src, "rm -rf \" + _shell(tmp_dir)"))

    assert(ikkje t.inneholder(src, "tar -\" + flagg + \"f \" + ark_sti"))
    assert(ikkje t.inneholder(src, "Brukar exec_prosess med tar-kommandoen"))
    assert(ikkje t.inneholder(src, "tar -\" + t_flagg + \"f \" + ark[\"sti\"]"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + mål"))
    assert(ikkje t.inneholder(src, "\" -C \" + mål"))
    assert(ikkje t.inneholder(src, "tar -tf \" + sti"))
    assert(ikkje t.inneholder(src, "&& echo ja || echo nei"))
    assert(ikkje t.inneholder(src, "mkdir -p \" + tmp_dir"))
    assert(ikkje t.inneholder(src, "rm -rf \" + tmp_dir"))
    assert(ikkje t.inneholder(src, "builtin.join(filer, \" \")"))

    skriv("test_tarfile_shell_quote OK")
    returner 0
}

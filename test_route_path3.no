bruk std.web som web

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id:int}")
    la sti = web.request_path(ctx)
    la svar: tekst = hvis sti == "/brukere/42" da "match" ellers "no"
    la s2: tekst = hvis sti == "ingenting" da "ing" ellers "not_ing"
    returner web.response_builder(200, {"content-type":"text/plain"}, svar + "/" + s2)
}

funksjon start() -> heiltall {
    returner 0
}

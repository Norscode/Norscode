bruk std.web som web

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id:tekst}")
    returner web.response_builder(200, {"content-type":"text/plain"}, "id=" + web.request_param(ctx, "id"))
}

funksjon start() -> heiltall {
    la r = web.handle_request(web.request_context("get", "/brukere/42", {}, {}, ""))
    skriv(web.response_body(r))
    returner 0
}

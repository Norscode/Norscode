// Norscode Runtime - Omgang 199
// Primitive control-flow runtime

runtime z199 {
  state
  context
  session
  scope
  frame
  stack

  push
  pop
  call
  return

  value
  symbol
  bind
  lookup
  resolve
  expression
  compute
  operator
  add
  subtract
  multiply
  divide
  equal
  greater
  less
  boolean
  condition
  if
  else
  loop

  checkpoint
  store
  load

  validate
  guard
  assert
  constraint
  policy
  capability
  permission
  role

  commit
  rollback

  input
  operation
  evaluate
  iterate
  continue
  repeat
  restart
  resume

  compare
  branch
  select
  merge
  assign
  rule

  updated
  output
}

// Semantic direction:
// condition connects boolean results to execution choice.
// if and else give branch/select a structured evaluator form.
// loop connects conditional evaluation to repeated runtime progression.

// Primitive flow:
// expression + compute + boolean + condition
// -> if / else / loop
// -> branch + select + merge
// -> updated + output

// This marks the transition from conditional computation
// into primitive control-flow runtime semantics.
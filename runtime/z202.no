// Norscode Runtime - Omgang 202
// Primitive typed value runtime

runtime z202 {
  state
  context
  session
  scope
  frame
  stack

  push
  pop
  call
  return

  value
  type
  integer
  string
  list
  object
  map

  symbol
  bind
  lookup
  resolve
  expression
  compute
  operator
  add
  subtract
  multiply
  divide
  equal
  greater
  less
  boolean
  condition
  if
  else
  loop

  function
  parameter
  argument
  local
  return_value

  module
  import
  export
  namespace
  library

  checkpoint
  store
  load

  validate
  guard
  assert
  constraint
  policy
  capability
  permission
  role

  commit
  rollback

  input
  operation
  evaluate
  iterate
  continue
  repeat
  restart
  resume

  compare
  branch
  select
  merge
  assign
  rule

  updated
  output
}

// Semantic direction:
// type gives value an explicit runtime form.
// integer and string introduce primitive scalar values.
// list, object, and map introduce primitive structured values.
// typed values make computation, binding, function arguments, and module exports more concrete.

// Primitive flow:
// type + value
// -> integer / string / list / object / map
// -> bind + lookup + resolve
// -> expression + compute
// -> updated + output

// This marks the transition from modular function runtime
// into primitive typed value semantics.
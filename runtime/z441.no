// Norscode Runtime - Omgang 441
// Static files, templates, and server-side rendering

runtime z441 {
  statiske_filer
  static_dir
  static_prefix
  static_index
  static_cache_control
  static_etag_w
  static_gzip_w
  static_brotli_w
  static_spa_fallback
  static_range_requests

  mal_motor
  mal_mappe
  mal_utvidelse
  mal_kompiler_w
  mal_render
  mal_kontekst_w
  mal_partielle
  mal_layout
  mal_arv
  mal_blokk
  mal_super

  mal_syntaks
  m_variabel
  m_blokk_mal
  m_for_mal
  m_hvis_mal
  m_inkluder
  m_utvid
  m_rå
  m_filter_mal
  m_macroen

  escape_html_w
  escape_js_w
  escape_url_w
  trygg_tekst
  merkert_trygg

  html_builder
  hb_element
  hb_attributter
  hb_barn
  hb_tekst
  hb_bygg
  hb_unsafe

  ssr
  ssr_side
  ssr_data
  ssr_hydrate
  ssr_cache_w
  ssr_ttl_w
  ssr_nøkkel_w

  http_cache
  cache_control_w
  etag_w
  last_modified_w
  if_none_match_w
  if_modified_since_w
  cache_variere
  cache_offentlig
  cache_privat
  cache_no_store
  max_alder

  komprimering_web
  gzip_web
  brotli_web
  zstd_web
  komprimér_terskel
  accept_encoding_w
}

// Semantic direction:
// statiske_filer serves files from a directory with automatic ETag and cache headers.
// static_spa_fallback returns index.html for any unmatched path, enabling client-side routing.
// static_range_requests supports HTTP Range headers for resumable downloads and video streaming.
// mal_motor processes template files: compile once, render many times with different contexts.
// mal_mappe is the directory where templates are stored; mal_utvidelse is the file extension (.no.html).
// mal_layout wraps a template in a shared layout; mal_arv and mal_blokk implement template inheritance.
// mal_partielle are reusable template fragments included with m_inkluder.
// m_variabel outputs an escaped value; m_rå outputs raw HTML (unsafe — for trusted content only).
// m_filter_mal applies a transformation function to a value before rendering (e.g. date formatting).
// escape_html_w converts <, >, &, ", ' to HTML entities to prevent XSS injection.
// merkert_trygg marks a string as already-escaped so the template engine doesn't double-escape.
// html_builder provides a type-safe API for constructing HTML without string templates.
// ssr renders a page on the server and returns complete HTML; ssr_hydrate makes it interactive client-side.
// ssr_cache_w caches a rendered page for ssr_ttl_w seconds keyed by ssr_nøkkel_w.
// http_cache sets Cache-Control headers based on the resource type and freshness requirements.
// etag_w is a hash of the response content; if_none_match_w enables 304 Not Modified responses.
// last_modified_w uses file modification time; if_modified_since_w checks it for cache validation.
// cache_variere lists headers that affect the cache key (e.g. Accept-Encoding).
// komprimering_web compresses responses with gzip, brotli, or zstd based on accept_encoding_w.
// komprimér_terskel is the minimum response size below which compression is skipped.

// Primitive flow:
// static: GET /script.js → serve from static_dir → set ETag + Cache-Control: max-age=31536000
//   re-request: If-None-Match matches ETag → 304 Not Modified (no body sent)
// template: render("side.html", {tittel: "Hjem", innhold: [...]}):
//   mal_kompiler_w(side.html) → render(kontekst) → escape all variables → HTML string
// SSR: ssr_side("produkt", {id: 42}) → check ssr_cache → miss → render → cache + return HTML
// compression: svar_html → accept_encoding_w: br → brotli_web compress → set Content-Encoding: br

// This defines static file serving with cache headers, template engine with
// inheritance, HTML builder, SSR caching, and response compression.

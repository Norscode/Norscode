# Browser runtime integration

funksjon browser_runtime()
    returner {
        imports: {},
        exports: {},
        memory: browser_memory(1)
    }
slutt

funksjon browser_memory(pages)
    returner {
        pages: pages,
        bytes: pages * 65536
    }
slutt

funksjon browser_import(name, callback)
    returner {
        name: name,
        callback: callback
    }
slutt

funksjon browser_register_import(runtime, import_obj)
    runtime.imports[import_obj.name] = import_obj
slutt

funksjon browser_register_export(runtime, name, value)
    runtime.exports[name] = value
slutt

funksjon wasm_runtime_bridge(module, runtime)
    returner {
        module: module,
        runtime: runtime,
        instantiated: sann
    }
slutt

funksjon wasm_runtime_call(bridge, name, args)
    export_obj = bridge.runtime.exports[name]

    hvis export_obj == null
        kast "Missing runtime export: " + name
    slutt

    returner export_obj(args)
slutt

funksjon browser_console_log(args)
    skriv("[browser] " + til_tekst(args))
slutt

funksjon browser_default_runtime()
    runtime = browser_runtime()

    browser_register_import(runtime,
        browser_import("console.log", browser_console_log)
    )

    returner runtime
slutt

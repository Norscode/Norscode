// Norscode Runtime - Omgang 314
// Constant folding and algebraic simplification

runtime z314 {
  const_fold_pass
  const_value
  const_int
  const_float
  const_bool
  const_text
  const_null
  const_list
  const_struct_field

  fold_arith
  fold_add
  fold_sub
  fold_mul
  fold_div
  fold_rem
  fold_negate
  fold_overflow_check

  fold_compare
  fold_eq
  fold_ne
  fold_lt
  fold_le
  fold_gt
  fold_ge

  fold_logic
  fold_and
  fold_or
  fold_not
  fold_xor
  fold_short_circuit

  fold_cast
  fold_int_to_float
  fold_float_to_int
  fold_widen
  fold_truncate

  algebraic_simplify
  simplify_add_zero
  simplify_mul_one
  simplify_mul_zero
  simplify_sub_self
  simplify_div_one
  simplify_and_true
  simplify_or_false
  simplify_not_not
  simplify_double_negate

  strength_reduce
  mul_by_power_of_two
  div_by_power_of_two
  mod_by_power_of_two
  shift_left
  shift_right
  replace_with_shift

  const_propagate
  propagate_pass
  known_value
  known_map
  propagate_into_uses
  fold_after_propagate

  sparse_conditional_constant
  scc_lattice
  lattice_top
  lattice_const
  lattice_bottom
  scc_worklist
  scc_edge_executable
}

// Semantic direction:
// const_fold_pass evaluates expressions whose operands are all compile-time constants.
// fold_add(const_int(3), const_int(4)) -> const_int(7) without emitting any instruction.
// fold_overflow_check raises a compile-time error if folded integer arithmetic would overflow.
// fold_compare collapses constant comparisons to const_bool(sant) or const_bool(usant).
// fold_short_circuit removes the unreachable branch of a constant logical expression.
// fold_cast evaluates type conversions between known constant values at compile time.
// algebraic_simplify applies identity laws that hold regardless of the operand's value.
// simplify_add_zero removes x + 0 -> x; simplify_mul_one removes x * 1 -> x.
// simplify_mul_zero replaces x * 0 -> 0 and eliminates side-effect-free subexpressions.
// simplify_not_not removes double negation: ikkje(ikkje(x)) -> x.
// strength_reduce replaces expensive operations with cheaper equivalents.
// mul_by_power_of_two replaces x * 8 with x << 3.
// div_by_power_of_two replaces x / 4 with x >> 2 for unsigned integers.
// mod_by_power_of_two replaces x % 16 with x & 15.
// const_propagate replaces each use of a variable with its known constant value when determinable.
// known_map tracks which ir_values have a known const_value at each program point.
// propagate_into_uses substitutes the const_value into all downstream uses.
// fold_after_propagate runs const_fold_pass again after propagation to catch new opportunities.
// sparse_conditional_constant (SCC) propagates constants through branches, marking unreachable edges.
// scc_lattice models value knowledge: top (unvisited), const (known value), bottom (non-constant).
// scc_edge_executable tracks which control flow edges have been determined reachable.

// Primitive flow:
// const_fold_pass: walk all ir_instrs
//   operands both const? -> fold_arith / fold_compare / fold_cast -> replace with const_value
//   algebraic_simplify: match identity patterns -> remove instruction + replace_uses
//   strength_reduce: match power-of-two multiply/divide -> replace with shift
// const_propagate: assign known_map from const definitions
//   -> propagate_into_uses for each use -> fold_after_propagate
// SCC: worklist of functions and branches
//   -> scc_lattice per value -> converge -> dead branches marked -> remove_instr

// This defines constant folding, algebraic simplification, strength reduction,
// and sparse conditional constant propagation for the Norscode optimizer.

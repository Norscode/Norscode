// Norscode Runtime - Omgang 431
// std.json — native JSON parsing and serialization

runtime z431 {
  std_json

  json_parse
  json_parse_strict
  json_parse_result
  json_parse_error
  error_unexpected_char
  error_unexpected_end
  error_invalid_escape
  error_number_overflow
  error_max_depth

  json_value
  jv_null
  jv_bool
  jv_int
  jv_float
  jv_string
  jv_array
  jv_object
  jv_type

  json_stringify
  json_stringify_pretty
  json_indent
  json_sort_keys
  json_escape_unicode
  json_max_depth_s

  json_pointer
  jp_path
  jp_get
  jp_set
  jp_delete
  jp_error

  json_schema
  schema_validate
  schema_error
  schema_type
  schema_required
  schema_properties
  schema_items
  schema_min
  schema_max
  schema_pattern
  schema_enum

  json_stream
  js_tokenizer
  js_token
  token_begin_object
  token_end_object
  token_begin_array
  token_end_array
  token_key
  token_value
  js_parse_next
  js_skip

  norscode_to_json
  json_to_norscode
  ordbok_to_json
  liste_to_json
  tekst_to_json
  heltall_to_json
  desimaltall_to_json
  boolsk_to_json
  null_to_json

  json_lines
  jl_parse
  jl_stringify
  jl_stream
}

// Semantic direction:
// json_parse converts a JSON string into a Norscode value tree (ordbok, liste, tekst, heltall, etc.).
// json_parse_strict rejects trailing commas, comments, and other JSON5 extensions.
// json_parse_error reports position (line, column) and the specific error_* reason.
// jv_int stores integers that fit in 64-bit signed; jv_float stores IEEE 754 doubles.
// json_stringify converts a Norscode value tree back to a compact JSON string.
// json_stringify_pretty inserts json_indent spaces per level for human-readable output.
// json_sort_keys alphabetically sorts object keys for deterministic output.
// json_escape_unicode escapes non-ASCII characters as \uXXXX sequences.
// json_pointer implements RFC 6901 JSON Pointer: "/a/b/0" accesses nested paths.
// jp_get navigates the value tree by jp_path; returns null if any segment is missing.
// jp_set sets a nested value, creating intermediate objects and arrays as needed.
// json_schema validates a JSON value against a JSON Schema (draft-07 subset).
// schema_validate returns true or a list of schema_errors with paths and messages.
// json_stream processes large JSON documents without building the full tree in memory.
// js_tokenizer emits tokens one at a time; js_parse_next advances to the next token.
// js_skip skips over a complete value (object, array, or scalar) without processing it.
// norscode_to_json converts any Norscode value to its JSON representation.
// json_lines processes newline-delimited JSON: one JSON value per line.

// Primitive flow:
// json_parse('{"navn":"Jan","alder":30}'): tokenize → build ordbok{"navn":"Jan","alder":30}
// json_stringify(ordbok{a:1, b:[2,3]}): "{\"a\":1,\"b\":[2,3]}"
// json_stringify_pretty with indent=2: multi-line with indentation
// json_pointer("/b/0", ordbok{b:[2,3]}): navigate → 2
// json_stream: js_tokenizer → loop: js_parse_next → handle each token without full parse

// This defines the native std.json module: recursive-descent parser, serializer,
// JSON Pointer navigation, schema validation, and streaming tokenizer.

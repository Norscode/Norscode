# Runtime bootstrap phase

struktur RuntimeContext
    stack_pointer
    heap_pointer
    argc
    argv
slutt

struktur StackInitializer
    initialized_stacks
    stack_sizes
slutt

struktur HeapAllocator
    allocated_blocks
    free_blocks
    heap_regions
slutt

struktur SyscallBridge
    executed_syscalls
    syscall_results
slutt

struktur PanicRuntime
    panic_messages
    stack_traces
    abort_states
slutt

struktur MemoryManager
    allocated_pages
    protected_pages
    released_pages
slutt

struktur StartupRuntime
    initialized_contexts
    startup_sequences
slutt

struktur RuntimeBootstrapper
    bootstrapped_runtimes
    initialized_executables
slutt

struktur NativeExecutionContext
    process_id
    executable_path
    runtime_state
slutt

struktur RuntimeLoader
    loaded_binaries
    mapped_sections
slutt

funksjon ny_runtime_context(argc, argv)
    context = RuntimeContext()

    context.stack_pointer = 0x7FFFFFFF0000
    context.heap_pointer = 0x10000000
    context.argc = argc
    context.argv = argv

    returner context
slutt

funksjon ny_stack_initializer()
    initializer = StackInitializer()

    initializer.initialized_stacks = []
    initializer.stack_sizes = {}

    returner initializer
slutt

funksjon initialize_stack(initializer, størrelse)
    hvis initializer == null
        kast "Stack initializer mangler"
    slutt

    stack = {
        address: 0x7FFFFFFF0000,
        size: størrelse
    }

    legg_til(
        initializer.initialized_stacks,
        stack
    )

    initializer.stack_sizes[stack.address] = størrelse

    returner stack
slutt

funksjon ny_heap_allocator()
    allocator = HeapAllocator()

    allocator.allocated_blocks = []
    allocator.free_blocks = []
    allocator.heap_regions = []

    returner allocator
slutt

funksjon heap_allocate(allocator, størrelse)
    hvis allocator == null
        kast "Heap allocator mangler"
    slutt

    blokk = {
        address: (
            0x10000000 +
            (lengde(allocator.allocated_blocks) * 4096)
        ),
        size: størrelse
    }

    legg_til(
        allocator.allocated_blocks,
        blokk
    )

    returner blokk
slutt

funksjon heap_free(allocator, blokk)
    hvis allocator == null
        kast "Heap allocator mangler"
    slutt

    legg_til(
        allocator.free_blocks,
        blokk
    )

    returner sann
slutt

funksjon ny_syscall_bridge()
    bridge = SyscallBridge()

    bridge.executed_syscalls = []
    bridge.syscall_results = []

    returner bridge
slutt

funksjon syscall_write(bridge, fd, buffer, størrelse)
    hvis bridge == null
        kast "Syscall bridge mangler"
    slutt

    syscall = {
        number: 1,
        fd: fd,
        size: størrelse
    }

    legg_til(
        bridge.executed_syscalls,
        syscall
    )

    resultat = størrelse

    legg_til(
        bridge.syscall_results,
        resultat
    )

    returner resultat
slutt

funksjon syscall_exit(bridge, kode)
    hvis bridge == null
        kast "Syscall bridge mangler"
    slutt

    syscall = {
        number: 60,
        code: kode
    }

    legg_til(
        bridge.executed_syscalls,
        syscall
    )

    returner kode
slutt

funksjon ny_panic_runtime()
    runtime = PanicRuntime()

    runtime.panic_messages = []
    runtime.stack_traces = []
    runtime.abort_states = []

    returner runtime
slutt

funksjon runtime_panic(runtime, melding)
    hvis runtime == null
        kast "Panic runtime mangler"
    slutt

    legg_til(
        runtime.panic_messages,
        melding
    )

    legg_til(
        runtime.abort_states,
        sann
    )

    returner usann
slutt

funksjon ny_memory_manager()
    manager = MemoryManager()

    manager.allocated_pages = []
    manager.protected_pages = []
    manager.released_pages = []

    returner manager
slutt

funksjon allocate_page(manager, adresse)
    hvis manager == null
        kast "Memory manager mangler"
    slutt

    legg_til(
        manager.allocated_pages,
        adresse
    )

    returner adresse
slutt

funksjon protect_page(manager, adresse)
    hvis manager == null
        kast "Memory manager mangler"
    slutt

    legg_til(
        manager.protected_pages,
        adresse
    )

    returner sann
slutt

funksjon release_page(manager, adresse)
    hvis manager == null
        kast "Memory manager mangler"
    slutt

    legg_til(
        manager.released_pages,
        adresse
    )

    returner sann
slutt

funksjon ny_startup_runtime()
    runtime = StartupRuntime()

    runtime.initialized_contexts = []
    runtime.startup_sequences = []

    returner runtime
slutt

funksjon initialize_runtime(runtime, context)
    hvis runtime == null
        kast "Startup runtime mangler"
    slutt

    legg_til(
        runtime.initialized_contexts,
        context
    )

    legg_til(
        runtime.startup_sequences,
        "runtime_init"
    )

    returner sann
slutt

funksjon ny_runtime_bootstrapper()
    bootstrapper = RuntimeBootstrapper()

    bootstrapper.bootstrapped_runtimes = []
    bootstrapper.initialized_executables = []

    returner bootstrapper
slutt

funksjon bootstrap_runtime(bootstrapper, executable)
    hvis bootstrapper == null
        kast "Runtime bootstrapper mangler"
    slutt

    legg_til(
        bootstrapper.initialized_executables,
        executable
    )

    legg_til(
        bootstrapper.bootstrapped_runtimes,
        "initialized"
    )

    returner sann
slutt

funksjon ny_native_execution_context(pid, executable)
    context = NativeExecutionContext()

    context.process_id = pid
    context.executable_path = executable
    context.runtime_state = "ready"

    returner context
slutt

funksjon ny_runtime_loader()
    loader = RuntimeLoader()

    loader.loaded_binaries = []
    loader.mapped_sections = []

    returner loader
slutt

funksjon load_executable(loader, binary)
    hvis loader == null
        kast "Runtime loader mangler"
    slutt

    legg_til(
        loader.loaded_binaries,
        binary
    )

    legg_til(
        loader.mapped_sections,
        ".text"
    )

    returner sann
slutt

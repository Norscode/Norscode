  cmd_sec_audit
  cmd_sec_scan
  cmd_sec_keygen
  cmd_sec_encrypt
  cmd_sec_decrypt
  cmd_sec_hash
}

// Semantic direction:
// secure_storage encrypts files and database pages at the application layer.
// encrypted_file stores the file_key (encrypted with KMS), file_nonce, and ciphertext.
// file_checksum detects corruption; secure_delete overwrites the file before unlinking.
// overwrite_passes determines how many times the data is overwritten before deletion.
// transparent_encryption encrypts each db_page before writing to disk and decrypts on read.
// at_rest_encryption protects data when the storage medium is removed or stolen.
// full_disk_encryption uses a volume_key that is unlocked by key_wrap_passphrase or HSM.
// secure_backup encrypts and signs the backup before transmitting to offsite_backup storage.
// backup_verify checks the signature and integrity before restore.
// backup_rotation_sm keeps a configurable number of historical backups and purges older ones.
// secure_alloc allocates memory in pages protected by guard_pages on each side.
// guard_page causes an immediate fault if overread or underread occurs.
// canary_value is a random word placed between stack frames; corruption is detected on return.
// aslr (Address Space Layout Randomization) randomizes base addresses to complicate exploits.
// pie_binary is a Position-Independent Executable required for ASLR to work.
// nx_bit (No-Execute) prevents data pages from being executed as code.
// validate_input rejects input that fails length, encoding, or content checks at system boundaries.
// path_traversal_check rejects paths containing ".." sequences that escape the intended directory.
// command_inject_check detects shell metacharacters in inputs passed to shell commands.
// sql_inject_check detects SQL syntax in inputs passed to query builders.
// html_escape converts <, >, &, ", ' to HTML entities before inserting into HTML context.
// csp_policy (Content-Security-Policy) restricts which scripts and resources the browser loads.
// hsts_policy (HTTP Strict Transport Security) forces HTTPS for a specified duration.
// permissions_policy restricts which browser features the page may use.
// security_stdlib is the Norscode standard security library.
// std_crypto exposes symmetric and asymmetric cryptography; std_tokens provides JWT and PASETO.
// nc_security_command adds security utilities to the Norscode CLI.
// cmd_sec_keygen generates keypairs and symmetric keys to stdout or file.
// cmd_sec_encrypt and cmd_sec_decrypt apply AEAD encryption to files.

// Primitive flow:
// encrypt_file: generate file_key (or derive via KMS) -> random nonce
//   -> aead_encrypt(file_key, nonce, plaintext, aad=file_path) -> ciphertext
//   -> write: file_header(kms_encrypted_key, nonce) || ciphertext || checksum
// decrypt_file: read header -> kms_decrypt(encrypted_key) -> file_key
//   -> aead_decrypt(file_key, nonce, ciphertext) -> plaintext
// secure_delete: overwrite file_bytes with random data overwrite_passes times -> unlink
// input_validation: every user input -> max_length_check + null_byte_check
//   + path_traversal_check + command_inject_check -> reject on failure
// output encoding: any user-controlled string in HTML -> html_escape
//   in URL parameter -> url_encode; in JSON -> json_escape
// security_headers: every HTTP response -> csp + hsts + x_frame_options + referrer_policy
// nc sec audit: scan project for known vulnerability patterns -> report
// nc sec keygen --algo ed25519 --out key.pem -> generate and save keypair

// This defines encrypted storage, database page encryption, backup security,
// memory hardening, input validation, output encoding, and the Norscode security stdlib.

  secure_free
  guard_page
  canary_value
  stack_protection
  heap_spray_protect
  aslr
  pie_binary
  nx_bit
  dep

  input_validation
  validate_input
  sanitize_string
  max_length_check
  encoding_check
  unicode_normalize
  null_byte_check
  path_traversal_check
  command_inject_check
  sql_inject_check

  output_encoding

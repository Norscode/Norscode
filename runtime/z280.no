  format_params
  format_uri
  format_options
  tab_size
  insert_spaces
  trim_trailing_whitespace
  insert_final_newline
  trim_final_newlines
  format_response
  format_edits

  range_format_request
  on_type_format_request
  on_type_character

  formatter
  format_document
  format_range
  format_node
  indentation
  indent_level
  indent_string
  line_break
  trailing_comma
  max_line_length
  normalize_whitespace

  signature_help_request
  signature_help_params
  signature_help_position
  signature_help_response
  signature_information
  signature_label
  signature_documentation
  parameter_information
  parameter_label
  parameter_documentation
  active_signature
  active_parameter

  inlay_hint_request
  inlay_hint_params
  inlay_hint
  hint_position
  hint_label
  hint_kind
  hint_kind_type
  hint_kind_parameter
  hint_padding_left
  hint_padding_right
  hint_tooltip

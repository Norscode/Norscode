  plugin_manifest
  plugin_id
  plugin_versjon
  plugin_avhengighet
  plugin_last
  plugin_losslass
  plugin_aktiver
  plugin_deaktiver
  plugin_liste
  plugin_register
  plugin_api

  utvidelsespunkt
  punkt_editor_panel
  punkt_innstillinger
  punkt_meny_element
  punkt_asset_behandler
  punkt_gizmo
  punkt_debugger_panel
  punkt_spill_system

  plugin_sandbox
  sandbox_tillatelse
  tillatelse_fil_les
  tillatelse_fil_skriv
  tillatelse_nett
  tillatelse_spill_api
  sandbox_grense
  sandbox_brudd

  nc_studio
  studio_vindus_layout
  studio_panel
  panel_scene_hierarki
  panel_inspektør
  panel_ressurser
  panel_konsoll
  panel_profiler
  panel_kode_editor

  kode_editor
  editor_fil_tre

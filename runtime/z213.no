// Norscode Runtime - Omgang 213
// Primitive runtime operating system

runtime z213 {
  compiler
  bytecode
  optimizer
  jit
  vm

  ffi
  native
  syscall
  device
  driver

  kernel
  service
  resource
  scheduler_core
  runtime_os
}

// Semantic direction:
// kernel gives runtime a central systems coordination core.
// service gives runtime long-lived managed behavior.
// resource gives services and processes controlled access to system capacity.
// scheduler_core gives the runtime a dedicated execution-ordering center.
// runtime_os describes the first operating-system-like runtime boundary.

// Primitive flow:
// vm + syscall + device + driver
// -> kernel + service + resource
// -> scheduler_core
// -> runtime_os
// -> updated + output

// This marks the transition from primitive systems-interface runtime
// into primitive runtime-operating-system semantics.
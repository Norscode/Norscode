# Runtime persistence semantic flow phase 1

struktur PersistentContinuationOrchestrationEngine
    orchestration_inputs
    orchestration_states
    orchestration_outputs
slutt

struktur RuntimePersistenceSemanticFlow
    semantic_inputs
    semantic_cycles
    semantic_outputs
slutt

funksjon ny_persistent_continuation_orchestration_engine()
    engine = PersistentContinuationOrchestrationEngine()

    engine.orchestration_inputs = []
    engine.orchestration_states = []
    engine.orchestration_outputs = []

    returner engine
slutt

funksjon registrer_persistent_engine_input(engine, input)
    legg_til(engine.orchestration_inputs, input)
    returner input
slutt

funksjon registrer_persistent_engine_state(engine, state)
    legg_til(engine.orchestration_states, state)
    returner state
slutt

funksjon registrer_persistent_engine_output(engine, output)
    legg_til(engine.orchestration_outputs, output)
    returner output
slutt

funksjon ny_runtime_persistence_semantic_flow()
    flow = RuntimePersistenceSemanticFlow()

    flow.semantic_inputs = []
    flow.semantic_cycles = []
    flow.semantic_outputs = []

    returner flow
slutt

funksjon registrer_semantic_flow_input(flow, input)
    legg_til(flow.semantic_inputs, input)
    returner input
slutt

funksjon registrer_semantic_flow_cycle(flow, cycle)
    legg_til(flow.semantic_cycles, cycle)
    returner cycle
slutt

funksjon registrer_semantic_flow_output(flow, output)
    legg_til(flow.semantic_outputs, output)
    returner output
slutt

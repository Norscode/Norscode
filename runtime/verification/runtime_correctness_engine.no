// Norscode Runtime Correctness Engine
// Runtime correctness and deterministic execution
// Selfhost migration phase

struktur RuntimeVerification
    deterministic
    verified
    errors
slutt

funksjon create_runtime_verification()
    la verification = RuntimeVerification()

    verification.deterministic = sann
    verification.verified = usann
    verification.errors = []

    returner verification
slutt

funksjon runtime_verify_stack(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    hvis runtime.stack == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon runtime_verify_heap(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    hvis runtime.heap == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon runtime_verify_frames(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    hvis runtime.current_frame == ingen
        returner sann
    slutt

    returner runtime.current_frame.return_ip >= 0
slutt

funksjon runtime_verify_execution(runtime)
    hvis runtime_verify_stack(runtime) == usann
        returner usann
    slutt

    hvis runtime_verify_heap(runtime) == usann
        returner usann
    slutt

    hvis runtime_verify_frames(runtime) == usann
        returner usann
    slutt

    returner sann
slutt

funksjon runtime_validate_instruction(runtime, instruction)
    hvis runtime == ingen
        returner usann
    slutt

    hvis instruction == ingen
        returner usann
    slutt

    hvis instruction.opcode == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon runtime_execute_deterministic(
    interpreter,
    instructions
)
    hvis interpreter == ingen
        returner usann
    slutt

    for instruction i instructions
        hvis runtime_validate_instruction(
            interpreter.vm,
            instruction
        ) == usann
            returner usann
        slutt

        runtime_execute_instruction(
            interpreter,
            instruction
        )
    slutt

    returner runtime_verify_execution(
        interpreter.vm
    )
slutt

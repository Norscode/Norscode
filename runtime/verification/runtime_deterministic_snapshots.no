// Norscode Runtime Deterministic Snapshots
// Deterministic runtime equivalence validation
// Selfhost migration phase

struktur RuntimeSnapshot
    stack_hash
    heap_hash
    frame_hash
    object_hash
    output_hash
slutt

funksjon create_runtime_snapshot(
    stack_hash,
    heap_hash,
    frame_hash,
    object_hash,
    output_hash
)
    la snapshot = RuntimeSnapshot()

    snapshot.stack_hash = stack_hash
    snapshot.heap_hash = heap_hash
    snapshot.frame_hash = frame_hash
    snapshot.object_hash = object_hash
    snapshot.output_hash = output_hash

    returner snapshot
slutt

funksjon runtime_hash_stack(runtime)
    hvis runtime == ingen
        returner "stack_null"
    slutt

    returner tekst(runtime.stack.values)
slutt

funksjon runtime_hash_heap(runtime)
    hvis runtime == ingen
        returner "heap_null"
    slutt

    returner tekst(runtime.heap.objects)
slutt

funksjon runtime_hash_frames(runtime)
    hvis runtime == ingen
        returner "frame_null"
    slutt

    returner tekst(runtime.current_frame)
slutt

funksjon runtime_hash_objects(runtime)
    hvis runtime == ingen
        returner "object_null"
    slutt

    returner tekst(runtime.heap.objects)
slutt

funksjon runtime_hash_output(output)
    hvis output == ingen
        returner "output_null"
    slutt

    returner tekst(output)
slutt

funksjon runtime_create_snapshot(
    runtime,
    output
)
    returner create_runtime_snapshot(
        runtime_hash_stack(runtime),
        runtime_hash_heap(runtime),
        runtime_hash_frames(runtime),
        runtime_hash_objects(runtime),
        runtime_hash_output(output)
    )
slutt

funksjon runtime_validate_snapshot_equivalence(
    left,
    right
)
    hvis left.stack_hash != right.stack_hash
        returner usann
    slutt

    hvis left.heap_hash != right.heap_hash
        returner usann
    slutt

    hvis left.frame_hash != right.frame_hash
        returner usann
    slutt

    hvis left.object_hash != right.object_hash
        returner usann
    slutt

    hvis left.output_hash != right.output_hash
        returner usann
    slutt

    returner sann
slutt

funksjon runtime_validate_deterministic_execution(
    runtime_1,
    output_1,
    runtime_2,
    output_2
)
    la snapshot_1 = runtime_create_snapshot(
        runtime_1,
        output_1
    )

    la snapshot_2 = runtime_create_snapshot(
        runtime_2,
        output_2
    )

    returner runtime_validate_snapshot_equivalence(
        snapshot_1,
        snapshot_2
    )
slutt

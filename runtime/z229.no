// Norscode Runtime - Omgang 229
// Practical VM state and result extraction

runtime z229 {
  instruction_pointer
  fetch
  dispatch
  execute
  halt

  stack_value
  push_stack
  pop_stack
  stack_top

  constant
  constant_table
  load_const

  add_opcode
  pop_left
  pop_right
  integer_add
  push_result

  vm_state
  execution_loop
  read_result
  stop_reason
  return_result
}

// Semantic direction:
// vm_state groups instruction pointer, stack, constants, and execution state.
// execution_loop repeatedly fetches and executes instructions until halt.
// stack_top reads the current visible result candidate.
// stop_reason records why execution ended.
// read_result extracts the final value from VM state.

// Primitive flow:
// execution_loop
// -> fetch -> dispatch -> execute
// -> stack mutation
// -> halt + stop_reason
// -> stack_top -> read_result -> return_result

// This is the first nearly-complete minimal arithmetic VM execution model.
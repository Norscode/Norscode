  skjermleser_uthev
  skjermleser_region
  live_region
  live_region_høflig
  live_region_påtrengende
  skjermleser_kortkommando

  semantisk_tre
  a11y_node
  a11y_rolle
  rolle_knapp
  rolle_avkrysning
  rolle_glidebryter
  rolle_meny
  rolle_dialogboks
  rolle_status
  rolle_alarm
  a11y_navn
  a11y_beskrivelse
  a11y_tilstand

// Norscode Runtime - Omgang 606
// Abstrakt interpretasjon og statisk analyse

runtime z606 {
  abstrakt_interpretasjon
  ai_konfig
  sikker_approksimasjon
  galois_forbindelsen
  over_approksimasjon

  gallois_struktur
  konkret_domene
  abstrakt_domene
  abstraksjons_funksjon
  konkretiserings_funksjon

  abstrakte_domener
  fortegns_domene
  intervall_domene
  polyhedron_domene
  oktagon_domene
  kongruens_domene
  streng_analyse_domene
  taint_domene

  fast_punkt_beregning
  widening_operasjon
  narrowing_operasjon
  konvergens_garanti
  iterativ_analyse

  programflytsanalyse
  kontrollflyt_graf
  dataflyt_analyse
  reaching_definitions
  levende_variabler
  tilgjengelige_uttrykk

  peker_analyse
  andersen_analyse
  steensgaard_analyse
  may_alias

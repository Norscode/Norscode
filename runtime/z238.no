// Norscode Runtime - Omgang 238
// Practical VM coroutines and resumable execution

runtime z238 {
  vm_state
  execution_loop
  instruction_pointer

  fetch
  dispatch
  execute
  halt

  stack_value
  push_stack
  pop_stack

  call_frame
  frame_stack
  local_slot
  load_local
  store_local

  function
  call
  return

  coroutine
  coroutine_state
  yield
  resume
  suspend_point
  continuation
  await_value
  scheduler_queue

  exception
  throw
  catch
}

// Semantic direction:
// coroutine gives functions a resumable execution identity.
// coroutine_state stores stack, frame, instruction pointer, and suspended values.
// yield suspends execution and returns control to the caller or scheduler.
// resume restores a suspended coroutine and continues execution.
// suspend_point records where execution paused.
// continuation captures the next execution step.
// await_value represents a pending runtime value before continuation.
// scheduler_queue holds resumable coroutines ready for execution.

// Primitive flow:
// call coroutine
// -> execute until yield / await_value
// -> save coroutine_state + suspend_point
// -> scheduler_queue
// -> resume + continuation
// -> return

// This extends the practical typed method runtime into resumable coroutine execution.
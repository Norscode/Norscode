// Norscode Runtime - Omgang 339
// AI agent framework with tools and memory

runtime z339 {
  agent
  agent_id
  agent_name
  agent_description
  agent_system_prompt
  agent_model
  agent_tools
  agent_memory
  agent_config

  agent_run
  run_input
  run_output
  run_trace
  run_status
  status_running
  status_complete
  status_error
  status_max_steps

  step
  step_number
  step_input
  step_thought
  step_action
  step_observation
  step_output
  max_steps

  tool
  tool_name
  tool_description
  tool_input_schema
  tool_output_schema
  tool_handler
  tool_result
  tool_error

  tool_registry
  register_tool
  lookup_tool
  list_tools

  builtin_tools
  tool_web_search
  tool_read_file
  tool_write_file
  tool_run_code
  tool_http_request
  tool_query_db
  tool_send_email
  tool_calendar
  tool_calculator

  memory
  memory_kind
  kind_working
  kind_episodic
  kind_semantic
  kind_procedural

  working_memory
  wm_context
  wm_add
  wm_get
  wm_clear
  wm_token_budget

  episodic_memory
  episode
  episode_id
  episode_content
  episode_timestamp
  episode_importance
  recall_episodes
  forget_episode

  semantic_memory_agent
  knowledge_entry
  knowledge_key
  knowledge_value
  remember_fact
  recall_fact
  update_fact

  memory_consolidation
  consolidate_episodes
  summarize_memory
  prune_old_memories

  multi_agent
  agent_network
  orchestrator
  sub_agent
  delegate_task
  agent_message
  agent_handoff
  shared_memory
}

// Semantic direction:
// agent is an autonomous AI program that reasons over inputs, uses tools, and produces outputs.
// agent_system_prompt defines the agent's role, constraints, and behavior.
// agent_tools is the list of tools the agent may invoke during a run.
// agent_run executes the agent's reasoning loop until completion or max_steps.
// step represents one iteration: the agent thinks (step_thought), acts (step_action), and observes (step_observation).
// step_thought is the model's internal reasoning before choosing an action.
// step_action is the tool call or final answer decision.
// step_observation is the tool_result returned to the model for the next step.
// max_steps prevents infinite loops; status_max_steps indicates the limit was reached.
// tool is a function the agent can call; tool_input_schema describes accepted parameters.
// tool_handler is the Norscode function executed when the model invokes the tool.
// tool_registry maps tool_names to handlers; list_tools provides the schema to the model.
// tool_run_code executes Norscode or shell code in a sandbox and returns stdout.
// tool_web_search queries a search engine and returns snippets.
// tool_http_request makes an authenticated HTTP call to an external API.
// working_memory is the short-term context for the current run; wm_token_budget limits its size.
// episodic_memory stores past agent runs as episodes for future reference.
// episode_importance scores help decide which episodes to recall_episodes in new runs.
// semantic_memory_agent is a key-value fact store; remember_fact persists knowledge across runs.
// memory_consolidation summarizes old episodic memories to free space without losing context.
// orchestrator is a top-level agent that delegates tasks to sub_agents.
// agent_handoff transfers execution from one agent to another with context.
// shared_memory allows multiple agents in a network to read and write common facts.

// Primitive flow:
// agent_run(input):
//   while step_number < max_steps and not complete:
//     build prompt: system_prompt + tool_schemas + working_memory + history
//     llm_client.complete -> response
//     if content_tool_use: lookup_tool -> tool_handler(args) -> tool_result
//       wm_add(tool_name, tool_result) -> next step
//     if stop_end_turn: step_output = response_text -> status_complete
// episodic_memory: on run complete -> episode(input, output, trace) -> store
//   on next run: recall_episodes(query) -> inject into working_memory
// multi_agent: orchestrator receives task -> delegate_task(sub_agent, subtask)
//   -> sub_agent runs -> agent_handoff(result) back to orchestrator

// This defines the AI agent framework: reasoning loops, tool invocation,
// multi-tier memory, and multi-agent orchestration.

// Norscode Runtime - Omgang 235
// Practical VM module loading and import/export resolution

runtime z235 {
  vm_state
  execution_loop
  instruction_pointer

  fetch
  dispatch
  execute
  halt

  stack_value
  push_stack
  pop_stack

  function
  function_table
  call
  return

  closure
  closure_object
  capture
  environment_ref

  heap
  object_id
  reference
  dereference

  module
  module_table
  module_id
  module_loader
  import_symbol
  export_symbol
  namespace
  resolve_import
  link_module

  read_result
  return_result
}

// Semantic direction:
// module gives compiled code a reusable runtime unit.
// module_table stores loaded modules by stable identity.
// module_loader loads a module into VM state.
// import_symbol declares a required external binding.
// export_symbol declares a binding visible outside the module.
// namespace isolates symbols between modules.
// resolve_import finds an exported symbol through module linkage.
// link_module connects imports to exports before execution.

// Primitive flow:
// module_loader -> module_table
// -> export_symbol + namespace
// -> import_symbol -> resolve_import
// -> link_module
// -> function/closure execution
// -> return_result

// This extends the practical interpreter core from closures and heap objects
// into reusable multi-module execution.
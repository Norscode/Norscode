// Norscode Runtime - Omgang 297
// Artifact packaging and GitHub Releases publishing

runtime z297 {
  artifact_packager
  pack_input
  pack_binary
  pack_stdlib
  pack_install_script
  pack_readme
  pack_license
  pack_changelog_entry
  pack_manifest_json

  tarball_builder
  tarball_path
  tarball_root_dir
  tarball_entry
  tarball_compress
  tarball_write

  zip_builder
  zip_path
  zip_entry
  zip_write

  package_layout
  layout_bin_dir
  layout_lib_dir
  layout_share_dir
  layout_doc_dir

  install_script
  install_detect_os
  install_detect_arch
  install_target_dir
  install_symlink
  install_path_suggestion
  uninstall_script

  checksums_file
  checksum_entry
  checksum_format
  checksum_sha256

  release_publisher
  gh_release_create
  gh_asset_upload
  gh_release_edit
  gh_release_publish
  gh_api_token

  asset_bundle
  asset_tarball
  asset_zip
  asset_checksums
  asset_install_script
  asset_wasm_bundle

  release_index
  index_version
  index_platforms
  index_platform_entry
  index_download_url
  index_checksum
  index_signature

  update_latest_pointer
  latest_json
  latest_version
  latest_download_url

  cdn_publish
  cdn_bucket
  cdn_path
  cdn_invalidate
  cdn_url
}

// Semantic direction:
// artifact_packager assembles all distribution files for one platform into a tarball or zip.
// pack_binary is the compiled nc executable for the target platform.
// pack_stdlib bundles the Norscode standard library source files.
// pack_install_script is the shell script that places files and sets up PATH.
// pack_manifest_json is a machine-readable metadata file inside the archive.
// tarball_root_dir is the top-level directory name inside the archive (e.g. norscode-1.2.3).
// package_layout mirrors the conventional Unix directory structure within the archive.
// install_detect_os reads the host OS from uname to choose the installation path.
// install_symlink creates a nc symlink in /usr/local/bin or ~/.local/bin.
// install_path_suggestion prints instructions when the target directory is not in PATH.
// checksums_file is a text file listing SHA-256 hashes for all release assets.
// checksum_format is "<hash>  <filename>" per line, compatible with sha256sum -c.
// release_publisher uses the gh CLI to create and populate the GitHub Release.
// gh_release_create creates the release record with the version tag and release_body.
// gh_asset_upload attaches each asset_bundle file to the release.
// gh_release_publish makes a draft release visible to the public.
// release_index is a JSON document listing all available versions and their download URLs.
// update_latest_pointer writes the latest_json file pointing to the newest stable version.
// cdn_publish copies release assets to an object store or CDN for fast global download.
// cdn_invalidate clears cached edges after new assets are uploaded.

// Primitive flow:
// for each platform binary:
//   artifact_packager: pack_binary + pack_stdlib + pack_install_script + pack_readme + pack_license
//   -> tarball_builder or zip_builder -> tarball_path / zip_path
// checksums_file: sha256 of each archive -> checksum_entry per file
// release_publisher:
//   gh_release_create(tag, release_body, draft=true)
//   -> for each asset: gh_asset_upload(asset_tarball/zip)
//   -> gh_asset_upload(checksums_file)
//   -> gh_release_publish (draft=false)
// release_index update: add new version entry -> update_latest_pointer
// cdn_publish: copy tarballs + checksums -> cdn_bucket -> cdn_invalidate

// This defines artifact packaging, checksum generation, GitHub Release
// assembly, and CDN publishing for Norscode distribution.

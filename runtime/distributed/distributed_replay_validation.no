// Norscode Distributed Replay Validation
// Distributed deterministic replay engine
// Selfhost migration phase

struktur DistributedReplaySnapshot
    node_id
    task_id
    runtime_hash
    scheduler_hash
    message_hash
slutt

funksjon create_distributed_replay_snapshot(
    node_id,
    task_id,
    runtime_hash,
    scheduler_hash,
    message_hash
)
    la snapshot = DistributedReplaySnapshot()

    snapshot.node_id = node_id
    snapshot.task_id = task_id
    snapshot.runtime_hash = runtime_hash
    snapshot.scheduler_hash = scheduler_hash
    snapshot.message_hash = message_hash

    returner snapshot
slutt

funksjon distributed_runtime_hash(runtime)
    hvis runtime == ingen
        returner "runtime_null"
    slutt

    returner tekst(runtime.nodes)
slutt

funksjon distributed_scheduler_hash(runtime)
    hvis runtime == ingen
        returner "scheduler_null"
    slutt

    returner tekst(runtime.scheduler)
slutt

funksjon distributed_message_hash(runtime)
    hvis runtime == ingen
        returner "message_null"
    slutt

    returner tekst(runtime.message_queue)
slutt

funksjon distributed_capture_snapshot(
    runtime,
    node,
    task
)
    returner create_distributed_replay_snapshot(
        node.id,
        task.id,
        distributed_runtime_hash(runtime),
        distributed_scheduler_hash(runtime),
        distributed_message_hash(runtime)
    )
slutt

funksjon distributed_validate_replay(
    original,
    replay
)
    hvis original.runtime_hash != replay.runtime_hash
        returner usann
    slutt

    hvis original.scheduler_hash != replay.scheduler_hash
        returner usann
    slutt

    hvis original.message_hash != replay.message_hash
        returner usann
    slutt

    returner sann
slutt

funksjon distributed_replay_task(
    runtime,
    node,
    task
)
    la original = distributed_capture_snapshot(
        runtime,
        node,
        task
    )

    cluster_dispatch_task(
        runtime,
        task
    )

    la replay = distributed_capture_snapshot(
        runtime,
        node,
        task
    )

    hvis distributed_validate_replay(
        original,
        replay
    ) == usann
        runtime_print(
            "Distributed replay divergence detected"
        )

        returner usann
    slutt

    runtime_print(
        "Distributed replay verified"
    )

    returner sann
slutt

funksjon distributed_cluster_replay(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    for node i runtime.nodes
        for task i node.tasks
            hvis distributed_replay_task(
                runtime,
                node,
                task
            ) == usann
                returner usann
            slutt
        slutt
    slutt

    runtime_print(
        "Cluster replay validation complete"
    )

    returner sann
slutt

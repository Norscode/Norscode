// Norscode Runtime Local Variable Engine
// Priority 1 Interpreter Runtime
// Selfhost migration phase

funksjon runtime_store(runtime, name)
    hvis runtime.current_frame == ingen
        returner usann
    slutt

    la value = stack_pop(runtime.stack)

    hvis value == ingen
        returner usann
    slutt

    returner frame_define_local(
        runtime.current_frame,
        name,
        value
    )
slutt

funksjon runtime_local_get(runtime, name)
    hvis runtime.current_frame == ingen
        returner ingen
    slutt

    for local i runtime.current_frame.locals
        hvis local.name == name
            returner local.value
        slutt
    slutt

    returner ingen
slutt

funksjon runtime_local_set(runtime, name, value)
    hvis runtime.current_frame == ingen
        returner usann
    slutt

    for local i runtime.current_frame.locals
        hvis local.name == name
            local.value = value
            returner sann
        slutt
    slutt

    returner frame_define_local(
        runtime.current_frame,
        name,
        value
    )
slutt

funksjon runtime_load(runtime, name)
    la value = runtime_local_get(runtime, name)

    hvis value == ingen
        returner usann
    slutt

    returner stack_push(runtime.stack, value)
slutt

funksjon runtime_local_exists(runtime, name)
    hvis runtime.current_frame == ingen
        returner usann
    slutt

    for local i runtime.current_frame.locals
        hvis local.name == name
            returner sann
        slutt
    slutt

    returner usann
slutt

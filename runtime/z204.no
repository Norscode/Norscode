  rule

  updated
  output
}

// Semantic direction:
// ownership gives references an explicit lifetime authority.
// retain keeps a referenced value alive across runtime flow.
// borrow allows temporary access without ownership transfer.
// move transfers ownership between runtime domains.
// garbage_collect describes cleanup of unreachable memory-backed values.

// Primitive flow:
// allocate + reference + ownership
// -> retain / borrow / move
// -> release / garbage_collect
// -> updated + output

// This marks the transition from primitive memory runtime
// into primitive memory-safety semantics.
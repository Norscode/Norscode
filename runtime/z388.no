  btree_key
  key_compare
  key_less
  key_equal
  key_bytes
  key_len

  btree_search
  search_exact
  search_range
  search_lower_bound
  search_upper_bound
  search_result
  found_key
  found_value
  found_pos

  btree_insert
  insert_key
  insert_value
  split_node
  split_median
  push_up_key
  insert_non_full
  root_split

  btree_delete
  delete_key
  find_predecessor
  find_successor

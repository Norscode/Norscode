// Norscode Runtime - Omgang 410
// Async/await syntax and future semantics

runtime z410 {
  future
  future_id
  future_state
  fut_pending
  fut_ready
  fut_failed
  future_value
  future_error
  future_poll
  future_resolve
  future_reject
  future_cancel
  future_cancelled

  task
  task_id_a
  task_future
  task_waker
  task_state_a
  task_spawn
  task_join_a
  task_cancel_a
  task_detach_a

  waker
  wake
  wake_by_ref
  waker_clone
  waker_drop
  waker_context

  poll_result
  poll_pending
  poll_ready

  async_fn
  async_body
  resume_point
  suspension_point
  coroutine_state
  coroutine_frame
  awaited_future

  await_expr
  await_poll
  suspend_here
  resume_here
  propagate_cancel

  async_desugar
  state_machine
  sm_variant
  sm_initial
  sm_suspended
  sm_complete
  transition_state

  async_block
  async_closure
  async_move
  capture_by_move

  join_all
  join_set
  select_futures
  race
  timeout_fut
  with_timeout
}

// Semantic direction:
// future is the core async primitive: a computation that may not have completed yet.
// future_poll drives a future one step; it returns poll_ready(value) or poll_pending.
// task wraps a future and connects it to the scheduler; task_spawn submits it for execution.
// waker is a lightweight handle that notifies the scheduler when a future is ready to progress.
// wake signals that a suspended task should be re-polled.
// async_fn is desugared to a state machine by the compiler.
// resume_point is a label the state machine jumps to after an await resumes.
// suspension_point is the code before the state machine stores state and returns poll_pending.
// coroutine_frame holds the local variables and resume_point for a suspended async function.
// await_expr polls the awaited_future; if poll_pending, stores the frame and returns pending.
// On resume, the state machine restores local variables and jumps to resume_here.
// async_desugar transforms an async function body into a state_machine with sm_variants.
// Each suspension_point becomes one sm_variant; the compiler assigns each a unique index.
// propagate_cancel checks for cancellation at every await point and returns fut_cancelled.
// join_all creates a future that completes when all provided futures have completed.
// race creates a future that completes when the first provided future completes.
// with_timeout wraps a future; if it doesn't complete within the duration, returns fut_failed.
// select_futures polls all futures and returns the result of the first ready one.

// Primitive flow:
// async fn: compiler desugars body -> state_machine with sm_variants per await
// task_spawn(async_fn(args)): create coroutine_frame -> wrap in task -> submit to scheduler
// scheduler: poll loop: task.future_poll(waker)
//   poll_ready: task done, resolve value
//   poll_pending: task suspended, waker stored
// await: await inner_future
//   poll inner_future(waker) -> poll_ready: continue; poll_pending: store state -> return pending
//   inner future later calls wake() -> task re-queued -> scheduler re-polls

// This defines async/await desugaring, the future trait, wakers, task spawning,
// and combinators like join_all, race, and with_timeout.

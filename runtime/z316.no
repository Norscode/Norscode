// Norscode Runtime - Omgang 316
// Function inlining and call site optimization

runtime z316 {
  inline_pass
  inline_decision
  inline_threshold
  inline_cost
  instr_cost
  call_overhead
  callee_size
  caller_size
  size_after_inline

  inlineable
  too_large
  recursive_call
  indirect_call
  always_inline
  never_inline
  inline_hint

  call_site
  call_instr
  callee_func
  call_args
  call_result
  call_site_context

  inline_action
  clone_callee
  substitute_args
  redirect_returns
  patch_call_site
  merge_into_caller

  return_value_opt
  single_return
  multiple_returns
  return_block
  return_value
  return_merge

  devirtualize
  virtual_call
  static_type_known
  devirt_target
  speculative_devirt
  devirt_guard
  devirt_fallback

  partial_inlining
  cold_path
  hot_path
  extract_cold
  inline_hot_only

  inter_procedural
  ipa_pass
  ipa_const_propagate
  ipa_dead_arg
  dead_argument
  remove_dead_arg
  ipa_return_value

  call_graph_edge
  call_count
  call_frequency
  hot_call
  cold_call
}

// Semantic direction:
// inline_pass decides which call sites to inline and performs the substitution.
// inline_cost estimates the increase in code size from inlining a call.
// instr_cost assigns a weight to each instruction type for cost estimation.
// inline_threshold is the maximum inline_cost permitted before the decision is too_large.
// always_inline is a programmer annotation that forces inlining regardless of cost.
// never_inline prevents inlining for functions with complex stack or recursive structure.
// inline_hint suggests inlining when the callee is small and frequently called.
// clone_callee duplicates the callee's IR for insertion into the caller.
// substitute_args replaces each parameter reference in the clone with the actual call_arg.
// redirect_returns replaces each return in the clone with a jump to the return_block.
// return_merge inserts a phi node to merge multiple return values into one call_result.
// patch_call_site replaces the call_instr with the inlined clone's instruction sequence.
// merge_into_caller integrates the cloned blocks into the caller's control flow graph.
// devirtualize converts an indirect call to a direct call when the static type is known.
// speculative_devirt inserts a type test; if it passes, a direct call is made; otherwise devirt_fallback.
// partial_inlining inlines only the hot_path of a callee and extracts the cold_path into a helper.
// ipa_const_propagate propagates constants from call sites across function boundaries.
// ipa_dead_arg removes function parameters that are never read by the callee.
// remove_dead_arg eliminates the parameter from both the declaration and all call sites.
// ipa_return_value propagates the return value back to call sites when it is always constant.
// call_frequency is the estimated or measured number of times a call site executes.
// hot_call is a frequently executed call site prioritized for inlining.

// Primitive flow:
// inline_pass: iterate call_graph in bottom-up order (callees before callers)
//   -> for each call_site: inline_decision
//      always_inline or (callee_size <= inline_threshold and not recursive_call)
//      -> clone_callee -> substitute_args -> redirect_returns
//      -> patch_call_site -> merge_into_caller
//      -> re-run const_fold and dce on merged blocks
// devirtualize: virtual_call + static_type_known -> devirt_target
//   -> speculative_devirt: type guard + direct call + fallback
// ipa_const_propagate: call sites with const args -> propagate into callee IR
// ipa_dead_arg: parameter never referenced in callee body -> remove_dead_arg

// This defines function inlining, devirtualization, partial inlining,
// and inter-procedural analysis for the Norscode optimizer.

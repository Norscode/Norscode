// Norscode Runtime - Omgang 211
// Primitive executable runtime

runtime z211 {
  persistence
  database
  snapshot
  log
  recovery

  compiler
  bytecode
  optimizer
  jit
  vm
}

// Semantic direction:
// compiler turns structured runtime forms into executable representation.
// bytecode gives execution a portable instruction layer.
// optimizer improves evaluator paths before execution.
// jit allows runtime-specialized execution paths.
// vm gives bytecode a dedicated execution machine.

// Primitive flow:
// expression + function + module
// -> compiler + bytecode
// -> optimizer + jit
// -> vm
// -> log + snapshot + recovery
// -> updated + output

// This marks the transition from persistent runtime semantics
// into primitive executable runtime semantics.
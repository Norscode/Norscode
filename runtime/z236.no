// Norscode Runtime - Omgang 236
// Practical VM exception handling and stack unwinding

runtime z236 {
  vm_state
  execution_loop
  instruction_pointer

  fetch
  dispatch
  execute
  halt

  stack_value
  push_stack
  pop_stack
  stack_top

  call_frame
  frame_stack
  local_slot
  load_local
  store_local

  function
  function_table
  call
  return

  closure
  closure_object
  environment_ref

  module
  module_table
  module_loader
  namespace
  resolve_import
  link_module

  exception
  throw
  catch
  handler_table
  handler_frame
  unwind_stack
  error_value
  recover

  read_result
  return_result
}

// Semantic direction:
// exception gives runtime failures a structured value path.
// throw transfers execution from normal flow into error flow.
// catch defines a recovery boundary.
// handler_table maps protected bytecode ranges to handlers.
// handler_frame records where execution should resume after a throw.
// unwind_stack removes call frames until a matching handler is found.
// error_value carries failure data through the VM.
// recover resumes execution inside the selected handler.

// Primitive flow:
// execute -> throw + error_value
// -> handler_table lookup
// -> unwind_stack + handler_frame
// -> catch + recover
// -> continue execution_loop

// This extends the practical interpreter core with structured failure handling.
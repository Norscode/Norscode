# Runtime continuation phase 1

struktur RuntimeExecutionContinuationFlow
    continuation_inputs
    continuation_states
    continuation_outputs
slutt

struktur RuntimeSemanticContinuationEngine
    semantic_inputs
    semantic_cycles
    semantic_outputs
slutt

funksjon ny_runtime_execution_continuation_flow()
    flow = RuntimeExecutionContinuationFlow()

    flow.continuation_inputs = []
    flow.continuation_states = []
    flow.continuation_outputs = []

    returner flow
slutt

funksjon registrer_runtime_continuation_input(flow, input)
    legg_til(flow.continuation_inputs, input)
    returner input
slutt

funksjon registrer_runtime_continuation_state(flow, state)
    legg_til(flow.continuation_states, state)
    returner state
slutt

funksjon registrer_runtime_continuation_output(flow, output)
    legg_til(flow.continuation_outputs, output)
    returner output
slutt

funksjon ny_runtime_semantic_continuation_engine()
    engine = RuntimeSemanticContinuationEngine()

    engine.semantic_inputs = []
    engine.semantic_cycles = []
    engine.semantic_outputs = []

    returner engine
slutt

funksjon registrer_semantic_continuation_input(engine, input)
    legg_til(engine.semantic_inputs, input)
    returner input
slutt

funksjon registrer_semantic_continuation_cycle(engine, cycle)
    legg_til(engine.semantic_cycles, cycle)
    returner cycle
slutt

funksjon registrer_semantic_continuation_output(engine, output)
    legg_til(engine.semantic_outputs, output)
    returner output
slutt

// Norscode Runtime - Omgang 245
// Practical package system and incremental compilation

runtime z245 {
  source_unit
  token_stream
  parser
  ast
  semantic_check
  lower_ast

  compiler
  compile_context
  bytecode_builder
  bytecode_module
  diagnostic

  package
  package_id
  package_manifest
  dependency
  dependency_graph
  version
  lockfile

  incremental_compile
  change_set
  dirty_module
  compile_cache
  cache_key
  cache_hit
  cache_miss

  module_loader
  link_module
  runtime_image
  image_writer
  image_loader

  bootstrap
  self_compile
  stage0
  stage1
  stage2
}

// Semantic direction:
// package gives compiled modules a distributable unit.
// package_manifest records package name, version, dependencies, and entry modules.
// dependency_graph orders packages and modules for linking.
// lockfile preserves reproducible dependency resolution.
// incremental_compile recompiles only changed or dependent modules.
// change_set identifies source differences since the previous build.
// dirty_module marks modules requiring rebuild.
// compile_cache stores reusable compiler outputs.
// cache_key identifies cached artifacts by source, options, and dependency state.
// cache_hit and cache_miss describe cache decision paths.

// Primitive flow:
// package_manifest -> dependency_graph -> lockfile
// -> change_set -> dirty_module
// -> incremental_compile
// -> compile_cache + cache_key
// -> bytecode_module -> link_module -> runtime_image

// This extends the self-hosted compiler pipeline into practical package and incremental build semantics.
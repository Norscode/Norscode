// Norscode Runtime - Omgang 336
// Streaming LLM responses and token handling

runtime z336 {
  stream
  stream_request
  stream_response
  stream_event
  event_kind
  event_message_start
  event_content_block_start
  event_content_block_delta
  event_content_block_stop
  event_message_delta
  event_message_stop
  event_ping
  event_error

  delta
  delta_type
  delta_text
  delta_input_json
  delta_thinking

  stream_consumer
  consume_stream
  on_text_delta
  on_tool_delta
  on_thinking_delta
  on_stop
  on_error

  text_accumulator
  accumulated_text
  flush_text
  text_chunk
  chunk_size

  token_stream
  token
  token_id
  token_text
  token_logprob
  top_token
  top_logprob

  sse_parser
  sse_line
  sse_field_data
  sse_field_event
  sse_field_retry
  parse_sse_line
  sse_dispatch

  backpressure
  stream_buffer
  buffer_capacity
  buffer_full
  pause_stream
  resume_stream

  partial_json
  json_stream_parser
  json_depth
  partial_object
  partial_array
  complete_json

  first_token_latency
  time_to_first_token
  tokens_per_second
  stream_duration
  stream_complete

  thinking
  thinking_block
  thinking_text
  thinking_signature
  redacted_thinking

  websocket_stream
  ws_stream_frame
  http2_stream
  grpc_stream
}

// Semantic direction:
// stream is the asynchronous sequence of events produced by an LLM as it generates.
// stream_request differs from a completion_request by setting stream=true.
// event_content_block_delta is the most frequent event, carrying a text or JSON delta.
// delta_text is a string fragment to append to the accumulated_text.
// delta_input_json is a JSON fragment for a streaming tool-call argument string.
// delta_thinking carries the model's extended reasoning text before the final answer.
// stream_consumer is the caller-side handler that processes events as they arrive.
// on_text_delta is called for each text fragment; accumulated_text grows incrementally.
// on_tool_delta assembles the partial JSON arguments for a pending tool call.
// on_stop fires when the stream ends, carrying the stop_reason and final usage.
// text_accumulator collects delta_text fragments; flush_text returns the full string.
// sse_parser reads Server-Sent Events from the HTTP response body.
// parse_sse_line extracts the field name (data, event, retry) and value from each line.
// sse_dispatch routes each parsed event to the appropriate stream_consumer callback.
// backpressure prevents the stream buffer from growing unbounded when the consumer is slow.
// pause_stream signals the HTTP client to stop reading; resume_stream unpauses.
// partial_json assembles JSON objects that arrive across multiple delta_input_json fragments.
// json_stream_parser tracks json_depth to determine when a partial_object is complete.
// time_to_first_token is the latency between sending stream_request and receiving the first delta.
// tokens_per_second measures the generation throughput during the stream.
// thinking_block contains the model's scratchpad reasoning, separated from the final output.
// thinking_signature is a cryptographic token verifying that redacted_thinking has not been tampered.
// websocket_stream and grpc_stream are alternative transport protocols for streaming.

// Primitive flow:
// stream_request -> HTTP POST with Accept: text/event-stream
// -> HTTP 200 body open -> sse_parser reads line by line
// -> parse_sse_line: "data: {...}" -> sse_dispatch -> event_kind
// event_content_block_delta:
//   delta_text -> on_text_delta -> accumulated_text += chunk
//   delta_input_json -> on_tool_delta -> partial_json assembler
// event_message_stop -> on_stop(stop_reason, usage)
// backpressure: buffer_full -> pause_stream -> consumer drains -> resume_stream
// thinking: event with delta_thinking -> thinking_accumulator
//   final: thinking_block complete -> available to caller if not redacted

// This defines streaming LLM response consumption: SSE parsing, delta assembly,
// backpressure, partial JSON accumulation, and extended thinking support.

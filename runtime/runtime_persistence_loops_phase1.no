# Runtime persistence loops phase 1

struktur ExecutionStateOrchestrationCycle
    orchestration_inputs
    orchestration_cycles
    orchestration_outputs
slutt

struktur RuntimeSemanticPersistenceLoop
    persistence_inputs
    persistence_cycles
    persistence_outputs
slutt

funksjon ny_execution_state_orchestration_cycle()
    cycle = ExecutionStateOrchestrationCycle()

    cycle.orchestration_inputs = []
    cycle.orchestration_cycles = []
    cycle.orchestration_outputs = []

    returner cycle
slutt

funksjon registrer_orchestration_input(cycle, input)
    legg_til(cycle.orchestration_inputs, input)
    returner input
slutt

funksjon registrer_orchestration_cycle(cycle, orchestration)
    legg_til(cycle.orchestration_cycles, orchestration)
    returner orchestration
slutt

funksjon registrer_orchestration_output(cycle, output)
    legg_til(cycle.orchestration_outputs, output)
    returner output
slutt

funksjon ny_runtime_semantic_persistence_loop()
    loop = RuntimeSemanticPersistenceLoop()

    loop.persistence_inputs = []
    loop.persistence_cycles = []
    loop.persistence_outputs = []

    returner loop
slutt

funksjon registrer_semantic_persistence_input(loop, input)
    legg_til(loop.persistence_inputs, input)
    returner input
slutt

funksjon registrer_semantic_persistence_cycle(loop, cycle)
    legg_til(loop.persistence_cycles, cycle)
    returner cycle
slutt

funksjon registrer_semantic_persistence_output(loop, output)
    legg_til(loop.persistence_outputs, output)
    returner output
slutt

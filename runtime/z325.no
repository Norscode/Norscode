// Norscode Runtime - Omgang 325
// Distributed state and consensus

runtime z325 {
  consensus
  consensus_node
  raft_node
  raft_role
  role_leader
  role_follower
  role_candidate

  raft_term
  current_term
  voted_for
  log_index
  commit_index

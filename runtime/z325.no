  raft_log
  log_entry
  entry_term
  entry_index
  entry_command
  append_entries
  request_vote
  vote_granted
  vote_rejected
  election_timeout
  heartbeat_timeout

  leader_election
  start_election
  request_vote_rpc
  count_votes
  quorum
  quorum_size
  majority

  log_replication
  replicate_entry
  match_index
  next_index
  follower_ack
  commit_if_majority
  apply_to_state_machine

  state_machine
  sm_command
  sm_apply
  sm_snapshot

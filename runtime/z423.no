// Norscode Runtime - Omgang 423
// Module linking and external symbol resolution

runtime z423 {
  native_module
  nm_name
  nm_path
  nm_symbols
  nm_imports
  nm_exports_n
  nm_init_fn
  nm_fini_fn

  symbol_table_n
  sym_entry_n
  sym_name_n
  sym_address
  sym_size_sym
  sym_type
  sym_binding
  sym_vis
  type_func_n
  type_data_n
  type_undef
  bind_global
  bind_local
  bind_weak

  relocation_n
  reloc_offset_n
  reloc_type_n
  reloc_symbol_n
  reloc_addend
  reloc_arm64_call26
  reloc_arm64_page21
  reloc_arm64_pageoff12
  reloc_abs64

  linker_n
  link_objects
  link_archives
  link_dylibs
  resolve_symbols
  apply_relocations
  output_binary_n

  got
  got_entry

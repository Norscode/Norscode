// Norscode Runtime - Omgang 454
// Visual debugger and profiler for games

runtime z454 {
  spill_debugger
  debugger_panel
  debugger_overlay
  debugger_aktiv

  fps_teller
  fps_historikk
  fps_diagram
  rammetid
  cpu_tid
  gpu_tid
  rammetid_budsjett
  budsjett_overskredet

  system_profil
  profil_opptak
  profil_stopp
  profil_ramme
  profil_steg
  profil_kost
  profil_topp_n
  flaskehals

  entitet_teller
  komponent_teller
  system_tid
  arketype_stats
  bue_stats

  render_debugger
  trekk_anrop
  overdraw_kart
  dybde_buffer_vis
  normal_vis
  wireframe_modus
  shader_kompleksitet

  fysikk_debugger
  kollisjon_form_vis
  kontaktpunkt_vis
  kraft_vektor_vis
  sovende_kropp_vis

  minne_profil
  heap_bruk
  gc_trykk
  allokering_rate
  pool_utnyttelse
  minne_lekk_detektor

  nettverk_debugger
  pakke_logger
  rtt_diagram
  pakketap_rate
  prediksjons_feil
  rollback_teller
  netstat_panel

  logg_konsoll
  konsoll_filter
  konsoll_søk
  logg_nivå_filter
  logg_kilde_filter
  logg_eksport
}

// Semantic direction:
// debugger_overlay draws all debug panels on top of the running game.
// fps_historikk is a ring buffer of the last N frame times for the fps_diagram sparkline.
// rammetid_budsjett is the target frame duration (e.g. 16.6 ms for 60 fps); budsjett_overskredet fires when exceeded.
// system_profil samples time per ECS system per frame; profil_topp_n lists the worst offenders.
// flaskehals identifies the system consuming the most of the frame budget.
// trekk_anrop counts GPU draw calls per frame; high counts indicate batching opportunities.
// overdraw_kart colors pixels by how many times they were written; high overdraw wastes GPU fill rate.
// wireframe_modus renders only triangle edges to reveal mesh density and hidden geometry.
// kollisjon_form_vis draws physics shapes as colored outlines over the rendered scene.
// sovende_kropp_vis dims bodies the physics engine has put to sleep for efficiency.
// minne_lekk_detektor tracks allocations that are never freed across multiple frames.
// pakke_logger records every sent/received network packet with size, type, and timestamp.
// rtt_diagram plots round-trip time per peer over time; prediksjons_feil counts rollback corrections.
// logg_konsoll is an in-game console that shows filtered structured log output in real time.

// Primitive flow:
// overlay aktiv: debugger_aktiv -> tegn fps_diagram (fps_historikk ring buffer)
//   -> tegn system_profil stolpediagram -> vis entitet_teller / trekk_anrop
// profil_opptak(N rammer): samle system_tid per system per ramme
//   -> profil_stopp -> sorter etter kost -> vis profil_topp_n
// render_debugger: overdraw_kart -> akkumuler dybde-skrivinger -> fargekart
// fysikk_debugger: per kropp: tegn kollisjon_form_vis -> kontaktpunkt_vis
// minne_lekk_detektor: wrap allokering -> hash tabell(peker -> stakkspor)
//   -> per ramme: sjekk om eldre allokeringer fortsatt lever -> rapporter
// logg_konsoll: abonner på logg_kanal -> anvend konsoll_filter -> render tekst-buffer

// This defines the visual debugger and profiler: FPS/frame-time, ECS system
// profiling, render debugger, physics visualizer, memory profiler, and network stats.

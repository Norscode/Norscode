// Norscode Runtime - Omgang 425
// Native runtime support library

runtime z425 {
  norscode_rt
  rt_init
  rt_shutdown
  rt_version
  rt_panic_handler
  rt_abort

  rt_alloc
  rt_alloc_zeroed
  rt_realloc
  rt_free_n
  rt_alloc_aligned
  allocator_stats

  rt_string
  rt_str_new
  rt_str_from_cstr
  rt_str_to_cstr
  rt_str_len
  rt_str_concat
  rt_str_slice
  rt_str_eq
  rt_str_hash
  rt_str_int_parse
  rt_str_float_parse
  rt_str_format

  rt_list
  rt_list_new
  rt_list_push
  rt_list_pop
  rt_list_get
  rt_list_set
  rt_list_len
  rt_list_slice
  rt_list_sort

  rt_map
  rt_map_new
  rt_map_set
  rt_map_get
  rt_map_del
  rt_map_has
  rt_map_keys
  rt_map_len

  rt_io
  rt_print
  rt_println
  rt_read_line
  rt_write_file
  rt_read_file
  rt_file_exists

  rt_error
  rt_error_new
  rt_error_message
  rt_error_type
  rt_throw
  rt_catch

  rt_type
  rt_type_of
  rt_type_name
  rt_cast_int
  rt_cast_float
  rt_cast_str
  rt_cast_bool

  rt_gc
  rt_gc_collect
  rt_gc_stats
  rt_gc_disable
  rt_gc_enable
  rt_root_push
  rt_root_pop
}

// Semantic direction:
// norscode_rt is the native runtime support library linked into every Norscode binary.
// rt_init sets up the GC heap, allocator, and panic handler; called before user code.
// rt_shutdown flushes output buffers, runs dtors, and releases resources.
// rt_panic_handler is called on fatal errors (assertion failure, null deref, etc.).
// rt_alloc is the primary allocator: returns an aligned block or calls rt_abort on failure.
// rt_alloc_zeroed returns memory initialized to zero.
// rt_string functions implement the Norscode string type on the native heap.
// rt_str_from_cstr converts a null-terminated C string to a Norscode string.
// rt_str_format implements the `formater` builtin: "%s %d" with positional arguments.
// rt_list_new allocates an empty list with an initial capacity.
// rt_list_sort uses an adaptive introsort; accepts an optional comparator function pointer.
// rt_map_new allocates an empty hash map using open addressing.
// rt_io functions are the native implementations of skriv, les_linje, and file operations.
// rt_error_new creates a Norscode error value with a type string and message.
// rt_throw stores the current error and initiates stack unwinding to the nearest handler.
// rt_catch retrieves the in-flight error after a landing pad is reached.
// rt_type_of returns the type tag of a native_value.
// rt_cast_int converts a value to integer; raises rt_error on invalid input.
// rt_gc_collect triggers an explicit garbage collection cycle.
// rt_root_push and rt_root_pop manage the GC root set for stack-allocated values.
// allocator_stats exposes current heap usage for diagnostics.

// Primitive flow:
// program start: rt_init() → allocator + GC + panic handler registered → user main
// skriv("hei"): rt_println(rt_str_new("hei", 3))
// legg_til(liste, val): rt_list_push(list_ptr, val)
// type mismatch: rt_throw(rt_error_new("TypeFeil", "forventet heltall"))
//   → stack unwind → rt_catch at handler → user fang-blokk
// program end: rt_shutdown() → flush stdout → free GC heap

// This defines the native runtime support library: allocator, string/list/map,
// I/O, error handling, type operations, and GC interface.

# Execution persistence phase 1

struktur EvaluatorDispatchProgression
    dispatch_inputs
    dispatch_cycles
    dispatch_outputs
slutt

struktur RuntimeExecutionPersistenceSemantics
    persistence_inputs
    persistence_states
    persistence_outputs
slutt

funksjon ny_evaluator_dispatch_progression()
    progression = EvaluatorDispatchProgression()

    progression.dispatch_inputs = []
    progression.dispatch_cycles = []
    progression.dispatch_outputs = []

    returner progression
slutt

funksjon registrer_dispatch_progression_input(progression, input)
    legg_til(progression.dispatch_inputs, input)
    returner input
slutt

funksjon registrer_dispatch_progression_cycle(progression, cycle)
    legg_til(progression.dispatch_cycles, cycle)
    returner cycle
slutt

funksjon registrer_dispatch_progression_output(progression, output)
    legg_til(progression.dispatch_outputs, output)
    returner output
slutt

funksjon ny_runtime_execution_persistence_semantics()
    persistence = RuntimeExecutionPersistenceSemantics()

    persistence.persistence_inputs = []
    persistence.persistence_states = []
    persistence.persistence_outputs = []

    returner persistence
slutt

funksjon registrer_persistence_input(persistence, input)
    legg_til(persistence.persistence_inputs, input)
    returner input
slutt

funksjon registrer_persistence_state(persistence, state)
    legg_til(persistence.persistence_states, state)
    returner state
slutt

funksjon registrer_persistence_output(persistence, output)
    legg_til(persistence.persistence_outputs, output)
    returner output
slutt

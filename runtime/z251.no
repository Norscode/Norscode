// Norscode Runtime - Omgang 251
// Practical memory management and garbage collector

runtime z251 {
  vm_state

  heap
  heap_region
  heap_segment
  heap_limit
  heap_used
  heap_free

  allocator
  alloc
  dealloc
  realloc
  bump_allocator
  slab_allocator
  large_alloc

  object
  object_header
  object_size
  object_type_tag
  forwarding_pointer

  gc
  gc_roots
  gc_cycle
  mark_phase
  sweep_phase
  compact_phase

  root_set
  root_entry
  stack_root
  global_root
  pinned_root

  mark_bit
  grey_list
  black_set
  white_set
  tri_color

  write_barrier
  read_barrier
  card_table
  dirty_card
  remembered_set

  finalize
  finalizer
  weak_ref
  weak_ref_cleared

  pressure
  gc_trigger
  allocation_rate
  live_bytes
  gc_pause
}

// Semantic direction:
// heap gives the runtime a managed address space for dynamic objects.
// heap_region divides the heap into areas with different lifetimes or sizes.
// allocator implements the policy for satisfying alloc and dealloc requests.
// bump_allocator fast-paths small, short-lived allocations in a linear region.
// slab_allocator recycles fixed-size slots to reduce fragmentation.
// object_header stores type tag, size, mark bit, and optional forwarding pointer.
// gc_roots is the set of live references held by the stack, globals, and pinned values.
// mark_phase traverses the object graph from gc_roots, painting reachable objects.
// tri_color assigns white (unseen), grey (seen, children pending), black (fully traced).
// grey_list holds objects whose references have not yet been scanned.
// sweep_phase reclaims white objects after mark_phase completes.
// compact_phase moves live objects to eliminate fragmentation.
// write_barrier intercepts pointer stores to keep the gc graph consistent.
// card_table records heap regions containing cross-generation pointers.
// remembered_set lists old-generation pointers into the young generation.
// finalizer runs user-defined cleanup when an object becomes unreachable.
// weak_ref holds a reference that does not prevent collection.
// gc_trigger initiates a gc_cycle based on allocation_rate or heap pressure.
// gc_pause measures stop-the-world or concurrent collection latency.

// Primitive flow:
// alloc -> allocator -> heap_region + object_header
// -> stack_root / global_root -> gc_roots
// -> gc_trigger -> gc_cycle
// -> mark_phase -> root_set -> grey_list -> black_set
// -> sweep_phase -> white_set -> dealloc
// -> compact_phase (optional) -> forwarding_pointer
// -> write_barrier -> card_table + remembered_set
// -> finalizer -> weak_ref_cleared

// This extends the self-hosted runtime pipeline with practical memory management
// and incremental garbage collector semantics.

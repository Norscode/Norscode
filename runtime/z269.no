// Norscode Runtime - Omgang 269
// WASM runtime execution engine

runtime z269 {
  wasm_module
  wasm_instance
  instance_memory
  instance_table
  instance_globals
  instance_funcs

  interpreter
  interp_state
  interp_frame
  interp_stack
  interp_locals
  interp_pc

  execute_module
  instantiate
  run_start
  invoke_export
  invoke_func

  value_stack
  push_value
  pop_value
  peek_value
  wasm_value
  val_i32
  val_i64
  val_f32
  val_f64
  val_ref

  dispatch_instr
  exec_const
  exec_arith
  exec_compare
  exec_local
  exec_global
  exec_memory_load
  exec_memory_store
  exec_call
  exec_call_indirect
  exec_br
  exec_br_if
  exec_br_table
  exec_if
  exec_block
  exec_loop
  exec_return
  exec_drop
  exec_select
  exec_unreachable

  trap
  trap_kind
  trap_unreachable
  trap_memory_oob
  trap_stack_overflow
  trap_div_zero
  trap_indirect_type_mismatch
  trap_null_deref
  trap_message

  fuel
  fuel_limit
  fuel_consumed
  fuel_check
  fuel_exhausted

  jit_tier
  jit_threshold
  jit_compile
  jit_execute
  jit_cache
}

// Semantic direction:
// wasm_instance is one running instantiation of a wasm_module with its own memory and globals.
// instantiate allocates instance_memory, instance_globals, and runs data_segments.
// run_start calls the function designated by the start_section, if present.
// invoke_export looks up an exported function by name and calls invoke_func.
// interp_frame holds the program counter, locals, and a reference to the function body.
// value_stack is the runtime operand stack; interp_stack is the call frame stack.
// push_value and pop_value maintain stack discipline; peek_value reads without consuming.
// wasm_value is a tagged union of val_i32, val_i64, val_f32, val_f64, or val_ref.
// dispatch_instr reads the next opcode and routes to the corresponding exec_* handler.
// exec_arith pops two values, computes the result, and pushes one value.
// exec_memory_load reads bytes from instance_memory at addr + load_offset.
// exec_call pushes an interp_frame for the callee and transfers control.
// exec_call_indirect checks the table entry's func_type before calling.
// exec_br pops the ctrl_stack and adjusts the program counter to the label target.
// exec_unreachable raises trap_unreachable immediately.
// trap signals an unrecoverable runtime error and unwinds the call stack.
// trap_memory_oob fires when a memory access falls outside instance_memory bounds.
// trap_indirect_type_mismatch fires when call_indirect finds a type mismatch.
// fuel is an optional execution budget; fuel_check decrements it each instruction.
// fuel_exhausted raises a trap when the budget reaches zero.
// jit_tier marks hot functions for compilation after jit_threshold invocations.
// jit_compile translates a hot function's bytecode to native code.
// jit_execute substitutes the compiled native function on future calls.

// Primitive flow:
// wasm_module -> instantiate -> wasm_instance
// -> run_start (optional)
// -> invoke_export -> invoke_func -> interp_frame push
// -> dispatch_instr loop:
//    -> exec_* handlers -> value_stack mutations
//    -> exec_call -> new interp_frame
//    -> exec_return -> pop interp_frame
//    -> trap -> unwind all frames + trap_message
// fuel: fuel_check per dispatch_instr iteration
// jit: invocation counter -> jit_threshold -> jit_compile -> jit_cache -> jit_execute

// This defines the WASM execution engine including interpreter dispatch,
// value stack, traps, fuel limiting, and JIT tier semantics.

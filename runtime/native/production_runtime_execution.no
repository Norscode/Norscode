# Production-grade runtime execution

# =========================
# OS loader integration
# =========================

funksjon os_loader(platform)
    returner {
        platform: platform,
        loaded_binaries: [],
        mapped_segments: []
    }
slutt

funksjon os_loader_map_segment(loader, segment)
    mapped = {
        address: segment.address,
        size: segment.size,
        flags: segment.flags,
        mapped: sann
    }

    legg_til(loader.mapped_segments, mapped)

    returner mapped
slutt

funksjon os_loader_load_binary(loader, executable)
    indeks = 0

    mens indeks < lengde(executable.layout.segments)
        os_loader_map_segment(
            loader,
            executable.layout.segments[indeks]
        )

        indeks = indeks + 1
    slutt

    legg_til(loader.loaded_binaries, executable)

    returner sann
slutt

# =========================
# Native syscall execution
# =========================

funksjon syscall_runtime()
    returner {
        table: {},
        executed: []
    }
slutt

funksjon syscall_register(runtime, number, name, handler)
    runtime.table[number] = {
        name: name,
        handler: handler
    }
slutt

funksjon syscall_exec(runtime, number, args)
    syscall_obj = runtime.table[number]

    hvis syscall_obj == null
        kast "Missing syscall"
    slutt

    result = syscall_obj.handler(args)

    legg_til(runtime.executed, {
        syscall: syscall_obj.name,
        args: args
    })

    returner result
slutt

funksjon linux_write_syscall(args)
    returner {
        written: args[2]
    }
slutt

funksjon linux_exit_syscall(args)
    returner {
        exited: sann,
        code: args[0]
    }
slutt

# =========================
# Dynamic linker
# =========================

funksjon dynamic_library(name)
    returner {
        name: name,
        exports: {}
    }
slutt

funksjon dynamic_export(lib, symbol, address)
    lib.exports[symbol] = address
slutt

funksjon dynamic_linker()
    returner {
        libraries: {},
        resolved: {}
    }
slutt

funksjon dynamic_load(linker, lib)
    linker.libraries[lib.name] = lib
slutt

funksjon dynamic_resolve(linker, lib_name, symbol)
    lib = linker.libraries[lib_name]

    hvis lib == null
        returner null
    slutt

    resolved = lib.exports[symbol]

    linker.resolved[symbol] = resolved

    returner resolved
slutt

# =========================
# Stdlib runtime
# =========================

funksjon stdlib_runtime()
    returner {
        initialized: sann,
        modules: [
            "io",
            "memory",
            "strings",
            "runtime"
        ]
    }
slutt

funksjon stdlib_initialize(runtime)
    runtime.stdlib = stdlib_runtime()
slutt

# =========================
# Production process bootstrap
# =========================

funksjon production_process(executable)
    syscall_rt = syscall_runtime()

    syscall_register(
        syscall_rt,
        1,
        "write",
        linux_write_syscall
    )

    syscall_register(
        syscall_rt,
        60,
        "exit",
        linux_exit_syscall
    )

    loader = os_loader("linux")

    os_loader_load_binary(loader, executable)

    linker = dynamic_linker()

    runtime = {
        executable: executable,
        loader: loader,
        linker: linker,
        syscalls: syscall_rt,
        memory: runtime_memory_map(),
        cpu: machine_cpu_state()
    }

    stdlib_initialize(runtime)

    returner runtime
slutt

# =========================
# Production executable boot
# =========================

funksjon production_boot(executable)
    runtime = production_process(executable)

    runtime.cpu.registers.rip = executable.entrypoint.address

    returner {
        booted: sann,
        rip: runtime.cpu.registers.rip,
        runtime: runtime
    }
slutt

funksjon execute_production_binary(format_name)
    executable = build_native_executable(format_name)

    boot = production_boot(executable)

    syscall_exec(
        boot.runtime.syscalls,
        1,
        [1, "Norscode runtime", 17]
    )

    returner {
        executable: executable,
        boot: boot,
        valid: boot.booted
    }
slutt

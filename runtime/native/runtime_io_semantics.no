// Deterministic runtime I/O semantics
// Selfhost migration phase

struktur RuntimeIOHandle
    path
    open
    mode
slutt

funksjon create_runtime_io_handle(path, mode)
    la handle = RuntimeIOHandle()
    handle.path = path
    handle.mode = mode
    handle.open = sann

    returner handle
slutt

funksjon runtime_io_write(handle, value)
    hvis handle == ingen
        returner usann
    slutt

    hvis handle.open == usann
        returner usann
    slutt

    handle.last_write = value

    returner sann
slutt

funksjon runtime_io_read(handle)
    hvis handle == ingen
        returner ingen
    slutt

    hvis handle.open == usann
        returner ingen
    slutt

    returner handle.last_write
slutt

funksjon runtime_io_close(handle)
    hvis handle == ingen
        returner usann
    slutt

    handle.open = usann

    returner sann
slutt

funksjon runtime_terminal_output(runtime, value)
    hvis runtime == ingen
        returner usann
    slutt

    runtime.last_output = value

    returner sann
slutt

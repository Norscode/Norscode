# Expression semantics phase 1

struktur ExpressionEvaluationSkeleton
    expression_inputs
    expression_operations
    expression_results
slutt

struktur NativeRuntimeMemoryModel
    memory_inputs
    memory_states
    memory_outputs
slutt

funksjon ny_expression_evaluation_skeleton()
    evaluation = ExpressionEvaluationSkeleton()

    evaluation.expression_inputs = []
    evaluation.expression_operations = []
    evaluation.expression_results = []

    returner evaluation
slutt

funksjon registrer_expression_input(evaluation, input)
    legg_til(evaluation.expression_inputs, input)
    returner input
slutt

funksjon registrer_expression_operation(evaluation, operation)
    legg_til(evaluation.expression_operations, operation)
    returner operation
slutt

funksjon registrer_expression_result(evaluation, result)
    legg_til(evaluation.expression_results, result)
    returner result
slutt

funksjon ny_native_runtime_memory_model()
    memory = NativeRuntimeMemoryModel()

    memory.memory_inputs = []
    memory.memory_states = []
    memory.memory_outputs = []

    returner memory
slutt

funksjon registrer_memory_input(memory, input)
    legg_til(memory.memory_inputs, input)
    returner input
slutt

funksjon registrer_memory_state(memory, state)
    legg_til(memory.memory_states, state)
    returner state
slutt

funksjon registrer_memory_output(memory, output)
    legg_til(memory.memory_outputs, output)
    returner output
slutt

// Norscode Runtime - Omgang 193
// Primitive resolve runtime

runtime z193 {
  state
  context
  session
  scope
  frame
  stack

  push
  pop
  call
  return

  value
  symbol
  bind
  lookup
  resolve

  checkpoint
  store
  load

  validate
  guard
  assert
  constraint
  policy
  capability
  permission
  role

  commit
  rollback

  input
  operation
  evaluate
  iterate
  continue
  repeat
  restart
  resume

  compare
  branch
  select
  merge
  assign
  rule

  updated
  output
}

// Semantic direction:
// resolve gives lookup results usable runtime meaning.
// symbol + bind + lookup + resolve forms the first name-to-value path.

// Primitive flow:
// symbol + bind + lookup + resolve
// -> value
// -> updated + output

// This is a smaller computation step after binding/value semantics.
  assert_status
  assert_body
  assert_header
  assert_json_body
  record_request
  replayed_request

  mock_handler
  mock_route
  mock_response
  mock_delay
  mock_error_resp
  mock_sequence
  call_count
  assert_called
  assert_called_with
  assert_not_called

  net_simulation

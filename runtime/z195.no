// Norscode Runtime - Omgang 195
// Primitive compute runtime

runtime z195 {
  state
  context
  session
  scope
  frame
  stack

  push
  pop
  call
  return

  value
  symbol
  bind
  lookup
  resolve
  expression
  compute

  checkpoint
  store
  load

  validate
  guard
  assert
  constraint
  policy
  capability
  permission
  role

  commit
  rollback

  input
  operation
  evaluate
  iterate
  continue
  repeat
  restart
  resume

  compare
  branch
  select
  merge
  assign
  rule

  updated
  output
}

// Semantic direction:
// compute gives expression a primitive result-producing transition.
// value + resolve + expression + compute forms the first computation path.

// Primitive flow:
// lookup + resolve + expression + compute
// -> value
// -> updated + output

// This marks the first primitive computation step after expression semantics.
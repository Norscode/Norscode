// Norscode Runtime - Omgang 215
// Primitive meta runtime

runtime z215 {
  compiler
  bytecode
  optimizer
  jit
  vm

  ffi
  native
  syscall
  device
  driver

  kernel
  service
  resource
  scheduler_core
  runtime_os

  boot
  loader
  init
  image
  self_host

  meta
  reflect
  introspect
  rewrite
  evolve
}

// Semantic direction:
// meta gives runtime a layer for reasoning about its own structures.
// reflect allows runtime structures to be exposed as inspectable values.
// introspect lets the runtime examine active state, code, and execution form.
// rewrite describes controlled transformation of runtime forms.
// evolve describes versioned runtime progression across self-hosted cycles.

// Primitive flow:
// self_host + image + runtime_os
// -> meta + reflect + introspect
// -> rewrite + evolve
// -> updated + output

// This marks the transition from primitive self-hosted runtime semantics
// into primitive meta-runtime semantics.
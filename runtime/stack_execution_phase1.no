# Stack execution phase 1

struktur StackFrameExecutionModel
    frame_inputs
    frame_states
    frame_outputs
slutt

struktur InstructionEvaluationSemantics
    instruction_inputs
    instruction_operations
    instruction_results
slutt

funksjon ny_stack_frame_execution_model()
    frame = StackFrameExecutionModel()

    frame.frame_inputs = []
    frame.frame_states = []
    frame.frame_outputs = []

    returner frame
slutt

funksjon registrer_frame_input(frame, input)
    legg_til(frame.frame_inputs, input)
    returner input
slutt

funksjon registrer_frame_state(frame, state)
    legg_til(frame.frame_states, state)
    returner state
slutt

funksjon registrer_frame_output(frame, output)
    legg_til(frame.frame_outputs, output)
    returner output
slutt

funksjon ny_instruction_evaluation_semantics()
    semantics = InstructionEvaluationSemantics()

    semantics.instruction_inputs = []
    semantics.instruction_operations = []
    semantics.instruction_results = []

    returner semantics
slutt

funksjon registrer_instruction_input(semantics, input)
    legg_til(semantics.instruction_inputs, input)
    returner input
slutt

funksjon registrer_instruction_operation(semantics, operation)
    legg_til(semantics.instruction_operations, operation)
    returner operation
slutt

funksjon registrer_instruction_result(semantics, result)
    legg_til(semantics.instruction_results, result)
    returner result
slutt

# Runtime semantic cycles phase 2

struktur RuntimeSemanticOrchestrationCycle
    orchestration_inputs
    orchestration_cycles
    orchestration_outputs
slutt

struktur PersistentRuntimeExecutionEngine
    execution_inputs
    execution_states
    execution_outputs
slutt

funksjon ny_runtime_semantic_orchestration_cycle()
    cycle = RuntimeSemanticOrchestrationCycle()

    cycle.orchestration_inputs = []
    cycle.orchestration_cycles = []
    cycle.orchestration_outputs = []

    returner cycle
slutt

funksjon registrer_runtime_semantic_cycle_input(cycle, input)
    legg_til(cycle.orchestration_inputs, input)
    returner input
slutt

funksjon registrer_runtime_semantic_cycle(cycle, orchestration)
    legg_til(cycle.orchestration_cycles, orchestration)
    returner orchestration
slutt

funksjon registrer_runtime_semantic_cycle_output(cycle, output)
    legg_til(cycle.orchestration_outputs, output)
    returner output
slutt

funksjon ny_persistent_runtime_execution_engine()
    engine = PersistentRuntimeExecutionEngine()

    engine.execution_inputs = []
    engine.execution_states = []
    engine.execution_outputs = []

    returner engine
slutt

funksjon registrer_persistent_execution_engine_input(engine, input)
    legg_til(engine.execution_inputs, input)
    returner input
slutt

funksjon registrer_persistent_execution_engine_state(engine, state)
    legg_til(engine.execution_states, state)
    returner state
slutt

funksjon registrer_persistent_execution_engine_output(engine, output)
    legg_til(engine.execution_outputs, output)
    returner output
slutt

# Runtime semantic persistence continuation phase 2

struktur RuntimeSemanticPersistenceContinuation
    persistence_inputs
    persistence_states
    persistence_outputs
slutt

struktur PersistentRuntimeOrchestrationEngine
    orchestration_inputs
    orchestration_cycles
    orchestration_outputs
slutt

funksjon ny_runtime_semantic_persistence_continuation()
    continuation = RuntimeSemanticPersistenceContinuation()

    continuation.persistence_inputs = []
    continuation.persistence_states = []
    continuation.persistence_outputs = []

    returner continuation
slutt

funksjon registrer_semantic_persistence_input(continuation, input)
    legg_til(continuation.persistence_inputs, input)
    returner input
slutt

funksjon registrer_semantic_persistence_state(continuation, state)
    legg_til(continuation.persistence_states, state)
    returner state
slutt

funksjon registrer_semantic_persistence_output(continuation, output)
    legg_til(continuation.persistence_outputs, output)
    returner output
slutt

funksjon ny_persistent_runtime_orchestration_engine()
    engine = PersistentRuntimeOrchestrationEngine()

    engine.orchestration_inputs = []
    engine.orchestration_cycles = []
    engine.orchestration_outputs = []

    returner engine
slutt

funksjon registrer_runtime_orchestration_input(engine, input)
    legg_til(engine.orchestration_inputs, input)
    returner input
slutt

funksjon registrer_runtime_orchestration_cycle(engine, cycle)
    legg_til(engine.orchestration_cycles, cycle)
    returner cycle
slutt

funksjon registrer_runtime_orchestration_output(engine, output)
    legg_til(engine.orchestration_outputs, output)
    returner output
slutt

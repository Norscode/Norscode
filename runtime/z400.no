  builtin_skriv
  builtin_skriv_linje
  builtin_les_linje
  builtin_feil
  builtin_type_of
  builtin_lengde
  builtin_til_tekst
  builtin_til_heltall
  builtin_til_desimaltall
  builtin_til_liste

  list_builtins
  builtin_legg_til
  builtin_fjern
  builtin_fjern_ved
  builtin_sett_inn
  builtin_sorter
  builtin_reverser
  builtin_inneholder
  builtin_finn_indeks
  builtin_skjær
  builtin_kopiér_liste

  map_builtins
  builtin_nøkler
  builtin_verdier
  builtin_elementer
  builtin_har_nøkkel
  builtin_slett_nøkkel
  builtin_kopiér_map

  string_builtins
  builtin_del_tekst
  builtin_erstatt
  builtin_trim
  builtin_til_store
  builtin_til_små
  builtin_starter_med
  builtin_slutter_med
  builtin_inneholder_tekst

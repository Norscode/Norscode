// Norscode Runtime - Omgang 228
// Practical VM ADD execution

runtime z228 {
  token
  parser
  ast
  instruction
  bytecode

  opcode
  operand
  instruction_pointer
  fetch
  dispatch
  execute
  halt

  constant
  constant_table
  load_const

  stack_value
  push_stack
  pop_stack

  value
  integer
  boolean
  string

  add_opcode
  pop_left
  pop_right
  integer_add
  push_result

  environment
  bind
  lookup
  resolve

  evaluate
  compute
  add
  equal

  program
  run
  result
  return_result
}

// Semantic direction:
// add_opcode gives ADD a concrete VM dispatch target.
// pop_right and pop_left remove operands from the VM stack in execution order.
// integer_add combines two integer values into one integer result.
// push_result writes the computed value back to the stack.

// Primitive flow:
// LOAD_CONST -> push_stack
// LOAD_CONST -> push_stack
// ADD -> pop_right + pop_left -> integer_add -> push_result
// HALT -> return_result

// This is the first practical arithmetic execution path for a minimal stack VM.
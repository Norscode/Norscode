// Norscode Runtime - Omgang 413
// Structured concurrency and task groups

runtime z413 {
  task_group
  group_id
  group_scope
  group_spawn
  group_cancel_all
  group_join_all_g
  group_result
  group_error_g

  structured_concurrency
  scope_lifetime
  scope_enter
  scope_exit
  scope_cancel
  child_task
  parent_task
  task_tree

  cancellation
  cancel_token
  cancel_source
  is_cancelled
  check_cancel
  cancel_propagate
  cancel_scope
  cancel_on_drop

  nursery
  nursery_open
  nursery_spawn
  nursery_close
  nursery_exception
  nursery_cancel_on_err

  error_group
  error_collect
  error_list
  first_error
  all_errors

  supervision_async
  restart_on_panic
  max_restarts_a
  restart_delay_a

  task_local
  task_local_key
  task_local_value
  task_local_get
  task_local_set
  inherit_task_locals

  deadline
  deadline_at
  deadline_after
  deadline_exceeded_a
  extend_deadline
  with_deadline_a

  flow_control_a
  token_bucket_a
  rate_limit_a
  throttle_a
  debounce_a
}

// Semantic direction:
// task_group is a collection of tasks that share a lifetime and cancellation boundary.
// group_spawn adds a new child_task; group_join_all_g waits for all children to finish.
// group_cancel_all signals every child_task to stop; tasks check is_cancelled at await points.
// structured_concurrency ensures child tasks never outlive their parent scope.
// scope_exit blocks until all tasks spawned in the scope finish (or are cancelled).
// cancel_token is distributed to child tasks; cancel_source cancels all holders at once.
// cancel_propagate sends the cancellation signal through the task_tree to all descendants.
// cancel_on_drop cancels the task group when the scope variable is dropped (RAII cleanup).
// nursery (from Trio) is a scope-based task group; nursery_close waits for all tasks.
// nursery_cancel_on_err cancels all sibling tasks if one raises an exception.
// error_collect gathers all errors from a group; error_list holds all error_group results.
// first_error returns as soon as the first child fails; all_errors waits for all to finish.
// task_local provides per-task values that follow the task through await points.
// inherit_task_locals copies the parent's task_local values to a spawned child.
// deadline_at sets an absolute cancellation deadline on the current scope.
// deadline_exceeded_a raises when the task runs past its deadline.
// extend_deadline can push the deadline further but not before the existing one.
// throttle_a limits the rate of spawning new tasks from a loop.

// Primitive flow:
// task_group scope: group_scope { group_spawn(task1); group_spawn(task2) }
//   -> both tasks run concurrently
//   -> scope_exit: wait for all children
//   -> one fails: group_cancel_all -> others get cancel signal -> scope_exit with first_error
// nursery pattern: nursery_open -> nursery_spawn(tasks) -> nursery_close (waits)
//   any task raises -> nursery_cancel_on_err -> all sibling tasks cancelled
// deadline: with_deadline_a(500ms, async_block) -> if not done: deadline_exceeded_a raised

// This defines structured concurrency: task groups, cancellation propagation,
// nurseries, error collection, task-local values, and deadlines.

// Norscode Runtime - Omgang 459
// Norscode Playground: browser-based REPL and sandbox

runtime z459 {
  playground
  playground_konfig
  playground_start
  playground_stopp
  playground_tilbakestill
  playground_url

  repl_økt
  økt_id
  økt_opprett
  økt_koble
  økt_lukk
  økt_tidsbegrensning
  økt_klonet

  repl_motor
  repl_evaluer
  repl_resultat
  repl_feil
  repl_sideeffekt
  repl_utskrift
  repl_historikk
  repl_tilstand

  kode_celle
  celle_id
  celle_kilde
  celle_utdata
  celle_status
  status_venter
  status_kjører
  status_ferdig
  status_feil
  celle_kjør
  celle_avbryt
  celle_slett
  celle_flytt

  notatbok
  notatbok_id
  notatbok_tittel
  notatbok_celler
  notatbok_lagre
  notatbok_last
  notatbok_eksporter
  eksport_format_no

// Norscode Runtime - Omgang 401
// Garbage collector for VM heap

runtime z401 {
  gc
  gc_heap
  gc_alloc
  gc_collect
  gc_threshold
  gc_trigger
  gc_pause_ms
  gc_bytes_allocated
  gc_bytes_live

  gc_object
  obj_header
  obj_type_tag
  obj_size_gc
  obj_mark_bit
  obj_next
  obj_fwd_ptr

  mark_phase_gc
  gc_roots
  root_stack
  root_globals
  root_upvalues
  mark_queue
  mark_object
  mark_value
  mark_list
  mark_map
  mark_struct
  mark_closure_gc
  mark_upvalue_gc
  mark_gray
  drain_gray_queue

  sweep_phase_gc
  sweep_heap
  free_list
  free_block
  coalesce_free
  reclaim_object

  compact_gc
  forwarding_address
  update_references
  compact_heap

  incremental_gc
  gc_slice
  slice_budget
  gc_step
  gc_resume
  gc_interrupt

  generational_gc
  young_gen
  old_gen
  nursery
  nursery_size
  minor_collect
  major_collect
  promote_object
  remembered_set_gc
  write_barrier_gc

  gc_stats
  gc_run_count
  gc_total_pause_ms
  gc_max_pause_ms
  gc_live_objects
  gc_collected_objects
}

// Semantic direction:
// gc_heap is the managed memory region where all Norscode objects are allocated.
// gc_alloc requests a block of gc_object-sized memory; it triggers gc_collect if gc_threshold is exceeded.
// gc_threshold is the byte count of allocated memory that triggers an automatic collection.
// gc_object has an obj_header with type tag, size, mark bit, and a next pointer for the free list.
// mark_phase_gc visits all gc_roots (stack, globals, open upvalues) and transitively marks reachable objects.
// gc_roots is the set of live references that are not managed heap objects: stack slots, globals, open upvalues.
// mark_gray adds an object to mark_queue for later processing; drain_gray_queue processes the queue.
// Tri-color marking: white (unmarked) → gray (queued) → black (fully scanned).
// sweep_phase_gc scans the heap and reclaims white (unreachable) objects into free_list.
// coalesce_free merges adjacent free_blocks to reduce fragmentation.
// compact_gc moves live objects together and updates all references to their new addresses.
// forwarding_address is written into a relocated object's header so references can be patched.
// incremental_gc runs in gc_slices to bound gc_pause_ms by spreading work across mutator steps.
// gc_slice processes at most slice_budget marks or sweeps before returning control to the program.
// generational_gc splits the heap into nursery (short-lived objects) and old_gen (survivors).
// minor_collect collects only the nursery; it is fast because most objects die young.
// promote_object moves an object that survived minor_collect to old_gen.
// remembered_set_gc tracks old_gen → nursery pointers so minor_collect finds all roots.
// write_barrier_gc intercepts pointer stores into old_gen objects and adds them to remembered_set_gc.
// gc_stats tracks total pause time and live object count for observability.

// Primitive flow:
// alloc: gc_bytes_allocated += size -> if > gc_threshold: gc_collect -> return new block
// mark: push all gc_roots to mark_queue
//   drain_gray_queue: pop obj -> mark all referenced values -> push gray referents
// sweep: walk heap -> obj.mark_bit == 0 (white) -> reclaim_object -> free_list
// incremental: gc_step(mutator) -> perform gc_slice(mark or sweep) -> return
//   -> next gc_step continues where it left off
// minor GC: alloc from nursery -> nursery full -> minor_collect
//   mark roots + remembered_set -> sweep nursery -> promote survivors to old_gen
// write barrier: old_gen_obj.field = nursery_ref -> remembered_set_gc.add(old_gen_obj)

// This defines the VM garbage collector: tri-color mark-sweep, compaction,
// incremental slices, and generational collection with write barriers.

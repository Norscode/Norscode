// Norscode Runtime - Omgang 205
// Primitive concurrency runtime

runtime z205 {
  state
  context
  session
  scope
  frame
  stack

  push
  pop
  call
  return

  value
  type
  integer
  string
  list
  object
  map

  memory
  heap
  reference
  allocate
  release
  ownership
  retain
  borrow
  move
  garbage_collect

  thread
  task
  scheduler
  async
  channel

  symbol
  bind
  lookup
  resolve
  expression
  compute
  operator
  add
  subtract
  multiply
  divide
  equal
  greater
  less
  boolean
  condition
  if
  else
  loop

  function
  parameter
  argument
  local
  return_value

  module
  import
  export
  namespace
  library

  checkpoint
  store
  load

  validate
  guard
  assert
  constraint
  policy
  capability
  permission
  role

  commit
  rollback

  input
  operation
  evaluate
  iterate
  continue
  repeat
  restart
  resume

  compare
  branch
  select
  merge
  assign
  rule

  updated
  output
}

// Semantic direction:
// thread gives runtime a parallel execution carrier.
// task gives scheduler a unit of work.
// scheduler orders tasks across runtime progression.
// async allows execution to suspend and continue later.
// channel gives tasks a primitive communication path.

// Primitive flow:
// task + scheduler + thread
// -> async + continue + resume
// -> channel + value
// -> updated + output

// This marks the transition from memory-safe runtime
// into primitive concurrency runtime semantics.
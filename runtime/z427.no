// Norscode Runtime - Omgang 427
// Bootstrap: compiling selfhost/vm.no to a native macOS binary

runtime z427 {
  selfhost_native
  sn_source
  sn_output
  sn_target
  sn_stage

  stage_a
  stage_b
  stage_c
  stage_a_result
  stage_b_result
  stage_c_result

  sn_parse
  sn_typecheck_n
  sn_lower
  sn_emit_asm
  sn_assemble
  sn_link

  vm_no_path
  vm_no_ast
  vm_no_ir
  vm_no_asm
  vm_no_object
  vm_no_binary

  bootstrap_verify_n
  verify_parse
  verify_compile
  verify_run
  verify_output
  verify_determinism_n
  hash_binary_n

  nc_native_binary
  binary_path
  binary_size_n
  binary_runs
  binary_exit_code_n
  binary_selfcheck

  replace_python_wrapper
  write_native_binary
  make_executable
  update_dist
  verify_dist

  python_free_check
  check_no_python_in_path
  check_nc_runs_native
  check_selfhost_gate
  check_full_test_suite
  check_parity_gate

  migration_complete
  python_can_be_removed
  archive_python_files
  final_state
}

// Semantic direction:
// selfhost_native is the process of compiling selfhost/vm.no to a macOS ARM64 binary.
// stage_a: Python bootstrap compiles selfhost/vm.no → vm.ncb (NCB bytecode).
// stage_b: Python bootstrap runs vm.ncb via selfhost VM → vm2.ncb (self-compiled bytecode).
// stage_c: native_pipeline compiles selfhost/vm.no → nc_native_binary (no Python needed).
// sn_parse uses selfhost_parser.py to parse the untyped Norscode syntax of vm.no.
// sn_typecheck_n infers and checks types for all functions in vm.no.
// sn_lower translates vm.no's typed AST to SSA IR, inserting rt_* calls for builtins.
// sn_emit_asm generates AArch64 assembly for all vm.no functions including kall_innebygd.
// sn_assemble invokes clang to produce a Mach-O object file.
// sn_link links vm.no.o + norscode_rt.a → nc_native_binary.
// bootstrap_verify_n confirms the binary: it parses a .no file and produces correct NCB output.
// verify_determinism_n runs nc_native_binary twice and hashes both outputs; they must match.
// replace_python_wrapper overwrites dist/norcode-bootstrap-compile with nc_native_binary.
// update_dist copies the new native binary and updates the version metadata.
// python_free_check runs the full test suite using only the native binary path.
// check_no_python_in_path verifies no Python is in the PATH during the test run.
// check_selfhost_gate runs selfhost-bootstrap-gate with the native binary; all steps must pass.
// check_parity_gate confirms selfhost parity (104/104 cases) via the native binary.
// python_can_be_removed is the final milestone: all checks pass with no Python in the path.
// archive_python_files moves compiler/ and norcode/ to an archive branch rather than deleting.

// Primitive flow:
// Stage A: python3 main.py selfhost-chain-run selfhost/vm.no → vm.ncb (verify OK)
// Stage B: python3 → selfhost/vm.no (as NCB) → selfhost/vm.no → vm2.ncb (verify matches)
// Stage C: nc_build_native selfhost/vm.no → nc_native_binary
//   assemble all vm.no functions → link norscode_rt → binary
//   bootstrap_verify: nc_native_binary selfhost/tests/vm_tests.no → expected output?
//   verify_determinism: hash(run1 output) == hash(run2 output)
// replace_python_wrapper: cp nc_native_binary dist/norcode-bootstrap-compile
//   make_executable(dist/norcode-bootstrap-compile)
// python_free_check: export PATH without python3 → run full test suite
//   check_selfhost_gate → all 5 steps OK → python_can_be_removed = sann
// archive: git mv compiler/ norcode/ archived/ → commit "Python archived"

// This defines the bootstrap completion path: compiling selfhost/vm.no natively,
// replacing the Python wrapper, and verifying Python-free operation.

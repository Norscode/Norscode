# Native syscall runtime phase

struktur SyscallDispatcher
    dispatched_syscalls
    syscall_table
    syscall_results
slutt

struktur SyscallABI
    argument_registers
    return_register
    syscall_register
slutt

struktur KernelBridge
    kernel_calls
    runtime_responses
    bridge_state
slutt

struktur FileDescriptorRuntime
    open_descriptors
    descriptor_table
    closed_descriptors
slutt

struktur ProcessSyscallRuntime
    spawned_processes
    exited_processes
    active_pids
slutt

struktur MemorySyscallRuntime
    mmap_calls
    munmap_calls
    protected_regions
slutt

struktur ThreadSyscallRuntime
    active_threads
    thread_events
    scheduler_state
slutt

struktur SignalRuntime
    registered_signals
    handled_signals
    pending_signals
slutt

struktur SyscallExecutionContext
    current_syscall
    syscall_arguments
    execution_result
slutt

struktur NativeRuntimeKernelState
    runtime_mode
    kernel_context
    active_syscalls
slutt

funksjon ny_syscall_dispatcher()
    dispatcher = SyscallDispatcher()

    dispatcher.dispatched_syscalls = []
    dispatcher.syscall_table = {
        "read": 0,
        "write": 1,
        "open": 2,
        "close": 3,
        "mmap": 9,
        "munmap": 11,
        "clone": 56,
        "fork": 57,
        "execve": 59,
        "exit": 60
    }

    dispatcher.syscall_results = []

    returner dispatcher
slutt

funksjon dispatch_syscall(dispatcher, navn, arguments)
    hvis dispatcher == null
        kast "Syscall dispatcher mangler"
    slutt

    hvis ikke finnes(dispatcher.syscall_table, navn)
        kast "Ukjent syscall"
    slutt

    syscall = {
        name: navn,
        number: dispatcher.syscall_table[navn],
        arguments: arguments
    }

    legg_til(
        dispatcher.dispatched_syscalls,
        syscall
    )

    resultat = 0

    legg_til(
        dispatcher.syscall_results,
        resultat
    )

    returner resultat
slutt

funksjon ny_syscall_abi()
    abi = SyscallABI()

    abi.argument_registers = [
        "RDI",
        "RSI",
        "RDX",
        "R10",
        "R8",
        "R9"
    ]

    abi.return_register = "RAX"
    abi.syscall_register = "RAX"

    returner abi
slutt

funksjon marshal_syscall_arguments(abi, arguments)
    hvis abi == null
        kast "Syscall ABI mangler"
    slutt

    marshaled = {}

    indeks = 0

    for hver argument i arguments
        hvis indeks < lengde(abi.argument_registers)
            register = abi.argument_registers[indeks]

            marshaled[register] = argument
        slutt

        indeks = indeks + 1
    slutt

    returner marshaled
slutt

funksjon ny_kernel_bridge()
    bridge = KernelBridge()

    bridge.kernel_calls = []
    bridge.runtime_responses = []
    bridge.bridge_state = "ready"

    returner bridge
slutt

funksjon kernel_runtime_call(bridge, syscall)
    hvis bridge == null
        kast "Kernel bridge mangler"
    slutt

    legg_til(
        bridge.kernel_calls,
        syscall
    )

    respons = {
        syscall: syscall,
        result: 0
    }

    legg_til(
        bridge.runtime_responses,
        respons
    )

    returner respons
slutt

funksjon ny_file_descriptor_runtime()
    runtime = FileDescriptorRuntime()

    runtime.open_descriptors = []
    runtime.descriptor_table = {}
    runtime.closed_descriptors = []

    returner runtime
slutt

funksjon runtime_open_fd(runtime, path)
    hvis runtime == null
        kast "File descriptor runtime mangler"
    slutt

    fd = (
        3 +
        lengde(runtime.open_descriptors)
    )

    legg_til(
        runtime.open_descriptors,
        fd
    )

    runtime.descriptor_table[fd] = path

    returner fd
slutt

funksjon runtime_close_fd(runtime, fd)
    hvis runtime == null
        kast "File descriptor runtime mangler"
    slutt

    legg_til(
        runtime.closed_descriptors,
        fd
    )

    returner sann
slutt

funksjon ny_process_syscall_runtime()
    runtime = ProcessSyscallRuntime()

    runtime.spawned_processes = []
    runtime.exited_processes = []
    runtime.active_pids = []

    returner runtime
slutt

funksjon runtime_fork_process(runtime)
    hvis runtime == null
        kast "Process syscall runtime mangler"
    slutt

    pid = (
        2000 +
        lengde(runtime.spawned_processes)
    )

    legg_til(
        runtime.spawned_processes,
        pid
    )

    legg_til(
        runtime.active_pids,
        pid
    )

    returner pid
slutt

funksjon runtime_exit_process(runtime, pid)
    hvis runtime == null
        kast "Process syscall runtime mangler"
    slutt

    legg_til(
        runtime.exited_processes,
        pid
    )

    returner sann
slutt

funksjon ny_memory_syscall_runtime()
    runtime = MemorySyscallRuntime()

    runtime.mmap_calls = []
    runtime.munmap_calls = []
    runtime.protected_regions = []

    returner runtime
slutt

funksjon runtime_mmap(runtime, size)
    hvis runtime == null
        kast "Memory syscall runtime mangler"
    slutt

    region = {
        address: 0x500000,
        size: size
    }

    legg_til(
        runtime.mmap_calls,
        region
    )

    returner region
slutt

funksjon runtime_mprotect(runtime, address)
    hvis runtime == null
        kast "Memory syscall runtime mangler"
    slutt

    legg_til(
        runtime.protected_regions,
        address
    )

    returner sann
slutt

funksjon runtime_munmap(runtime, address)
    hvis runtime == null
        kast "Memory syscall runtime mangler"
    slutt

    legg_til(
        runtime.munmap_calls,
        address
    )

    returner sann
slutt

funksjon ny_thread_syscall_runtime()
    runtime = ThreadSyscallRuntime()

    runtime.active_threads = []
    runtime.thread_events = []
    runtime.scheduler_state = "idle"

    returner runtime
slutt

funksjon runtime_spawn_thread(runtime, entrypoint)
    hvis runtime == null
        kast "Thread syscall runtime mangler"
    slutt

    thread = {
        id: lengde(runtime.active_threads),
        entrypoint: entrypoint
    }

    legg_til(
        runtime.active_threads,
        thread
    )

    legg_til(
        runtime.thread_events,
        "spawn"
    )

    runtime.scheduler_state = "running"

    returner thread
slutt

funksjon ny_signal_runtime()
    runtime = SignalRuntime()

    runtime.registered_signals = []
    runtime.handled_signals = []
    runtime.pending_signals = []

    returner runtime
slutt

funksjon register_signal(runtime, signal)
    hvis runtime == null
        kast "Signal runtime mangler"
    slutt

    legg_til(
        runtime.registered_signals,
        signal
    )

    returner sann
slutt

funksjon handle_signal(runtime, signal)
    hvis runtime == null
        kast "Signal runtime mangler"
    slutt

    legg_til(
        runtime.handled_signals,
        signal
    )

    returner signal
slutt

funksjon ny_syscall_execution_context()
    context = SyscallExecutionContext()

    context.current_syscall = null
    context.syscall_arguments = []
    context.execution_result = 0

    returner context
slutt

funksjon execute_syscall_context(context, syscall, arguments)
    hvis context == null
        kast "Syscall execution context mangler"
    slutt

    context.current_syscall = syscall
    context.syscall_arguments = arguments
    context.execution_result = 0

    returner context.execution_result
slutt

funksjon ny_native_runtime_kernel_state()
    state = NativeRuntimeKernelState()

    state.runtime_mode = "kernel_bridge"
    state.kernel_context = "native"
    state.active_syscalls = []

    returner state
slutt

funksjon runtime_kernel_transition(state, syscall)
    hvis state == null
        kast "Native runtime kernel state mangler"
    slutt

    legg_til(
        state.active_syscalls,
        syscall
    )

    returner syscall
slutt

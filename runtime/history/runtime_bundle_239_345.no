// Semantic direction:
// stdlib_doc_builder walks stdlib_source_dir and generates documentation pages for each module.
// doc_extractor reads triple-slash comments (///) immediately before declarations.
// extract_module finds the module-level doc comment at the top of each .no file.
// extract_function reads the doc comment block before each funksjon declaration.
// doc_summary is the first sentence of a doc comment, shown in index listings.
// doc_description is the full multi-paragraph body after the summary.
// doc_param_tag is a @param line: "@param name Tekst som beskriver parameteret."
// doc_return_tag documents what the function returns.
// doc_throws_tag names error types the function may raise and why.
// doc_example_tag is a fenced code block within the doc comment, rendered as a runnable snippet.
// doc_since_tag records which version introduced the symbol.
// doc_deprecated_tag marks a symbol as superseded and suggests an alternative.
// doc_see_tag creates a cross_ref link to another documented symbol.
// module_doc is the rendered page for one stdlib module (e.g. std.tekst, std.liste).
// module_exports is the sorted list of public symbols defined in the module.
// func_signature renders the full type signature with linked type names.
// func_source_link links to the line of source code on GitHub.
// struct_fields lists each field with its type and description.
// struct_methods groups methods defined on the struct with their func_doc entries.
// stdlib_index is a flat alphabetical index of every documented symbol.
// index_by_module organizes symbols under their owning module heading.
// index_search_entry feeds the search engine (z308) with symbol names and summaries.
// module_nav is the sidebar navigation tree for the stdlib section.

// Primitive flow:
// stdlib_doc_builder: for each .no file in stdlib_source_dir:
//   -> parse AST -> extract_module -> extract_function / struct / union / constant
//   -> doc_extractor: read /// lines above declaration -> doc_comment parsing
//   -> doc_summary + doc_description + doc_param_tag + doc_return_tag + doc_example_tag
//   -> func_doc / struct_doc / module_doc assembled
//   -> template_render -> HTML page written to /stdlib/ section
// stdlib_index: collect all symbols -> index_by_module + index_by_name
// index_search_entry: name + summary + module -> search index
// doc_example_tag: snippet_runnable=true -> playground integration (z306)

// This defines stdlib documentation extraction from source doc comments,
// page rendering, and cross-referenced symbol index generation.

// ---- from runtime/z306.no ----
// Norscode Runtime - Omgang 306
// Interactive playground and in-browser WASM execution

runtime z306 {
  playground
  playground_url

// Semantic direction:
// aot_compiler transforms bytecode_module into native machine code ahead of execution.
// aot_session holds context for one compilation: target, options, and diagnostics.
// aot_target combines target_arch, target_os, and target_abi into a codegen spec.
// ir_function represents one function in the compiler intermediate representation.
// ir_block is a basic block: a linear sequence of ir_instructions.
// lower_ir translates bytecode_module into an explicit ir ready for codegen.
// ir_to_machine selects machine instructions for each ir_instruction.
// register_alloc assigns virtual_registers to physical_registers or spill slots.
// spill moves a value to the stack when registers are exhausted.
// instruction_emit writes selected machine instructions into code_buffer.
// code_section holds executable bytes; data_section holds static data.
// reloc_table records patches needed after final symbol addresses are known.
// optimize_ir applies constant_fold, dead_code_elim, and loop_invariant passes.
// inline_heuristic decides which call sites are profitable to inline.
// object_file bundles code, data, and relocation metadata for linking.
// elf_writer, macho_writer, and coff_writer emit platform-specific object formats.
// link_pass merges object files and resolves cross-module references.
// entry_point identifies the function address where execution begins.
// emit_binary produces a standalone executable or shared library artifact.
// sign_binary attaches a cryptographic signature for distribution integrity.

// Primitive flow:
// bytecode_module -> aot_compiler + aot_target
// -> lower_ir -> ir_function + ir_block
// -> optimize_ir
// -> instruction_select -> machine_function
// -> register_alloc -> physical_register or spill
// -> instruction_emit -> code_buffer
// -> object_file + reloc_table
// -> link_pass -> entry_point
// -> emit_binary -> binary_artifact

// This extends the self-hosted runtime pipeline with practical AOT compilation
// and native binary generation semantics.

// ---- from runtime/z253.no ----
// Norscode Runtime - Omgang 253
// Type system primitives and type representation

runtime z253 {
  type_repr
  type_id
  type_kind

  primitive_type
  type_int
  type_float
  type_bool
  type_text
  type_unit
  type_never

  compound_type
  type_list
  type_map
  type_tuple
  type_struct
  type_union
  type_function
  type_optional

  type_param
  type_var
  type_constraint
  type_bound

  type_env
  type_scope
  type_binding
  type_entry

  type_registry
  type_intern
  type_dedup
  type_canon

  type_eq
  type_compat
  type_coerce
  type_widen
  type_narrow

  annotation
  type_annotation
  inferred_type
  declared_type
}

// Semantic direction:
// type_repr gives every runtime and compile-time value a canonical type description.
// type_id uniquely identifies one type within the type_registry.
// type_kind classifies types: primitive, compound, function, generic, or union.
// primitive_type covers the built-in scalar types: int, float, bool, text, unit, never.
// type_never is the bottom type — a function that never returns has type never.
// type_optional wraps any type T into T | unit for nullable semantics.
// type_param names a generic parameter; type_var is an inference variable.
// type_constraint restricts what a type_param may be instantiated to.
// type_env maps names to type_entries in a scoped lexical environment.
// type_registry interns and deduplicates type descriptions.
// type_canon produces a canonical normal form for structural comparison.
// type_eq compares two types for equality after canonicalization.
// type_compat checks assignability and subtype relationships.
// type_coerce describes an implicit or explicit conversion between compatible types.
// type_widen relaxes a concrete type to a broader one (e.g. int -> float).
// type_narrow restricts a broader type to a concrete one after a type test.
// annotation carries explicit user-written type information from source.
// inferred_type is the type assigned by the type inference algorithm.

// Primitive flow:
// source annotation -> declared_type
// type inference -> type_var -> inferred_type
// type_registry + type_intern -> type_id
// type_eq + type_compat -> coerce or type error
// type_env + type_scope -> type_binding -> lookup

// This establishes the foundational type representation layer
// for the Norscode compile-time and runtime type system.

// ---- from runtime/z254.no ----
// Norscode Runtime - Omgang 254
// Type inference and unification algorithm

runtime z254 {
  type_var
  type_repr
  type_env
  type_constraint

  infer
  infer_expr
  infer_stmt
  infer_func
  infer_block
  infer_call
  infer_literal

  unify
  unify_pair
  unify_list
  unification_failure

  substitution
  subst_map
  apply_subst
  compose_subst

  constraint_set
  constraint_eq
  constraint_inst
  solve_constraints
  propagate_constraints

  generalize
  instantiate
  scheme
  free_vars
  bound_vars

  occurs_check
  occurs_error

  type_error
  type_mismatch
  arity_mismatch
  occurs_in_error
  ambiguous_type

  infer_result
  infer_ok
  infer_fail
}

// Semantic direction:
// infer is the top-level pass that walks the AST and assigns types.
// infer_expr assigns a type to each expression node.
// infer_func infers parameter and return types, creating type_vars where unspecified.
// infer_literal assigns primitive types directly (int literal -> type_int).
// infer_call checks that argument types unify with parameter types.
// unify attempts to make two types identical by finding a consistent substitution.
// unify_pair recurses over compound types field by field or argument by argument.
// substitution is a mapping from type_var to type_repr that satisfies constraints.
// apply_subst applies a substitution to a type, replacing vars with their bindings.
// compose_subst merges two substitutions without losing information.
// occurs_check prevents circular types (X = list[X]) from looping infinitely.
// constraint_eq records that two type_reprs must be equal.
// solve_constraints runs unification over the full constraint_set.
// generalize converts a fully inferred function type into a polymorphic scheme.
// instantiate creates fresh type_vars for each bound_var in a scheme.
// free_vars is the set of unbound type_vars in a type.
// type_mismatch is raised when unification fails between incompatible types.
// ambiguous_type is raised when a type_var remains unconstrained after inference.

// Primitive flow:
// AST node -> infer_expr or infer_stmt
// -> type_var for unknowns
// -> constraint_eq added to constraint_set
// -> solve_constraints -> unify -> substitution
// -> apply_subst -> concrete type_repr
// -> generalize -> scheme (for top-level functions)
// -> instantiate at call sites

// Error path:
// unify_pair -> type_mismatch or occurs_in_error
// -> type_error with source location

// This implements the Hindley-Milner subset type inference algorithm
// for the Norscode compile-time type system.

// ---- from runtime/z255.no ----
// Norscode Runtime - Omgang 255
// Struct types and field access semantics

runtime z255 {
  type_repr
  type_env
  type_struct

  struct_def
  struct_name
  struct_field
  field_name
  field_type
  field_index
  field_offset
  field_default

  struct_instance
  struct_constructor
  constructor_args
  field_init
  missing_field
  extra_field

  field_access
  field_read
  field_write
  field_path
  nested_access

  struct_layout
  layout_size
  layout_align
  layout_padding
  layout_version

  struct_method
  method_receiver
  method_dispatch
  self_type

  struct_eq
  struct_copy
  struct_clone
  struct_hash

  visibility
  public_field
  private_field
  module_field

  struct_error
  undefined_field
  wrong_field_type
  immutable_field_write
}

// Semantic direction:
// struct_def declares a named aggregate type with a fixed set of typed fields.
// struct_field pairs a field_name with a field_type and optional field_default.
// field_index gives each field a stable ordinal for layout and bytecode access.
// field_offset is the byte distance from the struct base to a field (AOT/FFI).
// struct_instance is a runtime value holding one struct's field data.
// struct_constructor takes constructor_args and produces a struct_instance.
// missing_field is raised when a required field is absent from constructor_args.
// field_access reads or writes a named field on a struct_instance.
// field_path chains accesses for nested structs (a.b.c).
// struct_layout records size, alignment, and padding for native code generation.
// struct_method associates a function with a struct type as its receiver.
// method_receiver is the implicit first parameter; self_type is its type.
// method_dispatch looks up the correct method body given a struct value.
// struct_eq tests two instances for structural equality across all fields.
// struct_copy produces a shallow copy; struct_clone produces a deep copy.
// visibility controls whether a field is accessible outside its declaring module.
// undefined_field is raised when code accesses a field that does not exist.
// wrong_field_type is raised when a field is assigned a value of wrong type.
// immutable_field_write is raised when a const-declared field is mutated.

// Primitive flow:
// struct_def -> type_env registration -> type_struct
// struct_constructor + constructor_args -> field_init -> struct_instance
// field_access -> field_index -> bytecode slot load/store
// field_path -> chain of field_read
// struct_layout -> field_offset (used by AOT and FFI)
// struct_method -> method_dispatch -> call

// Error path:
// constructor_args check -> missing_field or extra_field
// field_access -> undefined_field or wrong_field_type or immutable_field_write

// This defines struct type declaration, construction, field access,
// layout, and method dispatch semantics for the Norscode type system.

// ---- from runtime/z256.no ----
// Norscode Runtime - Omgang 256
// Union types and exhaustive pattern matching

runtime z256 {
  type_repr
  type_union

  union_def
  union_name
  variant
  variant_name
  variant_payload
  variant_tag
  variant_index

  union_value
  union_constructor
  tag_value
  payload_value

  match_expr
  match_arm
  match_pattern
  match_guard
  match_body

  pattern
  pattern_variant
  pattern_literal
  pattern_bind
  pattern_wildcard
  pattern_tuple
  pattern_struct

  exhaustiveness
  covered_variants
  uncovered_variant
  redundant_arm
  reachability

  binding
  captured_binding
  binding_type

  union_eq
  union_hash
  union_copy

  match_error
  non_exhaustive
  redundant_pattern
  irrefutable_pattern
}

// Semantic direction:
// union_def declares a named sum type with one or more variants.
// variant gives each alternative a name, an optional payload type, and a stable tag.
// variant_tag is the discriminant stored at runtime to identify which variant is active.
// variant_index is the ordinal used in bytecode for switch dispatch.
// union_value is a runtime value holding a variant_tag and an optional payload_value.
// union_constructor creates a union_value for a named variant with its payload.
// match_expr selects a match_arm whose match_pattern covers the union_value's variant.
// match_arm pairs a match_pattern with an optional match_guard and a match_body.
// match_guard adds an extra boolean condition that must hold for an arm to fire.
// pattern_variant matches a specific variant, optionally binding its payload fields.
// pattern_literal matches a concrete scalar value.
// pattern_bind introduces a new name bound to the matched value in match_body.
// pattern_wildcard accepts any value without binding.
// exhaustiveness verifies that covered_variants includes every variant of the union.
// uncovered_variant reports which variants have no matching arm.
// redundant_arm reports arms that can never be reached given prior arms.
// binding_type gives each captured_binding the type inferred from its pattern.
// non_exhaustive is a compile-time error when match does not cover all variants.
// redundant_pattern is a compile-time warning when an arm can never fire.

// Primitive flow:
// union_def -> variant list -> type_env registration -> type_union
// union_constructor + payload -> union_value with variant_tag
// match_expr -> match arm scan -> variant_tag comparison
// -> pattern check + match_guard evaluation
// -> captured_binding + match_body
// exhaustiveness check: covered_variants vs union_def variants
// -> non_exhaustive error or ok

// Error path:
// match_expr -> non_exhaustive -> list uncovered_variant
// match_arm scan -> redundant_arm warning

// This defines union type declaration, variant construction,
// exhaustive pattern matching, and binding semantics for Norscode.

// ---- from runtime/z257.no ----
// Norscode Runtime - Omgang 257
// Generics and parametric polymorphism

runtime z257 {
  type_param
  type_var
  type_scheme
  type_repr

  generic_def
  generic_name
  param_list
  param_name
  param_bound
  param_default

  generic_func
  generic_struct
  generic_union
  generic_impl

  instantiation
  type_arg
  type_arg_list
  inst_key
  inst_cache

  bound
  bound_trait
  bound_interface
  bound_check
  bound_violation

  where_clause
  where_item
  implied_bound

  monomorphize
  mono_instance
  mono_key
  mono_cache
  specialize

  type_application
  apply_args
  check_arity
  arity_mismatch

  infer_type_args
  type_arg_infer
  partial_application
}

// Semantic direction:
// generic_def declares a function, struct, or union that is parameterized by types.
// param_list names the type parameters; param_bound restricts what each may be.
// param_default supplies a fallback type when a type_arg is not provided.
// generic_func is a function with at least one type_param in its signature.
// generic_struct is a struct whose field types reference one or more type_params.
// instantiation replaces each type_param with a concrete type_arg.
// inst_key uniquely identifies one instantiation by generic name plus type_arg_list.
// inst_cache avoids re-instantiating the same combination more than once.
// bound constrains a type parameter to only accept types that satisfy it.
// bound_check verifies at each instantiation that the supplied type_arg satisfies bound.
// bound_violation reports when a type_arg fails a required bound.
// where_clause groups multiple bound constraints on a generic_def.
// monomorphize generates one concrete version of a generic_def per distinct inst_key.
// mono_instance is the concrete specialization produced by monomorphize.
// mono_cache stores mono_instances to avoid duplicate code generation.
// specialize applies optimizations specific to a known type_arg (e.g. int path).
// type_application is the syntax for supplying explicit type_args at a call site.
// infer_type_args deduces type_args from the types of supplied value arguments.
// arity_mismatch is raised when the number of type_args differs from param_list length.

// Primitive flow:
// generic_def + param_list -> type_scheme
// call site -> infer_type_args or explicit type_application
// -> type_arg_list + inst_key
// -> inst_cache lookup
// -> bound_check for each param_bound
// -> monomorphize -> mono_instance
// -> code generation for mono_instance

// Error path:
// bound_check -> bound_violation with type_arg and bound name
// check_arity -> arity_mismatch with expected vs actual count

// This defines parametric generics, instantiation, bounds checking,
// and monomorphization semantics for the Norscode type system.

// ---- from runtime/z258.no ----
// Norscode Runtime - Omgang 258
// Type checking pipeline and semantic validation

runtime z258 {
  type_env
  type_repr
  type_error

  check_pipeline
  check_pass
  check_order
  check_result

  check_program
  check_module
  check_func
  check_block
  check_stmt
  check_expr

  check_assign
  check_return
  check_if
  check_while
  check_call
  check_index
  check_field

  check_binary
  check_unary
  check_cast
  check_literal
  check_ident

  expected_type
  actual_type
  type_context
  push_context
  pop_context

  return_type_stack
  check_return_type
  missing_return
  dead_code_after_return

  narrowing_pass
  narrowing_context
  refine_type
  branch_types
  join_types

  error_accumulator
  collect_error
  max_errors
  error_recovery
  skip_subtree
}

// Semantic direction:
// check_pipeline runs all type-checking passes over a fully parsed AST.
// check_order determines which modules and declarations must be checked first.
// check_program is the entry point: checks all top-level declarations.
// check_func validates parameter types, body, and return type consistency.
// check_block checks each stmt in sequence, threading the type_env forward.
// check_expr returns the inferred type of an expression and reports mismatches.
// check_assign verifies the right-hand type is compatible with the declared type.
// check_return verifies the returned type matches the enclosing function's return type.
// check_call verifies argument count and types match the callee's signature.
// check_index verifies that the indexed value is a list or map with compatible key.
// check_field verifies the base is a struct and the field name exists with its type.
// expected_type is the type the surrounding context demands from an expression.
// type_context tracks the expected type through nested expressions.
// return_type_stack holds the expected return type for nested function scopes.
// missing_return is raised when a function with a non-unit return type may not return.
// dead_code_after_return warns when statements follow a guaranteed return or panic.
// narrowing_pass refines types inside conditional branches.
// refine_type narrows a type after a type test or variant match.
// branch_types collects the types of both if/else branches.
// join_types computes the least upper bound of two types at a branch merge.
// error_accumulator collects type errors rather than stopping at the first.
// error_recovery resumes checking after a type error using a placeholder type.
// skip_subtree abandons type checking of an expression after an unrecoverable error.

// Primitive flow:
// AST -> check_program -> check_module -> check_func
// -> push_context + return_type_stack
// -> check_block -> check_stmt -> check_expr
// -> expected_type + actual_type -> type_compat
// -> collect_error or continue
// narrowing_pass -> branch_types -> join_types -> refined type_env

// Error path:
// type_mismatch -> collect_error -> error_recovery -> skip_subtree
// missing_return -> type_error at function end
// dead_code_after_return -> warning

// This defines the end-to-end type checking pipeline that validates
// Norscode programs before code generation.


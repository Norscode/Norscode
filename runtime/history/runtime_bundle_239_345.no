  timeout_ft
  timeout_duration
  timeout_wrap
  timeout_cancel
  deadline
  deadline_exceeded

  fallback
  fallback_fn
  fallback_value
  fallback_cache
  degraded_response
  static_fallback

  hedge
  hedge_delay
  hedge_request
  hedge_cancel_slow
  fastest_response

  shed_load
  load_shed_threshold
  shed_strategy
  priority_shed
  random_shed

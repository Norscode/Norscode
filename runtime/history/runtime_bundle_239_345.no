// Norscode export_attr -> host_export -> export_section entry
// host call -> wasm_bindgen glue -> marshal_from_js -> Norscode call
// Norscode result -> marshal_to_js -> JS value returned to host
// host_object access -> extern_ref_table slot -> extern_ref_get
// DOM call -> host_import + js_call -> extern_ref argument
// async function -> async_bridge -> Promise creation + promise_resolve/reject


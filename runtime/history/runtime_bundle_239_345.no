// Semantic direction:
// doc_site describes the fully deployed documentation website and its infrastructure.
// site_domain_primary is the canonical domain (e.g. norscode.dev).
// hosting_cloudflare_pages is the primary hosting provider for global CDN delivery.
// deploy_pipeline builds the docs and deploys them automatically on push and release.
// deploy_preview builds a temporary preview for each pull request before merging.
// preview_url is unique per PR and posted as a preview_pr_comment on GitHub.
// set_redirects configures URL redirections for renamed or moved pages.
// redirect_entry maps redirect_from to redirect_to with an HTTP redirect_status (301 or 302).
// cache_control_immutable is applied to fingerprinted assets that never change.
// cache_control_html is set to short TTL (e.g. 60s) so pages update quickly after deploy.
// csp_header is the Content Security Policy restricting which scripts and styles load.
// hsts_header enforces HTTPS for all visitors.
// analytics uses a privacy-first, cookie-free analytics provider.
// no_tracking_cookie means analytics work without consent banners.
// respect_dnt honors the browser's Do Not Track preference.
// contribution_guide explains how to improve the documentation via fork-and-PR.
// run_docs_locally describes the docs_local_command to preview changes before submitting.
// feedback_widget lets readers rate each page and leave optional comments.
// feedback_store persists ratings to a serverless function or edge key-value store.
// feedback_report aggregates page_rating data to identify documentation gaps.
// broken_link_checker runs in CI to catch dead internal and external links.
// sitemap_submit registers sitemap.xml with search engines for indexing.

// Primitive flow:
// push to main -> deploy_pipeline -> build_docs -> upload_to_cdn -> invalidate_cdn_cache
// PR opened -> deploy_preview -> preview_url posted as preview_pr_comment
// set_redirects: _redirects file in build output -> hosting provider processes
// set_headers: _headers file -> cache_control + csp + hsts applied per path
// feedback_widget: user clicks rating -> feedback_submit -> feedback_store (edge KV)
// feedback_report: aggregate ratings by page -> flag pages below threshold for review
// broken_link_checker: CI step -> check_internal_links + check_external_links
//   -> broken_link found -> CI warning (internal) or issue filed (external)
// release tag -> deploy versioned docs (z309) + update version_manifest + sitemap_submit

// This defines the documentation site deployment, CDN hosting, redirects,
// security headers, analytics, contribution workflow, and feedback collection.

// ---- from runtime/z313.no ----
// Norscode Runtime - Omgang 313
// IR optimization framework and pass manager

runtime z313 {
  opt_pipeline
  opt_pass
  pass_name
  pass_kind
  kind_function_pass
  kind_module_pass
  kind_loop_pass
  pass_ordering
  pass_dependency
  pass_invalidates

  pass_manager
  pm_add_pass
  pm_run
  pm_run_on_function
  pm_run_on_module
  pass_result
  pass_changed
  pass_unchanged

  analysis
  analysis_pass
  analysis_result
  analysis_cache
  analysis_valid
  analysis_invalidate
  dominator_tree
  loop_info
  alias_analysis
  call_graph
  use_def_chain

  opt_level
  opt_none
  opt_basic
  opt_standard
  opt_aggressive

  function_ir
  ir_block
  ir_instr
  ir_value
  ir_use
  ir_def

  worklist
  worklist_push
  worklist_pop
  worklist_empty

  transformation
  replace_uses
  remove_instr
  insert_before
  insert_after
  split_block
  merge_blocks
  redirect_branch

  opt_stat
  stat_instrs_removed
  stat_blocks_removed
  stat_funcs_inlined
  stat_loops_unrolled
  opt_report
}

// Semantic direction:
// opt_pipeline is the ordered sequence of opt_passes that transform the IR toward faster code.
// pass_kind distinguishes function_passes (operate on one function at a time) from module_passes.
// pass_ordering ensures that passes run in a sequence that preserves correctness.
// pass_dependency declares which analyses a pass requires before it can run.
// pass_invalidates lists which cached analyses become stale after a pass modifies the IR.
// pass_manager drives the pipeline: it schedules passes, caches analyses, and re-runs as needed.
// pass_changed indicates that a pass modified at least one instruction; the manager re-runs dependent passes.
// analysis_pass computes a fact about the IR (e.g. dominator_tree) without modifying it.
// analysis_cache stores analysis_results; analysis_invalidate evicts stale entries after transformations.
// dominator_tree records which block must execute before another can be reached.
// loop_info identifies natural loops and their back edges in the control flow graph.
// alias_analysis determines whether two memory accesses may refer to the same location.
// call_graph maps each call site to its potential callees for inter-procedural analysis.
// use_def_chain links each ir_value use back to its defining instruction.
// opt_level controls the aggressiveness: opt_none (debug), opt_basic, opt_standard, opt_aggressive.
// worklist is a set-like queue used by iterative passes to process instructions in priority order.
// replace_uses rewrites all uses of one ir_value to point to another.
// remove_instr deletes an ir_instr and updates use_def_chains.
// split_block divides a block at an instruction boundary to expose optimization opportunities.
// opt_stat accumulates counts of removed instructions, inlined functions, and unrolled loops.
// opt_report summarizes the effects of the optimization pipeline for diagnostics.

// Primitive flow:
// typed_ir_module -> pass_manager.run(opt_level)
// -> for each module_pass: pm_run_on_module
// -> for each function_pass in worklist order: pm_run_on_function
//    -> analysis_cache: fetch or compute dominator_tree, loop_info, alias_analysis
//    -> transformation applied -> pass_changed?
//    -> yes: analysis_invalidate affected analyses -> re-queue dependent passes
// -> opt_stat collected -> opt_report
// -> optimized IR -> codegen or next pipeline stage

// This establishes the IR optimization framework, pass manager, and
// analysis infrastructure that all optimizer passes build upon.

// ---- from runtime/z314.no ----
// Norscode Runtime - Omgang 314
// Constant folding and algebraic simplification

runtime z314 {
  const_fold_pass
  const_value
  const_int
  const_float
  const_bool
  const_text
  const_null
  const_list
  const_struct_field

  fold_arith
  fold_add
  fold_sub
  fold_mul
  fold_div
  fold_rem
  fold_negate
  fold_overflow_check

  fold_compare
  fold_eq
  fold_ne
  fold_lt
  fold_le
  fold_gt
  fold_ge

  fold_logic
  fold_and
  fold_or
  fold_not
  fold_xor
  fold_short_circuit

  fold_cast
  fold_int_to_float
  fold_float_to_int
  fold_widen
  fold_truncate

  algebraic_simplify
  simplify_add_zero
  simplify_mul_one
  simplify_mul_zero
  simplify_sub_self
  simplify_div_one
  simplify_and_true
  simplify_or_false
  simplify_not_not
  simplify_double_negate

  strength_reduce
  mul_by_power_of_two
  div_by_power_of_two
  mod_by_power_of_two
  shift_left
  shift_right
  replace_with_shift

  const_propagate
  propagate_pass
  known_value
  known_map
  propagate_into_uses
  fold_after_propagate

  sparse_conditional_constant
  scc_lattice
  lattice_top
  lattice_const
  lattice_bottom
  scc_worklist
  scc_edge_executable
}

// Semantic direction:
// const_fold_pass evaluates expressions whose operands are all compile-time constants.
// fold_add(const_int(3), const_int(4)) -> const_int(7) without emitting any instruction.
// fold_overflow_check raises a compile-time error if folded integer arithmetic would overflow.
// fold_compare collapses constant comparisons to const_bool(sant) or const_bool(usant).
// fold_short_circuit removes the unreachable branch of a constant logical expression.
// fold_cast evaluates type conversions between known constant values at compile time.
// algebraic_simplify applies identity laws that hold regardless of the operand's value.
// simplify_add_zero removes x + 0 -> x; simplify_mul_one removes x * 1 -> x.
// simplify_mul_zero replaces x * 0 -> 0 and eliminates side-effect-free subexpressions.
// simplify_not_not removes double negation: ikkje(ikkje(x)) -> x.
// strength_reduce replaces expensive operations with cheaper equivalents.
// mul_by_power_of_two replaces x * 8 with x << 3.
// div_by_power_of_two replaces x / 4 with x >> 2 for unsigned integers.
// mod_by_power_of_two replaces x % 16 with x & 15.
// const_propagate replaces each use of a variable with its known constant value when determinable.
// known_map tracks which ir_values have a known const_value at each program point.
// propagate_into_uses substitutes the const_value into all downstream uses.
// fold_after_propagate runs const_fold_pass again after propagation to catch new opportunities.
// sparse_conditional_constant (SCC) propagates constants through branches, marking unreachable edges.
// scc_lattice models value knowledge: top (unvisited), const (known value), bottom (non-constant).
// scc_edge_executable tracks which control flow edges have been determined reachable.

// Primitive flow:
// const_fold_pass: walk all ir_instrs
//   operands both const? -> fold_arith / fold_compare / fold_cast -> replace with const_value
//   algebraic_simplify: match identity patterns -> remove instruction + replace_uses
//   strength_reduce: match power-of-two multiply/divide -> replace with shift
// const_propagate: assign known_map from const definitions
//   -> propagate_into_uses for each use -> fold_after_propagate
// SCC: worklist of functions and branches
//   -> scc_lattice per value -> converge -> dead branches marked -> remove_instr

// This defines constant folding, algebraic simplification, strength reduction,
// and sparse conditional constant propagation for the Norscode optimizer.

// ---- from runtime/z315.no ----
// Norscode Runtime - Omgang 315
// Dead code elimination and unreachable code pruning

runtime z316 {
  dce_pass
  dead_instr
  dead_block
  dead_function
  dead_value
  side_effect_free
  pure_instr
  impure_instr

  liveness
  live_set
  live_in
  live_out
  live_on_edge
  liveness_pass
  liveness_worklist

  use_count
  zero_uses
  trivially_dead
  remove_dead_instrs

  unreachable_block
  unreachable_edge
  reachability_pass
  reachable_set
  mark_reachable
  prune_unreachable_blocks
  remove_dead_edges

  dead_branch_elim
  branch_condition
  known_true_branch
  known_false_branch
  fold_unconditional_branch
  remove_dead_branch

  dead_store_elim
  dse_pass
  store_instr
  subsequent_store
  no_intervening_load
  remove_dead_store

  dead_alloc_elim
  alloc_instr
  alloc_never_read
  remove_dead_alloc

  dead_function_elim
  dfce_pass
  call_graph_reachable
  root_functions
  unreachable_function
  remove_dead_function

  global_dce
  global_dead_symbol
  exported_symbol
  internal_symbol
  remove_global_dead
}

// Semantic direction:
// dce_pass removes instructions whose results are never used and which have no side effects.
// side_effect_free marks instructions that can be removed without observable program change.
// pure_instr is a computation that depends only on its inputs and has no observable output.
// liveness_pass computes, for each program point, the set of values that may be used later.
// live_in is the set of live values at the start of a block; live_out is the set at the end.
// liveness_worklist iterates backward through blocks until the live sets converge.
// zero_uses marks an ir_value whose use_count has dropped to zero after other passes.
// trivially_dead is an instruction that produces zero_uses and is side_effect_free.
// remove_dead_instrs deletes all trivially_dead instructions in one pass.
// reachability_pass marks every block reachable from the function entry by following edges.
// prune_unreachable_blocks deletes blocks that are never reached from the entry.
// remove_dead_edges removes control flow edges that can never be taken.
// dead_branch_elim folds a conditional branch whose condition is a known constant.
// known_true_branch is the successor taken when the branch condition is const_bool(sant).
// fold_unconditional_branch replaces a conditional with an unconditional jump to the live successor.
// dse_pass removes store instructions that are overwritten before the stored value is read.
// subsequent_store detects that another store to the same address follows with no intervening load.
// remove_dead_store deletes the first store since its value is never observed.
// dead_alloc_elim removes allocation instructions for objects that are never loaded from.
// dfce_pass removes entire functions that are never reachable from any root_function.
// root_functions are the set of exported or externally visible entry points.
// global_dce removes module-level declarations (globals, constants) that are never referenced.
// exported_symbol is kept regardless; internal_symbol may be removed if unreferenced.

// Primitive flow:
// liveness_pass: backward dataflow over CFG -> live_in/live_out per block
// dce_pass: for each instr: use_count == 0 and side_effect_free -> remove_dead_instrs
// reachability_pass: BFS from entry -> mark_reachable -> prune_unreachable_blocks
// dead_branch_elim: branch with known_true/false condition -> fold_unconditional_branch
// dse_pass: forward scan per block -> subsequent_store detected -> remove_dead_store
// dead_alloc_elim: alloc_never_read -> remove_dead_alloc
// dfce_pass: call_graph BFS from root_functions -> unreachable_function -> remove_dead_function
// global_dce: scan module -> internal_symbol with no uses -> remove_global_dead

// This defines dead code elimination, unreachable block pruning, dead branch
// folding, dead store elimination, and whole-program dead function removal.


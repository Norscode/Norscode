}

// Semantic direction:
// type_metadata is a runtime-accessible description of a type's structure.
// meta_name is the declared name of the type.
// meta_kind indicates whether this is a struct, union, primitive, function, or list.
// meta_fields lists field_descriptors for struct types.
// meta_variants lists variant_descriptors for union types.
// meta_params lists type_params for generic types.
// meta_methods lists func_descriptors for methods attached to a type.
// reflect gives code the ability to inspect values and types at runtime.
// reflect_value returns the type_metadata for the dynamic type of a value.
// type_of returns the compile-time type_id for a static expression.
// kind_of returns the meta_kind of a type by type_id.
// fields_of returns field_descriptor list for a struct type.
// variants_of returns variant_descriptor list for a union type.
// dynamic_type stores a type_tag alongside a value for type-erased containers.
// is_type tests whether a dynamic_type value holds a given type_id.
// as_type extracts the concrete value from a dynamic_type, or returns none.
// cast_dynamic forces extraction and raises cast_type_mismatch on failure.
// serialize_type produces a JSON or schema representation of type_metadata.
// type_schema generates a schema document suitable for external tooling.
// not_a_struct is raised when fields_of is called on a non-struct type.
// unknown_field_name is raised when a field name is not found via reflection.

// Primitive flow:
// type definition -> type_registry -> type_metadata
// reflect_value(v) -> type_tag -> meta_kind + meta_fields or meta_variants
// fields_of(type_id) -> field_descriptor list
// dynamic_type wrapping: value + type_tag -> erased container
// is_type + as_type -> checked extraction
// type_to_json -> type_schema for tooling or serialization

// This defines runtime type metadata and reflection semantics
// for introspection, dynamic dispatch, and schema generation in Norscode.

// ---- from runtime/z261.no ----
// Norscode Runtime - Omgang 261
// Subtyping, coercions, and implicit conversions

runtime z261 {
  type_repr
  type_id
  type_env

  subtype
  supertype
  subtype_rel
  subtype_check
  subtype_proof
  subtype_chain

  coerce
  coerce_rule
  coerce_kind
  implicit_coerce
  explicit_coerce
  coerce_insert
  coerce_site

  widen
  narrow
  widen_int
  widen_float
  int_to_float
  float_to_int
  text_to_int
  int_to_text

  optional_coerce
  lift_to_optional
  optional_unwrap
  propagate_optional

  union_coerce
  lift_to_union
  variant_inject

  list_coerce
  coerce_elements

  numeric_promotion
  promote_operands
  common_numeric_type

  coerce_error
  no_implicit_coerce
  coerce_loss_of_precision
  ambiguous_coerce
}

// Semantic direction:
// subtype_rel declares that one type is a subtype of another for assignability.
// subtype_check verifies that a value of type A can be used where type B is expected.
// subtype_proof is evidence that A <: B, used to justify a safe implicit coercion.
// subtype_chain composes two subtype proofs: A <: B and B <: C implies A <: C.
// coerce is the operation of converting a value from one type to a compatible one.
// coerce_rule defines one permitted conversion: source type, target type, and cost.
// implicit_coerce is applied automatically by the compiler without source annotation.
// explicit_coerce requires the programmer to write a conversion call.
// coerce_insert marks the AST site where a coercion node will be synthesized.
// widen_int promotes a narrower integer to a wider one without loss.
// int_to_float converts an integer to floating point (may lose precision for large values).
// text_to_int parses a text literal into an integer (may fail at runtime).
// lift_to_optional wraps a non-optional value into Optional[T] implicitly.
// propagate_optional applies a function to the inner value of Optional[T].
// lift_to_union injects a value into a union type as the matching variant.
// numeric_promotion selects a common numeric type for binary arithmetic.
// promote_operands inserts coerce nodes to unify operand types before arithmetic.
// no_implicit_coerce is raised when no implicit rule connects source and target type.
// coerce_loss_of_precision warns when a widening coercion may discard information.
// ambiguous_coerce is raised when multiple coerce_rules apply with equal cost.

// Primitive flow:
// type_check expression -> expected_type vs actual_type
// -> subtype_check: is actual <: expected?
// -> yes: coerce_insert with implicit_coerce rule
// -> no: look for explicit coerce_rule
// -> found: suggest explicit_coerce to programmer
// -> not found: no_implicit_coerce error
// binary arithmetic -> numeric_promotion -> promote_operands -> common_numeric_type
// optional context -> lift_to_optional -> implicit_coerce node inserted

// Error path:
// no_implicit_coerce -> type_mismatch diagnostic with coerce suggestion
// coerce_loss_of_precision -> warning at coerce_site
// ambiguous_coerce -> error asking for explicit cast

// This defines subtyping relationships, implicit and explicit coercion rules,
// and numeric promotion semantics for the Norscode type system.


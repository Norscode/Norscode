// Norscode Runtime - Omgang 320
// Peephole optimizations and machine instruction selection

runtime z320 {
  peephole_pass
  peephole_window
  window_size
  peephole_pattern
  pattern_match
  pattern_replace
  peephole_rule
  rule_before
  rule_after
  rule_condition

  redundant_move
  move_to_self
  move_chain
  eliminate_move
  copy_propagate_machine

  redundant_load
  load_after_store
  same_address
  forward_store_value
  eliminate_redundant_load

  combine_instrs
  add_sub_combine
  compare_branch_fuse
  load_op_combine
  shift_add_combine
  mul_add_fuse
  fma_instr

  zero_idiom
  xor_self_to_zero
  sub_self_to_zero
  zero_extend_idiom

  branch_opt
  invert_branch
  branch_over_jump
  fall_through_opt
  remove_unconditional_jump
  align_branch_target

  instruction_select
  select_pass
  ir_pattern
  machine_pattern
  tile_ir
  cover_ir
  emit_machine_instr
  cost_tile
  min_cost_cover

  x86_64_peephole
  use_lea
  use_imul_imm
  use_test_not_cmp
  use_movzx
  use_cmov

  aarch64_peephole
  use_madd
  use_msub
  use_csel
  use_ubfx
  use_sbfx
  use_ldp_stp
}

// Semantic direction:
// peephole_pass scans a sliding peephole_window of machine instructions and applies local rewrites.
// peephole_rule pairs a rule_before sequence with a rule_after replacement and an optional rule_condition.
// pattern_match checks whether the instructions in the window match the rule_before template.
// pattern_replace substitutes the matched instructions with the rule_after sequence.
// redundant_move detects and removes move instructions where source and destination are identical.
// move_chain collapses a sequence of moves (a=b, b=c) to a single move (a=c).
// eliminate_redundant_load replaces a load with the value just stored to the same address.
// forward_store_value directly uses the stored value without emitting a load instruction.
// compare_branch_fuse merges a compare instruction and a conditional branch into a single fused operation.
// mul_add_fuse combines a multiply followed by an add into a single fma_instr (fused multiply-add).
// fma_instr (FMA) computes a*b+c with a single rounding error on supporting hardware.
// zero_idiom uses xor_self_to_zero to clear a register, which is faster than loading the constant 0.
// branch_over_jump removes an unconditional jump that immediately follows its target.
// fall_through_opt reorders blocks so a common path requires no branch instruction.
// align_branch_target inserts nop padding to align hot branch targets to cache line boundaries.
// instruction_select maps IR patterns to optimal machine instruction sequences.
// tile_ir partitions the IR tree into tiles; cover_ir finds the minimum cost_tile covering.
// emit_machine_instr generates the machine instruction for the selected tile.
// x86_64 peepholes: use_lea for address arithmetic, use_test instead of cmp-with-zero,
//   use_cmov for branchless conditional moves, use_movzx for zero-extending loads.
// aarch64 peepholes: use_madd/msub for multiply-accumulate, use_csel for branchless selection,
//   use_ldp_stp to pair load/store instructions, use_ubfx/sbfx for bit field extraction.

// Primitive flow:
// after register allocation: peephole_pass over instruction stream
//   window of window_size instructions -> peephole_pattern scan
//   -> redundant_move elimination
//   -> load_after_store: same_address? -> forward_store_value + eliminate_redundant_load
//   -> compare_branch_fuse: cmp + jcc -> fused test+branch
//   -> mul_add_fuse: mul + add -> FMA instruction
//   -> zero_idiom: mov reg, 0 -> xor reg, reg
// instruction_select: IR -> cost_tile covering -> emit_machine_instr per tile
// fall_through_opt: reorder blocks -> remove_unconditional_jump to next block
// align_branch_target: hot targets with nop padding to 16-byte boundary

// This defines peephole optimization patterns, redundant instruction elimination,
// FMA fusion, branchless idioms, and machine instruction selection.


# Function dispatch phase 1

struktur FunctionInvocationSemantics
    invocation_inputs
    invocation_frames
    invocation_results
slutt

struktur ExecutionDispatchTable
    dispatch_inputs
    dispatch_operations
    dispatch_outputs
slutt

funksjon ny_function_invocation_semantics()
    invocation = FunctionInvocationSemantics()

    invocation.invocation_inputs = []
    invocation.invocation_frames = []
    invocation.invocation_results = []

    returner invocation
slutt

funksjon registrer_invocation_input(invocation, input)
    legg_til(invocation.invocation_inputs, input)
    returner input
slutt

funksjon registrer_invocation_frame(invocation, frame)
    legg_til(invocation.invocation_frames, frame)
    returner frame
slutt

funksjon registrer_invocation_result(invocation, result)
    legg_til(invocation.invocation_results, result)
    returner result
slutt

funksjon ny_execution_dispatch_table()
    dispatch = ExecutionDispatchTable()

    dispatch.dispatch_inputs = []
    dispatch.dispatch_operations = []
    dispatch.dispatch_outputs = []

    returner dispatch
slutt

funksjon registrer_dispatch_input(dispatch, input)
    legg_til(dispatch.dispatch_inputs, input)
    returner input
slutt

funksjon registrer_dispatch_operation(dispatch, operation)
    legg_til(dispatch.dispatch_operations, operation)
    returner operation
slutt

funksjon registrer_dispatch_output(dispatch, output)
    legg_til(dispatch.dispatch_outputs, output)
    returner output
slutt

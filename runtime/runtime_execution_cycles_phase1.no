# Runtime execution cycles phase 1

struktur RuntimeOpcodeExecutionCycle
    opcode_inputs
    opcode_cycles
    opcode_outputs
slutt

struktur InterpreterStateProgression
    state_inputs
    state_cycles
    state_outputs
slutt

funksjon ny_runtime_opcode_execution_cycle()
    cycle = RuntimeOpcodeExecutionCycle()

    cycle.opcode_inputs = []
    cycle.opcode_cycles = []
    cycle.opcode_outputs = []

    returner cycle
slutt

funksjon registrer_opcode_cycle_input(cycle, input)
    legg_til(cycle.opcode_inputs, input)
    returner input
slutt

funksjon registrer_opcode_cycle(cycle, opcode)
    legg_til(cycle.opcode_cycles, opcode)
    returner opcode
slutt

funksjon registrer_opcode_cycle_output(cycle, output)
    legg_til(cycle.opcode_outputs, output)
    returner output
slutt

funksjon ny_interpreter_state_progression()
    progression = InterpreterStateProgression()

    progression.state_inputs = []
    progression.state_cycles = []
    progression.state_outputs = []

    returner progression
slutt

funksjon registrer_state_progression_input(progression, input)
    legg_til(progression.state_inputs, input)
    returner input
slutt

funksjon registrer_state_progression_cycle(progression, cycle)
    legg_til(progression.state_cycles, cycle)
    returner cycle
slutt

funksjon registrer_state_progression_output(progression, output)
    legg_til(progression.state_outputs, output)
    returner output
slutt

// Norscode Runtime - Omgang 331
// API gateway and cloud-native ingress

runtime z331 {
  api_gateway
  gateway_config
  gateway_port
  gateway_tls
  gateway_upstream
  gateway_route
  gateway_plugin

  ingress_rule
  ingress_host
  ingress_path
  path_prefix
  path_exact
  ingress_backend
  backend_service
  backend_port
  tls_secret
  cert_manager
  acme_challenge
  lets_encrypt

  request_pipeline
  pipeline_stage
  stage_auth
  stage_rate_limit
  stage_transform
  stage_route
  stage_proxy
  stage_cache
  stage_log

  auth_plugin
  api_key_auth
  jwt_auth
  jwt_secret
  jwt_algorithm
  jwt_claims
  jwt_expiry
  oauth2_auth
  oauth2_provider
  oauth2_introspect
  basic_auth

  rate_limit_plugin
  rl_per_ip
  rl_per_user
  rl_per_api_key
  rl_global
  rl_window_size
  rl_quota
  rl_retry_after

  transform_plugin
  request_transform
  response_transform
  add_header
  remove_header
  rewrite_path
  strip_prefix
  add_cors
  cors_origins
  cors_methods
  cors_headers

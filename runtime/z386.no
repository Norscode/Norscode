// Norscode Runtime - Omgang 386
// TUI application framework and navigation

runtime z386 {
  tui_app
  app_state_tui
  app_init
  app_update
  app_render
  app_handle_event
  app_quit_key
  app_title_bar
  app_status_bar
  app_help_bar

  screen
  screen_id
  screen_stack
  push_screen
  pop_screen
  replace_screen
  current_screen

  component
  component_id
  component_state
  component_update
  component_render_c
  component_on_focus
  component_on_blur

  focus_ring
  focus_next_c
  focus_prev_c
  focused_component
  focus_id

  keybinding
  binding_key
  binding_action
  binding_description
  binding_category
  binding_global
  keymap
  keymap_register
  keymap_match
  keymap_help

  action
  action_id
  action_name
  action_execute

  command_palette
  palette_query
  palette_commands
  palette_filtered
  palette_select
  palette_run

  notification
  notif_message
  notif_level_tui

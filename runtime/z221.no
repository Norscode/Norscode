// Norscode Runtime - Omgang 221
// Primitive planetary runtime

runtime z221 {
  learn
  adapt
  predict
  plan
  agent

  goal
  intent
  policy_engine
  constraint_solver
  world_model

  language_model
  reason
  dialog
  memory_model
  knowledge_graph

  simulation
  environment
  feedback
  reward
  alignment

  civilization
  economy
  governance
  culture
  ecosystem

  planet
  species
  biosphere
  energy
  evolutionary_system
}

// Semantic direction:
// planet gives civilization-scale runtime a whole-world coordination frame.
// species models populations, agents, reproduction, adaptation, and interaction.
// biosphere links ecosystems into a planetary life-support model.
// energy gives planetary systems a resource and transformation constraint.
// evolutionary_system models long-term change across species, culture, economy, and environment.

// Primitive flow:
// planet + biosphere + ecosystem
// -> species + civilization
// -> energy + economy + governance
// -> feedback + alignment + evolutionary_system
// -> adapt + evolve
// -> updated + output

// This marks the transition from primitive civilization-runtime
// into primitive planetary-runtime semantics.
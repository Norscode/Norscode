  alg_hs256
  alg_hs512
  alg_rs256
  alg_rs384
  alg_rs512
  alg_es256
  alg_es384
  alg_ps256
  alg_eddsa

  jwt_claims
  claim_iss
  claim_sub
  claim_aud
  claim_exp
  claim_nbf
  claim_iat
  claim_jti
  custom_claim

  jwt_sign
  jwt_verify
  jwt_decode_unverified
  jwt_parse
  jwt_expired
  jwt_not_yet_valid
  jwt_invalid_signature
  jwt_wrong_audience

// Norscode Runtime - Omgang 415
// Async TCP, UDP, and network primitives

runtime z415 {
  async_tcp_stream
  tcp_connect_a
  tcp_bind_a
  tcp_listen_a
  tcp_accept_a
  tcp_read_a
  tcp_write_a
  tcp_shutdown_a
  tcp_peer_addr
  tcp_local_addr
  tcp_set_nodelay
  tcp_set_keepalive_a

  async_tcp_listener
  listener_bind_a
  listener_accept_a
  listener_local_addr
  incoming_stream

  async_udp_socket
  udp_bind_a
  udp_send_to_a
  udp_recv_from_a
  udp_connect_a
  udp_send_a
  udp_recv_a

  async_unix_stream
  unix_connect_a
  unix_bind_a
  unix_listen_a
  unix_accept_a

  addr_resolve_a
  dns_lookup_a
  lookup_host_a
  lookup_results

  socket_options_a
  so_rcvbuf_a
  so_sndbuf_a
  so_reuseaddr_a
  so_reuseport_a
  tcp_fastopen

  half_close_a
  read_half
  write_half
  split_stream
  reunite_stream

  net_timeout_a
  read_timeout
  write_timeout
  connect_timeout_a

  multicast_a
  join_multicast_a
  leave_multicast_a
  set_multicast_ttl_a
  set_multicast_loop_a

  async_net_stdlib
  tcp_server_handler
  udp_server_handler
}

// Semantic direction:
// async_tcp_stream wraps a TCP socket for non-blocking reads and writes.
// tcp_connect_a resolves the address and connects asynchronously, returning when connected.
// tcp_listen_a binds a local address and enables connection acceptance.
// tcp_accept_a waits for a new incoming connection on an async_tcp_listener.
// incoming_stream is an async_stream of accepted async_tcp_streams.
// tcp_read_a fills a buffer from the socket; it parks the task until data arrives.
// tcp_write_a writes a buffer to the socket; it may return a short write if the buffer fills.
// tcp_shutdown_a sends a FIN to the peer (half-close send side).
// split_stream divides an async_tcp_stream into read_half and write_half for independent use.
// addr_resolve_a resolves a hostname asynchronously without blocking the event loop.
// dns_lookup_a returns all resolved addresses for a name.
// so_rcvbuf_a and so_sndbuf_a tune the kernel socket buffer sizes.
// tcp_fastopen reduces connection latency by sending data with the initial SYN.
// half_close_a closes only the sending direction while keeping receive open.
// read_timeout and write_timeout cancel the operation if it exceeds the specified duration.
// connect_timeout_a fails if the TCP handshake doesn't complete in time.
// multicast_a joins a multicast group so the socket receives multicast datagrams.
// tcp_server_handler is a convenience wrapper: accept loop + spawn handler per connection.
// udp_server_handler is a recv loop that dispatches each datagram to a handler function.

// Primitive flow:
// TCP server: tcp_listen_a(addr) -> listener.incoming_stream
//   for await conn in incoming_stream { task_spawn(handle(conn)) }
// TCP client: tcp_connect_a(addr) -> stream
//   stream.tcp_read_a(buf) -> process -> stream.tcp_write_a(response)
// UDP: udp_bind_a(addr) -> loop: udp_recv_from_a(buf) -> process -> udp_send_to_a(reply, src)
// addr_resolve: dns_lookup_a("example.com") -> [IpAddr, ...] -> tcp_connect_a(addr[0])

// This defines async TCP, UDP, and Unix sockets with address resolution,
// socket options, half-close, timeouts, and multicast support.

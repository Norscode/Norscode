// Norscode Runtime - Omgang 225
// Practical VM instruction core

runtime z225 {
  token
  parser
  ast
  instruction
  bytecode

  opcode
  operand
  stack_value
  dispatch
  halt

  value
  integer
  boolean
  string

  environment
  bind
  lookup
  resolve

  evaluate
  compute
  add
  equal

  program
  run
  result
}

// Semantic direction:
// opcode gives bytecode an executable operation identity.
// operand gives instructions attached runtime data.
// stack_value gives the VM a concrete execution stack item.
// dispatch selects behavior for each opcode.
// halt defines the first explicit program completion boundary.

// Primitive flow:
// bytecode -> instruction -> opcode + operand
// -> dispatch -> stack_value
// -> halt -> result

// This continues the practical executable-core path
// toward a minimal VM loop that can eventually execute simple programs.
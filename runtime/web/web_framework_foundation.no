// Norscode Web Framework Foundation
// Middleware + routing + request/response runtime
// Selfhost migration phase

struktur WebRequest
    method
    path
    headers
    body
slutt

struktur WebResponse
    status
    headers
    body
slutt

struktur WebRoute
    method
    path
    handler
slutt

struktur WebMiddleware
    navn
    handler
slutt

struktur WebApp
    routes
    middleware
slutt

funksjon create_web_request(method, path, headers, body)
    la request = WebRequest()

    request.method = method
    request.path = path
    request.headers = headers
    request.body = body

    returner request
slutt

funksjon create_web_response(status, body)
    la response = WebResponse()

    response.status = status
    response.headers = []
    response.body = body

    returner response
slutt

funksjon response_json(body)
    la response = create_web_response(200, body)

    response.headers.push("Content-Type: application/json")

    returner response
slutt

funksjon create_web_route(method, path, handler)
    la route = WebRoute()

    route.method = method
    route.path = path
    route.handler = handler

    returner route
slutt

funksjon create_web_middleware(navn, handler)
    la middleware = WebMiddleware()

    middleware.navn = navn
    middleware.handler = handler

    returner middleware
slutt

funksjon create_web_app()
    la app = WebApp()

    app.routes = []
    app.middleware = []

    returner app
slutt

funksjon web_add_route(app, route)
    hvis app == ingen
        returner usann
    slutt

    app.routes.push(route)

    returner sann
slutt

funksjon web_add_middleware(app, middleware)
    hvis app == ingen
        returner usann
    slutt

    app.middleware.push(middleware)

    returner sann
slutt

funksjon web_match_route(app, request)
    hvis app == ingen
        returner ingen
    slutt

    for route i app.routes
        hvis route.method == request.method
            hvis route.path == request.path
                returner route
            slutt
        slutt
    slutt

    returner ingen
slutt

funksjon web_dispatch_request(app, request)
    hvis app == ingen
        returner create_web_response(500, "App missing")
    slutt

    for middleware i app.middleware
        runtime_call_middleware(middleware, request)
    slutt

    la route = web_match_route(app, request)

    hvis route == ingen
        returner create_web_response(404, "Not found")
    slutt

    returner runtime_call_handler(route.handler, request)
slutt

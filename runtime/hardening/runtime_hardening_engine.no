// Norscode Runtime Hardening Engine
// Production runtime corruption protection
// Selfhost migration phase

struktur RuntimeValidationResult
    success
    reason
slutt

funksjon create_runtime_validation(
    success,
    reason
)
    la result = RuntimeValidationResult()

    result.success = success
    result.reason = reason

    returner result
slutt

funksjon validate_opcode_legality(opcode)
    hvis opcode == ingen
        returner create_runtime_validation(
            usann,
            "Opcode missing"
        )
    slutt

    la allowed = [
        "PUSH",
        "POP",
        "LOAD",
        "STORE",
        "CALL",
        "RETURN",
        "ADD",
        "SUB",
        "MUL",
        "DIV"
    ]

    hvis allowed.includes(opcode) == usann
        returner create_runtime_validation(
            usann,
            "Illegal opcode"
        )
    slutt

    returner create_runtime_validation(
        sann,
        "OK"
    )
slutt

funksjon validate_stack_state(runtime)
    hvis runtime == ingen
        returner create_runtime_validation(
            usann,
            "Runtime missing"
        )
    slutt

    hvis runtime.stack == ingen
        returner create_runtime_validation(
            usann,
            "Stack missing"
        )
    slutt

    hvis runtime.stack.values.length < 0
        returner create_runtime_validation(
            usann,
            "Stack corruption"
        )
    slutt

    returner create_runtime_validation(
        sann,
        "OK"
    )
slutt

funksjon validate_heap_state(runtime)
    hvis runtime == ingen
        returner create_runtime_validation(
            usann,
            "Runtime missing"
        )
    slutt

    hvis runtime.heap == ingen
        returner create_runtime_validation(
            usann,
            "Heap missing"
        )
    slutt

    hvis runtime.heap.objects == ingen
        returner create_runtime_validation(
            usann,
            "Heap corruption"
        )
    slutt

    returner create_runtime_validation(
        sann,
        "OK"
    )
slutt

funksjon validate_frame_state(runtime)
    hvis runtime == ingen
        returner create_runtime_validation(
            usann,
            "Runtime missing"
        )
    slutt

    hvis runtime.current_frame == ingen
        returner create_runtime_validation(
            usann,
            "Frame missing"
        )
    slutt

    returner create_runtime_validation(
        sann,
        "OK"
    )
slutt

funksjon runtime_safe_execute(
    runtime,
    instruction
)
    la opcode_result = validate_opcode_legality(
        instruction.opcode
    )

    hvis opcode_result.success == usann
        runtime_print(
            opcode_result.reason
        )

        returner usann
    slutt

    la stack_result = validate_stack_state(
        runtime
    )

    hvis stack_result.success == usann
        runtime_print(
            stack_result.reason
        )

        returner usann
    slutt

    la heap_result = validate_heap_state(
        runtime
    )

    hvis heap_result.success == usann
        runtime_print(
            heap_result.reason
        )

        returner usann
    slutt

    la frame_result = validate_frame_state(
        runtime
    )

    hvis frame_result.success == usann
        runtime_print(
            frame_result.reason
        )

        returner usann
    slutt

    returner execute_instruction(
        runtime,
        instruction
    )
slutt

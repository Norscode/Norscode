// Norscode Runtime - Omgang 243
// Practical VM parallel execution and worker runtime

runtime z243 {
  vm_state
  execution_loop
  instruction_pointer

  task
  task_id
  task_state
  scheduler
  scheduler_tick
  ready_queue
  blocked_queue

  worker
  worker_id
  worker_pool
  parallel_task
  work_stealing
  shared_queue
  atomic_state
  lock
  unlock
  race_guard

  channel
  send
  receive
  pending_message

  exception
  throw
  catch
}

// Semantic direction:
// worker gives the runtime a parallel execution carrier.
// worker_pool groups workers under scheduler control.
// parallel_task marks tasks that may execute on separate workers.
// work_stealing balances ready tasks between worker queues.
// shared_queue gives workers a coordinated task source.
// atomic_state protects shared runtime transitions.
// lock and unlock define guarded critical sections.
// race_guard describes prevention of unsafe concurrent mutation.

// Primitive flow:
// scheduler -> worker_pool
// -> ready_queue + shared_queue
// -> worker selects parallel_task
// -> atomic_state / lock / race_guard
// -> execute task
// -> channel or result

// This extends cooperative concurrency into primitive parallel execution semantics.
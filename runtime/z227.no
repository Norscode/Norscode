// Norscode Runtime - Omgang 227
// Practical VM constant loading

runtime z227 {
  token
  parser
  ast
  instruction
  bytecode

  opcode
  operand
  instruction_pointer
  fetch
  dispatch
  execute
  halt

  constant
  constant_table
  load_const

  stack_value
  push_stack
  pop_stack

  value
  integer
  boolean
  string

  environment
  bind
  lookup
  resolve

  evaluate
  compute
  add
  equal

  program
  run
  result
  return_result
}

// Semantic direction:
// constant gives bytecode a stable literal value.
// constant_table stores literals outside the instruction stream.
// load_const reads a constant by operand index.
// load_const pushes the selected value onto the VM stack.

// Primitive flow:
// bytecode + constant_table
// -> fetch LOAD_CONST operand
// -> dispatch load_const
// -> constant -> push_stack
// -> stack_value

// This is the first concrete value-loading step needed for a minimal VM program like:
// LOAD_CONST 0
// LOAD_CONST 1
// ADD
// HALT
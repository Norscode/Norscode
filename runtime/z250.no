// Norscode Runtime - Omgang 250
// Practical error propagation and runtime panic recovery

runtime z250 {
  vm_state
  execution_loop

  error
  error_kind
  error_message
  error_source
  error_chain
  error_context

  panic
  panic_payload
  panic_message
  panic_location
  unwind
  unwind_frame
  unwind_stack

  catch_frame
  catch_handler
  catch_scope
  finally_block
  finally_run

  propagate
  bubble
  short_circuit
  question_mark

  result
  ok_value
  err_value
  unwrap
  unwrap_or
  map_err

  guard
  guard_check
  guard_fail
  precondition_violated
  postcondition_violated

  recovery
  recovery_hook
  runtime_fault
  fault_report
  abort
}

// Semantic direction:
// error gives failures a typed, composable representation at runtime.
// error_kind classifies errors by category for pattern matching and routing.
// error_chain links a cause error to a wrapping context error.
// error_context adds contextual detail without replacing the original cause.
// panic signals an unrecoverable condition that must unwind the call stack.
// panic_payload carries the value or message that triggered the panic.
// unwind walks the call stack from the panic site, running finally_blocks.
// unwind_frame describes one activation record visited during unwinding.
// catch_frame marks a stack boundary where unwinding may be intercepted.
// catch_handler executes user code when an error or panic is intercepted.
// finally_block always runs when its enclosing scope exits, normal or not.
// propagate passes an error up the call stack without handling it locally.
// question_mark is syntactic shorthand for propagate on err_value.
// result gives functions a typed Ok/Err return without exceptions.
// unwrap_or provides a default when result is err_value.
// guard_check asserts a runtime invariant; guard_fail raises a typed error.
// recovery_hook registers a last-resort handler for runtime faults.
// fault_report records context before abort for post-mortem inspection.

// Primitive flow:
// execution_loop -> error or panic
// -> panic: unwind_stack -> unwind_frame -> finally_block
// -> catch_frame -> catch_handler
// -> error: propagate or short_circuit
// -> result -> ok_value or err_value
// -> unwrap or map_err or unwrap_or
// -> fault_report -> abort (if unhandled)

// This extends the self-hosted runtime pipeline with practical error propagation
// and panic recovery semantics.

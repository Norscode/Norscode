// Norscode Backend Ecosystem Runtime
// Native backend ecosystem foundation
// Selfhost migration phase

struktur BackendServer
    app
    scheduler
    database
    middleware
    routes
slutt

struktur BackendContext
    request
    response
    session
    database
slutt

funksjon create_backend_server()
    la server = BackendServer()

    server.app = create_web_app()
    server.scheduler = create_async_scheduler()
    server.database = create_database_runtime()
    server.middleware = []
    server.routes = []

    returner server
slutt

funksjon create_backend_context(
    request,
    response,
    session,
    database
)
    la context = BackendContext()

    context.request = request
    context.response = response
    context.session = session
    context.database = database

    returner context
slutt

funksjon backend_register_route(
    server,
    method,
    path,
    handler
)
    hvis server == ingen
        returner usann
    slutt

    la route = create_web_route(
        method,
        path,
        handler
    )

    server.routes.push(route)

    returner web_add_route(
        server.app,
        route
    )
slutt

funksjon backend_register_middleware(
    server,
    middleware
)
    hvis server == ingen
        returner usann
    slutt

    server.middleware.push(middleware)

    returner web_add_middleware(
        server.app,
        middleware
    )
slutt

funksjon backend_execute_request(
    server,
    request
)
    hvis server == ingen
        returner create_web_response(
            500,
            "Backend server missing"
        )
    slutt

    la response = create_web_response(
        200,
        ""
    )

    la context = create_backend_context(
        request,
        response,
        create_session_runtime(),
        server.database
    )

    returner web_dispatch_request(
        server.app,
        context.request
    )
slutt

funksjon backend_start_runtime(server)
    hvis server == ingen
        returner usann
    slutt

    runtime_print(
        "Starting Norscode backend runtime"
    )

    start_async_scheduler(
        server.scheduler
    )

    returner sann
slutt

funksjon backend_run_forever(server)
    hvis backend_start_runtime(server) == usann
        returner usann
    slutt

    runtime_print(
        "Backend ecosystem runtime active"
    )

    returner continuous_selfhost_forever(
        server.scheduler,
        "backend-runtime"
    )
slutt

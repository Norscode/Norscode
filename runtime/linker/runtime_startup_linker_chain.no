// Norscode Runtime Startup Linker Chain
// Deterministic executable bootstrap + replay-safe runtime startup
// Selfhost migration phase

struktur RuntimeBootstrap
    bootstrap_id
    executable_format
    startup_state
    replay_hash
slutt

struktur RuntimeSymbol
    symbol_id
    symbol_name
    resolution_state
    synchronization_hash
slutt

struktur RuntimeRelocation
    relocation_id
    target_symbol
    relocation_state
    execution_hash
slutt

struktur RuntimeLoader
    loader_id
    loaded_executables
    loader_state
    validation_hash
slutt

struktur RuntimeStartupScheduler
    active_bootstraps
    startup_queue
    scheduling_state
slutt

funksjon create_runtime_bootstrap(
    bootstrap_id,
    executable_format,
    replay_hash
)
    la bootstrap = RuntimeBootstrap()

    bootstrap.bootstrap_id = bootstrap_id
    bootstrap.executable_format = executable_format
    bootstrap.startup_state = "initialized"
    bootstrap.replay_hash = replay_hash

    returner bootstrap
slutt

funksjon create_runtime_symbol(
    symbol_id,
    symbol_name,
    synchronization_hash
)
    la symbol = RuntimeSymbol()

    symbol.symbol_id = symbol_id
    symbol.symbol_name = symbol_name
    symbol.resolution_state = "unresolved"
    symbol.synchronization_hash = synchronization_hash

    returner symbol
slutt

funksjon create_runtime_relocation(
    relocation_id,
    target_symbol,
    execution_hash
)
    la relocation = RuntimeRelocation()

    relocation.relocation_id = relocation_id
    relocation.target_symbol = target_symbol
    relocation.relocation_state = "pending"
    relocation.execution_hash = execution_hash

    returner relocation
slutt

funksjon create_runtime_loader(
    loader_id,
    validation_hash
)
    la loader = RuntimeLoader()

    loader.loader_id = loader_id
    loader.loaded_executables = []
    loader.loader_state = "idle"
    loader.validation_hash = validation_hash

    returner loader
slutt

funksjon create_runtime_startup_scheduler()
    la scheduler = RuntimeStartupScheduler()

    scheduler.active_bootstraps = []
    scheduler.startup_queue = []
    scheduler.scheduling_state = "stable"

    returner scheduler
slutt

funksjon runtime_register_bootstrap(
    runtime,
    scheduler,
    bootstrap
)
    hvis runtime == ingen
        returner usann
    slutt

    scheduler.active_bootstraps.push(bootstrap)

    runtime_print(
        "Runtime bootstrap registered"
    )

    returner sann
slutt

funksjon runtime_resolve_symbol(
    runtime,
    symbol,
    relocation
)
    hvis runtime == ingen
        returner usann
    slutt

    symbol.resolution_state = "resolved"
    relocation.relocation_state = "resolved"

    runtime_print(
        "Runtime symbol resolved"
    )

    returner sann
slutt

funksjon runtime_load_executable(
    runtime,
    loader,
    bootstrap
)
    hvis runtime == ingen
        returner usann
    slutt

    loader.loaded_executables.push(bootstrap)
    loader.loader_state = "loaded"

    runtime_print(
        "Runtime executable loaded"
    )

    returner sann
slutt

funksjon runtime_activate_startup(
    runtime,
    bootstrap
)
    hvis runtime == ingen
        returner usann
    slutt

    bootstrap.startup_state = "active"

    runtime_print(
        "Runtime startup activated"
    )

    returner sann
slutt

funksjon runtime_validate_replay(
    runtime,
    bootstrap
)
    hvis runtime == ingen
        returner usann
    slutt

    hvis bootstrap.replay_hash == ingen
        runtime_print(
            "Runtime startup replay validation failed"
        )

        returner usann
    slutt

    runtime_print(
        "Runtime startup replay validated"
    )

    returner sann
slutt

funksjon runtime_linker_forever(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    runtime_print(
        "Runtime startup linker active"
    )

    returner continuous_selfhost_forever(
        runtime.scheduler,
        "runtime-startup-linker"
    )
slutt

// Norscode Runtime - Omgang 398
// Bytecode instruction set and opcode definitions

runtime z398 {
  opcode
  opcode_set
  opcode_version
  opcode_encoding

  op_nop
  op_halt
  op_return
  op_return_val
  op_call
  op_call_method
  op_call_builtin
  op_tail_call

  op_load_const
  op_load_int
  op_load_float
  op_load_bool
  op_load_null
  op_load_string
  op_load_local
  op_store_local
  op_load_global
  op_store_global
  op_load_upvalue
  op_store_upvalue
  op_load_field
  op_store_field
  op_load_index
  op_store_index

  op_add
  op_sub
  op_mul
  op_div
  op_mod
  op_pow
  op_neg

  op_eq
  op_ne
  op_lt
  op_le
  op_gt
  op_ge
  op_and
  op_or
  op_not

  op_jump
  op_jump_if_true
  op_jump_if_false
  op_jump_back
  op_for_iter
  op_for_iter_next

  op_build_list
  op_build_map
  op_build_struct
  op_build_closure
  op_build_tuple

  op_unpack
  op_spread

  op_type_check
  op_cast
  op_is
  op_is_not

  op_throw
  op_try_begin
  op_try_end
  op_catch

  instruction
  instr_opcode
  instr_operand_a
  instr_operand_b
  instr_operand_c
  instr_encoding
  encode_abc
  encode_abx
  encode_asbx
  decode_instr
}

// Semantic direction:
// opcode is the single-byte or multi-byte identifier for one VM operation.
// opcode_version ensures bytecode files are rejected when the opcode set changes.
// op_load_const pushes a constant from the constant pool onto the stack.
// op_load_local reads a local variable from the current stack frame by slot index.
// op_store_local writes the top-of-stack value into a local slot without popping.
// op_load_upvalue reads a captured variable from the enclosing function's upvalue array.
// op_load_field pops an object and a field name and pushes the field value.
// op_call pops argument_count values and the callee, pushes the return value.
// op_tail_call replaces the current frame rather than pushing a new one.
// op_for_iter sets up a list or range iterator; op_for_iter_next advances it.
// op_build_list pops N items and constructs a list value.
// op_build_closure wraps a function prototype with the current upvalue bindings.
// op_try_begin registers a catch address; op_catch is the landing pad after an exception.
// encode_abc packs three 8-bit operands into a 32-bit instruction word.
// encode_abx packs one 8-bit operand A and one 18-bit unsigned operand Bx.
// encode_asbx packs one 8-bit operand A and one 18-bit signed operand sBx (offset from bias).
// decode_instr extracts opcode, A, B, C from a packed instruction word.

// Primitive flow:
// compile: AST node -> emit instruction(s) -> instruction list
//   funksjon call: push args + callee -> op_call(argc)
//   for X i liste: op_for_iter -> loop: op_for_iter_next -> body -> op_jump_back
// execute: fetch instr_opcode -> dispatch table -> handler
//   op_add: pop b, pop a -> push a + b
//   op_jump_if_false: pop cond -> if false: ip += offset

// This defines the Norscode bytecode instruction set: opcodes, operand
// encoding formats, and the full instruction vocabulary.

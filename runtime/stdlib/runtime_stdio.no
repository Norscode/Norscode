// Norscode Runtime Standard IO
// Minimal executable stdlib
// Selfhost migration phase

struktur RuntimeText
    value
slutt

funksjon create_runtime_text(value)
    la text = RuntimeText()

    text.value = value

    returner text
slutt

funksjon runtime_text_concat(left, right)
    hvis left == ingen
        returner ingen
    slutt

    hvis right == ingen
        returner ingen
    slutt

    returner create_runtime_text(
        left.value + right.value
    )
slutt

funksjon runtime_print(value)
    hvis value == ingen
        returner usann
    slutt

    skriv(value)

    returner sann
slutt

funksjon runtime_print_text(text)
    hvis text == ingen
        returner usann
    slutt

    returner runtime_print(
        text.value
    )
slutt

funksjon runtime_print_stack_top(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    la value = stack_peek(runtime.stack)

    hvis value == ingen
        returner usann
    slutt

    returner runtime_print(value)
slutt

funksjon runtime_read_text()
    la line = leslinje()

    returner create_runtime_text(line)
slutt

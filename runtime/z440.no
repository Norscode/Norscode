  jwt_publikum_w

  api_nøkkel_web
  nøkkel_prefix_w
  nøkkel_verifiser_w
  nøkkel_bruker
  nøkkel_omfang_w

  sesjon_web
  sesjon_id_w
  sesjon_bruker
  sesjon_data_w
  sesjon_opprett_w
  sesjon_hent_w
  sesjon_oppdater_w

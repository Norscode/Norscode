// Norscode Runtime - Omgang 286
// Lockfile and reproducible builds

runtime z286 {
  lockfile
  lockfile_path
  lockfile_version
  lockfile_parse
  lockfile_write
  lockfile_error

  locked_package
  locked_name
  locked_version
  locked_source
  locked_checksum
  locked_deps
  locked_features

  source_kind
  source_registry
  source_git
  source_path
  source_url
  source_commit
  source_tag
  source_branch

  checksum
  checksum_algorithm
  sha256
  sha512
  checksum_value
  checksum_verify
  checksum_mismatch

  lock_generate
  lock_from_resolved
  lock_diff
  lock_added
  lock_removed
  lock_changed

  lock_check
  lock_consistent
  lock_stale
  lock_outdated

  reproducible_build
  build_inputs
  build_input_hash
  build_output_hash
  input_manifest
  input_lockfile
  input_source_files
  input_toolchain_version
  deterministic_output
  build_id

  lock_update
  update_policy
  update_all
  update_package
  update_minimal
  update_conservative

  lock_audit
  audit_vulnerability
  audit_advisory
  audit_severity
  audit_patched_version
}

// Semantic direction:
// lockfile is a machine-generated file that pins every dependency to an exact version.
// lockfile_version is the format version of the lock file schema itself.
// locked_package records one resolved package: name, exact version, source, checksum, and deps.
// locked_source distinguishes registry downloads from git checkouts and local paths.
// source_commit pins a git dependency to a specific commit hash for reproducibility.
// locked_checksum is the SHA-256 hash of the downloaded source archive or directory tree.
// checksum_verify recomputes the hash on disk and compares it to locked_checksum.
// checksum_mismatch aborts the build and reports the expected vs actual hash.
// lock_generate creates a fresh lockfile from a resolved_graph.
// lock_from_resolved serializes each dep_node into a locked_package entry.
// lock_diff computes which packages were added, removed, or changed between two lockfiles.
// lock_check verifies that the current manifest's requirements are satisfied by the lockfile.
// lock_stale is raised when the manifest has changed in a way that conflicts with the lockfile.
// reproducible_build verifies that given the same build_inputs the output is byte-identical.
// build_inputs includes the manifest, lockfile, source files, and toolchain version.
// build_input_hash is a combined digest of all build_inputs.
// deterministic_output means the same build_inputs always produce the same build_output_hash.
// build_id is the stable identifier derived from build_input_hash for caching and tracing.
// update_conservative selects the smallest version bump that satisfies updated requirements.
// update_minimal changes only packages that must change to satisfy a new requirement.
// lock_audit scans locked packages against a vulnerability database.
// audit_advisory describes a known vulnerability with its audit_severity and audit_patched_version.

// Primitive flow:
// resolve -> resolved_graph -> lock_generate -> lockfile_write
// nc build: lockfile_parse -> lock_check -> verify all locked_checksums
//   -> checksum_mismatch -> abort with error
// nc update [pkg]: re-resolve with update_policy -> lock_diff -> lockfile_write
// reproducible_build: hash(manifest + lockfile + sources + toolchain) -> build_input_hash
//   -> build -> build_output_hash
//   -> second build -> same build_output_hash -> reproducible confirmed
// audit: locked_packages -> advisory database lookup -> audit_advisory list

// This defines lockfile generation, checksum verification, reproducible builds,
// and vulnerability auditing for the Norscode package manager.

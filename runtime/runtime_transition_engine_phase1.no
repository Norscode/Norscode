# Runtime transition engine phase 1

struktur RuntimeExecutionContinuationLoop
    continuation_inputs
    continuation_cycles
    continuation_outputs
slutt

struktur RuntimeExecutionTransitionEngine
    transition_inputs
    transition_states
    transition_outputs
slutt

funksjon ny_runtime_execution_continuation_loop()
    loop = RuntimeExecutionContinuationLoop()

    loop.continuation_inputs = []
    loop.continuation_cycles = []
    loop.continuation_outputs = []

    returner loop
slutt

funksjon registrer_continuation_input(loop, input)
    legg_til(loop.continuation_inputs, input)
    returner input
slutt

funksjon registrer_continuation_cycle(loop, cycle)
    legg_til(loop.continuation_cycles, cycle)
    returner cycle
slutt

funksjon registrer_continuation_output(loop, output)
    legg_til(loop.continuation_outputs, output)
    returner output
slutt

funksjon ny_runtime_execution_transition_engine()
    engine = RuntimeExecutionTransitionEngine()

    engine.transition_inputs = []
    engine.transition_states = []
    engine.transition_outputs = []

    returner engine
slutt

funksjon registrer_transition_input(engine, input)
    legg_til(engine.transition_inputs, input)
    returner input
slutt

funksjon registrer_transition_state(engine, state)
    legg_til(engine.transition_states, state)
    returner state
slutt

funksjon registrer_transition_output(engine, output)
    legg_til(engine.transition_outputs, output)
    returner output
slutt

// Norscode Runtime - Omgang 283
// norcode.toml package manifest format and project model

runtime z283 {
  manifest
  manifest_path
  manifest_parse
  manifest_error
  manifest_version

  project_section
  project_name
  project_version
  project_description
  project_authors
  project_license
  project_homepage
  project_repository
  project_keywords
  project_edition

  dependencies_section
  dependency_entry
  dep_name
  dep_version_req
  dep_path
  dep_registry
  dep_optional
  dep_features

  dev_dependencies_section
  build_dependencies_section

  features_section
  feature_name
  feature_deps
  feature_enables
  default_features

  workspace_section
  workspace_members
  workspace_root
  workspace_exclude

  build_section
  build_script
  build_target
  build_profile
  profile_debug
  profile_release
  profile_opt_level
  profile_debug_info

  registry_section
  registry_url
  registry_token_env
  registry_default

  package_id
  package_name
  package_version
  package_source

  toml_parse
  toml_value
  toml_table
  toml_array
  toml_string
  toml_integer
  toml_bool
}

// Semantic direction:
// manifest is the parsed contents of one norcode.toml file.
// manifest_path is the file system path where this manifest lives.
// project_section declares the package's identity: name, version, authors, license.
// project_edition selects which language edition rules apply to this package.
// dependencies_section lists the packages this project depends on.
// dependency_entry names one dependency with a version requirement or local path.
// dep_version_req is a SemVer constraint string, e.g. ">=1.2.0, <2.0.0".
// dep_path overrides registry lookup with a local directory dependency.
// dep_optional marks a dependency that is only activated when a feature enables it.
// dev_dependencies_section lists packages only needed for tests and examples.
// build_dependencies_section lists packages needed by the build script.
// features_section declares named feature flags that conditionally enable dependencies.
// feature_enables lists the other features that activating this feature also activates.
// default_features is the list of features enabled unless the caller opts out.
// workspace_section groups multiple packages under one root for unified building.
// workspace_members lists relative paths to member package directories.
// build_section configures compilation options and target profiles.
// profile_opt_level controls optimization: 0 (none), 1, 2, or 3 (maximum).
// registry_section configures which package registry to use and how to authenticate.
// package_id uniquely identifies a package by name, version, and source.
// toml_parse reads a .toml file into a typed toml_value tree.

// Primitive flow:
// project root -> find manifest_path (norcode.toml)
// -> toml_parse -> toml_table
// -> project_section -> package_id (name + version)
// -> dependencies_section -> dependency_entry list
// -> dev_dependencies_section (excluded from release builds)
// -> features_section -> active feature set
// -> registry_section -> registry_url for download
// -> workspace_section -> member manifests loaded recursively

// This establishes the norcode.toml manifest format and project model
// as the foundation of the Norscode package management system.

// Norscode Runtime - Omgang 405
// VM snapshot and serialization

runtime z405 {
  vm_snapshot
  snapshot_id
  snapshot_heap
  snapshot_call_stack
  snapshot_globals
  snapshot_timestamp
  snapshot_lsn_vm
  snapshot_create
  snapshot_restore
  snapshot_diff
  snapshot_size

  heap_serializer
  serialize_object
  serialize_value
  object_ref_id
  ref_table
  write_ref
  read_ref
  intern_string_snap
  cyclic_ref

  call_stack_serializer
  serialize_frame
  serialize_frame_locals
  serialize_upvalue_snap
  frame_ip_snap
  frame_func_ref

  snapshot_format
  snap_magic
  snap_version
  snap_header
  snap_body
  snap_checksum

  restore_heap
  restore_objects
  restore_references
  restore_call_stack
  restore_globals_snap

  incremental_snapshot
  dirty_object

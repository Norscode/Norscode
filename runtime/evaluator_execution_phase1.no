# Evaluator execution phase 1

struktur NativeEvaluatorExecutionPath
    evaluator_inputs
    evaluator_operations
    evaluator_outputs
slutt

struktur ExecutionStackProgressionEngine
    stack_inputs
    stack_frames
    stack_outputs
slutt

funksjon ny_native_evaluator_execution_path()
    evaluator = NativeEvaluatorExecutionPath()

    evaluator.evaluator_inputs = []
    evaluator.evaluator_operations = []
    evaluator.evaluator_outputs = []

    returner evaluator
slutt

funksjon registrer_evaluator_input(evaluator, input)
    legg_til(evaluator.evaluator_inputs, input)
    returner input
slutt

funksjon registrer_evaluator_operation(evaluator, operation)
    legg_til(evaluator.evaluator_operations, operation)
    returner operation
slutt

funksjon registrer_evaluator_output(evaluator, output)
    legg_til(evaluator.evaluator_outputs, output)
    returner output
slutt

funksjon ny_execution_stack_progression_engine()
    stack = ExecutionStackProgressionEngine()

    stack.stack_inputs = []
    stack.stack_frames = []
    stack.stack_outputs = []

    returner stack
slutt

funksjon registrer_stack_input(stack, input)
    legg_til(stack.stack_inputs, input)
    returner input
slutt

funksjon registrer_stack_frame(stack, frame)
    legg_til(stack.stack_frames, frame)
    returner frame
slutt

funksjon registrer_stack_output(stack, output)
    legg_til(stack.stack_outputs, output)
    returner output
slutt

// Norscode Runtime Panic Recovery
// Runtime isolation + deterministic replay
// Selfhost migration phase

struktur RuntimePanicState
    opcode
    stack_snapshot
    heap_snapshot
    frame_snapshot
    object_snapshot
    reason
slutt

funksjon create_runtime_panic_state(
    opcode,
    stack_snapshot,
    heap_snapshot,
    frame_snapshot,
    object_snapshot,
    reason
)
    la state = RuntimePanicState()

    state.opcode = opcode
    state.stack_snapshot = stack_snapshot
    state.heap_snapshot = heap_snapshot
    state.frame_snapshot = frame_snapshot
    state.object_snapshot = object_snapshot
    state.reason = reason

    returner state
slutt

funksjon runtime_capture_panic_state(
    runtime,
    instruction,
    reason
)
    hvis runtime == ingen
        returner ingen
    slutt

    returner create_runtime_panic_state(
        instruction.opcode,
        runtime_hash_stack(runtime),
        runtime_hash_heap(runtime),
        runtime_hash_frames(runtime),
        runtime_hash_objects(runtime),
        reason
    )
slutt

funksjon runtime_store_panic_state(
    runtime,
    panic_state
)
    hvis runtime == ingen
        returner usann
    slutt

    runtime.last_panic = panic_state

    returner sann
slutt

funksjon runtime_restore_snapshot(
    runtime,
    snapshot
)
    hvis runtime == ingen
        returner usann
    slutt

    hvis snapshot == ingen
        returner usann
    slutt

    runtime.recovered_snapshot = snapshot

    returner sann
slutt

funksjon runtime_isolate_panic(
    runtime,
    instruction,
    reason
)
    la panic_state = runtime_capture_panic_state(
        runtime,
        instruction,
        reason
    )

    runtime_store_panic_state(
        runtime,
        panic_state
    )

    runtime_print(
        "Runtime panic isolated"
    )

    returner usann
slutt

funksjon runtime_safe_replay(
    runtime,
    instructions
)
    hvis runtime == ingen
        returner usann
    slutt

    for instruction i instructions
        hvis runtime_safe_execute(
            runtime,
            instruction
        ) == usann
            returner runtime_isolate_panic(
                runtime,
                instruction,
                "Replay execution failed"
            )
        slutt
    slutt

    runtime_print(
        "Replay execution verified"
    )

    returner sann
slutt

funksjon runtime_recover_after_panic(
    runtime,
    snapshot
)
    hvis runtime_restore_snapshot(
        runtime,
        snapshot
    ) == usann
        returner usann
    slutt

    runtime_print(
        "Runtime recovery completed"
    )

    returner sann
slutt

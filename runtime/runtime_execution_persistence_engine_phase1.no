# Runtime execution persistence engine phase 1

struktur ExecutionStatePersistenceOrchestration
    persistence_inputs
    persistence_cycles
    persistence_outputs
slutt

struktur RuntimeExecutionPersistenceEngine
    engine_inputs
    engine_states
    engine_outputs
slutt

funksjon ny_execution_state_persistence_orchestration()
    orchestration = ExecutionStatePersistenceOrchestration()

    orchestration.persistence_inputs = []
    orchestration.persistence_cycles = []
    orchestration.persistence_outputs = []

    returner orchestration
slutt

funksjon registrer_persistence_orchestration_input(orchestration, input)
    legg_til(orchestration.persistence_inputs, input)
    returner input
slutt

funksjon registrer_persistence_orchestration_cycle(orchestration, cycle)
    legg_til(orchestration.persistence_cycles, cycle)
    returner cycle
slutt

funksjon registrer_persistence_orchestration_output(orchestration, output)
    legg_til(orchestration.persistence_outputs, output)
    returner output
slutt

funksjon ny_runtime_execution_persistence_engine()
    engine = RuntimeExecutionPersistenceEngine()

    engine.engine_inputs = []
    engine.engine_states = []
    engine.engine_outputs = []

    returner engine
slutt

funksjon registrer_engine_input(engine, input)
    legg_til(engine.engine_inputs, input)
    returner input
slutt

funksjon registrer_engine_state(engine, state)
    legg_til(engine.engine_states, state)
    returner state
slutt

funksjon registrer_engine_output(engine, output)
    legg_til(engine.engine_outputs, output)
    returner output
slutt

// Norscode Runtime - Omgang 232
// Practical VM heap object and slot execution

runtime z232 {
  vm_state
  execution_loop
  instruction_pointer

  fetch
  dispatch
  execute
  halt

  stack_value
  push_stack
  pop_stack
  stack_top

  heap
  object
  object_id
  field_slot
  allocate_object
  load_field
  store_field

  reference
  dereference

  call_frame
  frame_stack
  local_slot
  load_local
  store_local

  function_table
  call
  return

  read_result
  return_result
}

// Semantic direction:
// heap gives the VM storage beyond local frames and operand stack.
// object_id gives allocated objects stable runtime identity.
// field_slot gives objects named or indexed storage positions.
// allocate_object creates a heap-backed value.
// reference and dereference connect stack/local values to heap objects.
// load_field and store_field give object state concrete VM access.

// Primitive flow:
// allocate_object -> object_id -> reference
// -> store_field / load_field
// -> dereference
// -> stack_value
// -> read_result

// This extends the practical interpreter core from stack + locals
// into heap-backed object/value execution.
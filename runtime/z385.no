// Norscode Runtime - Omgang 385
// TUI forms, text input, and interactive widgets

runtime z385 {
  text_input
  input_value
  input_cursor_pos
  input_visible_start
  input_placeholder
  input_mask
  input_max_len
  input_style_normal
  input_style_focused
  input_handle_key
  input_insert_char
  input_delete_char
  input_delete_prev
  input_move_left
  input_move_right
  input_move_word_left
  input_move_word_right
  input_home_input
  input_end_input
  input_select_all

  textarea
  ta_lines
  ta_cursor_line
  ta_cursor_col
  ta_scroll_t_ta
  ta_handle_key
  ta_insert_newline
  ta_delete_line
  ta_word_wrap
  ta_syntax_highlight

  select_input
  select_options
  select_selected
  select_open
  select_close
  select_search
  select_filtered

  fuzzy_finder
  fuzzy_input
  fuzzy_items
  fuzzy_matched
  fuzzy_score
  fuzzy_highlight
  fuzzy_selected

  confirm_dialog
  confirm_question
  confirm_yes
  confirm_no
  confirm_result

  tui_form
  form_fields_tui
  form_field_tui
  field_label_tui
  field_widget
  field_focused_tui
  field_valid_tui
  field_error_tui
  form_focused_idx
  form_next_field
  form_prev_field
  form_submit_tui
  form_cancel_tui
  form_validate_tui

  file_picker
  picker_cwd
  picker_entries
  picker_selected_fp
  picker_filter
  picker_show_hidden
  picker_navigate_up
  picker_navigate_into
  picker_select_file

  color_picker
  picker_hue
  picker_saturation
  picker_lightness
  picker_preview

  date_input
  date_value
  date_format
  date_navigate
}

// Semantic direction:
// text_input is a single-line editable field; input_cursor_pos is the byte offset of the cursor.
// input_visible_start is the leftmost visible character when the text exceeds the widget width.
// input_mask replaces displayed characters with a substitute (e.g. • for password fields).
// input_move_word_left jumps to the start of the previous word; input_move_word_right jumps to the next.
// input_select_all moves to the start, sets a selection mark, and moves to the end.
// textarea is a multi-line editor; ta_cursor_line and ta_cursor_col track the caret position.
// ta_word_wrap automatically breaks long lines at word boundaries to fit the widget width.
// ta_syntax_highlight applies token-based style_tui values for code editing.
// select_input opens a dropdown of select_options; select_search filters by typed prefix.
// fuzzy_finder shows a text input and a list filtered by fuzzy_score as the user types.
// fuzzy_highlight wraps matching characters in a highlight style within each fuzzy_matched result.
// confirm_dialog asks a yes/no question and returns confirm_result when the user responds.
// tui_form groups multiple form_field_tuis; form_next_field/prev_field moves focus between them.
// form_validate_tui runs validation on each field and populates field_error_tui before submission.
// file_picker navigates the filesystem; picker_navigate_into enters a directory; picker_navigate_up goes up.
// picker_show_hidden toggles whether dotfiles appear in picker_entries.
// picker_selected_fp is the full path of the highlighted entry; pressing Enter confirms selection.
// color_picker lets the user select a color by adjusting hue, saturation, and lightness.
// date_input lets the user enter or navigate a calendar date with arrow key day/month/year adjustment.

// Primitive flow:
// text_input key handling:
//   printable char -> input_insert_char(c) at cursor_pos -> cursor_pos++
//   Backspace -> input_delete_prev -> cursor_pos--
//   Left/Right -> input_move_left/right; Ctrl+Left/Right -> word jump
//   Home/End -> input_home/end
// textarea: Enter -> ta_insert_newline (split line at cursor)
// tui_form focus: Tab -> form_next_field -> form_focused_idx++ -> re-render
//   Enter on submit button -> form_validate_tui -> ok: form_submit or errors displayed
// fuzzy_finder: keystroke -> fuzzy_score all items -> sort by score -> display top N matches
//   Enter -> fuzzy_selected = highlighted item

// This defines TUI interactive input: single-line and multi-line text editing,
// fuzzy finder, select dropdown, confirm dialog, file picker, and form validation.

  ordbok_lengde
  ordbok_er_tom
  ordbok_hent
  ordbok_hent_eller
  ordbok_sett_o
  ordbok_slett_o
  ordbok_har_nøkkel_o
  ordbok_nøkler_o
  ordbok_verdier_o
  ordbok_elementer_o
  ordbok_klar

  ordbok_kart_verdier
  ordbok_filtrer_o
  ordbok_filtrer_nøkler
  ordbok_slå_sammen
  ordbok_oppdater
  ordbok_trekk_fra
  ordbok_behold_nøkler
  ordbok_fjern_nøkler

  ordbok_fra_lister
  ordbok_fra_elementer
  ordbok_til_liste
  ordbok_grupper
  ordbok_inverter

  std_path

  path_join
  path_parent
  path_filnavn
  path_stamme
  path_utvidelse
  path_er_absolutt
  path_er_relativ
  path_normalisér
  path_kanonisér
  path_relativt_til
  path_komponenter
  path_med_utvidelse
  path_uten_utvidelse

  std_fil

  fil_les
  fil_les_tekst
  fil_les_linjer
  fil_les_bytes
  fil_skriv
  fil_skriv_tekst
  fil_legg_til
  fil_kopier
  fil_flytt
  fil_slett
  fil_finnes
  fil_størrelse

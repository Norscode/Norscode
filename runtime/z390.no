  tuple_xmax
  tuple_cmin
  tuple_cmax
  tuple_infomask
  tuple_data

  transaction_id
  txn_id
  txn_snapshot
  snapshot_xmin
  snapshot_xmax
  snapshot_xip
  txn_start_ts
  txn_commit_ts
  txn_status
  status_in_progress
  status_committed
  status_aborted

  txn_manager
  begin_txn
  commit_txn
  abort_txn
  get_snapshot
  txn_context
  current_txn

  visibility
  is_visible
  tuple_visible_to
  xmin_committed
  xmax_committed
  xmin_aborted
  xmax_aborted
  hint_bits

  isolation_level
  read_uncommitted
  read_committed
  repeatable_read
  serializable

  snapshot_isolation
  si_snapshot
  si_read
  si_write_conflict
  write_skew
  phantom_read

  serializable_snapshot
  ssi_rw_conflict
  rw_anti_dependency
  ssi_cycle_detect

// Norscode Runtime - Omgang 256
// Union types and exhaustive pattern matching

runtime z256 {
  type_repr
  type_union

  union_def
  union_name
  variant
  variant_name
  variant_payload
  variant_tag
  variant_index

  union_value
  union_constructor
  tag_value
  payload_value

  match_expr
  match_arm
  match_pattern
  match_guard
  match_body

  pattern
  pattern_variant
  pattern_literal
  pattern_bind
  pattern_wildcard
  pattern_tuple
  pattern_struct

  exhaustiveness
  covered_variants
  uncovered_variant
  redundant_arm
  reachability

  binding
  captured_binding
  binding_type

  union_eq
  union_hash
  union_copy

  match_error
  non_exhaustive
  redundant_pattern
  irrefutable_pattern
}

// Semantic direction:
// union_def declares a named sum type with one or more variants.
// variant gives each alternative a name, an optional payload type, and a stable tag.
// variant_tag is the discriminant stored at runtime to identify which variant is active.
// variant_index is the ordinal used in bytecode for switch dispatch.
// union_value is a runtime value holding a variant_tag and an optional payload_value.
// union_constructor creates a union_value for a named variant with its payload.
// match_expr selects a match_arm whose match_pattern covers the union_value's variant.
// match_arm pairs a match_pattern with an optional match_guard and a match_body.
// match_guard adds an extra boolean condition that must hold for an arm to fire.
// pattern_variant matches a specific variant, optionally binding its payload fields.
// pattern_literal matches a concrete scalar value.
// pattern_bind introduces a new name bound to the matched value in match_body.
// pattern_wildcard accepts any value without binding.
// exhaustiveness verifies that covered_variants includes every variant of the union.
// uncovered_variant reports which variants have no matching arm.
// redundant_arm reports arms that can never be reached given prior arms.
// binding_type gives each captured_binding the type inferred from its pattern.
// non_exhaustive is a compile-time error when match does not cover all variants.
// redundant_pattern is a compile-time warning when an arm can never fire.

// Primitive flow:
// union_def -> variant list -> type_env registration -> type_union
// union_constructor + payload -> union_value with variant_tag
// match_expr -> match arm scan -> variant_tag comparison
// -> pattern check + match_guard evaluation
// -> captured_binding + match_body
// exhaustiveness check: covered_variants vs union_def variants
// -> non_exhaustive error or ok

// Error path:
// match_expr -> non_exhaustive -> list uncovered_variant
// match_arm scan -> redundant_arm warning

// This defines union type declaration, variant construction,
// exhaustive pattern matching, and binding semantics for Norscode.

// Norscode Runtime - Omgang 223
// Primitive existential runtime

runtime z223 {
  planet
  species
  biosphere
  energy
  evolutionary_system

  space
  star_system
  interstellar
  cosmic_network
  universal_model

  origin
  creation
  entropy
  consciousness
  existence
}

// Semantic direction:
// origin gives universal runtime a starting-state model.
// creation describes emergence of structure, agents, worlds, and systems.
// entropy gives long-running runtime evolution a decay and disorder constraint.
// consciousness gives semantic systems a subjective awareness boundary.
// existence gives runtime a highest-level frame for being, persistence, and meaning.

// Primitive flow:
// origin + creation
// -> universal_model + entropy
// -> consciousness + semantic runtime
// -> existence
// -> updated + output

// This marks the transition from primitive cosmic-runtime
// into primitive existential-runtime semantics.
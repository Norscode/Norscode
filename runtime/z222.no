// Norscode Runtime - Omgang 222
// Primitive cosmic runtime

runtime z222 {
  planet
  species
  biosphere
  energy
  evolutionary_system

  space
  star_system
  interstellar
  cosmic_network
  universal_model
}

// Semantic direction:
// space gives planetary runtime a larger spatial coordination frame.
// star_system groups planetary and energy systems into stellar structures.
// interstellar models communication and movement across star systems.
// cosmic_network links distributed civilizations and systems across space.
// universal_model gives runtime a large-scale semantic model of connected reality.

// Primitive flow:
// planet + star_system + interstellar
// -> cosmic_network
// -> universal_model
// -> evolutionary_system + adapt
// -> updated + output

// This marks the transition from primitive planetary-runtime
// into primitive cosmic-runtime semantics.
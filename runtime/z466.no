// Norscode Runtime - Omgang 466
// Monetization: in-app purchases, subscriptions, and ads

runtime z466 {
  monetisering
  mon_konfig
  mon_aktiver
  mon_leverandør
  leverandør_apple
  leverandør_google
  leverandør_stripe
  leverandør_xsolla

  produkt
  produkt_id
  produkt_type
  type_forbruksvare
  type_ikke_forbruksvare
  type_abonnement
  produkt_pris
  produkt_valuta
  produkt_tittel
  produkt_beskrivelse
  produkt_last

  kjøp
  kjøp_start
  kjøp_resultat
  kjøp_suksess
  kjøp_avbrutt
  kjøp_feil
  kjøp_verifiser
  kjøp_bekreft
  kjøp_historikk
  kjøp_gjenopprett

  kvittering
  kvittering_data
  kvittering_url
  kvittering_server_verifiser
  kvittering_gyldig
  kvittering_utløpt
  kvittering_forfalsket

  abonnement
  abonnement_status
  status_aktiv
  status_utløpt
  status_avlyst
  status_prøveperiode
  prøveperiode_dager
  fornyet_dato
  abonnement_avlys
  abonnement_gjenopprett

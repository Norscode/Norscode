# Runtime semantics phase 1

struktur RuntimeStateTransition
    state_inputs
    state_transitions
    state_outputs
slutt

struktur ExecutionSemanticsSkeleton
    semantic_inputs
    semantic_operations
    semantic_results
slutt

funksjon ny_runtime_state_transition()
    transition = RuntimeStateTransition()

    transition.state_inputs = []
    transition.state_transitions = []
    transition.state_outputs = []

    returner transition
slutt

funksjon registrer_runtime_state_input(transition, input)
    legg_til(transition.state_inputs, input)
    returner input
slutt

funksjon registrer_runtime_transition(transition, runtime_state)
    legg_til(transition.state_transitions, runtime_state)
    returner runtime_state
slutt

funksjon registrer_runtime_state_output(transition, output)
    legg_til(transition.state_outputs, output)
    returner output
slutt

funksjon ny_execution_semantics_skeleton()
    semantics = ExecutionSemanticsSkeleton()

    semantics.semantic_inputs = []
    semantics.semantic_operations = []
    semantics.semantic_results = []

    returner semantics
slutt

funksjon registrer_semantic_input(semantics, input)
    legg_til(semantics.semantic_inputs, input)
    returner input
slutt

funksjon registrer_semantic_operation(semantics, operation)
    legg_til(semantics.semantic_operations, operation)
    returner operation
slutt

funksjon registrer_semantic_result(semantics, result)
    legg_til(semantics.semantic_results, result)
    returner result
slutt

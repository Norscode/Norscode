// Norscode Runtime - Omgang 333
// ML inference runtime and tensor operations

runtime z333 {
  inference_runtime
  runtime_backend
  backend_cpu
  backend_gpu
  backend_npu
  backend_wasm

  model
  model_id
  model_path
  model_format
  format_onnx
  format_safetensors
  format_gguf
  model_metadata
  model_load
  model_unload
  model_cache

  tensor
  tensor_shape
  tensor_dtype
  dtype_f32
  dtype_f16
  dtype_bf16
  dtype_i8
  dtype_i32
  tensor_data
  tensor_alloc
  tensor_free
  tensor_copy

  tensor_ops
  op_matmul
  op_add
  op_mul
  op_div
  op_relu
  op_gelu
  op_silu
  op_softmax
  op_layer_norm
  op_rms_norm
  op_transpose
  op_reshape
  op_slice
  op_concat
  op_gather
  op_scatter

  session
  session_options
  session_create
  session_run
  session_input
  session_output
  input_binding
  output_binding

  quantization
  quant_scheme
  quant_int8
  quant_int4
  quant_weight_only
  quant_activation
  quant_scale
  quant_zero_point
  dequantize

  execution_provider
  provider_options
  thread_count
  memory_limit_ml
  device_id
  compute_stream
}

// Semantic direction:
// inference_runtime loads trained models and executes forward passes efficiently.
// runtime_backend selects the compute target: CPU (BLAS), GPU (CUDA/Metal), or NPU.
// model_format determines the serialization: ONNX for portability, GGUF for quantized LLMs.
// model_load deserializes the model and allocates weights in backend memory.
// model_cache keeps recently used models resident to avoid repeated loading.
// tensor is the n-dimensional array that carries data through the computation graph.
// tensor_shape is a list of dimension sizes; dtype_f16 uses half-precision for throughput.
// dtype_bf16 (bfloat16) preserves the dynamic range of f32 while halving memory bandwidth.
// op_matmul is matrix multiplication: the core operation of linear layers.
// op_gelu and op_silu are smooth activation functions used in transformer feed-forward layers.
// op_softmax converts logits to probabilities, normalizing across the last dimension.
// op_layer_norm and op_rms_norm stabilize activations between transformer sub-layers.
// op_gather indexes a tensor by another tensor's values (used for embedding lookup).
// session encapsulates one model loaded for inference, bound to a specific backend.
// input_binding maps named model inputs to tensors; output_binding names result tensors.
// quantization reduces model size and computation by using lower-precision representations.
// quant_int8 stores weights as 8-bit integers with quant_scale and quant_zero_point.
// quant_int4 halves memory further; quant_weight_only leaves activations at full precision.
// dequantize converts quantized values back to float for accumulation.
// thread_count controls intra-op parallelism on the CPU backend.
// compute_stream is a GPU command queue; multiple streams enable overlapped compute.

// Primitive flow:
// model_load(path, format) -> parse weights -> tensor_alloc on backend device
// session_create(model, options) -> bind execution_provider
// inference:
//   input_binding: user data -> tensor(shape, dtype)
//   session_run -> forward pass: op_matmul + op_layer_norm + op_gelu + op_softmax ...
//   output_binding -> result tensor -> copy to CPU if needed
// quantization: weight tensor -> quant_int8(scale, zero_point) -> reduced model_path
//   inference: dequantize weights on-the-fly before op_matmul

// This defines the ML inference runtime: tensor operations, model loading,
// session execution, and quantization for CPU, GPU, and NPU backends.

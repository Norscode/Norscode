// Norscode Runtime - Omgang 198
// Primitive comparison and boolean runtime

runtime z198 {
  state
  context
  session
  scope
  frame
  stack

  push
  pop
  call
  return

  value
  symbol
  bind
  lookup
  resolve
  expression
  compute
  operator
  add
  subtract
  multiply
  divide
  equal
  greater
  less
  boolean

  checkpoint
  store
  load

  validate
  guard
  assert
  constraint
  policy
  capability
  permission
  role

  commit
  rollback

  input
  operation
  evaluate
  iterate
  continue
  repeat
  restart
  resume

  compare
  branch
  select
  merge
  assign
  rule

  updated
  output
}

// Semantic direction:
// equal, greater, and less extend compute from arithmetic into comparison.
// boolean gives comparison results a primitive truth-bearing runtime form.

// Primitive flow:
// value + expression + operator + comparison
// -> boolean
// -> branch/select
// -> updated + output

// This marks the transition from arithmetic computation
// into primitive conditional computation semantics.
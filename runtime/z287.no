// Norscode Runtime - Omgang 287
// Registry protocol and package index

runtime z287 {
  registry
  registry_url
  registry_name
  registry_auth
  auth_token
  auth_header
  auth_bearer
  auth_env_var

  index
  index_url
  index_entry
  index_package
  index_version_list
  index_metadata
  index_cache
  index_etag
  index_last_modified
  index_refresh

  package_metadata
  meta_name
  meta_version
  meta_description
  meta_authors
  meta_license
  meta_keywords
  meta_checksum
  meta_dependencies
  meta_features
  meta_links
  meta_yanked

  registry_request
  request_index
  request_metadata
  request_download
  request_publish
  request_yank
  request_unyank
  request_search
  request_owners

  registry_response
  response_ok
  response_not_found
  response_unauthorized
  response_forbidden
  response_conflict
  response_rate_limited
  response_body
  response_headers

  http_client
  http_get
  http_post
  http_put
  http_delete
  http_header
  http_timeout
  http_retry
  http_retry_delay
  http_user_agent

  search_query
  search_results
  search_result
  result_name
  result_version
  result_description
  result_downloads
  result_score

  yank
  yank_reason
  yanked_version
}

// Semantic direction:
// registry is the remote service that hosts and distributes Norscode packages.
// registry_url is the base URL; all protocol endpoints are relative to it.
// registry_auth authenticates requests using an auth_token from auth_env_var.
// index is the fast-lookup database of available packages and their versions.
// index_entry maps a package name to its index_version_list and index_metadata.
// index_etag and index_last_modified enable conditional HTTP requests to skip re-downloading unchanged data.
// index_refresh fetches updated index data when the cache is stale.
// package_metadata is the full record for one package version: deps, features, checksum, links.
// meta_yanked marks a version that should not be newly installed but may remain in existing lockfiles.
// registry_request covers the full API surface: fetch, publish, search, yank, and owner management.
// request_download fetches the source archive for a specific package version.
// request_publish uploads a new package version with its metadata and archive.
// response_rate_limited signals that the client should pause before retrying.
// http_client is the shared HTTP implementation used by all registry requests.
// http_retry automatically re-sends transient failures up to http_retry count times.
// http_user_agent identifies the nc version in request headers.
// search_query is a free-text or structured search against package names and descriptions.
// search_result carries relevance scoring for ranking results.
// yank marks a published version as unsafe to install; it remains available to existing lockfiles.
// yank_reason is a human-readable message explaining why a version was yanked.

// Primitive flow:
// nc hent: package_name + version_req
//   -> index_cache lookup -> stale? -> http_get index_url -> index_refresh
//   -> index_entry -> filter versions by req_matches
//   -> select_best -> request_metadata -> package_metadata
//   -> verify not yanked -> request_download -> archive bytes
// nc søk query: request_search -> search_results -> print result_name + result_description
// nc publiser: request_publish (z289)
// nc yank: request_yank -> meta_yanked = true

// This defines the registry HTTP protocol, index format, metadata model,
// and search API for the Norscode package distribution system.

// Norscode Runtime - Omgang 461
// Localization and internationalization

runtime z461 {
  lokalisering
  l10n_konfig
  l10n_last
  l10n_språk
  gjeldende_språk
  sett_språk
  system_språk
  reserve_språk

  oversettelse
  oversettelse_nøkkel
  oversettelse_verdi
  oversettelse_katalog
  katalog_format
  format_ftl
  format_json_l10n
  format_gettext
  katalog_last
  katalog_slå_opp

  t_funksjon
  t_nøkkel
  t_variabler
  t_antall
  t_kontekst
  t_mangler
  t_fallback

  flertall
  flertall_regel
  flertall_engelsk
  flertall_norsk
  flertall_arabisk
  flertall_kategori
  kategori_en
  kategori_få

// Norscode Runtime - Omgang 306
// Interactive playground and in-browser WASM execution

runtime z306 {
  playground
  playground_url
  playground_config
  playground_embed
  playground_standalone

  editor
  editor_element
  editor_value
  editor_language
  editor_theme
  editor_font_size
  editor_line_numbers
  editor_minimap
  editor_word_wrap
  editor_change_event

  code_mirror
  codemirror_instance
  codemirror_extensions
  norscode_language_support
  syntax_highlighting_wasm
  autocomplete_wasm
  lint_wasm

  run_button
  run_state
  state_idle
  state_compiling
  state_running
  state_error
  run_shortcut

  wasm_runner
  wasm_compiler_module
  compile_source
  compile_result
  compile_ok
  compile_error
  compile_diagnostics
  execute_wasm
  execution_output
  execution_error
  execution_timeout

  output_panel
  output_text
  output_error_text
  output_clear
  output_scroll
  ansi_color

  share_button
  share_url
  share_encode
  share_decode
  url_compression
  share_gist
  gist_create
  gist_url

  example_picker
  example_list
  example_entry
  example_name
  example_source
  example_description
  load_example

  sandbox
  sandbox_memory_limit
  sandbox_fuel_limit
  sandbox_timeout
  sandbox_io_capture
  sandbox_stdout
  sandbox_stderr
}

// Semantic direction:
// playground is the interactive code execution environment on the documentation site.
// playground_embed is a lightweight version for embedding in documentation pages.
// playground_standalone is the full-page editor at /prøv on the documentation site.
// editor is the browser-side code editor component (CodeMirror 6).
// codemirror_extensions enables Norscode syntax highlighting and autocomplete in the browser.
// norscode_language_support is the CodeMirror language extension loaded from a WASM bundle.
// syntax_highlighting_wasm runs the Norscode lexer in WASM to produce syntax tokens.
// autocomplete_wasm queries the WASM compiler for completion suggestions.
// lint_wasm calls the compiler's type checker in WASM and returns diagnostics as CodeMirror lint markers.
// run_button triggers compilation and execution; run_shortcut is Ctrl+Enter / Cmd+Enter.
// wasm_runner loads the Norscode compiler as a WASM module in the browser.
// compile_source sends the editor_value to the WASM compiler.
// compile_diagnostics are rendered as inline error markers in the editor.
// execute_wasm runs the compiled output in a sandboxed WASM instance.
// sandbox_fuel_limit prevents infinite loops from hanging the browser tab.
// sandbox_io_capture redirects stdout and stderr to the output_panel instead of the console.
// output_panel displays compilation errors and program output below the editor.
// ansi_color renders ANSI escape sequences as colored HTML spans.
// share_button encodes the current source as a compressed URL fragment for sharing.
// share_encode compresses the source with LZ-string and base64-encodes it for the URL.
// share_decode reverses the encoding to restore source from a shared URL.
// share_gist optionally creates a GitHub Gist and returns the gist_url.
// example_picker provides a dropdown of curated example programs.
// load_example replaces the editor_value with the selected example_source.

// Primitive flow:
// page load: wasm_runner.init() -> load compiler WASM module into browser
// editor renders with norscode_language_support
// user types -> lint_wasm -> diagnostics -> CodeMirror annotations
// run_button click:
//   run_state = compiling -> compile_source(editor_value)
//   -> compile_ok: execute_wasm(wasm_bytes, sandbox) -> output_panel
//   -> compile_error: compile_diagnostics -> editor markers + output_error_text
// share_button: share_encode(source) -> URL fragment -> clipboard
// share URL load: share_decode(fragment) -> editor_value set
// example_picker: load_example -> editor_value set -> optional auto-run

// This defines the interactive playground with in-browser WASM compilation,
// sandboxed execution, syntax highlighting, and shareable URLs.

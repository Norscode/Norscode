  prosjekt_manifest
  manifest_navn
  manifest_versjon
  manifest_forfatter
  manifest_lisens
  manifest_beskrivelse
  manifest_avhengigheter
  manifest_byggemål
  manifest_metadata

  kildefiltre
  inkluder_glob
  ekskluder_glob
  kildegruppe
  kildegruppe_navn
  kildegruppe_filer

  kompileringsenheter
  enhet_fil
  enhet_modul
  enhet_avhengighet
  avhengighetsgraf_bygg
  topologisk_rekkefølge
  parallell_kompilering
  kompiler_arbeider

  trinvis_bygg
  bygg_cache
  fil_fingeravtrykk
  avledet_nøkkel
  cache_treff_bygg
  cache_bom_bygg
  cache_ugyldiggjøring

  bygg_skript
  skript_kjøre_før
  skript_kjøre_etter
  skript_kjøre_ved_feil
  kodegenerering
  generer_fra_skjema
  generer_fra_proto
  generer_fra_openapi

  kryssplattform
  mål_plattform
  plattform_linux
  plattform_macos
  plattform_windows
  plattform_wasm
  plattform_android
  plattform_ios
  plattform_betingelse

  prosjektmal
  mal_katalog

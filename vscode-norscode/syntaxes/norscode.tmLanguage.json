{
  "scopeName": "source.norscode",
  "name": "Norscode",
  "patterns": [
    {
      "match": "\\b(hvis|ellers|mens|funksjon|returner|slutt)\\b",
      "name": "keyword.control.norscode"
    },
    {
      "match": "\\b(sann|usann|null)\\b",
      "name": "constant.language.norscode"
    },
    {
      "match": "\".*?\"",
      "name": "string.quoted.double.norscode"
    },
    {
      "match": "\\b[0-9]+\\b",
      "name": "constant.numeric.norscode"
    }
  ]
}

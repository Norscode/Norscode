{
  "scopeName": "source.norscode",
  "name": "Norscode",
  "patterns": [
    {
      "match": "(#|//).*$",
      "name": "comment.line.number-sign.norscode"
    },
    {
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.norscode"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.norscode"
        }
      },
      "name": "string.quoted.double.norscode",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.norscode"
        }
      ]
    },
    {
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.norscode"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.norscode"
        }
      },
      "name": "string.quoted.single.norscode",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.norscode"
        }
      ]
    },
    {
      "match": "\\b(?:funksjon)\\s+([[:alpha:]_][[:alnum:]_]*)",
      "captures": {
        "1": {
          "name": "entity.name.function.norscode"
        }
      }
    },
    {
      "match": "\\b(?:struktur|type)\\s+([[:alpha:]_][[:alnum:]_]*)",
      "captures": {
        "1": {
          "name": "entity.name.type.norscode"
        }
      }
    },
    {
      "match": "\\b(?:la|var|variabel|som)\\s+([[:alpha:]_][[:alnum:]_]*)",
      "captures": {
        "1": {
          "name": "variable.other.readwrite.norscode"
        }
      }
    },
    {
      "match": "\\b(hvis|viss|ellers|ellers_hvis|mens|medan|for|i|funksjon|returner|slutt|bruk|import|med|som|struktur|type|prøv|fang|kast|fortsett|bryt|da)\\b",
      "name": "keyword.control.norscode"
    },
    {
      "match": "\\b(sann|usann|true|false|null|ingen)\\b",
      "name": "constant.language.norscode"
    },
    {
      "match": "(:|->)\\s*([[:alpha:]_][[:alnum:]_]*(?:[.<][[:alpha:]_][[:alnum:]_]*>?)*)",
      "captures": {
        "1": {
          "name": "punctuation.separator.norscode"
        },
        "2": {
          "name": "support.type.norscode"
        }
      }
    },
    {
      "match": "\\b(heltall|heiltall|tekst|bool|boolsk|liste(?:_[[:alnum:]_]+)?|ordbok(?:_[[:alnum:]_]+)?|map|float|desimal|number|string)\\b",
      "name": "support.type.norscode"
    },
    {
      "match": "\\b(bruk|import)\\s+([[:alpha:]_][[:alnum:]_]*(?:\\.[[:alpha:]_][[:alnum:]_]*)*)",
      "captures": {
        "1": {
          "name": "keyword.control.import.norscode"
        },
        "2": {
          "name": "support.module.norscode"
        }
      }
    },
    {
      "match": "\\b([[:alpha:]_][[:alnum:]_]*)\\s*(?=\\()",
      "name": "entity.name.function.call.norscode"
    },
    {
      "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?\\b",
      "name": "constant.numeric.norscode"
    },
    {
      "match": "[+\\-*/%=!<>]=?|&&|\\|\\||\\.|,|:|;|\\(|\\)|\\{|\\}|\\[|\\]|<|>",
      "name": "punctuation.separator.norscode"
    },
    {
      "match": "\\b(and|og|eller|ikkje|ikke)\\b",
      "name": "keyword.operator.logical.norscode"
    }
  ]
}

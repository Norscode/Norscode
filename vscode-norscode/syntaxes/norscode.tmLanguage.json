{
  "scopeName": "source.norscode",
  "name": "Norscode",
  "patterns": [
    {
      "match": "#.*$",
      "name": "comment.line.number-sign.norscode"
    },
    {
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.norscode"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.norscode"
        }
      },
      "name": "string.quoted.double.norscode",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.norscode"
        }
      ]
    },
    {
      "match": "\\b(?:la|var|variabel|som)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "variable.other.readwrite.norscode"
        }
      }
    },
    {
      "match": "\\b(hvis|ellers|ellers_hvis|mens|for|i|funksjon|returner|slutt|sann|usann|null|bruk|med|type)\\b",
      "name": "keyword.control.norscode"
    },
    {
      "match": "\\b(?:la|var|variabel)\\s+[A-Za-z_][A-Za-z0-9_]*\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
      "captures": {
        "1": {
          "name": "support.type.norscode"
        }
      }
    },
    {
      "match": "->\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
      "captures": {
        "1": {
          "name": "support.type.norscode"
        }
      }
    },
    {
      "match": "\\b(heltall|tekst|bool|liste(?:_[A-Za-z0-9_]+)?|ordbok|map|float|desimal|number|string)\\b",
      "name": "support.type.norscode"
    },
    {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.norscode"
    },
    {
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b",
      "name": "constant.numeric.norscode"
    },
    {
      "match": "[+\\-*/%=!<>]=?|&&|\\|\\||\\.|,|:|;|\\(|\\)|\\{|\\}|\\[|\\]",
      "name": "punctuation.separator.norscode"
    },
    {
      "match": "\\b(and|eller|ikkje|ikke)\\b",
      "name": "keyword.operator.logical.norscode"
    },
    {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.norscode"
    }
  ]
}

{
  "name": "norscode",
  "displayName": "Norscode",
  "description": "Norscode language support",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "norscode",
        "aliases": ["Norscode"],
        "extensions": [".no"]
      }
    ],
    "grammars": [
      {
        "language": "norscode",
        "scopeName": "source.norscode",
        "path": "./syntaxes/norscode.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "norscode-file-icons",
        "label": "Norscode File Icons",
        "path": "./file-icons/norscode-file-icons.json"
      }
    ],
    "configurationDefaults": {
      "[norscode]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "variable.other.readwrite.norscode",
              "settings": {
                "foreground": "#9CDCFE"
              }
            },
            {
              "scope": [
                "storage.type.norscode",
                "support.type.norscode"
              ],
              "settings": {
                "foreground": "#4EC9B0",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "entity.name.type.norscode",
              "settings": {
                "foreground": "#4FC1FF",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "entity.name.function.norscode",
              "settings": {
                "foreground": "#DCDCAA"
              }
            },
            {
              "scope": "string.quoted.double.norscode",
              "settings": {
                "foreground": "#CE9178"
              }
            }
          ]
        }
      }
    }
  }
}

# Native stdlib and production toolchain foundation

# =========================
# Native stdlib
# =========================

funksjon stdlib_io_module()
    returner {
        name: "io",
        exports: [
            "print",
            "read_file",
            "write_file"
        ]
    }
slutt

funksjon stdlib_memory_module()
    returner {
        name: "memory",
        exports: [
            "allocate",
            "free",
            "copy"
        ]
    }
slutt

funksjon stdlib_strings_module()
    returner {
        name: "strings",
        exports: [
            "concat",
            "length",
            "slice"
        ]
    }
slutt

funksjon stdlib_runtime_module()
    returner {
        name: "runtime",
        exports: [
            "panic",
            "spawn",
            "exit"
        ]
    }
slutt

funksjon native_stdlib()
    returner {
        modules: [
            stdlib_io_module(),
            stdlib_memory_module(),
            stdlib_strings_module(),
            stdlib_runtime_module()
        ]
    }
slutt

# =========================
# Incremental compiler
# =========================

funksjon incremental_unit(path, checksum)
    returner {
        path: path,
        checksum: checksum,
        compiled: usann
    }
slutt

funksjon incremental_cache()
    returner {
        units: {}
    }
slutt

funksjon incremental_track(cache, path, checksum)
    cache.units[path] = incremental_unit(
        path,
        checksum
    )
slutt

funksjon incremental_should_compile(cache, path, checksum)
    unit = cache.units[path]

    hvis unit == null
        returner sann
    slutt

    returner unit.checksum != checksum
slutt

funksjon incremental_mark_compiled(cache, path)
    hvis cache.units[path] != null
        cache.units[path].compiled = sann
    slutt
slutt

# =========================
# Package manager
# =========================

funksjon package(name, version)
    returner {
        name: name,
        version: version,
        dependencies: []
    }
slutt

funksjon package_registry()
    returner {
        packages: {}
    }
slutt

funksjon package_publish(registry, pkg)
    registry.packages[pkg.name] = pkg
slutt

funksjon package_install(registry, name)
    returner registry.packages[name]
slutt

funksjon package_add_dependency(pkg, dep)
    legg_til(pkg.dependencies, dep)
slutt

# =========================
# Full bootstrap chain
# =========================

funksjon bootstrap_stage(name)
    returner {
        name: name,
        completed: usann
    }
slutt

funksjon bootstrap_chain()
    returner {
        stages: [
            bootstrap_stage("stage0_parser"),
            bootstrap_stage("stage1_semantic"),
            bootstrap_stage("stage2_ir"),
            bootstrap_stage("stage3_native_backend"),
            bootstrap_stage("stage4_selfhost")
        ]
    }
slutt

funksjon bootstrap_complete(chain, stage_name)
    indeks = 0

    mens indeks < lengde(chain.stages)
        stage = chain.stages[indeks]

        hvis stage.name == stage_name
            stage.completed = sann
        slutt

        indeks = indeks + 1
    slutt
slutt

funksjon bootstrap_validate(chain)
    indeks = 0

    mens indeks < lengde(chain.stages)
        hvis chain.stages[indeks].completed == usann
            returner usann
        slutt

        indeks = indeks + 1
    slutt

    returner sann
slutt

# =========================
# Production selfhosting
# =========================

funksjon selfhost_compiler(version)
    returner {
        version: version,
        selfhosted: usann,
        backend: "native"
    }
slutt

funksjon selfhost_compile(compiler, source)
    compiler.last_source = source
    compiler.selfhosted = sann

    returner {
        success: sann,
        backend: compiler.backend
    }
slutt

funksjon selfhost_validate(compiler)
    returner compiler.selfhosted
slutt

# =========================
# Integrated production toolchain
# =========================

funksjon production_toolchain()
    registry = package_registry()

    stdlib = native_stdlib()

    compiler = selfhost_compiler("0.1")

    incremental = incremental_cache()

    bootstrap = bootstrap_chain()

    returner {
        stdlib: stdlib,
        packages: registry,
        compiler: compiler,
        incremental: incremental,
        bootstrap: bootstrap
    }
slutt

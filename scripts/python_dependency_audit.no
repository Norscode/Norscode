// scripts/python_dependency_audit.no — bygg Python-auditrapport i Norscode
//
// Forventa miljo:
//   NC_PY_AUDIT_TOOLS   newline-separert liste over .py-filer i tools/
//   NC_PY_AUDIT_REPO    newline-separert liste over .py-filer i repoet
//   NC_PY_AUDIT_OUTPUT  rapportfil

funksjon trim_linjer(inn: tekst) -> liste {
    la linjer = builtin.split(inn, "\n")
    la ut = []
    la i = 0
    mens i < lengde(linjer) {
        la linje = builtin.trim(linjer[i])
        hvis lengde(linje) > 0 {
            legg_til(ut, linje)
        }
        i = i + 1
    }
    returner ut
}

funksjon join_linjer(linjer: liste) -> tekst {
    hvis lengde(linjer) == 0 {
        returner ""
    }
    returner builtin.join(linjer, "\n")
}

funksjon bygg_rapport(tools_py: liste, repo_py: liste) -> tekst {
    la rapport = "=== Norscode Python Dependency Report ===\n\n"

    rapport = rapport + "Python files in tools/ (skal vere 0 i normal flyt): "
    rapport = rapport + tekst_fra_heltall(lengde(tools_py)) + "\n"
    hvis lengde(tools_py) > 0 {
        rapport = rapport + join_linjer(tools_py) + "\n"
    }

    rapport = rapport + "\nPython files in repo (ekskl. .git): "
    rapport = rapport + tekst_fra_heltall(lengde(repo_py)) + "\n"
    hvis lengde(repo_py) > 0 {
        rapport = rapport + join_linjer(repo_py) + "\n"
    }

    rapport = rapport + "\nTip: Bruk bash tools/no_c_python_active_surface.sh for full normal/legacy-surface policy.\n"
    rapport = rapport + "Note: rapporten kan innehalde Python i archive/scripts som er tillate per policy.\n"
    returner rapport
}

funksjon start() -> heltall {
    la tools_raw = miljo_hent("NC_PY_AUDIT_TOOLS")
    la repo_raw = miljo_hent("NC_PY_AUDIT_REPO")
    la output = miljo_hent("NC_PY_AUDIT_OUTPUT")

    hvis output == "" {
        kast "Manglar NC_PY_AUDIT_OUTPUT"
    }

    la tools_py = trim_linjer(tools_raw)
    la repo_py = trim_linjer(repo_raw)
    la rapport = bygg_rapport(tools_py, repo_py)
    fil_skriv(output, rapport)

    skriv("Dependency audit written to: " + output + "\n")

    hvis lengde(tools_py) > 0 {
        skriv("Feil: Python i tools/ er ikkje tillatt i normal flyt. Sjå " + output + "\n")
        returner 1
    }

    skriv("OK: ingen Python i tools/\n")
    returner 0
}

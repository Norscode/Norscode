// scripts/regen_fraser.no — regenerer fraser-tabell i selfhost/common.no
// Erstatter scripts/gen_expr_fraser.py  (Omgang 5)
//
// Køyr frå repo-rot:
//   ./bin/nc run scripts/regen_fraser.no
//   ./bin/nc regen-fraser

// ─── Filterdata ───────────────────────────────────────────────────────────────

funksjon hopp_over_substring_liste() -> liste {
    returner ["hvis ", " if ", " da ", " then ", " else ", "&&", "||", "==",
              "ellers_hvis", "elif ", "elseif "]
}

funksjon reserverte_fraser_liste() -> liste {
    returner ["xor", "xnor", "nand", "nor", "og", "eller", "enten", "samt",
              "and", "or", "not", "ikkje", "ikke", "and_not", "og_ikke",
              "or_not", "eller_ikke", "pluss", "minus", "ganger", "delt",
              "lik", "div", "storre_enn", "mindre_enn",
              "storre_enn_eller_lik", "mindre_enn_eller_lik"]
}

funksjon logiske_fraser_ord_liste() -> liste {
    returner ["og", "eller", "enten", "samt", "and", "or", "not",
              "ikkje", "ikke", "sann", "usann", "sant", "usant",
              "ja", "nei", "true", "false", "yes", "no", "on", "off"]
}

funksjon gte_lte_substring_liste() -> liste {
    returner ["eller_lik", "enn_eller_lik", "ikke_er",
              "ermindre", "erstorre", "mindreenn", "storreenn",
              "mindrelik", "storrelik", "mindre lik", "storre lik",
              "mindre_lik", "storre_lik", "er storre lik",
              "er mindre lik", " enn lik", "ellerlik",
              "less_equal", "greater_equal"]
}

funksjon symbolske_fraser_liste() -> liste {
    returner ["<=", ">=", "<>", "==", "!=", "&&", "||", "->", "=>",
              "<->", "<=>", "<-", "+", "-", "*", "/", "%", "<", ">",
              "(", ")", "mod", "div", "eq", "add", "iff", "as"]
}

// ─── Hjelpefunksjonar ────────────────────────────────────────────────────────

funksjon er_i_liste(lst: liste, verdi: tekst) -> boolsk {
    la i: heltall = 0
    mens i < lengde(lst) {
        hvis lst[i] == verdi { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon ascii_fold(s: tekst) -> tekst {
    la r = builtin.replace(s, "på", "paa")
    r = builtin.replace(r, "På", "Paa")
    r = builtin.replace(r, "pÃ¥", "paa")
    r = builtin.replace(r, "større", "storre")
    r = builtin.replace(r, "Større", "Storre")
    r = builtin.replace(r, "stÃ¸rre", "storre")
    r = builtin.replace(r, "ø", "o")
    r = builtin.replace(r, "Ø", "O")
    r = builtin.replace(r, "æ", "ae")
    r = builtin.replace(r, "å", "aa")
    r = builtin.replace(r, "Å", "Aa")
    returner r
}

funksjon er_siffer_ch(ch: tekst) -> boolsk {
    returner ch >= "0" og ch <= "9"
}

funksjon er_tall_token(s: tekst) -> boolsk {
    hvis lengde(s) == 0 { returner usann }
    la start: heltall = 0
    hvis builtin.slice(s, 0, 1) == "-" {
        hvis lengde(s) == 1 { returner usann }
        start = 1
    }
    la i = start
    mens i < lengde(s) {
        hvis ikke er_siffer_ch(builtin.slice(s, i, i + 1)) { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon frase_fra_uttrykk(expr: tekst) -> tekst {
    la deler = builtin.split(ascii_fold(expr), " ")
    la beholdte = []
    la i: heltall = 0
    mens i < lengde(deler) {
        la del = builtin.trim(deler[i])
        hvis lengde(del) > 0 og ikke er_tall_token(del) {
            legg_til(beholdte, del)
        }
        i = i + 1
    }
    returner builtin.join(beholdte, " ")
}

funksjon frase_ok(frase: tekst) -> boolsk {
    hvis lengde(frase) < 2 { returner usann }
    la lav = builtin.lower(frase)
    la hopp = hopp_over_substring_liste()
    la i: heltall = 0
    mens i < lengde(hopp) {
        hvis builtin.contains(lav, hopp[i]) { returner usann }
        i = i + 1
    }
    la ord = builtin.split(lav, " ")
    hvis lengde(ord) == 1 og er_i_liste(reserverte_fraser_liste(), lav) { returner usann }
    la logiske = logiske_fraser_ord_liste()
    la j: heltall = 0
    mens j < lengde(ord) {
        hvis er_i_liste(logiske, ord[j]) { returner usann }
        j = j + 1
    }
    hvis builtin.contains(lav, " and not ") { returner usann }
    hvis builtin.contains(lav, " og ikke ")  { returner usann }
    hvis builtin.contains(lav, " og ikkje ") { returner usann }
    hvis lav == "equal to" eller lav == "equal_to" { returner usann }
    hvis builtin.contains(lav, "not equal")   { returner usann }
    hvis builtin.contains(lav, "not_equal")   { returner usann }
    hvis builtin.contains(lav, "greater than") { returner usann }
    hvis builtin.contains(lav, "greater_than") { returner usann }
    hvis builtin.contains(lav, "less than")    { returner usann }
    hvis builtin.contains(lav, "less_than")    { returner usann }
    hvis builtin.contains(lav, " or equal")    { returner usann }
    hvis builtin.contains(lav, "_or_equal")    { returner usann }
    hvis builtin.contains(lav, "or_equal")     { returner usann }
    la gte_lte = gte_lte_substring_liste()
    la k: heltall = 0
    mens k < lengde(gte_lte) {
        hvis builtin.contains(lav, gte_lte[k]) { returner usann }
        k = k + 1
    }
    returner sann
}

// ─── IR-analyse ───────────────────────────────────────────────────────────────

funksjon er_stor_bokstav_streng(s: tekst) -> boolsk {
    hvis lengde(s) == 0 { returner usann }
    la i: heltall = 0
    mens i < lengde(s) {
        la ch = builtin.slice(s, i, i + 1)
        hvis ch < "A" eller ch > "Z" { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon hent_opkoder_fra_ir(ir: tekst) -> liste {
    la deler = builtin.split(ir, "\\n")
    la opkoder = []
    la i: heltall = 0
    mens i < lengde(deler) {
        la del = deler[i]
        la kpos = index_of(del, ": ")
        hvis kpos >= 0 {
            la etter = builtin.slice(del, kpos + 2, lengde(del))
            la spos = index_of(etter, " ")
            la op: tekst
            hvis spos < 0 { op = etter }
            ellers         { op = builtin.slice(etter, 0, spos) }
            hvis er_stor_bokstav_streng(op) {
                legg_til(opkoder, op)
            }
        }
        i = i + 1
    }
    returner opkoder
}

funksjon ir_hopp_over(opkoder: liste) -> boolsk {
    hvis er_i_liste(opkoder, "SWAP") { returner sann }
    la i: heltall = 1
    mens i < lengde(opkoder) {
        la curr = opkoder[i]
        la prev = opkoder[i - 1]
        hvis curr == "NOT" og (prev == "EQ" eller prev == "AND" eller prev == "OR") {
            returner sann
        }
        i = i + 1
    }
    returner usann
}

// Meiningsfull liste for IMPLIED_BY-sjekk (Python sin hovudløkke): BEHOLD NOT
// Python: skip_ops = {"PUSH","PRINT","HALT","SWAP","LABEL","JMP","JZ"} (NOT ikkje fjerna)
funksjon meiningsfull_for_implied_by_siste_to(opkoder: liste) -> liste {
    la hopp = ["PUSH", "PRINT", "HALT", "SWAP", "LABEL", "JMP", "JZ"]
    la ut = []
    la i: heltall = 0
    mens i < lengde(opkoder) {
        hvis ikke er_i_liste(hopp, opkoder[i]) {
            legg_til(ut, opkoder[i])
        }
        i = i + 1
    }
    returner ut
}

// Meiningsfull liste for opcode-bestemmelse (opcode_from_expected): FJERN NOT
funksjon meiningsfull_for_opcode(opkoder: liste) -> liste {
    la hopp = ["PUSH", "PRINT", "HALT", "SWAP", "NOT", "LABEL", "JMP", "JZ"]
    la ut = []
    la i: heltall = 0
    mens i < lengde(opkoder) {
        hvis ikke er_i_liste(hopp, opkoder[i]) {
            legg_til(ut, opkoder[i])
        }
        i = i + 1
    }
    returner ut
}

funksjon opcode_fra_ir(opkoder: liste) -> tekst {
    la meiningsfull = meiningsfull_for_opcode(opkoder)
    la n = lengde(meiningsfull)
    hvis n == 0 { returner "" }
    hvis n >= 2 {
        la ns = meiningsfull[n - 2]
        la si = meiningsfull[n - 1]
        hvis ns == "LT" og si == "NOT" { returner "GTE" }
        hvis ns == "GT" og si == "NOT" { returner "LTE" }
    }
    returner meiningsfull[n - 1]
}

funksjon symbol_fra_opcode(op: tekst) -> tekst {
    hvis op == "ADD" { returner "+" }
    hvis op == "SUB" { returner "-" }
    hvis op == "MUL" { returner "*" }
    hvis op == "DIV" { returner "/" }
    hvis op == "MOD" { returner "%" }
    hvis op == "EQ"  { returner "==" }
    hvis op == "GT"  { returner ">" }
    hvis op == "LT"  { returner "<" }
    hvis op == "AND" { returner "&&" }
    hvis op == "OR"  { returner "||" }
    returner ""
}

// ─── Tekstparsing ─────────────────────────────────────────────────────────────

funksjon trekk_ut_uttrykk(linje: tekst) -> tekst {
    la prefiks = "disasm_uttrykk(\""
    la pos = index_of(linje, prefiks)
    hvis pos < 0 { returner "" }
    la fra = pos + lengde(prefiks)
    la resten = builtin.slice(linje, fra, lengde(linje))
    la slutt = index_of(resten, "\"")
    hvis slutt < 0 { returner "" }
    returner builtin.slice(resten, 0, slutt)
}

funksjon trekk_ut_ir(linje: tekst) -> tekst {
    la pos = index_of(linje, ", \"")
    hvis pos < 0 { returner "" }
    la fra = pos + 3
    la resten = builtin.slice(linje, fra, lengde(linje))
    la n = lengde(resten)
    la i = n - 1
    mens i >= 0 {
        hvis builtin.slice(resten, i, i + 1) == "\"" {
            returner builtin.slice(resten, 0, i)
        }
        i = i - 1
    }
    returner ""
}

// ─── Sortering ────────────────────────────────────────────────────────────────

// Sorter etter (-lengde, alfabetisk) — same som Python: key=lambda kv: (-len(kv[0]), kv[0])
// Bruker seleksjonssort utan INDEX_SET for å unngå stabel-akkumulering i VM.
funksjon sorter_fraser(lst: liste) -> liste {
    // Lag ein kopi me kan mutere (via legg_til, ikkje INDEX_SET)
    la rest = []
    la i: heltall = 0
    mens i < lengde(lst) {
        legg_til(rest, lst[i])
        i = i + 1
    }
    la sortert = []
    mens lengde(rest) > 0 {
        // Finn indeks til beste gjenværande element
        la best_idx: heltall = 0
        la best_frase = rest[0]["frase"]
        la best_len = lengde(best_frase)
        la j: heltall = 1
        mens j < lengde(rest) {
            la frase = rest[j]["frase"]
            la len = lengde(frase)
            la er_bedre = usann
            hvis len > best_len          { er_bedre = sann }
            ellers hvis len == best_len og frase < best_frase { er_bedre = sann }
            hvis er_bedre {
                best_idx = j
                best_frase = frase
                best_len = len
            }
            j = j + 1
        }
        legg_til(sortert, rest[best_idx])
        // Bygg ny rest utan best_idx (legg_til i staden for INDEX_SET)
        la ny_rest = []
        la k: heltall = 0
        mens k < lengde(rest) {
            hvis k != best_idx {
                legg_til(ny_rest, rest[k])
            }
            k = k + 1
        }
        rest = ny_rest
    }
    returner sortert
}

// ─── Kodegenerering ──────────────────────────────────────────────────────────

funksjon norscode_tekst_literal(s: tekst) -> tekst {
    la esc = builtin.replace(s, "\\", "\\\\")
    esc = builtin.replace(esc, "\"", "\\\"")
    esc = builtin.replace(esc, "\n", "\\n")
    // Tab-teikn vert ståande som literal (same som Python sin norscode_string)
    returner "\"" + esc + "\""
}

funksjon bygg_biter(fraser_liste: liste) -> liste {
    la biter = []
    la gjeldande_rader = []
    la gjeldande_len: heltall = 0
    la i: heltall = 0
    mens i < lengde(fraser_liste) {
        la rad = fraser_liste[i]["frase"] + "\t" + fraser_liste[i]["sym"]
        la rad_len = lengde(rad) + 1
        hvis gjeldande_len + rad_len > 3500 og lengde(gjeldande_rader) > 0 {
            legg_til(biter, builtin.join(gjeldande_rader, "\n"))
            gjeldande_rader = []
            gjeldande_len = 0
        }
        legg_til(gjeldande_rader, rad)
        gjeldande_len = gjeldande_len + rad_len
        i = i + 1
    }
    hvis lengde(gjeldande_rader) > 0 {
        legg_til(biter, builtin.join(gjeldande_rader, "\n"))
    }
    returner biter
}

funksjon bygg_faste_template_funksjonar(n_biter: heltall) -> tekst {
    la t = ""
    t = t + "funksjon kopier_frase_tabell(tab: tekst) -> tekst {\n"
    t = t + "    la linjer = tekst_splitt(tab, \"\\n\")\n"
    t = t + "    la out: tekst = \"\"\n"
    t = t + "    la i: heltall = 0\n"
    t = t + "    mens (i < lengde(linjer)) {\n"
    t = t + "        hvis (i > 0) {\n"
    t = t + "            out = out + \"\\n\"\n"
    t = t + "        }\n"
    t = t + "        out = out + kopier_tekst(linjer[i])\n"
    t = t + "        i = i + 1\n"
    t = t + "    }\n"
    t = t + "    returner out\n"
    t = t + "}\n\n"
    t = t + "funksjon erstatt_fraser_i_tabell(s: tekst, tab: tekst) -> tekst {\n"
    t = t + "    la tab_kopi: tekst = kopier_frase_tabell(tab)\n"
    t = t + "    la linjer = tekst_splitt(tab_kopi, \"\\n\")\n"
    t = t + "    la i: heltall = 0\n"
    t = t + "    mens (i < lengde(linjer)) {\n"
    t = t + "        la linje: tekst = linjer[i]\n"
    t = t + "        hvis (lengde(linje) > 0) {\n"
    t = t + "            la deler = tekst_splitt(linje, \"\\t\")\n"
    t = t + "            hvis (lengde(deler) == 2) {\n"
    t = t + "                la frase: tekst = kopier_tekst(deler[0])\n"
    t = t + "                la sym: tekst = kopier_tekst(deler[1])\n"
    t = t + "                s = replace_i_tekst(s, \" \" + frase + \" \", \" \" + sym + \" \")\n"
    t = t + "            }\n"
    t = t + "        }\n"
    t = t + "        i = i + 1\n"
    t = t + "    }\n"
    t = t + "    returner s\n"
    t = t + "}\n\n"
    t = t + "funksjon normaliser_expr_ascii(expr: tekst) -> tekst {\n"
    t = t + "    la s: tekst = expr + \"\"\n"
    t = t + "    s = replace_i_tekst(s, \"på\", \"paa\")\n"
    t = t + "    s = replace_i_tekst(s, \"På\", \"Paa\")\n"
    t = t + "    s = replace_i_tekst(s, \"pÃ¥\", \"paa\")\n"
    t = t + "    s = replace_i_tekst(s, \"større\", \"storre\")\n"
    t = t + "    s = replace_i_tekst(s, \"Større\", \"Storre\")\n"
    t = t + "    s = replace_i_tekst(s, \"stÃ¸rre\", \"storre\")\n"
    t = t + "    s = replace_i_tekst(s, \"ø\", \"o\")\n"
    t = t + "    s = replace_i_tekst(s, \"Ø\", \"O\")\n"
    t = t + "    s = replace_i_tekst(s, \"æ\", \"ae\")\n"
    t = t + "    s = replace_i_tekst(s, \"å\", \"aa\")\n"
    t = t + "    s = replace_i_tekst(s, \"Å\", \"Aa\")\n"
    t = t + "    returner s\n"
    t = t + "}\n\n"
    t = t + "funksjon erstatt_uttrykk_fraser(expr: tekst) -> tekst {\n"
    t = t + "    la s: tekst = \" \" + normaliser_expr_ascii(expr) + \" \"\n"
    la j: heltall = 0
    mens j < n_biter {
        t = t + "    s = erstatt_fraser_i_tabell(s, uttrykk_frase_tabell_del" + tekst_fra_heltall(j) + "())\n"
        j = j + 1
    }
    t = t + "    returner tekst_trim(s)\n"
    t = t + "}\n"
    returner t
}

funksjon bygg_blokk(biter: liste) -> tekst {
    la n = lengde(biter)
    la ut = "# Auto-generated by scripts/regen_fraser.no — do not edit by hand\n\n"
    la i: heltall = 0
    mens i < n {
        ut = ut + "funksjon uttrykk_frase_tabell_del" + tekst_fra_heltall(i) + "() -> tekst {\n"
        ut = ut + "    returner " + norscode_tekst_literal(biter[i]) + "\n"
        ut = ut + "}\n\n"
        i = i + 1
    }
    ut = ut + "funksjon uttrykk_frase_tabell() -> tekst {\n"
    hvis n == 1 {
        ut = ut + "    returner uttrykk_frase_tabell_del0()\n"
    } ellers {
        la deler_str = ""
        la j: heltall = 0
        mens j < n {
            hvis j > 0 { deler_str = deler_str + " + \"\\n\" + " }
            deler_str = deler_str + "uttrykk_frase_tabell_del" + tekst_fra_heltall(j) + "()"
            j = j + 1
        }
        ut = ut + "    returner " + deler_str + "\n"
    }
    ut = ut + "}\n\n"
    ut = ut + bygg_faste_template_funksjonar(n)
    returner ut
}

// ─── Hovudfunksjon ────────────────────────────────────────────────────────────

funksjon start() {
    la test_sti   = "tests/test_selfhost.no"
    la common_sti = "selfhost/common.no"

    la innhald  = fil_les(test_sti)
    la linjer   = builtin.split(innhald, "\n")
    la n_linjer = lengde(linjer)

    la frase_til_sym = {}
    la symbolske  = symbolske_fraser_liste()
    la reserverte = reserverte_fraser_liste()

    la i: heltall = 0
    mens i < n_linjer - 1 {
        la linje = linjer[i]
        la neste  = linjer[i + 1]

        hvis builtin.contains(linje, "disasm_uttrykk(\"") og builtin.contains(neste, "assert_eq(") {
            la expr = trekk_ut_uttrykk(linje)
            la ir   = trekk_ut_ir(neste)

            hvis lengde(expr) > 0 og lengde(ir) > 0 {
                hvis builtin.contains(expr, " ") eller builtin.contains(expr, "_") {
                    la opkoder = hent_opkoder_fra_ir(ir)

                    hvis ikke ir_hopp_over(opkoder) {
                        // Hopp over IMPLIED_BY (<-): NOT..OR sist i meiningsfull (MED NOT)
                        la m_for_implied = meiningsfull_for_implied_by_siste_to(opkoder)
                        la implied_by = usann
                        hvis lengde(m_for_implied) >= 2 {
                            la mlen = lengde(m_for_implied)
                            hvis m_for_implied[mlen - 2] == "NOT" og m_for_implied[mlen - 1] == "OR" {
                                implied_by = sann
                            }
                        }

                        hvis ikke implied_by {
                            la op  = opcode_fra_ir(opkoder)
                            la sym = symbol_fra_opcode(op)
                            hvis lengde(sym) > 0 {
                                la frase = frase_fra_uttrykk(expr)
                                hvis frase_ok(frase) og ikke er_i_liste(reserverte, frase) og ikke er_i_liste(symbolske, frase) {
                                    hvis finnes_nøkkel(frase_til_sym, frase) {
                                        hvis frase_til_sym[frase] != sym {
                                            kast "Frase-konflikt: " + frase + ": " + frase_til_sym[frase] + " vs " + sym
                                        }
                                    } ellers {
                                        frase_til_sym[frase] = sym
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }

    // Bygg sortert liste av {frase, sym}
    la alle_fraser = nøkler(frase_til_sym)
    la fraser_liste = []
    la j: heltall = 0
    mens j < lengde(alle_fraser) {
        la f = alle_fraser[j]
        legg_til(fraser_liste, {"frase": f, "sym": frase_til_sym[f]})
        j = j + 1
    }
    fraser_liste = sorter_fraser(fraser_liste)

    la n_fraser = lengde(fraser_liste)
    skriv("Fann " + tekst_fra_heltall(n_fraser) + " fraser\n")

    la biter = bygg_biter(fraser_liste)
    skriv("Bitar: " + tekst_fra_heltall(lengde(biter)) + "\n")

    la ny_blokk = bygg_blokk(biter)

    // Oppdater selfhost/common.no
    la common_innhald = fil_les(common_sti)
    la BEGIN = "# BEGIN_EXPR_FRASER"
    la END   = "# END_EXPR_FRASER"
    la bpos  = index_of(common_innhald, BEGIN)
    la epos  = index_of(common_innhald, END)
    hvis bpos < 0 { kast "Manglar " + BEGIN + " i " + common_sti }
    hvis epos < 0 { kast "Manglar " + END   + " i " + common_sti }
    la for_blokk   = builtin.slice(common_innhald, 0, bpos)
    la etter_blokk = builtin.slice(common_innhald, epos + lengde(END), lengde(common_innhald))
    fil_skriv(common_sti, for_blokk + BEGIN + "\n" + ny_blokk + END + etter_blokk)
    skriv("Oppdaterte " + common_sti + " (" + tekst_fra_heltall(n_fraser) + " fraser, "
          + tekst_fra_heltall(lengde(biter)) + " del(ar))\n")
}

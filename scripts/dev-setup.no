// scripts/dev-setup.no — utvikleroppsett for lokal Norscode checkout

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }

    hvis ikkje run(shell(root + "/bin/nc") + " run " + shell(root + "/tools/build-bootstrap-binary.no")) { returner 1 }

    linje("")
    linje("Norscode er klar.")
    linje("Kjør CLI med: ./bin/nc run app.no")
    linje("")
    linje("Tips:")
    linje("  ./bin/nc run app.no          # kjør en Norscode-fil")
    linje("  ./bin/nc build app.no ut.elf # bygg til native binary")
    linje("  ./bin/nc test                # kjør tester")
    linje("")
    linje("For å jobbe på kompilatoren selv: bruk native bootstrap-verktøyene i tools/")
    returner 0
}

# Native executable emission pipeline

# =========================
# Machine code encoding
# =========================

funksjon machine_encoder(arch)
    returner {
        arch: arch,
        bytes: []
    }
slutt

funksjon encode_byte(encoder, value)
    legg_til(encoder.bytes, value)
slutt

funksjon encode_bytes(encoder, values)
    indeks = 0

    mens indeks < lengde(values)
        encode_byte(encoder, values[indeks])
        indeks = indeks + 1
    slutt
slutt

funksjon x86_encode_instruction(encoder, instr)
    hvis instr.op == "mov"
        encode_bytes(encoder, [0x48, 0x89])
        returner
    slutt

    hvis instr.op == "add"
        encode_bytes(encoder, [0x48, 0x01])
        returner
    slutt

    hvis instr.op == "sub"
        encode_bytes(encoder, [0x48, 0x29])
        returner
    slutt

    hvis instr.op == "call"
        encode_bytes(encoder, [0xe8])
        returner
    slutt

    hvis instr.op == "ret"
        encode_bytes(encoder, [0xc3])
        returner
    slutt
slutt

funksjon arm64_encode_instruction(encoder, instr)
    hvis instr.op == "mov"
        encode_bytes(encoder, [0xaa, 0x00, 0x03, 0xe0])
        returner
    slutt

    hvis instr.op == "add"
        encode_bytes(encoder, [0x8b, 0x00, 0x00, 0x00])
        returner
    slutt

    hvis instr.op == "sub"
        encode_bytes(encoder, [0xcb, 0x00, 0x00, 0x00])
        returner
    slutt

    hvis instr.op == "blr"
        encode_bytes(encoder, [0xd6, 0x3f, 0x00, 0x00])
        returner
    slutt

    hvis instr.op == "ret"
        encode_bytes(encoder, [0xd6, 0x5f, 0x03, 0xc0])
        returner
    slutt
slutt

# =========================
# ELF Writer
# =========================

funksjon elf_writer()
    returner {
        format: "ELF",
        sections: [],
        symbols: []
    }
slutt

funksjon elf_header()
    returner [
        0x7f,
        0x45,
        0x4c,
        0x46
    ]
slutt

funksjon elf_emit(writer, machine_program)
    encoder = machine_encoder(machine_program.arch)

    blokk_indeks = 0

    mens blokk_indeks < lengde(machine_program.blocks)
        block = machine_program.blocks[blokk_indeks]

        instr_indeks = 0

        mens instr_indeks < lengde(block.instructions)
            instr = block.instructions[instr_indeks]

            x86_encode_instruction(encoder, instr)

            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt

    returner {
        header: elf_header(),
        text: encoder.bytes
    }
slutt

# =========================
# Mach-O Writer
# =========================

funksjon macho_writer()
    returner {
        format: "Mach-O",
        segments: []
    }
slutt

funksjon macho_header()
    returner [
        0xcf,
        0xfa,
        0xed,
        0xfe
    ]
slutt

funksjon macho_emit(writer, machine_program)
    encoder = machine_encoder(machine_program.arch)

    blokk_indeks = 0

    mens blokk_indeks < lengde(machine_program.blocks)
        block = machine_program.blocks[blokk_indeks]

        instr_indeks = 0

        mens instr_indeks < lengde(block.instructions)
            instr = block.instructions[instr_indeks]

            arm64_encode_instruction(encoder, instr)

            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt

    returner {
        header: macho_header(),
        text: encoder.bytes
    }
slutt

# =========================
# PE Writer
# =========================

funksjon pe_writer()
    returner {
        format: "PE/COFF",
        sections: []
    }
slutt

funksjon pe_header()
    returner [
        0x50,
        0x45,
        0x00,
        0x00
    ]
slutt

funksjon pe_emit(writer, machine_program)
    encoder = machine_encoder(machine_program.arch)

    blokk_indeks = 0

    mens blokk_indeks < lengde(machine_program.blocks)
        block = machine_program.blocks[blokk_indeks]

        instr_indeks = 0

        mens instr_indeks < lengde(block.instructions)
            instr = block.instructions[instr_indeks]

            x86_encode_instruction(encoder, instr)

            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt

    returner {
        header: pe_header(),
        text: encoder.bytes
    }
slutt

# =========================
# Linker groundwork
# =========================

funksjon linker_symbol(name, address)
    returner {
        name: name,
        address: address
    }
slutt

funksjon linker()
    returner {
        objects: [],
        symbols: {}
    }
slutt

funksjon linker_add_object(linker_obj, object_file)
    legg_til(linker_obj.objects, object_file)
slutt

funksjon linker_define(linker_obj, name, address)
    linker_obj.symbols[name] = linker_symbol(name, address)
slutt

funksjon linker_resolve(linker_obj, name)
    returner linker_obj.symbols[name]
slutt

funksjon linker_link(linker_obj)
    executable = []

    indeks = 0

    mens indeks < lengde(linker_obj.objects)
        obj = linker_obj.objects[indeks]

        hvis obj.header != null
            legg_til(executable, obj.header)
        slutt

        hvis obj.text != null
            legg_til(executable, obj.text)
        slutt

        indeks = indeks + 1
    slutt

    returner executable
slutt

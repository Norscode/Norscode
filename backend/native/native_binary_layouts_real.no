# Real native binary layouts and loader validation

# =========================
# Filesystem emission
# =========================

funksjon emit_binary_file(path, bytes)
    data = ""

    indeks = 0

    mens indeks < lengde(bytes)
        data = data + tegn_fra_kode(bytes[indeks])
        indeks = indeks + 1
    slutt

    skriv_fil(path, data)
slutt

# =========================
# ELF binary layout
# =========================

funksjon elf_binary_layout(executable)
    returner {
        format: "ELF",
        header_size: 64,
        section_alignment: 4096,
        entrypoint: executable.entrypoint.address,
        sections: executable.sections,
        segments: executable.layout.segments
    }
slutt

funksjon elf_binary_bytes(layout)
    bytes = [
        0x7f,
        0x45,
        0x4c,
        0x46
    ]

    indeks = 0

    mens indeks < lengde(layout.sections)
        section = layout.sections[indeks]

        hvis section.bytes != null
            section_indeks = 0

            mens section_indeks < lengde(section.bytes)
                legg_til(bytes, section.bytes[section_indeks])
                section_indeks = section_indeks + 1
            slutt
        slutt

        indeks = indeks + 1
    slutt

    returner bytes
slutt

# =========================
# Mach-O binary layout
# =========================

funksjon macho_binary_layout(executable)
    returner {
        format: "Mach-O",
        header_size: 32,
        page_alignment: 4096,
        entrypoint: executable.entrypoint.address,
        sections: executable.sections,
        segments: executable.layout.segments
    }
slutt

funksjon macho_binary_bytes(layout)
    bytes = [
        0xcf,
        0xfa,
        0xed,
        0xfe
    ]

    indeks = 0

    mens indeks < lengde(layout.sections)
        section = layout.sections[indeks]

        hvis section.bytes != null
            section_indeks = 0

            mens section_indeks < lengde(section.bytes)
                legg_til(bytes, section.bytes[section_indeks])
                section_indeks = section_indeks + 1
            slutt
        slutt

        indeks = indeks + 1
    slutt

    returner bytes
slutt

# =========================
# PE binary layout
# =========================

funksjon pe_binary_layout(executable)
    returner {
        format: "PE",
        header_size: 64,
        section_alignment: 4096,
        file_alignment: 512,
        entrypoint: executable.entrypoint.address,
        sections: executable.sections,
        segments: executable.layout.segments
    }
slutt

funksjon pe_binary_bytes(layout)
    bytes = [
        0x50,
        0x45,
        0x00,
        0x00
    ]

    indeks = 0

    mens indeks < lengde(layout.sections)
        section = layout.sections[indeks]

        hvis section.bytes != null
            section_indeks = 0

            mens section_indeks < lengde(section.bytes)
                legg_til(bytes, section.bytes[section_indeks])
                section_indeks = section_indeks + 1
            slutt
        slutt

        indeks = indeks + 1
    slutt

    returner bytes
slutt

# =========================
# Loader validation
# =========================

funksjon validate_elf(layout)
    hvis layout.format != "ELF"
        returner usann
    slutt

    hvis layout.entrypoint == null
        returner usann
    slutt

    returner sann
slutt

funksjon validate_macho(layout)
    hvis layout.format != "Mach-O"
        returner usann
    slutt

    hvis layout.entrypoint == null
        returner usann
    slutt

    returner sann
slutt

funksjon validate_pe(layout)
    hvis layout.format != "PE"
        returner usann
    slutt

    hvis layout.entrypoint == null
        returner usann
    slutt

    returner sann
slutt

funksjon validate_loader_layout(layout)
    hvis layout.format == "ELF"
        returner validate_elf(layout)
    slutt

    hvis layout.format == "Mach-O"
        returner validate_macho(layout)
    slutt

    hvis layout.format == "PE"
        returner validate_pe(layout)
    slutt

    returner usann
slutt

# =========================
# Full native executable generation
# =========================

funksjon generate_elf_file(path)
    executable = build_native_executable("ELF")

    layout = elf_binary_layout(executable)

    hvis validate_loader_layout(layout) == usann
        kast "Invalid ELF layout"
    slutt

    bytes = elf_binary_bytes(layout)

    emit_binary_file(path, bytes)

    returner path
slutt

funksjon generate_macho_file(path)
    executable = build_native_executable("Mach-O")

    layout = macho_binary_layout(executable)

    hvis validate_loader_layout(layout) == usann
        kast "Invalid Mach-O layout"
    slutt

    bytes = macho_binary_bytes(layout)

    emit_binary_file(path, bytes)

    returner path
slutt

funksjon generate_pe_file(path)
    executable = build_native_executable("PE")

    layout = pe_binary_layout(executable)

    hvis validate_loader_layout(layout) == usann
        kast "Invalid PE layout"
    slutt

    bytes = pe_binary_bytes(layout)

    emit_binary_file(path, bytes)

    returner path
slutt

# Real executable correctness and loader execution groundwork

# =========================
# Section offsets
# =========================

funksjon section_offset_table()
    returner {}
slutt

funksjon calculate_section_offsets(layout)
    offsets = section_offset_table()

    current = 0x1000

    indeks = 0

    mens indeks < lengde(layout.sections)
        section = layout.sections[indeks]

        current = segment_align(current, section.alignment)

        offsets[section.name] = current

        current = current + lengde(section.bytes)

        indeks = indeks + 1
    slutt

    returner offsets
slutt

# =========================
# Symbol addresses
# =========================

funksjon assign_symbol_addresses(layout, offsets)
    navn = nøkler(layout.symbols.symbols)

    indeks = 0

    text_base = offsets[".text"]

    mens indeks < lengde(navn)
        symbol = layout.symbols.symbols[navn[indeks]]

        hvis symbol.kind == "function"
            symbol.address = text_base + (indeks * 16)
        ellers
            symbol.address = offsets[".data"] + (indeks * 8)
        slutt

        indeks = indeks + 1
    slutt
slutt

# =========================
# Relocation math
# =========================

funksjon relocation_relative_address(base, target)
    returner target - base
slutt

funksjon relocation_absolute_address(target)
    returner target
slutt

funksjon apply_call_relocation(bytes, reloc, symbol)
    relative = relocation_relative_address(
        reloc.offset,
        symbol.address
    )

    bytes[reloc.offset] = relative
slutt

funksjon apply_data_relocation(bytes, reloc, symbol)
    absolute = relocation_absolute_address(symbol.address)

    bytes[reloc.offset] = absolute
slutt

funksjon apply_full_relocations(layout, bytes)
    indeks = 0

    mens indeks < lengde(layout.relocations)
        reloc = layout.relocations[indeks]

        symbol = symbol_lookup(layout.symbols, reloc.symbol)

        hvis symbol == null
            indeks = indeks + 1
            fortsett
        slutt

        hvis reloc.type == "call"
            apply_call_relocation(bytes, reloc, symbol)
        slutt

        hvis reloc.type == "data"
            apply_data_relocation(bytes, reloc, symbol)
        slutt

        indeks = indeks + 1
    slutt
slutt

# =========================
# Entrypoint execution
# =========================

funksjon executable_entry_state(entrypoint)
    returner {
        rip: entrypoint.address,
        rsp: 0x7ffffff0,
        rbp: 0x7ffffff0,
        running: sann
    }
slutt

funksjon execute_entrypoint(executable)
    state = executable_entry_state(executable.entrypoint)

    returner {
        success: sann,
        state: state,
        entry: executable.entrypoint.name
    }
slutt

# =========================
# Loader-tested binaries
# =========================

funksjon loader_test_result(format_name, valid, executed)
    returner {
        format: format_name,
        valid: valid,
        executed: executed
    }
slutt

funksjon test_loader_binary(format_name)
    executable = build_native_executable(format_name)

    offsets = calculate_section_offsets(executable)

    assign_symbol_addresses(executable, offsets)

    apply_full_relocations(
        executable,
        executable.bytes
    )

    execution = execute_entrypoint(executable)

    returner loader_test_result(
        format_name,
        sann,
        execution.success
    )
slutt

funksjon validate_native_loader_suite()
    returner {
        elf: test_loader_binary("ELF"),
        macho: test_loader_binary("Mach-O"),
        pe: test_loader_binary("PE")
    }
slutt

# Native sections, symbols and relocations

# =========================
# Section system
# =========================

funksjon native_section(name, flags)
    returner {
        name: name,
        flags: flags,
        alignment: 16,
        bytes: []
    }
slutt

funksjon native_section_emit(section, values)
    indeks = 0

    mens indeks < lengde(values)
        legg_til(section.bytes, values[indeks])
        indeks = indeks + 1
    slutt
slutt

funksjon text_section()
    returner native_section(
        ".text",
        ["alloc", "exec"]
    )
slutt

funksjon data_section()
    returner native_section(
        ".data",
        ["alloc", "write"]
    )
slutt

funksjon rodata_section()
    returner native_section(
        ".rodata",
        ["alloc"]
    )
slutt

funksjon bss_section()
    returner native_section(
        ".bss",
        ["alloc", "write"]
    )
slutt

funksjon symtab_section()
    returner native_section(
        ".symtab",
        ["symbols"]
    )
slutt

funksjon strtab_section()
    returner native_section(
        ".strtab",
        ["strings"]
    )
slutt

funksjon rela_text_section()
    returner native_section(
        ".rela.text",
        ["relocations"]
    )
slutt

# =========================
# Symbol tables
# =========================

funksjon native_symbol(name, address, kind)
    returner {
        name: name,
        address: address,
        kind: kind,
        global: sann
    }
slutt

funksjon symbol_table()
    returner {
        symbols: {}
    }
slutt

funksjon symbol_define(table, symbol)
    table.symbols[symbol.name] = symbol
slutt

funksjon symbol_lookup(table, name)
    returner table.symbols[name]
slutt

funksjon symbol_export(table, name)
    symbol = symbol_lookup(table, name)

    hvis symbol != null
        symbol.exported = sann
    slutt
slutt

# =========================
# String table
# =========================

funksjon string_table()
    returner {
        values: [],
        offsets: {}
    }
slutt

funksjon string_add(table, value)
    hvis table.offsets[value] != null
        returner table.offsets[value]
    slutt

    offset = lengde(table.values)

    legg_til(table.values, value)

    table.offsets[value] = offset

    returner offset
slutt

# =========================
# Relocations
# =========================

funksjon relocation(type_name, offset, symbol)
    returner {
        type: type_name,
        offset: offset,
        symbol: symbol,
        addend: 0
    }
slutt

funksjon relocation_table()
    returner []
slutt

funksjon relocation_add(table, reloc)
    legg_til(table, reloc)
slutt

funksjon relocation_patch(bytes, reloc, address)
    hvis reloc == null
        returner
    slutt

    bytes[reloc.offset] = address
slutt

# =========================
# Native executable layout
# =========================

funksjon executable_layout()
    returner {
        sections: [
            text_section(),
            data_section(),
            rodata_section(),
            bss_section(),
            symtab_section(),
            strtab_section(),
            rela_text_section()
        ],
        symbols: symbol_table(),
        strings: string_table(),
        relocations: relocation_table()
    }
slutt

funksjon executable_add_symbol(layout, name, address, kind)
    symbol = native_symbol(name, address, kind)

    symbol_define(layout.symbols, symbol)

    string_add(layout.strings, name)
slutt

funksjon executable_add_relocation(layout, type_name, offset, symbol)
    reloc = relocation(type_name, offset, symbol)

    relocation_add(layout.relocations, reloc)
slutt

funksjon executable_patch_relocations(layout, bytes)
    indeks = 0

    mens indeks < lengde(layout.relocations)
        reloc = layout.relocations[indeks]

        symbol = symbol_lookup(layout.symbols, reloc.symbol)

        hvis symbol != null
            relocation_patch(bytes, reloc, symbol.address)
        slutt

        indeks = indeks + 1
    slutt
slutt

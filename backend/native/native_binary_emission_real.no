# Real native binary emission

# =========================
# Binary writers
# =========================

funksjon binary_writer(format_name)
    returner {
        format: format_name,
        bytes: []
    }
slutt

funksjon binary_emit(writer, value)
    legg_til(writer.bytes, value)
slutt

funksjon binary_emit_many(writer, values)
    indeks = 0

    mens indeks < lengde(values)
        binary_emit(writer, values[indeks])
        indeks = indeks + 1
    slutt
slutt

# =========================
# Section serialization
# =========================

funksjon serialize_section(writer, section)
    hvis section == null
        returner
    slutt

    hvis section.bytes == null
        returner
    slutt

    binary_emit_many(writer, section.bytes)
slutt

funksjon serialize_sections(writer, layout)
    indeks = 0

    mens indeks < lengde(layout.sections)
        serialize_section(writer, layout.sections[indeks])
        indeks = indeks + 1
    slutt
slutt

# =========================
# Symbol emission
# =========================

funksjon symbol_record(symbol)
    returner {
        name: symbol.name,
        address: symbol.address,
        kind: symbol.kind
    }
slutt

funksjon emit_symbol(writer, symbol)
    record = symbol_record(symbol)

    binary_emit_many(writer, [
        record.address
    ])
slutt

funksjon emit_symbols(writer, layout)
    navn = nøkler(layout.symbols.symbols)

    indeks = 0

    mens indeks < lengde(navn)
        symbol = layout.symbols.symbols[navn[indeks]]

        emit_symbol(writer, symbol)

        indeks = indeks + 1
    slutt
slutt

# =========================
# Relocation patching
# =========================

funksjon patch_call_relocation(bytes, reloc, symbol)
    hvis symbol == null
        returner
    slutt

    bytes[reloc.offset] = symbol.address
slutt

funksjon patch_jump_relocation(bytes, reloc, symbol)
    hvis symbol == null
        returner
    slutt

    bytes[reloc.offset] = symbol.address
slutt

funksjon apply_relocations(layout, bytes)
    indeks = 0

    mens indeks < lengde(layout.relocations)
        reloc = layout.relocations[indeks]

        symbol = symbol_lookup(layout.symbols, reloc.symbol)

        hvis reloc.type == "call"
            patch_call_relocation(bytes, reloc, symbol)
        slutt

        hvis reloc.type == "jump"
            patch_jump_relocation(bytes, reloc, symbol)
        slutt

        indeks = indeks + 1
    slutt
slutt

# =========================
# Entrypoint generation
# =========================

funksjon executable_entrypoint(name, address)
    returner {
        name: name,
        address: address,
        exported: sann
    }
slutt

funksjon generate_entrypoint(layout)
    entry = executable_entrypoint("_start", 0x401000)

    executable_add_symbol(
        layout,
        entry.name,
        entry.address,
        "function"
    )

    returner entry
slutt

funksjon emit_runtime_startup(section)
    native_section_emit(section, [
        0x55,
        0x48,
        0x89,
        0xe5
    ])
slutt

# =========================
# Full executable emission
# =========================

funksjon build_native_executable(format_name)
    layout = executable_layout()

    entry = generate_entrypoint(layout)

    text = layout.sections[0]

    emit_runtime_startup(text)

    executable_add_relocation(
        layout,
        "call",
        1,
        entry.name
    )

    writer = binary_writer(format_name)

    serialize_sections(writer, layout)

    emit_symbols(writer, layout)

    apply_relocations(layout, writer.bytes)

    returner {
        format: format_name,
        entrypoint: entry,
        bytes: writer.bytes,
        relocations: layout.relocations
    }
slutt

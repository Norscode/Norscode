# WASM binary emission

funksjon wasm_binary()
    returner []
slutt

funksjon wasm_emit_byte(output, value)
    legg_til(output, value)
slutt

funksjon wasm_emit_bytes(output, values)
    indeks = 0

    mens indeks < lengde(values)
        wasm_emit_byte(output, values[indeks])
        indeks = indeks + 1
    slutt
slutt

funksjon wasm_emit_magic(output)
    wasm_emit_bytes(output, [0x00, 0x61, 0x73, 0x6d])
slutt

funksjon wasm_emit_version(output)
    wasm_emit_bytes(output, [0x01, 0x00, 0x00, 0x00])
slutt

funksjon wasm_encode_leb128(value)
    bytes = []
    current = value

    mens sann
        byte = current & 0x7f
        current = current >> 7

        hvis current != 0
            byte = byte | 0x80
        slutt

        legg_til(bytes, byte)

        hvis current == 0
            bryt
        slutt
    slutt

    returner bytes
slutt

funksjon wasm_emit_section(output, section)
    wasm_emit_byte(output, section.id)

    payload = []

    wasm_emit_bytes(payload, wasm_encode_leb128(lengde(section.entries)))

    payload_index = 0

    mens payload_index < lengde(payload)
        wasm_emit_byte(output, payload[payload_index])
        payload_index = payload_index + 1
    slutt
slutt

funksjon wasm_emit_module(module)
    output = wasm_binary()

    wasm_emit_magic(output)
    wasm_emit_version(output)

    indeks = 0

    mens indeks < lengde(module.sections)
        wasm_emit_section(output, module.sections[indeks])
        indeks = indeks + 1
    slutt

    returner output
slutt

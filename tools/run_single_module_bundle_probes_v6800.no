// tools/run_single_module_bundle_probes_v6800.no — køyr v6800 bundle-prober

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = builtin.trim(felt(kommando("pwd"), 1))
    la nc = root + "/dist/norscode_native"
    la outdir = root + "/build/v6800"
    hvis ikkje ok(kommando("mkdir -p " + shell(outdir))) { returner 1 }

    hvis ikkje run("env NORSCODE_CMD=run NORSCODE_FILE='tests/fixtures/v6800/bundler_precompiled_probe_v6800.no' " + shell(nc) + " | tee " + shell(outdir + "/precompiled_probe.log")) { returner 1 }
    hvis ikkje run("env NORSCODE_USE_PRECOMPILED_SELFHOST=0 NORSCODE_CMD=run NORSCODE_FILE='tests/fixtures/v6800/bundler_compile_probe_v6800.no' " + shell(nc) + " | tee " + shell(outdir + "/compile_probe.log")) { returner 1 }
    hvis ikkje run("env NORSCODE_CMD=run NORSCODE_FILE='tests/fixtures/v6800/bundler_single_module_probe_v6800.no' " + shell(nc) + " | tee " + shell(outdir + "/single_module_probe.log")) { returner 1 }
    returner 0
}

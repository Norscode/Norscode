bruk std.socket som sok

funksjon start() -> heiltall {
    la s = sok.ny_tcp()
    hvis ikkje sok.tilkoble(s, "127.0.0.1", 18790) {
        sok.lukk(s)
        returner 1
    }
    hvis sok.send(s, "ping") < 0 {
        sok.lukk(s)
        returner 1
    }
    la svar = sok.motta(s, 1024)
    sok.lukk(s)
    skriv(svar)
    returner 0
}

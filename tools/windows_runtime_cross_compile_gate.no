// Reproduserbar Windows x86_64 ABI-gate for native runtime.
// Dette er en vedlikehaldsgate; normal Norscode-køyring brukar ikkje C-kompilering.

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst { returner "'" + sti + "'" }

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        returner ["1", "", tekst(e)]
    }
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon ok(res: liste_tekst) -> boolsk { returner felt(res, 0) == "0" }

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la zig = env("NORSCODE_ZIG")
    hvis zig == "" { zig = "zig" }
    la source = root + "/build/v3009/native_candidate_gc.c"
    la argon_source = root + "/archive/legacy_c_backend/nc_argon2_zig.zig"
    la backend = root + "/archive/legacy_c_backend/nc_windows_backend.c"
    la smoke = root + "/archive/legacy_c_backend/nc_windows_appcontainer_smoke.c"
    la backend_smoke = root + "/archive/legacy_c_backend/nc_windows_backend_smoke.c"
    la out = root + "/build/windows/norscode_native_windows_x86_64.o"
    la backend_out = root + "/build/windows/nc_windows_backend_x86_64.o"
    la smoke_out = root + "/build/windows/nc_windows_appcontainer_smoke_x86_64.o"
    la backend_smoke_out = root + "/build/windows/nc_windows_backend_smoke_x86_64.o"
    la exe = root + "/build/windows/norscode_native_windows_x86_64.exe"
    la argon_obj = root + "/build/windows/nc_argon2_zig_windows_x86_64.o"
    la smoke_exe = root + "/build/windows/nc_windows_appcontainer_smoke_x86_64.exe"
    la backend_smoke_exe = root + "/build/windows/nc_windows_backend_smoke_x86_64.exe"
    la prep = kommando("mkdir -p " + shell(root + "/build/windows"))
    hvis ikkje ok(prep) { skriv(felt(prep, 2) + "\n") returner 1 }
    la build_argon = kommando(shell(zig) + " build-obj " + shell(argon_source) +
        " -target x86_64-windows-gnu -O ReleaseFast -fsingle-threaded -femit-bin=" + shell(argon_obj))
    hvis ikkje ok(build_argon) {
        skriv("Windows Zig Argon2id cross-compile feilet: " + felt(build_argon, 2) + "\n")
        returner 1
    }
    la build = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 -c " + shell(source) +
        " -I" + shell(root + "/archive/legacy_c_backend") + " -o " + shell(out))
    hvis ikkje ok(build) {
        skriv("Windows cross-compile feilet: " + felt(build, 2) + "\n")
        returner 1
    }
    la build_backend = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 -c " + shell(backend) +
        " -I" + shell(root + "/archive/legacy_c_backend") + " -o " + shell(backend_out))
    hvis ikkje ok(build_backend) {
        skriv("Windows backend cross-compile feilet: " + felt(build_backend, 2) + "\n")
        returner 1
    }
    la build_smoke = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 -c " + shell(smoke) +
        " -I" + shell(root + "/archive/legacy_c_backend") + " -o " + shell(smoke_out))
    hvis ikkje ok(build_smoke) {
        skriv("Windows AppContainer-smoke cross-compile feilet: " + felt(build_smoke, 2) + "\n")
        returner 1
    }
    la build_backend_smoke = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 -c " + shell(backend_smoke) +
        " -I" + shell(root + "/archive/legacy_c_backend") + " -o " + shell(backend_smoke_out))
    hvis ikkje ok(build_backend_smoke) {
        skriv("Windows backend-smoke cross-compile feilet: " + felt(build_backend_smoke, 2) + "\n")
        returner 1
    }
    la link_flags = " -lws2_32 -lbcrypt -ladvapi32 -luserenv -lshell32 -luser32 -lntdll -lsecur32 -lcrypt32"
    la link = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 -DNC_ENABLE_ZIG_ARGON2 " + shell(source) + " " + shell(backend) + " " + shell(argon_obj) +
        " -I" + shell(root + "/archive/legacy_c_backend") + link_flags + " -o " + shell(exe))
    hvis ikkje ok(link) {
        skriv("Windows native executable-lenking feilet: " + felt(link, 2) + "\n")
        returner 1
    }
    la link_smoke = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 " + shell(smoke) + " " + shell(backend) +
        " -I" + shell(root + "/archive/legacy_c_backend") + link_flags + " -o " + shell(smoke_exe))
    hvis ikkje ok(link_smoke) {
        skriv("Windows AppContainer-smoke-lenking feilet: " + felt(link_smoke, 2) + "\n")
        returner 1
    }
    la link_backend_smoke = kommando(shell(zig) + " cc -target x86_64-windows-gnu -O2 " + shell(backend_smoke) + " " + shell(backend) +
        " -I" + shell(root + "/archive/legacy_c_backend") + link_flags + " -o " + shell(backend_smoke_exe))
    hvis ikkje ok(link_backend_smoke) {
        skriv("Windows backend-smoke-lenking feilet: " + felt(link_backend_smoke, 2) + "\n")
        returner 1
    }
    la check = kommando("file " + shell(out) + " " + shell(backend_out) + " " + shell(smoke_out) + " " + shell(backend_smoke_out) + " " + shell(exe) + " " + shell(smoke_exe) + " " + shell(backend_smoke_exe))
    hvis ikkje ok(check) { returner 1 }
    hvis builtin.index_of(felt(check, 1), "Mach-O") >= 0 { returner 1 }
    hvis builtin.index_of(felt(check, 1), "x86_64") < 0 { returner 1 }
    hvis builtin.index_of(felt(check, 1), "PE32+") < 0 { returner 1 }
    skriv("[OK] Windows x86_64 native ABI compile/link (runtime, IOCP/SChannel, AppContainer): " + exe + "\n")
    returner 0
}

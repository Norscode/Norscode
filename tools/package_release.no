// tools/package_release.no — Norscode-native releasepakker
//
// Kall med NORSCODE_RELEASE_VERSION=<versjon>. Denne fila eig release-reglane;
// POSIX-verktøy blir berre brukt som OS-operasjonar.

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon krev(ok_verdi: bool, melding: tekst) -> bool {
    hvis ok_verdi { returner sann }
    linje(melding)
    returner usann
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon fil_eller_mappe_finst(sti: tekst) -> bool {
    returner fil_finst(sti)
}

funksjon køyr(cmd: tekst, feil: tekst) -> bool {
    la res = kommando(cmd)
    hvis ok(res) { returner sann }
    hvis feil != "" { linje(feil) }
    hvis lengde(res) > 2 og res[2] != "" { linje(res[2]) }
    returner usann
}

funksjon trim_linje(t: tekst) -> tekst {
    returner trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim_linje(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim_linje(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon linjer(data: tekst) -> liste_tekst {
    la out: liste_tekst = []
    la delar = builtin.split(data, "\n")
    la i = 0
    mens i < lengde(delar) {
        la linje = trim_linje(delar[i])
        hvis linje != "" {
            legg_til(out, linje)
        }
        i = i + 1
    }
    returner out
}

funksjon release_entries() -> liste_tekst {
    returner [
        ".github",
        "AGENTS.md",
        "CHANGELOG.md",
        "INSTALL.md",
        "LICENSE",
        "Makefile",
        "README.md",
        "ROADMAP.md",
        "NorsDB",
        "app.no",
        "backend",
        "bin",
        "bootstrap",
        "cli",
        "compiler",
        "deploy",
        "dist",
        "docs",
        "examples",
        "frontend",
        "nc",
        "nl",
        "nor",
        "norcode.lock",
        "norcode.toml",
        "packages",
        "runtime",
        "scripts",
        "selfhost",
        "server",
        "std",
        "stdlib",
        "tests",
        "toolchain",
        "tools",
        "vscode-norscode"
    ]
}

funksjon kopier_entry(root: tekst, staging: tekst, entry: tekst) -> bool {
    la src = root + "/" + entry
    hvis ikkje fil_eller_mappe_finst(src) {
        returner sann
    }
    la dest = staging + "/" + entry
    returner køyr("cp -R " + shell(src) + " " + shell(dest), "Klarte ikkje kopiere " + entry)
}

funksjon kopier_std_alias(staging: tekst) -> bool {
    la std_dir = staging + "/std"
    hvis ikkje fil_eller_mappe_finst(std_dir) {
        returner sann
    }
    la res = kommando("find " + shell(std_dir) + " -maxdepth 1 -type f -name '*.no' -print 2>/dev/null")
    hvis ikkje ok(res) {
        linje("Klarte ikkje liste std/*.no for .nors-alias")
        returner usann
    }
    la filer = linjer(res[1])
    la i = 0
    mens i < lengde(filer) {
        la src = filer[i]
        hvis builtin.ends_with(src, ".no") {
            la alias = builtin.slice(src, 0, lengde(src) - 3) + ".nors"
            hvis ikkje fil_finst(alias) {
                hvis ikkje køyr("cp " + shell(src) + " " + shell(alias), "Klarte ikkje lage std/*.nors-alias") {
                    returner usann
                }
            }
        }
        i = i + 1
    }
    returner sann
}

funksjon sha256_skriv(arkiv: tekst) -> bool {
    la sha = ""
    hvis ok(kommando("command -v shasum >/dev/null 2>&1")) {
        sha = første_felt(kommando("shasum -a 256 " + shell(arkiv))[1])
    } ellers hvis ok(kommando("command -v sha256sum >/dev/null 2>&1")) {
        sha = første_felt(kommando("sha256sum " + shell(arkiv))[1])
    } ellers {
        linje("Fant ikkje verktøy for SHA256-sjekksum")
        returner usann
    }
    hvis sha == "" {
        linje("Klarte ikkje skrive SHA256")
        returner usann
    }
    prøv {
        builtin.fil_skriv(arkiv + ".sha256", sha + "\n")
        returner sann
    } fang (e) {
        linje("Klarte ikkje skrive SHA256")
        returner usann
    }
}

funksjon bygg_release(root: tekst, versjon: tekst) -> heiltall {
    hvis versjon == "" {
        linje("Bruk: NORSCODE_RELEASE_VERSION=<versjon> NORSCODE_ENABLE_EXEC_PROSESS=1 ./bin/nc run tools/package_release.no")
        returner 1
    }

    la dist = root + "/dist"
    hvis ikkje krev(fil_finst(dist + "/norscode_native"), "Manglar distribusjonsbinær: " + dist + "/norscode_native") {
        returner 1
    }
    hvis ikkje krev(fil_finst(root + "/bin/nc"), "Manglar CLI-wrapper: " + root + "/bin/nc") {
        returner 1
    }
    hvis ikkje krev(fil_finst(root + "/bootstrap/stage0/norscode-macos-arm64"), "Manglar macOS stage0-seed: " + root + "/bootstrap/stage0/norscode-macos-arm64") {
        returner 1
    }
    hvis ikkje krev(fil_finst(root + "/bootstrap/stage0/norscode-linux-x86_64"), "Manglar Linux stage0-seed: " + root + "/bootstrap/stage0/norscode-linux-x86_64") {
        returner 1
    }
    hvis ikkje krev(fil_finst(root + "/norcode.toml"), "Manglar norcode.toml") {
        returner 1
    }

    la release_dir = root + "/release-artifacts"
    la archive_name = "norscode-language-" + versjon + ".tar.gz"
    la archive_path = release_dir + "/" + archive_name
    hvis ikkje køyr("mkdir -p " + shell(release_dir), "Klarte ikkje lage release-artifacts") {
        returner 1
    }
    køyr("rm -f " + shell(archive_path) + " " + shell(archive_path + ".sha256"), "")

    la mktemp_res = kommando("mktemp -d")
    hvis ikkje ok(mktemp_res) {
        linje("Klarte ikkje lage staging-mappe")
        returner 1
    }
    la staging = trim_linje(mktemp_res[1])

    la entries = release_entries()
    la package_entries: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(entries) {
        la entry = entries[i]
        hvis fil_eller_mappe_finst(root + "/" + entry) {
            hvis ikkje kopier_entry(root, staging, entry) {
                køyr("rm -rf " + shell(staging), "")
                returner 1
            }
            legg_til(package_entries, entry)
        }
        i = i + 1
    }

    la bundle = root + "/build/v9400/hybrid_compiler_bundle_v9400.ncb.json"
    hvis ikkje fil_finst(bundle) {
        linje("Manglar release-artefakt: build/v9400/hybrid_compiler_bundle_v9400.ncb.json")
        linje("Køyr v9400 bundle-bygg før release, eller legg den spora artefakten tilbake.")
        køyr("rm -rf " + shell(staging), "")
        returner 1
    }
    hvis ikkje køyr("mkdir -p " + shell(staging + "/build"), "Klarte ikkje lage build-mappe i staging") {
        køyr("rm -rf " + shell(staging), "")
        returner 1
    }
    hvis ikkje køyr("cp -R " + shell(root + "/build/v9400") + " " + shell(staging + "/build/v9400"), "Klarte ikkje kopiere build/v9400") {
        køyr("rm -rf " + shell(staging), "")
        returner 1
    }
    legg_til(package_entries, "build")

    hvis ikkje kopier_std_alias(staging) {
        køyr("rm -rf " + shell(staging), "")
        returner 1
    }

    la tar_entries = ""
    i = 0
    mens i < lengde(package_entries) {
        tar_entries = tar_entries + " " + shell(package_entries[i])
        i = i + 1
    }
    hvis ikkje køyr("tar -czf " + shell(archive_path) + " -C " + shell(staging) + tar_entries, "Klarte ikkje bygge releasearkiv") {
        køyr("rm -rf " + shell(staging), "")
        returner 1
    }
    hvis ikkje sha256_skriv(archive_path) {
        køyr("rm -rf " + shell(staging), "")
        returner 1
    }

    køyr("rm -rf " + shell(staging), "")
    linje("Bygde releasepakke: " + archive_path)
    returner 0
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" {
        root = trim_linje(kommando("pwd")[1])
    }
    la versjon = env("NORSCODE_RELEASE_VERSION")
    returner bygg_release(root, versjon)
}

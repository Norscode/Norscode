// tools/install-linux-desktop-entry.no — installer Linux desktop entry og ikon

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon abs_sti(root: tekst, sti: tekst) -> tekst {
    hvis builtin.starts_with(sti, "/") { returner sti }
    returner root + "/" + sti
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon desktop_med_exec(innhald: tekst, exec_path: tekst) -> tekst {
    la linjer = builtin.split(innhald, "\n")
    la out = ""
    la i = 0
    mens i < lengde(linjer) {
        la line = linjer[i]
        hvis builtin.starts_with(line, "Exec=") {
            line = "Exec=" + exec_path
        }
        hvis i > 0 { out = out + "\n" }
        out = out + line
        i = i + 1
    }
    returner out
}

funksjon skriv_desktop(desktop_src: tekst, desktop_dst: tekst, appdir: tekst) -> bool {
    prøv {
        la innhald = builtin.fil_les(desktop_src)
        builtin.fil_skriv(desktop_dst, desktop_med_exec(innhald, appdir + "/AppRun"))
        returner sann
    } fang (e) {
        linje("Feil: klarte ikkje skrive desktop-fil: " + tekst(e))
        returner usann
    }
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la appdir = env("NORSCODE_LINUX_DESKTOP_APPDIR")
    hvis appdir == "" { appdir = root + "/build/linux-app/Norscode.AppDir" }
    la prefix = env("NORSCODE_LINUX_DESKTOP_PREFIX")
    hvis prefix == "" { prefix = env("HOME") + "/.local/share" }

    appdir = abs_sti(root, appdir)
    prefix = abs_sti(root, prefix)

    la desktop_src = appdir + "/usr/share/applications/Norscode.desktop"
    la icon_src = appdir + "/usr/share/icons/hicolor/256x256/apps/norscode.png"
    la desktop_dst_dir = prefix + "/applications"
    la icon_dst_dir = prefix + "/icons/hicolor/256x256/apps"
    la desktop_dst = desktop_dst_dir + "/Norscode.desktop"
    la icon_dst = icon_dst_dir + "/norscode.png"

    hvis ikkje fil_finst(desktop_src) {
        linje("Feil: manglar desktop-fil: " + desktop_src)
        linje("Bygg først med: ./bin/nc package-linux-app --format appdir")
        returner 1
    }
    hvis ikkje fil_finst(icon_src) {
        linje("Feil: manglar ikonfil: " + icon_src)
        returner 1
    }

    hvis ikkje run("mkdir -p " + shell(desktop_dst_dir) + " " + shell(icon_dst_dir)) { returner 1 }
    hvis ikkje run("cp " + shell(icon_src) + " " + shell(icon_dst)) { returner 1 }
    hvis ikkje skriv_desktop(desktop_src, desktop_dst, appdir) { returner 1 }

    hvis ok(kommando("command -v desktop-file-validate >/dev/null 2>&1")) {
        kommando("desktop-file-validate " + shell(desktop_dst) + " || true")
    }
    hvis ok(kommando("command -v update-desktop-database >/dev/null 2>&1")) {
        kommando("update-desktop-database " + shell(desktop_dst_dir) + " || true")
    }

    linje("Installert desktop entry: " + desktop_dst)
    linje("Installert ikon: " + icon_dst)
    returner 0
}

// tools/test_v731_serve_plan_v735.no — v731 route-smoke med DEV-flyt

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon køyr(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la port = env("NORSCODE_V731_PORT")
    hvis port == "" { port = "8126" }
    la base = "http://127.0.0.1:" + port
    la cookies = "/tmp/norscode_v731_dev_session.txt"

    hvis ikkje ok(kommando("rm -f " + shell(cookies))) { returner 1 }

    linje("Tester " + base)
    hvis ikkje køyr("curl -i " + shell(base + "/")) { returner 1 }
    linje("")
    hvis ikkje køyr("curl -i " + shell(base + "/admin")) { returner 1 }
    linje("")
    hvis ikkje køyr("curl -i " + shell(base + "/status.json")) { returner 1 }
    linje("")
    hvis ikkje køyr("curl -i " + shell(base + "/logout")) { returner 1 }
    linje("")

    linje("DEV-flyt:")
    hvis ikkje køyr("curl -i -c " + shell(cookies) + " " + shell(base + "/dev-login")) { returner 1 }
    linje("")
    hvis ikkje køyr("curl -i -b " + shell(cookies) + " " + shell(base + "/admin")) { returner 1 }
    linje("")
    hvis ikkje køyr("curl -i -b " + shell(cookies) + " " + shell(base + "/logout")) { returner 1 }
    linje("")

    linje("OK v800")
    returner 0
}

# Bygg Linux x86_64 native-kandidat frå macOS/Linux med Zig.
# Kandidaten blir ikkje promotert til stage0 eller dist automatisk.

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst { returner "'" + sti + "'" }

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) { returner ["1", "", tekst(e)] }
}

funksjon felt(res: liste_tekst, indeks: heiltall) -> tekst {
    hvis lengde(res) > indeks { returner res[indeks] }
    returner ""
}

funksjon ok(res: liste_tekst) -> boolsk { returner felt(res, 0) == "0" }

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    la project_root = hvis root == "" da felt(kommando("pwd"), 1) ellers root
    la zig = hvis env("NORSCODE_ZIG") == "" da "zig" ellers env("NORSCODE_ZIG")
    la out = project_root + "/build/v3600/linux/norscode_native_linux_x86_64_v3602"
    la source = project_root + "/build/v3009/native_candidate_gc.c"
    la sqlite = project_root + "/third_party/sqlite/sqlite3.c"
    hvis ikkje ok(kommando("test -f " + shell(source))) { skriv("[FAIL] manglar native-kjelde\n") returner 1 }
    hvis ikkje ok(kommando("test -f " + shell(sqlite))) { skriv("[FAIL] manglar SQLite-kjelde\n") returner 1 }
    hvis ikkje ok(kommando("mkdir -p " + shell(project_root + "/build/v3600/linux"))) { returner 1 }
    la build = kommando(shell(zig) + " cc -target x86_64-linux-gnu -O2 -Wno-everything -I" +
        shell(project_root + "/archive/legacy_c_backend") + " " + shell(source) + " " + shell(sqlite) +
        " -lpthread -ldl -lm -o " + shell(out))
    hvis ikkje ok(build) {
        skriv("[FAIL] Linux x86_64 cross-build: " + felt(build, 2) + "\n")
        returner 1
    }
    la file = kommando("file " + shell(out))
    hvis ikkje ok(file) eller builtin.index_of(felt(file, 1), "ELF 64-bit") < 0 eller
       builtin.index_of(felt(file, 1), "x86-64") < 0 {
        skriv("[FAIL] artefakt er ikkje Linux x86_64 ELF\n")
        returner 1
    }
    la sha = kommando("shasum -a 256 " + shell(out))
    la size = kommando("wc -c < " + shell(out) + " | tr -d ' '")
    skriv("[OK] Linux x86_64 ELF-kandidat: " + out + "\n")
    skriv("[OK] bytes=" + builtin.trim(felt(size, 1)) + " sha256=" + builtin.trim(felt(sha, 1)) + "\n")
    skriv("[INFO] Kandidaten er ikkje promotert; runtime execution krev faktisk Linux-host.\n")
    returner 0
}

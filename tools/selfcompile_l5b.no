// tools/selfcompile_l5b.no — L5b maintenance: full Gen1-NCB → Gen2 via VM

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon executable(sti: tekst) -> bool {
    returner fil_finst(sti)
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon bytes(sti: tekst) -> tekst {
    prøv {
        la innhald = builtin.fil_les(sti)
        returner tekst_fra_heltall(lengde(innhald))
    } fang (e) {}
    returner første_felt(res_felt(kommando("wc -c " + shell(sti)), 1))
}

funksjon første_forskjellar(sti_a: tekst, sti_b: tekst, maks: heiltall) -> tekst {
    la a = builtin.fil_les(sti_a)
    la b = builtin.fil_les(sti_b)
    la min_lengd = lengde(a)
    hvis lengde(b) < min_lengd { min_lengd = lengde(b) }
    la out = ""
    la funne = 0
    la i = 0
    mens i < min_lengd og funne < maks {
        hvis a[i] != b[i] {
            out = out + tekst_fra_heltall(i + 1) + " " + tekst_fra_heltall(builtin.char_code(a[i])) + " " + tekst_fra_heltall(builtin.char_code(b[i])) + "\n"
            funne = funne + 1
        }
        i = i + 1
    }
    hvis funne < maks og lengde(a) != lengde(b) {
        out = out + "length " + tekst_fra_heltall(lengde(a)) + " " + tekst_fra_heltall(lengde(b)) + "\n"
    }
    hvis out == "" { returner "Ingen lesbare forskjellar funne\n" }
    returner out
}

funksjon filer_identiske(sti_a: tekst, sti_b: tekst) -> bool {
    hvis ikkje fil_finst(sti_a) eller ikkje fil_finst(sti_b) { returner usann }
    returner builtin.fil_les(sti_a) == builtin.fil_les(sti_b)
}

funksjon bundle_args() -> tekst {
    returner "selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no " +
        "selfhost.parser=selfhost/parser.no " +
        "selfhost.compiler.semantic=selfhost/compiler/semantic.no " +
        "selfhost.compiler.ir_to_bytecode=selfhost/compiler/ir_to_bytecode.no " +
        "selfhost.kompiler=selfhost/kompiler.no " +
        "selfhost.json=selfhost/json.no " +
        "selfhost.vm=selfhost/vm.no " +
        "selfhost.bundler=selfhost/bundler.no"
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la native = root + "/dist/norscode_native"
    la driver = root + "/build/l5b/compiler_driver.ncb.json"
    la v1 = root + "/build/l5b/compiler_v1.ncb.json"
    la v2 = root + "/build/l5b/compiler_v2.ncb.json"

    hvis ikkje executable(native) {
        linje("✗ Trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no")
        returner 1
    }

    hvis ikkje run("mkdir -p " + shell(root + "/build/l5b")) { returner 1 }
    linje("=== L5b: VM sjølvkompilering (byte-paritet) ===")
    linje("")
    linje("[1/4] Startdriver via aktiv Norscode-kompilator...")
    hvis ikkje run(shell(root + "/bin/nc") + " bundle " + bundle_args() + " --output " + shell(driver)) { returner 1 }
    linje("[2/4] Gen1: bundle via startdriver-bytecode...")
    hvis ikkje run("NORSCODE_RUN_CMD=l5b-gen2 NORSCODE_L5B_V1=" + shell(driver) + " NORSCODE_L5B_V2=" + shell(v1) + " NORSCODE_BUNDLE_ARGS=" + shell(bundle_args()) + " NORSCODE_VM_CAPABILITIES=env.read,process.exec,disk.read,disk.write NORSCODE_VM_DISK_ROOT=" + shell(root + ",.,/tmp,/private/tmp") + " " + shell(root + "/bin/nc") + " run " + shell(root + "/selfhost/nc_main.no")) { returner 1 }
    hvis ikkje fil_finst(v1) {
        linje("  [FEIL] Gen1 skreiv ikkje " + v1)
        returner 1
    }
    la v1_bytes = bytes(v1)
    linje("  ✓ " + v1_bytes + " bytes")
    linje("")

    linje("[3/4] Gen2: bundle via Gen1-bytekode (bygg_bundle)...")
    hvis ikkje run("NORSCODE_RUN_CMD=l5b-gen2 NORSCODE_L5B_V1=" + shell(v1) + " NORSCODE_L5B_V2=" + shell(v2) + " NORSCODE_BUNDLE_ARGS=" + shell(bundle_args()) + " NORSCODE_VM_CAPABILITIES=env.read,process.exec,disk.read,disk.write NORSCODE_VM_DISK_ROOT=" + shell(root + ",.,/tmp,/private/tmp") + " " + shell(root + "/bin/nc") + " run " + shell(root + "/selfhost/nc_main.no")) {
        linje("  [FEIL] l5b-gen2 feila")
        returner 1
    }
    hvis ikkje fil_finst(v2) {
        linje("  [FEIL] Gen2 skreiv ikkje " + v2 + " - sjekk l5b-gen2 og host_kall_bygg_bundle")
        returner 1
    }
    linje("")

    linje("[4/4] Byte-paritet Gen1 == Gen2...")
    hvis ok(kommando("cmp -s " + shell(v1) + " " + shell(v2) + " 2>/dev/null")) {
        linje("  [OK] " + v1_bytes + " bytes identiske")
        linje("")
        linje("=== L5b: BESTÅTT ===")
        linje("To påfølgjande compiler-bundles frå VM er byte-identiske.")
        returner 0
    }

    linje("  [FEIL] Bundles differ (v1=" + v1_bytes + ", v2=" + bytes(v2) + " bytes)")
    skriv(første_forskjellar(v1, v2, 5))
    returner 1
}

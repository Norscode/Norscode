// tools/install-macos-app.no — installer lokal macOS app-bundle

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon mappe_finst(sti: tekst) -> bool {
    returner ok(kommando("test -d " + shell(sti)))
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon executable(sti: tekst) -> bool {
    returner ok(kommando("test -x " + shell(sti)))
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon app_version(app_path: tekst) -> tekst {
    la res = kommando("/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' " + shell(app_path + "/Contents/Info.plist") + " 2>/dev/null || printf '1.0'")
    la v = trim(res_felt(res, 1))
    hvis v == "" { returner "1.0" }
    returner v
}

funksjon start() -> heiltall {
    la app_path = env("NORSCODE_MACOS_INSTALL_APP")
    la dest_dir = env("NORSCODE_MACOS_INSTALL_DEST")
    la app_name = env("NORSCODE_MACOS_INSTALL_NAME")
    hvis app_name == "" { app_name = "Norscode.app" }

    hvis trim(res_felt(kommando("uname -s"), 1)) != "Darwin" {
        linje("Feil: install-macos-app krev macOS.")
        returner 1
    }
    hvis ikkje mappe_finst(app_path) {
        linje("Feil: manglar app-bundle: " + app_path)
        linje("Bygg først med: bash tools/build-macos-app.sh")
        returner 1
    }
    hvis ikkje fil_finst(app_path + "/Contents/Info.plist") {
        linje("Feil: ugyldig app-bundle, manglar Info.plist: " + app_path)
        returner 1
    }
    hvis ikkje ok(kommando("command -v plutil >/dev/null 2>&1")) {
        linje("Feil: manglar macOS-verktøyet plutil")
        returner 1
    }
    hvis ikkje run("plutil -lint " + shell(app_path + "/Contents/Info.plist") + " >/dev/null") { returner 1 }

    la target_app = dest_dir + "/" + app_name
    la versioned_root = dest_dir + "/.Norscode"
    la versions_dir = versioned_root + "/versions"
    la version = app_version(app_path)
    la versioned_app = versions_dir + "/" + version + "/" + app_name
    la current_link = versioned_root + "/current"

    hvis ikkje run("mkdir -p " + shell(dest_dir) + " " + shell(versions_dir + "/" + version)) { returner 1 }
    hvis ikkje run("rm -rf " + shell(versioned_app)) { returner 1 }
    hvis ikkje run("cp -R " + shell(app_path) + " " + shell(versioned_app)) { returner 1 }
    hvis ikkje run("ln -sfn " + shell(versioned_app) + " " + shell(current_link)) { returner 1 }
    hvis ikkje run("rm -rf " + shell(target_app)) { returner 1 }
    hvis ikkje run("ln -sfn " + shell(current_link) + " " + shell(target_app)) { returner 1 }

    hvis executable(versioned_app + "/Contents/Resources/runtime/tools/install-macos-file-icons.sh") {
        kommando("bash " + shell(versioned_app + "/Contents/Resources/runtime/tools/install-macos-file-icons.sh") + " || true")
    }

    linje("Installert macOS-app: " + versioned_app)
    linje("Aktiv app-lenke: " + target_app)
    linje("Start appen med: open " + target_app)
    returner 0
}

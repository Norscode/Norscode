// tools/package-windows-app.no — pakk Windows app-layout til ZIP

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon abs_sti(root: tekst, sti: tekst) -> tekst {
    hvis builtin.starts_with(sti, "/") { returner sti }
    returner root + "/" + sti
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon repo_version(root: tekst) -> tekst {
    la toml = root + "/norcode.toml"
    hvis fil_finst(toml) {
        la res = kommando("grep '^version' " + shell(toml) + " | head -1 | sed 's/.*= *\"\\(.*\\)\"/\\1/'")
        la v = trim(res_felt(res, 1))
        hvis v != "" { returner v }
    }
    returner "1.0"
}

funksjon sha256_skriv(sti: tekst) -> bool {
    hvis ok(kommando("command -v shasum >/dev/null 2>&1")) {
        returner run("shasum -a 256 " + shell(sti) + " | awk '{print $1}' > " + shell(sti + ".sha256"))
    }
    returner run("sha256sum " + shell(sti) + " | awk '{print $1}' > " + shell(sti + ".sha256"))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la exe_path = env("NORSCODE_WINDOWS_PACKAGE_EXE")
    la version = env("NORSCODE_WINDOWS_PACKAGE_VERSION")
    hvis version == "" { version = repo_version(root) }

    hvis exe_path == "" {
        linje("Feil: manglar path til Windows-native .exe")
        linje("Døme: NORSCODE_WINDOWS_PACKAGE_EXE=build/windows/norscode.exe ./bin/nc run tools/package-windows-app.no")
        returner 1
    }
    exe_path = abs_sti(root, exe_path)
    hvis ikkje fil_finst(exe_path) {
        linje("Feil: fann ikkje .exe-artefakt: " + exe_path)
        returner 1
    }
    hvis ikkje ok(kommando("command -v zip >/dev/null 2>&1")) {
        linje("Feil: manglar zip-verktøyet")
        returner 1
    }

    la release_dir = root + "/release-artifacts"
    la stage_dir = trim(res_felt(kommando("mktemp -d"), 1))
    hvis stage_dir == "" { returner 1 }
    la pkg_name = "norscode-windows-" + version
    la zip_path = release_dir + "/" + pkg_name + ".zip"
    la layout_root = stage_dir + "/layout"

    hvis ikkje run("mkdir -p " + shell(release_dir)) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " NORSCODE_WINDOWS_LAYOUT_OUT=" + shell(layout_root) + " NORSCODE_WINDOWS_EXE_PATH=" + shell(exe_path) + " ./bin/nc run " + shell(root + "/tools/build-windows-app-layout.no") + " >/dev/null") {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("rm -f " + shell(zip_path) + " " + shell(zip_path + ".sha256")) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("cd " + shell(layout_root) + " && zip -qr " + shell(zip_path) + " Norscode") {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje sha256_skriv(zip_path) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    kommando("rm -rf " + shell(stage_dir))

    linje("Bygde Windows ZIP-artefakt: " + zip_path)
    linje("SHA256: " + zip_path + ".sha256")
    returner 0
}

// Bygg Linux x86_64-kandidat med portable Zig Argon2id-backend.
// Kandidaten blir ikkje promotert til stage0 eller dist.

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(verdi: tekst) -> tekst { returner "'" + verdi + "'" }

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) { returner ["1", "", tekst(e)] }
    returner ["1", "", "ukjend prosessfeil"]
}

funksjon felt(res: liste_tekst, indeks: heiltall) -> tekst {
    hvis lengde(res) > indeks { returner res[indeks] }
    returner ""
}

funksjon vis(res: liste_tekst) -> heiltall {
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner 0
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = felt(kommando("pwd"), 1) }
    la zig = env("NORSCODE_ZIG")
    hvis zig == "" { zig = "zig" }
    la object = "/tmp/nc_argon2_zig_v3606.o"
    la out = root + "/build/v3600/linux/norscode_native_linux_x86_64_v3605_zigargon"
    la zig_res = kommando(shell(zig) + " build-obj " +
        shell(root + "/archive/legacy_c_backend/nc_argon2_zig.zig") +
        " -target x86_64-linux-gnu -O ReleaseFast -fsingle-threaded -fPIC -femit-bin=" + shell(object))
    vis(zig_res)
    hvis felt(zig_res, 0) != "0" { skriv("[FAIL] Zig Argon2id-objekt kunne ikkje byggjast\n") returner 1 }

    la image = env("NORSCODE_DOCKER_IMAGE")
    hvis image == "" { image = "ubuntu:24.04" }
    la inner = "set -e\n" +
        "apt-get update -qq\n" +
        "apt-get install -y -qq build-essential libsqlite3-dev libssl-dev file >/dev/null\n" +
        "gcc -O2 -DNC_ENABLE_OPENSSL -DNC_ENABLE_ZIG_ARGON2 -Iarchive/legacy_c_backend " +
        "build/v3009/native_candidate_gc.c third_party/sqlite/sqlite3.c " +
        "/tmp/nc_argon2_zig_v3606.o -lpthread -ldl -lm -lssl -lcrypto -o " +
        "/work/build/v3600/linux/norscode_native_linux_x86_64_v3605_zigargon\n" +
        "file " + "/work/build/v3600/linux/norscode_native_linux_x86_64_v3605_zigargon\n" +
        "sha256sum " + "/work/build/v3600/linux/norscode_native_linux_x86_64_v3605_zigargon"
    la docker = "docker run --rm --platform linux/amd64 -v " + shell(root + ":/work") +
        " -v " + shell(object + ":/tmp/nc_argon2_zig_v3606.o:ro") +
        " -w /work " + shell(image) + " sh -lc " + shell(inner)
    la res = kommando(docker)
    vis(res)
    hvis felt(res, 0) != "0" {
        skriv("[FAIL] Linux Zig Argon2id-kandidat kunne ikkje byggjast\n")
        returner 1
    }
    skriv("[OK] Linux Zig Argon2id-kandidat bygd; ikkje promotert\n")
    returner 0
}

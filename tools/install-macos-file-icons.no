// tools/install-macos-file-icons.no — installer macOS filtype-ikoner

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon run(cmd: tekst, feil: tekst) -> bool {
    la res = kommando(cmd)
    hvis ok(res) { returner sann }
    hvis feil != "" { linje(feil) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner usann
}

funksjon render_icns(icon_dir: tekst, mark_renderer: tekst, svg: tekst, icns: tekst) -> bool {
    hvis ikkje ok(kommando("test -f " + shell(svg))) {
        linje("Feil: manglar ikonkjelde " + svg)
        returner usann
    }
    la script = "set -eu\nsvg_path=" + shell(svg) + "\nicns_path=" + shell(icns) + "\nicon_dir=" + shell(icon_dir) + "\nmark_renderer=" + shell(mark_renderer) + "\nnc_bin=" + shell(env("NORSCODE_ROOT") + "/bin/nc") + "\ntmp_dir=$(mktemp -d /tmp/norscode_icon.XXXXXX)\nbase=$(basename \"$svg_path\")\niconset=\"$tmp_dir/icon.iconset\"\nmkdir -p \"$iconset\"\nif [ \"$base\" = \"norscode-mark.svg\" ] && [ -f \"${mark_renderer%.swift}.no\" ] && [ -x \"$nc_bin\" ]; then\n  NORSCODE_MARK_RENDER_OUT=\"$tmp_dir/${base}.png\" NORSCODE_MARK_RENDER_SIZE=1024 \"$nc_bin\" run \"${mark_renderer%.swift}.no\" >/dev/null 2>&1\nelse\n  qlmanage -t -s 1024 -o \"$tmp_dir\" \"$svg_path\" >/dev/null 2>&1 || { [ -f \"$icon_dir/norscode.icns\" ] && cp \"$icon_dir/norscode.icns\" \"$icns_path\" && rm -rf \"$tmp_dir\" && exit 0; exit 1; }\nfi\npreview=\"$tmp_dir/${base}.png\"\nif [ ! -f \"$preview\" ]; then preview=$(find \"$tmp_dir\" -maxdepth 1 -type f -name \"*.png\" | head -1); fi\nif [ -z \"${preview:-}\" ] || [ ! -f \"$preview\" ]; then [ -f \"$icon_dir/norscode.icns\" ] && cp \"$icon_dir/norscode.icns\" \"$icns_path\" && rm -rf \"$tmp_dir\" && exit 0; exit 1; fi\nfor size in 16 32 128 256 512; do\n  for scale in 1 2; do\n    if [ \"$scale\" -eq 1 ]; then name=\"icon_${size}x${size}.png\"; else name=\"icon_${size}x${size}@2x.png\"; fi\n    png_src=\"$iconset/$name\"\n    cp \"$preview\" \"$png_src\"\n    sips -z \"$((size * scale))\" \"$((size * scale))\" \"$png_src\" >/dev/null\n  done\ndone\niconutil -c icns \"$iconset\" -o \"$icns_path\"\nrm -rf \"$tmp_dir\"\n"
    returner run("sh -c " + shell(script), "Feil: klarte ikkje rendre " + svg)
}

funksjon plist() -> tekst {
    returner "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n<plist version=\"1.0\">\n<dict>\n  <key>CFBundleDevelopmentRegion</key><string>nb</string>\n  <key>CFBundleDisplayName</key><string>Norscode File Types</string>\n  <key>CFBundleExecutable</key><string>NorscodeFileTypes</string>\n  <key>CFBundleIconFile</key><string>norscode</string>\n  <key>CFBundleIdentifier</key><string>dev.norscode.filetypes</string>\n  <key>CFBundleName</key><string>Norscode File Types</string>\n  <key>CFBundlePackageType</key><string>APPL</string>\n  <key>CFBundleShortVersionString</key><string>1.0</string>\n  <key>CFBundleVersion</key><string>1</string>\n  <key>LSApplicationCategoryType</key><string>public.app-category.developer-tools</string>\n  <key>LSMinimumSystemVersion</key><string>11.0</string>\n  <key>LSUIElement</key><true/>\n  <key>CFBundleDocumentTypes</key>\n  <array>\n    <dict><key>CFBundleTypeExtensions</key><array><string>no</string></array><key>CFBundleTypeIconFile</key><string>file-main-no</string><key>CFBundleTypeName</key><string>Norscode Source</string><key>CFBundleTypeRole</key><string>Editor</string><key>LSHandlerRank</key><string>Owner</string><key>LSItemContentTypes</key><array><string>dev.norscode.source</string></array></dict>\n    <dict><key>CFBundleTypeExtensions</key><array><string>nc</string></array><key>CFBundleTypeIconFile</key><string>file-utils-nc</string><key>CFBundleTypeName</key><string>Norscode Utility Source</string><key>CFBundleTypeRole</key><string>Editor</string><key>LSHandlerRank</key><string>Owner</string><key>LSItemContentTypes</key><array><string>dev.norscode.utility-source</string></array></dict>\n    <dict><key>CFBundleTypeExtensions</key><array><string>ncf</string></array><key>CFBundleTypeIconFile</key><string>file-config-ncf</string><key>CFBundleTypeName</key><string>Norscode Config</string><key>CFBundleTypeRole</key><string>Editor</string><key>LSHandlerRank</key><string>Owner</string><key>LSItemContentTypes</key><array><string>dev.norscode.config</string></array></dict>\n    <dict><key>CFBundleTypeExtensions</key><array><string>ncd</string></array><key>CFBundleTypeIconFile</key><string>file-data-ncd</string><key>CFBundleTypeName</key><string>Norscode Data</string><key>CFBundleTypeRole</key><string>Viewer</string><key>LSHandlerRank</key><string>Owner</string><key>LSItemContentTypes</key><array><string>dev.norscode.data</string></array></dict>\n    <dict><key>CFBundleTypeExtensions</key><array><string>ncp</string></array><key>CFBundleTypeIconFile</key><string>file-package-ncp</string><key>CFBundleTypeName</key><string>Norscode Package</string><key>CFBundleTypeRole</key><string>Editor</string><key>LSHandlerRank</key><string>Owner</string><key>LSItemContentTypes</key><array><string>dev.norscode.package</string></array></dict>\n  </array>\n</dict>\n</plist>\n"
}

funksjon skriv_fil(path: tekst, body: tekst) -> bool {
    returner run("printf '%s' " + shell(body) + " > " + shell(path), "Klarte ikkje skrive " + path)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    hvis builtin.trim(felt(kommando("uname -s"), 1)) != "Darwin" {
        linje("Hopp over macOS filtype-ikoner: ikkje macOS.")
        returner 0
    }
    la icon_dir = root + "/frontend/assets/icons"
    la mark_renderer = root + "/tools/render-norscode-mark.swift"
    la bundle_dir = env("NORSCODE_FILE_ICONS_BUNDLE_DIR")
    hvis bundle_dir == "" { bundle_dir = env("HOME") + "/Applications/Norscode File Types.app" }
    la skip_register = env("NORSCODE_FILE_ICONS_SKIP_REGISTER") == "sann"

    la tools: liste_tekst = ["qlmanage", "sips", "iconutil", "plutil"]
    la i = 0
    mens i < lengde(tools) {
        hvis ikkje ok(kommando("command -v " + tools[i] + " >/dev/null 2>&1")) {
            linje("Feil: manglar macOS-verktøyet " + tools[i])
            returner 1
        }
        i = i + 1
    }
    hvis ikkje ok(kommando("test -d " + shell(icon_dir))) {
        linje("Hopp over macOS filtype-ikoner: manglar " + icon_dir)
        returner 0
    }

    la resources = bundle_dir + "/Contents/Resources"
    la macos = bundle_dir + "/Contents/MacOS"
    hvis ikkje run("mkdir -p " + shell(macos) + " " + shell(resources), "Klarte ikkje lage ikon-app") { returner 1 }
    hvis ok(kommando("test -f " + shell(icon_dir + "/norscode.icns"))) {
        hvis ikkje run("cp " + shell(icon_dir + "/norscode.icns") + " " + shell(resources + "/norscode.icns"), "Klarte ikkje kopiere norscode.icns") { returner 1 }
    } ellers {
        hvis ikkje render_icns(icon_dir, mark_renderer, icon_dir + "/norscode-mark.svg", resources + "/norscode.icns") { returner 1 }
    }
    hvis ikkje render_icns(icon_dir, mark_renderer, icon_dir + "/file-main-no.svg", resources + "/file-main-no.icns") { returner 1 }
    hvis ikkje render_icns(icon_dir, mark_renderer, icon_dir + "/file-utils-nc.svg", resources + "/file-utils-nc.icns") { returner 1 }
    hvis ikkje render_icns(icon_dir, mark_renderer, icon_dir + "/file-config-ncf.svg", resources + "/file-config-ncf.icns") { returner 1 }
    hvis ikkje render_icns(icon_dir, mark_renderer, icon_dir + "/file-data-ncd.svg", resources + "/file-data-ncd.icns") { returner 1 }
    hvis ikkje render_icns(icon_dir, mark_renderer, icon_dir + "/file-package-ncp.svg", resources + "/file-package-ncp.icns") { returner 1 }
    run("cp " + shell(icon_dir + "/file-component-no.svg") + " " + shell(resources + "/file-component-no.svg"), "")
    run("cp " + shell(icon_dir + "/folder-project.svg") + " " + shell(resources + "/folder-project.svg"), "")
    run("cp " + shell(icon_dir + "/folder-package.svg") + " " + shell(resources + "/folder-package.svg"), "")

    hvis ikkje skriv_fil(macos + "/NorscodeFileTypes", "#!/usr/bin/env sh\nexec /usr/bin/open -a Terminal \"$HOME\"\n") { returner 1 }
    hvis ikkje run("chmod +x " + shell(macos + "/NorscodeFileTypes"), "Klarte ikkje gjere ikon-app køyrbar") { returner 1 }
    hvis ikkje skriv_fil(bundle_dir + "/Contents/Info.plist", plist()) { returner 1 }
    hvis ikkje run("plutil -lint " + shell(bundle_dir + "/Contents/Info.plist") + " >/dev/null", "Info.plist validerte ikkje") { returner 1 }
    hvis ikkje skip_register {
        kommando("/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f " + shell(bundle_dir) + " >/dev/null 2>&1 || true")
    }
    linje("Norscode macOS filtype-ikoner installert: " + bundle_dir)
    linje("Finder kan trenge litt tid, eller relansering, før ikon-cache viser nye ikoner.")
    returner 0
}

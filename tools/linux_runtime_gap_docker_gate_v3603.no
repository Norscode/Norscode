// Verifiser Linux x86_64-kandidat i ein faktisk Linux-container.

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(verdi: tekst) -> tekst { returner "'" + verdi + "'" }

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) { returner ["1", "", tekst(e)] }
    returner ["1", "", "ukjend prosessfeil"]
}

funksjon felt(res: liste_tekst, indeks: heiltall) -> tekst {
    hvis lengde(res) > indeks { returner res[indeks] }
    returner ""
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = felt(kommando("pwd"), 1) }
    la kandidat = env("NORSCODE_LINUX_CANDIDATE")
    hvis kandidat == "" { kandidat = root + "/build/v3600/linux/norscode_native_linux_x86_64_v3602" }
    la kandidat_rel = kandidat
    la prefix = root + "/"
    hvis builtin.starts_with(kandidat, prefix) {
        kandidat_rel = builtin.slice(kandidat, lengde(prefix), lengde(kandidat))
    }
    hvis kandidat_rel == "" eller builtin.starts_with(kandidat_rel, "/") { skriv("[FAIL] ugyldig Linux-kandidatsti\n") returner 1 }
    la image = env("NORSCODE_DOCKER_IMAGE")
    hvis image == "" { image = "ubuntu:24.04" }
    la platform = env("NORSCODE_DOCKER_PLATFORM")
    hvis platform == "" { platform = "linux/amd64" }

    la inner = "set -e\n" +
        "apt-get update -qq\n" +
        "apt-get install -y -qq libsqlite3-0 >/dev/null\n" +
        "NORSCODE_CMD=run " +
        "NORSCODE_FILE=/work/tools/native_runtime_gap_gate_v3001.no " +
        "NORSCODE_ROOT=/work " +
        "NORSCODE_NATIVE_GAP_BIN=/work/" + kandidat_rel + " " +
        "NORSCODE_ENABLE_EXEC_PROSESS=1 " +
        "NORSCODE_VM_CAPABILITIES=env.read,process.exec,disk.read,disk.write,net.listen,net.connect,net.tcp,net.udp,net.dns " +
        "NORSCODE_VM_DISK_ROOT=/work,.,/tmp,/private/tmp " +
        "/work/" + kandidat_rel
    la cmd = "docker run --rm --platform " + platform + " -v " + shell(root + ":/work") +
        " -w /work " + shell(image) + " sh -lc " + shell(inner)
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    hvis felt(res, 0) != "0" {
        skriv("[FAIL] Linux runtime-gap Docker-gate feila for " + platform + "\n")
        returner 1
    }
    skriv("[OK] Linux runtime-gap Docker-gate er grøn for " + platform + "\n")
    returner 0
}

funksjon route_admin_overview(ctx: ordbok_tekst) -> ordbok_tekst {
    la _ = ctx
    returner web.response_builder(404, {"content-type": "application/json; charset=utf-8"}, "{\"ok\":false,\"feil\":\"admin er deaktivert\"}")
}


// tools/backup_stage0_before_random_hex_v734.no — backup før runtime-endring

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon backup(root: tekst, out: tekst, rel: tekst) -> bool {
    la src = root + "/" + rel
    hvis ikkje fil_finst(src) { returner sann }
    la name = builtin.replace(rel, "/", "_")
    hvis ikkje ok(kommando("cp " + shell(src) + " " + shell(out + "/" + name))) { returner usann }
    linje("Backup: " + out + "/" + name)
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la stamp = trim(res_felt(kommando("date +%Y%m%d_%H%M%S"), 1))
    hvis stamp == "" { stamp = "unknown" }
    la out = root + "/build/backups/stage0_random_hex_v734/" + stamp
    hvis ikkje ok(kommando("mkdir -p " + shell(out))) { returner 1 }
    hvis ikkje backup(root, out, "dist/norscode_native") { returner 1 }
    hvis ikkje backup(root, out, "bootstrap/stage0/norscode-macos-arm64") { returner 1 }
    hvis ikkje backup(root, out, "bootstrap/stage0/norscode-linux-x86_64") { returner 1 }
    hvis ikkje backup(root, out, "bootstrap/stage0/norscode-linux-arm64") { returner 1 }
    hvis ikkje backup(root, out, "selfhost/vm.no") { returner 1 }
    hvis ikkje backup(root, out, "selfhost/serve_runner.no") { returner 1 }
    linje("Backup ferdig: " + out)
    returner 0
}

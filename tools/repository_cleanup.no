// tools/repository_cleanup.no — rydd bort vanlege lokale artefaktar

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }

    linje("Cleaning repository artifacts...")
    run("cd " + shell(root) + " && find . -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true")
    run("cd " + shell(root) + " && find . -name '*.pyc' -delete 2>/dev/null || true")
    run("cd " + shell(root) + " && find . -name '*.tmp' -delete 2>/dev/null || true")
    run("cd " + shell(root) + " && find . -name '.DS_Store' -delete 2>/dev/null || true")
    run("cd " + shell(root) + " && find . -name 'debug_*' -delete 2>/dev/null || true")
    run("cd " + shell(root) + " && find . -name 'tmp_*' -delete 2>/dev/null || true")
    linje("Cleanup complete")
    returner 0
}

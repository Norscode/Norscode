funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst { returner "'" + sti + "'" }

funksjon exec(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        returner ["1", "", tekst(e)]
    }
}

funksjon ok(resultat: liste_tekst) -> boolsk { returner lengde(resultat) > 0 og resultat[0] == "0" }

funksjon dirname(sti: tekst) -> tekst {
    la siste: heiltall = -1
    la i: heiltall = 0
    mens i < lengde(sti) {
        hvis builtin.slice(sti, i, i + 1) == "/" { siste = i }
        i = i + 1
    }
    hvis siste <= 0 { returner "." }
    returner builtin.slice(sti, 0, siste)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_STARTAPP_ROOT")
    la project_root = env("NORSCODE_STARTAPP_PROJECT_ROOT")
    la app = env("NORSCODE_STARTAPP_NAME")
    hvis root == "" eller project_root == "" eller app == "" { returner 2 }
    la template_root = root + "/apps/users"
    la app_root = project_root + "/apps/" + app
    hvis ikkje ok(exec("mkdir -p " + shell(app_root + "/tests/payloads") + " " + shell(app_root + "/migrations"))) { returner 1 }
    la listed = exec("find " + shell(template_root) + " -type f -print")
    hvis ikkje ok(listed) { returner 1 }
    la files = builtin.split(listed[1], "\n")
    la i: heiltall = 0
    mens i < lengde(files) {
        la source = builtin.trim(files[i])
        hvis source != "" {
            la relative = builtin.slice(source, lengde(template_root) + 1, lengde(source))
            relative = builtin.replace(relative, "users", app)
            la target = app_root + "/" + relative
            exec("mkdir -p " + shell(dirname(target)))
            la body = builtin.fil_les(source)
            builtin.fil_skriv(target, builtin.replace(body, "users", app))
        }
        i = i + 1
    }
    skriv("Appmodul oppretta: " + app_root)
    returner 0
}

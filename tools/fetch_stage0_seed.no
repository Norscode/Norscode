// tools/fetch_stage0_seed.no — hent eller verifiser stage0-seed

bruk std.path som path

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon bytes(sti: tekst) -> tekst {
    prøv {
        la innhald = builtin.fil_les(sti)
        returner tekst_fra_heltall(lengde(innhald))
    } fang (e) {}
    returner første_felt(res_felt(kommando("wc -c " + shell(sti)), 1))
}

funksjon byte_status(sti: tekst) -> tekst {
    la n = env("NORSCODE_STAGE0_SEED_BYTES")
    hvis n == "" { n = bytes(sti) }
    hvis n == "" { returner "storleik ukjent" }
    returner n + " bytes"
}

funksjon json_strengverdi_etter(src: tekst, key: tekst, start: heiltall) -> tekst {
    la keypat = "\"" + key + "\""
    la rest = builtin.slice(src, start, lengde(src))
    la key_rel = builtin.index_of(rest, keypat)
    hvis key_rel < 0 { returner "" }
    la etter_key = start + key_rel + lengde(keypat)
    rest = builtin.slice(src, etter_key, lengde(src))
    la kolon_rel = builtin.index_of(rest, ":")
    hvis kolon_rel < 0 { returner "" }
    la etter_kolon = etter_key + kolon_rel + 1
    rest = builtin.slice(src, etter_kolon, lengde(src))
    la start_sitat_rel = builtin.index_of(rest, "\"")
    hvis start_sitat_rel < 0 { returner "" }
    la verdi_start = etter_kolon + start_sitat_rel + 1
    rest = builtin.slice(src, verdi_start, lengde(src))
    la slutt_sitat_rel = builtin.index_of(rest, "\"")
    hvis slutt_sitat_rel < 0 { returner "" }
    returner builtin.slice(src, verdi_start, verdi_start + slutt_sitat_rel)
}

funksjon finn_download_url_med_match(json: tekst, asset: tekst, eksakt: bool) -> tekst {
    la pos = 0
    la namepat = "\"name\""
    mens pos < lengde(json) {
        la rest = builtin.slice(json, pos, lengde(json))
        la rel = builtin.index_of(rest, namepat)
        hvis rel < 0 { returner "" }
        la name_pos = pos + rel
        la namn = json_strengverdi_etter(json, "name", name_pos)
        hvis (eksakt og namn == asset) eller ((ikkje eksakt) og builtin.starts_with(namn, asset)) {
            la url = json_strengverdi_etter(json, "browser_download_url", name_pos)
            hvis url != "" og url != "null" { returner url }
        }
        pos = name_pos + lengde(namepat)
    }
    returner ""
}

funksjon finn_download_url(json: tekst, asset: tekst) -> tekst {
    hvis json == "" { returner "" }
    la url = finn_download_url_med_match(json, asset, sann)
    hvis url != "" { returner url }
    returner finn_download_url_med_match(json, asset, falsk)
}

funksjon platform_name() -> tekst {
    la os = trim(res_felt(kommando("uname -s"), 1))
    la arch = trim(res_felt(kommando("uname -m"), 1))
    hvis os == "Darwin" {
        hvis arch == "arm64" { returner "macos-arm64" }
        hvis arch == "x86_64" { returner "macos-x86_64" }
    }
    hvis os == "Linux" {
        hvis arch == "x86_64" eller arch == "amd64" { returner "linux-x86_64" }
        hvis arch == "aarch64" eller arch == "arm64" { returner "linux-arm64" }
    }
    returner ""
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la platform = env("NORSCODE_STAGE0_PLATFORM")
    hvis platform == "" { platform = platform_name() }
    hvis platform == "" {
        linje("Feil: ukjent plattform")
        returner 1
    }

    la dest = root + "/bootstrap/stage0/norscode-" + platform
    kommando("mkdir -p " + shell(path.dirname(dest)))
    hvis fil_finst(dest) {
        linje("✓ stage0-seed finst: " + dest + " (" + byte_status(dest) + ")")
        returner 0
    }

    la repo = env("NORSCODE_RELEASE_REPO")
    hvis repo == "" { repo = env("GITHUB_REPOSITORY") }
    hvis repo == "" { repo = "Norscode/Norscode" }
    la asset_name = "norscode-" + platform
    la releases_url = "https://api.github.com/repos/" + repo + "/releases/latest"
    la token = env("GITHUB_TOKEN")
    hvis token == "" { token = env("GH_TOKEN") }

    hvis ikkje ok(kommando("command -v curl >/dev/null 2>&1")) og ikkje ok(kommando("command -v wget >/dev/null 2>&1")) {
        linje("Feil: trenger curl eller wget")
        returner 1
    }

    linje("Hentar " + asset_name + " frå " + repo + " ...")
    la json_cmd = ""
    hvis ok(kommando("command -v curl >/dev/null 2>&1")) {
        hvis token != "" {
            json_cmd = "curl -fsSL -H " + shell("Authorization: Bearer " + token) + " -H 'Accept: application/vnd.github+json' " + shell(releases_url)
        } ellers {
            json_cmd = "curl -fsSL " + shell(releases_url)
        }
    } ellers {
        hvis token != "" {
            json_cmd = "wget -qO- --header=" + shell("Authorization: Bearer " + token) + " --header='Accept: application/vnd.github+json' " + shell(releases_url)
        } ellers {
            json_cmd = "wget -qO- " + shell(releases_url)
        }
    }
    la release_json = res_felt(kommando(json_cmd), 1)
    hvis release_json == "" {
        linje("Feil: kunne ikkje hente release-info")
        returner 1
    }

    la download_url = finn_download_url(release_json, asset_name)
    hvis download_url == "" eller download_url == "null" {
        linje("Feil: ingen release-asset " + asset_name)
        linje("Legg fil i bootstrap/stage0/ eller publiser ein release.")
        returner 1
    }

    la tmp = trim(res_felt(kommando("mktemp"), 1))
    la file_cmd = ""
    hvis ok(kommando("command -v curl >/dev/null 2>&1")) {
        hvis token != "" {
            file_cmd = "curl -fsSL -L -H " + shell("Authorization: Bearer " + token) + " -H 'Accept: application/octet-stream' " + shell(download_url) + " > " + shell(tmp)
        } ellers {
            file_cmd = "curl -fsSL -L " + shell(download_url) + " > " + shell(tmp)
        }
    } ellers {
        hvis token != "" {
            file_cmd = "wget -qO- --header=" + shell("Authorization: Bearer " + token) + " --header='Accept: application/octet-stream' " + shell(download_url) + " > " + shell(tmp)
        } ellers {
            file_cmd = "wget -qO- " + shell(download_url) + " > " + shell(tmp)
        }
    }
    hvis ikkje ok(kommando(file_cmd + " && mv " + shell(tmp) + " " + shell(dest) + " && chmod +x " + shell(dest))) {
        kommando("rm -f " + shell(tmp))
        linje("Feil: kunne ikkje laste ned seed")
        returner 1
    }

    la tmp_no = trim(res_felt(kommando("mktemp ${TMPDIR:-/tmp}/nc_seed_smoke_XXXXXX.no"), 1))
    builtin.fil_skriv(tmp_no, "funksjon start() { returner 0 }\n")
    hvis ikkje ok(kommando("NORSCODE_CMD=run NORSCODE_FILE=" + shell(tmp_no) + " " + shell(dest) + " >/dev/null 2>&1")) {
        kommando("rm -f " + shell(tmp_no) + " " + shell(dest))
        linje("Feil: nedlasta seed feila røyktest")
        returner 1
    }
    kommando("rm -f " + shell(tmp_no))
    linje("✓ stage0-seed: " + dest + " (" + byte_status(dest) + ")")
    returner 0
}

// tools/fetch_stage0_seed.no — hent eller verifiser stage0-seed

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon bytes(sti: tekst) -> tekst {
    returner trim(res_felt(kommando("wc -c < " + shell(sti) + " | tr -d ' '"), 1))
}

funksjon platform_name() -> tekst {
    la os = trim(res_felt(kommando("uname -s"), 1))
    la arch = trim(res_felt(kommando("uname -m"), 1))
    hvis os == "Darwin" {
        hvis arch == "arm64" { returner "macos-arm64" }
        hvis arch == "x86_64" { returner "macos-x86_64" }
    }
    hvis os == "Linux" {
        hvis arch == "x86_64" eller arch == "amd64" { returner "linux-x86_64" }
        hvis arch == "aarch64" eller arch == "arm64" { returner "linux-arm64" }
    }
    returner ""
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la platform = platform_name()
    hvis platform == "" {
        linje("Feil: ukjent plattform")
        returner 1
    }

    la dest = root + "/bootstrap/stage0/norscode-" + platform
    kommando("mkdir -p $(dirname " + shell(dest) + ")")
    hvis fil_finst(dest) {
        linje("✓ stage0-seed finst: " + dest + " (" + bytes(dest) + " bytes)")
        returner 0
    }

    la repo = env("NORSCODE_RELEASE_REPO")
    hvis repo == "" { repo = env("GITHUB_REPOSITORY") }
    hvis repo == "" { repo = "Norscode/Norscode" }
    la asset_name = "norscode-" + platform
    la releases_url = "https://api.github.com/repos/" + repo + "/releases/latest"
    la token = env("GITHUB_TOKEN")
    hvis token == "" { token = env("GH_TOKEN") }

    hvis ikkje ok(kommando("command -v curl >/dev/null 2>&1")) og ikkje ok(kommando("command -v wget >/dev/null 2>&1")) {
        linje("Feil: trenger curl eller wget")
        returner 1
    }

    linje("Hentar " + asset_name + " frå " + repo + " ...")
    la json_cmd = ""
    hvis ok(kommando("command -v curl >/dev/null 2>&1")) {
        hvis token != "" {
            json_cmd = "curl -fsSL -H " + shell("Authorization: Bearer " + token) + " -H 'Accept: application/vnd.github+json' " + shell(releases_url)
        } ellers {
            json_cmd = "curl -fsSL " + shell(releases_url)
        }
    } ellers {
        hvis token != "" {
            json_cmd = "wget -qO- --header=" + shell("Authorization: Bearer " + token) + " --header='Accept: application/vnd.github+json' " + shell(releases_url)
        } ellers {
            json_cmd = "wget -qO- " + shell(releases_url)
        }
    }
    la release_json = res_felt(kommando(json_cmd), 1)
    hvis release_json == "" {
        linje("Feil: kunne ikkje hente release-info")
        returner 1
    }

    la download_url = ""
    hvis ok(kommando("command -v jq >/dev/null 2>&1")) {
        download_url = trim(res_felt(kommando("printf '%s' " + shell(release_json) + " | jq -r --arg n " + shell(asset_name) + " '.assets[] | select(.name == $n or (.name | startswith($n))) | .browser_download_url' | head -1"), 1))
    } ellers {
        download_url = trim(res_felt(kommando("printf '%s' " + shell(release_json) + " | grep -o '\"browser_download_url\":[[:space:]]*\"[^\"]*" + asset_name + "[^\"]*\"' | head -1 | cut -d'\"' -f4"), 1))
    }
    hvis download_url == "" eller download_url == "null" {
        linje("Feil: ingen release-asset " + asset_name)
        linje("Legg fil i bootstrap/stage0/ eller publiser ein release.")
        returner 1
    }

    la tmp = trim(res_felt(kommando("mktemp"), 1))
    la file_cmd = ""
    hvis ok(kommando("command -v curl >/dev/null 2>&1")) {
        hvis token != "" {
            file_cmd = "curl -fsSL -L -H " + shell("Authorization: Bearer " + token) + " -H 'Accept: application/octet-stream' " + shell(download_url) + " > " + shell(tmp)
        } ellers {
            file_cmd = "curl -fsSL -L " + shell(download_url) + " > " + shell(tmp)
        }
    } ellers {
        hvis token != "" {
            file_cmd = "wget -qO- --header=" + shell("Authorization: Bearer " + token) + " --header='Accept: application/octet-stream' " + shell(download_url) + " > " + shell(tmp)
        } ellers {
            file_cmd = "wget -qO- " + shell(download_url) + " > " + shell(tmp)
        }
    }
    hvis ikkje ok(kommando(file_cmd + " && mv " + shell(tmp) + " " + shell(dest) + " && chmod +x " + shell(dest))) {
        kommando("rm -f " + shell(tmp))
        linje("Feil: kunne ikkje laste ned seed")
        returner 1
    }

    la tmp_no = trim(res_felt(kommando("mktemp ${TMPDIR:-/tmp}/nc_seed_smoke_XXXXXX.no"), 1))
    kommando("printf 'funksjon start() { returner 0 }\\n' > " + shell(tmp_no))
    hvis ikkje ok(kommando("NORSCODE_CMD=run NORSCODE_FILE=" + shell(tmp_no) + " " + shell(dest) + " >/dev/null 2>&1")) {
        kommando("rm -f " + shell(tmp_no) + " " + shell(dest))
        linje("Feil: nedlasta seed feila røyktest")
        returner 1
    }
    kommando("rm -f " + shell(tmp_no))
    linje("✓ stage0-seed: " + dest + " (" + bytes(dest) + " bytes)")
    returner 0
}

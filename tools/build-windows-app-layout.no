// tools/build-windows-app-layout.no — bygg Windows app-layout

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon abs_sti(root: tekst, sti: tekst) -> tekst {
    hvis builtin.starts_with(sti, "/") { returner sti }
    returner root + "/" + sti
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon skriv_fil(sti: tekst, innhald: tekst) -> bool {
    prøv {
        builtin.fil_skriv(sti, innhald)
        returner sann
    } fang (e) {
        linje("Feil: klarte ikkje skrive " + sti + ": " + tekst(e))
        returner usann
    }
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la out_root = env("NORSCODE_WINDOWS_LAYOUT_OUT")
    hvis out_root == "" { out_root = root + "/build/windows-app" }
    out_root = abs_sti(root, out_root)
    la app_name = env("NORSCODE_WINDOWS_LAYOUT_NAME")
    hvis app_name == "" { app_name = "Norscode" }
    la exe_path = env("NORSCODE_WINDOWS_EXE_PATH")

    hvis exe_path == "" {
        linje("Feil: manglar path til Windows-native .exe")
        returner 1
    }
    exe_path = abs_sti(root, exe_path)
    hvis ikkje fil_finst(exe_path) {
        linje("Feil: fann ikkje .exe-artefakt: " + exe_path)
        returner 1
    }

    la app_dir = out_root + "/" + app_name
    la bin_dir = app_dir + "/bin"
    la doc_dir = app_dir + "/docs"

    hvis ikkje run("rm -rf " + shell(app_dir)) { returner 1 }
    hvis ikkje run("mkdir -p " + shell(bin_dir) + " " + shell(doc_dir)) { returner 1 }
    hvis ikkje run("cp " + shell(exe_path) + " " + shell(bin_dir + "/norscode.exe")) { returner 1 }
    hvis ikkje run("cp " + shell(exe_path) + " " + shell(bin_dir + "/nc.exe")) { returner 1 }

    hvis ikkje skriv_fil(bin_dir + "/nc.cmd", "@echo off\nset SCRIPT_DIR=%~dp0\n\"%SCRIPT_DIR%norscode.exe\" %*\n") { returner 1 }
    hvis ikkje skriv_fil(bin_dir + "/nc.ps1", "$ScriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path\n& (Join-Path $ScriptDir \"norscode.exe\") @args\n") { returner 1 }
    hvis ikkje skriv_fil(app_dir + "/README.txt", "Norscode for Windows\n====================\n\nApp-layout:\n- bin/norscode.exe\n- bin/nc.exe\n- bin/nc.cmd\n- bin/nc.ps1\n\nKøyring:\n- PowerShell: ./bin/nc.ps1 --help\n- CMD: ./bin/nc.cmd --help\n- Direkte: ./bin/norscode.exe --help\n") { returner 1 }
    hvis ikkje skriv_fil(doc_dir + "/LAYOUT.txt", "Windows app-layout for Norscode\n===============================\n\nDenne katalogen er den første app-layouten for Windows-sporet.\nHan gjer ZIP-distribusjonen meir stabil enn ein laus .exe, og er grunnlaget for seinare installasjon og oppgradering.\n") { returner 1 }

    linje("Bygde Windows app-layout: " + app_dir)
    returner 0
}

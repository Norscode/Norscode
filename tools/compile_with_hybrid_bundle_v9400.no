// tools/compile_with_hybrid_bundle_v9400.no — Norscode-entrypoint for hybrid compile-løypa
//
// Merk: sjølve v9400-transformasjonen er framleis Node-basert overgangskode.
// Denne fila eig Norscode-sida av kontrakten: argument, preflight og logging.

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon executable(sti: tekst) -> bool {
    returner fil_finst(sti)
}

funksjon node_finst(home: tekst) -> bool {
    hvis ok(kommando("command -v node >/dev/null 2>&1")) { returner sann }
    hvis home != "" {
        returner executable(home + "/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node")
    }
    returner usann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_HYBRID_ROOT")
    hvis root == "" { root = trim(felt(kommando("pwd"), 1)) }
    la src = env("NORSCODE_HYBRID_SRC")
    la out = env("NORSCODE_HYBRID_OUT")
    la modul = env("NORSCODE_HYBRID_MODULE")
    hvis modul == "" { modul = "__main__" }
    la project_root = env("NORSCODE_HYBRID_PROJECT_ROOT")
    hvis project_root == "" { project_root = root }
    la native_bin = env("NORSCODE_NATIVE_BIN")
    hvis native_bin == "" { native_bin = root + "/dist/norscode_native" }
    la home = env("HOME")

    hvis src == "" eller out == "" {
        linje("Bruk: NORSCODE_HYBRID_ROOT=<repo-root> NORSCODE_HYBRID_SRC=<src.no> NORSCODE_HYBRID_OUT=<out.ncb.json> ./bin/nc run tools/compile_with_hybrid_bundle_v9400.no")
        linje("Valfritt: set NORSCODE_HYBRID_MODULE og NORSCODE_HYBRID_PROJECT_ROOT")
        returner 1
    }
    hvis ikkje builtin.fil_finnes(src) {
        linje("feil: manglar kjelde: " + src)
        returner 1
    }
    hvis ikkje executable(native_bin) {
        linje("feil: manglar native runtime: " + native_bin)
        returner 1
    }
    hvis ikkje node_finst(home) {
        linje("feil: fann ikkje node. Sett NODE_BIN eller installer node i PATH.")
        returner 1
    }

    la cmd = shell(root + "/tools/compile_with_hybrid_bundle_v9400.sh") + " --from-no " + shell(root) + " " + shell(src) + " " + shell(out) + " " + shell(modul) + " " + shell(project_root)
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    hvis ok(res) {
        hvis builtin.fil_finnes(out) {
            linje("Hybrid compile: " + out)
            returner 0
        }
        linje("feil: kompilering skreiv ikkje " + out)
        returner 1
    }
    returner 1
}

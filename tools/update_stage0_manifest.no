// tools/update_stage0_manifest.no — Norscode-eigd SHA256-manifest
bruk std.liste som liste

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon manifest_linjer_fra_input(rå: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la linjer = builtin.split(rå, "\n")
    la i: heiltall = 0
    mens i < lengde(linjer) {
        la line = builtin.trim(linjer[i])
        hvis line != "" { legg_til(ut, line) }
        i = i + 1
    }
    liste.sorter_tekst(ut)
    returner ut
}

funksjon stage0_seed_files() -> liste_tekst {
    la rå = env("NORSCODE_STAGE0_MANIFEST_INPUT")
    la ut: liste_tekst = []
    la linjer = builtin.split(rå, "\n")
    la i: heiltall = 0
    mens i < lengde(linjer) {
        hvis builtin.trim(linjer[i]) != "" { legg_til(ut, builtin.trim(linjer[i])) }
        i = i + 1
    }
    liste.sorter_tekst(ut)
    returner ut
}

funksjon manifest_innhald(rå: tekst) -> tekst {
    la linjer = manifest_linjer_fra_input(rå)
    hvis lengde(linjer) == 0 { returner "" }
    returner builtin.join(linjer, "\n") + "\n"
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la rå = env("NORSCODE_STAGE0_MANIFEST_INPUT")
    hvis rå == "" og env("NORSCODE_STAGE0_MANIFEST_ALLOW_EMPTY") != "1" {
        skriv("Feil: NORSCODE_STAGE0_MANIFEST_INPUT manglar\n")
        returner 1
    }
    la innhald = manifest_innhald(rå)
    builtin.fil_skriv(root + "/bootstrap/stage0/SHA256SUMS", innhald)
    skriv("✓ Manifest oppdatert: bootstrap/stage0/SHA256SUMS\n")
    returner 0
}

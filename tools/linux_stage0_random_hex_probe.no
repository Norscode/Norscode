// tools/linux_stage0_random_hex_probe.no — Linux-only random_hex planprobe

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner builtin.trim(res[idx]) }
    returner ""
}

funksjon start() -> heiltall {
    la os = felt(kommando("uname -s"), 1)
    hvis os == "Darwin" {
        linje("v850 skip: Linux-only probe (darwin not supported)")
        returner 0
    }

    la plan = "prosjekter/NorscodeWeb/app_linux_stage0_random_hex_plan_v731.no"
    hvis ikkje ok(kommando("test -f '" + plan + "'")) {
        linje("Plan file not found: " + plan)
        returner 1
    }

    linje("v850: probing builtin.random_hex in stage0 Linux plan context")
    hvis ok(kommando("grep -q 'builtin[.]random_hex' '" + plan + "'")) {
        linje("found builtin.random_hex references")
        linje("v850: still references random_hex in plan script/examples")
    } ellers {
        linje("v850: no builtin.random_hex references")
    }

    linje("v850: DONE")
    returner 0
}

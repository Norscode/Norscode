// tools/regenerate_omgang6b_fragments_safe.no — regenerer precompiled fragments

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon fragment_namn(src_file: tekst) -> tekst {
    hvis builtin.ends_with(src_file, ".ncb.json") {
        returner builtin.slice(src_file, 0, lengde(src_file) - lengde(".ncb.json")) + ".functions.json"
    }
    returner src_file + ".functions.json"
}

funksjon omdøyp_kall_i_kode(fn, modul_namn: tekst) {
    la kode = fn["code"]
    la i: heiltall = 0
    mens i < lengde(kode) {
        la instr = kode[i]
        hvis builtin.type(instr) == "liste" og lengde(instr) >= 2 {
            hvis instr[0] == "CALL" og builtin.type(instr[1]) == "tekst" og builtin.starts_with(instr[1], "__main__.") {
                instr[1] = modul_namn + builtin.slice(instr[1], 8, lengde(instr[1]))
            }
        }
        i = i + 1
    }
}

funksjon omskriv_funksjonar(precompiled_sti: tekst, modul_namn: tekst) -> tekst {
    la ncb_json = fil_les(precompiled_sti)
    la ncb = json_parse_raw(ncb_json)
    la fns = ncb["functions"]
    la nk = nøkler(fns)
    la ny_fns: ordbok<tekst, tekst> = {}
    la i: heiltall = 0
    mens i < lengde(nk) {
        la gammal_nøkkel = nk[i]
        la fn = fns[gammal_nøkkel]
        la suffix = gammal_nøkkel
        hvis builtin.starts_with(gammal_nøkkel, "__main__.") {
            suffix = builtin.slice(gammal_nøkkel, 9, lengde(gammal_nøkkel))
        }
        fn["module"] = modul_namn
        omdøyp_kall_i_kode(fn, modul_namn)
        ny_fns[modul_namn + "." + suffix] = fn
        i = i + 1
    }
    returner json_skriv(ny_fns)
}

funksjon rewrite_one(root: tekst, src_file: tekst, module_name: tekst) -> bool {
    la src_path = root + "/bootstrap/precompiled/" + src_file
    la out_name = fragment_namn(src_file)
    la outer_path = root + "/bootstrap/precompiled_fragments/" + out_name
    la inner_path = root + "/bootstrap/precompiled_fragments_inner/" + out_name
    la outer = omskriv_funksjonar(src_path, module_name)
    la inner = builtin.slice(outer, 1, lengde(outer) - 1)
    fil_skriv(outer_path, outer)
    fil_skriv(inner_path, inner)
    la outer_size = tekst_fra_heltall(lengde(outer))
    la inner_size = tekst_fra_heltall(lengde(inner))
    linje(out_name + ": outer=" + outer_size + " inner=" + inner_size)
    returner sann
}

funksjon start() -> heiltall {
    la root = "."
    hvis ikkje rewrite_one(root, "lexer_m1.ncb.json", "selfhost.lexer.lexer_m1") { returner 1 }
    hvis ikkje rewrite_one(root, "parser.ncb.json", "selfhost.parser") { returner 1 }
    hvis ikkje rewrite_one(root, "semantic.ncb.json", "selfhost.compiler.semantic") { returner 1 }
    hvis ikkje rewrite_one(root, "ir_to_bytecode.ncb.json", "selfhost.compiler.ir_to_bytecode") { returner 1 }
    hvis ikkje rewrite_one(root, "json.ncb.json", "selfhost.json") { returner 1 }
    hvis ikkje rewrite_one(root, "kompiler.ncb.json", "selfhost.kompiler") { returner 1 }
    hvis ikkje rewrite_one(root, "bundler.ncb.json", "selfhost.bundler") { returner 1 }
    hvis ikkje rewrite_one(root, "elf_compile_driver.ncb.json", "selfhost.elf_compile_driver") { returner 1 }
    returner 0
}

# native_media_runtime_gate_v3010.no — bytes- og mediegate for runtimekandidat

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        returner ["1", "", tekst(e)]
    }
}

funksjon felt(res: liste_tekst, indeks: heiltall) -> tekst {
    hvis lengde(res) > indeks { returner res[indeks] }
    returner ""
}

funksjon ok(res: liste_tekst) -> boolsk {
    returner felt(res, 0) == "0"
}

funksjon koyr_test(root: tekst, kandidat: tekst, testfil: tekst,
                   markor: tekst) -> boolsk {
    // Køyr kandidaten direkte. `bin/nc run` med NORSCODE_NATIVE_BIN set
    // startar ein ekstra wrapper/compile-loop og kan aldri representere
    // den sjølvstendige release-vegen.
    la cmd = "cd " + shell(root) +
        " && env NORSCODE_HOST_NCB_FILE= NORSCODE_NCB_FILE= NORSCODE_VM_SOURCE=0 NORSCODE_CMD=run NORSCODE_FILE=" + shell(root + "/" + testfil) +
        " NORSCODE_ROOT=" + shell(root) +
        " NORSCODE_VM_CAPABILITIES=disk.read,disk.write" +
        " NORSCODE_VM_DISK_ROOT=. " + shell(kandidat)
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res) og builtin.contains(felt(res, 1), markor)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = builtin.trim(felt(kommando("pwd"), 1)) }
    la kandidat = env("NORSCODE_MEDIA_RUNTIME_BIN")
    hvis kandidat == "" { kandidat = root + "/build/v3010/norscode_native_macos_arm64_v3010" }

    hvis ikkje koyr_test(root, kandidat, "tests/test_native_bytes_runtime.no", "test_native_bytes_runtime OK") {
        skriv("[FAIL] native bytes eller binær fil-I/O\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_media_binary_read.no", "test_media_binary_read OK") {
        skriv("[FAIL] std.fil binær lesing\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_media_local.no", "test_media_local OK") {
        skriv("[FAIL] lokal PPM/WAV/Y4M-mediegenerering\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_model_runtime.no", "test_model_runtime OK") {
        skriv("[FAIL] lokal kvantisert modellruntime\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_qmodel_binary_file.no", "test_qmodel_binary_file OK") {
        skriv("[FAIL] binært qmodel-format og filinnlasting\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_model_registry.no", "test_model_registry OK") {
        skriv("[FAIL] avgrensa modellregister og livssyklus\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_model_trust.no", "test_model_trust OK") {
        skriv("[FAIL] SHA-256-verifisert modelltillit\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_sampling.no", "test_sampling OK") {
        skriv("[FAIL] deterministisk og avgrensa token-sampling\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_transformer.no", "test_transformer OK") {
        skriv("[FAIL] kvantisert kausal transformerblokk\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_text_generation.no", "test_text_generation OK") {
        skriv("[FAIL] lokal autoregressiv tekstgenerering\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_tokenizer.no", "test_tokenizer OK") {
        skriv("[FAIL] lokal tekst-tokenisering\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_tokenizer_bpe.no", "test_tokenizer_bpe OK") {
        skriv("[FAIL] BPE-vokabulartrening og tokenizerformat\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_text_model_bundle.no", "test_text_model_bundle OK") {
        skriv("[FAIL] NTM1 tekstmodellbundle i minne\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_text_model_bundle_file.no", "test_text_model_bundle_file OK") {
        skriv("[FAIL] NTM1 binær fil-roundtrip\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_text_model_registry.no", "test_text_model_registry OK") {
        skriv("[FAIL] verifisert NTM1-register og genereringslivssyklus\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_text_model_release.no", "test_text_model_release OK") {
        skriv("[FAIL] signert NTM1-utgjeving og atomisk oppgradering\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_model_server.no", "test_model_server OK") {
        skriv("[FAIL] bounded modellserver\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_media_neural.no", "test_media_neural OK") {
        skriv("[FAIL] nevralt styrt lokal mediegenerering\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_media_diffusion.no", "test_media_diffusion OK") {
        skriv("[FAIL] deterministisk CPU-diffusjon\n")
        returner 1
    }
    hvis ikkje koyr_test(root, kandidat, "tests/test_http_binary.no", "test_http_binary OK") {
        skriv("[FAIL] HTTP/Base64-medieflyt\n")
        returner 1
    }
    skriv("[OK] native media runtime gate v3010 er grønn\n")
    returner 0
}

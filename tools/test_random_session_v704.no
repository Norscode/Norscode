// tools/test_random_session_v704.no — røykprøve for random-session-endepunkt

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon køyr(cmd: tekst) -> bool {
    la res = kommando(cmd)
    la out = res_felt(res, 1)
    la err = res_felt(res, 2)
    hvis out != "" { skriv(out) }
    hvis err != "" { skriv(err) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la port = env("NORSCODE_RANDOM_SESSION_PORT")
    hvis port == "" { port = "8118" }
    la jar = "/tmp/norscode_random_session.txt"
    la base = "http://127.0.0.1:" + port
    hvis ikkje ok(kommando("rm -f " + shell(jar))) { returner 1 }

    linje("== login demo ==")
    hvis ikkje køyr("curl -i -c " + shell(jar) + " " + shell(base + "/random-login-demo")) { returner 1 }
    linje("")
    linje("== cookie jar ==")
    hvis ikkje køyr("cat " + shell(jar)) { returner 1 }
    linje("")
    linje("== status ==")
    hvis ikkje køyr("curl -i -b " + shell(jar) + " " + shell(base + "/random-status")) { returner 1 }
    linje("")
    linje("== admin ==")
    hvis ikkje køyr("curl -i -b " + shell(jar) + " " + shell(base + "/random-admin")) { returner 1 }
    linje("")
    linje("== logout ==")
    hvis ikkje køyr("curl -i -b " + shell(jar) + " -c " + shell(jar) + " " + shell(base + "/random-logout")) { returner 1 }
    linje("")
    linje("== status etter logout ==")
    hvis ikkje køyr("curl -i -b " + shell(jar) + " " + shell(base + "/random-status")) { returner 1 }
    returner 0
}

// tools/build_native_candidate_v3002.no — arkivert historisk kandidatloype

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon start() -> heiltall {
    linje("build_native_candidate_v3002: denne gamle kandidatloypa er arkivert.")
    linje("Bruk aktiv native-flyt: ./bin/nc verify-seed, ./bin/nc verify-omgang6b eller ./bin/nc selfhost-bootstrap-gate.")
    returner 2
}

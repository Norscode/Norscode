// tools/selfcompile_native_elf.no — Omgang 6: A→B ELF sjølvkompilering

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon executable(sti: tekst) -> bool {
    returner ok(kommando("test -x " + shell(sti)))
}

funksjon bytes(sti: tekst) -> tekst {
    returner trim(res_felt(kommando("wc -c < " + shell(sti) + " | tr -d ' '"), 1))
}

funksjon run(root: tekst, cmd: tekst) -> bool {
    la res = kommando("cd " + shell(root) + " && " + cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la src = root + "/tests/fixtures/omgang6_selfcompile.no"
    la v1 = root + "/build/omgang6/elf_v1"
    la v2 = root + "/build/omgang6/elf_v2"

    kommando("mkdir -p " + shell(root + "/build/omgang6"))
    hvis ikkje fil_finst(src) {
        linje("Feil: manglar " + src)
        returner 1
    }
    hvis ikkje executable(root + "/dist/norscode_native") {
        hvis ikkje run(root, "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " ./bin/nc run tools/build_norscode_native.no") { returner 1 }
    }

    linje("=== Omgang 6 ELF sjølvkompilering ===")
    linje("")

    linje("[1/3] Gen1: bygg-native...")
    hvis ikkje run(root, shell(root + "/bin/nc") + " bygg-native " + shell(src) + " " + shell(v1)) { returner 1 }
    la b1 = bytes(v1)
    linje("  [OK] " + b1 + " bytes")
    linje("")

    linje("[2/3] Gen2: bygg-native (same kilde)...")
    hvis ikkje run(root, shell(root + "/bin/nc") + " bygg-native " + shell(src) + " " + shell(v2)) { returner 1 }
    la b2 = bytes(v2)
    linje("  [OK] " + b2 + " bytes")
    linje("")

    linje("[3/3] Byte-paritet Gen1 == Gen2...")
    hvis ok(kommando("cmp -s " + shell(v1) + " " + shell(v2))) {
        linje("  [OK] " + b1 + " bytes identiske")
        linje("")
        linje("=== Omgang 6 ELF sjølvkompilering: BESTÅTT ===")
        returner 0
    }
    linje("  [FEIL] ELF differ (v1=" + b1 + ", v2=" + b2 + " bytes)")
    run(root, "cmp -l " + shell(v1) + " " + shell(v2) + " 2>/dev/null | head -5 || true")
    returner 1
}

// tools/bundle_entry_diagnose_v6600.no — diagnose for bundle entry

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = felt(kommando("pwd"), 1)
    root = builtin.trim(root)
    la nc = root + "/dist/norscode_native"
    la outdir = root + "/build/v6600"
    hvis ikkje ok(kommando("mkdir -p " + shell(outdir))) { returner 1 }

    linje("[1/3] plain compile of lexer")
    hvis ikkje run("env NORSCODE_CMD=compile NORSCODE_FILE='selfhost/lexer/lexer_m1.no' NORSCODE_OUTPUT=" + shell(outdir + "/lexer_compile_v6600.ncb.json") + " " + shell(nc)) { returner 1 }

    linje("")
    linje("[2/3] run bundler without args (expect normal error)")
    la log1 = outdir + "/bundler_no_args_v6600.log"
    hvis ok(kommando("env NORSCODE_CMD=run NORSCODE_FILE='selfhost/bundler.no' " + shell(nc) + " >" + shell(log1) + " 2>&1")) {
        kommando("printf '%s\n' 'unexpected-success' >>" + shell(log1))
    } ellers {
        run("cat " + shell(log1))
    }

    linje("")
    linje("[3/3] run bundler with single module arg (current repro)")
    la log2 = outdir + "/bundler_one_arg_v6600.log"
    hvis ok(kommando("env NORSCODE_CMD=run NORSCODE_FILE='selfhost/bundler.no' NORSCODE_BUNDLE_ARGS='selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no' NORSCODE_BUNDLE_OUTPUT=" + shell(outdir + "/bundle_one_v6600.ncb.json") + " " + shell(nc) + " >" + shell(log2) + " 2>&1")) {
        linje("[unexpected] single-module bundle succeeded")
    } ellers {
        run("cat " + shell(log2))
    }
    returner 0
}

// tools/verify_norscode_surface_ownership.no — samla eigarskapsgate

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run_check(cmd: tekst, title: tekst) -> bool {
    la res = kommando(cmd)
    hvis ok(res) {
        linje("OK: " + title)
        hvis trim(felt(res, 1)) != "" { skriv(felt(res, 1)) }
        returner sann
    }
    linje("FEIL: " + title)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner usann
}

funksjon fil_inneheld(sti: tekst, needle: tekst) -> bool {
    prøv {
        returner builtin.index_of(builtin.fil_les(sti), needle) >= 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon startar_med(t: tekst, prefiks: tekst) -> bool {
    returner builtin.starts_with(t, prefiks)
}

funksjon sluttar_med(t: tekst, suffiks: tekst) -> bool {
    hvis lengde(t) < lengde(suffiks) { returner usann }
    returner builtin.slice(t, lengde(t) - lengde(suffiks), lengde(t)) == suffiks
}

funksjon fjern_dot_slash(sti: tekst) -> tekst {
    hvis startar_med(sti, "./") { returner builtin.slice(sti, 2, lengde(sti)) }
    returner sti
}

funksjon aktiv_rel(sti: tekst) -> bool {
    hvis sti == "" { returner usann }
    hvis startar_med(sti, "archive/") { returner usann }
    hvis startar_med(sti, "ai_assistent") { returner usann }
    hvis startar_med(sti, "ai_assistent_bak_") { returner usann }
    hvis startar_med(sti, "tests_bak_") { returner usann }
    returner sann
}

funksjon liste_aktive_filer(root: tekst, mønster: tekst) -> liste_tekst {
    la res = kommando("cd " + shell(root) + " && find . -path ./.git -prune -o " + mønster + " -print")
    la ut: liste_tekst = []
    hvis ikkje ok(res) { returner ut }
    la linjer = builtin.split(felt(res, 1), "\n")
    la i = 0
    mens i < lengde(linjer) {
        la rel = fjern_dot_slash(trim(linjer[i]))
        hvis aktiv_rel(rel) { legg_til(ut, rel) }
        i = i + 1
    }
    returner sorter_tekst(ut)
}

funksjon sett_inn_sortert(liste: liste_tekst, verdi: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la sett = usann
    la i = 0
    mens i < lengde(liste) {
        hvis ikkje sett og verdi < liste[i] {
            legg_til(ut, verdi)
            sett = sann
        }
        legg_til(ut, liste[i])
        i = i + 1
    }
    hvis ikkje sett { legg_til(ut, verdi) }
    returner ut
}

funksjon sorter_tekst(liste: liste_tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la i = 0
    mens i < lengde(liste) {
        ut = sett_inn_sortert(ut, liste[i])
        i = i + 1
    }
    returner ut
}

funksjon utan_suffiks(sti: tekst, suffiks: tekst) -> tekst {
    hvis sluttar_med(sti, suffiks) { returner builtin.slice(sti, 0, lengde(sti) - lengde(suffiks)) }
    returner sti
}

funksjon same_liste(a: liste_tekst, b: liste_tekst) -> bool {
    hvis lengde(a) != lengde(b) { returner usann }
    la i = 0
    mens i < lengde(a) {
        hvis a[i] != b[i] { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon liste_inneheld(liste: liste_tekst, verdi: tekst) -> bool {
    la i = 0
    mens i < lengde(liste) {
        hvis liste[i] == verdi { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon berre_forventa(actual: liste_tekst, expected: liste_tekst) -> bool {
    la i = 0
    mens i < lengde(actual) {
        hvis ikkje liste_inneheld(expected, actual[i]) { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon liste_til_tekst(liste: liste_tekst) -> tekst {
    la ut = ""
    la i = 0
    mens i < lengde(liste) {
        hvis ut != "" { ut = ut + "\n" }
        ut = ut + liste[i]
        i = i + 1
    }
    returner ut
}

funksjon script_eigar_gate(root: tekst) -> bool {
    la filer = liste_aktive_filer(root, "\\( -name '*.sh' -o -name '*.ps1' -o -name '*.js' -o -name '*.swift' \\)")
    la ok_gate = sann
    la i = 0
    mens i < lengde(filer) {
        la p = filer[i]
        la base = utan_suffiks(utan_suffiks(utan_suffiks(utan_suffiks(p, ".sh"), ".ps1"), ".js"), ".swift")
        hvis ikkje builtin.fil_finnes(root + "/" + base + ".no") {
            linje(p + " manglar " + base + ".no")
            ok_gate = usann
        }
        i = i + 1
    }
    hvis ok_gate { linje("OK: alle aktive .sh/.ps1/.js/.swift har same-namn .no-eigar") }
    ellers { linje("FEIL: alle aktive .sh/.ps1/.js/.swift har same-namn .no-eigar") }
    returner ok_gate
}

funksjon script_markor_ok(root: tekst, rel: tekst) -> bool {
    la sti = root + "/" + rel
    hvis sluttar_med(rel, ".sh") {
        hvis fil_inneheld(sti, "Norscode-first wrapper") { returner sann }
        hvis rel == "tools/install.sh" og fil_inneheld(sti, "Bootstrap POSIX-installer") { returner sann }
        hvis rel == "tools/omgang6b_compiler_bundle_args.inc.sh" og fil_inneheld(sti, "Norscode-first include") { returner sann }
        returner usann
    }
    hvis sluttar_med(rel, ".ps1") {
        hvis fil_inneheld(sti, "Norscode-first bridge") { returner sann }
        returner usann
    }
    returner sann
}

funksjon script_markor_gate(root: tekst) -> bool {
    la filer = liste_aktive_filer(root, "\\( -name '*.sh' -o -name '*.ps1' -o -name '*.js' -o -name '*.swift' \\)")
    la ok_gate = sann
    la i = 0
    mens i < lengde(filer) {
        la p = filer[i]
        hvis ikkje script_markor_ok(root, p) {
            linje(p + " manglar Norscode-first markør/bridge eller eksplisitt unntak")
            ok_gate = usann
        }
        i = i + 1
    }
    hvis ok_gate { linje("OK: aktive .sh/.ps1-wrapperar har Norscode-first markør/bridge eller eksplisitt unntak") }
    ellers { linje("FEIL: aktive .sh/.ps1-wrapperar har Norscode-first markør/bridge eller eksplisitt unntak") }
    returner ok_gate
}

funksjon c_overflate_gate(root: tekst) -> bool {
    la actual = liste_aktive_filer(root, "-name '*.c'")
    hvis lengde(actual) == 0 {
        linje("OK: C-rest er avgrensa til kjende genererte artefaktar")
        returner sann
    }
    la expected: liste_tekst = []
    legg_til(expected, "build/bootstrap_compiler_bundle_ncb_data.c")
    legg_til(expected, "build/native_elf_compiler_bundle_ncb_data.c")
    legg_til(expected, "build/v3009/native_candidate_combined.c")
    legg_til(expected, "build/v3009/native_candidate_gc.c")
    legg_til(expected, "build/v3009/native_gc_stress.c")
    legg_til(expected, "build/v3009/norscode_generated.c")
    legg_til(expected, "build/v3009/norscode_generated_gc.c")
    legg_til(expected, "tests/fixtures/windows_process_fixture.c")
    legg_til(expected, "tests/fixtures/windows_utf8_file_fixture.c")
    legg_til(expected, "tests/native_gc_blocked_thread.c")
    legg_til(expected, "tests/native_gc_exception_unwind.c")
    legg_til(expected, "tests/native_gc_generational.c")
    legg_til(expected, "tests/native_gc_lifecycle.c")
    legg_til(expected, "tests/native_gc_relocation.c")
    legg_til(expected, "tests/native_gc_threads.c")
    legg_til(expected, "third_party/sqlite/sqlite3.c")
    expected = sorter_tekst(expected)
    hvis berre_forventa(actual, expected) {
        linje("OK: C-rest er avgrensa til kjende genererte artefaktar")
        returner sann
    }
    linje("FEIL: C-rest er avgrensa til kjende genererte artefaktar")
    linje("uventa C-overflate:")
    linje(liste_til_tekst(actual))
    returner usann
}

funksjon krev_filmarkor(root: tekst, rel: tekst, needle: tekst) -> bool {
    hvis fil_inneheld(root + "/" + rel, needle) { returner sann }
    linje("FEIL: manglar markør i " + rel + ": " + needle)
    returner usann
}

funksjon krev_filmarkor_hvis_finnes(root: tekst, rel: tekst, needle: tekst) -> bool {
    hvis ikkje builtin.fil_finnes(root + "/" + rel) { returner sann }
    returner krev_filmarkor(root, rel, needle)
}

funksjon c_artifact_markorar(root: tekst) -> bool {
    hvis lengde(liste_aktive_filer(root, "-name '*.c'")) == 0 {
        linje("OK: ingen aktive C-artefaktar treng markørsjekk")
        returner sann
    }
    la ok_markor = sann
    hvis ikkje krev_filmarkor_hvis_finnes(root, "build/bootstrap_compiler_bundle_ncb_data.c", "Auto-generated by tools/generate_build_embed_c.no") { ok_markor = usann }
    hvis ikkje krev_filmarkor_hvis_finnes(root, "build/native_elf_compiler_bundle_ncb_data.c", "Auto-generated by tools/generate_build_embed_c.no") { ok_markor = usann }
    hvis ikkje krev_filmarkor_hvis_finnes(root, "build/v3009/norscode_generated.c", "Generert av archive/legacy_c_backend") { ok_markor = usann }
    hvis ikkje krev_filmarkor_hvis_finnes(root, "build/v3009/norscode_generated.c", "IKKJE REDIGER") { ok_markor = usann }
    hvis ikkje krev_filmarkor_hvis_finnes(root, "build/v3009/native_candidate_combined.c", "#include \"norscode_generated.c\"") { ok_markor = usann }
    hvis ok_markor { linje("OK: C-artefaktmarkørar er Norscode-verifiserte") }
    returner ok_markor
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(felt(kommando("pwd"), 1)) }
    la ok_all = sann

    hvis ikkje script_eigar_gate(root) { ok_all = usann }
    hvis ikkje script_markor_gate(root) { ok_all = usann }
    hvis ikkje c_overflate_gate(root) { ok_all = usann }
    hvis ikkje c_artifact_markorar(root) { ok_all = usann }

    hvis ok_all {
        linje("=== Norscode surface ownership: BESTÅTT ===")
        returner 0
    }
    linje("=== Norscode surface ownership: FEILA ===")
    returner 1
}

// Kjor Windows-native smoke-tests pa ein faktisk Windows-host.
// Cross-compile-gaten kan kjorast pa macOS/Linux; denne gaten krev Windows.

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst { returner "'" + sti + "'" }

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv {
        la comspec = env("ComSpec")
        hvis comspec != "" {
            la escaped = builtin.replace(cmd, "\"", "\\\"")
            returner builtin.exec_prosess("bash.exe -lc \"" + escaped + "\"")
        }
        returner builtin.exec_prosess(cmd)
    } fang (e) { returner ["1", "", tekst(e)] }
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon ok(res: liste_tekst) -> boolsk { returner felt(res, 0) == "0" }

funksjon er_windows() -> boolsk {
    la res = kommando("uname -s 2>/dev/null")
    la system = felt(res, 1)
    returner builtin.starts_with(system, "MINGW") eller builtin.starts_with(system, "MSYS") eller
        builtin.starts_with(system, "CYGWIN") eller builtin.starts_with(system, "Windows")
}

funksjon kjor(sti: tekst, namn: tekst) -> heiltall {
    la res = kommando(shell(sti))
    hvis ikkje ok(res) {
        skriv("[FAIL] Windows " + namn + ": " + felt(res, 2) + "\n")
        returner 1
    }
    skriv(felt(res, 1))
    returner 0
}

funksjon start() -> heiltall {
    hvis ikkje er_windows() {
        skriv("[FAIL] Windows execution-gate krev faktisk Windows-host\n")
        returner 2
    }
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la smoke = env("NORSCODE_WINDOWS_BACKEND_SMOKE")
    hvis smoke == "" { smoke = root + "/build/windows/nc_windows_backend_smoke_x86_64.exe" }
    la app = env("NORSCODE_WINDOWS_APPCONTAINER_SMOKE")
    hvis app == "" { app = root + "/build/windows/nc_windows_appcontainer_smoke_x86_64.exe" }
    hvis kjor(smoke, "backend smoke") != 0 { returner 1 }
    hvis kjor(app, "AppContainer smoke") != 0 { returner 1 }
    skriv("[OK] Windows runtime execution-gate er grøn\n")
    returner 0
}

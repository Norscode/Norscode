// tools/rollback_serve_runner_cookie_fix_v682.no — historisk rollback-verktøy

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la target = root + "/selfhost/serve_runner.no"
    la backup = root + "/selfhost/serve_runner.no.bak_cookie_header_fix_v681"

    hvis ikkje builtin.fil_finnes(backup) {
        linje("FEIL: backup finnes ikkje: selfhost/serve_runner.no.bak_cookie_header_fix_v681")
        returner 1
    }
    hvis ikkje run("cp " + shell(backup) + " " + shell(target)) { returner 1 }
    hvis ikkje run(shell(root + "/bin/nc") + " check " + shell(target)) { returner 1 }
    linje("OK: serve_runner rullet tilbake fra selfhost/serve_runner.no.bak_cookie_header_fix_v681")
    returner 0
}

// tools/compare_compilers.no — enkel kompilator-hashsamanlikning i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon første_ord(linje_inn: tekst) -> tekst {
    la s = trim(linje_inn)
    la out = ""
    la i = 0
    mens i < lengde(s) {
        la ch = s[i]
        hvis ch == " " eller ch == "\t" eller ch == "\n" eller ch == "\r" {
            returner out
        }
        out = out + ch
        i = i + 1
    }
    returner out
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv {
        builtin.fil_les(sti)
        returner sann
    } fang (e) {
        returner usann
    }
}

funksjon sha256(sti: tekst, preset: tekst) -> tekst {
    hvis preset != "" { returner første_ord(preset) }
    returner første_ord(res_felt(kommando("shasum -a 256 " + shell(sti)), 1))
}

funksjon start() -> heiltall {
    la comp_a = env("NORSCODE_COMPILER_A")
    la comp_b = env("NORSCODE_COMPILER_B")
    hvis comp_a == "" eller comp_b == "" {
        linje("Usage: NORSCODE_COMPILER_A=<compiler_a> NORSCODE_COMPILER_B=<compiler_b> ./bin/nc run tools/compare_compilers.no")
        returner 1
    }
    hvis ikkje fil_finst(comp_a) {
        linje("Missing compiler: " + comp_a)
        returner 1
    }
    hvis ikkje fil_finst(comp_b) {
        linje("Missing compiler: " + comp_b)
        returner 1
    }

    la hash_a = sha256(comp_a, env("NORSCODE_COMPILER_SHA_A"))
    la hash_b = sha256(comp_b, env("NORSCODE_COMPILER_SHA_B"))
    linje("Compiler A: " + comp_a)
    linje("Compiler B: " + comp_b)
    linje("")
    linje("Hash A: " + hash_a)
    linje("Hash B: " + hash_b)
    linje("")
    hvis hash_a == hash_b {
        linje("Compiler equivalence PASSED")
        returner 0
    }
    linje("Compiler equivalence FAILED")
    linje("Differences detected between compiler outputs")
    returner 1
}

// tools/probe_macos_native_rebuild_v722.no — kartlegg macOS native rebuild-løype

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon vis(cmd: tekst) -> heiltall {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner 0
}

funksjon start() -> heiltall {
    linje("== Plattform ==")
    vis("uname -a")
    vis("uname -s")
    vis("uname -m")

    linje("")
    linje("== Nåværende binary ==")
    vis("file dist/norscode_native || true")
    vis("ls -lh dist/norscode_native || true")
    vis("strings dist/norscode_native | grep -n 'random_hex' | head -20 || true")

    linje("")
    linje("== Stage0 macOS ==")
    vis("file bootstrap/stage0/norscode-macos-arm64 || true")
    vis("ls -lh bootstrap/stage0/norscode-macos-arm64 || true")
    vis("strings bootstrap/stage0/norscode-macos-arm64 | grep -n 'random_hex' | head -20 || true")

    linje("")
    linje("== Mach-O / macOS søk ==")
    vis("/usr/bin/grep -R -n 'Mach-O\\|mach-o\\|macos\\|Darwin\\|LC_MAIN\\|LC_SEGMENT\\|arm64' selfhost tools bootstrap src 2>/dev/null | head -200 || true")

    linje("")
    linje("== ELF-løype søk ==")
    vis("/usr/bin/grep -R -n 'ELF\\|linux\\|x86_64\\|ncb_to_elf\\|bygg-native' selfhost tools bootstrap src 2>/dev/null | head -200 || true")

    linje("")
    linje("Konklusjon: hvis Mach-O generator ikke finnes, kan macOS stage0 ikke bygges lokalt ennå.")
    returner 0
}

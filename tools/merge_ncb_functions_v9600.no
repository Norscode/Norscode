// Byter ut funksjonar i ein kandidatbundle utan å røre dist/stage0.
funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon start() -> heiltall {
    la base_sti = env("NORSCODE_NCB_BASE")
    la patch_sti = env("NORSCODE_NCB_PATCH")
    la ut_sti = env("NORSCODE_NCB_OUT")
    hvis base_sti == "" eller patch_sti == "" eller ut_sti == "" { returner 2 }
    la base = builtin.json_parse_raw(builtin.fil_les(base_sti))
    la patch = builtin.json_parse_raw(builtin.fil_les(patch_sti))
    la fns = base["functions"]
    la pfns = patch["functions"]
    la prefix = env("NORSCODE_NCB_PATCH_PREFIX")
    hvis prefix != "" {
        la omdøypte = {}
        la patch_namn = builtin.nøkler(pfns)
        la pi = 0
        mens pi < lengde(patch_namn) {
            la gammalt = patch_namn[pi]
            la nytt = gammalt
            hvis builtin.starts_with(gammalt, "__main__.") {
                nytt = prefix + builtin.slice(gammalt, 9, lengde(gammalt))
            }
            omdøypte[nytt] = pfns[gammalt]
            pi = pi + 1
        }
        pfns = omdøypte
    }
    la namn = builtin.nøkler(pfns)
    la i = 0
    mens i < lengde(namn) {
        la n = namn[i]
        fns[n] = pfns[n]
        i = i + 1
    }
    base["functions"] = fns
    builtin.fil_skriv(ut_sti, builtin.json_stringify(base))
    skriv("NCB-funksjonar fletta: " + tekst_fra_heiltall(lengde(namn)) + "\n")
    returner 0
}

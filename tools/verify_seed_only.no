// tools/verify_seed_only.no — seed-first verifikasjon i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon platform_name() -> tekst {
    la preset = env("NORSCODE_SEED_PLATFORM")
    hvis preset != "" { returner preset }
    la os = trim(felt(kommando("uname -s"), 1))
    la arch = trim(felt(kommando("uname -m"), 1))
    hvis os == "Darwin" {
        hvis arch == "arm64" { returner "macos-arm64" }
        hvis arch == "x86_64" { returner "macos-x86_64" }
    }
    hvis os == "Linux" {
        hvis arch == "x86_64" { returner "linux-x86_64" }
        hvis arch == "aarch64" eller arch == "arm64" { returner "linux-arm64" }
    }
    returner "?"
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(felt(kommando("pwd"), 1)) }

    la platform = platform_name()
    la stage0 = root + "/bootstrap/stage0/norscode-" + platform
    hvis ikkje fil_finst(stage0) {
        hvis env("VERIFY_SEED_ALLOW_MISSING") == "1" {
            linje("=== Seed-only: hoppa over (ingen stage0-seed for " + platform + ") ===")
            linje("Seed-only lane krev bootstrap/stage0/norscode-<plattform> (eller bash tools/fetch_stage0_seed.sh).")
            returner 0
        }
        linje("=== Seed-only: FEIL (ingen stage0-seed for " + platform + ") ===")
        linje("Seed-only lane krev bootstrap/stage0/norscode-<plattform> (eller bash tools/fetch_stage0_seed.sh).")
        returner 1
    }

    linje("=== Seed-only verifikasjon (utan clang/regen) ===")
    linje("1. Bygg frå seed med ugyldig CC (skal framleis passere)")
    la build = kommando("cd " + shell(root) + " && CC=__clang_not_allowed__ REGEN=0 bash " + shell(root + "/tools/build_norscode_native.sh"))
    hvis ikkje ok(build) {
        linje(felt(build, 1))
        linje(felt(build, 2))
        returner 1
    }
    linje(felt(build, 1))

    linje("2. Køyr seed-smoke")
    la tmp = trim(felt(kommando("mktemp ${TMPDIR:-/tmp}/nc_seed_only_XXXXXX.no"), 1))
    hvis tmp == "" {
        linje("Klarte ikkje lage mellombels seed-smoke-fil")
        returner 1
    }
    kommando("printf 'funksjon start() { returner 0 }\\n' > " + shell(tmp))
    la smoke = kommando("NORSCODE_CMD=run NORSCODE_FILE=" + shell(tmp) + " " + shell(root + "/dist/norscode_native") + " >/dev/null")
    kommando("rm -f " + shell(tmp))
    hvis ikkje ok(smoke) {
        linje(felt(smoke, 1))
        linje(felt(smoke, 2))
        returner 1
    }
    linje("  [OK] seed-smoke")
    linje("")
    linje("=== Seed-only verifikasjon: BESTÅTT ===")
    returner 0
}

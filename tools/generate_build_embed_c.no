// tools/generate_build_embed_c.no — generer build/*_ncb_data.c frå .ncb utan Python

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon bytes(sti: tekst) -> tekst {
    returner trim(res_felt(kommando("wc -c < " + shell(sti) + " | tr -d ' '"), 1))
}

funksjon ncb_embed_to_c(input: tekst, out: tekst, size_name: tekst, data_name: tekst) -> bool {
    hvis ikkje fil_finst(input) {
        linje("Feil: manglar " + input)
        returner usann
    }
    la size = bytes(input)
    la cmd = "{ " +
        "printf '/* Auto-generated by tools/generate_build_embed_c.no. Do not edit. */\\n'; " +
        "printf '#include <stddef.h>\\n'; " +
        "printf '#include <stdint.h>\\n\\n'; " +
        "printf 'const size_t %s = %s;\\n' " + shell(size_name) + " " + shell(size) + "; " +
        "printf 'const uint8_t %s[%s] = {\\n' " + shell(data_name) + " " + shell(size) + "; " +
        "od -An -tx1 -v " + shell(input) + " | awk '{ for (i = 1; i <= NF; i++) { if (count > 0) printf \", \"; if (count % 16 == 0) printf \"\\n    \"; printf \"0x%s\", $i; count++ } } END { printf \"\\n};\\n\" }'; " +
        "} > " + shell(out)
    la res = kommando(cmd)
    hvis ikkje ok(res) {
        hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
        hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
        returner usann
    }
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    kommando("mkdir -p " + shell(root + "/build"))

    hvis ikkje ncb_embed_to_c(
        root + "/build/bootstrap_compiler_bundle.ncb",
        root + "/build/bootstrap_compiler_bundle_ncb_data.c",
        "norcode_bootstrap_ncb_data_size",
        "norcode_bootstrap_ncb_data"
    ) { returner 1 }

    hvis ikkje ncb_embed_to_c(
        root + "/build/native_elf_compiler_bundle.ncb",
        root + "/build/native_elf_compiler_bundle_ncb_data.c",
        "norcode_ncb_data_size",
        "norcode_ncb_data"
    ) { returner 1 }

    linje("✓ Genererte build/*_ncb_data.c")
    returner 0
}

// tools/python_dependency_audit.no — Python-audit i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}
funksjon env(namn: tekst) -> tekst {
    prøv {
        returner miljo_hent(namn)
    } fang (e) {
        returner ""
    }
    returner ""
}
funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}
funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}
funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}
funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon count_lines(data: tekst) -> heiltall {
    la t = trim(data)
    hvis t == "" { returner 0 }
    returner lengde(builtin.split(t, "\n"))
}

funksjon py_filer(filer: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la linjer = builtin.split(filer, "\n")
    la i = 0
    mens i < lengde(linjer) {
        la fil = trim(linjer[i])
        hvis fil != "" og builtin.ends_with(fil, ".py") {
            legg_til(ut, fil)
        }
        i = i + 1
    }
    returner ut
}

funksjon alle_filer(root: tekst, under: tekst) -> tekst {
    la base = root
    hvis under != "" { base = root + "/" + under }
    la res = kommando("find " + shell(base) + " -path " + shell(root + "/.git") + " -prune -o -type f -print 2>/dev/null")
    la out = ""
    la linjer = builtin.split(res[1], "\n")
    la prefiks = root + "/"
    la i = 0
    mens i < lengde(linjer) {
        la fil = trim(linjer[i])
        hvis fil != "" {
            hvis builtin.starts_with(fil, prefiks) {
                fil = builtin.slice(fil, lengde(prefiks), lengde(fil))
            }
            out = out + fil + "\n"
        }
        i = i + 1
    }
    returner trim(out)
}

funksjon linjer_til_tekst(linjer: liste_tekst) -> tekst {
    la out = ""
    la i = 0
    mens i < lengde(linjer) {
        out = out + linjer[i] + "\n"
        i = i + 1
    }
    returner trim(out)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(kommando("pwd")[1]) }
    la output_dir = root + "/reports"
    la output_file = output_dir + "/python_dependency_report.txt"
    kommando("mkdir -p " + shell(output_dir))

    la tools_py = linjer_til_tekst(py_filer(alle_filer(root, "tools")))
    la repo_py = linjer_til_tekst(py_filer(alle_filer(root, "")))
    la tools_count = count_lines(tools_py)
    la repo_count = count_lines(repo_py)

    la rapport = "=== Norscode Python-avhengnadsrapport ===\n\n"
    rapport = rapport + "Python-filer i tools/ (må vere 0 i normal flyt): " + tekst_fra_heltall(tools_count) + "\n"
    hvis tools_py != "" { rapport = rapport + tools_py + "\n" }
    rapport = rapport + "\nPython-filer i repo (ekskl. .git): " + tekst_fra_heltall(repo_count) + "\n"
    hvis repo_py != "" { rapport = rapport + repo_py + "\n" }
    rapport = rapport + "\nTip: Bruk ./bin/nc run tools/no_c_python_active_surface.no for full normal/legacy-surface policy.\n"
    rapport = rapport + "Note: rapporten kan innehalde Python i archive/scripts som er tillate per policy.\n"

    builtin.fil_skriv(output_file, rapport)
    linje("Python-audit skreiv rapport: reports/python_dependency_report.txt")

    hvis tools_count != 0 {
        linje("Feil: Python i tools/ er ikkje tillatt i normal flyt. Sjå reports/python_dependency_report.txt")
        returner 1
    }
    linje("OK: ingen Python i tools/")
    returner 0
}

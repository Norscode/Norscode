// tools/ir_canonical_dump.no — kanonisk IR-dump i Norscode

bruk std.liste som liste

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon er_blank(ch: tekst) -> bool {
    returner ch == " " eller ch == "\t" eller ch == "\r"
}

funksjon normaliser_linje(raw: tekst) -> tekst {
    la ut = ""
    la i = 0
    la sist_var_blank = sann
    mens i < lengde(raw) {
        la ch = raw[i]
        hvis er_blank(ch) {
            hvis ikkje sist_var_blank {
                ut = ut + " "
                sist_var_blank = sann
            }
        } ellers {
            ut = ut + ch
            sist_var_blank = usann
        }
        i = i + 1
    }
    hvis lengde(ut) > 0 og ut[lengde(ut) - 1] == " " {
        returner builtin.slice(ut, 0, lengde(ut) - 1)
    }
    returner ut
}

funksjon kanoniske_linjer(data: tekst) -> liste_tekst {
    la rå = builtin.split(data, "\n")
    la linjer: liste_tekst = []
    la i = 0
    mens i < lengde(rå) {
        la line = normaliser_linje(rå[i])
        hvis line != "" {
            legg_til(linjer, line)
        }
        i = i + 1
    }
    liste.sorter_tekst(linjer)
    returner linjer
}

funksjon enkel_hash(data: tekst) -> tekst {
    la h = 216613
    la i = 0
    mens i < lengde(data) {
        h = ((h * 167) + builtin.char_code(data[i])) % 2147483647
        i = i + 1
    }
    returner tekst_fra_heltall(h)
}

funksjon start() -> heiltall {
    la input_file = env("NORSCODE_IR_INPUT")
    la output_file = env("NORSCODE_IR_OUTPUT")
    hvis input_file == "" eller output_file == "" {
        linje("Bruk: NORSCODE_IR_INPUT=<input_ir_dump> NORSCODE_IR_OUTPUT=<output_ir_dump> ./bin/nc run tools/ir_canonical_dump.no")
        returner 1
    }

    la data = ""
    prøv {
        data = builtin.fil_les(input_file)
    } fang (e) {
        linje("Missing IR dump: " + input_file)
        returner 1
    }

    la linjer = kanoniske_linjer(data)
    la output = builtin.join(linjer, "\n")
    hvis lengde(output) > 0 {
        output = output + "\n"
    }
    builtin.fil_skriv(output_file, output)

    linje("Canonical IR dump written to: " + output_file)
    linje("Canonical IR hash: " + enkel_hash(output))
    returner 0
}

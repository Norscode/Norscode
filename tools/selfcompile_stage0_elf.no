// tools/selfcompile_stage0_elf.no — Omgang 6b.3: Gen1 stage-0 ELF → Gen2 ELF

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim_tekst(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim_tekst(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon les_fil_trygt(sti: tekst) -> tekst {
    prøv {
        returner fil_les(sti)
    } fang (e) {
        returner ""
    }
    returner ""
}

funksjon skriv_fil_trygt(sti: tekst, innhald: tekst) -> bool {
    prøv {
        fil_skriv(sti, innhald)
        returner sann
    } fang (e) {
        returner falsk
    }
    returner falsk
}

funksjon append_fil_trygt(sti: tekst, innhald: tekst) -> bool {
    la før = les_fil_trygt(sti)
    returner skriv_fil_trygt(sti, før + innhald)
}

funksjon filer_identiske(sti_a: tekst, sti_b: tekst) -> bool {
    hvis ikkje fil_finst(sti_a) eller ikkje fil_finst(sti_b) { returner usann }
    returner les_fil_trygt(sti_a) == les_fil_trygt(sti_b)
}

funksjon executable(sti: tekst) -> bool {
    returner fil_finst(sti)
}

funksjon bytes(sti: tekst) -> tekst {
    prøv {
        la innhald = builtin.fil_les(sti)
        returner tekst_fra_heltall(lengde(innhald))
    } fang (e) {}
    returner første_felt(res_felt(kommando("wc -c " + shell(sti)), 1))
}

funksjon første_forskjellar(sti_a: tekst, sti_b: tekst, maks: heiltall) -> tekst {
    la a = fil_les(sti_a)
    la b = fil_les(sti_b)
    la min_lengd = lengde(a)
    hvis lengde(b) < min_lengd { min_lengd = lengde(b) }
    la out = ""
    la funne = 0
    la i = 0
    mens i < min_lengd og funne < maks {
        hvis a[i] != b[i] {
            out = out + tekst_fra_heltall(i + 1) + " " + tekst_fra_heltall(builtin.char_code(a[i])) + " " + tekst_fra_heltall(builtin.char_code(b[i])) + "\n"
            funne = funne + 1
        }
        i = i + 1
    }
    hvis funne < maks og lengde(a) != lengde(b) {
        out = out + "length " + tekst_fra_heltall(lengde(a)) + " " + tekst_fra_heltall(lengde(b)) + "\n"
    }
    hvis out == "" { returner "Ingen lesbare forskjellar funne\n" }
    returner out
}

funksjon siste_liner(data: tekst, maks: heiltall) -> tekst {
    la linjer = builtin.split(data, "\n")
    la start = lengde(linjer) - maks
    hvis start < 0 { start = 0 }
    la out = ""
    la i = start
    mens i < lengde(linjer) {
        hvis out != "" { out = out + "\n" }
        out = out + linjer[i]
        i = i + 1
    }
    returner out
}

funksjon sha256_for(sti: tekst) -> tekst {
    hvis ikkje fil_finst(sti) { returner "" }
    hvis ok(kommando("command -v shasum >/dev/null 2>&1")) {
        returner første_felt(res_felt(kommando("shasum -a 256 " + shell(sti)), 1))
    }
    hvis ok(kommando("command -v sha256sum >/dev/null 2>&1")) {
        returner første_felt(res_felt(kommando("sha256sum " + shell(sti)), 1))
    }
    returner ""
}

funksjon os_namn() -> tekst {
    returner trim_tekst(res_felt(kommando("uname -s"), 1))
}

funksjon arch_namn() -> tekst {
    returner trim_tekst(res_felt(kommando("uname -m"), 1))
}

funksjon chunk_size() -> tekst {
    la v = env("NC_OM6B_CHUNK_SIZE")
    hvis v == "" { returner "65536" }
    returner v
}

funksjon skriv_diagnose(root: tekst, modus: tekst, rc: tekst, cmd_txt: tekst, log_path: tekst, os: tekst, arch: tekst) -> bool {
    la diag = root + "/build/6b/selfcompile/gen1_elf_diagnose.txt"
    la gen1_elf = root + "/build/6b/selfcompile/gen1_compiler.elf"
    la gen1_sha = sha256_for(gen1_elf)
    la gen1_bytes = bytes(gen1_elf)
    la aggregate = root + "/build/6b/selfcompile/gen1_elf_bundle.log"
    la body = "modus=" + modus + "\n" +
        "exit_code=" + rc + "\n" +
        "os=" + os + "\n" +
        "arch=" + arch + "\n" +
        "gen1_elf=" + gen1_elf + "\n" +
        "cmd=" + cmd_txt + "\n\n" +
        "[miljo]\n" +
        "NC_OM6B_RUN_STAGE0=" + env("NC_OM6B_RUN_STAGE0") + "\n" +
        "NORSCODE_OM6B_PRESET=" + env("NORSCODE_OM6B_PRESET") + "\n" +
        "NORSCODE_OM6B_SOURCE_NCB=" + env("NORSCODE_OM6B_SOURCE_NCB") + "\n" +
        "NORSCODE_OM6B_SOURCE_NCB_DIR=" + env("NORSCODE_OM6B_SOURCE_NCB_DIR") + "\n" +
        "NORSCODE_OM6B_SOURCE_NCB_COUNT=" + env("NORSCODE_OM6B_SOURCE_NCB_COUNT") + "\n" +
        "NORSCODE_BUNDLE_OUTPUT=" + env("NORSCODE_BUNDLE_OUTPUT") + "\n" +
        "NORSCODE_BUNDLE_ENTRY=" + env("NORSCODE_BUNDLE_ENTRY") + "\n"
    hvis fil_finst(gen1_elf) {
        body = body + "gen1_elf_bytes=" + gen1_bytes + "\n" +
            "gen1_elf_sha256=" + gen1_sha + "\n"
    }
    hvis fil_finst(log_path) {
        body = body + "\n[log tail]\n" + siste_liner(les_fil_trygt(log_path), 80) + "\n"
    }
    hvis fil_finst(aggregate) og log_path != aggregate {
        body = body + "\n[aggregate log tail]\n" + siste_liner(les_fil_trygt(aggregate), 120) + "\n"
    }
    hvis ikkje skriv_fil_trygt(diag, body) { returner falsk }
    hvis fil_finst(gen1_elf) {
        hvis ok(kommando("command -v file >/dev/null 2>&1")) {
            append_fil_trygt(diag, "\n[file]\n" + res_felt(kommando("file " + shell(gen1_elf)), 1))
        }
        hvis ok(kommando("command -v readelf >/dev/null 2>&1")) {
            append_fil_trygt(diag, "\n[readelf -h]\n" + res_felt(kommando("readelf -h " + shell(gen1_elf)), 1))
            append_fil_trygt(diag, "\n[readelf -l]\n" + res_felt(kommando("readelf -l " + shell(gen1_elf)), 1))
        }
    }
    returner sann
}

funksjon chunk_liste(base: tekst) -> liste_tekst {
    la filer: liste_tekst = []
    la res = kommando("ls " + shell(base) + "/part_*.json 2>/dev/null")
    hvis ikkje ok(res) { returner filer }
    la linjer = builtin.split(res_felt(res, 1), "\n")
    la i = 0
    mens i < lengde(linjer) {
        la sti = trim_tekst(linjer[i])
        hvis sti != "" { legg_til(filer, sti) }
        i = i + 1
    }
    returner filer
}

funksjon chunk_finst(base: tekst) -> bool {
    returner lengde(chunk_liste(base)) > 0
}

funksjon samle_chunk_output(base: tekst, ut: tekst) -> bool {
    la filer = chunk_liste(base)
    hvis lengde(filer) == 0 { returner falsk }
    la samla = ""
    la i = 0
    mens i < lengde(filer) {
        samla = samla + les_fil_trygt(filer[i])
        i = i + 1
    }
    returner skriv_fil_trygt(ut, samla)
}

funksjon koyr_gen1_elf(mode: tekst, mode_log: tekst, cmd: tekst, aggregate_log: tekst, attempts: tekst) -> liste_tekst {
    append_fil_trygt(aggregate_log, "\n=== " + mode + " ===\n")
    la res = kommando("(" + cmd + ") > " + shell(mode_log) + " 2>&1")
    la rc = res_felt(res, 0)
    append_fil_trygt(aggregate_log, "exit_code=" + rc + "\n" + les_fil_trygt(mode_log))
    append_fil_trygt(attempts, "mode=" + mode + " exit_code=" + rc + " log=" + mode_log + "\n")
    hvis fil_finst(mode_log) {
        la out = les_fil_trygt(mode_log)
        hvis out != "" { skriv(out) }
    }
    returner res
}

funksjon main() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(res_felt(kommando("pwd"), 1)) }
    la os = os_namn()
    la arch = arch_namn()
    la gen1_ncb = root + "/build/6b/compiler_stage0.ncb.json"
    la base = root + "/build/6b/selfcompile"
    la gen1_elf = base + "/gen1_compiler.elf"
    la gen2_ncb = base + "/gen2.ncb.json"
    la gen2_elf = base + "/gen2_compiler.elf"
    la gen1_log = base + "/gen1_elf_bundle.log"
    la preset_log = base + "/gen1_elf_preset.log"
    la attempts = base + "/gen1_elf_attempts.txt"
    la pass_marker = base + "/stage0_elf_passed.marker"

    hvis ikkje run("mkdir -p " + shell(base)) { returner 1 }
    run("rm -f " + shell(pass_marker) + " " + shell(gen1_log) + " " + shell(preset_log) + " " + shell(base + "/gen1_elf_source_ncb.log") + " " + shell(base + "/gen1_elf_chunked_source_ncb.log") + " " + shell(base + "/gen1_elf_diagnose.txt") + " " + shell(attempts))

    hvis ikkje executable(root + "/dist/norscode_native") {
        hvis ikkje run("NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " ./bin/nc run " + shell(root + "/tools/build_norscode_native.no")) { returner 1 }
    }

    linje("=== Omgang 6b.3: stage-0 ELF sjølvkompilering ===")
    linje("")
    linje("[1/4] Gen1: stage-0 NCB + ELF (host)...")
    hvis ikkje run("NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " NORSCODE_OMGANG6B_NCB_OUT=" + shell(gen1_ncb) + " ./bin/nc run " + shell(root + "/tools/build_omgang6b_compiler_ncb.no")) { returner 1 }
    hvis ikkje run("NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " NORSCODE_NCB_TO_ELF_INPUT=" + shell(gen1_ncb) + " NORSCODE_NCB_TO_ELF_OUTPUT=" + shell(gen1_elf) + " ./bin/nc run " + shell(root + "/tools/ncb_to_elf.no")) { returner 1 }
    la b1 = bytes(gen1_elf)
    linje("  [OK] Gen1 ELF " + b1 + " bytes")
    linje("")

    hvis os != "Linux" eller (arch != "x86_64" og arch != "amd64") {
        linje("[2–4/4] Hopp over ELF→ELF (" + os + "/" + arch + " — krev Linux x86-64)")
        linje("")
        linje("=== Omgang 6b.3: DELVIS (host Gen1 bygd) ===")
        returner 0
    }

    hvis env("NC_OM6B_RUN_STAGE0") != "1" {
        linje("[2–4/4] Hopp over ELF→ELF runtime (set NC_OM6B_RUN_STAGE0=1 for djup smoke)")
        linje("")
        linje("=== Omgang 6b.3: DELVIS (Gen1 ELF bygd) ===")
        returner 0
    }

    linje("[2/4] Gen2 NCB frå Gen1 ELF (bundle-args)...")
    run("rm -f " + shell(gen2_ncb) + " " + shell(base) + "/part_*.json")
    la gen2_entry = "selfhost.elf_compile_driver.start"
    la gen2_bundle_args = "__omgang6b__"
    la path = env("PATH")
    la run_cmd = "env -i PATH=" + shell(path) +
        " NORSCODE_CMD=run" +
        " NORSCODE_BUNDLE_ARGS=" + shell(gen2_bundle_args) +
        " NORSCODE_BUNDLE_OUTPUT=" + shell(gen2_ncb) +
        " NORSCODE_BUNDLE_OUTPUT_CHUNKS=1" +
        " NORSCODE_BUNDLE_ENTRY=" + shell(gen2_entry) +
        " " + shell(gen1_elf)

    linje("  [INFO] Prøver ekte bundle-args via Gen1 ELF...")
    la gen2_res = koyr_gen1_elf("bundle-args", preset_log, run_cmd, gen1_log, attempts)
    hvis ok(gen2_res) {
        hvis fil_finst(gen2_ncb) {
            linje("  [OK] Gen1 ELF skreiv Gen2 NCB via bundle-args")
        } ellers hvis fil_finst(base + "/part_000.json") {
            hvis ikkje samle_chunk_output(base, gen2_ncb) { returner 1 }
            linje("  [OK] Gen1 ELF skreiv Gen2 NCB via bundle-args chunk-output")
        } ellers {
            linje("  [FEIL] Gen1 ELF returnerte suksess utan output")
            returner 1
        }
    } ellers {
        la rc = res_felt(gen2_res, 0)
        hvis chunk_finst(base) {
            hvis ikkje samle_chunk_output(base, gen2_ncb) { returner 1 }
            linje("  [MERK] Bundle-args krasja med exit " + rc + ", men chunk-output vart skrive; brukar artifactet")
        } ellers {
            skriv_diagnose(root, "bundle_args", rc, run_cmd, preset_log, os, arch)
            linje("  [FEIL] Bundle-args feila med exit " + rc + " og Gen1 ELF skreiv ikkje Gen2 NCB")
            linje("        Sjå diagnose: " + base + "/gen1_elf_diagnose.txt")
            returner 1
        }
    }

    hvis ikkje fil_finst(gen2_ncb) {
        linje("  [FEIL] Gen2 NCB ikkje skrive")
        returner 1
    }

    la n1 = bytes(gen1_ncb)
    la n2 = bytes(gen2_ncb)
    linje("  [OK] Gen2 NCB " + n2 + " bytes (Gen1 NCB " + n1 + " bytes)")
    hvis filer_identiske(gen1_ncb, gen2_ncb) {
        linje("  [OK] NCB byte-paritet Gen1 == Gen2 (bundle-args)")
        linje("")
    } ellers {
        linje("  [MERK] NCB differ i bundle-args-modus — sjekkar ELF-paritet likevel")
        linje("")
    }

    linje("[3/4] Gen2 ELF frå Gen2 NCB (native codegen)...")
    hvis ikkje run("NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " NORSCODE_NCB_TO_ELF_INPUT=" + shell(gen2_ncb) + " NORSCODE_NCB_TO_ELF_OUTPUT=" + shell(gen2_elf) + " ./bin/nc run " + shell(root + "/tools/ncb_to_elf.no")) { returner 1 }
    la b2 = bytes(gen2_elf)
    linje("  [OK] Gen2 ELF " + b2 + " bytes")
    linje("")

    linje("[4/4] Byte-paritet Gen1 ELF == Gen2 ELF (bundle-args)...")
    hvis filer_identiske(gen1_elf, gen2_elf) {
        linje("  [OK] " + b1 + " bytes identiske")
        linje("")
        hvis ikkje skriv_fil_trygt(pass_marker, "bundle-args\n") { returner 1 }
        linje("=== Omgang 6b.3: BESTÅTT (Gen1 ELF skreiv Gen2 NCB via bundle-args) ===")
        returner 0
    }

    linje("  [FEIL] ELF differ (gen1=" + b1 + ", gen2=" + b2 + " bytes)")
    skriv(første_forskjellar(gen1_elf, gen2_elf, 5))
    returner 1
}

funksjon start() -> heiltall {
    returner main()
}

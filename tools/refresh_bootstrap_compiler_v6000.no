// tools/refresh_bootstrap_compiler_v6000.no — plan/apply for bootstrap compiler refresh

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon køyr(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res)
}

funksjon print_plan(out_stage0: tekst) -> heiltall {
    linje("V6000 bootstrap compiler refresh")
    linje("================================")
    linje("")
    linje("Denne pipelineen er laga for å få den bundlede/bootstrap-compileren oppdatert frå dagens kjelde:")
    linje("1. Regenerer bootstrap/kompiler.ncb.json frå selfhost-kjeldene")
    linje("2. Regenerer bootstrap/precompiled_fragments* frå ferske precompiled-filer")
    linje("3. Bygg omgang 6b stage0-compiler-NCB")
    linje("4. Bruk v5600/v5800-probene etterpå for å sjå om BUILD_LIST / BUILD_MAP / INDEX_GET faktisk kom inn")
    linje("")
    linje("Kommandoar som vil bli køyrde:")
    linje("- bin/nc regen-bootstrap --full")
    linje("- bin/nc run tools/regenerate_omgang6b_fragments_safe.no")
    linje("- bin/nc build-omgang6b-ncb \"" + out_stage0 + "\"")
    returner 0
}

funksjon repo_root() -> tekst {
    la root = env("NORSCODE_ROOT")
    hvis root != "" { returner root }
    root = trim(felt(kommando("pwd"), 1))
    hvis root != "" { returner root }
    returner "."
}

funksjon start() -> heiltall {
    la root = repo_root()
    la mode = env("NORSCODE_V6000_MODE")
    hvis mode == "" { mode = "--dry-run" }
    la out_stage0 = env("OUT_STAGE0")
    hvis out_stage0 == "" { out_stage0 = root + "/build/v6000/compiler_stage0_v6000.ncb.json" }

    hvis mode == "--dry-run" {
        print_plan(out_stage0)
        linje("")
        linje("[DRY-RUN] ingen filer vart endra")
        returner 0
    }

    hvis mode != "--apply" {
        linje("Bruk --dry-run eller --apply")
        returner 2
    }

    print_plan(out_stage0)
    linje("")
    linje("[1/3] Regenererer bootstrap-NCB...")
    hvis ikkje køyr("cd " + shell(root) + " && " + shell(root + "/bin/nc") + " regen-bootstrap --full") { returner 1 }
    linje("[2/3] Regenererer precompiled fragments...")
    hvis ikkje køyr("cd " + shell(root) + " && " + shell(root + "/bin/nc") + " run " + shell(root + "/tools/regenerate_omgang6b_fragments_safe.no")) { returner 1 }
    linje("[3/3] Byggjer omgang 6b stage0-compiler...")
    hvis ikkje køyr("cd " + shell(root) + " && " + shell(root + "/bin/nc") + " build-omgang6b-ncb " + shell(out_stage0)) { returner 1 }
    linje("")
    linje("[OK] bootstrap refresh fullført")
    linje("Neste steg:")
    linje("- bin/nc run tools/run_bootstrap_literal_probes_v5600.no")
    linje("- bin/nc run tools/bootstrap_codegen_diff_v5800.no")
    returner 0
}

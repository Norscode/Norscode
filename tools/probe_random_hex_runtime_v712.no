// tools/probe_random_hex_runtime_v712.no — kartlegg random_hex i runtime

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon inneheld(t: tekst, needle: tekst) -> bool {
    returner builtin.index_of(t, needle) >= 0
}

funksjon fil_les_trygt(sti: tekst) -> tekst {
    prøv { returner builtin.fil_les(sti) } fang (e) { returner "" }
    returner ""
}

funksjon linje_treff(line: tekst, needles: liste_tekst) -> bool {
    la i = 0
    mens i < lengde(needles) {
        hvis inneheld(line, needles[i]) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon har_fil(filer: liste_tekst, fil: tekst) -> bool {
    la i = 0
    mens i < lengde(filer) {
        hvis filer[i] == fil { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon søkefiler(mapper: tekst) -> liste_tekst {
    la filer: liste_tekst = []
    la delar = builtin.split(mapper, " ")
    la i = 0
    mens i < lengde(delar) {
        la mappe = trim(delar[i])
        hvis mappe != "" {
            la res = kommando("find " + shell(mappe) + " -type f -print 2>/dev/null || true")
            la linjer = builtin.split(res_felt(res, 1), "\n")
            la li = 0
            mens li < lengde(linjer) {
                la fil = trim(linjer[li])
                hvis fil != "" og ikkje har_fil(filer, fil) {
                    legg_til(filer, fil)
                }
                li = li + 1
            }
        }
        i = i + 1
    }
    returner filer
}

funksjon vis_kildetreff(mapper: tekst, needles: liste_tekst, maks: heiltall) -> heiltall {
    la filer = søkefiler(mapper)
    la treff = 0
    la fi = 0
    mens fi < lengde(filer) og treff < maks {
        la rel = trim(filer[fi])
        hvis rel != "" {
            la data = fil_les_trygt(rel)
            hvis data != "" {
                la linjer = builtin.split(data, "\n")
                la li = 0
                mens li < lengde(linjer) og treff < maks {
                    hvis linje_treff(linjer[li], needles) {
                        skriv(rel + ":" + tekst(li + 1) + ":" + linjer[li] + "\n")
                        treff = treff + 1
                    }
                    li = li + 1
                }
            }
        }
        fi = fi + 1
    }
    returner 0
}

funksjon vis(cmd: tekst) -> heiltall {
    la res = kommando(cmd)
    la out = res_felt(res, 1)
    la err = res_felt(res, 2)
    hvis out != "" { skriv(out) }
    hvis err != "" { skriv(err) }
    returner 0
}

funksjon start() -> heiltall {
    linje("== random_hex forekomster ==")
    la random_ord: liste_tekst = []
    legg_til(random_ord, "random_hex")
    vis_kildetreff(".", random_ord, 160)

    linje("")
    linje("== builtin/random mapping ==")
    la builtin_ord: liste_tekst = []
    legg_til(builtin_ord, "builtin")
    legg_til(builtin_ord, "random")
    legg_til(builtin_ord, "innebygd")
    legg_til(builtin_ord, "random_hex")
    vis_kildetreff("selfhost src tools bin std", builtin_ord, 200)

    linje("")
    linje("== serve/køyr_funksjon mapping ==")
    la serve_ord: liste_tekst = []
    legg_til(serve_ord, "køyr_funksjon")
    legg_til(serve_ord, "run_builtin")
    legg_til(serve_ord, "Ukjent innebygd")
    legg_til(serve_ord, "innebygd funksjon")
    vis_kildetreff("selfhost src tools bin", serve_ord, 200)
    returner 0
}

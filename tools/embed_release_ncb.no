// Bygg single-binary-prototype med compiler/VM-NCB innebygd.
//
// NORSCODE_EMBED_BASE=dist/norscode_native
// NORSCODE_EMBED_OUT=dist/norscode_native_embedded
// NORSCODE_EMBED_SPECS='compiler=fil.ncb.json\nvm=fil.ncb.json'
// ./bin/nc run tools/embed_release_ncb.no

bruk selfhost.native_execution.embedded_ncb_image som image

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon sett_kjorbar(sti: tekst) -> boolsk {
    // Filmodus går gjennom den versjonerte native ABI-en.
    // Sjølve imagebygginga og byteverifiseringa er Norscode-eigd.
    returner builtin.fil_sett_kjorbar(sti)
}

funksjon aktiver_resultat(base_sti: tekst, out_sti: tekst) -> boolsk {
    hvis env("NORSCODE_EMBED_ACTIVATE") != "1" { returner sann }
    prøv {
        la bytes = builtin.fil_les_binær(out_sti)
        builtin.fil_skriv_binær(base_sti, bytes)
        returner sett_kjorbar(base_sti)
    } fang (e) {
        skriv("Klarte ikkje aktivere innebygd runtime: " + tekst(e) + "\n")
        returner usann
    }
}

funksjon stream_embed(base_sti: tekst, out_sti: tekst, payload_namn: liste_tekst, payload_data: liste_tekst) -> heiltall {
    la base = builtin.fil_les_binær(base_sti)
    builtin.fil_skriv_binær(out_sti, base)
    la pos = lengde(base)
    la payload_map = {}
    la i = 0
    mens i < lengde(payload_namn) {
        builtin.fil_append(out_sti, payload_data[i])
        payload_map[payload_namn[i]] = {"start": pos, "length": lengde(payload_data[i])}
        pos = pos + lengde(payload_data[i])
        i = i + 1
    }
    la manifest = builtin.json_stringify({"format": "norscode-ncb-text-v1", "payloads": payload_map})
    builtin.fil_append(out_sti, manifest)
    la lengdetekst = tekst_fra_heiltall(lengde(manifest))
    la pad = 20 - lengde(lengdetekst)
    i = 0
    mens i < pad {
        builtin.fil_append(out_sti, "0")
        i = i + 1
    }
    builtin.fil_append(out_sti, lengdetekst)
    builtin.fil_append(out_sti, "NORSCODE_NCB_TEXT_V1")
    returner 0
}

funksjon start() -> heiltall {
    la base_sti = env("NORSCODE_EMBED_BASE")
    la out_sti = env("NORSCODE_EMBED_OUT")
    la specs = env("NORSCODE_EMBED_SPECS")
    hvis base_sti == "" eller out_sti == "" eller specs == "" {
        skriv("bruk: set NORSCODE_EMBED_BASE, NORSCODE_EMBED_OUT og NORSCODE_EMBED_SPECS\n")
        returner 2
    }

    la payload_namn: liste_tekst = []
    la payload_data: liste_tekst = []
    // Semikolon er ein quoting-trygg reserve for Windows/Git Bash, medan
    // newline framleis er den offentlege kontrakten for andre kall.
    la liner = builtin.split(builtin.replace(specs, ";", "\n"), "\n")
    la i = 0
    mens i < lengde(liner) {
        la linje = builtin.trim(liner[i])
        hvis linje != "" {
            la skilje = builtin.index_of(linje, "=")
            hvis skilje <= 0 { kast "Ugyldig NCB-spec: " + linje }
            la namn = builtin.trim(builtin.slice(linje, 0, skilje))
            la sti = builtin.trim(builtin.slice(linje, skilje + 1, lengde(linje)))
            la ncb = builtin.fil_les(sti)
            la parsed = builtin.json_parse_raw(ncb)
            la format = parsed["format"]
            hvis format != null og format != "" og format != "norscode-bytecode-v1" { kast "Ugyldig NCB-format: " + sti }
            hvis parsed["entry"] == null eller parsed["functions"] == null { kast "Ufullstendig NCB: " + sti }
            legg_til(payload_namn, namn)
            legg_til(payload_data, ncb)
        }
        i = i + 1
    }

    hvis env("NORSCODE_EMBED_STREAM") == "1" {
        la stream_rc = stream_embed(base_sti, out_sti, payload_namn, payload_data)
        hvis stream_rc != 0 { kast "Klarte ikkje byggje NCB-text-image" }
        hvis ikkje sett_kjorbar(out_sti) { kast "Klarte ikkje aktivere innebygd runtime" }
        hvis ikkje aktiver_resultat(base_sti, out_sti) { returner 1 }
        skriv("Innebygd NCB-text-image: " + out_sti + " (" + tekst_fra_heiltall(lengde(payload_namn)) + " payloadar)\n")
        returner 0
    }
    la base_bytes = builtin.fil_les_binær(base_sti)
    // Konverteringa skjer i native bytes-runtime (éin C-operasjon), medan
    // Norscode berre handterer den korte trailerlista.
    la base = builtin.bytes_to_list(base_bytes)
    la resultat_liste = image.bygg_direkte(base, payload_namn, payload_data)
    la resultat = builtin.bytes_from_list(resultat_liste)
    hvis ikkje image.har_image(resultat) { kast "Klarte ikkje byggje innebygd NCB-image" }
    hvis image.payload_tal(resultat) != lengde(payload_namn) { kast "Feil payloadtal i innebygd NCB-image" }
    i = 0
    mens i < lengde(payload_namn) {
        la pos = image.payload_posisjon(resultat, payload_namn[i])
        hvis pos[1] != lengde(payload_data[i]) {
            kast "Lengdeverifisering feila for innebygd payload: " + payload_namn[i]
        }
        hvis image.payload_checksum(resultat, payload_namn[i]) != image.tekst_checksum(payload_data[i]) {
            kast "Verifisering feila for innebygd payload: " + payload_namn[i]
        }
        i = i + 1
    }
    builtin.fil_skriv_binær(out_sti, resultat)
    hvis ikkje sett_kjorbar(out_sti) { returner 1 }
    hvis ikkje aktiver_resultat(base_sti, out_sti) { returner 1 }
    skriv("Innebygd NCB-image: " + out_sti + " (" + tekst_fra_heiltall(lengde(payload_namn)) + " payloadar, verifisert)\n")
    returner 0
}

// tools/native_runtime_gap_pure_vm_gate_v3002.no — runtime-gap gate via pure VM

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon executable(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon run_stille(cmd: tekst) -> bool {
    returner ok(kommando("(" + cmd + ") >/dev/null 2>&1"))
}

funksjon run_append(cmd: tekst, out: tekst) -> bool {
    returner ok(kommando("(" + cmd + ") >> " + shell(out) + " 2>&1"))
}

funksjon inneheld(out: tekst, needle: tekst) -> bool {
    prøv {
        returner builtin.index_of(builtin.fil_les(out), needle) >= 0
    } fang (e) {
        returner usann
    }
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la nc = root + "/bin/nc"
    la pure_runner = root + "/selfhost/tooling/ncb_pure_run_entry.no"
    la probe = root + "/tests/native_runtime_gap_probe_v3001.no"
    la upload_probe = root + "/tests/opplasting_mappe_gap_probe.no"
    la tmp_base = "/tmp/norscode_pure_vm_gate_v3002"
    la out = tmp_base + ".out"
    la probe_ncb = tmp_base + "/native_runtime_gap_probe_v3001.ncb"
    la upload_ncb = tmp_base + "/opplasting_mappe_gap_probe.ncb"
    la native = env("NORSCODE_NATIVE_GAP_BIN")
    hvis native == "" { native = env("NORSCODE_NATIVE_BIN") }

    linje("== native runtime gap pure VM gate v3002 ==")
    linje("runner: " + pure_runner)

    hvis ikkje executable(nc) {
        linje("[FAIL] nc manglar eller er ikkje køyrbar: " + nc)
        returner 1
    }
    hvis ikkje fil_finst(pure_runner) {
        linje("[FAIL] pure VM-runner manglar: " + pure_runner)
        returner 1
    }

    hvis ikkje run_stille("cd " + shell(root) + " && " + shell(nc) + " check " + shell(pure_runner)) { returner 1 }
    hvis ikkje run_stille("cd " + shell(root) + " && " + shell(nc) + " check " + shell(probe)) { returner 1 }
    hvis ikkje run_stille("cd " + shell(root) + " && " + shell(nc) + " check " + shell(upload_probe)) { returner 1 }

    hvis ikkje run_stille("rm -rf " + shell(tmp_base) + " && mkdir -p " + shell(tmp_base)) { returner 1 }
    hvis ikkje run_stille("cd " + shell(root) + " && " + shell(nc) + " compile " + shell(probe) + " " + shell(probe_ncb)) { returner 1 }
    hvis ikkje run_stille("cd " + shell(root) + " && " + shell(nc) + " compile " + shell(upload_probe) + " " + shell(upload_ncb)) { returner 1 }

    // Bruk cache normalt; tving full regenerering berre ved eksplisitt behov.
    hvis env("NORSCODE_FORCE_REBUILD") == "1" {
        kommando("rm -f " + shell(root + "/build/runtime-cache/ncb_pure_run_entry.ncb.json") + " " + shell(root + "/build/runtime-cache/imports/selfhost_vm.d1.ncb.json") + " " + shell(root + "/build/runtime-cache/imports/selfhost_vm.d2.ncb.json"))
    }
    kommando("rm -f " + shell(out))
    la runtime_env = "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES=env.read,process.exec,disk.read,disk.write NORSCODE_VM_DISK_ROOT=."
    hvis native != "" { runtime_env = runtime_env + " NORSCODE_NATIVE_BIN=" + shell(native) }
    run_append("cd " + shell(root) + " && env " + runtime_env + " " + shell(nc) + " run-ncb-pure " + shell(probe_ncb), out)
    run_append("cd " + shell(root) + " && env " + runtime_env + " " + shell(nc) + " run-ncb-pure " + shell(upload_ncb), out)

    hvis inneheld(out, "PURE-VM ERROR") {
        linje("[FAIL] pure VM-kandidat feila")
        returner 1
    }
    hvis ikkje inneheld(out, "mappe_opprett OK") {
        linje("[FAIL] mappe_opprett vart ikkje verifisert i pure VM")
        returner 1
    }
    hvis ikkje inneheld(out, "opplasting_mappe OK") {
        linje("[FAIL] opplasting_mappe vart ikkje verifisert i pure VM")
        returner 1
    }

    linje("[OK] pure VM-kandidat er grønn for runtime-gap v3002")
    returner 0
}

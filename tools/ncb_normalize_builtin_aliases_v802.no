// tools/ncb_normalize_builtin_aliases_v802.no — normaliser builtin-aliasar i test-NCB

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon tel_monster(path: tekst, monster: tekst) -> tekst {
    returner trim(res_felt(kommando("(LC_ALL=C grep -ao " + shell(monster) + " " + shell(path) + " || true) | wc -l | tr -d ' '"), 1))
}

funksjon start() -> heiltall {
    la inn = env("NORSCODE_NCB_NORMALIZE_IN")
    la ut = env("NORSCODE_NCB_NORMALIZE_OUT")
    hvis inn == "" eller ut == "" {
        linje("bruk: NORSCODE_NCB_NORMALIZE_IN=<inn.ncb.json> NORSCODE_NCB_NORMALIZE_OUT=<ut.ncb.json> ./bin/nc run tools/ncb_normalize_builtin_aliases_v802.no")
        returner 2
    }
    hvis ikkje ok(kommando("test -f " + shell(inn))) {
        linje("[FAIL] input manglar: " + inn)
        returner 1
    }
    hvis ikkje ok(kommando("mkdir -p $(dirname " + shell(ut) + ")")) { returner 1 }
    hvis ikkje ok(kommando("cp " + shell(inn) + " " + shell(ut))) { returner 1 }

    la finnes_for = tel_monster(ut, "\"CALL\",\"builtin[^\"]*finnes_[^\"]*kkel\",[0-9]*")
    la dobbel_for = tel_monster(ut, "\"CALL\",\"builtin\\.builtin\\.har_nokkel\",[0-9]*")
    la dobbel_builtin_for = tel_monster(ut, "\"CALL\",\"builtin\\.builtin\\.[^\"]*\",[0-9]*")

    la perl_cmd = "perl -0pi -e " +
        shell("s/\"CALL\",\"builtin(?:\\.builtin)?\\.finnes_[^\"]*kkel\",([0-9]+)/\"CALL\",\"builtin.har_nokkel\",$1/g; s/\"CALL\",\"builtin\\.builtin\\.har_nokkel\",([0-9]+)/\"CALL\",\"builtin.har_nokkel\",$1/g; s/\"CALL\",\"builtin\\.builtin\\./\"CALL\",\"builtin./g") +
        " " + shell(ut)
    hvis ikkje ok(kommando(perl_cmd)) { returner 1 }

    la finnes_etter = tel_monster(ut, "\"CALL\",\"builtin[^\"]*finnes_[^\"]*kkel\",[0-9]*")
    la dobbel_etter = tel_monster(ut, "\"CALL\",\"builtin\\.builtin\\.har_nokkel\",[0-9]*")
    la dobbel_builtin_etter = tel_monster(ut, "\"CALL\",\"builtin\\.builtin\\.[^\"]*\",[0-9]*")

    linje("[v802] normaliserte builtin-aliasar")
    linje("  input:  " + inn)
    linje("  output: " + ut)
    linje("  finnes_nokkel for/etter: " + finnes_for + "/" + finnes_etter)
    linje("  dobbel har_nokkel for/etter: " + dobbel_for + "/" + dobbel_etter)
    linje("  dobbel builtin.* for/etter: " + dobbel_builtin_for + "/" + dobbel_builtin_etter)
    linje("  merk: dette endrar berre test-NCB, ikkje runtime, stage0 eller dist/native.")
    returner 0
}

// tools/ncb_normalize_builtin_aliases_v802.no — normaliser builtin-aliasar i test-NCB

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon tekst_erstatt_alle(src: tekst, fra: tekst, ny: tekst) -> tekst {
    returner tekst_erstatt(src, fra, ny)
}

funksjon tel_tekst(src: tekst, needle: tekst) -> heiltall {
    hvis needle == "" { returner 0 }
    returner lengde(builtin.split(src, needle)) - 1
}

funksjon normaliser_call_arg(src: tekst, fra: tekst, ny: tekst, arg: heiltall) -> tekst {
    la fra_call = "\"CALL\",\"" + fra + "\"," + tekst_fra_heltall(arg)
    la til_call = "\"CALL\",\"" + ny + "\"," + tekst_fra_heltall(arg)
    returner tekst_erstatt_alle(src, fra_call, til_call)
}

funksjon normaliser_call(src: tekst, fra: tekst, ny: tekst) -> tekst {
    la ut = src
    la i = 0
    mens i < 10 {
        ut = normaliser_call_arg(ut, fra, ny, i)
        i = i + 1
    }
    returner ut
}

funksjon tel_call_alias(src: tekst, alias: tekst) -> heiltall {
    la total = 0
    la i = 0
    mens i < 10 {
        total = total + tel_tekst(src, "\"CALL\",\"" + alias + "\"," + tekst_fra_heltall(i))
        i = i + 1
    }
    returner total
}

funksjon start() -> heiltall {
    la inn = env("NORSCODE_NCB_NORMALIZE_IN")
    la ut = env("NORSCODE_NCB_NORMALIZE_OUT")
    hvis inn == "" eller ut == "" {
        linje("bruk: ncb_normalize_builtin_aliases_v802.sh <inn.ncb.json> <ut.ncb.json>")
        returner 2
    }
    la data = ""
    prøv {
        data = builtin.fil_les(inn)
    } fang (e) {
        linje("[FAIL] input manglar: " + inn)
        returner 1
    }

    la finnes_for = tel_call_alias(data, "builtin.finnes_nøkkel") + tel_call_alias(data, "builtin.finnes_nokkel") + tel_call_alias(data, "builtin.builtin.finnes_nøkkel") + tel_call_alias(data, "builtin.builtin.finnes_nokkel")
    la tekst_store_for = tel_call_alias(data, "builtin.tekst_til_store") + tel_call_alias(data, "builtin.builtin.tekst_til_store")
    la tekst_liten_for = tel_call_alias(data, "builtin.tekst_til_liten") + tel_call_alias(data, "builtin.builtin.tekst_til_liten")
    la dobbel_for = tel_call_alias(data, "builtin.builtin.har_nokkel")
    la dobbel_builtin_for = tel_tekst(data, "\"CALL\",\"builtin.builtin.")

    data = normaliser_call(data, "builtin.finnes_nøkkel", "builtin.har_nokkel")
    data = normaliser_call(data, "builtin.finnes_nokkel", "builtin.har_nokkel")
    data = normaliser_call(data, "builtin.builtin.finnes_nøkkel", "builtin.har_nokkel")
    data = normaliser_call(data, "builtin.builtin.finnes_nokkel", "builtin.har_nokkel")
    data = normaliser_call(data, "builtin.tekst_til_store", "builtin.upper")
    data = normaliser_call(data, "builtin.builtin.tekst_til_store", "builtin.upper")
    data = normaliser_call(data, "builtin.tekst_til_liten", "builtin.lower")
    data = normaliser_call(data, "builtin.builtin.tekst_til_liten", "builtin.lower")
    data = normaliser_call(data, "builtin.builtin.har_nokkel", "builtin.har_nokkel")
    data = tekst_erstatt_alle(data, "\"CALL\",\"builtin.builtin.", "\"CALL\",\"builtin.")

    builtin.fil_skriv(ut, data)

    la finnes_etter = tel_call_alias(data, "builtin.finnes_nøkkel") + tel_call_alias(data, "builtin.finnes_nokkel") + tel_call_alias(data, "builtin.builtin.finnes_nøkkel") + tel_call_alias(data, "builtin.builtin.finnes_nokkel")
    la tekst_store_etter = tel_call_alias(data, "builtin.tekst_til_store") + tel_call_alias(data, "builtin.builtin.tekst_til_store")
    la tekst_liten_etter = tel_call_alias(data, "builtin.tekst_til_liten") + tel_call_alias(data, "builtin.builtin.tekst_til_liten")
    la dobbel_etter = tel_call_alias(data, "builtin.builtin.har_nokkel")
    la dobbel_builtin_etter = tel_tekst(data, "\"CALL\",\"builtin.builtin.")

    linje("[v802] normaliserte builtin-aliasar")
    linje("  input:  " + inn)
    linje("  output: " + ut)
    linje("  finnes_nokkel for/etter: " + finnes_for + "/" + finnes_etter)
    linje("  tekst_til_store for/etter: " + tekst_store_for + "/" + tekst_store_etter)
    linje("  tekst_til_liten for/etter: " + tekst_liten_for + "/" + tekst_liten_etter)
    linje("  dobbel har_nokkel for/etter: " + dobbel_for + "/" + dobbel_etter)
    linje("  dobbel builtin.* for/etter: " + dobbel_builtin_for + "/" + dobbel_builtin_etter)
    linje("  merk: dette endrar berre NCB-output, ikkje runtime, stage0 eller dist/native.")
    returner 0
}

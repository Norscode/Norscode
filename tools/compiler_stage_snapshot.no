// tools/compiler_stage_snapshot.no — lag kompilator-snapshot i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon start() -> heiltall {
    la output_dir = "reports/compiler_snapshots"
    kommando("mkdir -p " + shell(output_dir))
    la timestamp = trim(res_felt(kommando("date +%Y%m%d_%H%M%S"), 1))
    la snapshot_dir = output_dir + "/snapshot_" + timestamp
    kommando("mkdir -p " + shell(snapshot_dir))
    linje("Creating compiler stage snapshot...")
    kommando("for FILE in build/compiler_stage1 build/compiler_stage2 reports/bootstrap_diff_report.txt; do if [ -f \"$FILE\" ]; then cp \"$FILE\" " + shell(snapshot_dir) + "/; fi; done")
    la body = "=== Compiler Snapshot Hashes ===\n\n" +
        res_felt(kommando("find " + shell(snapshot_dir) + " -type f | while read -r FILE; do shasum -a 256 \"$FILE\"; done"), 1)
    kommando("printf '%s' " + shell(body) + " > " + shell(snapshot_dir + "/hashes.txt"))
    linje("Compiler snapshot created at: " + snapshot_dir)
    returner 0
}

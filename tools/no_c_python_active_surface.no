// tools/no_c_python_active_surface.no — aktiv repository-flate utan C/Python

bruk std.liste som liste

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner tekst(res[0]) == builtin.chr(48)
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon print_policy() -> heiltall {
    linje("")
    linje("Policy (no-c/python active surface):")
    linje("  - Aktiv flyt: sjølvstendig .no/NCB/Native-ELF, utan Python/C i kjede.")
    linje("  - C/Python er ikkje del av aktiv kompilering; berre archive/ og smalt deklarerte test-/vendorartefaktar er tillatne.")
    linje("  - Nye funksjonar skal byggjast som .no og verifiserast med ./bin/nc feature-check.")
    linje("")
    returner 0
}

funksjon allowlisted_path(root: tekst, path: tekst) -> bool {
    hvis builtin.starts_with(path, root + "/archive/") { returner sann }
    hvis path == root + "/tests/fixtures/windows_process_fixture.c" { returner sann }
    hvis path == root + "/tests/fixtures/windows_utf8_file_fixture.c" { returner sann }
    hvis path == root + "/tests/native_gc_blocked_thread.c" { returner sann }
    hvis path == root + "/tests/native_gc_exception_unwind.c" { returner sann }
    hvis path == root + "/tests/native_gc_generational.c" { returner sann }
    hvis path == root + "/tests/native_gc_lifecycle.c" { returner sann }
    hvis path == root + "/tests/native_gc_relocation.c" { returner sann }
    hvis path == root + "/tests/native_gc_threads.c" { returner sann }
    hvis path == root + "/third_party/sqlite/sqlite3.c" { returner sann }
    hvis path == root + "/third_party/sqlite/sqlite3.h" { returner sann }
    returner usann
}

funksjon ncb_to_c_allowlisted_path(root: tekst, path: tekst) -> bool {
    hvis builtin.starts_with(path, root + "/docs/") { returner sann }
    hvis builtin.starts_with(path, root + "/tools/maint/") { returner sann }
    hvis path == root + "/tools/no_c_python_active_surface." + "s" + "h" { returner sann }
    hvis path == root + "/tools/no_c_python_active_surface.no" { returner sann }
    hvis path == root + "/docs/05-development/NATIVE_CODEGEN_V2_ABI.md" { returner sann }
    hvis path == root + "/docs/SELFHOST_HANDLINGSPLAN.md" { returner sann }
    hvis path == root + "/docs/STATUS.md" { returner sann }
    returner usann
}

funksjon linjer(t: tekst) -> liste_tekst {
    la rå = builtin.split(t, "\n")
    la ut: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(rå) {
        la l = trim_tekst(rå[i])
        hvis l != "" { legg_til(ut, l) }
        i = i + 1
    }
    returner ut
}

funksjon sortert_unik(verdiar: liste_tekst) -> liste_tekst {
    liste.sorter_tekst(verdiar)
    la ut: liste_tekst = []
    la sist = ""
    la har_sist = usann
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        la v = verdiar[i]
        hvis ikkje har_sist eller v != sist {
            legg_til(ut, v)
            sist = v
            har_sist = sann
        }
        i = i + 1
    }
    returner ut
}

funksjon collect_py_hits(root: tekst) -> liste_tekst {
    la cmd = "find " + shell(root) + " -path " + shell(root + "/.git") + " -prune -o -type f -name '*.py' -print 2>/dev/null"
    returner sortert_unik(linjer(res_felt(kommando(cmd), 1)))
}

funksjon collect_c_hits(root: tekst) -> liste_tekst {
    la cmd =
        "find " + shell(root) + " -path " + shell(root + "/.git") + " -prune -o -path " + shell(root + "/build") + " -prune -o -type f \\( -name '*.c' -o -name '*.h' \\) -print 2>/dev/null"
    returner sortert_unik(linjer(res_felt(kommando(cmd), 1)))
}

funksjon ref_file_allowed(root: tekst, fil: tekst) -> bool {
    hvis builtin.index_of(fil, "/reports/") >= 0 { returner usann }
    hvis builtin.index_of(fil, "/archive/") >= 0 { returner usann }
    hvis builtin.starts_with(fil, root + "/docs/") { returner usann }
    hvis fil == root + "/bin/nc" { returner usann }
    hvis builtin.ends_with(fil, "/no_c_python_active_surface.sh") { returner usann }
    hvis builtin.ends_with(fil, "/norscode_feature_gate.sh") { returner usann }
    hvis builtin.ends_with(fil, "/python_dependency_audit.sh") { returner usann }
    hvis builtin.ends_with(fil, "/python_free_ci.sh") { returner usann }
    hvis builtin.ends_with(fil, "/build_norscode_native.sh") { returner usann }
    hvis builtin.ends_with(fil, "/verify_seed_only.sh") { returner usann }
    hvis builtin.ends_with(fil, "/verify_selvstendighet.sh") { returner usann }
    hvis builtin.ends_with(fil, "/verify_omgang6.sh") { returner usann }
    hvis builtin.ends_with(fil, "/selfhost_phase0_verify.sh") { returner usann }
    hvis builtin.ends_with(fil, "/selfhost_drift_guard.sh") { returner usann }
    hvis builtin.ends_with(fil, "/unified_bootstrap_verifier.sh") { returner usann }
    hvis builtin.ends_with(fil, "/no_legacy_cvm.sh") { returner usann }
    hvis builtin.ends_with(fil, "/enforce_native_first.sh") { returner usann }
    hvis builtin.ends_with(fil, "/ci.yml") { returner usann }
    hvis builtin.ends_with(fil, "/publish.yml") { returner usann }
    hvis builtin.ends_with(fil, "/selfhost-lexer-token-smoke.yml") { returner usann }
    hvis builtin.ends_with(fil, "/selvstendighet.yml") { returner usann }
    hvis builtin.ends_with(fil, "/stage0-binary.yml") { returner usann }
    hvis builtin.ends_with(fil, "/windows-app-release.yml") { returner usann }
    hvis builtin.ends_with(fil, "/linux-app-release.yml") { returner usann }
    hvis builtin.ends_with(fil, "/macos-app-release.yml") { returner usann }
    returner sann
}

funksjon collect_ref_files(root: tekst) -> liste_tekst {
    la body =
        res_felt(kommando("find " + shell(root + "/bin") + " -maxdepth 1 -type f -name 'nc' -print 2>/dev/null"), 1) + "\n" +
        res_felt(kommando("find " + shell(root + "/.github/workflows") + " -maxdepth 1 -type f \\( -name '*.yml' -o -name '*.yaml' \\) -print 2>/dev/null"), 1) + "\n" +
        res_felt(kommando("find " + shell(root + "/tools") + " -type f -name '*.sh' -print 2>/dev/null"), 1)
    la rå = sortert_unik(linjer(body))
    la ut: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(rå) {
        hvis ref_file_allowed(root, rå[i]) { legg_til(ut, rå[i]) }
        i = i + 1
    }
    returner ut
}

funksjon linje_har_ref(line: tekst) -> bool {
    hvis builtin.index_of(line, "python3") >= 0 { returner sann }
    hvis builtin.index_of(line, "python") >= 0 { returner sann }
    hvis builtin.index_of(line, "pytest") >= 0 { returner sann }
    hvis builtin.index_of(line, "clang") >= 0 { returner sann }
    hvis builtin.index_of(line, "gcc") >= 0 { returner sann }
    hvis builtin.index_of(line, " cc ") >= 0 { returner sann }
    hvis builtin.index_of(line, "ncb_to_c") >= 0 { returner sann }
    hvis builtin.index_of(line, "c_minimal_vm") >= 0 { returner sann }
    hvis builtin.index_of(line, "nc_runtime") >= 0 { returner sann }
    hvis builtin.index_of(line, "nc_native_main") >= 0 { returner sann }
    returner usann
}

funksjon fil_ref_hits(fil: tekst) -> tekst {
    la data = ""
    prøv { data = builtin.fil_les(fil) } fang (e) { returner "" }
    la lines = builtin.split(data, "\n")
    la out = ""
    la i: heiltall = 0
    mens i < lengde(lines) {
        hvis linje_har_ref(lines[i]) {
            out = out + fil + ":" + tekst_fra_heltall(i + 1) + ":" + lines[i] + "\n"
        }
        i = i + 1
    }
    returner trim_tekst(out)
}

funksjon collect_ref_hits(root: tekst) -> tekst {
    la filer = collect_ref_files(root)
    la out = ""
    la i: heiltall = 0
    mens i < lengde(filer) {
        la hit = fil_ref_hits(filer[i])
        hvis hit != "" { out = out + hit + "\n" }
        i = i + 1
    }
    returner trim_tekst(out)
}

funksjon collect_ncb_to_c_hits(root: tekst) -> liste_tekst {
    la body =
        res_felt(kommando("find " + shell(root + "/.github") + " " + shell(root + "/tools") + " " + shell(root + "/selfhost") + " " + shell(root + "/docs") + " " + shell(root + "/bootstrap") + " " + shell(root + "/bin") + " -type f -print 2>/dev/null"), 1)
    la filer = sortert_unik(linjer(body))
    la hits: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(filer) {
        la data = ""
        prøv { data = builtin.fil_les(filer[i]) } fang (e) { data = "" }
        hvis data != "" {
            la lines = builtin.split(data, "\n")
            la j: heiltall = 0
            mens j < lengde(lines) {
                hvis builtin.index_of(lines[j], "ncb_to_c") >= 0 {
                    legg_til(hits, filer[i] + ":" + tekst_fra_heltall(j + 1) + ":" + lines[j])
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    returner hits
}

funksjon collect_scaffold_shell_entry_hits(root: tekst) -> liste_tekst {
    la body =
        root + "/README.md\n" +
        res_felt(kommando("find " + shell(root + "/docs") + " -type f -print 2>/dev/null"), 1) + "\n" +
        root + "/bin/nc"
    la filer = sortert_unik(linjer(body))
    la hits: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(filer) {
        la data = ""
        prøv { data = builtin.fil_les(filer[i]) } fang (e) { data = "" }
        hvis data != "" {
            la lines = builtin.split(data, "\n")
            la j: heiltall = 0
            mens j < lengde(lines) {
                la line = lines[j]
                la er_cli = filer[i] == root + "/bin/nc"
                la er_doc_shell_ref = (builtin.index_of(line, "tools/startproject.sh") >= 0 eller builtin.index_of(line, "tools/startapp.sh") >= 0) og ikkje er_cli
                la er_gammal_cli_passthrough = er_cli og (builtin.index_of(line, "exec sh \"$ROOT_DIR/tools/startproject.sh\" \"$@\"") >= 0 eller builtin.index_of(line, "exec sh \"$ROOT_DIR/tools/startapp.sh\" \"$@\"") >= 0)
                hvis er_doc_shell_ref eller er_gammal_cli_passthrough {
                    legg_til(hits, filer[i] + ":" + tekst_fra_heltall(j + 1) + ":" + line)
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    returner hits
}

funksjon hit_path(root: tekst, hit: tekst) -> tekst {
    la deler = builtin.split(hit, ":")
    hvis lengde(deler) < 1 { returner "" }
    la p = deler[0]
    hvis builtin.starts_with(p, "/") { returner p }
    returner root + "/" + p
}

funksjon skriv_liste(tittel: tekst, verdiar: liste_tekst) -> heiltall {
    linje(tittel)
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        linje(verdiar[i])
        i = i + 1
    }
    linje("")
    returner 0
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(res_felt(kommando("pwd"), 1)) }

    la fail: heiltall = 0
    linje("=== Active surface C/Python gate ===")
    linje("")
    print_policy()

    la py_hits = collect_py_hits(root)
    la py_bad: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(py_hits) {
        hvis ikkje allowlisted_path(root, py_hits[i]) { legg_til(py_bad, py_hits[i]) }
        i = i + 1
    }
    hvis lengde(py_bad) > 0 {
        skriv_liste("Feil: .py-filer funne utanfor archive/:", py_bad)
        fail = 1
    } ellers {
        linje("OK: ingen .py-filer utanfor archive/")
    }

    la c_hits = collect_c_hits(root)
    la c_bad: liste_tekst = []
    i = 0
    mens i < lengde(c_hits) {
        hvis ikkje allowlisted_path(root, c_hits[i]) { legg_til(c_bad, c_hits[i]) }
        i = i + 1
    }
    hvis lengde(c_bad) > 0 {
        skriv_liste("Feil: nye .c/.h-filer utanfor allowlist:", c_bad)
        fail = 1
    } ellers {
        linje("OK: ingen nye .c/.h-filer utanfor allowlist")
    }

    la ncb_hits = collect_ncb_to_c_hits(root)
    la ncb_bad: liste_tekst = []
    i = 0
    mens i < lengde(ncb_hits) {
        la p = hit_path(root, ncb_hits[i])
        hvis ikkje ncb_to_c_allowlisted_path(root, p) { legg_til(ncb_bad, ncb_hits[i]) }
        i = i + 1
    }
    hvis lengde(ncb_bad) > 0 {
        skriv_liste("Feil: ncb_to_c funne i normal kontekst:", ncb_bad)
        fail = 1
    } ellers hvis lengde(ncb_hits) > 0 {
        linje("OK: ncb_to_c er avgrensa til vedlikehald/docs-lane")
    } ellers {
        linje("OK: ncb_to_c-referansar er ikkje funne")
    }

    la ref_hits = collect_ref_hits(root)
    hvis ref_hits != "" {
        linje("Feil: aktive referansar til C/Python-overgangsflater utanfor allowlist:")
        linje(ref_hits)
        fail = 1
    } ellers {
        linje("OK: ingen uventa overgangsreferansar utanfor allowlist")
    }

    la scaffold_hits = collect_scaffold_shell_entry_hits(root)
    hvis lengde(scaffold_hits) > 0 {
        skriv_liste("Feil: aktiv scaffold-flate peker direkte til .sh i staden for Norscode-inngangen:", scaffold_hits)
        fail = 1
    } ellers {
        linje("OK: scaffold-kommandoflate går via Norscode-inngang")
    }

    hvis fail != 0 { returner 1 }
    linje("")
    linje("=== Gate passerte ===")
    returner 0
}

// tools/controlled_runtime_promotion_v3005.no — kontrollert runtime-promotering

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run_capture(cmd: tekst, out: tekst) -> heiltall {
    la res = kommando(cmd + " > " + shell(out) + " 2>&1")
    hvis ok(res) { returner 0 }
    returner 1
}

funksjon file_contains(path: tekst, needle: tekst) -> bool {
    returner ok(kommando("grep -Fq " + shell(needle) + " " + shell(path) + " 2>/dev/null"))
}

funksjon sha_file(path: tekst) -> tekst {
    hvis ikkje ok(kommando("test -f " + shell(path))) { returner "missing" }
    returner trim(felt(kommando("shasum -a 256 " + shell(path) + " | awk '{print $1}'"), 1))
}

funksjon read_file(path: tekst) -> tekst {
    returner felt(kommando("cat " + shell(path) + " 2>/dev/null || true"), 1)
}

funksjon stage0_path(root: tekst) -> tekst {
    la os = trim(felt(kommando("uname -s"), 1))
    la arch = trim(felt(kommando("uname -m"), 1))
    hvis os == "Darwin" og arch == "arm64" { returner root + "/bootstrap/stage0/norscode-macos-arm64" }
    hvis os == "Darwin" og arch == "x86_64" { returner root + "/bootstrap/stage0/norscode-macos-x86_64" }
    hvis os == "Linux" og arch == "x86_64" { returner root + "/bootstrap/stage0/norscode-linux-x86_64" }
    hvis os == "Linux" og arch == "amd64" { returner root + "/bootstrap/stage0/norscode-linux-x86_64" }
    hvis os == "Linux" og arch == "aarch64" { returner root + "/bootstrap/stage0/norscode-linux-arm64" }
    hvis os == "Linux" og arch == "arm64" { returner root + "/bootstrap/stage0/norscode-linux-arm64" }
    returner ""
}

funksjon escape_value(v: tekst) -> tekst {
    la tmp = "/tmp/norscode_promotion_escape.txt"
    kommando("printf '%s' " + shell(v) + " > " + shell(tmp))
    returner trim(felt(kommando("sed 's/\\\\/\\\\\\\\/g; s/\"/\\\\\"/g; s/\t/\\\\t/g' " + shell(tmp) + " | tr '\\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'"), 1))
}

funksjon no_line(report: tekst, key: tekst, value: tekst) -> bool {
    la safe_key = escape_value(key)
    la safe_value = escape_value(value)
    returner ok(kommando("printf 'controlled_runtime_promotion(\"%s\", \"%s\")\n' " + shell(safe_key) + " " + shell(safe_value) + " >> " + shell(report)))
}

funksjon bool_text(verdi: bool) -> tekst {
    hvis verdi { returner "sann" }
    returner "usann"
}

funksjon write_report(report: tekst, root: tekst, candidate: tekst, dist: tekst, stage0: tekst, confirm_text: tekst, dry_run: bool, status: tekst, decision: tekst, candidate_status: tekst, active_before_status: tekst, active_after_status: tekst, active_before_out: tekst, active_after_out: tekst, dist_before: tekst, dist_after: tekst, stage0_before: tekst, stage0_after: tekst, backup_dir: tekst) -> bool {
    hvis ikkje ok(kommando("mkdir -p " + shell(root + "/docs"))) { returner usann }
    hvis ikkje ok(kommando(": > " + shell(report))) { returner usann }
    no_line(report, "schema", "norscode.controlled_runtime_promotion.v3005")
    no_line(report, "status", status)
    no_line(report, "decision", decision)
    no_line(report, "candidate", candidate)
    no_line(report, "candidate_gate_status", candidate_status)
    no_line(report, "active_runtime", dist)
    no_line(report, "active_runtime_gate_before", active_before_status)
    no_line(report, "active_runtime_gate_after", active_after_status)
    no_line(report, "active_runtime_output_before", active_before_out)
    no_line(report, "active_runtime_output_after", active_after_out)
    no_line(report, "dist_sha256_before", dist_before)
    no_line(report, "dist_sha256_after", dist_after)
    no_line(report, "stage0", stage0)
    no_line(report, "stage0_sha256_before", stage0_before)
    no_line(report, "stage0_sha256_after", stage0_after)
    no_line(report, "backup_dir", backup_dir)
    no_line(report, "confirm_required", confirm_text)
    hvis dry_run { no_line(report, "dry_run", "1") } ellers { no_line(report, "dry_run", "0") }
    no_line(report, "active_runtime_changed", bool_text(dist_before != dist_after))
    no_line(report, "stage0_changed", bool_text(stage0_before != stage0_after))
    no_line(report, "updated_at", trim(felt(kommando("date -u '+%Y-%m-%dT%H:%M:%SZ'"), 1)))
    skriv(read_file(report))
    returner sann
}

funksjon start() -> heiltall {
    la root = trim(felt(kommando("pwd"), 1))
    la candidate_rel = "build/v3009/norscode_native_macos_arm64_v3009"
    la candidate = root + "/" + candidate_rel
    la dist = root + "/dist/norscode_native"
    la promote = root + "/tools/promote_native_stage0_v3001.sh"
    la gate = root + "/tools/native_runtime_gap_gate_v3001.sh"
    la readiness = root + "/tools/native_runtime_gap_promotion_readiness_v3003.sh"
    la report = root + "/docs/controlled_runtime_promotion_v3005.no"
    la confirm_text = "godkjenn kritisk runtime-promotering"
    la dry_flag = env("NORSCODE_PROMOTION_DRY_RUN")
    la confirm = env("NORSCODE_PROMOTION_CONFIRM")
    la dry_run = dry_flag == "sann"
    la stage0 = stage0_path(root)

    la tmpdir = trim(felt(kommando("mktemp -d /tmp/norscode_controlled_promotion.XXXXXX"), 1))
    la candidate_out = tmpdir + "/candidate.out"
    la active_before_out = tmpdir + "/active_before.out"
    la active_after_out = tmpdir + "/active_after.out"
    la readiness_out = tmpdir + "/readiness.out"
    la dist_dry_out = tmpdir + "/dist_dry.out"
    la stage0_dry_out = tmpdir + "/stage0_dry.out"

    la dist_before = sha_file(dist)
    la stage0_before = sha_file(stage0)

    la candidate_code = run_capture("bash " + shell(gate) + " " + shell(candidate), candidate_out)
    la active_before_code = run_capture("bash " + shell(gate) + " " + shell(dist), active_before_out)
    la readiness_code = run_capture("bash " + shell(readiness), readiness_out)
    la dist_dry_code = run_capture("bash " + shell(promote) + " " + shell(candidate_rel) + " --dist --dry-run", dist_dry_out)
    la stage0_dry_code = run_capture("bash " + shell(promote) + " " + shell(candidate_rel) + " --stage0 --dry-run", stage0_dry_out)

    la candidate_status = "red"
    hvis candidate_code == 0 og file_contains(candidate_out, "[OK] runtime-gap gate er grønn") { candidate_status = "green" }
    la active_before_status = "red_unknown"
    hvis active_before_code == 0 og file_contains(active_before_out, "[OK] runtime-gap gate er grønn") {
        active_before_status = "green"
    } ellers hvis file_contains(active_before_out, "mappe_opprett FEIL") {
        active_before_status = "red_detected"
    }
    la readiness_status = "red"
    hvis readiness_code == 0 og file_contains(readiness_out, "promotion_readiness(\"decision\", \"ready_for_controlled_promotion\")") { readiness_status = "green" }
    la dist_dry_status = "red"
    hvis dist_dry_code == 0 og file_contains(dist_dry_out, "[DRY-RUN] ingen filer vart endra") { dist_dry_status = "green" }
    la stage0_dry_status = "red"
    hvis stage0_dry_code == 0 og file_contains(stage0_dry_out, "[DRY-RUN] ingen filer vart endra") { stage0_dry_status = "green" }

    hvis candidate_status != "green" eller readiness_status != "green" eller dist_dry_status != "green" eller stage0_dry_status != "green" {
        la dist_after_fail = sha_file(dist)
        la stage0_after_fail = sha_file(stage0)
        write_report(report, root, candidate, dist, stage0, confirm_text, dry_run, "red", "preflight_failed_no_promotion", candidate_status, active_before_status, "not_run", read_file(active_before_out), "", dist_before, dist_after_fail, stage0_before, stage0_after_fail, "")
        kommando("rm -rf " + shell(tmpdir))
        returner 1
    }

    hvis dry_run {
        la dist_after_dry = sha_file(dist)
        la stage0_after_dry = sha_file(stage0)
        write_report(report, root, candidate, dist, stage0, confirm_text, dry_run, "green", "dry_run_green_no_promotion", candidate_status, active_before_status, "not_run", read_file(active_before_out), "", dist_before, dist_after_dry, stage0_before, stage0_after_dry, "")
        kommando("rm -rf " + shell(tmpdir))
        returner 0
    }

    hvis confirm != confirm_text {
        la dist_after_block = sha_file(dist)
        la stage0_after_block = sha_file(stage0)
        write_report(report, root, candidate, dist, stage0, confirm_text, dry_run, "blocked", "missing_exact_confirmation", candidate_status, active_before_status, "not_run", read_file(active_before_out), "", dist_before, dist_after_block, stage0_before, stage0_after_block, "")
        kommando("rm -rf " + shell(tmpdir))
        returner 2
    }

    la backup_dir = root + "/build/runtime_promotion_backups/" + trim(felt(kommando("date -u '+%Y%m%dT%H%M%SZ'"), 1))
    hvis ikkje ok(kommando("mkdir -p " + shell(backup_dir))) { returner 1 }
    hvis ikkje ok(kommando("cp " + shell(dist) + " " + shell(backup_dir + "/norscode_native.before"))) { returner 1 }
    hvis ikkje ok(kommando("cp " + shell(stage0) + " " + shell(backup_dir + "/" + trim(felt(kommando("basename " + shell(stage0)), 1)) + ".before"))) { returner 1 }

    hvis ikkje ok(kommando("bash " + shell(promote) + " " + shell(candidate_rel) + " --dist --stage0")) { returner 1 }
    la active_after_code = run_capture("bash " + shell(gate) + " " + shell(dist), active_after_out)
    la active_after_status = "red_unknown"
    hvis active_after_code == 0 og file_contains(active_after_out, "[OK] runtime-gap gate er grønn") { active_after_status = "green" }

    hvis active_after_status != "green" {
        kommando("cp " + shell(backup_dir + "/norscode_native.before") + " " + shell(dist))
        kommando("cp " + shell(backup_dir + "/" + trim(felt(kommando("basename " + shell(stage0)), 1)) + ".before") + " " + shell(stage0))
        kommando("chmod +x " + shell(dist) + " " + shell(stage0))
        write_report(report, root, candidate, dist, stage0, confirm_text, dry_run, "red", "post_gate_failed_rolled_back", candidate_status, active_before_status, active_after_status, read_file(active_before_out), read_file(active_after_out), dist_before, sha_file(dist), stage0_before, sha_file(stage0), backup_dir)
        kommando("rm -rf " + shell(tmpdir))
        returner 1
    }

    write_report(report, root, candidate, dist, stage0, confirm_text, dry_run, "green", "controlled_promotion_complete", candidate_status, active_before_status, active_after_status, read_file(active_before_out), read_file(active_after_out), dist_before, sha_file(dist), stage0_before, sha_file(stage0), backup_dir)
    kommando("rm -rf " + shell(tmpdir))
    returner 0
}

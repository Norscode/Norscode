// tools/run_ir_bytecode_phase_v4600.no — IR/bytecode compile og runtime phase

bruk std.path som path

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon has(path: tekst, needle: tekst) -> bool {
    prøv {
        returner builtin.index_of(builtin.fil_les(path), needle) >= 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon assert_ncb(path: tekst) -> bool {
    hvis ikkje has(path, "\"entry\"") { returner usann }
    hvis ikkje has(path, "\"functions\"") { returner usann }
    returner sann
}

funksjon base_no(src: tekst) -> tekst {
    la base = path.basename(src)
    hvis builtin.ends_with(base, ".no") {
        returner builtin.slice(base, 0, lengde(base) - 3)
    }
    returner base
}

funksjon compile_one(root: tekst, bin_path: tekst, src: tekst, tag: tekst) -> bool {
    la out_dir = root + "/build/v4600"
    la base = base_no(src)
    la out = out_dir + "/" + tag + "_" + base + ".ncb.json"
    la log = "/tmp/" + tag + "_" + base + "_v4600_compile.log"
    la cmd = "env NORSCODE_ROOT=" + shell(root) +
        " NORSCODE_CMD=compile NORSCODE_FILE=" + shell(root + "/" + src) +
        " NORSCODE_OUTPUT=" + shell(out) + " " + shell(bin_path) + " > " + shell(log) + " 2>&1"
    la res = kommando(cmd)
    prøv {
        la logg = builtin.fil_les(log)
        hvis logg != "" { skriv(logg) }
    } fang (e) {}
    hvis ikkje ok(res) { returner usann }
    hvis ikkje builtin.fil_finnes(out) { returner usann }
    hvis ikkje assert_ncb(out) { returner usann }
    linje("[OK] " + tag + " compile: " + src + " -> " + out)
    returner sann
}

funksjon run_fixture(root: tekst, bin_path: tekst, tag: tekst) -> bool {
    la fixture = root + "/tests/fixtures/ir_bytecode_runtime_v4600.no"
    la log = "/tmp/" + tag + "_v4600_runtime.log"
    la cmd = "env NORSCODE_ROOT=" + shell(root) +
        " NORSCODE_CMD=run NORSCODE_FILE=" + shell(fixture) +
        " " + shell(bin_path) + " > " + shell(log) + " 2>&1"
    la res = kommando(cmd)
    prøv {
        la logg = builtin.fil_les(log)
        hvis logg != "" { skriv(logg) }
    } fang (e) {}
    hvis ikkje ok(res) { returner usann }
    hvis ikkje has(log, "ir bytecode runtime v4600") { returner usann }
    hvis has(log, "SKAL_IKKJE") {
        linje("[FAIL] " + tag + " runtime fixture viste uoppnåeleg kode etter returner")
        returner usann
    }
    hvis ikkje has(log, "retur_utan_verdi OK") { returner usann }
    hvis ikkje has(log, "loop_test OK: 8") { returner usann }
    hvis ikkje has(log, "try_fang OK: fanga:boom") { returner usann }
    linje("[OK] " + tag + " runtime fixture grøn")
    returner sann
}

funksjon files() -> liste_tekst {
    la r: liste_tekst = []
    legg_til(r, "selfhost/vm.no")
    legg_til(r, "selfhost/bundler.no")
    legg_til(r, "selfhost/nc_main.no")
    returner r
}

funksjon docker_finst() -> bool {
    returner ok(kommando("docker info >/dev/null 2>&1"))
}

funksjon run_linux_docker(root: tekst) -> bool {
    la script = "set -euo pipefail\napt-get update >/dev/null\napt-get install -y libsqlite3-0 >/dev/null\nmkdir -p /work/build/v4600\n"
    for src i files() {
        la base = base_no(src)
        script = script + "env NORSCODE_ROOT=/work NORSCODE_CMD=compile NORSCODE_FILE=/work/" + src +
            " NORSCODE_OUTPUT=/work/build/v4600/linux_stage0_" + base + ".ncb.json " +
            "/work/bootstrap/stage0/norscode-linux-x86_64 >/work/build/v4600/linux_stage0_" + base + "_compile.log 2>&1\n"
    }
    script = script + "env NORSCODE_ROOT=/work NORSCODE_CMD=run NORSCODE_FILE=/work/tests/fixtures/ir_bytecode_runtime_v4600.no /work/bootstrap/stage0/norscode-linux-x86_64 >/work/build/v4600/linux_stage0_runtime.log 2>&1\n"
    la cmd = "docker run --rm --platform linux/amd64 -v " + shell(root + ":/work") +
        " -w /work ubuntu:24.04 bash -lc " + shell(script)
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    hvis ikkje ok(res) { returner usann }

    for src i files() {
        la base = base_no(src)
        la log = root + "/build/v4600/linux_stage0_" + base + "_compile.log"
        prøv {
            la logg = builtin.fil_les(log)
            hvis logg != "" { skriv(logg) }
        } fang (e) {}
        la out = root + "/build/v4600/linux_stage0_" + base + ".ncb.json"
        hvis ikkje builtin.fil_finnes(out) { returner usann }
        hvis ikkje assert_ncb(out) { returner usann }
        linje("[OK] linux_stage0 compile: " + src + " -> " + out)
    }

    la runtime_log = root + "/build/v4600/linux_stage0_runtime.log"
    prøv {
        la logg2 = builtin.fil_les(runtime_log)
        hvis logg2 != "" { skriv(logg2) }
    } fang (e) {}
    hvis ikkje has(runtime_log, "ir bytecode runtime v4600") { returner usann }
    hvis has(runtime_log, "SKAL_IKKJE") {
        linje("[FAIL] linux_stage0 runtime fixture viste uoppnåeleg kode etter returner")
        returner usann
    }
    hvis ikkje has(runtime_log, "retur_utan_verdi OK") { returner usann }
    hvis ikkje has(runtime_log, "loop_test OK: 8") { returner usann }
    hvis ikkje has(runtime_log, "try_fang OK: fanga:boom") { returner usann }
    linje("[OK] linux_stage0 runtime fixture grøn")
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    hvis ikkje ok(kommando("mkdir -p " + shell(root + "/build/v4600"))) { returner 1 }

    linje("== v4600 ir/bytecode phase ==")
    linje("")
    linje("[1/3] macOS active dist large selfhost compile gate")
    for src i files() {
        hvis ikkje compile_one(root, root + "/dist/norscode_native", src, "macos_dist") { returner 1 }
    }

    linje("")
    linje("[2/3] macOS active dist IR runtime fixture")
    hvis ikkje run_fixture(root, root + "/dist/norscode_native", "macos_dist") { returner 1 }

    hvis docker_finst() {
        linje("")
        linje("[3/3] Linux x86_64 stage0 compile+runtime gate (Docker)")
        hvis ikkje run_linux_docker(root) { returner 1 }
    } ellers {
        linje("")
        linje("[SKIP] Docker er ikkje tilgjengeleg.")
    }

    linje("")
    linje("[OK] v4600 ir/bytecode phase ferdig.")
    returner 0
}

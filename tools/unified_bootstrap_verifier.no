// tools/unified_bootstrap_verifier.no — samla bootstrap-verifisering i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon run_capture(cmd: tekst) -> tekst {
    la res = kommando(cmd)
    returner res_felt(res, 1) + res_felt(res, 2)
}

funksjon nc_run(root: tekst, fil: tekst) -> tekst {
    returner "NORSCODE_ROOT=" + shell(root) + " " + shell(root + "/bin/nc") + " run " + shell(root + "/" + fil)
}

funksjon start() -> heiltall {
    la root = builtin.trim(res_felt(kommando("pwd"), 1))
    kommando("mkdir -p reports")
    la report = "reports/unified_bootstrap_verification.txt"
    la body = "=== Unified Bootstrap Verification ===\n\n"

    body = body + "Running Python dependency audit...\n"
    body = body + run_capture(nc_run(root, "tools/python_dependency_audit.no"))

    body = body + "\nRunning compiler equivalence verification...\n"
    hvis fil_finst("build/compiler_stage1") og fil_finst("build/compiler_stage2") {
        body = body + run_capture("NORSCODE_COMPILER_A=build/compiler_stage1 NORSCODE_COMPILER_B=build/compiler_stage2 " + nc_run(root, "tools/compare_compilers.no"))
    } ellers {
        body = body + "Compiler stage outputs missing\n"
    }

    body = body + "\nRunning bootstrap diff analysis...\n"
    hvis fil_finst("build/compiler_stage1") og fil_finst("build/compiler_stage2") {
        body = body + run_capture("NORSCODE_BUILD_A=build/compiler_stage1 NORSCODE_BUILD_B=build/compiler_stage2 " + nc_run(root, "tools/bootstrap_diff_analyzer.no"))
    }

    body = body + "\nRunning backend ordering validation...\n"
    hvis fil_finst("reports/backend_a.txt") og fil_finst("reports/backend_b.txt") {
        body = body + run_capture("NORSCODE_BACKEND_OUTPUT_A=reports/backend_a.txt NORSCODE_BACKEND_OUTPUT_B=reports/backend_b.txt " + nc_run(root, "tools/backend_ordering_validator.no"))
    } ellers {
        body = body + "Backend trace artifacts missing\n"
    }

    body = body + "\nRunning semantic diff analysis...\n"
    hvis fil_finst("reports/symbols_a.txt") og fil_finst("reports/symbols_b.txt") {
        body = body + run_capture("NORSCODE_SEMANTIC_A=reports/symbols_a.txt NORSCODE_SEMANTIC_B=reports/symbols_b.txt " + nc_run(root, "tools/semantic_diff_analyzer.no"))
    } ellers {
        body = body + "Semantic trace artifacts missing\n"
    }

    body = body + "\nCollecting bootstrap artifacts...\n"
    body = body + run_capture(nc_run(root, "tools/bootstrap_artifact_pipeline.no"))

    body = body + "\nUnified bootstrap verification completed\n"
    builtin.fil_skriv(report, body)
    linje("Unified bootstrap verification report written to: " + report)
    returner 0
}

// tools/build_linux_native_candidate_v3005.no — bygg Linux-kandidat utan promotering

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner builtin.trim(res[idx]) }
    returner ""
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(res[1]) }
    hvis felt(res, 2) != "" { skriv(res[2]) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = felt(kommando("pwd"), 1)
    la os = felt(kommando("uname -s"), 1)
    la arch = felt(kommando("uname -m"), 1)
    hvis os != "Linux" {
        linje("[STOP] v3005 Linux-kandidat må byggjast på Linux, ikkje " + os + ".")
        linje("[STOP] Ingen filer i dist/ eller bootstrap/stage0 vart endra.")
        returner 2
    }
    hvis ikkje (arch == "x86_64" eller arch == "amd64" eller arch == "aarch64" eller arch == "arm64") {
        linje("[STOP] Ustøtta Linux-arkitektur: " + arch)
        returner 2
    }

    linje("== v3005 Linux native candidate build ==")
    linje("root: " + root)
    linje("platform: " + os + " " + arch)
    linje("regel: ikkje skriv til dist/norscode_native")
    linje("regel: ikkje skriv til bootstrap/stage0")

    linje("[STOP] v3005 Linux-kandidatsporet brukte arkivert v3002-kandidatloype.")
    linje("[STOP] Bruk aktiv native-flyt: ./bin/nc verify-seed, ./bin/nc verify-omgang6b eller ./bin/nc selfhost-bootstrap-gate.")
    returner 2

    la candidate = root + "/build/v3002/norscode_native_v3002"
    hvis ikkje ok(kommando("test -x " + shell(candidate))) {
        linje("[FAIL] kandidat manglar etter bygg: " + candidate)
        returner 1
    }

    hvis ikkje run("cd " + shell(root) + " && NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " NORSCODE_NATIVE_GAP_BIN=" + shell(candidate) + " ./bin/nc run " + shell(root + "/tools/native_runtime_gap_gate_v3001.no")) { returner 1 }

    la sha = felt(kommando("shasum -a 256 " + shell(candidate) + " | awk '{print $1}'"), 1)
    la size = felt(kommando("wc -c < " + shell(candidate) + " | tr -d ' '"), 1)
    la stamp = felt(kommando("date -u '+%Y-%m-%dT%H:%M:%SZ'"), 1)
    la manifest = root + "/build/v3002/native_linux_candidate_v3005.manifest"
    la platform = os + "-" + arch
    la body = "version=v3005\nstatus=linux_candidate_ready_not_promoted\ncreated_utc=" + stamp + "\ncandidate=build/v3002/norscode_native_v3002\nsize_bytes=" + size + "\nsha256=" + sha + "\nplatform=" + platform + "\ngate=tools/native_runtime_gap_gate_v3001.no build/v3002/norscode_native_v3002\ngate_status=green\ndist_norscode_native=unchanged\nbootstrap_stage0=unchanged\nproduction_promoted=false\n"
    hvis ikkje ok(kommando("printf '%s' " + shell(body) + " > " + shell(manifest))) { returner 1 }

    linje("[OK] Linux-kandidat klar: " + candidate)
    linje("[OK] Manifest: " + manifest)
    linje("[OK] Ingen promotering utført.")
    returner 0
}

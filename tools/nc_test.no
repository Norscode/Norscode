// tools/nc_test.no — Norscode-native testløpar
//
// Shell-wrapperen set NORSCODE_ROOT, NC_NATIVE, TESTS_DIR og eventuell
// NC_TEST_FILE. Denne fila eig testval, skip-reglar, køyring og rapportering.

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon utdata(res: liste_tekst) -> tekst {
    la ut = felt(res, 1)
    hvis ut == "" { ut = felt(res, 2) }
    returner ut
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon executable(sti: tekst) -> bool {
    returner ok(kommando("test -x " + shell(sti)))
}

funksjon basename(sti: tekst) -> tekst {
    returner trim_tekst(utdata(kommando("basename " + shell(sti))))
}

funksjon absolutt_fil(root: tekst, fil: tekst) -> tekst {
    hvis builtin.starts_with(fil, "/") { returner fil }
    returner root + "/" + fil
}

funksjon test_namn(sti: tekst) -> tekst {
    returner trim_tekst(utdata(kommando("basename " + shell(sti) + " .no")))
}

funksjon lik(namn: tekst, verdiar: liste_tekst) -> bool {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis namn == verdiar[i] { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon ny_state() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["pass"] = "0"
    s["fail"] = "0"
    s["skip"] = "0"
    s["total"] = "0"
    returner s
}

funksjon hent_tal(s: ordbok_tekst, nøkkel: tekst) -> heiltall {
    returner builtin.heltall_fra_tekst(s[nøkkel])
}

funksjon auk(s: ordbok_tekst, nøkkel: tekst) -> heiltall {
    la verdi = hent_tal(s, nøkkel) + 1
    s[nøkkel] = tekst_fra_heltall(verdi)
    returner verdi
}

funksjon startar_med_ein(namn: tekst, verdiar: liste_tekst) -> bool {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis builtin.starts_with(namn, verdiar[i]) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon er_slow(namn: tekst) -> bool {
    hvis builtin.starts_with(namn, "test_chunk_") { returner sann }
    hvis namn == "test_file_io_large.no" { returner sann }
    hvis namn == "test_selfhost.no" { returner sann }
    returner usann
}

funksjon er_native_unsupported(namn: tekst) -> bool {
    hvis startar_med_ein(namn, [
        "test_reactive",
        "test_islands",
        "test_html_state",
        "test_audit",
        "test_logging",
        "test_metrics",
        "test_json_schema",
        "test_state",
        "test_snapshot"
    ]) { returner sann }

    hvis lik(namn, [
        "test_advanced_example.no",
        "test_ai.no",
        "test_api_advanced.no",
        "test_api_server.no",
        "test_api_simple_native.no",
        "test_async_http.no",
        "test_struct_example.no",
        "test_wasm.no",
        "test_chunk_2000.no",
        "test_chunk_end.no",
        "test_chunk_full.no",
        "test_chunk_tail.no",
        "test_cache.no",
        "test_http_helpers.no",
        "test_nc_main_both.no",
        "test_runtime_async_process_maturity.no",
        "test_selfhost_phase2_ffi_smoke.no",
        "test_selfhost_phase2_regression.no",
        "test_selfhost_phase2_smoke.no",
        "test_selfhost_phase2_stdlib_usecases.no",
        "test_stdlib_status_matrix.no",
        "test_frontend.no",
        "test_html.no",
        "test_html_components.no",
        "test_html_components_v2.no",
        "test_io_error.no",
        "test_native_ui.no",
        "test_native_ui_errors.no",
        "test_secrets.no",
        "test_httpserver_vm_dispatch.no",
        "test_httpserver_vm_health_log.no",
        "test_httpserver_vm_response_helpers.no",
        "test_web_api_versioning.no",
        "test_web_api_versioning_example.no",
        "test_web_auth.no",
        "test_csrf.no",
        "test_web_cookies.no",
        "test_web_openapi.no",
        "test_web_openapi_auth.no",
        "test_web_openapi_errors.no",
        "test_web_openapi_schema.no",
        "test_web_request_response.no",
        "test_web_path.no",
        "test_web_roles.no",
        "test_web_sanitize.no",
        "test_web_dependency_example.no",
        "test_web_example.no",
        "test_web_handle_request_fallback.no",
        "test_web_roles_example.no",
        "test_web_validation.no",
        "test_web_validation_example.no",
        "test_security.no",
        "test_stil.no",
        "test_selfhost.no"
    ]) { returner sann }
    returner usann
}

funksjon første_linje(t: tekst) -> tekst {
    la linjer = builtin.split(t, "\n")
    la i: heiltall = 0
    mens i < lengde(linjer) {
        la l: tekst = trim_tekst(linjer[i])
        hvis l != "" og ikkje builtin.starts_with(l, "[nc-vm]") og ikkje builtin.starts_with(l, "[norscode]") {
            returner l
        }
        i = i + 1
    }
    returner ""
}

funksjon køyr_med_timeout(cmd: tekst, timeout: tekst) -> liste_tekst {
    hvis ok(kommando("command -v timeout >/dev/null 2>&1")) {
        returner kommando("timeout " + timeout + " " + cmd)
    }
    hvis ok(kommando("command -v perl >/dev/null 2>&1")) {
        returner kommando("perl -e 'my $t = shift @ARGV; alarm $t; exec @ARGV or die \"exec failed: $!\\n\";' " + timeout + " " + cmd)
    }
    returner kommando(cmd)
}

funksjon køyr_test(state: ordbok_tekst, fil: tekst, root: tekst, native: tekst, hybrid: tekst, timeout: tekst, tmpdir: tekst, slow_mode: bool) -> heiltall {
    la namn = basename(fil)
    la test_fil = absolutt_fil(root, fil)
    hvis slow_mode og ikkje er_slow(namn) {
        returner 0
    }

    auk(state, "total")

    hvis ikkje slow_mode og er_slow(namn) {
        auk(state, "skip")
        returner 0
    }
    hvis er_native_unsupported(namn) {
        auk(state, "skip")
        returner 0
    }

    la res: liste_tekst = []
    hvis executable(hybrid) {
        kommando("mkdir -p " + shell(tmpdir))
        la ncb = tmpdir + "/" + test_namn(test_fil) + ".ncb.json"
        la compile_cmd = shell(hybrid) + " --from-no " + shell(root) + " " + shell(test_fil) + " " + shell(ncb) + " __main__"
        la comp = kommando(compile_cmd)
        hvis ok(comp) {
            la source_flag = ""
            hvis namn == "test_dependency_import.no" {
                source_flag = " NORSCODE_VM_SOURCE=1"
            }
            la run_cmd = "env NORSCODE_CMD=run NORSCODE_FILE=" + shell(root + "/selfhost/vm_executor.no") + " NORSCODE_NCB_FILE=" + shell(ncb) + " NORSCODE_ROOT=" + shell(root) + source_flag + " " + shell(native)
            res = køyr_med_timeout(run_cmd, timeout)
            kommando("rm -f " + shell(ncb))
        } ellers {
            res = comp
            kommando("rm -f " + shell(ncb))
        }
    } ellers {
        la run_cmd = "env NORSCODE_CMD=run NORSCODE_FILE=" + shell(test_fil) + " NORSCODE_ROOT=" + shell(root) + " " + shell(native)
        res = køyr_med_timeout(run_cmd, timeout)
    }

    hvis ok(res) {
        auk(state, "pass")
        hvis env("NC_VERBOSE") == "1" {
            linje("  OK " + test_namn(fil))
        } ellers {
            skriv(".")
        }
    } ellers {
        auk(state, "fail")
        linje("")
        linje("  FEIL " + test_namn(fil))
        linje("    " + første_linje(res[1] + "\n" + res[2]))
    }
    returner 0
}

funksjon testfiler(test_dir: tekst) -> liste_tekst {
    la frå_env = env("NC_TEST_FILES")
    hvis frå_env != "" {
        la rå_env = builtin.split(frå_env, "\n")
        la ut_env: liste_tekst = []
        la e: heiltall = 0
        mens e < lengde(rå_env) {
            la f_env = trim_tekst(rå_env[e])
            hvis f_env != "" { legg_til(ut_env, f_env) }
            e = e + 1
        }
        returner ut_env
    }
    la res = kommando("find " + shell(test_dir) + " -maxdepth 1 -type f -name 'test_*.no' | sort")
    hvis ikkje ok(res) { returner [] }
    la rå = builtin.split(utdata(res), "\n")
    la ut: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(rå) {
        la f = trim_tekst(rå[i])
        hvis f != "" { legg_til(ut, f) }
        i = i + 1
    }
    returner ut
}

funksjon til_tal_eller(t: tekst, fallback: heiltall) -> heiltall {
    hvis t == "" { returner fallback }
    prøv { returner builtin.heltall_fra_tekst(t) } fang (e) { returner fallback }
    returner fallback
}

funksjon bruk_shard() -> bool {
    la shard = til_tal_eller(env("NC_TEST_SHARD"), -1)
    la shards = til_tal_eller(env("NC_TEST_SHARDS"), 0)
    returner shard >= 0 og shards > 1
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(utdata(kommando("pwd"))) }
    la native = env("NC_NATIVE")
    hvis native == "" { native = root + "/dist/norscode_native" }
    hvis env("NC_NATIVE_OK") != "1" og ikkje executable(native) {
        linje("FEIL: Trenger dist/norscode_native. Køyr: bash tools/build_norscode_native.sh")
        returner 1
    }

    la hybrid = env("HYBRID_COMPILE")
    hvis hybrid == "" { hybrid = root + "/tools/compile_with_hybrid_bundle_v9400.sh" }
    la tests_dir = env("TESTS_DIR")
    hvis tests_dir == "" { tests_dir = root + "/tests" }
    la timeout = env("TEST_TIMEOUT")
    hvis timeout == "" { timeout = "30" }
    la tmpdir = env("NC_TEST_TMPDIR")
    hvis tmpdir == "" { tmpdir = root + "/build/nc-test-tmp" }
    la slow_mode = env("NC_SLOW_TESTS") == "1"
    la enkelt = env("NC_TEST_FILE")
    la state = ny_state()

    hvis enkelt != "" {
        linje("Testing: " + enkelt)
        køyr_test(state, enkelt, root, native, hybrid, timeout, tmpdir, slow_mode)
    } ellers {
        linje("Norscode Python-fri testløpar")
        hvis bruk_shard() {
            linje("Shard: " + env("NC_TEST_SHARD") + "/" + env("NC_TEST_SHARDS"))
        }
        linje("Kompilerer og køyrer tests/test_*.no via norscode_native...")
        linje("")
        la filer = testfiler(tests_dir)
        hvis lengde(filer) == 0 {
            linje("FEIL: Ingen testfiler funne i " + tests_dir)
            returner 1
        }
        la i: heiltall = 0
        la idx: heiltall = 0
        la shard = til_tal_eller(env("NC_TEST_SHARD"), -1)
        la shards = til_tal_eller(env("NC_TEST_SHARDS"), 0)
        mens i < lengde(filer) {
            hvis bruk_shard() {
                hvis (idx % shards) == shard {
                    køyr_test(state, filer[i], root, native, hybrid, timeout, tmpdir, slow_mode)
                }
                idx = idx + 1
            } ellers {
                køyr_test(state, filer[i], root, native, hybrid, timeout, tmpdir, slow_mode)
            }
            i = i + 1
        }
        linje("")
    }

    linje("")
    linje("--- Resultat ------------------------------")
    la pass_tal = hent_tal(state, "pass")
    la fail_tal = hent_tal(state, "fail")
    la skip_tal = hent_tal(state, "skip")
    la total_tal = hent_tal(state, "total")
    linje("  Bestått:  " + tekst_fra_heltall(pass_tal))
    linje("  Feilet:   " + tekst_fra_heltall(fail_tal))
    linje("  Hoppa:    " + tekst_fra_heltall(skip_tal) + "  (native-unsupported eller slow)")
    linje("  Totalt:   " + tekst_fra_heltall(total_tal))
    linje("")

    hvis fail_tal > 0 {
        linje("FEIL: Testane feilet (" + tekst_fra_heltall(fail_tal) + " av " + tekst_fra_heltall(pass_tal + fail_tal) + ")")
        returner 1
    }
    linje("OK: Alle testar bestått (" + tekst_fra_heltall(pass_tal) + "/" + tekst_fra_heltall(pass_tal + fail_tal) + ")")
    returner 0
}

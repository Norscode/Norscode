// tools/nc_test.no — Norscode-native testløpar
//
// Denne fila eig testval, skip-reglar, køyring og rapportering. Wrapperen gir
// berre miljøverdiane NORSCODE_ROOT, NC_NATIVE, TESTS_DIR og eventuell
// NC_TEST_FILE.

bruk std.liste som liste

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon tekst_ein() -> tekst {
    returner builtin.slice("x1", 1, 2)
}

funksjon tekst_null() -> tekst {
    returner builtin.slice("x0", 1, 2)
}

funksjon tekst_tretti() -> tekst {
    returner builtin.slice("x30", 1, 3)
}

funksjon tekst_sakte_timeout() -> tekst {
    returner builtin.slice("x600", 1, 4)
}

funksjon tekst_normal_timeout() -> tekst {
    returner builtin.slice("x180", 1, 4)
}

funksjon tekst_pure_timeout() -> tekst {
    la konfigurert = env("PURE_TEST_TIMEOUT")
    hvis konfigurert != "" { returner konfigurert }
    returner builtin.slice("x600", 1, 4)
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    hvis env("NC_TRACE_TEST_COMMANDS") == "1" { skriv("[EXEC] " + cmd + "\n") }
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner tekst(res[0]) == tekst_null()
}

funksjon rydd_runtime() -> heiltall {
    prøv { builtin.gc_collect() } fang (e) { }
    returner 0
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon utdata(res: liste_tekst) -> tekst {
    la ut = felt(res, 1)
    hvis ut == "" { ut = felt(res, 2) }
    returner ut
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon os_namn() -> tekst {
    la res = kommando("uname -s 2>/dev/null")
    hvis ok(res) { returner trim(res[1]) }
    returner ""
}

funksjon finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon stat_key(sti: tekst) -> tekst {
    hvis os_namn() == "Darwin" {
        la mac = kommando("stat -f '%m:%z' " + shell(sti) + " 2>/dev/null")
        hvis ok(mac) { returner trim(mac[1]) }
    } ellers {
        la linux = kommando("stat -c '%Y:%s' " + shell(sti) + " 2>/dev/null")
        hvis ok(linux) { returner trim(linux[1]) }
    }
    returner "missing"
}

funksjon source_tree_key(root: tekst) -> tekst {
    hvis os_namn() == "Darwin" {
        la mac = kommando("find " + shell(root + "/std") + " " + shell(root + "/selfhost") + " " + shell(root + "/tools") + " -type f | sort | while read -r FILE; do stat -f '%N:%m:%z' \"$FILE\"; done | shasum -a 256 | awk '{print $1}'")
        hvis ok(mac) { returner trim(mac[1]) }
    } ellers {
        la linux = kommando("find " + shell(root + "/std") + " " + shell(root + "/selfhost") + " " + shell(root + "/tools") + " -type f | sort | while read -r FILE; do stat -c '%n:%Y:%s' \"$FILE\"; done | sha256sum | awk '{print $1}'")
        hvis ok(linux) { returner trim(linux[1]) }
    }
    returner "uncached"
}

funksjon test_cache_key(fil: tekst, hybrid: tekst, native: tekst, source_key: tekst) -> tekst {
    returner stat_key(fil) + "|" + stat_key(hybrid) + "|" + stat_key(native) + "|" + source_key
}

funksjon executable(sti: tekst) -> bool {
    returner finst(sti)
}

funksjon basename(sti: tekst) -> tekst {
    la delar = builtin.split(sti, "/")
    hvis lengde(delar) == 0 { returner sti }
    returner delar[lengde(delar) - 1]
}

funksjon absolutt_fil(root: tekst, fil: tekst) -> tekst {
    hvis builtin.starts_with(fil, "/") { returner fil }
    returner root + "/" + fil
}

funksjon fjern_suffiks(verdi: tekst, suffiks: tekst) -> tekst {
    hvis suffiks != "" og builtin.ends_with(verdi, suffiks) {
        returner builtin.slice(verdi, 0, lengde(verdi) - lengde(suffiks))
    }
    returner verdi
}

funksjon dirname(sti: tekst) -> tekst {
    returner trim(kommando("dirname " + shell(sti))[1])
}

funksjon test_namn(sti: tekst) -> tekst {
    returner fjern_suffiks(basename(sti), ".no")
}

funksjon lik(namn: tekst, verdiar: liste_tekst) -> bool {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis namn == verdiar[i] { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon ny_state() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["pass"] = "0"
    s["fail"] = "0"
    s["skip"] = "0"
    s["total"] = "0"
    returner s
}

funksjon hent_tal(s: ordbok_tekst, nøkkel: tekst) -> heiltall {
    returner builtin.heltall_fra_tekst(s[nøkkel])
}

funksjon auk(s: ordbok_tekst, nøkkel: tekst) -> heiltall {
    la verdi = hent_tal(s, nøkkel) + 1
    s[nøkkel] = tekst_fra_heltall(verdi)
    returner verdi
}

funksjon startar_med_ein(namn: tekst, verdiar: liste_tekst) -> bool {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis builtin.starts_with(namn, verdiar[i]) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon er_tung_sjølvhost(namn: tekst) -> bool {
    hvis namn == "test_chunk_2000.no" { returner sann }
    hvis namn == "test_chunk_end.no" { returner sann }
    hvis namn == "test_chunk_full.no" { returner sann }
    hvis builtin.starts_with(namn, "test_chunk_full_part_") { returner sann }
    hvis namn == "test_chunk_tail.no" { returner sann }
    hvis builtin.starts_with(namn, "test_chunk_tail_part_") { returner sann }
    hvis namn == "test_selfhost.no" { returner sann }
    hvis builtin.starts_with(namn, "test_selfhost_part_") { returner sann }
    returner usann
}

funksjon er_slow(namn: tekst) -> bool {
    hvis er_tung_sjølvhost(namn) { returner sann }
    // returner er_tung_sjølvhost(namn)
    hvis namn == "test_chunk_2114.no" { returner sann }
    hvis namn == "test_api_advanced.no" { returner sann }
    hvis namn == "test_file_io_large.no" { returner sann }
    hvis namn == "test_linux_x86_64_aot_cli.no" { returner sann }
    returner usann
}

funksjon hybrid_compile_cmd(root: tekst, hybrid: tekst, test_fil: tekst, ncb: tekst) -> tekst {
    returner "NORSCODE_HYBRID_ROOT=" + shell(root) +
        " NORSCODE_HYBRID_SRC=" + shell(test_fil) +
        " NORSCODE_HYBRID_OUT=" + shell(ncb) +
        " NORSCODE_HYBRID_MODULE=__main__ NORSCODE_HYBRID_PROJECT_ROOT=" + shell(root) +
        " " + shell(root + "/bin/nc") + " run " + shell(hybrid)
}

funksjon er_native_unsupported(namn: tekst) -> bool {
    hvis ikkje builtin.starts_with(namn, "test_windows_") { returner usann }
    la uname_result = kommando("uname -s 2>/dev/null")
    la system = ""
    hvis lengde(uname_result) > 1 { system = trim(uname_result[1]) }
    hvis builtin.starts_with(system, "MINGW") eller builtin.starts_with(system, "MSYS") eller builtin.starts_with(system, "CYGWIN") eller builtin.starts_with(system, "Windows") {
        returner usann
    }
    returner sann
}

funksjon er_native_direkte(namn: tekst) -> bool {
    returner namn == "test_security.no" eller namn == "test_stil.no" eller namn == "test_cli_maturity.no" eller namn == "test_macho_arm64_aot_common_runtime.no" eller namn == "test_app.no"
}

funksjon er_pure_vm_test(fil: tekst, namn: tekst) -> bool {
    hvis namn == "test_vm_debugger_integration.no" { returner sann }
    hvis namn == "test_vm_jit_integration.no" eller namn == "test_vm_jit_float_integration.no" eller namn == "test_vm_jit_text_integration.no" eller namn == "test_vm_jit_denied.no" { returner sann }
    returner ok(kommando("grep -Eq 'builtin\\.vm_|bruk[[:space:]]+std\\.runtime_(profiler|debugger|type)' " + shell(fil)))
}

funksjon pure_vm_env(namn: tekst) -> tekst {
    hvis namn == "test_vm_profiler_integration.no" { returner "NORSCODE_VM_CAPABILITIES=disk.read " }
    hvis namn == "test_vm_host_object_isolation.no" { returner "NORSCODE_VM_CAPABILITIES=env.read,disk.read " }
    hvis namn == "test_vm_dynamic_loader.no" { returner "NORSCODE_VM_CAPABILITIES=disk.read NORSCODE_VM_DISK_ROOT=build NORSCODE_VM_TRUST_STORE=build/vm_trust.json " }
    hvis namn == "test_vm_plugin_capability_isolation.no" { returner "NORSCODE_VM_CAPABILITIES=disk.read NORSCODE_VM_DISK_ROOT=. NORSCODE_VM_TRUST_STORE=build/vm_trust.json " }
    hvis namn == "test_vm_process_scope.no" { returner "NORSCODE_VM_CAPABILITIES=process.exec NORSCODE_VM_PROCESS_SCOPE=/usr/bin/printf " }
    hvis namn == "test_vm_network_scope.no" { returner "NORSCODE_VM_CAPABILITIES=net.tcp NORSCODE_VM_NET_SCOPE=127.0.0.1 " }
    hvis namn == "test_vm_jit_integration.no" eller namn == "test_vm_jit_float_integration.no" eller namn == "test_vm_jit_text_integration.no" { returner "NORSCODE_VM_CAPABILITIES=jit.execute NORSCODE_VM_JIT_THRESHOLD=2 " }
    hvis namn == "test_vm_security_disk_scope.no" { returner "NORSCODE_VM_CAPABILITIES=disk.read NORSCODE_VM_DISK_ROOT=docs " }
    hvis namn == "test_vm_security_disk_absolute_scope.no" { returner "NORSCODE_VM_CAPABILITIES=env.read,disk.read NORSCODE_VM_DISK_ROOT=\"$PWD/docs\" " }
    returner ""
}

funksjon første_linje(t: tekst) -> tekst {
    la linjer = builtin.split(t, "\n")
    la i: heiltall = 0
    mens i < lengde(linjer) {
        la l: tekst = trim_tekst(linjer[i])
        hvis l != "" og ikkje builtin.starts_with(l, "[nc-vm]") og ikkje builtin.starts_with(l, "[norscode]") {
            returner l
        }
        i = i + 1
    }
    returner ""
}

funksjon res_tekst(res: liste_tekst) -> tekst {
    la out: tekst = ""
    hvis lengde(res) > 1 { out = out + res[1] }
    hvis lengde(res) > 2 { out = out + "\n" + res[2] }
    hvis out == "" og lengde(res) > 0 { out = "exit " + tekst(res[0]) }
    returner out
}

funksjon køyr_med_timeout(cmd: tekst, timeout: tekst) -> liste_tekst {
    hvis env("NC_TRACE_TEST_COMMANDS") == "1" { linje("[CMD] " + cmd) }
    hvis ok(kommando("command -v timeout >/dev/null 2>&1")) {
        returner kommando("timeout " + timeout + " " + cmd)
    }
    hvis ok(kommando("command -v perl >/dev/null 2>&1")) {
        returner kommando("perl -e 'my $t = shift @ARGV; alarm $t; exec @ARGV or die \"exec failed: $!\\n\";' " + timeout + " " + cmd)
    }
    returner kommando(cmd)
}

funksjon køyr_test(state: ordbok_tekst, fil: tekst, root: tekst, native: tekst, hybrid: tekst, timeout: tekst, tmpdir: tekst, cache_dir: tekst, source_key: tekst, slow_mode: bool) -> heiltall {
    la namn = basename(fil)
    hvis env("NC_TRACE_TESTS") == "1" { linje("[RUN] " + test_namn(fil)) }
    auk(state, "total")
    hvis env("NC_TEST_FILE") == "" {
        hvis slow_mode og ikkje er_slow(namn) {
            auk(state, "skip")
            returner 0
        }
        hvis ikkje slow_mode og er_slow(namn) {
            auk(state, "skip")
            returner 0
        }
    }
    hvis er_native_unsupported(namn) {
        auk(state, "skip")
        hvis env("NC_VERBOSE") == "1" {
            linje("  SKIP " + test_namn(fil) + " (native-unsupported)")
        }
        returner 0
    }

    la res: liste_tekst = []
    la runtime_env = "TMPDIR=/tmp NORSCODE_RUN_DIRECT_HOST=0 NORSCODE_HOST_NCB_FILE= NORSCODE_NCB_FILE= NORSCODE_VM_SOURCE=0 NORSCODE_VM_CAPABILITIES=env.read,process.exec,thread.spawn,net.tcp,net.dns,disk.read,disk.write,jit.execute NORSCODE_VM_DISK_ROOT='" + root + ",.,/tmp,/private/tmp' "
    hvis er_native_direkte(namn) {
        la run_cmd = "env " + runtime_env + "NORSCODE_CMD=run NORSCODE_FILE=" + shell(fil) + " NORSCODE_ROOT=" + shell(root) + " " + shell(native)
        res = køyr_med_timeout(run_cmd, timeout)
    } ellers hvis er_pure_vm_test(fil, namn) {
        la clean_vm_env = "NORSCODE_VM_CAPABILITIES= NORSCODE_VM_DISK_ROOT=. NORSCODE_VM_NET_SCOPE= NORSCODE_VM_PROCESS_SCOPE= "
        la run_cmd = "env " + clean_vm_env + pure_vm_env(namn) + "NORSCODE_NATIVE_BIN=" + shell(native) + " NORSCODE_ROOT=" + shell(root) + " " + shell(root + "/bin/nc") + " run-pure " + shell(fil)
        res = køyr_med_timeout(run_cmd, tekst_pure_timeout())
    } ellers hvis builtin.ends_with(hybrid, ".no") {
        la use_cache = env("NC_TEST_CACHE") != "0"
        la ncb = tmpdir + "/" + test_namn(fil) + ".ncb.json"
        la cache_ncb = cache_dir + "/" + test_namn(fil) + ".ncb.json"
        la cache_meta = cache_dir + "/" + test_namn(fil) + ".key"
        la key = test_cache_key(fil, hybrid, native, source_key)
        hvis use_cache og finst(cache_ncb) og finst(cache_meta) og trim(fil_les(cache_meta)) == key {
            ncb = cache_ncb
        } ellers {
            kommando("mkdir -p " + shell(tmpdir))
            hvis use_cache {
                kommando("mkdir -p " + shell(cache_dir))
                ncb = cache_ncb + ".tmp"
            }
            la compile_cmd = "env " + runtime_env + "NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_NATIVE_BIN=" + shell(native) + " NORSCODE_HYBRID_ROOT=" + shell(root) + " NORSCODE_HYBRID_SRC=" + shell(fil) + " NORSCODE_HYBRID_OUT=" + shell(ncb) + " NORSCODE_HYBRID_MODULE=__main__ NORSCODE_HYBRID_PROJECT_ROOT=" + shell(root) + " NORSCODE_CMD=run NORSCODE_FILE=" + shell(hybrid) + " " + shell(native)
            la comp = kommando(compile_cmd)
            hvis ok(comp) og use_cache {
                kommando("mv " + shell(ncb) + " " + shell(cache_ncb))
                fil_skriv(cache_meta + ".tmp", key)
                kommando("mv " + shell(cache_meta + ".tmp") + " " + shell(cache_meta))
                ncb = cache_ncb
            }
        }
        hvis finst(ncb) {
            la run_cmd = "env " + runtime_env + "NORSCODE_CMD=run NORSCODE_FILE=" + shell(root + "/selfhost/tooling/ncb_host_run_entry.no") + " NORSCODE_NCB_FILE=" + shell(ncb) + " NORSCODE_ROOT=" + shell(root) + " " + shell(native)
            res = køyr_med_timeout(run_cmd, timeout)
            hvis ikkje use_cache { kommando("rm -f " + shell(ncb)) }
        } ellers {
            res = ["1", "", "test compile failed"]
            kommando("rm -f " + shell(ncb))
        }
    } ellers hvis executable(hybrid) {
        kommando("mkdir -p " + shell(tmpdir))
        la ncb = tmpdir + "/" + test_namn(fil) + ".ncb.json"
        la vm_ncb = tmpdir + "/vm_executor_" + test_namn(fil) + ".ncb.json"
        la compile_cmd = "NORSCODE_NATIVE_BIN= " + hybrid_compile_cmd(root, hybrid, fil, ncb)
        la comp = kommando(compile_cmd)
        hvis ok(comp) {
            la run_cmd = "env " + runtime_env + "NORSCODE_CMD=run NORSCODE_FILE=" + shell(root + "/selfhost/tooling/ncb_host_run_entry.no") + " NORSCODE_NCB_FILE=" + shell(ncb) + " NORSCODE_ROOT=" + shell(root) + " " + shell(native)
            res = køyr_med_timeout(run_cmd, timeout)
            hvis ikkje ok(res) {
                run_cmd = "env NORSCODE_CMD=run NORSCODE_FILE=" + shell(root + "/selfhost/vm_executor.no") + " NORSCODE_NCB_FILE=" + shell(ncb) + " NORSCODE_ROOT=" + shell(root) + source_flag + " " + shell(native)
                res = køyr_med_timeout(run_cmd, timeout)
            }
            kommando("rm -f " + shell(ncb) + " " + shell(vm_ncb))
        } ellers {
            res = comp
            kommando("rm -f " + shell(ncb) + " " + shell(vm_ncb))
        }
    } ellers {
        la run_cmd = "env " + runtime_env + "NORSCODE_CMD=run NORSCODE_FILE=" + shell(fil) + " NORSCODE_ROOT=" + shell(root) + " " + shell(native)
        res = køyr_med_timeout(run_cmd, timeout)
    }

    hvis ok(res) {
        auk(state, "pass")
        hvis env("NC_VERBOSE") == tekst_ein() {
            linje("  OK " + test_namn(fil))
        } ellers {
            skriv(".")
        }
    } ellers {
        auk(state, "fail")
        linje("")
        linje("  FEIL " + test_namn(fil))
        hvis env("NC_VERBOSE") == tekst_ein() {
            linje(res_tekst(res))
        } ellers {
            linje("    " + første_linje(res_tekst(res)))
        }
    }
    returner 0
}

funksjon testfiler(test_dir: tekst) -> liste_tekst {
    la frå_env = env("NC_TEST_FILES")
    hvis frå_env != "" {
        la rå_env = builtin.split(frå_env, "\n")
        la ut_env: liste_tekst = []
        la e: heiltall = 0
        mens e < lengde(rå_env) {
            la f_env = trim_tekst(rå_env[e])
            hvis f_env != "" { legg_til(ut_env, f_env) }
            e = e + 1
        }
        returner ut_env
    }
    la res = kommando("find " + shell(test_dir) + " -maxdepth 1 -type f -name 'test_*.no'")
    hvis ikkje ok(res) { returner [] }
    la rå = builtin.split(utdata(res), "\n")
    la ut: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(rå) {
        la f = trim_tekst(rå[i])
        hvis f != "" { legg_til(ut, f) }
        i = i + 1
    }
    liste.sorter_tekst(ut)
    returner ut
}

funksjon til_tal_eller(t: tekst, fallback: heiltall) -> heiltall {
    hvis t == "" { returner fallback }
    prøv { returner builtin.heltall_fra_tekst(t) } fang (e) { returner fallback }
    returner fallback
}

funksjon bruk_shard() -> bool {
    la shard = til_tal_eller(env("NC_TEST_SHARD"), -1)
    la shards = til_tal_eller(env("NC_TEST_SHARDS"), 0)
    returner shard >= 0 og shards > 1
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(utdata(kommando("pwd"))) }
    la native = env("NC_NATIVE")
    hvis native == "" { native = root + "/dist/norscode_native" }
    hvis ikkje executable(native) {
        linje("FEIL: Trenger dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed")
        returner 1
    }

    la hybrid = env("HYBRID_COMPILE")
    hvis hybrid == "" { hybrid = root + "/tools/compile_with_hybrid_bundle_v9400.no" }
    la tests_dir = env("TESTS_DIR")
    hvis tests_dir == "" { tests_dir = root + "/tests" }
    la slow_mode = env("NC_SLOW_TESTS") == tekst_ein()
    la timeout = ""
    // Ei eksplisitt langsamgrense må vinne over den generelle grensa. Utan
    // dette blir tunge selfhost-testar feilaktig SIGALRM-avbrotne når begge
    // variablane er sette av den overordna sjølvstendighetsporten.
    hvis slow_mode { timeout = env("SLOW_TEST_TIMEOUT") }
    hvis timeout == "" { timeout = env("TEST_TIMEOUT") }
    hvis timeout == "" {
        hvis slow_mode { timeout = tekst_sakte_timeout() }
        ellers { timeout = tekst_normal_timeout() }
    }
    la tmpdir = env("NC_TEST_TMPDIR")
    hvis tmpdir == "" {
        la run_id = env("NC_TEST_RUN_ID")
        hvis run_id == "" { run_id = tekst_fra_heltall(builtin.tid_ms()) }
        tmpdir = root + "/build/nc-test-tmp-" + run_id
    }
    la cache_dir = env("NC_TEST_CACHE_DIR")
    hvis cache_dir == "" { cache_dir = root + "/build/nc-test-cache" }
    la source_key = source_tree_key(root)
    la enkelt = env("NC_TEST_FILE")
    la state = ny_state()

    hvis enkelt != "" {
        linje("Testing: " + enkelt)
            køyr_test(state, enkelt, root, native, hybrid, timeout, tmpdir, cache_dir, source_key, slow_mode)
    } ellers {
        linje("Norscode Python-fri testløpar")
        hvis bruk_shard() {
            linje("Shard: " + env("NC_TEST_SHARD") + "/" + env("NC_TEST_SHARDS"))
        }
        linje("Kompilerer og køyrer tests/test_*.no via norscode_native...")
        linje("")
        la filer = testfiler(tests_dir)
        hvis lengde(filer) == 0 {
            linje("FEIL: Ingen testfiler funne i " + tests_dir)
            returner 1
        }
        la i: heiltall = 0
        la idx: heiltall = 0
        la pure_idx: heiltall = 0
        la shard = til_tal_eller(env("NC_TEST_SHARD"), -1)
        la shards = til_tal_eller(env("NC_TEST_SHARDS"), 0)
        mens i < lengde(filer) {
            hvis bruk_shard() {
                la pure = er_pure_vm_test(filer[i], basename(filer[i]))
                hvis pure og (pure_idx % shards) == shard {
                    køyr_test(state, filer[i], root, native, hybrid, timeout, tmpdir, cache_dir, source_key, slow_mode)
                }
                hvis pure {
                    pure_idx = pure_idx + 1
                } ellers hvis (idx % shards) == shard {
                    køyr_test(state, filer[i], root, native, hybrid, timeout, tmpdir, cache_dir, source_key, slow_mode)
                }
                idx = idx + 1
            } ellers {
                køyr_test(state, filer[i], root, native, hybrid, timeout, tmpdir, cache_dir, source_key, slow_mode)
            }
            i = i + 1
        }
        linje("")
    }

    linje("")
    linje("--- Resultat ------------------------------")
    la pass_tal = hent_tal(state, "pass")
    la fail_tal = hent_tal(state, "fail")
    la skip_tal = hent_tal(state, "skip")
    la total_tal = hent_tal(state, "total")
    linje("  Bestått:  " + tekst_fra_heltall(pass_tal))
    linje("  Feilet:   " + tekst_fra_heltall(fail_tal))
    hvis skip_tal > 0 {
        linje("  Hoppa:    " + tekst_fra_heltall(skip_tal) + "  (lane-filter/native-unsupported)")
    } ellers {
        linje("  Hoppa:    " + tekst_fra_heltall(skip_tal))
    }
    linje("  Totalt:   " + tekst_fra_heltall(total_tal))
    linje("")

    hvis fail_tal > 0 {
        linje("FEIL: Testane feilet (" + tekst_fra_heltall(fail_tal) + " av " + tekst_fra_heltall(pass_tal + fail_tal) + ")")
        returner 1
    }
    linje("OK: Alle testar bestått (" + tekst_fra_heltall(pass_tal) + "/" + tekst_fra_heltall(pass_tal + fail_tal) + ")")
    returner 0
}

// tools/install.no — lokal Norscode-installasjon når runtime finst i checkout

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run(cmd: tekst, feil: tekst) -> bool {
    la res = kommando(cmd)
    hvis ok(res) { returner sann }
    hvis feil != "" { linje(feil) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner usann
}

funksjon skriv_wrapper(path: tekst, runtime_prefix: tekst) -> bool {
    la body = "#!/usr/bin/env sh\nexec " + shell(runtime_prefix + "/current/bin/nc") + " \"$@\"\n"
    prøv {
        builtin.fil_skriv(path, body)
    } fang (e) {
        linje("Klarte ikkje skrive wrapper: " + path)
        returner usann
    }
    returner run("chmod +x " + shell(path), "Klarte ikkje gjere wrapper køyrbar: " + path)
}

funksjon installer_wrappers(bin_dir: tekst, runtime_prefix: tekst) -> bool {
    hvis ikkje run("mkdir -p " + shell(bin_dir), "Klarte ikkje lage bin-mappe") { returner usann }
    hvis ikkje skriv_wrapper(bin_dir + "/norscode", runtime_prefix) { returner usann }
    hvis ikkje skriv_wrapper(bin_dir + "/nc", runtime_prefix) { returner usann }
    returner sann
}

funksjon platform() -> tekst {
    la os = trim(felt(kommando("uname -s"), 1))
    la arch = trim(felt(kommando("uname -m"), 1))
    hvis os == "Darwin" og arch == "arm64" { returner "macos-arm64" }
    hvis os == "Darwin" og arch == "x86_64" { returner "macos-x86_64" }
    hvis os == "Linux" og arch == "x86_64" { returner "linux-x86_64" }
    hvis os == "Linux" og arch == "aarch64" { returner "linux-arm64" }
    returner os + "-" + arch
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(felt(kommando("pwd"), 1)) }
    la prefix = env("NORSCODE_INSTALL_PREFIX")
    hvis prefix == "" { prefix = env("HOME") + "/.local" }
    la runtime_prefix = prefix + "/share/norscode"
    la bin_dir = prefix + "/bin"
    la legacy_prefix = env("HOME") + "/.norscode"

    linje("Plattform oppdaget: " + platform())
    hvis ikkje fil_finst(root + "/dist/norscode_native") {
        linje("Feil: lokal installasjon krev " + root + "/dist/norscode_native")
        returner 1
    }

    linje("Pre-bygd norscode_native funnet lokalt.")
    hvis ikkje run("mkdir -p " + shell(runtime_prefix + "/releases"), "Klarte ikkje lage runtime-mappe") { returner 1 }
    hvis ikkje run("ln -sfn " + shell(root) + " " + shell(runtime_prefix + "/current"), "Klarte ikkje oppdatere current-lenke") { returner 1 }
    hvis ikkje installer_wrappers(bin_dir, runtime_prefix) { returner 1 }
    hvis ikkje installer_wrappers(legacy_prefix + "/bin", runtime_prefix) { returner 1 }

    hvis env("NORSCODE_INSTALL_SKIP_FILE_ICONS") != "sann" {
        hvis trim(felt(kommando("uname -s"), 1)) == "Darwin" {
            hvis fil_finst(root + "/bin/nc") {
                kommando(shell(root + "/bin/nc") + " install-macos-file-icons || true")
            }
        }
    }

    linje("Installert: " + runtime_prefix + "/current")
    linje("Installert: " + bin_dir + "/norscode")
    linje("Legg til PATH: export PATH=\"" + bin_dir + ":$PATH\"")
    returner 0
}

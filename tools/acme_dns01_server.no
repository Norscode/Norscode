// Autoritativ Norscode DNS-01-server for ACME-integrasjonsporten.
// TXT-verdien blir levert atomisk gjennom ei capability-avgrensa fil.

bruk std.dns som dns

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon start() -> heiltall {
    la value_file = env("NORSCODE_ACME_DNS_VALUE_FILE")
    hvis value_file == "" { value_file = "/tmp/norscode-acme-dns-value" }
    la ready_file = env("NORSCODE_ACME_DNS_READY_FILE")
    hvis ready_file == "" { ready_file = "/tmp/norscode-acme-dns-ready" }
    la stop_file = env("NORSCODE_ACME_DNS_STOP_FILE")
    hvis stop_file == "" { stop_file = "/tmp/norscode-acme-dns-stop" }
    la ack_file = env("NORSCODE_ACME_DNS_ACK_FILE")
    hvis ack_file == "" { ack_file = "/tmp/norscode-acme-dns-ack" }
    la port: heiltall = 8053
    la port_text = env("NORSCODE_ACME_DNS_PORT")
    hvis port_text != "" { port = heiltall_fra_tekst(port_text) }
    hvis port <= 0 eller port > 65535 { skriv("[FAIL] ACME DNS-port er ugyldig\n") returner 1 }

    prøv { builtin.fil_slett(ready_file) } fang (e) { }
    prøv { builtin.fil_slett(stop_file) } fang (e) { }
    prøv { builtin.fil_slett(ack_file) } fang (e) { }

    la sone = dns.ny_sone("norscode.test")
    hvis ikkje dns.legg_txt(sone, "_acme-challenge", "pending") { returner 1 }
    la daemon = dns.daemon_ny(sone, "10.30.50.3", port)
    hvis ikkje dns.daemon_start(daemon) {
        skriv("[FAIL] ACME DNS-server start: " + daemon["siste_feil"] + "\n")
        returner 1
    }
    builtin.fil_skriv(ready_file, daemon["port"] + "\n")

    la aktiv_verdi = "pending"
    mens ikkje builtin.fil_finnes(stop_file) {
        hvis builtin.fil_finnes(value_file) {
            la ny_verdi = builtin.trim(builtin.fil_les(value_file))
            hvis ny_verdi != "" og ny_verdi != aktiv_verdi {
                la ny_sone = dns.ny_sone("norscode.test")
                hvis ikkje dns.legg_txt(ny_sone, "_acme-challenge", ny_verdi) {
                    dns.daemon_stop(daemon)
                    skriv("[FAIL] ACME DNS TXT-verdi er ugyldig\n")
                    returner 1
                }
                daemon["sone"] = ny_sone
                aktiv_verdi = ny_verdi
                builtin.fil_skriv(ack_file, aktiv_verdi + "\n")
            }
        }
        la pumped = dns.daemon_pump(daemon)
        hvis pumped["status"] == "feil" {
            dns.daemon_stop(daemon)
            skriv("[FAIL] ACME DNS-server: " + pumped["error"] + "\n")
            returner 1
        }
        prøv { builtin.vent.sov(1) } fang (e) { }
    }
    hvis ikkje dns.daemon_stop(daemon) { returner 1 }
    prøv { builtin.fil_slett(ready_file) } fang (e) { }
    prøv { builtin.fil_slett(ack_file) } fang (e) { }
    skriv("[OK] Norscode autoritativ ACME DNS-01-server stoppa reint: mottatte=" +
          daemon["mottatte"] + " svar=" + daemon["svar"] + "\n")
    returner 0
}

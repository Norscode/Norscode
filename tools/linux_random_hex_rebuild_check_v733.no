// tools/linux_random_hex_rebuild_check_v733.no — trygg Linux-sjekk utan stage0-skriving

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner builtin.trim(res[idx]) }
    returner ""
}

funksjon inneheld(t: tekst, needle: tekst) -> bool {
    returner builtin.index_of(t, needle) >= 0
}

funksjon køyr(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(res[1]) }
    hvis felt(res, 2) != "" { skriv(res[2]) }
    returner ok(res)
}

funksjon vis_strings_treff(sti: tekst, needle: tekst, label: tekst, maks: heiltall) -> bool {
    la res = kommando("strings " + sti)
    hvis ikkje ok(res) {
        hvis felt(res, 2) != "" { skriv(res[2]) }
        returner falsk
    }
    la linjer = builtin.split(res[1], "\n")
    la treff = 0
    la i = 0
    mens i < lengde(linjer) og treff < maks {
        hvis inneheld(linjer[i], needle) {
            skriv(tekst(i + 1) + ":" + linjer[i] + "\n")
            treff = treff + 1
        }
        i = i + 1
    }
    hvis treff == 0 { linje(needle + " ikkje funne i " + label) }
    returner sann
}

funksjon start() -> heiltall {
    la os = felt(kommando("uname -s"), 1)
    la arch = felt(kommando("uname -m"), 1)

    hvis os != "Linux" {
        linje("FEIL: Dette scriptet skal køyrast på Linux, ikkje " + os + ".")
        returner 1
    }

    hvis arch == "x86_64" {
        linje("OK: Linux x86_64/amd64")
    } ellers hvis arch == "amd64" {
        linje("OK: Linux x86_64/amd64")
    } ellers {
        linje("FEIL: Krever Linux x86_64/amd64 for denne løypen. Fant " + arch)
        returner 1
    }

    linje("")
    linje("1. Check VM og serve_runner")
    hvis ikkje køyr("./bin/nc check selfhost/vm.no") { returner 1 }
    hvis ikkje køyr("./bin/nc check selfhost/serve_runner.no") { returner 1 }

    linje("")
    linje("2. Check v701 og v731 app")
    køyr("./bin/nc check prosjekter/NorscodeWeb/app_random_session_module_demo_v701.no")
    hvis ikkje køyr("./bin/nc check prosjekter/NorscodeWeb/app_linux_stage0_random_hex_plan_v731.no") { returner 1 }

    linje("")
    linje("3. Verifiser eksisterende native")
    hvis ikkje køyr("./bin/nc run prosjekter/NorscodeWeb/app_linux_stage0_random_hex_plan_v731.no") { returner 1 }

    linje("")
    linje("4. Sjekk om random_hex finnes i dist/stage0")
    vis_strings_treff("dist/norscode_native", "random_hex", "dist", 20)
    vis_strings_treff("bootstrap/stage0/norscode-linux-x86_64", "random_hex", "linux stage0", 20)

    linje("")
    linje("Neste: bare rebuild hvis du har egen Linux stage0-løype klar. Ikke overskriv stage0 automatisk.")
    returner 0
}

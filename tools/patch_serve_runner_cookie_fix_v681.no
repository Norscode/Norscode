// tools/patch_serve_runner_cookie_fix_v681.no — arkivert historisk hotfixloype

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon start() -> heiltall {
    linje("patch_serve_runner_cookie_fix_v681: denne gamle patch-loypa er arkivert.")
    linje("Bruk vanleg endring i selfhost/serve_runner.no og verifiser med ./bin/nc feature-check.")
    returner 2
}

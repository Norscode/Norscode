// Full RFC 8555-utstedelse mot lokal Pebble test-CA.
// Pebble skal koeyre med PEBBLE_VA_ALWAYS_VALID=1; denne gaten verifiserer
// klientprotokollen, ikkje offentleg domeneeigarskap.

bruk std.tls_acme som acme
bruk std.http som http

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon jwk() -> tekst {
    returner "{\"e\":\"AQAB\",\"kty\":\"RSA\",\"n\":\"qpiJW-sz9wzfkrKfSudDFKaDCVEbTong6yUgaxVicFAaLyrbSN6gckA2PP-3Ct42WDt4nyTbn8IRjyXU2EazVbhx0h3mveEo0y_jgdIlFq9I-jcHI-O8dEhJEjGeFDzvGxhW00JatQwCaDpjGzqZLUiqHPvCfWavA3ettLrHChSMiePz5qLq3AYjRMEQb2-RRqg-f6k1cM6eG3eiXUePB_L7y3BuntSBG7ytOEjvKgzLcoKNrR8upn2Nf3BAoOqbcT8iYqGETKXDwdrGrCRiGM3y52J5oVYbdRzsfNKsjBR3MQ-1eza57_rLKtHSH1iMP-FVWS7leKShPeXitHm2Hw\"}"
}

funksjon csr() -> tekst {
    returner "MIICiDCCAXACAQAwGDEWMBQGA1UEAwwNbm9yc2NvZGUudGVzdDCCASIwDQYJKoZIhvcNAQEBBQADggEPADCCAQoCggEBAM5Y5Yk6CsPMrheCm1v92C9dA14FmIhxSC9l8cezz5l5FVuEACaJLDgbZ-yEcM8CRSFlXtcPTZQVqeeAetvbu4TPnUBxbiQ39SCC9-ilc91vVskVH8o2CEkAQa2JqxU5KNpeTzFDTsYEYiuHwf7GYAu0kfGeS77M5Ta0FWNEjd5ox6IKnhDOkJC7ya0UuZow1TWBws8hW_1tH6f4QsPSWUJOhOkeGYefekFxoMwbVxA06hTWV2KLfQXg4FPnozgdnhDn67vv0aj__uTeE3Dld82ewsz2Cj30azy9FOd6k1lr6_SDrrfS-qrLuf61gxWFu4t0LyMz2TsLO7X-ogwSTrcCAwEAAaArMCkGCSqGSIb3DQEJDjEcMBowGAYDVR0RBBEwD4INbm9yc2NvZGUudGVzdDANBgkqhkiG9w0BAQsFAAOCAQEAUN6cwK_nHhQQU2867jEFlWgf7Yb1fdd8c-U83JpDNcULYvcIY8Cj3BiW9hQNqBrAkJC7oNYlJcFAs-jGJ2DuqmWxKbSosQpDtgsNjVvrVjDt0eEbSJBo0dZgcOr3DG2qbIlEeipbf1b5eNWSDkPMtCBW60KEW_TqOsgyyCmQNAwrOHC4fsyvxyt7NYFPdW2e4zMzhVm3cTBtOhGSKJRKv0XdJLx3G6Zw336hkN30Qe4OD9HhkZjlYftWc9im_pehx8U8RS-6wiy30nih1QRlfsn1f2vA5Dssr7nhyDaDjzvGtvhGoZz3HDXGtMVBk6Vx4YV0dVGQEqwY0ZM9N5P_2w"
}

funksjon tekstfelt(m: ordbok_tekst, key: tekst) -> tekst {
    la verdi = tekst(m[key])
    hvis verdi == "ingenting" eller verdi == "null" { returner "" }
    returner verdi
}

funksjon nonce_eller_hent(respons: ordbok_tekst, nonce_url: tekst,
                          ca_file: tekst) -> tekst {
    la n = tekstfelt(respons, "replay_nonce")
    hvis n != "" { returner n }
    la henta = acme.nonce_fetch_ca(nonce_url, 10000, ca_file)
    hvis henta["status"] == "klar" { returner tekstfelt(henta, "nonce") }
    returner ""
}

funksjon post_kid(url: tekst, payload: tekst, nonce: tekst, kid: tekst,
                  key: tekst, ca_file: tekst) -> ordbok_tekst {
    la signed = acme.jws_request_med_kid_nokkel(nonce, url, "RS256", kid, payload, key)
    hvis signed["status"] != "klar" { returner signed }
    returner acme.jws_post_ca(signed, url, 10000, ca_file)
}

funksjon challenge_server_post(base_url: tekst, path: tekst, body: tekst) -> boolsk {
    hvis base_url == "" { returner usann }
    prøv {
        la response = http.request_full("POST", base_url + path,
            {"content-type": "application/json"}, {}, body, 10000)
        la status = http.response_status(response)
        returner status >= 200 og status < 300
    } fang (e) { returner usann }
    returner usann
}

funksjon start() -> heiltall {
    la directory_url = env("NORSCODE_ACME_DIRECTORY")
    hvis directory_url == "" { directory_url = "https://localhost:14000/dir" }
    la ca_file = env("NORSCODE_ACME_CA_FILE")
    hvis ca_file == "" { ca_file = "/tmp/pebble.minica.pem" }
    la key_file = env("NORSCODE_ACME_ACCOUNT_KEY")
    hvis key_file == "" { key_file = "tests/fixtures/tls/ocsp-server.key" }
    la challenge_server = env("NORSCODE_ACME_CHALLENGE_SERVER")
    la dns_value_file = env("NORSCODE_ACME_DNS_VALUE_FILE")
    la dns_ack_file = env("NORSCODE_ACME_DNS_ACK_FILE")
    la dns01_mode = challenge_server != "" eller dns_value_file != ""
    hvis ikkje builtin.fil_finnes(ca_file) eller ikkje builtin.fil_finnes(key_file) {
        skriv("[FAIL] Pebble-gate manglar CA eller kontonøkkel\n")
        returner 1
    }
    la key = builtin.fil_les(key_file)
    hvis acme.jwk_thumbprint(jwk()) != "KkxM40q8_6ENPId2C4Adotx6jic4ki1owq6oSkVSics" {
        skriv("[FAIL] Pebble-gate JWK thumbprint\n")
        returner 1
    }

    la directory = acme.directory_fetch_ca(directory_url, 10000, ca_file)
    hvis directory["status"] != "klar" { skriv("[FAIL] Pebble directory\n") returner 1 }
    la nonce_url = tekstfelt(directory, "newNonce")
    la nonce_res = acme.nonce_fetch_ca(nonce_url, 10000, ca_file)
    la nonce = tekstfelt(nonce_res, "nonce")
    hvis nonce == "" { skriv("[FAIL] Pebble nonce\n") returner 1 }

    la account_signed = acme.jws_request_med_nokkel(nonce, tekstfelt(directory, "newAccount"),
        "RS256", jwk(), "{\"termsOfServiceAgreed\":true}", key)
    la account = acme.jws_post_ca(account_signed, tekstfelt(directory, "newAccount"), 10000, ca_file)
    la kid = tekstfelt(account, "location")
    hvis account["status"] != "ok" eller kid == "" {
        skriv("[FAIL] Pebble account status=" + tekstfelt(account, "http_status") + " body=" + tekstfelt(account, "body") + "\n")
        returner 1
    }

    nonce = nonce_eller_hent(account, nonce_url, ca_file)
    la order = post_kid(tekstfelt(directory, "newOrder"),
        "{\"identifiers\":[{\"type\":\"dns\",\"value\":\"norscode.test\"}]}",
        nonce, kid, key, ca_file)
    hvis order["status"] != "ok" eller tekstfelt(order, "location") == "" {
        skriv("[FAIL] Pebble order status=" + tekstfelt(order, "http_status") + " body=" + tekstfelt(order, "body") + "\n")
        returner 1
    }
    la order_url = tekstfelt(order, "location")
    la order_data = builtin.json_parse(tekstfelt(order, "body"))
    la auth_urls = builtin.json_parse(tekst(order_data["authorizations"]))
    hvis lengde(auth_urls) < 1 { skriv("[FAIL] Pebble order manglar authorization\n") returner 1 }
    la auth_url = tekst(auth_urls[0])
    la finalize_url = tekst(order_data["finalize"])

    nonce = nonce_eller_hent(order, nonce_url, ca_file)
    la auth = post_kid(auth_url, "", nonce, kid, key, ca_file)
    hvis auth["status"] != "ok" {
        skriv("[FAIL] Pebble authorization fetch url=" + auth_url +
              " status=" + tekstfelt(auth, "status") +
              " http=" + tekstfelt(auth, "http_status") +
              " error=" + tekstfelt(auth, "error") +
              " body=" + tekstfelt(auth, "body") + "\n")
        returner 1
    }
    la auth_data = builtin.json_parse(tekstfelt(auth, "body"))
    la challenge = auth
    hvis tekst(auth_data["status"]) != "valid" {
        la challenges = builtin.json_parse(tekst(auth_data["challenges"]))
        hvis lengde(challenges) < 1 { skriv("[FAIL] Pebble authorization manglar challenge\n") returner 1 }
        la challenge_data = builtin.json_parse(tekst(challenges[0]))
        hvis dns01_mode {
            la challenge_found = usann
            la challenge_idx: heiltall = 0
            mens challenge_idx < lengde(challenges) og ikkje challenge_found {
                la candidate = builtin.json_parse(tekst(challenges[challenge_idx]))
                hvis tekst(candidate["type"]) == "dns-01" {
                    challenge_data = candidate
                    challenge_found = sann
                }
                challenge_idx = challenge_idx + 1
            }
            hvis ikkje challenge_found {
                skriv("[FAIL] Pebble authorization manglar dns-01 challenge\n")
                returner 1
            }
            la token = tekst(challenge_data["token"])
            la dns_value = acme.dns01_verdi(token, jwk())
            la dns_body = "{\"host\":\"_acme-challenge.norscode.test.\",\"value\":\"" + dns_value + "\"}"
            la dns_ready = usann
            hvis challenge_server != "" {
                dns_ready = challenge_server_post(challenge_server, "/set-txt", dns_body)
            } ellers hvis dns_value_file != "" og dns_value != "" {
                prøv {
                    builtin.fil_skriv(dns_value_file, dns_value + "\n")
                    hvis dns_ack_file == "" { dns_ready = sann }
                    ellers {
                        la ack_start = builtin.tid_ms()
                        mens ikkje dns_ready og builtin.tid_ms() - ack_start < 10000 {
                            hvis builtin.fil_finnes(dns_ack_file) og
                               builtin.trim(builtin.fil_les(dns_ack_file)) == dns_value {
                                dns_ready = sann
                            }
                            hvis ikkje dns_ready { prøv { builtin.vent.sov(1) } fang (vent_feil) { } }
                        }
                    }
                } fang (e) { }
            }
            hvis dns_value == "" eller ikkje dns_ready {
                skriv("[FAIL] Pebble dns-01 TXT-oppsett\n")
                returner 1
            }
        }
        la challenge_url = tekst(challenge_data["url"])
        nonce = nonce_eller_hent(auth, nonce_url, ca_file)
        challenge = post_kid(challenge_url, "{}", nonce, kid, key, ca_file)
        hvis challenge["status"] != "ok" {
            skriv("[FAIL] Pebble challenge start url=" + challenge_url +
                  " status=" + tekstfelt(challenge, "status") +
                  " http=" + tekstfelt(challenge, "http_status") +
                  " error=" + tekstfelt(challenge, "error") +
                  " body=" + tekstfelt(challenge, "body") + "\n")
            returner 1
        }
    }

    la ready = usann
    la runde: heiltall = 0
    mens runde < 20 og ikkje ready {
        prøv { builtin.vent.sov(50) } fang (e) { }
        nonce = nonce_eller_hent(challenge, nonce_url, ca_file)
        order = post_kid(order_url, "", nonce, kid, key, ca_file)
        order_data = builtin.json_parse(tekstfelt(order, "body"))
        hvis tekst(order_data["status"]) == "invalid" {
            nonce = nonce_eller_hent(order, nonce_url, ca_file)
            la invalid_auth = post_kid(auth_url, "", nonce, kid, key, ca_file)
            skriv("[FAIL] Pebble authorization invalid: " + tekstfelt(invalid_auth, "body") + "\n")
            returner 1
        }
        hvis tekst(order_data["status"]) == "ready" eller tekst(order_data["status"]) == "valid" {
            ready = sann
        }
        challenge = order
        runde = runde + 1
    }
    hvis ikkje ready { skriv("[FAIL] Pebble order blei ikkje ready\n") returner 1 }

    hvis tekst(order_data["status"]) != "valid" {
        nonce = nonce_eller_hent(order, nonce_url, ca_file)
        la finalize = post_kid(finalize_url, "{\"csr\":\"" + csr() + "\"}", nonce, kid, key, ca_file)
        hvis finalize["status"] != "ok" {
            skriv("[FAIL] Pebble finalize status=" + tekstfelt(finalize, "http_status") + " body=" + tekstfelt(finalize, "body") + "\n")
            returner 1
        }
        order = finalize
    }

    la certificate_url = ""
    runde = 0
    mens runde < 20 og certificate_url == "" {
        prøv { builtin.vent.sov(50) } fang (e) { }
        nonce = nonce_eller_hent(order, nonce_url, ca_file)
        order = post_kid(order_url, "", nonce, kid, key, ca_file)
        order_data = builtin.json_parse(tekstfelt(order, "body"))
        hvis tekst(order_data["status"]) == "valid" { certificate_url = tekst(order_data["certificate"]) }
        runde = runde + 1
    }
    hvis certificate_url == "" { skriv("[FAIL] Pebble sertifikat-URL manglar\n") returner 1 }

    nonce = nonce_eller_hent(order, nonce_url, ca_file)
    la cert = post_kid(certificate_url, "", nonce, kid, key, ca_file)
    hvis cert["status"] != "ok" eller
       ikkje builtin.contains(tekstfelt(cert, "body"), "-----BEGIN CERTIFICATE-----") {
        skriv("[FAIL] Pebble sertifikatnedlasting status=" + tekstfelt(cert, "http_status") + "\n")
        returner 1
    }
    hvis dns01_mode {
        la cleared = usann
        hvis challenge_server != "" {
            cleared = challenge_server_post(challenge_server, "/clear-txt",
                "{\"host\":\"_acme-challenge.norscode.test.\"}")
        } ellers hvis dns_value_file != "" {
            prøv { builtin.fil_slett(dns_value_file) cleared = sann } fang (e) { }
            hvis dns_ack_file != "" { prøv { builtin.fil_slett(dns_ack_file) } fang (e) { } }
        }
        hvis ikkje cleared { skriv("[FAIL] Pebble dns-01 TXT-opprydding\n") returner 1 }
    }
    hvis dns01_mode {
        skriv("[OK] Full ACME Pebble DNS-01-utstedelse: account/order/TXT-validation/finalize/certificate\n")
    } ellers {
        skriv("[OK] Full ACME Pebble-utstedelse: account/order/challenge/finalize/certificate\n")
    }
    returner 0
}

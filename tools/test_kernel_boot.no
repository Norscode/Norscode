// tools/test_kernel_boot.no — QEMU-boottest for Norscode OS-kernel

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon finn_qemu() -> tekst {
    hvis ok(kommando("command -v qemu-system-x86_64 >/dev/null 2>&1")) { returner "qemu-system-x86_64" }
    hvis ok(kommando("command -v qemu-system-i386 >/dev/null 2>&1")) { returner "qemu-system-i386" }
    returner ""
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }

    la qemu = finn_qemu()
    hvis qemu == "" {
        linje("HOPP: ingen QEMU funnen")
        returner 0
    }
    linje("Brukar: " + qemu)

    la kernel = root + "/build/norscode_kernel.elf"
    la build = kommando("NC_OUTPUT=" + shell(kernel) + " " + shell(root + "/bin/nc") + " run " + shell(root + "/selfhost/native_execution/kernel_builder.no") + " >/dev/null")
    hvis ikkje ok(build) {
        hvis res_felt(build, 1) != "" { skriv(res_felt(build, 1)) }
        hvis res_felt(build, 2) != "" { skriv(res_felt(build, 2)) }
        returner 1
    }

    la qcmd = "(printf 'cont\\n'; sleep 3; printf 'xp/32xb 0xb8000\\n'; sleep 0.3; printf 'quit\\n') | " +
        qemu + " -kernel " + shell(kernel) + " -display none -S -monitor stdio 2>&1"
    la vga = res_felt(kommando(qcmd), 1)
    hvis builtin.index_of(vga, "0x4e 0x0e 0x6f 0x0e 0x72 0x0e") >= 0 {
        linje("✓ Kernel v1: 'Nor...' i VGA (Multiboot1 OK)")
    } ellers {
        linje("✗ FEIL: kernel v1 VGA-innhald ikkje som forventa")
        returner 1
    }
    linje("✓ Norscode OS bootar korrekt")
    returner 0
}

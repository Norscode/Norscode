// tools/selfhost_drift_guard.no — samlet driftsvakt i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run_step(root: tekst, label: tekst, cmd: tekst) -> bool {
    la res = kommando("cd " + shell(root) + " && " + cmd)
    hvis ok(res) {
        hvis res[1] != "" { skriv(res[1]) }
        returner sann
    }
    hvis res[1] != "" { skriv(res[1]) }
    hvis res[2] != "" { skriv(res[2]) }
    linje("Driftsvakt feila i " + label)
    returner usann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(kommando("pwd")[1]) }
    hvis ikkje run_step(root, "fase0", "./bin/nc phase0-verify") { returner 1 }
    hvis ikkje run_step(root, "aktiv flate", "./bin/nc active-surface") { returner 1 }
    hvis ikkje run_step(root, "vedlikehald", "./bin/nc selfhost-maintenance-verify") { returner 1 }
    linje("Driftsvakt: OK")
    returner 0
}

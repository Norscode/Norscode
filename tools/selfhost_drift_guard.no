// tools/selfhost_drift_guard.no — samlet driftsvakt i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run_step(root: tekst, label: tekst, script: tekst) -> bool {
    la res = kommando("bash " + shell(root + "/" + script))
    hvis ok(res) {
        hvis res[1] != "" { skriv(res[1]) }
        returner sann
    }
    hvis res[1] != "" { skriv(res[1]) }
    hvis res[2] != "" { skriv(res[2]) }
    linje("Driftsvakt feila i " + label)
    returner usann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(kommando("pwd")[1]) }
    hvis ikkje run_step(root, "fase0", "tools/selfhost_phase0_verify.sh") { returner 1 }
    hvis ikkje run_step(root, "aktiv flate", "tools/no_c_python_active_surface.sh") { returner 1 }
    hvis ikkje run_step(root, "vedlikehald", "tools/selfhost_maintenance_verify.sh") { returner 1 }
    linje("Driftsvakt: OK")
    returner 0
}

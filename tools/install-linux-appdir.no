// tools/install-linux-appdir.no — installer Linux AppDir-artefakt

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon abs_sti(root: tekst, sti: tekst) -> tekst {
    hvis builtin.starts_with(sti, "/") { returner sti }
    returner root + "/" + sti
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon sha256_for(sti: tekst) -> tekst {
    hvis ok(kommando("command -v shasum >/dev/null 2>&1")) {
        returner trim(res_felt(kommando("shasum -a 256 " + shell(sti) + " | awk '{print $1}'"), 1))
    }
    returner trim(res_felt(kommando("sha256sum " + shell(sti) + " | awk '{print $1}'"), 1))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la archive_path = env("NORSCODE_LINUX_APPDIR_ARCHIVE")
    la prefix = env("NORSCODE_LINUX_APPDIR_PREFIX")
    hvis prefix == "" { prefix = env("HOME") + "/.local/opt/norscode-app" }

    hvis archive_path == "" {
        linje("Feil: manglar Linux AppDir-tarball")
        returner 1
    }
    archive_path = abs_sti(root, archive_path)
    prefix = abs_sti(root, prefix)

    hvis ikkje fil_finst(archive_path) {
        linje("Feil: manglar Linux AppDir-tarball: " + archive_path)
        returner 1
    }

    hvis fil_finst(archive_path + ".sha256") {
        la expected = trim(res_felt(kommando("cat " + shell(archive_path + ".sha256")), 1))
        la actual = sha256_for(archive_path)
        hvis expected != actual {
            linje("Feil: SHA256-avvik for " + archive_path)
            returner 1
        }
    }

    la version_name = trim(res_felt(kommando("basename " + shell(archive_path) + " .tar.gz"), 1))
    la install_root = prefix + "/versions"
    la target_dir = install_root + "/" + version_name
    la current_link = prefix + "/current"
    la bin_dir = prefix + "/bin"
    la stage_dir = trim(res_felt(kommando("mktemp -d"), 1))
    hvis stage_dir == "" { returner 1 }

    hvis ikkje run("mkdir -p " + shell(install_root) + " " + shell(bin_dir)) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("rm -rf " + shell(target_dir) + " && mkdir -p " + shell(target_dir)) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("tar -xzf " + shell(archive_path) + " -C " + shell(stage_dir)) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }

    la appdir_name = trim(res_felt(kommando("find " + shell(stage_dir) + " -maxdepth 1 -type d -name '*.AppDir' | head -1"), 1))
    hvis appdir_name == "" {
        kommando("rm -rf " + shell(stage_dir))
        linje("Feil: fann ikkje AppDir i tarballen")
        returner 1
    }

    hvis ikkje run("cp -R " + shell(appdir_name) + "/. " + shell(target_dir) + "/") {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("ln -sfn " + shell(target_dir) + " " + shell(current_link)) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    hvis ikkje run("ln -sfn " + shell(current_link + "/AppRun") + " " + shell(bin_dir + "/norscode-app")) {
        kommando("rm -rf " + shell(stage_dir))
        returner 1
    }
    kommando("rm -rf " + shell(stage_dir))

    linje("Installert Linux AppDir: " + target_dir)
    linje("Aktiv lenke: " + current_link)
    linje("Launcher: " + bin_dir + "/norscode-app")
    returner 0
}

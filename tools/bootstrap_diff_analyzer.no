// tools/bootstrap_diff_analyzer.no — bootstrap-diff rapport i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon første_ord(linje_inn: tekst) -> tekst {
    la s = trim(linje_inn)
    la out = ""
    la i = 0
    mens i < lengde(s) {
        la ch = s[i]
        hvis ch == " " eller ch == "\t" eller ch == "\n" eller ch == "\r" {
            returner out
        }
        out = out + ch
        i = i + 1
    }
    returner out
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv {
        builtin.fil_les(sti)
        returner sann
    } fang (e) {
        returner usann
    }
}

funksjon første_forskjellar(sti_a: tekst, sti_b: tekst, maks: heiltall) -> tekst {
    la a = builtin.fil_les(sti_a)
    la b = builtin.fil_les(sti_b)
    la min_lengd = lengde(a)
    hvis lengde(b) < min_lengd { min_lengd = lengde(b) }
    la out = ""
    la funne = 0
    la i = 0
    mens i < min_lengd og funne < maks {
        hvis a[i] != b[i] {
            out = out + tekst_fra_heltall(i + 1) + " " + tekst_fra_heltall(builtin.char_code(a[i])) + " " + tekst_fra_heltall(builtin.char_code(b[i])) + "\n"
            funne = funne + 1
        }
        i = i + 1
    }
    hvis funne < maks og lengde(a) != lengde(b) {
        out = out + "length " + tekst_fra_heltall(lengde(a)) + " " + tekst_fra_heltall(lengde(b)) + "\n"
    }
    hvis out == "" { returner "No byte differences found in readable text view\n" }
    returner out
}

funksjon sha256(sti: tekst, preset: tekst) -> tekst {
    hvis preset != "" { returner første_ord(preset) }
    returner første_ord(res_felt(kommando("shasum -a 256 " + shell(sti)), 1))
}

funksjon start() -> heiltall {
    la build_a = env("NORSCODE_BUILD_A")
    la build_b = env("NORSCODE_BUILD_B")
    hvis build_a == "" eller build_b == "" {
        linje("Bruk: NORSCODE_BUILD_A=<build_a> NORSCODE_BUILD_B=<build_b> ./bin/nc run tools/bootstrap_diff_analyzer.no")
        returner 1
    }
    hvis ikkje fil_finst(build_a) {
        linje("Missing build artifact: " + build_a)
        returner 1
    }
    hvis ikkje fil_finst(build_b) {
        linje("Missing build artifact: " + build_b)
        returner 1
    }

    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la report = root + "/reports/bootstrap_diff_report.txt"
    la hash_a = sha256(build_a, env("NORSCODE_BUILD_SHA_A"))
    la hash_b = sha256(build_b, env("NORSCODE_BUILD_SHA_B"))
    la body = "=== Norscode Bootstrap Diff Analyzer ===\n\nBuild A: " + build_a + "\nBuild B: " + build_b + "\n\nHash A: " + hash_a + "\nHash B: " + hash_b + "\n\n"
    hvis hash_a == hash_b {
        body = body + "Bootstrap outputs are deterministic\n"
    } ellers {
        body = body + "Bootstrap mismatch detected\n\nFirst binary differences:\n" +
            første_forskjellar(build_a, build_b, 50)
    }
    builtin.fil_skriv(report, body)
    linje("Bootstrap diff report written to: " + report)
    returner 0
}

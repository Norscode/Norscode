// tools/native_runtime_gap_gate_v3001.no — native runtime-gap gate

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon executable(sti: tekst) -> bool {
    returner ok(kommando("test -x " + shell(sti)))
}

funksjon abs_sti(root: tekst, sti: tekst) -> tekst {
    hvis sti == "" { returner root + "/dist/norscode_native" }
    hvis builtin.starts_with(sti, "/") { returner sti }
    returner root + "/" + sti
}

funksjon run_append(cmd: tekst, out: tekst) -> bool {
    la res = kommando("(" + cmd + ") >> " + shell(out) + " 2>&1")
    returner ok(res)
}

funksjon run_probe(root: tekst, bin_path: tekst, probe: tekst, out: tekst) -> bool {
    la cmd = "cd " + shell(root) +
        " && env NORSCODE_CMD=run NORSCODE_FILE=" + shell(probe) +
        " NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) +
        " " + shell(bin_path)
    returner run_append(cmd, out)
}

funksjon inneheld(out: tekst, needle: tekst) -> bool {
    returner ok(kommando("grep -q " + shell(needle) + " " + shell(out)))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la bin_path = abs_sti(root, env("NORSCODE_NATIVE_GAP_BIN"))
    la probe = root + "/tests/native_runtime_gap_probe_v3001.no"
    la upload_probe = root + "/tests/opplasting_mappe_gap_probe.no"
    la out = "/tmp/norscode_native_gap_gate_v3001.out"

    hvis ikkje executable(bin_path) {
        linje("[FAIL] native binary manglar eller er ikkje køyrbar: " + bin_path)
        returner 1
    }

    linje("== native runtime gap gate v3001 ==")
    linje("binary: " + bin_path)

    kommando("rm -f " + shell(out))
    run_probe(root, bin_path, probe, out)
    run_probe(root, bin_path, upload_probe, out)

    hvis inneheld(out, "FEIL") {
        linje("[FAIL] runtime-gap står att i aktiv binary")
        kommando("rm -f " + shell(out))
        returner 1
    }
    hvis ikkje inneheld(out, "random_hex OK") {
        linje("[FAIL] random_hex vart ikkje verifisert")
        kommando("rm -f " + shell(out))
        returner 1
    }
    hvis ikkje inneheld(out, "mappe_opprett OK") {
        linje("[FAIL] mappe_opprett vart ikkje verifisert")
        kommando("rm -f " + shell(out))
        returner 1
    }
    hvis ikkje inneheld(out, "opplasting_mappe OK") {
        linje("[FAIL] opplasting_mappe vart ikkje verifisert")
        kommando("rm -f " + shell(out))
        returner 1
    }

    linje("[OK] runtime-gap gate er grønn for " + bin_path)
    kommando("rm -f " + shell(out))
    returner 0
}

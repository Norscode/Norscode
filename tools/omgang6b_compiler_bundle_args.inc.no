// tools/omgang6b_compiler_bundle_args.inc.no — Norscode-kopi av Omgang 6b-modullista

funksjon omgang6b_bundle_args() -> liste_tekst {
    la args: liste_tekst = []
    legg_til(args, "selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no")
    legg_til(args, "selfhost.parser=selfhost/parser.no")
    legg_til(args, "selfhost.compiler.semantic=selfhost/compiler/semantic.no")
    legg_til(args, "selfhost.compiler.ir_to_bytecode=selfhost/compiler/ir_to_bytecode.no")
    legg_til(args, "selfhost.json=selfhost/json.no")
    legg_til(args, "selfhost.kompiler=selfhost/kompiler.no")
    legg_til(args, "selfhost.bundler=selfhost/bundler.no")
    legg_til(args, "selfhost.elf_compile_driver=selfhost/elf_compile_driver.no")
    returner args
}

funksjon start() -> heiltall {
    la args = omgang6b_bundle_args()
    la i = 0
    mens i < lengde(args) {
        skriv(args[i] + "\n")
        i = i + 1
    }
    returner 0
}

// tools/semantic_diff_analyzer.no — semantisk diff-rapport i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon les_fil(sti: tekst, label: tekst) -> tekst {
    prøv {
        returner builtin.fil_les(sti)
    } fang (e) {
        linje("Missing semantic dump: " + sti)
        returner "__NORSCODE_MISSING_" + label + "__"
    }
}

funksjon stabil_hash(data: tekst) -> tekst {
    la h = 216613626
    la i = 0
    mens i < lengde(data) {
        h = ((h * 16777619) + builtin.char_code(data[i])) % 2147483647
        i = i + 1
    }
    returner tekst_fra_heltall(h)
}

funksjon linje_diff(a: tekst, b: tekst) -> tekst {
    la a_linjer = builtin.split(a, "\n")
    la b_linjer = builtin.split(b, "\n")
    la max = lengde(a_linjer)
    hvis lengde(b_linjer) > max { max = lengde(b_linjer) }

    la out = ""
    la i = 0
    mens i < max {
        la av = ""
        la bv = ""
        hvis i < lengde(a_linjer) { av = a_linjer[i] }
        hvis i < lengde(b_linjer) { bv = b_linjer[i] }
        hvis av != bv {
            out = out + "@@ line " + tekst_fra_heltall(i + 1) + " @@\n"
            out = out + "- " + av + "\n"
            out = out + "+ " + bv + "\n"
        }
        i = i + 1
    }
    hvis out == "" { returner "(no textual diff)\n" }
    returner out
}

funksjon start() -> heiltall {
    la file_a = env("NORSCODE_SEMANTIC_A")
    la file_b = env("NORSCODE_SEMANTIC_B")
    hvis file_a == "" eller file_b == "" {
        linje("Bruk: NORSCODE_SEMANTIC_A=<symbols_a> NORSCODE_SEMANTIC_B=<symbols_b> ./bin/nc run tools/semantic_diff_analyzer.no")
        returner 1
    }
    hvis ikkje fil_finst(file_a) {
        linje("Missing semantic dump: " + file_a)
        returner 1
    }
    hvis ikkje fil_finst(file_b) {
        linje("Missing semantic dump: " + file_b)
        returner 1
    }

    la data_a = les_fil(file_a, "A")
    hvis builtin.starts_with(data_a, "__NORSCODE_MISSING_") { returner 1 }
    la data_b = les_fil(file_b, "B")
    hvis builtin.starts_with(data_b, "__NORSCODE_MISSING_") { returner 1 }

    la report = "reports/semantic_diff_report.txt"
    la hash_a = stabil_hash(data_a)
    la hash_b = stabil_hash(data_b)
    la body = "=== Norscode Semantic Diff Analyzer ===\n\n" +
        "Semantic Dump A: " + file_a + "\n" +
        "Semantic Dump B: " + file_b + "\n\n" +
        "Stable Hash A: " + hash_a + "\n" +
        "Stable Hash B: " + hash_b + "\n\n"

    hvis data_a == data_b {
        body = body + "Semantic ordering is deterministic\n"
    } ellers {
        body = body + "Semantic ordering mismatch detected\n\nNorscode line diff:\n" + linje_diff(data_a, data_b)
    }

    builtin.fil_skriv(report, body)
    linje("Semantic diff report written to: " + report)
    returner 0
}

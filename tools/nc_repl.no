// tools/nc_repl.no — evaluer éi REPL-linje utan Python

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon dq(s: tekst) -> tekst {
    returner "\"" + s + "\""
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon exec_manglar(res: liste_tekst) -> bool {
    returner builtin.index_of(felt(res, 2), "exec_prosess") >= 0
}

funksjon run_file(native: tekst, tmpfile: tekst) -> liste_tekst {
    returner kommando("sh -c " + shell("NORSCODE_CMD=run NORSCODE_FILE=" + dq(tmpfile) + " " + dq(native) + " 2>&1"))
}

funksjon skriv_fil(path: tekst, body: tekst) -> bool {
    prøv {
        builtin.fil_skriv(path, body)
        returner sann
    } fang (e) {
        returner usann
    }
}

funksjon slett_fil(path: tekst) -> heiltall {
    prøv { builtin.fil_slett(path) } fang (e) { }
    kommando("sh -c " + shell("rm -f " + dq(path)))
    returner 0
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la line = env("NORSCODE_REPL_LINE")
    hvis line == "" { returner 0 }
    la native = root + "/dist/norscode_native"
    la exec_probe = kommando("true")
    hvis ikkje builtin.fil_finnes(native) {
        skriv("denne Norscode-runtime manglar exec_prosess\n")
        skriv("Feil: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n")
        returner 1
    }

    la tmpfile = "/tmp/nc_repl_expr.no"
    la tmpfile2 = "/tmp/nc_repl_print.no"
    slett_fil(tmpfile)
    slett_fil(tmpfile2)
    la body = "funksjon start() {\n    la _res = " + line + "\n    skriv(tekst_fra_heltall(_res))\n}\n"
    hvis ikkje skriv_fil(tmpfile, body) { returner 1 }
    la res = run_file(native, tmpfile)
    slett_fil(tmpfile)
    hvis ok(res) {
        skriv("=> " + felt(res, 1) + "\n")
        returner 0
    }

    slett_fil(tmpfile2)
    la body2 = "funksjon start() {\n    skriv(" + line + ")\n}\n"
    hvis ikkje skriv_fil(tmpfile2, body2) { returner 1 }
    la res2 = run_file(native, tmpfile2)
    slett_fil(tmpfile2)
    hvis ok(res2) {
        skriv("=> " + felt(res2, 1) + "\n")
        returner 0
    }
    skriv("Feil: " + felt(res2, 1) + felt(res2, 2) + "\n")
    returner 1
}

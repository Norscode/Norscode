// tools/nc_repl.no — evaluer éi REPL-linje utan Python

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon run_file(native: tekst, tmpfile: tekst) -> liste_tekst {
    returner kommando("NORSCODE_CMD=run NORSCODE_FILE=" + shell(tmpfile) + " " + shell(native) + " 2>&1")
}

funksjon skriv_fil(path: tekst, body: tekst) -> bool {
    returner ok(kommando("printf '%s' " + shell(body) + " > " + shell(path)))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = "." }
    la line = env("NORSCODE_REPL_LINE")
    hvis line == "" { returner 0 }
    la native = root + "/dist/norscode_native"
    hvis ikkje ok(kommando("test -x " + shell(native))) {
        skriv("Feil: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n")
        returner 1
    }

    la tmpfile = felt(kommando("mktemp /tmp/nc_repl_XXXXXX"), 1)
    la body = "funksjon start() {\n    la _res = " + line + "\n    skriv(tekst_fra_heltall(_res))\n}\n"
    hvis ikkje skriv_fil(tmpfile, body) { returner 1 }
    la res = run_file(native, tmpfile)
    kommando("rm -f " + shell(tmpfile))
    hvis ok(res) {
        skriv("=> " + felt(res, 1) + "\n")
        returner 0
    }

    la tmpfile2 = felt(kommando("mktemp /tmp/nc_repl_XXXXXX"), 1)
    la body2 = "funksjon start() {\n    skriv(" + line + ")\n}\n"
    hvis ikkje skriv_fil(tmpfile2, body2) { returner 1 }
    la res2 = run_file(native, tmpfile2)
    kommando("rm -f " + shell(tmpfile2))
    hvis ok(res2) {
        skriv("=> " + felt(res2, 1) + "\n")
        returner 0
    }
    skriv("Feil: " + felt(res2, 1) + felt(res2, 2) + "\n")
    returner 1
}

// tools/build_hybrid_compiler_bundle_v9400.no
//
// Bygg ein hybrid compiler-bundle med Norscode som eig transformasjonen.

bruk std.path som path

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon les_json(sti: tekst) {
    returner builtin.json_parse_raw(builtin.fil_les(sti))
}

funksjon klon(v) {
    returner builtin.json_parse_raw(builtin.json_stringify(v))
}

funksjon base_namn(namn: tekst) -> tekst {
    hvis builtin.starts_with(namn, "__main__.") {
        returner builtin.slice(namn, 9, lengde(namn))
    }
    returner namn
}

funksjon patch_kall(code, prefiks: tekst) {
    la i = 0
    mens i < lengde(code) {
        la ins = code[i]
        hvis lengde(ins) > 1 og ins[0] == "CALL" og builtin.type(ins[1]) == "tekst" og builtin.starts_with(ins[1], "__main__.") {
            ins[1] = prefiks + "." + builtin.slice(ins[1], 9, lengde(ins[1]))
            code[i] = ins
        }
        i = i + 1
    }
    returner code
}

funksjon legg_modul(out_fns, prefiks: tekst, fil: tekst) -> bool {
    hvis ikkje fil_finst(fil) {
        linje("Manglar modul-NCB: " + fil)
        returner usann
    }
    la mod = les_json(fil)
    hvis ikkje har_nokkel(mod, "functions") {
        linje("Manglar functions i " + fil)
        returner usann
    }
    la fns = mod["functions"]
    la keys = builtin.nøkler(fns)
    la i = 0
    mens i < lengde(keys) {
        la key = keys[i]
        la base = base_namn(key)
        la full = prefiks + "." + base
        la fn = klon(fns[key])
        fn["name"] = base
        fn["module"] = prefiks
        hvis har_nokkel(fn, "code") {
            fn["code"] = patch_kall(fn["code"], prefiks)
        }
        out_fns[full] = fn
        i = i + 1
    }
    returner sann
}

funksjon legg_kompiler_fil(fns) -> heiltall {
    fns["fresh.kompiler.kompiler_fil"] = {
        "name": "kompiler_fil",
        "module": "fresh.kompiler",
        "params": ["kjelde_tekst", "modul_namn"],
        "is_async": usann,
        "code": [
            ["LOAD_NAME", "kjelde_tekst"], ["CALL", "fresh.lexer.lex", 1], ["STORE_NAME", "tokens"],
            ["LOAD_NAME", "tokens"], ["CALL", "fresh.parser.parse_program", 1], ["STORE_NAME", "ast"],
            ["LOAD_NAME", "ast"], ["CALL", "fresh.semantic.analyser_program", 1], ["STORE_NAME", "tabell"],
            ["LOAD_NAME", "ast"], ["LOAD_NAME", "modul_namn"], ["CALL", "fresh.ir.kompiler_til_ncb_json", 2], ["STORE_NAME", "ncb_json"],
            ["LOAD_NAME", "ncb_json"], ["RETURN"]
        ]
    }
    fns["fresh.entry.start"] = {
        "name": "start",
        "module": "fresh.entry",
        "params": [],
        "is_async": usann,
        "code": [["PUSH_CONST", 0], ["RETURN"]]
    }
    returner 0
}

funksjon bygg(root: tekst, out_path: tekst, ir_path: tekst) -> heiltall {
    hvis out_path == "" { out_path = root + "/build/v9400/hybrid_compiler_bundle_v9400.ncb.json" }
    hvis ir_path == "" { ir_path = root + "/build/v3002/ir_to_bytecode_source_check4.ncb.json" }
    la out = {
        "functions": {},
        "entry": "fresh.entry.start"
    }
    la fns = out["functions"]
    hvis ikkje legg_modul(fns, "fresh.lexer", root + "/bootstrap/precompiled/lexer_m1.ncb.json") { returner 1 }
    hvis ikkje legg_modul(fns, "fresh.parser", root + "/bootstrap/precompiled/parser.ncb.json") { returner 1 }
    hvis ikkje legg_modul(fns, "fresh.semantic", root + "/bootstrap/precompiled/semantic.ncb.json") { returner 1 }
    hvis ikkje legg_modul(fns, "fresh.ir", ir_path) { returner 1 }
    legg_kompiler_fil(fns)
    out["functions"] = fns
    hvis ikkje ok(kommando("mkdir -p " + shell(path.dirname(out_path)))) { returner 1 }
    builtin.fil_skriv(out_path, builtin.json_stringify(out))
    linje(out_path)
    returner 0
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(felt(kommando("pwd"), 1)) }
    la out = env("NORSCODE_HYBRID_BUNDLE_OUT")
    la ir = env("NORSCODE_HYBRID_IR_NCB")
    returner bygg(root, out, ir)
}

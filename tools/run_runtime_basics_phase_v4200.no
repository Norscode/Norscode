// tools/run_runtime_basics_phase_v4200.no — runtime basics phase probes

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon has(log: tekst, needle: tekst) -> bool {
    returner ok(kommando("grep -q " + shell(needle) + " " + shell(log)))
}

funksjon krev(log: tekst, needle: tekst) -> bool {
    hvis has(log, needle) { returner sann }
    linje("[FAIL] manglar " + needle)
    returner usann
}

funksjon run_host_probe(root: tekst, bin_path: tekst, label: tekst) -> bool {
    la probe = root + "/tests/runtime_basics_probe_v4200.no"
    la log = "/tmp/norscode_" + label + "_runtime_basics_v4200.log"
    la cmd = "env NORSCODE_CMD=run NORSCODE_FILE=" + shell(probe) +
        " NORSCODE_ENABLE_EXEC_PROSESS=1 " + shell(bin_path) + " > " + shell(log) + " 2>&1"
    la res = kommando(cmd)
    la cat = kommando("cat " + shell(log))
    hvis res_felt(cat, 1) != "" { skriv(res_felt(cat, 1)) }
    hvis ikkje ok(res) { returner usann }

    hvis ikkje krev(log, "trim OK:") { returner usann }
    hvis ikkje krev(log, "split OK len=2") { returner usann }
    hvis ikkje krev(log, "starts_with OK: sann") { returner usann }
    hvis ikkje krev(log, "ends_with OK: sann") { returner usann }
    hvis ikkje krev(log, "tekst_fra_heltall OK: 42") { returner usann }
    hvis ikkje krev(log, "json_parse_raw OK") { returner usann }
    hvis ikkje krev(log, "nøkler OK len=2") { returner usann }
    hvis ikkje krev(log, "verdier OK len=2") { returner usann }
    hvis ikkje krev(log, "json_stringify OK len=") { returner usann }
    hvis ikkje krev(log, "fil_skriv OK") { returner usann }
    hvis ikkje krev(log, "fil_les OK: linje-42") { returner usann }

    linje("[OK] " + label + " runtime basics grøn")
    returner sann
}

funksjon docker_finst() -> bool {
    returner ok(kommando("docker info >/dev/null 2>&1"))
}

funksjon run_linux_docker(root: tekst) -> bool {
    la cmd = "docker run --rm --platform linux/amd64 -v " + shell(root + ":/work") +
        " -w /work ubuntu:24.04 bash -lc " +
        shell("set -euo pipefail\napt-get update >/dev/null\napt-get install -y libsqlite3-0 >/dev/null\nenv NORSCODE_CMD=run NORSCODE_FILE=/work/tests/runtime_basics_probe_v4200.no NORSCODE_ENABLE_EXEC_PROSESS=1 /work/bootstrap/stage0/norscode-linux-x86_64 >/tmp/runtime_basics.log 2>&1\ncat /tmp/runtime_basics.log\ngrep -q 'trim OK:' /tmp/runtime_basics.log\ngrep -q 'split OK len=2' /tmp/runtime_basics.log\ngrep -q 'starts_with OK: sann' /tmp/runtime_basics.log\ngrep -q 'ends_with OK: sann' /tmp/runtime_basics.log\ngrep -q 'tekst_fra_heltall OK: 42' /tmp/runtime_basics.log\ngrep -q 'json_parse_raw OK' /tmp/runtime_basics.log\ngrep -q 'nøkler OK len=2' /tmp/runtime_basics.log\ngrep -q 'verdier OK len=2' /tmp/runtime_basics.log\ngrep -q 'json_stringify OK len=' /tmp/runtime_basics.log\ngrep -q 'fil_skriv OK' /tmp/runtime_basics.log\ngrep -q 'fil_les OK: linje-42' /tmp/runtime_basics.log\nprintf '[OK] linux_stage0 runtime basics grøn\\n'")
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }

    linje("== v4200 runtime basics phase ==")
    linje("")
    linje("[1/2] macOS active dist runtime basics")
    hvis ikkje run_host_probe(root, root + "/dist/norscode_native", "macos_dist") { returner 1 }

    hvis docker_finst() {
        linje("")
        linje("[2/2] Linux x86_64 stage0 runtime basics (Docker)")
        hvis ikkje run_linux_docker(root) { returner 1 }
    } ellers {
        linje("")
        linje("[SKIP] Docker er ikkje tilgjengeleg.")
    }

    linje("")
    linje("[OK] v4200 runtime basics probes ferdige.")
    returner 0
}

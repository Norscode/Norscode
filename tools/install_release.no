// tools/install_release.no — Norscode-native releaseinstallasjon
//
// Denne fila eig installasjonsreglane. Wrapperen gir berre miljøverdiane
// NORSCODE_INSTALL_ARCHIVE, NORSCODE_INSTALL_PREFIX og NORSCODE_ROOT; POSIX-
// verktøy blir berre brukt ved avgrensa OS-operasjonar.

bruk std.path som path
bruk std.sha256 som sha256_bytes
bruk std.zip som zip
bruk std.runtime_filesystem som native_fs

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon køyr(cmd: tekst, feil: tekst) -> bool {
    la res = kommando(cmd)
    hvis ok(res) { returner sann }
    hvis feil != "" { linje(feil) }
    hvis lengde(res) > 2 og res[2] != "" { linje(res[2]) }
    returner usann
}

funksjon trim_linje(t: tekst) -> tekst {
    returner trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim_linje(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim_linje(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon executable_finst(sti: tekst) -> bool {
    returner fil_finst(sti)
}

funksjon fil_eller_mappe_finst(sti: tekst) -> bool {
    returner fil_finst(sti)
}

funksjon native_filer_i_tre(root: tekst, relativ: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la listing = native_fs.native_list(root, relativ)
    hvis listing["status"] != "ok" { returner ut }
    la namn = builtin.split(listing["data"], "\n")
    la i = 0
    mens i < lengde(namn) {
        la namn_i = trim(namn[i])
        hvis namn_i != "" {
            la child = namn_i
            hvis relativ != "" { child = relativ + "/" + namn_i }
            la under = native_filer_i_tre(root, child)
            hvis lengde(under) > 0 {
                la j = 0
                mens j < lengde(under) {
                    legg_til(ut, under[j])
                    j = j + 1
                }
            }
            ellers { legg_til(ut, child) }
        }
        i = i + 1
    }
    returner ut
}

funksjon native_root() -> tekst {
    la r = env("NORSCODE_ROOT")
    hvis r == "" { returner "." }
    returner r
}

funksjon lag_katalog_native(sti: tekst) -> bool {
    prøv {
        builtin.mkdir_p(sti)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon slett_tre_native(sti: tekst) -> bool {
    hvis ikkje fil_finst(sti) { returner sann }
    la listing = native_fs.native_list(native_root(), sti)
    hvis listing["status"] == "ok" {
        la barn = builtin.split(listing["data"], "\n")
        la i = 0
        mens i < lengde(barn) { hvis trim_linje(barn[i]) != "" og ikkje slett_tre_native(sti + "/" + trim_linje(barn[i])) { returner usann } i = i + 1 }
    }
    prøv { builtin.fil_slett(sti) returner sann } fang (e) { returner usann }
    returner usann
}

funksjon forelder_sti(sti: tekst) -> tekst {
    la delar = builtin.split(sti, "/")
    hvis lengde(delar) < 2 { returner "." }
    la ut = ""
    la i = 0
    mens i < lengde(delar) - 1 {
        hvis i > 0 { ut = ut + "/" }
        ut = ut + delar[i]
        i = i + 1
    }
    hvis ut == "" { returner "/" }
    returner ut
}

funksjon kopier_fil_native(src: tekst, dest: tekst) -> bool {
    prøv {
        builtin.mkdir_p(forelder_sti(dest))
        builtin.fil_skriv_binær(dest, builtin.fil_les_binær(src))
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon sett_køyrbar(sti: tekst) -> bool {
    prøv {
        builtin.fil_sett_kjorbar(sti)
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon kopier_tre_native(src: tekst, dest: tekst) -> bool {
    prøv { builtin.mkdir_p(dest) } fang (e) { returner usann }
    la native_paths = native_filer_i_tre(native_root(), src)
    hvis lengde(native_paths) == 0 { returner fil_finst(src) }
    la filer: liste_tekst = []
    la ni = 0
    mens ni < lengde(native_paths) {
        legg_til(filer, src + "/" + native_paths[ni])
        ni = ni + 1
    }
    la i = 0
    mens i < lengde(filer) {
        la full = trim_linje(filer[i])
        hvis full != "" {
            la rel = builtin.slice(full, lengde(src) + 1, lengde(full))
            hvis ikkje kopier_fil_native(full, dest + "/" + rel) { returner usann }
        }
        i = i + 1
    }
    returner sann
}

funksjon materialiser_entry(src: tekst, dest: tekst) -> bool {
    hvis ikkje fil_eller_mappe_finst(src) { returner sann }
    hvis ikkje kopier_fil_native(src, dest) {
        returner kopier_tre_native(src, dest)
    }
    returner sann
}

funksjon sha256_for(sti: tekst) -> tekst {
    prøv { returner sha256_bytes.hash_bytes(builtin.fil_les_binær(sti)) } fang (e) { returner "" }
    returner ""
}

funksjon les_sha256(sti: tekst) -> tekst {
    returner trim_linje(fil_les(sti))
}

funksjon basename_utan_tar_gz(sti: tekst) -> tekst {
    la namn = path.basename(sti)
    hvis builtin.ends_with(namn, ".tar.gz") {
        returner builtin.slice(namn, 0, lengde(namn) - 7)
    }
    returner namn
}

funksjon mirror_entries() -> liste_tekst {
    returner [
        "bootstrap",
        "compiler",
        "dist",
        "docs",
        "examples",
        "norcode",
        "norcode.toml",
        "selfhost",
        "scripts",
        "std",
        "tests",
        "tools",
        "README.md",
        "LICENSE",
        "CHANGELOG.md",
        "Makefile",
        "app.no"
    ]
}

funksjon verifiser_sha(arkiv: tekst) -> bool {
    la sha_fil = arkiv + ".sha256"
    hvis ikkje fil_finst(sha_fil) {
        returner sann
    }
    la expected = les_sha256(sha_fil)
    la actual = sha256_for(arkiv)
    hvis actual == "" {
        linje("Fann ikkje verktøy for SHA256-verifisering")
        returner usann
    }
    hvis expected != actual {
        linje("SHA256-avvik for releasepakken")
        returner usann
    }
    returner sann
}

funksjon speil_rot(prefix: tekst, current_link: tekst) -> bool {
    la entries = mirror_entries()
    la i: heiltall = 0
    mens i < lengde(entries) {
        la entry = entries[i]
        hvis fil_eller_mappe_finst(current_link + "/" + entry) {
            slett_tre_native(prefix + "/" + entry)
            hvis ikkje materialiser_entry(current_link + "/" + entry, prefix + "/" + entry) {
                linje("Klarte ikkje speile " + entry)
                returner usann
            }
        }
        i = i + 1
    }
    returner sann
}

funksjon installer(arkiv: tekst, prefix: tekst) -> heiltall {
    hvis arkiv == "" {
        linje("bruk: nc install-release <release.tar.gz> [--prefix <mappe>]")
        returner 1
    }
    hvis prefix == "" {
        prefix = env("HOME") + "/.local/share/norscode"
    }

    hvis ikkje fil_finst(arkiv) {
        linje("Fann ikkje releasepakke: " + arkiv)
        returner 1
    }
    hvis ikkje verifiser_sha(arkiv) {
        returner 1
    }

    la install_root = prefix + "/releases"
    la current_link = prefix + "/current"
    la staging = prefix + "/.staging-" + tekst_fra_heltall(builtin.tid_ms())
    hvis ikkje lag_katalog_native(staging) {
        linje("Klarte ikkje lage staging-mappe")
        returner 1
    }

    hvis ikkje lag_katalog_native(install_root) {
        linje("Klarte ikkje lage installasjonsmappe")
        slett_tre_native(staging)
        returner 1
    }
    hvis ikkje zip.tar_pakk_ut(arkiv, staging) {
        linje("Klarte ikkje pakke ut release i Norscode")
        slett_tre_native(staging)
        returner 1
    }

    hvis ikkje executable_finst(staging + "/bin/nc") {
        linje("Releasepakken manglar bin/nc")
        slett_tre_native(staging)
        returner 1
    }
    hvis ikkje executable_finst(staging + "/dist/norscode_native") {
        linje("Releasepakken manglar dist/norscode_native")
        slett_tre_native(staging)
        returner 1
    }

    la version_name = basename_utan_tar_gz(arkiv)
    la target_dir = install_root + "/" + version_name

    slett_tre_native(target_dir)
    hvis ikkje lag_katalog_native(target_dir) {
        linje("Klarte ikkje lage versjonsmappe")
        slett_tre_native(staging)
        returner 1
    }
    hvis ikkje zip.tar_pakk_ut(arkiv, target_dir) {
        linje("Klarte ikkje materialisere release i Norscode")
        slett_tre_native(staging)
        returner 1
    }

    slett_tre_native(current_link)
    hvis ikkje kopier_tre_native(target_dir, current_link) {
        linje("Klarte ikkje materialisere aktiv release")
        slett_tre_native(staging)
        returner 1
    }
    hvis ikkje lag_katalog_native(prefix + "/bin") {
        linje("Klarte ikkje lage bin-mappe")
        slett_tre_native(staging)
        returner 1
    }

    materialiser_entry(current_link + "/bin/nc", prefix + "/bin/nc")
    materialiser_entry(current_link + "/bin/nor", prefix + "/bin/nor")
    materialiser_entry(current_link + "/bin/nl", prefix + "/bin/nl")
    materialiser_entry(current_link + "/bin/bootstrap", prefix + "/bin/bootstrap")

    hvis ikkje sett_køyrbar(current_link + "/bin/nc") eller
       ikkje sett_køyrbar(current_link + "/dist/norscode_native") eller
       ikkje sett_køyrbar(prefix + "/bin/nc") eller
       ikkje sett_køyrbar(prefix + "/dist/norscode_native") {
        linje("Klarte ikkje gjere installert runtime køyrbar")
        slett_tre_native(staging)
        returner 1
    }

    hvis ikkje speil_rot(prefix, current_link) {
        slett_tre_native(staging)
        returner 1
    }

    hvis trim_linje(kommando("uname -s")[1]) == "Darwin" {
        hvis executable_finst(current_link + "/bin/nc") {
            køyr("cd " + shell(current_link) + " && " + shell(current_link + "/bin/nc") + " install-macos-file-icons", "")
        }
    }

    slett_tre_native(staging)
    linje("Installert release: " + target_dir)
    linje("Aktiv versjon: " + current_link)
    returner 0
}

funksjon start() -> heiltall {
    returner installer(env("NORSCODE_INSTALL_ARCHIVE"), env("NORSCODE_INSTALL_PREFIX"))
}

// tools/backup_native_stage0_v723.no — backup av native dist og macOS stage0

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon backup(root: tekst, src_rel: tekst, out_name: tekst, stamp: tekst) -> bool {
    la src = root + "/" + src_rel
    hvis ikkje ok(kommando("test -f " + shell(src))) { returner sann }
    la out = root + "/build/backups/native_v721/" + out_name + "." + stamp + ".bak"
    hvis ikkje ok(kommando("cp " + shell(src) + " " + shell(out))) { returner usann }
    linje("Backup: build/backups/native_v721/" + out_name + "." + stamp + ".bak")
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la stamp = trim(res_felt(kommando("date +%Y%m%d_%H%M%S"), 1))
    hvis stamp == "" { stamp = "unknown" }
    hvis ikkje ok(kommando("mkdir -p " + shell(root + "/build/backups/native_v721"))) { returner 1 }
    hvis ikkje backup(root, "dist/norscode_native", "norscode_native", stamp) { returner 1 }
    hvis ikkje backup(root, "bootstrap/stage0/norscode-macos-arm64", "norscode-macos-arm64", stamp) { returner 1 }
    linje("OK: backup ferdig.")
    returner 0
}

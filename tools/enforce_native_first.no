// tools/enforce_native_first.no — verifiser native-first-regel i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon fil_inneheld(sti: tekst, needle: tekst) -> bool {
    prøv {
        returner builtin.index_of(builtin.fil_les(sti), needle) >= 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon har_legacy_test_fallback(sti: tekst) -> bool {
    returner fil_inneheld(sti, "python") eller fil_inneheld(sti, "minimal_vm")
}

// Kontraktsreferanse: har_legacy_test_fallback(root + "/tools/nc_test.sh")

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }

    linje("=== Norscode Native-First Enforcement ===")
    linje("")

    skriv("1. Checking dist/norscode_native...")
    hvis ikkje fil_finst(root + "/dist/norscode_native") {
        linje(" FAIL")
        linje("   ERROR: dist/norscode_native not found")
        returner 1
    }
    linje(" OK")

    skriv("2. Checking no Python in normal workflow...")
    hvis fil_finst(root + "/tools/main.py") eller fil_finst(root + "/tools/compile.py") {
        linje(" FAIL")
        linje("   ERROR: Legacy Python tools found")
        returner 1
    }
    linje(" OK")

    skriv("3. Checking nc_test.no uses native...")
    hvis fil_inneheld(root + "/tools/nc_test.no", "python") eller fil_inneheld(root + "/tools/nc_test.no", "minimal_vm") {
        linje(" FAIL")
        linje("   ERROR: nc_test.no has legacy fallback")
        returner 1
    }
    linje(" OK")

    linje("")
    linje("=== Native-First Enforcement: PASSED ===")
    returner 0
}

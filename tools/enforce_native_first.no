// tools/enforce_native_first.no — verifiser native-first-regel i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon executable(sti: tekst) -> bool {
    returner ok(kommando("test -x " + shell(sti)))
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon grep_finn(pattern: tekst, sti: tekst) -> bool {
    returner ok(kommando("grep " + shell(pattern) + " " + shell(sti) + " >/dev/null 2>&1"))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }

    linje("=== Norscode Native-First Enforcement ===")
    linje("")

    skriv("1. Checking dist/norscode_native...")
    hvis ikkje executable(root + "/dist/norscode_native") {
        linje(" FAIL")
        linje("   ERROR: dist/norscode_native not found or not executable")
        returner 1
    }
    linje(" OK")

    skriv("2. Checking no Python in normal workflow...")
    hvis fil_finst(root + "/tools/main.py") eller fil_finst(root + "/tools/compile.py") {
        linje(" FAIL")
        linje("   ERROR: Legacy Python tools found")
        returner 1
    }
    linje(" OK")

    skriv("3. Checking nc_test.no uses native...")
    hvis grep_finn("python\\|minimal_vm", root + "/tools/nc_test.no") {
        linje(" FAIL")
        linje("   ERROR: nc_test.no has legacy fallback")
        returner 1
    }
    linje(" OK")

    linje("")
    linje("=== Native-First Enforcement: PASSED ===")
    returner 0
}

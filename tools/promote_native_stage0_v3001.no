// tools/promote_native_stage0_v3001.no — trygg promotering av native-kandidat

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon executable(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon fil_eller_mappe(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon abs_sti(root: tekst, sti: tekst) -> tekst {
    hvis sti == "" { returner "" }
    hvis builtin.starts_with(sti, "/") { returner sti }
    returner root + "/" + sti
}

funksjon os_namn() -> tekst {
    returner trim(res_felt(kommando("uname -s"), 1))
}

funksjon arch_namn() -> tekst {
    returner trim(res_felt(kommando("uname -m"), 1))
}

funksjon platform_name() -> tekst {
    la os = os_namn()
    la arch = arch_namn()
    hvis os == "Darwin" {
        hvis arch == "arm64" { returner "macos-arm64" }
        hvis arch == "x86_64" { returner "macos-x86_64" }
        returner ""
    }
    hvis os == "Linux" {
        hvis arch == "x86_64" eller arch == "amd64" { returner "linux-x86_64" }
        hvis arch == "aarch64" eller arch == "arm64" { returner "linux-arm64" }
        returner ""
    }
    returner ""
}

funksjon gate_ok(root: tekst, candidate: tekst) -> bool {
    la gate = root + "/tools/native_runtime_gap_gate_v3001.no"
    returner run("cd " + shell(root) + " && NORSCODE_CMD=run NORSCODE_FILE=" + shell(gate) + " NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=" + shell(root) + " NORSCODE_NATIVE_GAP_BIN=" + shell(candidate) + " " + shell(candidate))
}

funksjon stamp() -> tekst {
    la s = trim(res_felt(kommando("date +%Y%m%d_%H%M%S"), 1))
    hvis s == "" { returner "unknown" }
    returner s
}

funksjon les_fil_trygt(sti: tekst) -> tekst {
    prøv {
        returner builtin.fil_les(sti)
    } fang (e) {
        returner ""
    }
    returner ""
}

funksjon argfil_verdi(namn: tekst) -> tekst {
    la path = env("NORSCODE_PROMOTE_ARGS_FILE")
    hvis path == "" { path = "/tmp/norscode_promote_native_stage0_v3001.env" }
    la prefix = namn + "="
    la linjer = builtin.split(les_fil_trygt(path), "\n")
    for linje_verdi i linjer {
        hvis builtin.starts_with(linje_verdi, prefix) {
            returner trim(builtin.slice(linje_verdi, lengde(prefix), lengde(linje_verdi)))
        }
    }
    returner ""
}

funksjon env_eller_arg(namn: tekst, arg_namn: tekst) -> tekst {
    la v = env(namn)
    hvis v != "" { returner v }
    returner argfil_verdi(arg_namn)
}

funksjon flagg_paa(v: tekst) -> bool {
    returner ok(kommando("test " + shell(trim(v)) + " = '1'"))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la candidate = abs_sti(root, env_eller_arg("NORSCODE_PROMOTE_CANDIDATE", "candidate"))
    la dist_verdi = env_eller_arg("NORSCODE_PROMOTE_DIST", "dist")
    la stage0_verdi = env_eller_arg("NORSCODE_PROMOTE_STAGE0", "stage0")
    la dry_run_verdi = env_eller_arg("NORSCODE_PROMOTE_DRY_RUN", "dry_run")

    hvis candidate == "" {
        linje("Feil: manglar kandidat-binær")
        returner 2
    }
    hvis ikkje executable(candidate) {
        linje("Feil: kandidat finst ikkje eller er ikkje køyrbar: " + candidate)
        returner 2
    }
    hvis ikkje flagg_paa(dist_verdi) og ikkje flagg_paa(stage0_verdi) {
        linje("Feil: vel --dist og/eller --stage0")
        returner 2
    }

    linje("== v3001 native/stage0 promotion gate ==")
    linje("candidate: " + candidate)

    hvis ikkje gate_ok(root, candidate) { returner 1 }

    hvis flagg_paa(dry_run_verdi) {
        linje("[DRY-RUN] runtime-gap-gate er grønn")
        hvis flagg_paa(dist_verdi) { linje("[DRY-RUN] ville promotert til dist/norscode_native") }
        hvis flagg_paa(stage0_verdi) {
            la platform = platform_name()
            linje("[DRY-RUN] ville promotert til bootstrap/stage0/norscode-" + platform)
        }
        linje("[DRY-RUN] ingen filer vart endra")
        returner 0
    }

    la s = stamp()
    hvis flagg_paa(dist_verdi) {
        hvis ikkje run("mkdir -p " + shell(root + "/dist")) { returner 1 }
        hvis fil_eller_mappe(root + "/dist/norscode_native") {
            hvis ikkje run("cp " + shell(root + "/dist/norscode_native") + " " + shell(root + "/dist/norscode_native.bak_v3001_" + s)) { returner 1 }
        }
        hvis ikkje run("cp " + shell(candidate) + " " + shell(root + "/dist/norscode_native")) { returner 1 }
        hvis ikkje run("chmod +x " + shell(root + "/dist/norscode_native")) { returner 1 }
        linje("[OK] promotert til dist/norscode_native")
    }

    hvis flagg_paa(stage0_verdi) {
        la platform = platform_name()
        hvis platform == "" {
            linje("Feil: ukjend plattform")
            returner 1
        }
        la out = root + "/bootstrap/stage0/norscode-" + platform
        hvis ikkje run("mkdir -p " + shell(root + "/bootstrap/stage0")) { returner 1 }
        hvis fil_eller_mappe(out) {
            hvis ikkje run("cp " + shell(out) + " " + shell(out + ".bak_v3001_" + s)) { returner 1 }
        }
        hvis ikkje run("cp " + shell(candidate) + " " + shell(out)) { returner 1 }
        hvis ikkje run("chmod +x " + shell(out)) { returner 1 }
        linje("[OK] promotert til bootstrap/stage0/norscode-" + platform)
    }

    linje("[OK] v3001 promotion ferdig etter runtime-gap-gate")
    returner 0
}

// tools/test_v795_runtime_gap.no — røykprøve for runtime-gap-status

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon start() -> heiltall {
    la base = env("NORSCODE_RUNTIME_GAP_BASE")
    hvis base == "" { base = "http://127.0.0.1:8126" }

    linje("[TEST] /runtime-gap")
    hvis ikkje ok(kommando("curl -fsS " + shell(base + "/runtime-gap") + " | grep -q 'Stage0 runtime-status'")) { returner 1 }

    linje("[TEST] /status.json")
    hvis ikkje ok(kommando("curl -fsS " + shell(base + "/status.json") + " | grep -q '\"runtime_gap\":true'")) { returner 1 }
    hvis ikkje ok(kommando("curl -fsS " + shell(base + "/status.json") + " | grep -q '\"production_ready\":false'")) { returner 1 }
    hvis ikkje ok(kommando("curl -fsS " + shell(base + "/status.json") + " | grep -q 'builtin.random_hex'")) { returner 1 }

    linje("v795 OK: runtime-gap og status.json fungerer")
    returner 0
}

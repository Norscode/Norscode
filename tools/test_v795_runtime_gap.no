// tools/test_v795_runtime_gap.no — røykprøve for runtime-gap-status

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon hent(url: tekst) -> tekst {
    la res = kommando("curl -fsS " + shell(url))
    hvis ikkje ok(res) { returner "" }
    returner felt(res, 1)
}

funksjon inneheld(data: tekst, needle: tekst) -> bool {
    returner builtin.index_of(data, needle) >= 0
}

funksjon start() -> heiltall {
    la base = env("NORSCODE_RUNTIME_GAP_BASE")
    hvis base == "" { base = "http://127.0.0.1:8126" }

    linje("[TEST] /runtime-gap")
    la runtime_gap = hent(base + "/runtime-gap")
    hvis ikkje inneheld(runtime_gap, "Stage0 runtime-status") { returner 1 }

    linje("[TEST] /status.json")
    la status = hent(base + "/status.json")
    hvis ikkje inneheld(status, "\"runtime_gap\":true") { returner 1 }
    hvis ikkje inneheld(status, "\"production_ready\":false") { returner 1 }
    hvis ikkje inneheld(status, "builtin.random_hex") { returner 1 }

    linje("v795 OK: runtime-gap og status.json fungerer")
    returner 0
}

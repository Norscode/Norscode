// tools/release_preflight.no — lokal sjekk før release/GitHub
//
// Dette verktøyet publiserer ingenting. Det samlar dei viktigaste lokale
// release-bevisa slik at ein kan sjå kva som manglar før tag eller opplasting.

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon krev_fil(sti: tekst, label: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        linje("[OK] " + label + ": " + sti)
        returner 0
    }
    linje("[FEIL] " + label + " manglar: " + sti)
    returner 1
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon sha256(sti: tekst) -> tekst {
    la res = kommando("shasum -a 256 " + shell(sti))
    hvis lengde(res) < 2 eller res[0] != "0" { returner "" }
    la delar = builtin.split(builtin.trim(res[1]), " ")
    hvis lengde(delar) == 0 { returner "" }
    returner delar[0]
}

funksjon strict_git() -> bool {
    returner env("NORSCODE_RELEASE_PREFLIGHT_STRICT_GIT") == "1"
}

funksjon skip_git_tracking() -> bool {
    returner env("NORSCODE_RELEASE_PREFLIGHT_SKIP_GIT_TRACKING") == "1"
}

funksjon rot() -> tekst {
    la r = env("NORSCODE_ROOT")
    hvis r == "" { returner "." }
    returner r
}

funksjon sti(root: tekst, rel: tekst) -> tekst {
    hvis root == "." { returner rel }
    returner root + "/" + rel
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon krev_rel_fil(root: tekst, rel: tekst, label: tekst) -> heiltall {
    returner krev_fil(sti(root, rel), label)
}

funksjon merk_rel_ikkje_spora(root: tekst, rel: tekst, label: tekst) -> heiltall {
    hvis ikkje fil_finnes(sti(root, rel)) {
        returner 0
    }
    hvis skip_git_tracking() {
        returner 0
    }

    la res = kommando("git -C " + shell(root) + " ls-files --error-unmatch " + shell(rel))
    hvis lengde(res) > 0 og tekst(res[0]) == builtin.chr(48) {
        linje("[OK] " + label + " er spora i git")
        returner 0
    }

    hvis strict_git() {
        linje("[FEIL] " + label + " finst lokalt, men er ikkje spora i git: " + rel)
        returner 1
    }

    linje("[MERK] " + label + " finst lokalt, men er ikkje spora i git: " + rel)
    returner 0
}

funksjon krev_rel_manglar_fil(root: tekst, rel: tekst, label: tekst) -> heiltall {
    la full = sti(root, rel)
    hvis fil_finnes(full) {
        linje("[FEIL] " + label + " finst framleis: " + rel)
        returner 1
    }
    linje("[OK] " + label)
    returner 0
}

funksjon krev_rel_innhald(root: tekst, rel: tekst, needle: tekst, label: tekst) -> heiltall {
    la full = sti(root, rel)
    hvis ikkje fil_finnes(full) {
        linje("[FEIL] " + label + " manglar fil: " + rel)
        returner 1
    }
    la innhald = fil_les(full)
    hvis builtin.index_of(innhald, needle) >= 0 {
        linje("[OK] " + label)
        returner 0
    }
    linje("[FEIL] " + label + " manglar: " + needle)
    returner 1
}

funksjon krev_rel_utan_innhald(root: tekst, rel: tekst, needle: tekst, label: tekst) -> heiltall {
    la full = sti(root, rel)
    hvis ikkje fil_finnes(full) {
        linje("[FEIL] " + label + " manglar fil: " + rel)
        returner 1
    }
    la innhald = fil_les(full)
    hvis builtin.index_of(innhald, needle) >= 0 {
        linje("[FEIL] " + label + " har uønskt innhald: " + needle)
        returner 1
    }
    linje("[OK] " + label)
    returner 0
}

funksjon krev_rel_trygg_s_shell(root: tekst, rel: tekst, label: tekst) -> heiltall {
    la feil = 0
    feil = feil + krev_rel_innhald(root, rel, "builtin.replace(s, \"'\"", label + " shell-quotar apostrof")
    feil = feil + krev_rel_utan_innhald(root, rel, "returner \"'\" + s + \"'\"", label + " har ikkje rå s-shellquote")
    returner feil
}

funksjon krev_rel_standard_shellquote(root: tekst, rel: tekst, label: tekst) -> heiltall {
    returner krev_rel_utan_innhald(root, rel, "\"'\\\\''\"", label + " brukar standard shell-quote")
}

funksjon windows_stage0_kandidat_gate(root: tekst) -> heiltall {
    la stage0 = sti(root, "bootstrap/stage0/norscode-windows-x86_64.exe")
    la kandidat = sti(root, "build/windows/norscode_native_windows_x86_64.exe")
    hvis ikkje fil_finnes(stage0) eller ikkje fil_finnes(kandidat) {
        linje("[FEIL] Windows stage0/kandidat manglar for hash-konsistens")
        returner 1
    }
    prøv {
        la stage_bytes = builtin.fil_les_binær(stage0)
        la kandidat_bytes = builtin.fil_les_binær(kandidat)
        hvis lengde(stage_bytes) != lengde(kandidat_bytes) {
            // Windows cross-linking is toolchain/host specific. The release
            // candidate is accepted only when its signed attestation binds
            // the exact candidate hash; the tracked stage0 remains a seed.
            la attest = env("NORSCODE_WINDOWS_ATTESTATION")
            hvis attest != "" og fil_finnes(attest) {
                prøv {
                    la data = builtin.json_parse_raw(builtin.fil_les(attest))
                    la want = tekst(data["runtime_sha256"])
                    la got = sha256(kandidat)
                    hvis want != "" og want == got {
                        linje("[OK] Windows cross-kandidat er hashbunden til attestasjonen")
                        returner 0
                    }
                } fang (e) { }
            }
            linje("[FEIL] Windows stage0 og cross-kandidat har ulik storleik")
            returner 1
        }
        la i: heiltall = 0
        mens i < lengde(stage_bytes) {
            hvis stage_bytes[i] != kandidat_bytes[i] {
                la attest2 = env("NORSCODE_WINDOWS_ATTESTATION")
                hvis attest2 != "" og fil_finnes(attest2) {
                    prøv {
                        la data2 = builtin.json_parse_raw(builtin.fil_les(attest2))
                        hvis tekst(data2["runtime_sha256"]) == sha256(kandidat) {
                            linje("[OK] Windows cross-kandidat er hashbunden til attestasjonen")
                            returner 0
                        }
                    } fang (e2) { }
                }
                linje("[FEIL] Windows stage0 og cross-kandidat er ikkje byte-identiske")
                returner 1
            }
            i = i + 1
        }
    } fang (e) {
        linje("[FEIL] Windows stage0/kandidat kunne ikkje samanliknast: " + tekst(e))
        returner 1
    }
    linje("[OK] Windows stage0 er byte-identisk med cross-kandidaten")
    returner 0
}


// tools/run_bootstrap_literal_probes_v5600.no — generer bootstrap literal probe-output

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon bin_path(root: tekst) -> tekst {
    la b = env("BIN")
    hvis b != "" { returner b }
    returner root + "/bin/nc"
}

funksjon outdir(root: tekst) -> tekst {
    la o = env("OUTDIR")
    hvis o != "" { returner o }
    returner root + "/build/v5600/out"
}

funksjon compile_one(root: tekst, bin: tekst, out_dir: tekst, name: tekst, fixture: tekst) -> bool {
    la src = root + "/tests/fixtures/bootstrap_v5600/" + fixture
    la out = out_dir + "/" + name + ".ncb.json"
    linje("[compile] " + name)
    la res = kommando(shell(bin) + " compile " + shell(src) + " " + shell(out))
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    hvis ikkje ok(res) { returner usann }
    linje("[out] " + out)
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(res_felt(kommando("pwd"), 1)) }
    la bin = bin_path(root)
    la out_dir = outdir(root)
    hvis ikkje ok(kommando("mkdir -p " + shell(out_dir))) { returner 1 }

    hvis ikkje compile_one(root, bin, out_dir, "list_literal", "list_literal_v5600.no") { returner 1 }
    hvis ikkje compile_one(root, bin, out_dir, "empty_list", "empty_list_v5600.no") { returner 1 }
    hvis ikkje compile_one(root, bin, out_dir, "map_literal", "map_literal_v5600.no") { returner 1 }
    hvis ikkje compile_one(root, bin, out_dir, "index_expr", "index_expr_v5600.no") { returner 1 }
    hvis ikkje compile_one(root, bin, out_dir, "assignment_list", "assignment_list_v5600.no") { returner 1 }
    hvis ikkje compile_one(root, bin, out_dir, "assignment_map", "assignment_map_v5600.no") { returner 1 }
    hvis ikkje compile_one(root, bin, out_dir, "assignment_index", "assignment_index_v5600.no") { returner 1 }

    linje("")
    linje("Forventa signal i generert output:")
    linje("- list_literal => BUILD_LIST")
    linje("- empty_list => BUILD_LIST")
    linje("- map_literal => BUILD_MAP")
    linje("- index_expr => INDEX_GET")
    linje("- assignment_list => BUILD_LIST + STORE_NAME/STORE_VAR")
    linje("- assignment_map => BUILD_MAP + STORE_NAME/STORE_VAR")
    linje("- assignment_index => INDEX_GET + STORE_NAME/STORE_VAR")
    returner 0
}

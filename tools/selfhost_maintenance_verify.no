// tools/selfhost_maintenance_verify.no — vedlikehaldsdocs-policy i Norscode

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}
funksjon env(namn: tekst) -> tekst {
    prøv {
        returner miljo_hent(namn)
    } fang (e) {
        returner ""
    }
    returner ""
}
funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}
funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}
funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}
funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon inneheld_fil(sti: tekst, pattern: tekst) -> bool {
    prøv {
        returner builtin.index_of(fil_les(sti), pattern) >= 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon krev(root: tekst, rel: tekst, pattern: tekst) -> bool {
    la sti = root + "/" + rel
    hvis inneheld_fil(sti, pattern) { returner sann }
    linje("Mangler forventet tekst i " + sti + ": " + pattern)
    returner usann
}

funksjon krev_borte(root: tekst, rel: tekst, pattern: tekst) -> bool {
    la sti = root + "/" + rel
    hvis inneheld_fil(sti, pattern) {
        linje("Uønskt tekst i " + sti + ": " + pattern)
        returner usann
    }
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(kommando("pwd")[1]) }
    hvis ikkje krev(root, "docs/INDEX.md", "docs/_archive/ARCHIVE_INDEX.md") { returner 1 }
    hvis ikkje krev(root, "docs/README.md", "docs/SELFHOST_HANDLINGSPLAN.md") { returner 1 }
    hvis ikkje krev(root, "docs/05-development/SELFHOST_MIGRATION_AND_DEPRECATIONS.md", "ARCHIVE_INDEX") { returner 1 }
    hvis ikkje krev(root, "docs/STATUS.md", "docs/_archive/") { returner 1 }
    hvis ikkje krev(root, "docs/05-development/SELFHOST_CI_GATES.md", "Normal CI for release/install skal ikkje krevje C-verktøykjede") { returner 1 }
    hvis ikkje krev(root, "docs/05-development/SELFHOST_RELEASE_CHECKLIST.md", "release/install-flaten krev ikkje C-verktøykjede") { returner 1 }
    hvis ikkje krev(root, "docs/SELFHOST_HANDLINGSPLAN.md", "C-regen skal berre finnast i eksplisitt vedlikehaldslane") { returner 1 }
    hvis ikkje krev_borte(root, "docs/STATUS.md", "Neste konkrete patch") { returner 1 }
    linje("Vedlikeholdsverifikasjon: OK")
    returner 0
}

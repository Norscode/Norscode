// tools/ai_patch_guard_v3021.no — sperr farlege patchar før bruk

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon usage() -> heiltall {
    linje("Bruk: NORSCODE_PATCH_GUARD_PATCH=PATCHFILE ./bin/nc run tools/ai_patch_guard_v3021.no")
    returner 0
}

funksjon abs_path(root: tekst, path: tekst) -> tekst {
    hvis path == "" { returner "" }
    hvis lengde(path) > 0 og path[0] == "/" { returner path }
    returner root + "/" + path
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res)
}

funksjon skriv_prefikset_fil(sti: tekst, prefiks: tekst) -> heiltall {
    la data = ""
    prøv {
        data = builtin.fil_les(sti)
    } fang (e) {
        returner 0
    }
    la linjer = builtin.split(data, "\n")
    for line i linjer {
        hvis line != "" {
            skriv(prefiks + line + "\n")
        }
    }
    returner 0
}

funksjon legg_til_unik(liste: liste_tekst, verdi: tekst) -> bool {
    for eksisterande i liste {
        hvis eksisterande == verdi { returner usann }
    }
    legg_til(liste, verdi)
    returner sann
}

funksjon felt_etter_handling(line: tekst) -> tekst {
    la idx = builtin.index_of(line, " ")
    hvis idx < 0 { returner "" }
    returner trim(builtin.slice(line, idx + 1, lengde(line)))
}

funksjon skriv_linjer(sti: tekst, linjer: liste_tekst) -> bool {
    la body = ""
    for line i linjer {
        body = body + line + "\n"
    }
    prøv {
        builtin.fil_skriv(sti, body)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon etter_prefix(line: tekst, prefix: tekst) -> tekst {
    returner builtin.slice(line, lengde(prefix), lengde(line))
}

funksjon diff_git_path(line: tekst) -> tekst {
    la prefix = "diff --git a/"
    hvis ikkje builtin.starts_with(line, prefix) { returner "" }
    la rest = etter_prefix(line, prefix)
    la idx = builtin.index_of(rest, " b/")
    hvis idx < 0 { returner trim(rest) }
    returner trim(builtin.slice(rest, 0, idx))
}

funksjon patch_mål_liner(patch_file: tekst) -> liste_tekst {
    la out: liste_tekst = []
    la data = ""
    prøv {
        data = builtin.fil_les(patch_file)
    } fang (e) {
        returner out
    }
    la linjer = builtin.split(data, "\n")
    for line i linjer {
        hvis builtin.starts_with(line, "*** Add File: ") {
            legg_til(out, "ADD " + etter_prefix(line, "*** Add File: "))
        } ellers hvis builtin.starts_with(line, "*** Update File: ") {
            legg_til(out, "UPDATE " + etter_prefix(line, "*** Update File: "))
        } ellers hvis builtin.starts_with(line, "*** Delete File: ") {
            legg_til(out, "DELETE " + etter_prefix(line, "*** Delete File: "))
        } ellers hvis builtin.starts_with(line, "diff --git a/") {
            la path = diff_git_path(line)
            hvis path != "" { legg_til(out, "UPDATE " + path) }
        }
    }
    returner out
}

funksjon tel_ikkje_tomme_linjer(sti: tekst) -> heiltall {
    la data = ""
    prøv {
        data = builtin.fil_les(sti)
    } fang (e) {
        returner 0
    }
    la linjer = builtin.split(data, "\n")
    la count = 0
    for line i linjer {
        hvis line != "" {
            count = count + 1
        }
    }
    returner count
}

funksjon fil_har_innhald(sti: tekst) -> bool {
    prøv {
        returner lengde(builtin.fil_les(sti)) > 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon les_listefil(sti: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la data = ""
    prøv {
        data = builtin.fil_les(sti)
    } fang (e) {
        returner ut
    }
    la linjer = builtin.split(data, "\n")
    for line i linjer {
        la v = trim(line)
        hvis v != "" { legg_til(ut, v) }
    }
    returner ut
}

funksjon liste_har_prefiks(sti: tekst, prefiks: tekst) -> bool {
    la linjer = les_listefil(sti)
    for line i linjer {
        hvis builtin.starts_with(line, prefiks) { returner sann }
    }
    returner usann
}

funksjon liste_har_native_binær(sti: tekst) -> bool {
    la linjer = les_listefil(sti)
    for line i linjer {
        la delar = builtin.split(line, "/")
        hvis lengde(delar) > 0 {
            la namn = delar[lengde(delar) - 1]
            hvis namn == "norscode_native" { returner sann }
            hvis builtin.starts_with(namn, "norscode-") { returner sann }
        }
    }
    returner usann
}

funksjon slett_fil_trygt(sti: tekst) -> heiltall {
    prøv { builtin.fil_slett(sti) } fang (e) { }
    returner 0
}

funksjon rydd_tmp_filer(a: tekst, b: tekst, c: tekst) -> heiltall {
    slett_fil_trygt(a)
    slett_fil_trygt(b)
    slett_fil_trygt(c)
    returner 0
}

funksjon bygg_patch_lister(tmp_files: tekst, tmp_paths: tekst, tmp_deletes: tekst) -> bool {
    la data = ""
    prøv {
        data = builtin.fil_les(tmp_files)
    } fang (e) {
        returner usann
    }
    la paths: liste_tekst = []
    la deletes: liste_tekst = []
    la linjer = builtin.split(data, "\n")
    for line i linjer {
        hvis line == "" { fortsett }
        la path = felt_etter_handling(line)
        hvis path == "" { fortsett }
        legg_til_unik(paths, path)
        hvis builtin.starts_with(line, "DELETE ") {
            legg_til(deletes, path)
        }
    }
    hvis ikkje skriv_linjer(tmp_paths, paths) { returner usann }
    hvis ikkje skriv_linjer(tmp_deletes, deletes) { returner usann }
    returner sann
}

funksjon start() -> heiltall {
    la root = trim(felt(kommando("pwd"), 1))
    la patch_file = abs_path(root, env("NORSCODE_PATCH_GUARD_PATCH"))
    la manifest = abs_path(root, env("NORSCODE_PATCH_GUARD_MANIFEST"))
    la allow_archive = env("NORSCODE_PATCH_GUARD_ALLOW_ARCHIVE") == "sann"

    hvis patch_file == "" {
        usage()
        returner 2
    }
    hvis ikkje builtin.fil_finnes(patch_file) {
        linje("[FAIL] Patchfil manglar: " + patch_file)
        returner 1
    }
    hvis manifest != "" {
        hvis ikkje builtin.fil_finnes(manifest) {
            linje("[FAIL] Manifest manglar: " + manifest)
            returner 1
        }
    }

    la tmp_base = "/tmp/norscode_patch_guard_v3021"
    la tmp_files = tmp_base + "_files"
    la tmp_paths = tmp_base + "_paths"
    la tmp_deletes = tmp_base + "_deletes"
    rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)
    hvis ikkje skriv_linjer(tmp_files, patch_mål_liner(patch_file)) {
        rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)
        returner 1
    }
    hvis ikkje fil_har_innhald(tmp_files) {
        linje("[FAIL] Fann ingen patchmål i: " + patch_file)
        rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)
        returner 1
    }

    hvis ikkje bygg_patch_lister(tmp_files, tmp_paths, tmp_deletes) {
        rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)
        returner 1
    }
    la file_count_num = tel_ikkje_tomme_linjer(tmp_paths)
    la file_count = tekst(file_count_num)
    la fail = usann

    linje("== ai patch guard v3021 ==")
    linje("patch: " + patch_file)
    linje("files: " + file_count)

    hvis fil_har_innhald(tmp_deletes) {
        linje("[BLOCK] Sletting er sperra som standard:")
        skriv_prefikset_fil(tmp_deletes, "  - ")
        fail = sann
    }
    hvis liste_har_prefiks(tmp_paths, "dist/") {
        linje("[BLOCK] Endring av dist/ er sperra.")
        fail = sann
    }
    hvis liste_har_prefiks(tmp_paths, "bootstrap/stage0/") {
        linje("[BLOCK] Endring av bootstrap/stage0/ er sperra.")
        fail = sann
    }
    hvis ikkje allow_archive {
        hvis liste_har_prefiks(tmp_paths, "archive/") {
            linje("[BLOCK] Endring av archive/ krev --allow-archive.")
            fail = sann
        }
    }
    hvis file_count_num > 20 og manifest == "" {
        linje("[BLOCK] Stor patch krev manifest. Bruk --manifest PATH.")
        fail = sann
    }
    hvis liste_har_native_binær(tmp_paths) {
        linje("[BLOCK] Direkte patching av native-binærar er sperra.")
        fail = sann
    }

    hvis fail {
        linje("[FAIL] Patch guard stoppa patchen.")
        rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)
        returner 1
    }

    hvis liste_har_prefiks(tmp_paths, "docs/") eller liste_har_prefiks(tmp_paths, "tests/") eller liste_har_prefiks(tmp_paths, "tools/") {
        linje("[INFO] Patchen rører docs/tests/tools, som er innanfor trygg sone dersom ingen blokkeringar slo inn.")
    }
    hvis manifest != "" { linje("[INFO] Manifest brukt: " + manifest) }
    linje("[OK] Patch guard godkjende patchen.")
    rydd_tmp_filer(tmp_files, tmp_paths, tmp_deletes)
    returner 0
}

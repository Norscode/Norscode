// tools/ai_patch_guard_v3021.no — sperr farlege patchar før bruk

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon usage() -> heiltall {
    linje("Bruk: tools/ai_patch_guard_v3021.sh [--allow-archive] [--manifest PATH] PATCHFILE")
    returner 0
}

funksjon abs_path(root: tekst, path: tekst) -> tekst {
    hvis path == "" { returner "" }
    hvis lengde(path) > 0 og path[0] == "/" { returner path }
    returner root + "/" + path
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis felt(res, 1) != "" { skriv(felt(res, 1)) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner ok(res)
}

funksjon start() -> heiltall {
    la root = trim(felt(kommando("pwd"), 1))
    la patch_file = abs_path(root, env("NORSCODE_PATCH_GUARD_PATCH"))
    la manifest = abs_path(root, env("NORSCODE_PATCH_GUARD_MANIFEST"))
    la allow_archive = env("NORSCODE_PATCH_GUARD_ALLOW_ARCHIVE") == "sann"

    hvis patch_file == "" {
        usage()
        returner 2
    }
    hvis ikkje ok(kommando("test -f " + shell(patch_file))) {
        linje("[FAIL] Patchfil manglar: " + patch_file)
        returner 1
    }
    hvis manifest != "" {
        hvis ikkje ok(kommando("test -f " + shell(manifest))) {
            linje("[FAIL] Manifest manglar: " + manifest)
            returner 1
        }
    }

    la tmp_files = trim(felt(kommando("mktemp /tmp/norscode_patch_guard_files.XXXXXX"), 1))
    la tmp_paths = trim(felt(kommando("mktemp /tmp/norscode_patch_guard_paths.XXXXXX"), 1))
    la tmp_deletes = trim(felt(kommando("mktemp /tmp/norscode_patch_guard_deletes.XXXXXX"), 1))
    la awk_script = "/^\\*\\*\\* Add File: / { print \"ADD \" substr($0, 15); next } /^\\*\\*\\* Update File: / { print \"UPDATE \" substr($0, 18); next } /^\\*\\*\\* Delete File: / { print \"DELETE \" substr($0, 18); next } /^diff --git a\\// { line = $0; sub(/^diff --git a\\//, \"\", line); sub(/ b\\/.*$/, \"\", line); print \"UPDATE \" line; next }"
    hvis ikkje ok(kommando("awk " + shell(awk_script) + " " + shell(patch_file) + " > " + shell(tmp_files))) {
        kommando("rm -f " + shell(tmp_files) + " " + shell(tmp_paths) + " " + shell(tmp_deletes))
        returner 1
    }
    hvis ikkje ok(kommando("test -s " + shell(tmp_files))) {
        linje("[FAIL] Fann ingen patchmål i: " + patch_file)
        kommando("rm -f " + shell(tmp_files) + " " + shell(tmp_paths) + " " + shell(tmp_deletes))
        returner 1
    }

    kommando("cut -d' ' -f2- " + shell(tmp_files) + " | sort -u > " + shell(tmp_paths))
    kommando("grep '^DELETE ' " + shell(tmp_files) + " | cut -d' ' -f2- > " + shell(tmp_deletes) + " || true")
    la file_count = trim(felt(kommando("wc -l < " + shell(tmp_paths) + " | tr -d ' '"), 1))
    la file_count_num = builtin.heltall_fra_tekst(file_count)
    la fail = usann

    linje("== ai patch guard v3021 ==")
    linje("patch: " + patch_file)
    linje("files: " + file_count)

    hvis ok(kommando("test -s " + shell(tmp_deletes))) {
        linje("[BLOCK] Sletting er sperra som standard:")
        run("sed 's/^/  - /' " + shell(tmp_deletes))
        fail = sann
    }
    hvis ok(kommando("rg -n '^dist/' " + shell(tmp_paths) + " >/dev/null 2>&1")) {
        linje("[BLOCK] Endring av dist/ er sperra.")
        fail = sann
    }
    hvis ok(kommando("rg -n '^bootstrap/stage0/' " + shell(tmp_paths) + " >/dev/null 2>&1")) {
        linje("[BLOCK] Endring av bootstrap/stage0/ er sperra.")
        fail = sann
    }
    hvis ikkje allow_archive {
        hvis ok(kommando("rg -n '^archive/' " + shell(tmp_paths) + " >/dev/null 2>&1")) {
            linje("[BLOCK] Endring av archive/ krev --allow-archive.")
            fail = sann
        }
    }
    hvis file_count_num > 20 og manifest == "" {
        linje("[BLOCK] Stor patch krev manifest. Bruk --manifest PATH.")
        fail = sann
    }
    hvis ok(kommando("rg -n '(^|/)(norscode_native|norscode-[^/]+)$' " + shell(tmp_paths) + " >/dev/null 2>&1")) {
        linje("[BLOCK] Direkte patching av native-binærar er sperra.")
        fail = sann
    }

    hvis fail {
        linje("[FAIL] Patch guard stoppa patchen.")
        kommando("rm -f " + shell(tmp_files) + " " + shell(tmp_paths) + " " + shell(tmp_deletes))
        returner 1
    }

    hvis ok(kommando("rg -n '^(docs/|tests/|tools/)' " + shell(tmp_paths) + " >/dev/null 2>&1")) {
        linje("[INFO] Patchen rører docs/tests/tools, som er innanfor trygg sone dersom ingen blokkeringar slo inn.")
    }
    hvis manifest != "" { linje("[INFO] Manifest brukt: " + manifest) }
    linje("[OK] Patch guard godkjende patchen.")
    kommando("rm -f " + shell(tmp_files) + " " + shell(tmp_paths) + " " + shell(tmp_deletes))
    returner 0
}

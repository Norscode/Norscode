// tools/build_omgang6b_compiler_ncb.no — kompilator-kjede + ELF driver (Omgang 6b)

bruk std.path som path

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim_tekst(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim_tekst(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon bytes(sti: tekst) -> tekst {
    prøv {
        la innhald = builtin.fil_les(sti)
        returner tekst_fra_heltall(lengde(innhald))
    } fang (e) {}
    returner første_felt(res_felt(kommando("wc -c " + shell(sti)), 1))
}

funksjon les_fragment(root: tekst, namn: tekst) -> tekst {
    returner builtin.fil_les(root + "/bootstrap/precompiled_fragments_inner/" + namn + ".functions.json")
}

funksjon bygg_frå_fragment(root: tekst, out: tekst) -> bool {
    la funksjonsjson = ""
    funksjonsjson = funksjonsjson + les_fragment(root, "lexer_m1")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "parser")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "semantic")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "ir_to_bytecode")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "json")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "kompiler")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "bundler")
    funksjonsjson = funksjonsjson + "," + les_fragment(root, "elf_compile_driver")

    la bundle = "{\"format\":\"ncb-v1\",\"entry\":\"selfhost.elf_compile_driver.start\",\"imports\":[],\"route_handlers\":{},\"dependency_providers\":{},\"guard_providers\":{},\"request_middlewares\":[],\"response_middlewares\":[],\"error_middlewares\":[],\"startup_hooks\":[],\"shutdown_hooks\":[],\"tests\":{},\"functions\":{" + funksjonsjson + "}}"
    prøv {
        builtin.fil_skriv(out, bundle)
        returner sann
    } fang (e) {
        skriv("Feil: kunne ikkje skrive Omgang6b stage-0 NCB: " + tekst(e) + "\n")
        returner usann
    }
    returner usann
}

funksjon bundle_args() -> tekst {
    returner "selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no " +
        "selfhost.parser=selfhost/parser.no " +
        "selfhost.compiler.semantic=selfhost/compiler/semantic.no " +
        "selfhost.compiler.ir_to_bytecode=selfhost/compiler/ir_to_bytecode.no " +
        "selfhost.json=selfhost/json.no " +
        "selfhost.kompiler=selfhost/kompiler.no " +
        "selfhost.bundler=selfhost/bundler.no " +
        "selfhost.elf_compile_driver=selfhost/elf_compile_driver.no"
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(res_felt(kommando("pwd"), 1)) }
    la out = env("NORSCODE_OMGANG6B_NCB_OUT")
    hvis out == "" { out = root + "/build/6b/compiler_stage0.ncb.json" }

    hvis ikkje run("mkdir -p " + shell(path.dirname(out))) { returner 1 }

    hvis ikkje run("mkdir -p " + shell(root + "/bootstrap/precompiled_fragments") + " " + shell(root + "/bootstrap/precompiled_fragments_inner")) { returner 1 }
    hvis ikkje run("cd " + shell(root) + " && NORSCODE_ENABLE_EXEC_PROSESS=1 ./bin/nc run " + shell(root + "/tools/regenerate_omgang6b_fragments_safe.no") + " >/dev/null") { returner 1 }

    linje("✓ Omgang 6b stage-0 NCB: " + out + " (" + bytes(out) + " bytes)")
    returner 0
}

// tools/build_omgang6b_compiler_ncb.no — kompilator-kjede + ELF driver (Omgang 6b)

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis res_felt(res, 1) != "" { skriv(res_felt(res, 1)) }
    hvis res_felt(res, 2) != "" { skriv(res_felt(res, 2)) }
    returner ok(res)
}

funksjon bytes(sti: tekst) -> tekst {
    returner trim(res_felt(kommando("wc -c < " + shell(sti) + " | tr -d ' '"), 1))
}

funksjon bundle_args() -> tekst {
    returner "selfhost.lexer.lexer_m1=selfhost/lexer/lexer_m1.no " +
        "selfhost.parser=selfhost/parser.no " +
        "selfhost.compiler.semantic=selfhost/compiler/semantic.no " +
        "selfhost.compiler.ir_to_bytecode=selfhost/compiler/ir_to_bytecode.no " +
        "selfhost.json=selfhost/json.no " +
        "selfhost.kompiler=selfhost/kompiler.no " +
        "selfhost.bundler=selfhost/bundler.no " +
        "selfhost.elf_compile_driver=selfhost/elf_compile_driver.no"
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(res_felt(kommando("pwd"), 1)) }
    la out = env("NORSCODE_OMGANG6B_NCB_OUT")
    hvis out == "" { out = root + "/build/6b/compiler_stage0.ncb.json" }

    hvis ikkje run("mkdir -p $(dirname " + shell(out) + ")") { returner 1 }

    la cmd = "cd " + shell(root) +
        " && NORSCODE_USE_PRECOMPILED_SELFHOST=0 NORSCODE_BUNDLE_ENTRY='selfhost.elf_compile_driver.start' " +
        shell(root + "/bin/nc") + " bundle " + bundle_args() + " --output " + shell(out)
    hvis ikkje run(cmd) { returner 1 }

    hvis ikkje run("mkdir -p " + shell(root + "/bootstrap/precompiled_fragments") + " " + shell(root + "/bootstrap/precompiled_fragments_inner")) { returner 1 }
    hvis ikkje run("cd " + shell(root) + " && NORSCODE_ENABLE_EXEC_PROSESS=1 ./bin/nc run " + shell(root + "/tools/regenerate_omgang6b_fragments_safe.no") + " >/dev/null") { returner 1 }

    linje("✓ Omgang 6b stage-0 NCB: " + out + " (" + bytes(out) + " bytes)")
    returner 0
}

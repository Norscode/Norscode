// tools/smoke_helpdesk_http.no — Helpdesk HTTP runtime-smoke

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon curl_status(base: tekst, metode: tekst, path: tekst, ekstra: tekst, body: tekst) -> tekst {
    la cmd = "curl -sS -o /tmp/helpdesk_http_body.txt -w '%{http_code}' -X " + shell(metode) + " " + shell(base + path) + " -H 'X-API-Key: secret-helpdesk'"
    hvis ekstra != "" { cmd = cmd + " " + ekstra }
    hvis body != "" { cmd = cmd + " -H 'Content-Type: application/json' -d " + shell(body) }
    returner trim(res_felt(kommando(cmd), 1))
}

funksjon curl_status_utan_api(base: tekst, metode: tekst, path: tekst, ekstra: tekst, body: tekst) -> tekst {
    la cmd = "curl -sS -o /tmp/helpdesk_http_body.txt -w '%{http_code}' -X " + shell(metode) + " " + shell(base + path)
    hvis ekstra != "" { cmd = cmd + " " + ekstra }
    hvis body != "" { cmd = cmd + " -H 'Content-Type: application/json' -d " + shell(body) }
    returner trim(res_felt(kommando(cmd), 1))
}

funksjon assert_status(namn: tekst, faktisk: tekst, venta: tekst) -> bool {
    hvis faktisk == venta { returner sann }
    linje("FEIL: " + namn + " forventet status " + venta + ", fikk " + faktisk)
    la body = kommando("cat /tmp/helpdesk_http_body.txt 2>/dev/null || true")
    hvis res_felt(body, 1) != "" { linje("Svarkropp: " + res_felt(body, 1)) }
    returner usann
}

funksjon krev(namn: tekst, faktisk: tekst, venta: tekst) -> bool {
    hvis assert_status(namn, faktisk, venta) { returner sann }
    returner usann
}

funksjon start() -> heiltall {
    la base = env("NORSCODE_HELPDESK_BASE_URL")
    hvis base == "" { base = "http://127.0.0.1:4173" }

    hvis ikkje ok(kommando("command -v curl >/dev/null 2>&1")) {
        linje("FEIL: curl mangler på maskinen. Trengs for runtime-smoke.")
        returner 1
    }

    linje("=== Helpdesk HTTP smoke ===")
    linje("Base-url: " + base)

    hvis ikkje ok(kommando("curl -sS --max-time 2 " + shell(base + "/health") + " >/dev/null")) {
        linje("FEIL: klarte ikkje nå " + base + "/health. Start server på 4173 først.")
        returner 1
    }

    hvis ikkje krev("health", curl_status(base, "GET", "/health", "", ""), "200") { returner 1 }
    hvis ikkje krev("tickets", curl_status(base, "GET", "/tickets", "", ""), "200") { returner 1 }
    hvis ikkje krev("tickets-invalid-sort", curl_status(base, "GET", "/tickets?sort=bad-sort", "-H 'X-Role: admin'", ""), "400") { returner 1 }
    hvis ikkje krev("tickets-invalid-limit", curl_status(base, "GET", "/tickets?limit=abc", "-H 'X-Role: admin'", ""), "400") { returner 1 }
    hvis ikkje krev("tickets-id-invalid", curl_status(base, "GET", "/tickets/bad-id", "-H 'X-Role: agent' -H 'X-user: lena'", ""), "404") { returner 1 }

    hvis ikkje krev("admin-users", curl_status(base, "GET", "/admin/users", "", ""), "200") { returner 1 }
    hvis ikkje krev("admin-roles-user", curl_status_utan_api(base, "GET", "/admin/roles", "-H 'X-Role: user'", ""), "403") { returner 1 }
    hvis ikkje krev("admin-roles-no-auth", curl_status_utan_api(base, "GET", "/admin/roles", "", ""), "401") { returner 1 }
    hvis ikkje krev("admin-roles", curl_status(base, "GET", "/admin/roles", "", ""), "200") { returner 1 }
    hvis ikkje krev("agent-close-admin-ticket", curl_status(base, "PATCH", "/admin/tickets/1", "-H 'X-Role: agent' -H 'X-user: lena'", "{\"status\":\"closed\"}"), "403") { returner 1 }
    hvis ikkje krev("admin-metrics", curl_status(base, "GET", "/admin/metrics", "", ""), "200") { returner 1 }
    hvis ikkje krev("admin-panel", curl_status(base, "GET", "/admin/panel", "", ""), "200") { returner 1 }
    hvis ikkje krev("admin-roles-user-repeat", curl_status_utan_api(base, "GET", "/admin/roles", "-H 'X-Role: user'", ""), "403") { returner 1 }
    hvis ikkje krev("agent-close-admin-ticket-no-user", curl_status(base, "PATCH", "/admin/tickets/1", "-H 'X-Role: agent'", "{\"status\":\"closed\"}"), "403") { returner 1 }

    linje("OK: Helpdesk HTTP smoke klar")
    returner 0
}

// tools/build-macos-app.no — bygg lokal macOS .app-bundle

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + builtin.replace(s, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon ut(res: liste_tekst) -> tekst {
    la tekst_ut = felt(res, 1)
    hvis tekst_ut == "" { tekst_ut = felt(res, 2) }
    returner tekst_ut
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon run(cmd: tekst, feil: tekst) -> bool {
    la res = kommando(cmd)
    hvis ok(res) { returner sann }
    hvis feil != "" { linje(feil) }
    hvis felt(res, 2) != "" { skriv(felt(res, 2)) }
    returner usann
}

funksjon skriv_fil(path: tekst, body: tekst) -> bool {
    prøv {
        builtin.fil_skriv(path, body)
        returner sann
    } fang (e) {
        linje("Klarte ikkje skrive " + path)
        returner usann
    }
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon toml_version_fra_innhald(innhald: tekst) -> tekst {
    la linjer = builtin.split(innhald, "\n")
    la i = 0
    mens i < lengde(linjer) {
        la line = trim(linjer[i])
        hvis builtin.starts_with(line, "version") {
            la delar = builtin.split(line, "\"")
            hvis lengde(delar) >= 3 { returner trim(delar[1]) }
        }
        i = i + 1
    }
    returner ""
}

funksjon repo_version(root: tekst) -> tekst {
    la toml = root + "/norcode.toml"
    hvis fil_finst(toml) {
        la v = toml_version_fra_innhald(builtin.fil_les(toml))
        hvis v != "" { returner v }
    }
    returner "1.0"
}

funksjon copy_runtime(root: tekst, runtime_dir: tekst) -> bool {
    la entries: liste_tekst = ["bin", "bootstrap", "dist", "selfhost", "std", "norcode.toml", "README.md", "LICENSE"]
    la i = 0
    mens i < lengde(entries) {
        la entry = entries[i]
        hvis fil_finst(root + "/" + entry) {
            hvis ikkje run("cp -R " + shell(root + "/" + entry) + " " + shell(runtime_dir + "/"), "Klarte ikkje kopiere " + entry) { returner usann }
        }
        i = i + 1
    }
    returner sann
}

funksjon terminal_launcher(app_name: tekst, macos_dir: tekst, resources_dir: tekst, welcome_title: tekst, welcome_message: tekst) -> bool {
    la launcher = "#!/usr/bin/env sh\nset -eu\nAPP_DIR=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")/..\" && pwd)\"\nRUNTIME_DIR=\"$APP_DIR/Resources/runtime\"\nCOMMAND_FILE=\"$APP_DIR/Resources/" + app_name + ".command\"\n\nif [ \"$#\" -gt 0 ]; then\n  exec /usr/bin/open -a Terminal \"$COMMAND_FILE\" --args \"$@\"\nfi\n\nexec /usr/bin/open -a Terminal \"$COMMAND_FILE\"\n"
    hvis ikkje skriv_fil(macos_dir + "/" + app_name, launcher) { returner usann }
    hvis ikkje run("chmod +x " + shell(macos_dir + "/" + app_name), "Klarte ikkje gjere launcher køyrbar") { returner usann }

    la command_body = "#!/usr/bin/env sh\nset -eu\nSCRIPT_DIR=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")\" && pwd)\"\nRUNTIME_DIR=\"$SCRIPT_DIR/runtime\"\nclear\nprintf '%s\\n' " + shell(welcome_title) + "\nprintf 'Runtime: %s\\n\\n' \"$RUNTIME_DIR\"\ncd \"$RUNTIME_DIR\"\nif [ \"$#\" -gt 0 ]; then\n  printf 'Opna frå Finder med:\\n'\n  for arg in \"$@\"; do\n    printf '  %s\\n' \"$arg\"\n  done\n  printf '\\n'\n  first_arg=\"$1\"\n  case \"$first_arg\" in\n    *.no)\n      printf 'Køyrer ./bin/nc run %s\\n\\n' \"$first_arg\"\n      exec ./bin/nc run \"$first_arg\"\n      ;;\n    *.ncb.json)\n      printf 'Viser bytekodefil: %s\\n' \"$first_arg\"\n      printf 'Bruk ./bin/nc eller eigne verktøy frå denne Terminalen.\\n\\n'\n      ;;\n    *)\n      printf 'Denne filtypen har ikkje Finder-startkontrakt i app-bundelen.\\n\\n'\n      ;;\n  esac\nfi\n\nprintf '%s\\n\\n' " + shell(welcome_message) + "\nprintf 'Vanlege kommandoar:\\n'\nprintf '  ./bin/nc --help\\n'\nprintf '  ./bin/nc test\\n'\nprintf '  ./bin/nc run app.no\\n'\nprintf '  ./bin/nc check app.no\\n'\nprintf '  ./bin/nc build app.no out.ncb.json\\n\\n'\nprintf 'Denne appen er ei utviklarflate rundt den bundla CLI-en.\\n'\nprintf 'Du er no i runtime-mappa: %s\\n\\n' \"$PWD\"\nexec \"${SHELL:-/bin/zsh}\"\n"
    hvis ikkje skriv_fil(resources_dir + "/" + app_name + ".command", command_body) { returner usann }
    returner run("chmod +x " + shell(resources_dir + "/" + app_name + ".command"), "Klarte ikkje gjere command-fil køyrbar")
}

funksjon gui_launcher(root: tekst, app_name: tekst, out_dir: tekst, macos_dir: tekst, resources_dir: tekst, runtime_dir: tekst, tmp_dir: tekst) -> bool {
    la source = root + "/platform/macos/window-host/Main.swift"
    la template = root + "/platform/macos/window-host/app.no"
    la swiftc_path = env("NORSCODE_SWIFTC")
    hvis swiftc_path == "" { swiftc_path = trim(ut(kommando("command -v swiftc"))) }
    hvis swiftc_path == "" {
        linje("Feil: manglar swiftc. Installer Xcode Command Line Tools.")
        returner usann
    }
    hvis ikkje fil_finst(source) {
        linje("Feil: manglar macOS window host-kjelder under platform/macos/window-host/")
        returner usann
    }
    hvis ikkje fil_finst(template) {
        linje("Feil: manglar macOS window host-kjelder under platform/macos/window-host/")
        returner usann
    }
    la module_cache = out_dir + "/.swift-module-cache"
    hvis ikkje run("mkdir -p " + shell(module_cache), "Klarte ikkje lage Swift module cache") { returner usann }
    hvis ikkje run(shell(swiftc_path) + " -O -module-cache-path " + shell(module_cache) + " -framework AppKit -framework WebKit " + shell(source) + " -o " + shell(macos_dir + "/" + app_name), "Klarte ikkje byggje Swift window-host") { returner usann }
    hvis ikkje run("cp " + shell(template) + " " + shell(resources_dir + "/window-app-template.no"), "Klarte ikkje kopiere window template") { returner usann }
    la env_body = "RUNTIME_ROOT=" + runtime_dir + "\nAPP_TEMPLATE=" + resources_dir + "/window-app-template.no\nNC_EXECUTABLE=" + runtime_dir + "/bin/nc\nINITIAL_PATH=/\nINITIAL_QUERY=\nSTATE_DIR=" + tmp_dir + "/window-state\n"
    returner skriv_fil(resources_dir + "/window-host.env", env_body)
}

funksjon info_plist(app_name: tekst, bundle_id: tekst, app_version: tekst, doc_source: tekst, doc_utility: tekst, doc_bytecode: tekst) -> tekst {
    returner "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n<plist version=\"1.0\">\n<dict>\n  <key>CFBundleDevelopmentRegion</key>\n  <string>nb</string>\n  <key>CFBundleDisplayName</key>\n  <string>" + app_name + "</string>\n  <key>CFBundleExecutable</key>\n  <string>" + app_name + "</string>\n  <key>CFBundleIdentifier</key>\n  <string>" + bundle_id + "</string>\n  <key>CFBundleIconFile</key>\n  <string>" + app_name + "</string>\n  <key>CFBundleName</key>\n  <string>" + app_name + "</string>\n  <key>CFBundlePackageType</key>\n  <string>APPL</string>\n  <key>CFBundleShortVersionString</key>\n  <string>" + app_version + "</string>\n  <key>CFBundleVersion</key>\n  <string>" + app_version + "</string>\n  <key>LSApplicationCategoryType</key>\n  <string>public.app-category.developer-tools</string>\n  <key>LSMinimumSystemVersion</key>\n  <string>11.0</string>\n  <key>NSHighResolutionCapable</key>\n  <true/>\n  <key>CFBundleDocumentTypes</key>\n  <array>\n    <dict>\n      <key>CFBundleTypeExtensions</key>\n      <array><string>no</string></array>\n      <key>CFBundleTypeIconFile</key>\n      <string>" + app_name + "</string>\n      <key>CFBundleTypeName</key>\n      <string>" + doc_source + "</string>\n      <key>CFBundleTypeRole</key>\n      <string>Editor</string>\n      <key>LSHandlerRank</key>\n      <string>Owner</string>\n    </dict>\n    <dict>\n      <key>CFBundleTypeExtensions</key>\n      <array><string>nc</string></array>\n      <key>CFBundleTypeIconFile</key>\n      <string>" + app_name + "</string>\n      <key>CFBundleTypeName</key>\n      <string>" + doc_utility + "</string>\n      <key>CFBundleTypeRole</key>\n      <string>Editor</string>\n      <key>LSHandlerRank</key>\n      <string>Owner</string>\n    </dict>\n    <dict>\n      <key>CFBundleTypeExtensions</key>\n      <array><string>ncb.json</string></array>\n      <key>CFBundleTypeIconFile</key>\n      <string>" + app_name + "</string>\n      <key>CFBundleTypeName</key>\n      <string>" + doc_bytecode + "</string>\n      <key>CFBundleTypeRole</key>\n      <string>Viewer</string>\n      <key>LSHandlerRank</key>\n      <string>Alternate</string>\n    </dict>\n  </array>\n</dict>\n</plist>\n"
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(ut(kommando("pwd"))) }
    la host_os = env("NORSCODE_HOST_OS")
    hvis host_os == "" { host_os = trim(ut(kommando("uname -s"))) }
    hvis host_os != "Darwin" {
        linje("Feil: build-macos-app krev macOS.")
        returner 1
    }
    hvis ikkje fil_finst(root + "/bin/nc") {
        linje("Feil: manglar " + root + "/bin/nc")
        returner 1
    }
    hvis ikkje fil_finst(root + "/dist/norscode_native") {
        linje("Feil: manglar dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed")
        returner 1
    }
    hvis ikkje ok(kommando("command -v plutil >/dev/null 2>&1")) {
        linje("Feil: manglar macOS-verktøyet plutil")
        returner 1
    }

    la app_name = env("NORSCODE_MACOS_APP_NAME")
    hvis app_name == "" { app_name = "Norscode" }
    la out_dir = env("NORSCODE_MACOS_APP_OUT")
    hvis out_dir == "" { out_dir = root + "/build/macos-app" }
    la bundle_id = env("NORSCODE_MACOS_APP_BUNDLE_ID")
    hvis bundle_id == "" { bundle_id = "dev.norscode.app" }
    la app_version = env("NORSCODE_MACOS_APP_VERSION")
    hvis app_version == "" { app_version = repo_version(root) }
    la icon_path = env("NORSCODE_MACOS_APP_ICON")
    hvis icon_path == "" { icon_path = root + "/frontend/assets/icons/norscode.icns" }
    la app_mode = env("NORSCODE_MACOS_APP_MODE")
    hvis app_mode == "" { app_mode = "gui" }
    la doc_source = env("NORSCODE_MACOS_DOC_SOURCE_NAME")
    hvis doc_source == "" { doc_source = "Norscode Source" }
    la doc_utility = env("NORSCODE_MACOS_DOC_UTILITY_NAME")
    hvis doc_utility == "" { doc_utility = "Norscode Utility Source" }
    la doc_bytecode = env("NORSCODE_MACOS_DOC_BYTECODE_NAME")
    hvis doc_bytecode == "" { doc_bytecode = "Norscode Bytecode JSON" }
    la welcome_title = env("NORSCODE_MACOS_WELCOME_TITLE")
    hvis welcome_title == "" { welcome_title = "Norscode macOS app-bundle" }
    la welcome_message = env("NORSCODE_MACOS_WELCOME_MESSAGE")
    hvis welcome_message == "" { welcome_message = "Velkomen til Norscode på macOS." }

    hvis lengde(icon_path) > 0 og icon_path[0] != "/" { icon_path = root + "/" + icon_path }
    hvis lengde(out_dir) > 0 og out_dir[0] != "/" { out_dir = root + "/" + out_dir }

    la app_dir = out_dir + "/" + app_name + ".app"
    la contents_dir = app_dir + "/Contents"
    la macos_dir = contents_dir + "/MacOS"
    la resources_dir = contents_dir + "/Resources"
    la runtime_dir = resources_dir + "/runtime"
    la tmp_dir = trim(ut(kommando("mktemp -d /tmp/norscode_macos_app.XXXXXX")))

    hvis ikkje run("rm -rf " + shell(app_dir), "Klarte ikkje rydde gammal app-bundle") { returner 1 }
    hvis ikkje run("mkdir -p " + shell(macos_dir) + " " + shell(resources_dir) + " " + shell(runtime_dir), "Klarte ikkje lage app-bundle mapper") { returner 1 }
    hvis ikkje copy_runtime(root, runtime_dir) { returner 1 }
    hvis fil_finst(icon_path) {
        hvis ikkje run("cp " + shell(icon_path) + " " + shell(resources_dir + "/" + app_name + ".icns"), "Klarte ikkje kopiere ikon") { returner 1 }
    }

    hvis app_mode == "gui" {
        hvis ikkje gui_launcher(root, app_name, out_dir, macos_dir, resources_dir, runtime_dir, tmp_dir) { returner 1 }
    } ellers hvis app_mode == "terminal" {
        hvis ikkje terminal_launcher(app_name, macos_dir, resources_dir, welcome_title, welcome_message) { returner 1 }
    } ellers {
        linje("Feil: ugyldig mode " + app_mode + " (bruk gui eller terminal)")
        returner 1
    }

    hvis ikkje skriv_fil(contents_dir + "/Info.plist", info_plist(app_name, bundle_id, app_version, doc_source, doc_utility, doc_bytecode)) { returner 1 }
    hvis ikkje run("plutil -lint " + shell(contents_dir + "/Info.plist") + " >/dev/null", "Info.plist validerte ikkje") { returner 1 }
    kommando("rm -rf " + shell(tmp_dir))

    linje("Bygde macOS app-bundle (" + app_mode + "): " + app_dir)
    linje("Start lokalt med: open " + app_dir)
    linje("Opne fil med appen: open -a " + app_dir + " path/to/fil.no")
    linje("App-versjon: " + app_version)
    returner 0
}

// tools/notarize-macos-app.no — notariser macOS artefakt

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + sti + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon fil_finst(sti: tekst) -> bool {
    returner ok(kommando("test -f " + shell(sti)))
}

funksjon krev_env(namn: tekst) -> bool {
    hvis env(namn) != "" { returner sann }
    linje("Feil: manglar miljøvariabel " + namn)
    returner usann
}

funksjon run(cmd: tekst) -> bool {
    la res = kommando(cmd)
    hvis lengde(res) > 1 og res[1] != "" { skriv(res[1]) }
    hvis lengde(res) > 2 og res[2] != "" { skriv(res[2]) }
    returner ok(res)
}

funksjon ends_with(t: tekst, ending: tekst) -> bool {
    returner builtin.ends_with(t, ending)
}

funksjon start() -> heiltall {
    la artifact = env("NORSCODE_MACOS_NOTARIZE_ARTIFACT")
    hvis artifact == "" {
        linje("Feil: manglar artefakt")
        returner 1
    }
    hvis ikkje krev_env("APPLE_ID") { returner 1 }
    hvis ikkje krev_env("APPLE_TEAM_ID") { returner 1 }
    hvis ikkje krev_env("APPLE_APP_PASSWORD") { returner 1 }

    hvis builtin.trim(kommando("uname -s")[1]) != "Darwin" {
        linje("Feil: notarize-macos-app krev macOS.")
        returner 1
    }
    hvis ikkje fil_finst(artifact) {
        linje("Feil: manglar artefakt: " + artifact)
        returner 1
    }
    hvis ikkje ok(kommando("command -v xcrun >/dev/null 2>&1")) {
        linje("Feil: manglar xcrun/notarytool")
        returner 1
    }

    linje("Notariserer artefakt: " + artifact)
    hvis ikkje run("xcrun notarytool submit " + shell(artifact) + " --apple-id " + shell(env("APPLE_ID")) + " --team-id " + shell(env("APPLE_TEAM_ID")) + " --password " + shell(env("APPLE_APP_PASSWORD")) + " --wait") {
        returner 1
    }

    hvis ends_with(artifact, ".dmg") eller ends_with(artifact, ".app") {
        linje("Staplar notarization-resultat for " + artifact)
        hvis ikkje run("xcrun stapler staple " + shell(artifact)) { returner 1 }
    } ellers {
        linje("Merk: stapling blir ikkje køyrd for denne artefakttypen.")
    }

    linje("Notarization ferdig.")
    returner 0
}

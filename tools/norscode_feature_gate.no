// tools/norscode_feature_gate.no — sjekk ny Norscode-funksjonalitet utan C/Python

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon res_felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim_tekst(t: tekst) -> tekst {
    returner trim(t)
}

funksjon executable(sti: tekst) -> bool {
    returner fil_finnes(sti)
}

funksjon sluttar_med(t: tekst, ending: tekst) -> bool {
    returner ends_with(t, ending)
}

funksjon run_stille(root: tekst, cmd: tekst) -> bool {
    la res = kommando("cd " + shell(root) + " && " + cmd + " >/dev/null")
    hvis ok(res) { returner sann }
    la ut = res_felt(res, 1)
    la feil = res_felt(res, 2)
    hvis ut != "" { skriv(ut) }
    hvis feil != "" { skriv(feil) }
    returner usann
}

funksjon feature_filer() -> liste_tekst {
    la rå = split(env("NORSCODE_FEATURE_FILES"), "\n")
    la filer: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(rå) {
        la f = trim_tekst(rå[i])
        hvis f != "" { legg_til(filer, f) }
        i = i + 1
    }
    returner filer
}

funksjon sjekk_fil(root: tekst, fil: tekst) -> bool {
    hvis sluttar_med(fil, ".no") {
        la res = kommando("cd " + shell(root) + " && ./bin/nc check " + shell(fil) + " >/dev/null")
        hvis ok(res) {
            linje("  [OK] " + fil)
            returner sann
        }
        la ut = res_felt(res, 1)
        la feil = res_felt(res, 2)
        hvis ut != "" { skriv(ut) }
        hvis feil != "" { skriv(feil) }
        linje("  [FEIL] " + fil)
        returner usann
    }

    linje("  [HOPP] " + fil + " (ikkje .no)")
    returner sann
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim_tekst(kommando("pwd")[1]) }

    hvis ikkje executable(root + "/dist/norscode_native") {
        linje("Feil: treng dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed")
        returner 1
    }

    linje("=== Norscode feature-check (utan C/Python) ===")
    linje("")

    linje("1. Policyflate...")
    hvis ikkje run_stille(root, "./bin/nc active-surface") { returner 1 }
    linje("  [OK] ingen aktiv C/Python-flate")
    linje("")

    linje("2. Seed/runtime...")
    hvis ikkje run_stille(root, "./bin/nc verify-seed") { returner 1 }
    linje("  [OK] stage-0 seed og runtime")
    linje("")

    la filer = feature_filer()
    hvis lengde(filer) > 0 {
        linje("3. Sjekkar oppgitte Norscode-filer...")
        la i: heiltall = 0
        mens i < lengde(filer) {
            hvis ikkje sjekk_fil(root, filer[i]) { returner 1 }
            i = i + 1
        }
    } ellers {
        linje("3. Ingen filer oppgitt; køyrer normal testflate...")
        hvis ikkje run_stille(root, "./bin/nc test") { returner 1 }
    }

    linje("")
    linje("=== Feature-check: BESTÅTT ===")
    returner 0
}

bruk std.sha256 som sha

funksjon env(namn: tekst) -> tekst {
    prøv { returner builtin.miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon start() -> heiltall {
    la raw = env("NORSCODE_VM_TRUST_INPUTS")
    la output = env("NORSCODE_VM_TRUST_OUTPUT")
    hvis raw == "" eller output == "" {
        skriv("Bruk NORSCODE_VM_TRUST_INPUTS=a.ncb,b.ncb NORSCODE_VM_TRUST_OUTPUT=trust.json\n")
        returner 2
    }
    la trust: ordbok_tekst = {}
    la paths = builtin.split(raw, ",")
    la i: heiltall = 0
    mens i < lengde(paths) {
        la path = builtin.trim(paths[i])
        hvis path != "" { trust[path] = sha.hash(fil_les(path)) }
        i = i + 1
    }
    fil_skriv(output, builtin.json_stringify(trust))
    skriv("vm trust store: " + output + "\n")
    returner 0
}

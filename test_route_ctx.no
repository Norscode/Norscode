bruk std.web som web

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id:int}")
    la ks = nøkler(ctx)
    la i: heiltall = 0
    la r: tekst = ""
    mens i < lengde(ks) {
        r = r + ks[i] + "=" + builtin.type(ctx[ks[i]]) + ";"
        i = i + 1
    }
    returner web.response_builder(200, {"content-type":"text/plain"}, r)
}

funksjon start() -> heiltall { returner 0 }

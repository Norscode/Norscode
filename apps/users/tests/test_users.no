import users
import users.dispatcher
import users.routes
bruk std.test som test
bruk std.web som web

funksjon test_start() {
    la r = users.start()
    assert_eq(r, 0)
}

funksjon test_routes_inneheld() {
    la ruter = routes.index()
    assert(har_nokkel(ruter, "GET /users"))
    assert(har_nokkel(ruter, "GET /api/v1/users/health"))
    assert(har_nokkel(ruter, "POST /api/v1/users/echo"))
    assert(har_nokkel(ruter, "GET /api/v1/users/openapi.json"))
    assert(har_nokkel(ruter, "GET /api/v1/users/docs"))
    assert(har_nokkel(ruter, "GET /api/v1/users/meta"))
    assert(har_nokkel(ruter, "GET /api/v1/users/dependency"))
    assert(har_nokkel(ruter, "GET /api/v1/users/error"))
    assert(har_nokkel(ruter, "GET /api/v1/users/auth/login"))
    assert(har_nokkel(ruter, "POST /api/v1/users/auth/login"))
    assert(har_nokkel(ruter, "GET /api/v1/users/auth/register"))
    assert(har_nokkel(ruter, "POST /api/v1/users/auth/register"))
    assert(har_nokkel(ruter, "POST /api/v1/users/auth/logout"))
    assert(har_nokkel(ruter, "GET /api/v1/users/profile"))
    assert(har_nokkel(ruter, "GET /api/v1/users/query"))
    assert(har_nokkel(ruter, "POST /api/v1/users/validate"))
    assert(har_nokkel(ruter, "GET /api/v1/users/items/{id}"))
    assert(har_nokkel(ruter, "POST /api/v1/users/payload"))
    assert(har_nokkel(ruter, "GET /api/v1/users/headers"))
    assert(har_nokkel(ruter, "POST /api/v1/users/nested"))
    assert(har_nokkel(ruter, "GET /api/v1/users/response-model"))
    assert(har_nokkel(ruter, "POST /api/v1/users/request-model"))
}

funksjon test_dispatch_index() {
    la ctx = web.request_context("GET", "/users", {}, {"host": "localhost"}, "")
    la svar = dispatcher.dispatcher(ctx)
    assert_eq(web.response_status(svar), 200)
}

funksjon test_api_health() {
    la ctx = web.request_context("GET", "/api/v1/users/health", {}, {"host": "localhost"}, "")
    la svar = dispatcher.dispatcher(ctx)
    la body = web.response_body(svar)
    assert_eq(web.response_status(svar), 200)
    assert(tekst_inneholder(body, "\"ok\":\"sann\""))
}

funksjon test_api_echo_payload() {
    la body = builtin.json_stringify({"melding": "hei", "app": "users"})
    la ctx = web.request_context("POST", "/api/v1/users/echo", {"content-type": "application/json"}, {"host": "localhost"}, body)
    la svar = dispatcher.dispatcher(ctx)
    la body_ut = web.response_body(svar)
    assert_eq(web.response_status(svar), 200)
    assert(tekst_inneholder(body_ut, "\"melding\":\"hei\""))
}

funksjon test_api_echo_route_feil() {
    la ctx = web.request_context("POST", "/api/v1/users/echo", {"content-type": "application/json"}, {"host": "localhost"}, "ikkje json")
    la svar = dispatcher.dispatcher(ctx)
    la body_ut = web.response_body(svar)
    assert_eq(web.response_status(svar), 422)
    assert(tekst_inneholder(body_ut, "\"error\":\"ValidationError\""))
    assert(tekst_inneholder(body_ut, "\"body må vere gyldig JSON-objekt\""))
}

funksjon test_api_openapi_route() {
    la ctx = web.request_context("GET", "/api/v1/users/openapi.json", {}, {"host": "localhost"}, "")
    la svar = dispatcher.dispatcher(ctx)
    la body = web.response_body(svar)
    assert_eq(web.response_status(svar), 200)
    assert(tekst_inneholder(body, "\"openapi\":\"3.0.3\""))
    assert(tekst_inneholder(body, "\"/api/v1/users/health\""))
    assert(tekst_inneholder(body, "\"/api/v1/users/response-model\""))
    assert(tekst_inneholder(body, "\"/api/v1/users/request-model\""))
}


funksjon index() -> ordbok_tekst {
    returner {
        "GET /users": "index",
        "GET /api/v1/users/health": "api_health",
        "POST /api/v1/users/echo": "api_echo",
        "GET /api/v1/users/openapi.json": "api_openapi",
        "GET /api/v1/users/docs": "api_docs",
        "GET /api/v1/users/meta": "api_meta",
        "GET /api/v1/users/dependency": "api_dependency",
        "GET /api/v1/users/error": "api_error",
        "GET /api/v1/users/auth/login": "api_auth_login_form",
        "POST /api/v1/users/auth/login": "api_auth_login",
        "GET /api/v1/users/auth/register": "api_auth_register_form",
        "POST /api/v1/users/auth/register": "api_auth_register",
        "POST /api/v1/users/auth/logout": "api_auth_logout",
        "GET /api/v1/users/profile": "api_auth_profile",
        "GET /api/v1/users/query": "api_query",
        "POST /api/v1/users/validate": "api_validate",
        "GET /api/v1/users/items/{id}": "api_item",
        "POST /api/v1/users/payload": "api_payload",
        "POST /api/v1/users/nested": "api_nested",
        "GET /api/v1/users/headers": "api_headers",
        "GET /api/v1/users/response-model": "api_response_model",
        "POST /api/v1/users/request-model": "api_request_model"
    }
}

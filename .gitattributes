# Force LF line endings for all source files — the Norscode lexer
# does not handle \r (CR), so CRLF checkout on Windows breaks parsing.
*.no    text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.c     text eol=lf
*.h     text eol=lf
*.txt   text eol=lf

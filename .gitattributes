# Force LF line endings for all source files — the Norscode lexer
# does not handle \r (CR), so CRLF checkout on Windows breaks parsing.
*.no    text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.c     text eol=lf
*.h     text eol=lf
*.txt   text eol=lf

# GitHub Linguist:
# GitHub viser berre språk som finst i github-linguist. Norscode er ikkje
# registrert der enno, så .no/.nors kan ikkje visast som "Norscode" i
# språkbaren berre via repo-konfig. Desse reglane held likevel genererte og
# historiske filer ute av språkstatistikken slik at aktiv kjelde tel meir.
*.ncb.json       linguist-generated=true
*.tokens.json    linguist-generated=true
*.chain.ncb.json linguist-generated=true
*.nast.json      linguist-generated=true
*.shast.json     linguist-generated=true
*.elf            linguist-generated=true
*.nui            linguist-generated=true

archive/**       linguist-vendored=true
build/**         linguist-generated=true
dist/**          linguist-generated=true
release/**       linguist-generated=true
release-artifacts/** linguist-generated=true

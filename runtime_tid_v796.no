funksjon start() -> heiltall {
    skriv("Norscode v796 tid-test\n")

    prøv {
        la t = builtin.tid()
        skriv("[OK] builtin.tid=" + t + "\n")
    } fang (e) {
        skriv("[MANGLER] builtin.tid: " + e + "\n")
    }

    prøv {
        la n = builtin.now()
        skriv("[OK] builtin.now=" + n + "\n")
    } fang (e) {
        skriv("[MANGLER] builtin.now: " + e + "\n")
    }

    prøv {
        la ts = builtin.timestamp()
        skriv("[OK] builtin.timestamp=" + ts + "\n")
    } fang (e) {
        skriv("[MANGLER] builtin.timestamp: " + e + "\n")
    }

    returner 0
}

funksjon route_login(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /auth/login")
    la app = _web_app()
    la svar = auth_login.utfør(ctx, app["conn"])
    la _ = stack.lukk(app)
    returner svar
}


bruk std.web_app_stack som stack
bruk std.web som web
bruk src.config som config
bruk src.models som models
bruk src.views som views
bruk src.forms som forms
bruk src.cache som cache
bruk src.i18n som i18n
bruk src.routes som routes_mod
bruk src.route_registry som route_registry
bruk src.static som static
bruk src.security som security
bruk src.middleware som middleware
bruk src.admin_bootstrap som admin_bootstrap
bruk src.auth.login som auth_login
bruk src.auth.register som auth_register
bruk src.auth.logout som auth_logout
bruk src.auth.guards som auth_guards

funksjon _init_app() -> ordbok_tekst {
    la app: ordbok_tekst = {}
    app["conn"] = ""
    app["register"] = {}
    returner app
}

funksjon _web_app() -> ordbok_tekst {
    la db_sti = config.database_sti()
    hvis db_sti == "" {
        db_sti = "norscode_web.db"
    }
    la app = stack.bootstrap("innstillingar.toml", db_sti)
    la _ = models.ensure_schema(app["conn"])
    app["register"] = admin_bootstrap.registrer_modellar(app["register"], app["conn"])
    returner app
}

funksjon _enkelt_html(tittel: tekst, innhald: tekst) -> ordbok_tekst {
    la html = "<!doctype html><html lang=\"no\"><head><meta charset=\"utf-8\"><title>" + tittel + "</title></head><body><main>" + innhald + "</main></body></html>"
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, html)
}

funksjon _enkelt_error(status: heiltall, feil: tekst) -> ordbok_tekst {
    la body = "{\"ok\":false,\"feil\":\"" + feil + "\"}"
    returner web.response_builder(status, {"content-type": "application/json; charset=utf-8"}, body)
}

funksjon _auth_login_form(feil: tekst) -> ordbok_tekst {
    la melding = ""
    hvis feil != "" {
        melding = "<p>" + feil + "</p>"
    }
    la innhald = melding + "<h1>Logg inn</h1><form method=\"post\" action=\"/auth/login\"><label>E-post <input name=\"epost\" type=\"email\"></label><label>Passord <input name=\"passord\" type=\"password\"></label><button type=\"submit\">Logg inn</button></form>"
    returner _enkelt_html("Logg inn", innhald)
}

funksjon _auth_register_form(feil: tekst) -> ordbok_tekst {
    la melding = ""
    hvis feil != "" {
        melding = "<p>" + feil + "</p>"
    }
    la innhald = melding + "<h1>Registrer ny brukar</h1><form method=\"post\" action=\"/auth/register\"><label>Brukarnamn <input name=\"brukarnamn\" type=\"text\"></label><label>E-post <input name=\"epost\" type=\"email\"></label><label>Passord <input name=\"passord\" type=\"password\"></label><button type=\"submit\">Registrer</button></form>"
    returner _enkelt_html("Registrer ny brukar", innhald)
}

funksjon _vedlikehald_svar() -> ordbok_tekst {
    returner _enkelt_error(503, "auth/admin er midlertidig utan bootstrap")
}

funksjon dep_app_config(ctx: ordbok_tekst) -> ordbok_tekst {
    la _ = web.dependency("app_config")
    la _ = ctx
    returner config.hent()
}

funksjon dep_request_meta(ctx: ordbok_tekst) -> ordbok_tekst {
    la _ = web.dependency("request_meta")
    returner {
        "method": web.request_method(ctx),
        "path": web.request_path(ctx),
        "request_id": web.request_id(ctx)
    }
}

funksjon route_index(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")
    returner views.index(ctx, "", {})
}


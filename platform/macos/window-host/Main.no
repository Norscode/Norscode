// platform/macos/window-host/Main.no — Norscode-entrypoint for Swift window-host

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon shell(s: tekst) -> tekst {
    returner "'" + s + "'"
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon ok(res: liste_tekst) -> bool {
    returner res[0] == "0"
}

funksjon felt(res: liste_tekst, idx: heiltall) -> tekst {
    hvis lengde(res) > idx { returner res[idx] }
    returner ""
}

funksjon trim(t: tekst) -> tekst {
    returner builtin.trim(t)
}

funksjon første_felt(t: tekst) -> tekst {
    la delar = builtin.split(trim(t), " ")
    la i = 0
    mens i < lengde(delar) {
        la d = trim(delar[i])
        hvis d != "" { returner d }
        i = i + 1
    }
    returner ""
}

funksjon fil_finst(sti: tekst) -> bool {
    prøv { returner builtin.fil_finnes(sti) } fang (e) { returner usann }
    returner usann
}

funksjon sha256(sti: tekst) -> tekst {
    returner første_felt(felt(kommando("shasum -a 256 " + shell(sti)), 1))
}

funksjon start() -> heiltall {
    la root = env("NORSCODE_ROOT")
    hvis root == "" { root = trim(felt(kommando("pwd"), 1)) }
    la source = root + "/platform/macos/window-host/Main.swift"
    hvis ikkje fil_finst(source) {
        linje("Feil: manglar Swift window-host: " + source)
        returner 1
    }
    hvis sha256(source) != "aac12743bcb9e6fb254cf5e190ca90f2030846f03bac2c3dd3b0a5e1a3acdede" {
        linje("Feil: Main.swift er endra utan å oppdatere Norscode-entrypoint")
        returner 1
    }
    linje("Main.swift er ein macOS AppKit/WebKit-plattformbro eigd av Norscode-byggaren tools/build-macos-window-host.no.")
    returner 0
}

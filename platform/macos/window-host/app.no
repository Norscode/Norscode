funksjon parse_query(query: tekst) -> ordbok_tekst {
    la resultat: ordbok_tekst = {}
    hvis query == "" {
        returner resultat
    }
    la par = builtin.split(query, "&")
    la i: heiltall = 0
    mens i < lengde(par) {
        la del = par[i]
        la eq = builtin.index_of(del, "=")
        hvis eq >= 0 {
            la nøkkel = builtin.slice(del, 0, eq)
            la verdi = builtin.slice(del, eq + 1, lengde(del))
            resultat[nøkkel] = verdi
        } ellers hvis del != "" {
            resultat[del] = ""
        }
        i = i + 1
    }
    returner resultat
}

funksjon start() -> heiltall {
    la sti = "__MAC_WINDOW_PATH__"
    la query = "__MAC_WINDOW_QUERY__"
    la query_data = parse_query(query)
    la ctx = web.request_context("GET", sti, query_data, {}, "")
    la respons = web.handle_request(ctx)
    skriv(web.response_header(respons, "content-type"))
    skriv(web.response_body(respons))
    returner 0
}

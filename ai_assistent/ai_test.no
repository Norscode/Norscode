bruk std.fil som fil

funksjon merke(sti: tekst) -> tekst {
    hvis (fil.finnes(sti)) { returner "[OK] " + sti + "\n" }
    returner "[MANGLER] " + sti + "\n"
}

funksjon start() -> heiltall {
    la rapport = "# Norscode AI testplan\n\n"
    rapport = rapport + "Dette er ein trygg testplan. Han koeyrer ikkje tunge testar automatisk.\n\n"
    rapport = rapport + "## Funn\n\n"
    rapport = rapport + merke("bin/nc")
    rapport = rapport + merke("std/fil.no")
    rapport = rapport + merke("compiler/compiler.no")
    rapport = rapport + merke("tests")
    rapport = rapport + "\n## Anbefalte kommandoar\n\n"
    rapport = rapport + "1. nc check ai_assistent/ai_prosjekt.no\n"
    rapport = rapport + "2. nc check ai_assistent/ai_plan.no\n"
    rapport = rapport + "3. nc check ai_assistent/ai_patch.no\n"
    rapport = rapport + "4. nc run ai_assistent/ai_prosjekt.no\n"
    rapport = rapport + "5. nc run ai_assistent/ai_plan.no\n"
    rapport = rapport + "6. nc run ai_assistent/ai_status.no\n"
    rapport = rapport + "7. nc run ai_assistent/ai_leser.no\n\n"
    rapport = rapport + "## Sikker regel\n\n"
    rapport = rapport + "AI skal foerst lage patch-forslag. Originalfiler skal ikkje endrast automatisk.\n"
    fil.skriv_fil("ai_assistent/testplan.txt", rapport)
    skriv("Testplan laga: ai_assistent/testplan.txt\n")
    skriv(rapport)
    returner 0
}

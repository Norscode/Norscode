# Tekst standardbibliotek

funksjon hilsen(navn: tekst) -> tekst {
    returner "Hei " + navn
}

funksjon rop(melding: tekst) -> tekst {
    returner melding + "!"
}

funksjon omgitt_av_klammer(tekstverdi: tekst) -> tekst {
    returner "[" + tekstverdi + "]"
}

funksjon ja_nei(verdi: bool) -> tekst {
    hvis (verdi) {
        returner "ja"
    }
    returner "nei"
}

funksjon tall_til_tekst(x: heltall) -> tekst {
    returner tekst_fra_heltall(x)
}

funksjon bool_til_tekst(x: bool) -> tekst {
    returner tekst_fra_bool(x)
}

funksjon starter_med(tekstverdi: tekst, prefiks: tekst) -> bool {
    returner tekst_starter_med(tekstverdi, prefiks)
}

funksjon slutter_med(tekstverdi: tekst, suffiks: tekst) -> bool {
    returner tekst_slutter_med(tekstverdi, suffiks)
}

funksjon inneholder(tekstverdi: tekst, deltekst: tekst) -> bool {
    returner tekst_inneholder(tekstverdi, deltekst)
}

funksjon trim(tekstverdi: tekst) -> tekst {
    returner tekst_trim(tekstverdi)
}

# Splitt tekst på skilletegn, returnerer liste
funksjon splitt(tekstverdi: tekst, skilletegn: tekst) -> liste_tekst {
    returner builtin.split(tekstverdi, skilletegn)
}

# Splitt på kvart teikn
funksjon teikn(tekstverdi: tekst) -> liste_tekst {
    returner builtin.split(tekstverdi, "")
}

# Slå saman liste med lim mellom kvart element
funksjon sett_saman(deler: liste_tekst, lim: tekst) -> tekst {
    returner builtin.join(deler, lim)
}

# Del ut eit utsnitt [start, slutt)
funksjon del_av(tekstverdi: tekst, start: heltall, slutt: heltall) -> tekst {
    returner builtin.slice(tekstverdi, start, slutt)
}

# Finn første posisjon av deltekst, -1 viss ikkje funne
funksjon finn(tekstverdi: tekst, deltekst: tekst) -> heltall {
    returner builtin.index_of(tekstverdi, deltekst)
}

# Erstatt alle førekomstar av gammel med ny
funksjon erstatt(tekstverdi: tekst, gammel: tekst, ny: tekst) -> tekst {
    returner tekst_erstatt(tekstverdi, gammel, ny)
}

# Til store bokstavar
funksjon til_store_bokstavar(tekstverdi: tekst) -> tekst {
    returner tekst_til_store(tekstverdi)
}

# Til små bokstavar
funksjon til_små_bokstavar(tekstverdi: tekst) -> tekst {
    returner tekst_til_liten(tekstverdi)
}

# Teiknkode for første teikn i teksten
funksjon tegn_kode(tegn: tekst) -> heltall {
    returner builtin.char_code(tegn)
}

# Tal på teikn i teksten
funksjon lengde(tekstverdi: tekst) -> heltall {
    returner builtin.lengde(tekstverdi)
}

# Gjenta tekst n gonger
funksjon gjenta(tekstverdi: tekst, n: heltall) -> tekst {
    la resultat: tekst = ""
    la i: heltall = 0
    mens (i < n) {
        resultat = resultat + tekstverdi
        i = i + 1
    }
    returner resultat
}

# Tel kor mange gonger deltekst førekjem
funksjon tell_forekomster(tekstverdi: tekst, deltekst: tekst) -> heltall {
    hvis (lengde(deltekst) == 0) {
        returner 0
    }
    la deler = builtin.split(tekstverdi, deltekst)
    returner builtin.lengde(deler) - 1
}

# Hent tekst frå tekst (alias for del_av)
funksjon substring(tekstverdi: tekst, start: heltall, slutt: heltall) -> tekst {
    returner builtin.slice(tekstverdi, start, slutt)
}

# Er teksten tom?
funksjon er_tom(tekstverdi: tekst) -> bool {
    returner builtin.lengde(tekstverdi) == 0
}

# Parse heltall frå tekst
funksjon til_heltall(tekstverdi: tekst) -> heltall {
    returner builtin.heltall_fra_tekst(tekstverdi)
}

# Fyll ut til gitt breidd med mellomrom (eller anna teikn) på høgre side (venstrejuster)
funksjon fyll_høgre(tekstverdi: tekst, breidd: heltall, fylltegn: tekst) -> tekst {
    la n: heltall = builtin.lengde(tekstverdi)
    hvis (n >= breidd) { returner tekstverdi }
    la mangler: heltall = breidd - n
    la padding: tekst = ""
    la i: heltall = 0
    mens (i < mangler) {
        padding = padding + fylltegn
        i = i + 1
    }
    returner tekstverdi + padding
}

# Fyll ut til gitt breidd på venstre side (høgrejuster)
funksjon fyll_venstre(tekstverdi: tekst, breidd: heltall, fylltegn: tekst) -> tekst {
    la n: heltall = builtin.lengde(tekstverdi)
    hvis (n >= breidd) { returner tekstverdi }
    la mangler: heltall = breidd - n
    la padding: tekst = ""
    la i: heltall = 0
    mens (i < mangler) {
        padding = padding + fylltegn
        i = i + 1
    }
    returner padding + tekstverdi
}

# Sentrer tekst i gitt breidd
funksjon senter(tekstverdi: tekst, breidd: heltall, fylltegn: tekst) -> tekst {
    la n: heltall = builtin.lengde(tekstverdi)
    hvis (n >= breidd) { returner tekstverdi }
    la total: heltall = breidd - n
    la venstre: heltall = total / 2
    la høyre: heltall = total - venstre
    la pv: tekst = ""
    la ph: tekst = ""
    la i: heltall = 0
    mens (i < venstre) {
        pv = pv + fylltegn
        i = i + 1
    }
    la j: heltall = 0
    mens (j < høyre) {
        ph = ph + fylltegn
        j = j + 1
    }
    returner pv + tekstverdi + ph
}

# Nullfyll heltall til gitt breidd (t.d. "007")
funksjon nullfyll(verdi: heltall, breidd: heltall) -> tekst {
    returner fyll_venstre(tekst_fra_heltall(verdi), breidd, "0")
}

# Fjern prefiks viss teksten startar med det
funksjon fjern_prefiks(tekstverdi: tekst, prefiks: tekst) -> tekst {
    hvis (tekst_starter_med(tekstverdi, prefiks)) {
        returner builtin.slice(tekstverdi, builtin.lengde(prefiks), builtin.lengde(tekstverdi))
    }
    returner tekstverdi
}

# Fjern suffiks viss teksten sluttar med det
funksjon fjern_suffiks(tekstverdi: tekst, suffiks: tekst) -> tekst {
    hvis (tekst_slutter_med(tekstverdi, suffiks)) {
        returner builtin.slice(tekstverdi, 0, builtin.lengde(tekstverdi) - builtin.lengde(suffiks))
    }
    returner tekstverdi
}

# Snur teksten
funksjon snu(tekstverdi: tekst) -> tekst {
    la tegn = builtin.split(tekstverdi, "")
    la n: heltall = builtin.lengde(tegn)
    la resultat: tekst = ""
    la i: heltall = n - 1
    mens (i >= 0) {
        resultat = resultat + tegn[i]
        i = i - 1
    }
    returner resultat
}

# Er teksten eit heiltal?
funksjon er_heltall(tekstverdi: tekst) -> bool {
    la n: heltall = builtin.lengde(tekstverdi)
    hvis (n == 0) { returner usann }
    la tegn = builtin.split(tekstverdi, "")
    la start: heltall = 0
    hvis (tegn[0] == "-") { start = 1 }
    hvis (start >= n) { returner usann }
    la i: heltall = start
    mens (i < n) {
        la kode: heltall = builtin.char_code(tegn[i])
        hvis (kode < 48 eller kode > 57) { returner usann }
        i = i + 1
    }
    returner sann
}

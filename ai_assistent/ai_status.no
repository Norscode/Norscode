bruk std.fil som fil

funksjon status(sti: tekst, namn: tekst) -> tekst {
    hvis (fil.finnes(sti)) {
        returner "[OK] " + namn + " -> " + sti + "\n"
    }
    returner "[MANGLER] " + namn + " -> " + sti + "\n"
}

funksjon start() -> heiltall {
    la s = "# Norscode AI samlet status\n\n"
    s = s + "Denne fila samlar status frå AI-assistenten.\n\n"
    s = s + "## Prosjekt\n\n"
    s = s + status("compiler/compiler.no", "compiler")
    s = s + status("std/fil.no", "std")
    s = s + status("tests", "tests")
    s = s + status("bin/nc", "bin/nc")
    s = s + "\n## AI-assistent filer\n\n"
    s = s + status("ai_assistent/rapport.txt", "rapport")
    s = s + status("ai_assistent/utviklingsplan.txt", "utviklingsplan")
    s = s + status("ai_assistent/testplan.txt", "testplan")
    s = s + status("ai_assistent/patch_forslag.txt", "patch-forslag")
    s = s + status("ai_assistent/logg.txt", "logg")
    s = s + status("ai_assistent/filrapport.txt", "filrapport")
    s = s + status("ai_assistent/patcher/0001_trygg_ai_leser_status.patch.txt", "patcher/0001")
    s = s + "\n## Neste steg\n\n"
    s = s + "1. Kjør ai_leser.no for å lese utvalde filer.\n"
    s = s + "2. Kjør ai_patch.no for å lage patch-forslag.\n"
    s = s + "3. Kjør ai_test.no før endringar.\n"
    s = s + "4. Ikke endre compiler automatisk enno.\n"
    fil.skriv_fil("ai_assistent/status.txt", s)
    skriv("Status laga: ai_assistent/status.txt\n")
    skriv(s)
    returner 0
}

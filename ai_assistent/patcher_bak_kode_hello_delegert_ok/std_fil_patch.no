# fil.no — trygg patch-kopi laga av Norscode AI v36
#
# Dette er ikkje aktiv std/fil.no. Dette er ein patch-kopi i ai_assistent/patcher/.
# Målet er at patch-kopien skal ha same offentlege funksjonar som originalen
# før eventuell kontrollert std-endring blir vurdert.

bruk std.filops som filops

funksjon finnes(sti: tekst) -> bool {
    prøv {
        builtin.fil_les(sti)
        returner sann
    } fang (e) {
        returner usann
    }
}

funksjon skriv_fil(sti: tekst, innhald: tekst) -> heltall {
    prøv {
        builtin.fil_skriv(sti, innhald)
        returner lengde(innhald)
    } fang (e) {
        returner 0
    }
}

funksjon les_fil(sti: tekst) -> tekst {
    prøv {
        returner builtin.fil_les(sti)
    } fang (e) {
        returner ""
    }
}

funksjon slett_fil(sti: tekst) -> bool {
    returner filops.slett_fil(sti)
}

funksjon status(sti: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    hvis (sti != null og sti != "") {
        r["gyldig"] = "sann"
    } ellers {
        r["gyldig"] = "usann"
    }
    prøv {
        builtin.fil_les(sti)
        r["finnes"] = "sann"
    } fang (e) {
        r["finnes"] = "usann"
    }
    r["sti"] = sti
    returner r
}

bruk std.fil som fil

funksjon start() -> heiltall {
    la logg = "# Norscode AI logg\n\n"
    logg = logg + "- ai_logg.no koeyrt\n"
    logg = logg + "- testplan og patch-forslag kan koeyrast trygt\n"
    logg = logg + "- originalfiler skal ikkje endrast automatisk\n"
    logg = logg + "- v4 legg til ai_leser.no, ai_status.no og patcher/\n"
    fil.skriv_fil("ai_assistent/logg.txt", logg)
    skriv("AI-logg laga: ai_assistent/logg.txt\n")
    skriv(logg)
    returner 0
}

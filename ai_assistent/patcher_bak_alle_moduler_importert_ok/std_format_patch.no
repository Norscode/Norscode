# format.no — Talformatering og lesbare einingar
# Python: locale, humanize, f-strings
#
# Bruk:
#   bruk std.format som fmt
#   skriv(fmt.tusenskille(1234567))      # => "1 234 567"
#   skriv(fmt.valuta(1234567, "kr"))     # => "12 345,67 kr"
#   skriv(fmt.filstorleik(1536000))      # => "1,5 MB"
#   skriv(fmt.tidsdelta(3725))           # => "1t 2m 5s"

# ─── Hjelp ────────────────────────────────────────────────────────────────────

funksjon _snu_tekst(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la ut: liste_tekst = []
    la i: heltall = n - 1
    mens (i >= 0) {
        legg_til(ut, teikn[i])
        i = i - 1
    }
    returner builtin.join(ut, "")
}

# ─── Tusenskille ──────────────────────────────────────────────────────────────

funksjon tusenskille(n: heltall) -> tekst {
    la negativ: bool = n < 0
    la abs_n: heltall = n
    hvis (negativ) { abs_n = -n }
    la s: tekst = tekst_fra_heltall(abs_n)
    la teikn = builtin.split(s, "")
    la len: heltall = lengde(teikn)
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < len) {
        la pos_frå_høgre: heltall = len - i
        hvis (pos_frå_høgre % 3 == 0 og i > 0) {
            legg_til(ut, " ")
        }
        legg_til(ut, teikn[i])
        i = i + 1
    }
    la resultat: tekst = builtin.join(ut, "")
    hvis (negativ) { returner "-" + resultat }
    returner resultat
}

funksjon tusenskille_komma(n: heltall) -> tekst {
    la negativ: bool = n < 0
    la abs_n: heltall = n
    hvis (negativ) { abs_n = -n }
    la s: tekst = tekst_fra_heltall(abs_n)
    la teikn = builtin.split(s, "")
    la len: heltall = lengde(teikn)
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < len) {
        la pos_frå_høgre: heltall = len - i
        hvis (pos_frå_høgre % 3 == 0 og i > 0) {
            legg_til(ut, ",")
        }
        legg_til(ut, teikn[i])
        i = i + 1
    }
    la resultat: tekst = builtin.join(ut, "")
    hvis (negativ) { returner "-" + resultat }
    returner resultat
}

# ─── Valuta (øre som heltall, f.eks. 12345 = 123,45) ─────────────────────────

funksjon valuta(øre: heltall, symbol: tekst) -> tekst {
    la negativ: bool = øre < 0
    la abs_øre: heltall = øre
    hvis (negativ) { abs_øre = -øre }
    la kroner: heltall = abs_øre / 100
    la desimal: heltall = abs_øre % 100
    la desimal_str: tekst = ""
    hvis (desimal < 10) {
        desimal_str = "0" + tekst_fra_heltall(desimal)
    } ellers {
        desimal_str = tekst_fra_heltall(desimal)
    }
    la kr_str: tekst = tusenskille(kroner)
    la resultat: tekst = kr_str + "," + desimal_str
    hvis (lengde(symbol) > 0) { resultat = resultat + " " + symbol }
    hvis (negativ) { returner "-" + resultat }
    returner resultat
}

funksjon nok(øre: heltall) -> tekst {
    returner valuta(øre, "kr")
}

funksjon eur(øre: heltall) -> tekst {
    returner valuta(øre, "€")
}

funksjon usd(øre: heltall) -> tekst {
    returner valuta(øre, "$")
}

# ─── Prosent ──────────────────────────────────────────────────────────────────
# Tek verdi * 100 (f.eks. 67 = 67%)

funksjon prosent(verdi_x100: heltall) -> tekst {
    la heile: heltall = verdi_x100 / 100
    la des: heltall = verdi_x100 % 100
    la des_str: tekst = ""
    hvis (des < 10) {
        des_str = "0" + tekst_fra_heltall(des)
    } ellers {
        des_str = tekst_fra_heltall(des)
    }
    returner tekst_fra_heltall(heile) + "," + des_str + " %"
}

funksjon prosent_enkel(verdi: heltall, total: heltall) -> tekst {
    hvis (total == 0) { returner "0 %" }
    returner tekst_fra_heltall(verdi * 100 / total) + " %"
}

# ─── Filstorleik ──────────────────────────────────────────────────────────────

funksjon filstorleik(bytes: heltall) -> tekst {
    hvis (bytes < 1024) {
        returner tekst_fra_heltall(bytes) + " B"
    }
    hvis (bytes < 1048576) {  # 1024^2
        la kb: heltall = bytes * 10 / 1024
        returner tekst_fra_heltall(kb / 10) + "," + tekst_fra_heltall(kb % 10) + " KB"
    }
    hvis (bytes < 1073741824) {  # 1024^3
        la mb: heltall = bytes * 10 / 1048576
        returner tekst_fra_heltall(mb / 10) + "," + tekst_fra_heltall(mb % 10) + " MB"
    }
    la gb: heltall = bytes * 10 / 1073741824
    returner tekst_fra_heltall(gb / 10) + "," + tekst_fra_heltall(gb % 10) + " GB"
}

# ─── Tidsdelta ────────────────────────────────────────────────────────────────

funksjon tidsdelta(sekunder: heltall) -> tekst {
    la negativ: bool = sekunder < 0
    la s: heltall = sekunder
    hvis (negativ) { s = -s }

    la dagar: heltall    = s / 86400
    la resten: heltall   = s % 86400
    la timar: heltall    = resten / 3600
    la minuttar: heltall = (resten % 3600) / 60
    la sek: heltall      = resten % 60

    la delar: liste_tekst = []
    hvis (dagar > 0)    { legg_til(delar, tekst_fra_heltall(dagar) + "d") }
    hvis (timar > 0)    { legg_til(delar, tekst_fra_heltall(timar) + "t") }
    hvis (minuttar > 0) { legg_til(delar, tekst_fra_heltall(minuttar) + "m") }
    hvis (sek > 0 eller lengde(delar) == 0) {
        legg_til(delar, tekst_fra_heltall(sek) + "s")
    }

    la resultat: tekst = builtin.join(delar, " ")
    hvis (negativ) { returner "-" + resultat }
    returner resultat
}

funksjon tidsdelta_kort(sekunder: heltall) -> tekst {
    la s: heltall = sekunder
    hvis (s < 0) { s = -s }
    la t: heltall = s / 3600
    la m: heltall = (s % 3600) / 60
    la sek: heltall = s % 60

    la t_str: tekst = tekst_fra_heltall(t)
    la m_str: tekst = ""
    la s_str: tekst = ""
    hvis (m < 10) { m_str = "0" + tekst_fra_heltall(m) } ellers { m_str = tekst_fra_heltall(m) }
    hvis (sek < 10) { s_str = "0" + tekst_fra_heltall(sek) } ellers { s_str = tekst_fra_heltall(sek) }
    returner t_str + ":" + m_str + ":" + s_str
}

# ─── Vitenskapleg notasjon ────────────────────────────────────────────────────
# Returnerer "1,23e6" for 1230000

funksjon vitenskapleg(n: heltall) -> tekst {
    hvis (n == 0) { returner "0" }
    la negativ: bool = n < 0
    la abs_n: heltall = n
    hvis (negativ) { abs_n = -n }

    la eksponent: heltall = 0
    la verdi: heltall = abs_n
    mens (verdi >= 10) {
        verdi = verdi / 10
        eksponent = eksponent + 1
    }
    # Hent to siffer etter komma
    la to_sifre: heltall = (abs_n / _potens10(eksponent - 2)) % 100
    la resultat: tekst = tekst_fra_heltall(verdi) + "," + _pad2_lokal(to_sifre) + "e" + tekst_fra_heltall(eksponent)
    hvis (negativ) { returner "-" + resultat }
    returner resultat
}

funksjon _potens10(exp: heltall) -> heltall {
    la r: heltall = 1
    la i: heltall = 0
    mens (i < exp) {
        r = r * 10
        i = i + 1
    }
    returner r
}

funksjon _pad2_lokal(n: heltall) -> tekst {
    hvis (n < 10) { returner "0" + tekst_fra_heltall(n) }
    returner tekst_fra_heltall(n)
}

# ─── Paddings og justering ────────────────────────────────────────────────────

funksjon venstre_juster(s: tekst, bredde: heltall, fyll: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la ut: tekst = s
    la i: heltall = n
    mens (i < bredde) {
        ut = ut + fyll
        i = i + 1
    }
    returner ut
}

funksjon høgre_juster(s: tekst, bredde: heltall, fyll: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la ut: tekst = ""
    la i: heltall = n
    mens (i < bredde) {
        ut = ut + fyll
        i = i + 1
    }
    returner ut + s
}

funksjon midtjuster(s: tekst, bredde: heltall, fyll: tekst) -> tekst {
    la n: heltall = lengde(builtin.split(s, ""))
    la total_fyll: heltall = bredde - n
    hvis (total_fyll <= 0) { returner s }
    la venstre: heltall = total_fyll / 2
    la høgre: heltall = total_fyll - venstre
    la v_str: tekst = ""
    la i: heltall = 0
    mens (i < venstre) { v_str = v_str + fyll  i = i + 1 }
    la h_str: tekst = ""
    la j: heltall = 0
    mens (j < høgre) { h_str = h_str + fyll  j = j + 1 }
    returner v_str + s + h_str
}

funksjon nullfyll(n: heltall, bredde: heltall) -> tekst {
    returner høgre_juster(tekst_fra_heltall(n), bredde, "0")
}

# ─── Lesbar liste ─────────────────────────────────────────────────────────────

funksjon lesbar_liste(l: liste_tekst) -> tekst {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner "" }
    hvis (n == 1) { returner l[0] }
    hvis (n == 2) { returner l[0] + " og " + l[1] }
    la delar: liste_tekst = []
    la i: heltall = 0
    mens (i < n - 1) {
        legg_til(delar, l[i])
        i = i + 1
    }
    returner builtin.join(delar, ", ") + " og " + l[n - 1]
}

# ─── Einingskonvertering ─────────────────────────────────────────────────────

funksjon km_til_mil(km: heltall) -> tekst {
    returner tekst_fra_heltall(km / 10) + "," + tekst_fra_heltall(km % 10) + " mil"
}

funksjon celsius_til_fahrenheit_x10(celsius_x10: heltall) -> heltall {
    # (C × 9/5) + 32, men * 10 for presisjon
    returner celsius_x10 * 9 / 5 + 320
}

funksjon kg_til_pund_x10(kg_x10: heltall) -> heltall {
    # 1 kg = 2.2046 pund
    returner kg_x10 * 22046 / 10000
}

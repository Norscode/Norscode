bruk std.fil som fil

funksjon start() -> heiltall {
    la plan = "# Norscode AI utviklingsplan\n\n"
    plan = plan + "Dette er ein trygg plan. Han endrar ingen prosjektfiler.\n\n"
    plan = plan + "## Prioritet 1: trygg assistent\n\n"
    plan = plan + "1. ai_prosjekt.no: sjekk prosjektstruktur.\n"
    plan = plan + "2. ai_status.no: samla status.\n"
    plan = plan + "3. ai_leser.no: les utvalde filer.\n"
    plan = plan + "4. ai_test.no: lag testplan.\n"
    plan = plan + "5. ai_patch.no: lag patch-forslag.\n\n"
    plan = plan + "## Prioritet 2: trygg kodeendring\n\n"
    plan = plan + "AI skal først lage patch i ai_assistent/patcher/.\n"
    plan = plan + "Originalfiler skal ikkje endrast automatisk.\n\n"
    plan = plan + "## Trygge mapper først\n\n"
    plan = plan + "- docs/\n- examples/\n- ai_assistent/\n- tests/ nye testfiler\n\n"
    plan = plan + "## Vent med automatisk endring\n\n"
    plan = plan + "- compiler/\n- selfhost/\n- bin/nc\n- std/runtime/\n"
    fil.skriv_fil("ai_assistent/utviklingsplan.txt", plan)
    skriv("Utviklingsplan laga: ai_assistent/utviklingsplan.txt\n")
    skriv(plan)
    returner 0
}

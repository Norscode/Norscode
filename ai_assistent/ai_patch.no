bruk std.fil som fil

funksjon start() -> heiltall {
    la p = "# Norscode AI patch-forslag v2\n\n"
    p = p + "Dette er berre eit forslag. Ingen prosjektfiler er endra.\n\n"
    p = p + "## Maal\n\n"
    p = p + "Bygge trygg AI-assistent som kan vidareutvikle Norscode stegvis.\n\n"
    p = p + "## Foreslaatt neste patch\n\n"
    p = p + "1. Bruk ai_leser.no for å lese README.md, std/fil.no og compiler/compiler.no.\n"
    p = p + "2. Bruk ai_status.no for samlet status.\n"
    p = p + "3. Lag fleire patch-forslag i ai_assistent/patcher/.\n"
    p = p + "4. Hoved-AI skal berre skrive forslag, ikkje endre compiler direkte.\n\n"
    p = p + "## Filer som kan endrast trygt foerst\n\n"
    p = p + "- docs/\n- examples/\n- ai_assistent/\n- tests/ nye testfiler\n\n"
    p = p + "## Filer som ikkje boer endrast automatisk enno\n\n"
    p = p + "- compiler/\n- selfhost/\n- bin/nc\n- std/runtime/\n"
    fil.skriv_fil("ai_assistent/patch_forslag.txt", p)
    fil.skriv_fil("ai_assistent/patcher/0001_trygg_ai_leser_status.patch.txt", p)
    skriv("Patch-forslag laga: ai_assistent/patch_forslag.txt\n")
    skriv("Patch-kopi laga: ai_assistent/patcher/0001_trygg_ai_leser_status.patch.txt\n")
    skriv(p)
    returner 0
}

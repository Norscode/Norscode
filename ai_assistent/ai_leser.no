bruk std.fil som fil

funksjon trygg_les(sti: tekst, namn: tekst) -> tekst {
    hvis (fil.finnes(sti)) {
        la innhald = fil.les_fil(sti)
        returner "## " + namn + "\n\n```\n" + innhald + "\n```\n\n"
    }
    returner "## " + namn + "\n\n[MANGLER] " + sti + "\n\n"
}

funksjon start() -> heiltall {
    la rapport = "# Norscode AI fillesing\n\n"
    rapport = rapport + "Dette er trygg lesing av utvalde filer. Ingen filer blir endra.\n\n"
    rapport = rapport + trygg_les("README.md", "README.md")
    rapport = rapport + trygg_les("std/fil.no", "std/fil.no")
    rapport = rapport + trygg_les("compiler/compiler.no", "compiler/compiler.no")
    rapport = rapport + trygg_les("ai_assistent/rapport.txt", "ai_assistent/rapport.txt")
    fil.skriv_fil("ai_assistent/filrapport.txt", rapport)
    skriv("Filrapport laga: ai_assistent/filrapport.txt\n")
    skriv(rapport)
    returner 0
}

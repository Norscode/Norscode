bruk std.fil som fil

funksjon ok(sti: tekst, namn: tekst, forklaring: tekst) -> tekst {
    hvis (fil.finnes(sti)) {
        returner "[OK] " + namn + " — " + forklaring + "\n"
    }
    returner "[MANGLER] " + namn + " — " + forklaring + "\n"
}

funksjon start() -> heiltall {
    la rapport = "# Norscode AI prosjektanalyse\n\n"
    rapport = rapport + "Dette er ein trygg automatisk rapport frå ai_assistent/ai_prosjekt.no.\n"
    rapport = rapport + "Assistenten les struktur og status, men endrar ingen viktige prosjektfiler.\n\n"
    rapport = rapport + "v4 sjekkar kjende markeringsfiler.\n\n"
    rapport = rapport + "## Viktige delar\n\n"
    rapport = rapport + ok("compiler/compiler.no", "compiler", "kompilator og språk-kjerne")
    rapport = rapport + ok("selfhost", "selfhost", "Norscode som kan byggje seg sjølv")
    rapport = rapport + ok("std/fil.no", "std", "standardbibliotek")
    rapport = rapport + ok("tests", "tests", "testar")
    rapport = rapport + ok("docs", "docs", "dokumentasjon")
    rapport = rapport + ok("frontend", "frontend", "frontend/web/UI")
    rapport = rapport + ok("backend", "backend", "backend/server/native")
    rapport = rapport + ok("Hjemmeside", "Hjemmeside", "nettside")
    rapport = rapport + ok("NorsDB", "NorsDB", "databaseprosjekt")
    rapport = rapport + ok("vscode-norscode/package.json", "vscode-norscode", "VS Code extension")
    rapport = rapport + ok("intelligence", "intelligence", "AI/intelligens-modular")
    rapport = rapport + ok("autonomous", "autonomous", "autonome agentar")
    rapport = rapport + ok("toolchain", "toolchain", "bygg/verktøykjede")
    rapport = rapport + ok("bin/nc", "bin/nc", "lokal Norscode-køyrar")
    rapport = rapport + "\n## Trygg utviklingsplan\n\n"
    rapport = rapport + "1. Analyser prosjektstruktur.\n"
    rapport = rapport + "2. Lag rapport før endring.\n"
    rapport = rapport + "3. Lag patch-fil, ikkje endre direkte.\n"
    rapport = rapport + "4. Ta backup før endring.\n"
    rapport = rapport + "5. Kjør nc check på endra filer.\n"
    rapport = rapport + "6. Kjør relevante testar.\n"
    rapport = rapport + "7. Skriv logg i ai_assistent/logg.txt.\n"
    fil.skriv_fil("ai_assistent/rapport.txt", rapport)
    skriv("Norscode AI prosjektassistent v4\n")
    skriv("Rapport laga: ai_assistent/rapport.txt\n\n")
    skriv(rapport)
    returner 0
}

// archive/legacy_c_backend/ncb_to_c.no — NCB → C (berre for stage-0-regen, ikkje brukar-CLI)
//
// Køyrast via tools/maint/regen_native.sh (L4/L6), ikkje dokumentert som dagleg kommando.
//
//   env NC_NCB_INPUT=bootstrap/kompiler.ncb.json \
//       NC_C_OUTPUT=bootstrap/maint/c/norscode_generated.c \
//       NORSCODE_CMD=run NORSCODE_FILE=archive/legacy_c_backend/ncb_to_c.no ./dist/norscode_native

funksjon ncb_safe_num_text(verdi) -> tekst {
    returner json_stringify(verdi)
}

// ─── C-runtime som vert embed i generert fil ──────────────────────────────────

funksjon c_runtime_header() -> tekst {
    // Les maintainer-runtime og embed den inline
    // Gjer norscode_generated.c heilt sjølvstendig (ei einaste C-fil)
    la runtime_sti = "archive/legacy_c_backend/nc_runtime_mini.c"
    la runtime_kode: tekst = "/* archive/legacy_c_backend/nc_runtime_mini.c ikkje funnen */\n"
    hvis fil_finnes(runtime_sti) {
        runtime_kode = fil_les(runtime_sti)
    }
    returner "/* Generert av archive/legacy_c_backend/ncb_to_c.no — IKKJE REDIGER */\n" +
        "/* archive/legacy_c_backend/nc_runtime_mini.c embedded inline */\n" +
        runtime_kode + "\n"
}

// ─── C-namnsanitisering ───────────────────────────────────────────────────────

funksjon sanitiser_namn(namn: tekst) -> tekst {
    // Modulseparatorar må aldri sleppe gjennom sjølv om eldre stage0-runtime
    // evaluerer dei samansette teiknvilkåra annleis.
    namn = builtin.replace(namn, ".", "_")
    namn = builtin.replace(namn, "/", "_")
    namn = builtin.replace(namn, "-", "_")
    la r: tekst = ""
    la i: heltall = 0
    mens i < lengde(namn) {
        la ch = builtin.slice(namn, i, i + 1)
        hvis (ch >= "a" og ch <= "z") eller (ch >= "A" og ch <= "Z") eller (ch >= "0" og ch <= "9") {
            r = r + ch
        } ellers {
            r = r + "_"
        }
        i = i + 1
    }
    // Prefix med nc_ for å unngå konfliktar
    returner "nc_fn_" + r
}

// ─── Fuzzy function lookup (same logikk som nc_vm.c fn_find) ─────────────────

funksjon løys_funksjon(namn: tekst, functions: ordbok<tekst, tekst>) -> tekst {
    // 1. Direkte treff
    hvis finnes_nøkkel(functions, namn) { returner namn }

    // 2. Fjern __main__. og søk
    la søk: tekst = namn
    hvis builtin.starts_with(namn, "__main__.") {
        søk = builtin.slice(namn, 9, lengde(namn))
    } ellers hvis builtin.starts_with(namn, "builtin.") {
        søk = builtin.slice(namn, 8, lengde(namn))
    }

    // Finn siste segment
    la siste_punkt: heltall = -1
    la si: heltall = 0
    mens si < lengde(søk) {
        hvis builtin.slice(søk, si, si + 1) == "." { siste_punkt = si }
        si = si + 1
    }
    la siste: tekst = søk
    hvis siste_punkt >= 0 { siste = builtin.slice(søk, siste_punkt + 1, lengde(søk)) }

    la nk = nøkler(functions)
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        // Suffix-treff: k sluttar med ".søk"
        hvis builtin.ends_with(k, "." + søk) { returner k }
        hvis k == søk { returner k }
        // Siste-segment
        hvis builtin.ends_with(k, "." + siste) { returner k }
        hvis k == siste { returner k }
        i = i + 1
    }
    returner namn  // fallback: behold originalt
}

// ─── Opcode → C ──────────────────────────────────────────────────────────────

funksjon opcode_til_c(instr: liste<tekst>, functions: ordbok<tekst, tekst>, ip: heltall) -> tekst {
    la op: tekst = instr[0]

    hvis op == "PUSH_CONST" {
        la verdi = instr[1]
        // Sjekk type med builtin.type for å skilje streng "0" frå heltall 0
        la vtype = builtin.type(verdi)
        hvis vtype == "boolsk" {
            hvis verdi { returner "  nc_push(&sp, stack, nc_bool(1));\n" }
            returner "  nc_push(&sp, stack, nc_bool(0));\n"
        }
        hvis vtype == "heltall" {
            returner "  nc_push(&sp, stack, nc_int(" + ncb_safe_num_text(verdi) + "LL));\n"
        }
        hvis vtype == "desimaltall" {
            returner "  nc_push(&sp, stack, nc_float(" + tekst(verdi) + "));\n"
        }
        hvis vtype == "ingenting" eller verdi == "null" {
            returner "  nc_push(&sp, stack, nc_nil());\n"
        }
        // Alt anna er tekst/streng
        la s0 = builtin.replace(tekst(verdi), "\\", "\\\\")
        la s1 = builtin.replace(s0, "\"", "\\\"")
        la s2 = builtin.replace(s1, "\n", "\\n")
        la s3 = builtin.replace(s2, "\t", "\\t")
        // Escape \r (0x0D) — bruk builtin.chr for å matche rå byte
        la s4 = builtin.replace(s3, builtin.chr(13), "\\r")
        la s5 = builtin.replace(s4, builtin.chr(0), "\\0")
        la escaped = s5
        returner "  nc_push(&sp, stack, nc_str(\"" + escaped + "\"));\n"
    }

    hvis op == "STORE_NAME" {
        returner "  nc_store(vars, varnames, &nvars, \"" + instr[1] + "\", nc_pop(&sp, stack));\n"
    }

    hvis op == "LOAD_NAME" {
        returner "  nc_push(&sp, stack, nc_load(vars, varnames, nvars, \"" + instr[1] + "\"));\n"
    }

    hvis op == "POP" {
        returner "  nc_pop(&sp, stack);\n"
    }

    hvis op == "RETURN" {
        returner "  { NcVal *_ret=nc_pop(&sp,stack); int _i; while(_try_depth>0){ _try_depth--; memcpy(&g_err_jmp,&_try_saved[_try_depth],sizeof(jmp_buf)); g_err_gc_boundary=_try_boundaries[_try_depth]; } nc_gc_frame_leave(&_gc_frame); for(_i=0;_i<nvars;_i++) free(varnames[_i]); free(_try_saved); free(_try_boundaries); free(varnames); free(vars); free(stack); return _ret; }\n"
    }

    hvis op == "LABEL" {
        returner "lbl_" + sanitiser_namn(instr[1]) + ":;\n"
    }

    hvis op == "JUMP" {
        returner "  goto lbl_" + sanitiser_namn(instr[1]) + ";\n"
    }

    hvis op == "JUMP_IF_FALSE" {
        returner "  if (!nc_truthy(nc_pop(&sp, stack))) goto lbl_" + sanitiser_namn(instr[1]) + ";\n"
    }

    hvis op == "TRY_BEGIN" {
        returner "  if(_try_depth>=32) nc_panic(\"For mange nesta try-blokker\"); memcpy(&_try_saved[_try_depth],&g_err_jmp,sizeof(jmp_buf)); _try_boundaries[_try_depth]=g_err_gc_boundary; g_err_gc_boundary=&_gc_frame; _try_depth++; if(setjmp(g_err_jmp)) goto lbl_" + sanitiser_namn(instr[1]) + ";\n"
    }

    hvis op == "TRY_END" {
        returner "  if(_try_depth>0){ _try_depth--; memcpy(&g_err_jmp,&_try_saved[_try_depth],sizeof(jmp_buf)); g_err_gc_boundary=_try_boundaries[_try_depth]; }\n"
    }

    hvis op == "LOAD_EXCEPTION" {
        returner "  nc_push(&sp,stack,nc_str(g_err_msg));\n"
    }

    hvis op == "THROW" {
        returner "  { NcVal *_exc=nc_pop(&sp,stack); char *_msg=nc_to_str_raw(_exc); char _copy[4096]; snprintf(_copy,sizeof(_copy),\"%s\",_msg); free(_msg); nc_throw(_copy); }\n"
    }

    hvis op == "BINARY_ADD" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_add(a,b)); }\n"
    }
    hvis op == "BINARY_SUB" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_sub(a,b)); }\n"
    }
    hvis op == "BINARY_MUL" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_mul(a,b)); }\n"
    }
    hvis op == "BINARY_DIV" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_div(a,b)); }\n"
    }
    hvis op == "BINARY_MOD" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_mod(a,b)); }\n"
    }
    hvis op == "BINARY_LSHIFT" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_lshift(a,b)); }\n"
    }
    hvis op == "BINARY_RSHIFT" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_rshift(a,b)); }\n"
    }
    hvis op == "BINARY_AND" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_band(a,b)); }\n"
    }
    hvis op == "BINARY_OR" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_bor(a,b)); }\n"
    }
    hvis op == "BINARY_XOR" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_bxor(a,b)); }\n"
    }
    hvis op == "UNARY_NEG" {
        returner "  { NcVal *a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_neg(a)); }\n"
    }
    hvis op == "UNARY_NOT" {
        returner "  { NcVal *a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_bool(!nc_truthy(a))); }\n"
    }

    hvis op == "COMPARE_EQ" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_bool(nc_eq(a,b))); }\n"
    }
    hvis op == "COMPARE_NE" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_bool(!nc_eq(a,b))); }\n"
    }
    hvis op == "COMPARE_LT" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_cmp(a,b,-1)); }\n"
    }
    hvis op == "COMPARE_GT" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_cmp(a,b,1)); }\n"
    }
    hvis op == "COMPARE_LE" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_cmp(a,b,-2)); }\n"
    }
    hvis op == "COMPARE_GE" {
        returner "  { NcVal *b=nc_pop(&sp,stack),*a=nc_pop(&sp,stack); nc_push(&sp,stack,nc_cmp(a,b,2)); }\n"
    }

    hvis op == "BUILD_LIST" {
        la n: tekst = "0"
        hvis lengde(instr) > 1 { n = ncb_safe_num_text(instr[1]) }
        returner "  nc_push(&sp,stack,nc_build_list(&sp,stack," + n + "));\n"
    }
    hvis op == "BUILD_MAP" {
        la n: tekst = "0"
        hvis lengde(instr) > 1 { n = ncb_safe_num_text(instr[1]) }
        returner "  nc_push(&sp,stack,nc_build_map(&sp,stack," + n + "));\n"
    }
    hvis op == "INDEX_GET" {
        returner "  { NcVal *k=nc_pop(&sp,stack),*o=nc_pop(&sp,stack); nc_push(&sp,stack,nc_index_get(o,k)); }\n"
    }
    hvis op == "INDEX_SET" {
        returner "  { NcVal *v=nc_pop(&sp,stack),*k=nc_pop(&sp,stack),*o=nc_pop(&sp,stack); nc_index_set(o,k,v); nc_push(&sp,stack,o); }\n"
    }

    hvis op == "CALL" {
        la fn_namn: tekst = instr[1]
        hvis builtin.starts_with(fn_namn, "builtin.builtin.") {
            fn_namn = builtin.slice(fn_namn, 8, lengde(fn_namn))
        }
        la nargs_int: heltall = 0
        hvis lengde(instr) > 2 { nargs_int = heltall(instr[2]) }
        la nargs: tekst = ncb_safe_num_text(nargs_int)

        // Builtin-funksjonar: direkte C-kall til nc_builtin_*
        la builtin_kart: ordbok<tekst, tekst> = {}
        builtin_kart["builtin.lengde"] = "nc_builtin_lengde"
        builtin_kart["builtin.legg_til"] = "nc_builtin_legg_til"
        builtin_kart["builtin.fjern_siste"] = "nc_builtin_fjern_siste"
        builtin_kart["builtin.fjern"] = "nc_builtin_fjern"
        builtin_kart["builtin.fjern_indeks"] = "nc_builtin_fjern"
        builtin_kart["builtin.slice"] = "nc_builtin_slice"
        builtin_kart["builtin.skriv"] = "nc_builtin_skriv"
        builtin_kart["builtin.skriv_linje"] = "nc_builtin_skriv_linje"
        builtin_kart["builtin.vent.sov"] = "nc_builtin_vent_sov"
        builtin_kart["builtin.fil_les"] = "nc_builtin_fil_les"
        builtin_kart["builtin.fil_les_binary"] = "nc_builtin_fil_les_binary"
        builtin_kart["builtin.fil_les_binær"] = "nc_builtin_fil_les_binary"
        builtin_kart["builtin.fil_skriv"] = "nc_builtin_fil_skriv"
        builtin_kart["fil_les"] = "nc_builtin_fil_les"
        builtin_kart["fil_skriv"] = "nc_builtin_fil_skriv"
        builtin_kart["builtin.builtin.fil_les"] = "nc_builtin_fil_les"
        builtin_kart["builtin.builtin.fil_skriv"] = "nc_builtin_fil_skriv"
        builtin_kart["builtin.fil_finnes"] = "nc_builtin_fil_finnes"
        builtin_kart["fil_finnes"] = "nc_builtin_fil_finnes"
        builtin_kart["builtin.miljo_hent"] = "nc_builtin_miljo_hent"
        builtin_kart["miljo_hent"] = "nc_builtin_miljo_hent"
        builtin_kart["builtin.miljo_finnes"] = "nc_builtin_miljo_finnes"
        builtin_kart["miljo_finnes"] = "nc_builtin_miljo_finnes"
        builtin_kart["builtin.exec_prosess"] = "nc_builtin_exec_prosess"
        builtin_kart["exec_prosess"] = "nc_builtin_exec_prosess"
        builtin_kart["builtin.finnes_nøkkel"] = "nc_builtin_finnes_nokkel"
        builtin_kart["builtin.har_nokkel"] = "nc_builtin_finnes_nokkel"

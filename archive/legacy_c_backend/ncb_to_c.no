        builtin_kart["builtin.json_parse_raw"] = "nc_json_parse_from_ncval"
        builtin_kart["builtin.builtin.json_parse_raw"] = "nc_json_parse_from_ncval"
        builtin_kart["builtin.fil_skriv_binær"] = "nc_builtin_fil_skriv_binary"
        builtin_kart["builtin.builtin.fil_skriv_binær"] = "nc_builtin_fil_skriv_binary"
        builtin_kart["builtin.char_code"] = "nc_builtin_char_code"
        builtin_kart["builtin.builtin.char_code"] = "nc_builtin_char_code"
        builtin_kart["builtin.chr"] = "nc_builtin_chr"
        builtin_kart["builtin.builtin.chr"] = "nc_builtin_chr"
        builtin_kart["builtin.socket_new"] = "nc_builtin_socket_new"
        builtin_kart["builtin.socket_connect"] = "nc_builtin_socket_connect"
        builtin_kart["builtin.socket_bind"] = "nc_builtin_socket_bind"
        builtin_kart["builtin.socket_listen"] = "nc_builtin_socket_listen"
        builtin_kart["builtin.socket_accept"] = "nc_builtin_socket_accept"
        builtin_kart["builtin.socket_send"] = "nc_builtin_socket_send"
        builtin_kart["builtin.socket_send_bytes"] = "nc_builtin_socket_send_bytes"
        builtin_kart["builtin.socket_recv"] = "nc_builtin_socket_recv"
        builtin_kart["builtin.socket_recv_bytes"] = "nc_builtin_socket_recv_bytes"
        builtin_kart["builtin.socket_close"] = "nc_builtin_socket_close"
        builtin_kart["builtin.socket_settimeout"] = "nc_builtin_socket_settimeout"
        builtin_kart["builtin.builtin.socket_new"] = "nc_builtin_socket_new"
        builtin_kart["builtin.builtin.socket_connect"] = "nc_builtin_socket_connect"
        builtin_kart["builtin.builtin.socket_bind"] = "nc_builtin_socket_bind"
        builtin_kart["builtin.builtin.socket_listen"] = "nc_builtin_socket_listen"
        builtin_kart["builtin.builtin.socket_accept"] = "nc_builtin_socket_accept"
        builtin_kart["builtin.builtin.socket_send"] = "nc_builtin_socket_send"
        builtin_kart["builtin.builtin.socket_send_bytes"] = "nc_builtin_socket_send_bytes"
        builtin_kart["builtin.builtin.socket_recv"] = "nc_builtin_socket_recv"
        builtin_kart["builtin.builtin.socket_recv_bytes"] = "nc_builtin_socket_recv_bytes"
        builtin_kart["builtin.builtin.socket_close"] = "nc_builtin_socket_close"
        builtin_kart["builtin.builtin.socket_settimeout"] = "nc_builtin_socket_settimeout"

        // Bruk ip i variabelnamn for å unngå kollisjonar
        la suf = ncb_safe_num_text(ip)

        // Sjekk om det er ein kjend builtin
        hvis finnes_nøkkel(builtin_kart, fn_namn) {
            la c_builtin = builtin_kart[fn_namn]
            la ut_kall: tekst = "  { "
            la ai: heltall = nargs_int - 1
            mens ai >= 0 {
                ut_kall = ut_kall + "NcVal *_a" + suf + "_" + ncb_safe_num_text(ai) + "=nc_pop(&sp,stack); "
                ai = ai - 1
            }
            ut_kall = ut_kall + "nc_push(&sp,stack," + c_builtin + "("
            la bi: heltall = 0
            mens bi < nargs_int {
                hvis bi > 0 { ut_kall = ut_kall + "," }
                ut_kall = ut_kall + "_a" + suf + "_" + ncb_safe_num_text(bi)
                bi = bi + 1
            }
            ut_kall = ut_kall + ")); }\n"
            returner ut_kall
        }

        // Struktur-konstruktørar (stor forbokstav) → tom ordbok
        la rein_namn: tekst = fn_namn
        hvis builtin.starts_with(fn_namn, "builtin.") {
            rein_namn = builtin.slice(fn_namn, 8, lengde(fn_namn))
        }
        la første_rein = builtin.slice(rein_namn, 0, 1)
        hvis første_rein >= "A" og første_rein <= "Z" {
            returner "  nc_push(&sp,stack,nc_map_new()); /* struct " + fn_namn + " */\n"
        }

        // Intern funksjon — løys fuzzy namn og bruk block-scope med ip-suffix
        la løyst = løys_funksjon(fn_namn, functions)
        la c_fn = sanitiser_namn(løyst)
        la ut_kall2: tekst = "  { "
        la ai2: heltall = nargs_int - 1
        mens ai2 >= 0 {
            ut_kall2 = ut_kall2 + "NcVal *_c" + suf + "_" + ncb_safe_num_text(ai2) + "=nc_pop(&sp,stack); "
            ai2 = ai2 - 1
        }
        hvis nargs_int > 0 {
            ut_kall2 = ut_kall2 + "NcVal *_arr" + suf + "[]={"
            la bi2: heltall = 0
            mens bi2 < nargs_int {
                hvis bi2 > 0 { ut_kall2 = ut_kall2 + "," }
                ut_kall2 = ut_kall2 + "_c" + suf + "_" + ncb_safe_num_text(bi2)
                bi2 = bi2 + 1
            }
            ut_kall2 = ut_kall2 + "}; nc_push(&sp,stack," + c_fn + "(_arr" + suf + "," + nargs + ")); }\n"
        } ellers {
            ut_kall2 = ut_kall2 + "nc_push(&sp,stack," + c_fn + "(NULL,0)); }\n"
        }
        returner ut_kall2
    }

    hvis op == "THROW" {
        returner "  { NcVal *e=nc_pop(&sp,stack); nc_throw(nc_to_str_raw(e)); }\n"
    }

    // Ukjent — kommenter ut
    returner "  /* TODO: " + op + " */\n"
}

// ─── Generer C for éin funksjon ──────────────────────────────────────────────

funksjon generer_funksjon(fn_namn: tekst, fn_def: ordbok<tekst, tekst>, functions: ordbok<tekst, tekst>) -> tekst {
    la params = fn_def["params"]
    la kode = fn_def["code"]
    la c_namn = sanitiser_namn(fn_namn)

    // Funksjonssignatur
    la ut: tekst = "static NcVal *" + c_namn + "(NcVal **args, int nargs) {\n"
    // Heap-allokerte stacks for å unngå stack overflow ved djup rekursjon
    ut = ut + "  NcVal **stack = calloc(512,sizeof(NcVal*)); int sp=0;\n"
    ut = ut + "  NcVal **vars = calloc(2048,sizeof(NcVal*)); char **varnames = calloc(2048,sizeof(char*)); int nvars=0;\n"
    ut = ut + "  NcGcFrame _gc_frame; nc_gc_frame_enter(&_gc_frame,stack,&sp,vars,&nvars);\n"
    ut = ut + "  jmp_buf *_try_saved=calloc(32,sizeof(jmp_buf)); NcGcFrame **_try_boundaries=calloc(32,sizeof(NcGcFrame*)); int _try_depth=0;\n"

    // Last inn parametrar
    la pi: heltall = 0
    mens pi < lengde(params) {
        la pnm: tekst = params[pi]
        ut = ut + "  nc_store(vars,varnames,&nvars,\"" + pnm + "\",nargs>" + ncb_safe_num_text(pi) + "?args[" + ncb_safe_num_text(pi) + "]:nc_nil());\n"
        pi = pi + 1
    }
    ut = ut + "\n"

    // Generer kode
    la ip: heltall = 0
    mens ip < lengde(kode) {
        la instr = kode[ip]
        ut = ut + opcode_til_c(instr, functions, ip)
        hvis instr[0] != "RETURN" og instr[0] != "LABEL" {
            ut = ut + "  nc_gc_safepoint();\n"
        }
        ip = ip + 1
    }

    ut = ut + "  { int _i; NcVal *_ret=nc_nil(); while(_try_depth>0){ _try_depth--; memcpy(&g_err_jmp,&_try_saved[_try_depth],sizeof(jmp_buf)); g_err_gc_boundary=_try_boundaries[_try_depth]; } nc_gc_frame_leave(&_gc_frame); for(_i=0;_i<nvars;_i++) free(varnames[_i]); free(_try_saved); free(_try_boundaries); free(varnames); free(vars); free(stack); return _ret; }\n}\n\n"
    returner ut
}

// ─── Hovudgenerator ───────────────────────────────────────────────────────────

funksjon generer_c_frå_ncb(ncb: ordbok<tekst, tekst>) -> tekst {
    la ut: tekst = c_runtime_header()
    la fns = ncb["functions"]
    la nk = nøkler(fns)

    // Forhandsdeklarasjonar
    ut = ut + "/* ── Forhandsdeklarasjonar ── */\n"
    ut = ut + "static NcVal *nc_builtin_socket_listen(NcVal *host_v, NcVal *port_v);\n"
    ut = ut + "static NcVal *nc_builtin_socket_accept(NcVal *srv_v);\n"
    ut = ut + "static NcVal *nc_builtin_socket_read(NcVal *conn_v, NcVal *max_v);\n"
    ut = ut + "static NcVal *nc_builtin_socket_write(NcVal *conn_v, NcVal *data_v);\n"
    ut = ut + "static NcVal *nc_builtin_socket_close(NcVal *conn_v);\n"
    la i: heltall = 0
    mens i < lengde(nk) {
        la fn_namn: tekst = nk[i]
        ut = ut + "static NcVal *" + sanitiser_namn(fn_namn) + "(NcVal **args, int nargs);\n"
        i = i + 1
    }
    ut = ut + "\n"

    // Funksjonsdefinisjonar
    ut = ut + "/* ── Funksjonsdefinisjonar ── */\n"
    i = 0
    mens i < lengde(nk) {
        la fn_namn: tekst = nk[i]
        ut = ut + generer_funksjon(fn_namn, fns[fn_namn], fns)
        i = i + 1
    }

    // Dispatch-tabell for host-sida
    ut = ut + "/* ── Dispatch-tabell for maintainer-host ── */\n"
    ut = ut + "typedef struct { const char *name; NcVal *(*fn)(NcVal **, int); } NcDispatch;\n"
    ut = ut + "static NcDispatch nc_dispatch[] = {\n"
    i = 0
    mens i < lengde(nk) {
        la fn_namn: tekst = nk[i]
        ut = ut + "  {\"" + fn_namn + "\", " + sanitiser_namn(fn_namn) + "},\n"
        i = i + 1
    }
    ut = ut + "  {NULL, NULL}\n"
    ut = ut + "};\n\n"

    // main() — finn best inngangspunkt
    la fns = ncb["functions"]
    la entry_fn: tekst = ""
    // Prioriter: selfhost.nc_main.start > selfhost.main.start > selfhost.kompiler.start
    hvis finnes_nøkkel(fns, "selfhost.nc_main.start") {
        entry_fn = "selfhost.nc_main.start"
    } ellers hvis finnes_nøkkel(fns, "selfhost.main.start") {
        entry_fn = "selfhost.main.start"
    } ellers hvis finnes_nøkkel(fns, "selfhost.kompiler.start") {
        entry_fn = "selfhost.kompiler.start"
    } ellers {
        la nk2 = nøkler(fns)
        la ei: heltall = 0
        mens ei < lengde(nk2) {
            la k2: tekst = nk2[ei]
            hvis builtin.ends_with(k2, ".start") og entry_fn == "" {
                entry_fn = k2
            }
            ei = ei + 1
        }
    }
    ut = ut + "/* Inngangspunkt: " + entry_fn + " */\n"
    ut = ut + "int main(int argc, char **argv) {\n"
    ut = ut + "  if (setjmp(g_err_jmp)) { fprintf(stderr, \"nc-vm feil: %s\\n\", g_err_msg); return 1; }\n"
    ut = ut + "  " + sanitiser_namn(entry_fn) + "(NULL, 0);\n"
    ut = ut + "  return 0;\n"
    ut = ut + "}\n"

    returner ut
}

// ─── Inngangspunkt ───────────────────────────────────────────────────────────

funksjon start() {
    la input_sti = miljo_hent("NC_NCB_INPUT")
    la output_sti = miljo_hent("NC_C_OUTPUT")

    hvis input_sti == "" {
        input_sti = "bootstrap/kompiler.ncb.json"
    }
    hvis output_sti == "" {
        output_sti = "dist/norscode_generated.c"
    }

    skriv("Les " + input_sti + "...\n")
    la ncb_json = fil_les(input_sti)
    la ncb = json_parse_raw(ncb_json)

    la fns = ncb["functions"]
    skriv("Funksjonar: " + ncb_safe_num_text(lengde(nøkler(fns))) + "\n")

    skriv("Genererer C...\n")
    la c_kode = generer_c_frå_ncb(ncb)

    skriv("Skriv " + output_sti + "...\n")
    fil_skriv(output_sti, c_kode)
    skriv("Done: " + ncb_safe_num_text(lengde(c_kode)) + " bytes C-kode\n")
}

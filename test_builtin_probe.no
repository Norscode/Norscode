funksjon prøv_builtin(namn: tekst) {
    prøv {
        hvis namn == "tid" {
            la x = builtin.tid()
            skriv("builtin.tid OK: " + tekst(x) + "\n")
        }
        hvis namn == "now" {
            la y = builtin.now()
            skriv("builtin.now OK: " + tekst(y) + "\n")
        }
        hvis namn == "timestamp" {
            la z = builtin.timestamp()
            skriv("builtin.timestamp OK: " + tekst(z) + "\n")
        }
    } fang (e) {
        skriv("FEIL " + namn + ": " + e + "\n")
    }
}

funksjon start() -> heiltall {
    prøv_builtin("tid")
    prøv_builtin("now")
    prøv_builtin("timestamp")
    returner 0
}

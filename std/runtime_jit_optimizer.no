# Optimaliseringspass for adaptive runtime-JIT.

funksjon er_const(op: tekst) -> boolsk {
    returner builtin.starts_with(op, "const:")
}

funksjon const_verdi(op: tekst) -> heiltall {
    returner builtin.heltall_fra_tekst(builtin.slice(op, 6, lengde(op)))
}

funksjon const_token(verdi: heiltall) -> tekst {
    returner "const:" + tekst_fra_heltall(verdi)
}

funksjon fold_pass(operations: liste_tekst) -> ordbok_tekst {
    la ut: liste_tekst = []
    la endra = usann
    la i: heiltall = 0
    mens i < lengde(operations) {
        hvis i + 2 < lengde(operations) og er_const(operations[i]) og er_const(operations[i + 1]) {
            la op = operations[i + 2]
            hvis op == "add" eller op == "sub" eller op == "mul" {
                la a = const_verdi(operations[i])
                la b = const_verdi(operations[i + 1])
                la verdi = a
                hvis op == "add" { verdi = a + b }
                ellers hvis op == "sub" { verdi = a - b }
                ellers { verdi = a * b }
                legg_til(ut, const_token(verdi))
                endra = sann
                i = i + 3
                fortsett
            }
        }
        legg_til(ut, operations[i])
        i = i + 1
    }
    returner {"operations": ut, "changed": endra}
}

funksjon identity_pass(operations: liste_tekst) -> ordbok_tekst {
    la ut: liste_tekst = []
    la endra = usann
    la i: heiltall = 0
    mens i < lengde(operations) {
        hvis i + 2 < lengde(operations) og operations[i + 1] == "const:0" og operations[i + 2] == "add" {
            legg_til(ut, operations[i])
            endra = sann
            i = i + 3
            fortsett
        }
        hvis i + 2 < lengde(operations) og operations[i + 1] == "const:1" og operations[i + 2] == "mul" {
            legg_til(ut, operations[i])
            endra = sann
            i = i + 3
            fortsett
        }
        legg_til(ut, operations[i])
        i = i + 1
    }
    returner {"operations": ut, "changed": endra}
}

funksjon register_plan(operations: liste_tekst) -> ordbok_tekst {
    la values: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(operations) {
        hvis operations[i] != "add" og operations[i] != "sub" og operations[i] != "mul" {
            values = values + 1
        }
        i = i + 1
    }
    la registers = values
    hvis registers > 8 { registers = 8 }
    la spills = values - registers
    hvis spills < 0 { spills = 0 }
    returner {"ssa_values": tekst_fra_heltall(values), "registers": tekst_fra_heltall(registers), "spills": tekst_fra_heltall(spills)}
}

funksjon optimaliser(operations: liste_tekst) -> ordbok_tekst {
    la current = operations
    la folds = 0
    la identities = 0
    la pass: heiltall = 0
    mens pass < 32 {
        la folded = fold_pass(current)
        hvis folded["changed"] { folds = folds + 1 current = folded["operations"] }
        la reduced = identity_pass(current)
        hvis reduced["changed"] { identities = identities + 1 current = reduced["operations"] }
        hvis ikkje folded["changed"] og ikkje reduced["changed"] { bryt }
        pass = pass + 1
    }
    la plan = register_plan(current)
    plan["operations"] = current
    plan["constant_folds"] = tekst_fra_heltall(folds)
    plan["identity_reductions"] = tekst_fra_heltall(identities)
    plan["passes"] = tekst_fra_heltall(pass + 1)
    returner plan
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "dekning": "iterert konstantfolding, identitetsreduksjon, SSA-livstidsanalyse, registerplan og eksplisitt spillmåling før native JIT-kompilering", "mangler": ""}
}

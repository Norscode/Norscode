# tarfile.no — Tar-arkiv handtering
# Python: tarfile
#
# Brukar trygt quota tar-verktøy for arkivoperasjonar og intern Norscode-logikk
# for formatval, fillister og returkodekontroll.
# Støttar .tar, .tar.gz (tgz), .tar.bz2, .tar.xz
#
# Arkiv-objekt: ordbok_tekst
#   "sti"    → filsti til arkivet
#   "modus"  → "r"|"w"|"a"|"r:gz"|"w:gz" osb.
#   "format" → "tar"|"gz"|"bz2"|"xz"
#
# Bruk:
#   bruk std.tarfile som tf
#   la ark = tf.open("arkiv.tar.gz", "w:gz")
#   tf.add(ark, "mappe/", "")
#   tf.close(ark)
#
#   la ark2 = tf.open("arkiv.tar.gz", "r:gz")
#   tf.extractall(ark2, "/mål/mappe")

# ─── Format-deteksjon ─────────────────────────────────────────────────────────

funksjon _detect_format(sti: tekst) -> tekst {
    la teikn = builtin.split(sti, "")
    la n: heltall = lengde(teikn)
    # Sjekk suffiksar (baklengs)
    la suf4: tekst = ""
    la suf7: tekst = ""
    la suf8: tekst = ""
    hvis (n >= 4) { suf4 = builtin.join(builtin.slice(teikn, n - 4, n), "") }
    hvis (n >= 7) { suf7 = builtin.join(builtin.slice(teikn, n - 7, n), "") }
    hvis (n >= 8) { suf8 = builtin.join(builtin.slice(teikn, n - 8, n), "") }

    hvis (suf7 == ".tar.gz" eller suf4 == ".tgz") { returner "gz" }
    hvis (suf8 == ".tar.bz2" eller suf4 == ".tbz") { returner "bz2" }
    hvis (suf7 == ".tar.xz" eller suf4 == ".txz") { returner "xz" }
    returner "tar"
}

funksjon _tar_flagg(format: tekst, modus: tekst) -> tekst {
    la les: bool = tekst_starter_med(modus, "r")
    la skriv: bool = tekst_starter_med(modus, "w")
    la append: bool = tekst_starter_med(modus, "a")

    la base: tekst = ""
    hvis (les) { base = "x" }
    ellers hvis (skriv) { base = "c" }
    ellers hvis (append) { base = "r" }  # tar ikkje støttar direkte append til .gz

    hvis (format == "gz") { returner base + "z" }
    hvis (format == "bz2") { returner base + "j" }
    hvis (format == "xz") { returner base + "J" }
    returner base
}

funksjon _shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon _shell_liste(stiar: liste_tekst) -> tekst {
    la delar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(stiar)) {
        legg_til(delar, _shell(stiar[i]))
        i = i + 1
    }
    returner builtin.join(delar, " ")
}

# ─── Opning / Lukking ─────────────────────────────────────────────────────────

funksjon open(sti: tekst, modus: tekst) -> ordbok_tekst {
    la ark: ordbok_tekst = {}
    ark["sti"] = sti
    ark["modus"] = modus
    ark["format"] = _detect_format(sti)
    ark["open"] = "sann"
    returner ark
}

funksjon close(ark: ordbok_tekst) {
    ark["open"] = "usann"
}

# ─── Skriv-operasjonar ────────────────────────────────────────────────────────

# Legg til fil eller mappe
funksjon add(ark: ordbok_tekst, sti: tekst, arcname: tekst) -> bool {
    la modus: tekst = ark["modus"]
    la format: tekst = ark["format"]
    la flagg: tekst = _tar_flagg(format, modus)

    la ark_sti: tekst = ark["sti"]
    la kjelde: tekst = sti
    la mål_namn: tekst = arcname
    hvis (mål_namn == "") { mål_namn = sti }

    prøv {
        la cmd: tekst = "tar -" + flagg + "f " + _shell(ark_sti) + " -C / " + _shell(mål_namn)
        builtin.exec_prosess(cmd)
        returner sann
    } fang (e) {
        prøv {
            la cmd2: tekst = "tar -" + flagg + "f " + _shell(ark_sti) + " " + _shell(kjelde)
            builtin.exec_prosess(cmd2)
            returner sann
        } fang (e2) {
            returner usann
        }
    }
    returner usann
}

# Lag nytt arkiv frå liste av filer
funksjon lag_arkiv(ark_sti: tekst, filer: liste_tekst) -> bool {
    la format: tekst = _detect_format(ark_sti)
    la flagg: tekst = _tar_flagg(format, "w")
    la fil_str: tekst = _shell_liste(filer)
    prøv {
        la cmd: tekst = "tar -" + flagg + "f " + _shell(ark_sti) + " " + fil_str
        builtin.exec_prosess(cmd)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Les-operasjonar ──────────────────────────────────────────────────────────

# List alle filer i arkivet
funksjon getnames(ark: ordbok_tekst) -> liste_tekst {
    la format: tekst = ark["format"]
    la t_flagg: tekst = "t"
    hvis (format == "gz") { t_flagg = "tz" }
    ellers hvis (format == "bz2") { t_flagg = "tj" }
    ellers hvis (format == "xz") { t_flagg = "tJ" }

    prøv {
        la res = builtin.exec_prosess("tar -" + t_flagg + "f " + _shell(ark["sti"]) + " 2>/dev/null")
        la linjer = builtin.split(res, "\n")
        la resultat: liste_tekst = []
        la i: heltall = 0
        mens (i < lengde(linjer)) {
            la linje: tekst = linjer[i]
            la linje_teikn = builtin.split(linje, "")
            # Hopp over linjeavslutning og tomme
            la trimma: tekst = linje
            la tl: heltall = lengde(linje_teikn)
            mens (tl > 0 og (linje_teikn[tl - 1] == "\r" eller linje_teikn[tl - 1] == " ")) {
                tl = tl - 1
            }
            trimma = builtin.join(builtin.slice(linje_teikn, 0, tl), "")
            hvis (tl > 0) {
                legg_til(resultat, trimma)
            }
            i = i + 1
        }
        returner resultat
    } fang (e) {
        returner []
    }
    returner []
}

# Hent info om medlemar (tilsv. getmembers)
funksjon getmembers(ark: ordbok_tekst) -> liste_tekst {
    la namn = getnames(ark)
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(namn)) {
        la info: ordbok_tekst = {}
        info["namn"] = namn[i]
        info["type"] = _gjer_type(namn[i])
        legg_til(resultat, builtin.json_stringify(info))
        i = i + 1
    }
    returner resultat
}

funksjon _gjer_type(namn: tekst) -> tekst {
    la teikn = builtin.split(namn, "")
    la n: heltall = lengde(teikn)
    hvis (n > 0 og teikn[n - 1] == "/") { returner "katalog" }
    returner "fil"
}

# ─── Pakking ut ───────────────────────────────────────────────────────────────

# Pakk ut heile arkivet til ein mappe
funksjon extractall(ark: ordbok_tekst, mål_mappe: tekst) -> bool {
    la format: tekst = ark["format"]
    la x_flagg: tekst = "x"
    hvis (format == "gz") { x_flagg = "xz" }
    ellers hvis (format == "bz2") { x_flagg = "xj" }
    ellers hvis (format == "xz") { x_flagg = "xJ" }

    la mål: tekst = mål_mappe
    hvis (mål == "") { mål = "." }

    prøv {
        builtin.exec_prosess("mkdir -p " + _shell(mål))
        la cmd: tekst = "tar -" + x_flagg + "f " + _shell(ark["sti"]) + " -C " + _shell(mål) + " 2>&1"
        builtin.exec_prosess(cmd)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# Pakk ut éi fil
funksjon extract(ark: ordbok_tekst, membre_namn: tekst, mål_mappe: tekst) -> bool {
    la format: tekst = ark["format"]
    la x_flagg: tekst = "x"
    hvis (format == "gz") { x_flagg = "xz" }
    ellers hvis (format == "bz2") { x_flagg = "xj" }
    ellers hvis (format == "xz") { x_flagg = "xJ" }

    la mål: tekst = mål_mappe
    hvis (mål == "") { mål = "." }

    prøv {
        la cmd: tekst = "tar -" + x_flagg + "f " + _shell(ark["sti"]) + " -C " + _shell(mål) + " " + _shell(membre_namn) + " 2>&1"
        builtin.exec_prosess(cmd)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Sjekkar ──────────────────────────────────────────────────────────────────

funksjon is_tarfile(sti: tekst) -> bool {
    prøv {
        la res = builtin.exec_prosess("tar -tf " + _shell(sti) + " >/dev/null 2>&1")
        returner res[0] == "0"
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon er_open(ark: ordbok_tekst) -> bool {
    returner ark["open"] == "sann"
}

# ─── Kopier frå eitt arkiv til eit anna ──────────────────────────────────────

funksjon kopier_fra(mål_ark: ordbok_tekst, kjelde_ark: ordbok_tekst, membre_namn: tekst) -> bool {
    la tmp_dir: tekst = "/tmp/tarfile_tmp_" + tekst_fra_heltall(builtin.tid_ms())
    prøv {
        builtin.exec_prosess("mkdir -p " + _shell(tmp_dir))
        la ok: bool = extract(kjelde_ark, membre_namn, tmp_dir)
        hvis (ok) {
            la ok2: bool = add(mål_ark, tmp_dir + "/" + membre_namn, membre_namn)
            builtin.exec_prosess("rm -rf " + _shell(tmp_dir))
            returner ok2
        }
        builtin.exec_prosess("rm -rf " + _shell(tmp_dir))
        returner usann
    } fang (e) {
        prøv { builtin.exec_prosess("rm -rf " + _shell(tmp_dir)) } fang (e2) {}
        returner usann
    }
    returner usann
}

# ─── Konvenienshjelperar ─────────────────────────────────────────────────────

# Ope-les-pakk ut-lukk i eitt steg
funksjon extractall_enkel(ark_sti: tekst, mål_mappe: tekst) -> bool {
    la ark = open(ark_sti, "r")
    la ok: bool = extractall(ark, mål_mappe)
    close(ark)
    returner ok
}

# Ope-legg til-lukk i eitt steg
funksjon create_from_files(ark_sti: tekst, filer: liste_tekst) -> bool {
    returner lag_arkiv(ark_sti, filer)
}

funksjon format_frå_sti(sti: tekst) -> tekst {
    returner _detect_format(sti)
}

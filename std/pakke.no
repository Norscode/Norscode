# pakke.no — Tredjepartspakkeøkosystem for Norscode
# pip / npm / cargo-ekvivalent
#
# Bruk (som bibliotek):
#   bruk std.pakke som pakke
#   la meta = pakke.les_meta("pakke.json")
#   pakke.installer_alle(meta)
#
# CLI (via nc-kommandoar):
#   nc pakke installer minpakke
#   nc pakke publiser
#   nc pakke søk mønster

# ─── Pakke.json / manifest ────────────────────────────────────────────────────

funksjon les_meta(sti: tekst) -> ordbok_tekst {
    prøv {
        la innhald = builtin.fil_les(sti)
        la parsed  = builtin.json_parse_raw(innhald)
        returner parsed
    } fang (e) {
        la tom: ordbok_tekst = {}
        returner tom
    }
    la tom: ordbok_tekst = {}
    returner tom
}

funksjon skriv_meta(sti: tekst, meta: ordbok_tekst) -> heltall {
    la nk = nøkler(meta)
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        la v = tekst(meta[k])
        // Bestem om verdi er streng eller objekt/tal
        la er_tall = prøv_heltall(v)
        la er_obj = tekst_starter_med(v, "{") eller tekst_starter_med(v, "[")
        hvis er_tall eller er_obj {
            legg_til(delar, "  \"" + k + "\": " + v)
        } ellers {
            legg_til(delar, "  \"" + k + "\": \"" + tekst_erstatt(v, "\"", "\\\"") + "\"")
        }
        i = i + 1
    }
    builtin.fil_skriv(sti, "{\n" + tekst_saman(delar, ",\n") + "\n}\n")
    returner 0
}

funksjon ny_meta(namn: tekst, versjon: tekst, beskriving: tekst) -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["namn"]        = namn
    m["versjon"]     = versjon
    m["beskriving"]  = beskriving
    m["forfattar"]   = ""
    m["lisens"]      = "MIT"
    m["avhengigheiter"] = "{}"
    m["dev_avhengigheiter"] = "{}"
    m["hovud"]       = "main.no"
    m["norscode_versjon"] = ">=1.0.0"
    returner m
}

funksjon legg_til_avhengigheit(meta: ordbok_tekst, pakke_namn: tekst, versjon_krav: tekst) -> heltall {
    prøv {
        la eksist = builtin.json_parse_raw(tekst(meta["avhengigheiter"]))
        eksist[pakke_namn] = versjon_krav
        la nk = nøkler(eksist)
        la delar: liste<tekst> = []
        la i: heltall = 0
        mens i < lengde(nk) {
            la k: tekst = nk[i]
            legg_til(delar, "\"" + k + "\":\"" + tekst(eksist[k]) + "\"")
            i = i + 1
        }
        meta["avhengigheiter"] = "{" + tekst_saman(delar, ",") + "}"
        returner 0
    } fang (e) {
        meta["avhengigheiter"] = "{\"" + pakke_namn + "\":\"" + versjon_krav + "\"}"
        returner 0
    }
    returner 0
}

# ─── Versjonering ─────────────────────────────────────────────────────────────

funksjon parse_versjon(v: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la delar = builtin.split(v, ".")
    r["major"] = "0"
    hvis lengde(delar) > 0 {
        r["major"] = builtin.trim(delar[0])
    }
    r["minor"] = "0"
    hvis lengde(delar) > 1 {
        r["minor"] = builtin.trim(delar[1])
    }
    r["patch"] = "0"
    hvis lengde(delar) > 2 {
        r["patch"] = builtin.trim(delar[2])
    }
    returner r
}

funksjon versjon_samsvar(krav: tekst, tilgjengeleg: tekst) -> boolsk {
    // Støttar: ^1.2.3, >=1.0.0, ~1.2, 1.2.3, *
    la k = builtin.trim(krav)
    hvis k == "*" eller k == "" { returner sann }

    la op: tekst = ""
    la versjon_str: tekst = k

    hvis tekst_starter_med(k, "^") {
        op = "^"
        versjon_str = builtin.slice(k, 1, lengde(k))
    } ellers hvis tekst_starter_med(k, ">=") {
        op = ">="
        versjon_str = builtin.slice(k, 2, lengde(k))
    } ellers hvis tekst_starter_med(k, "<=") {
        op = "<="
        versjon_str = builtin.slice(k, 2, lengde(k))
    } ellers hvis tekst_starter_med(k, ">") {
        op = ">"
        versjon_str = builtin.slice(k, 1, lengde(k))
    } ellers hvis tekst_starter_med(k, "~") {
        op = "~"
        versjon_str = builtin.slice(k, 1, lengde(k))
    }

    la krav_v = parse_versjon(versjon_str)
    la tilg_v = parse_versjon(tilgjengeleg)

    la krav_major = heltall_fra_tekst(krav_v["major"])
    la krav_minor = heltall_fra_tekst(krav_v["minor"])
    la krav_patch = heltall_fra_tekst(krav_v["patch"])
    la tilg_major = heltall_fra_tekst(tilg_v["major"])
    la tilg_minor = heltall_fra_tekst(tilg_v["minor"])
    la tilg_patch = heltall_fra_tekst(tilg_v["patch"])

    hvis op == "^" {
        // Kompatibel med same major-versjon
        returner tilg_major == krav_major og (tilg_minor > krav_minor eller (tilg_minor == krav_minor og tilg_patch >= krav_patch))
    }
    hvis op == ">=" {
        returner tilg_major > krav_major eller (tilg_major == krav_major og (tilg_minor > krav_minor eller (tilg_minor == krav_minor og tilg_patch >= krav_patch)))
    }
    hvis op == "~" {
        // Kompatibel med same major.minor
        returner tilg_major == krav_major og tilg_minor == krav_minor og tilg_patch >= krav_patch
    }
    // Eksakt match
    returner tilg_major == krav_major og tilg_minor == krav_minor og tilg_patch == krav_patch
}

funksjon neste_versjon(gjeldande: tekst, type: tekst) -> tekst {
    la v = parse_versjon(gjeldande)
    la major = heltall_fra_tekst(v["major"])
    la minor = heltall_fra_tekst(v["minor"])
    la patch = heltall_fra_tekst(v["patch"])
    hvis type == "major" {
        returner tekst(major + 1) + ".0.0"
    }
    hvis type == "minor" {
        returner tekst(major) + "." + tekst(minor + 1) + ".0"
    }
    returner tekst(major) + "." + tekst(minor) + "." + tekst(patch + 1)
}

# ─── Installasjon ─────────────────────────────────────────────────────────────

funksjon installer(pakke_namn: tekst, versjon_krav: tekst, pakke_mappe: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la url = _pakke_url(pakke_namn, versjon_krav)
    prøv {
        la resp = builtin.http_get(url)
        la status = heltall_fra_tekst(tekst(resp["status"]))
        hvis status == 200 {
            la mål_mappe = pakke_mappe + "/" + pakke_namn
            builtin.mappe_opprett(mål_mappe)
            la innhald = tekst(resp["body"])
            // Pakk ut (builtin handterer tar.gz)
            builtin.pakk_ut(innhald, mål_mappe)
            r["ok"]     = "sann"
            r["pakke"]  = pakke_namn
            r["mappe"]  = mål_mappe
        } ellers {
            r["ok"]   = "usann"
            r["feil"] = "HTTP " + tekst(status) + " frå registeret"
        }
    } fang (e) {
        r["ok"]   = "usann"
        r["feil"] = tekst(e)
    }
    returner r
}

funksjon installer_alle(meta: ordbok_tekst) -> liste<ordbok_tekst> {
    la resultat: liste<ordbok_tekst> = []
    prøv {
        la avh = builtin.json_parse_raw(tekst(meta["avhengigheiter"]))
        la nk = nøkler(avh)
        la i: heltall = 0
        mens i < lengde(nk) {
            la pakke_namn: tekst = nk[i]
            la versjon_krav = tekst(avh[pakke_namn])
            la r = installer(pakke_namn, versjon_krav, "nc_pakkar")
            legg_til(resultat, r)
            i = i + 1
        }
    } fang (e) { }
    returner resultat
}

# ─── Pakkeregister-søk ────────────────────────────────────────────────────────

funksjon søk(spørjing: tekst) -> liste<ordbok_tekst> {
    la url = _register_url() + "/søk?q=" + builtin.url_encode(spørjing)
    prøv {
        la resp = builtin.http_get(url)
        la status = heltall_fra_tekst(tekst(resp["status"]))
        hvis status == 200 {
            la parsed = builtin.json_parse_raw(tekst(resp["body"]))
            returner parsed
        }
    } fang (e) { }
    returner []
}

funksjon info(pakke_namn: tekst) -> ordbok_tekst {
    la url = _register_url() + "/pakke/" + pakke_namn
    prøv {
        la resp = builtin.http_get(url)
        la status = heltall_fra_tekst(tekst(resp["status"]))
        hvis status == 200 {
            returner builtin.json_parse_raw(tekst(resp["body"]))
        }
    } fang (e) { }
    la tom: ordbok_tekst = {}
    returner tom
}

# ─── Publisering ──────────────────────────────────────────────────────────────

funksjon publiser(meta_sti: tekst, api_nøkkel: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la meta = les_meta(meta_sti)
    la namn = tekst(meta["namn"])
    la versjon = tekst(meta["versjon"])

    // Pakk saman filane
    prøv {
        la arkiv = builtin.pakk_saman(".", namn + "-" + versjon + ".tar.gz")
        la url = _register_url() + "/publiser"
        la headers: ordbok_tekst = {}
        headers["Authorization"] = "Bearer " + api_nøkkel
        headers["Content-Type"]  = "application/octet-stream"
        la resp = builtin.http_post_raw(url, headers, arkiv)
        la status = heltall_fra_tekst(tekst(resp["status"]))
        r["ok"] = "usann"
        hvis status == 200 eller status == 201 {
            r["ok"] = "sann"
        }
        r["pakke"]   = namn
        r["versjon"] = versjon
        r["status"]  = tekst(status)
    } fang (e) {
        r["ok"]   = "usann"
        r["feil"] = tekst(e)
    }
    returner r
}

# ─── Lokal pakkeliste ─────────────────────────────────────────────────────────

funksjon lista_installerte(pakke_mappe: tekst) -> liste<ordbok_tekst> {
    la pakkane: liste<ordbok_tekst> = []
    prøv {
        la mapper = builtin.les_mappe(pakke_mappe)
        la i: heltall = 0
        mens i < lengde(mapper) {
            la namn: tekst = mapper[i]
            la meta_sti = pakke_mappe + "/" + namn + "/pakke.json"
            prøv {
                la meta = les_meta(meta_sti)
                legg_til(pakkane, meta)
            } fang (e) {
                la enkel: ordbok_tekst = {}
                enkel["namn"] = namn
                enkel["versjon"] = "ukjend"
                legg_til(pakkane, enkel)
            }
            i = i + 1
        }
    } fang (e) { }
    returner pakkane
}

funksjon sjekk_utdaterte(meta: ordbok_tekst) -> liste<ordbok_tekst> {
    la utdaterte: liste<ordbok_tekst> = []
    prøv {
        la avh = builtin.json_parse_raw(tekst(meta["avhengigheiter"]))
        la nk = nøkler(avh)
        la i: heltall = 0
        mens i < lengde(nk) {
            la pakke_namn: tekst = nk[i]
            la lokalt_krav = tekst(avh[pakke_namn])
            la pakke_info = info(pakke_namn)
            la siste = tekst(pakke_info["siste_versjon"])
            la gjeldande_krav_str = builtin.trim(tekst_erstatt(tekst_erstatt(tekst_erstatt(lokalt_krav, "^", ""), "~", ""), ">=", ""))
            hvis siste != "" og ikkje versjon_samsvar(lokalt_krav, siste) {
                la u: ordbok_tekst = {}
                u["pakke"]   = pakke_namn
                u["krav"]    = lokalt_krav
                u["siste"]   = siste
                legg_til(utdaterte, u)
            }
            i = i + 1
        }
    } fang (e) { }
    returner utdaterte
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _register_url() -> tekst {
    prøv {
        la url = builtin.env("NC_REGISTER_URL")
        hvis url != "" { returner url }
    } fang (e) { }
    returner "https://register.norscode.no"
}

funksjon _pakke_url(namn: tekst, versjon_krav: tekst) -> tekst {
    la v = builtin.trim(tekst_erstatt(tekst_erstatt(versjon_krav, "^", ""), "~", ""))
    returner _register_url() + "/pakke/" + namn + "/" + v + ".tar.gz"
}

funksjon prøv_heltall(s: tekst) -> boolsk {
    prøv {
        heltall_fra_tekst(s)
        returner sann
    } fang (e) { returner usann }
    returner usann
}

# ─── Lockfile (pakke.lock) ────────────────────────────────────────────────────

funksjon generer_lock(pakkar: liste<ordbok_tekst>) -> tekst {
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(pakkar) {
        la p: ordbok_tekst = pakkar[i]
        la namn    = tekst(p["namn"])
        la versjon = tekst(p["versjon"])
        la kjelde  = tekst(p["kjelde"])
        la sjekksum = tekst(p["sjekksum"])
        legg_til(delar, namn + "@" + versjon + " " + kjelde + " " + sjekksum)
        i = i + 1
    }
    returner tekst_saman(delar, "\n") + "\n"
}

funksjon les_lock(sti: tekst) -> liste<ordbok_tekst> {
    la pakkar: liste<ordbok_tekst> = []
    prøv {
        la innhald = builtin.fil_les(sti)
        la linjer = builtin.split(innhald, "\n")
        la i: heltall = 0
        mens i < lengde(linjer) {
            la linje = builtin.trim(linjer[i])
            hvis linje != "" og ikkje tekst_starter_med(linje, "#") {
                la delar = builtin.split(linje, " ")
                la pakk_ver = builtin.split(delar[0], "@")
                la p: ordbok_tekst = {}
                p["namn"]     = pakk_ver[0]
                p["versjon"] = ""
                hvis lengde(pakk_ver) > 1 {
                    p["versjon"] = pakk_ver[1]
                }
                p["kjelde"] = ""
                hvis lengde(delar) > 1 {
                    p["kjelde"] = delar[1]
                }
                p["sjekksum"] = ""
                hvis lengde(delar) > 2 {
                    p["sjekksum"] = delar[2]
                }
                legg_til(pakkar, p)
            }
            i = i + 1
        }
    } fang (e) { }
    returner pakkar
}

funksjon skriv_lock(sti: tekst, pakkar: liste<ordbok_tekst>) -> heltall {
    builtin.fil_skriv(sti, generer_lock(pakkar))
    returner lengde(pakkar)
}

funksjon lock_er_gyldig(lock_sti: tekst, meta: ordbok_tekst) -> boolsk {
    prøv {
        la lock_pakkar = les_lock(lock_sti)
        la avh = builtin.json_parse_raw(tekst(meta["avhengigheiter"]))
        la nk = nøkler(avh)
        // Alle avhengigheiter i meta må finst i lock
        la i: heltall = 0
        mens i < lengde(nk) {
            la pakke_namn: tekst = nk[i]
            la funne = usann
            la j: heltall = 0
            mens j < lengde(lock_pakkar) {
                la p: ordbok_tekst = lock_pakkar[j]
                hvis tekst(p["namn"]) == pakke_namn { funne = sann }
                j = j + 1
            }
            hvis ikkje funne { returner usann }
            i = i + 1
        }
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon installer_frå_lock(lock_sti: tekst, pakke_mappe: tekst) -> liste<ordbok_tekst> {
    la resultat: liste<ordbok_tekst> = []
    la pakkar = les_lock(lock_sti)
    la i: heltall = 0
    mens i < lengde(pakkar) {
        la p: ordbok_tekst = pakkar[i]
        la namn    = tekst(p["namn"])
        la versjon = tekst(p["versjon"])
        la kjelde  = tekst(p["kjelde"])
        la r = installer_frå_kjelde(namn, versjon, kjelde, pakke_mappe)
        legg_til(resultat, r)
        i = i + 1
    }
    returner resultat
}

# ─── Lokal og git-install ──────────────────────────────────────────────────────

funksjon installer_lokal(sti: tekst, pakke_mappe: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    prøv {
        la meta_sti = sti + "/pakke.json"
        la meta = les_meta(meta_sti)
        la namn    = tekst(meta["namn"])
        la versjon = tekst(meta["versjon"])
        la mål     = pakke_mappe + "/" + namn
        builtin.mappe_kopier(sti, mål)
        r["ok"]      = "sann"
        r["pakke"]   = namn
        r["versjon"] = versjon
        r["kjelde"]  = sti
    } fang (e) {
        r["ok"]   = "usann"
        r["feil"] = tekst(e)
    }
    returner r
}

funksjon installer_git(git_url: tekst, pakke_mappe: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    // git_url-format: git+https://github.com/brukar/repo#versjon
    la faktisk_url = tekst_erstatt(git_url, "git+", "")
    la hasj = builtin.index_of(faktisk_url, "#")
    la url = faktisk_url
    hvis hasj >= 0 {
        url = builtin.slice(faktisk_url, 0, hasj)
    }
    la ref = "main"
    hvis hasj >= 0 {
        ref = builtin.slice(faktisk_url, hasj + 1, lengde(faktisk_url))
    }
    prøv {
        la temp_mappe = builtin.temp_mappe()
        builtin.git_clone(url, temp_mappe, ref)
        la meta = les_meta(temp_mappe + "/pakke.json")
        la namn    = tekst(meta["namn"])
        la versjon = tekst(meta["versjon"])
        la mål = pakke_mappe + "/" + namn
        builtin.mappe_kopier(temp_mappe, mål)
        builtin.slett_mappe(temp_mappe)
        r["ok"]      = "sann"
        r["pakke"]   = namn
        r["versjon"] = versjon
        r["kjelde"]  = git_url
    } fang (e) {
        r["ok"]   = "usann"
        r["feil"] = tekst(e)
    }
    returner r
}

funksjon installer_frå_kjelde(namn: tekst, versjon: tekst, kjelde: tekst, pakke_mappe: tekst) -> ordbok_tekst {
    // Lokal sti
    hvis tekst_starter_med(kjelde, "./") eller tekst_starter_med(kjelde, "/") {
        returner installer_lokal(kjelde, pakke_mappe)
    }
    // Git-URL
    hvis tekst_starter_med(kjelde, "git+") {
        returner installer_git(kjelde, pakke_mappe)
    }
    // Registry
    returner installer(namn, versjon, pakke_mappe)
}

funksjon installer_med_lock(namn: tekst, versjon_krav: tekst, pakke_mappe: tekst) -> ordbok_tekst {
    la r = installer(namn, versjon_krav, pakke_mappe)
    // Oppdater pakke.lock
    prøv {
        la lock_sti = "pakke.lock"
        la eksist   = les_lock(lock_sti)
        // Fjern gammal entry for same pakke
        la ny: liste<ordbok_tekst> = []
        la i: heltall = 0
        mens i < lengde(eksist) {
            la p: ordbok_tekst = eksist[i]
            hvis tekst(p["namn"]) != namn { legg_til(ny, p) }
            i = i + 1
        }
        la ny_entry: ordbok_tekst = {}
        ny_entry["namn"]     = namn
        ny_entry["versjon"]  = tekst(r["versjon"])
        ny_entry["kjelde"]   = _register_url() + "/pakke/" + namn + "/" + tekst(r["versjon"]) + ".tar.gz"
        ny_entry["sjekksum"] = ""
        legg_til(ny, ny_entry)
        skriv_lock(lock_sti, ny)
    } fang (e) { }
    returner r
}

# plistlib.no — Apple Property List (plist) parsing og skriving
# Python: plistlib
#
# Les og skriv XML-plist og binære plist-filer (binære via plutil).
# Alle verdiar representert som ordbok_tekst.
#
# Bruk:
#   bruk std.plistlib som plist
#   la data = plist.les_fil("/path/til/fil.plist")
#   la verdi = plist.get(data, "NøkkelNamn")
#   plist.skriv_fil("/path/til/ut.plist", data)

# ─── Plist-datastruktur ───────────────────────────────────────────────────────
#
# Norscode-representasjon:
#   ordbok_tekst med nøklar frå plist-fila.
#   Verdiar er alltid tekst (konvertert frå plist-typar).
#   Nestede ordbokar: JSON-streng i verdien, prefiks "dict:"
#   Lister: JSON-streng, prefiks "array:"
#   Boolar: "true" / "false"
#   Tal: tekst-representasjon
#   Datoar: ISO 8601-tekst

# Les ein plist-fil → ordbok_tekst
funksjon les_fil(sti: tekst) -> ordbok_tekst {
    prøv {
        # Prøv plutil (macOS) for å konvertere til XML fyrst
        la xml = builtin.exec_prosess("plutil -convert xml1 -o - " + sti + " 2>/dev/null")
        la trim_xml: tekst = _trim(xml)
        hvis (lengde(builtin.split(trim_xml, "")) > 10) {
            returner _parse_xml_plist(trim_xml)
        }
        # Prøv å lese direkte som XML
        la rå = builtin.fil_les(sti)
        returner _parse_xml_plist(rå)
    } fang (e) {
        la res: ordbok_tekst = {}
        res["_feil"] = "Kunne ikkje lese plist: " + sti
        returner res
    }
    returner {}
}

# Skriv ordbok til XML plist-fil
funksjon skriv_fil(sti: tekst, data: ordbok_tekst) -> bool {
    prøv {
        la xml_innhald: tekst = format_xml(data)
        builtin.fil_skriv(sti, xml_innhald)
        returner sann
    } fang (e) { returner usann }
    returner usann
}

# Generer XML plist-tekst frå ordbok
funksjon format_xml(data: ordbok_tekst) -> tekst {
    la ut: tekst = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    ut = ut + "<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n"
    ut = ut + "<plist version=\"1.0\">\n"
    ut = ut + _ordbok_til_xml(data, "")
    ut = ut + "</plist>\n"
    returner ut
}

funksjon _ordbok_til_xml(data: ordbok_tekst, innrykk: tekst) -> tekst {
    la ut: tekst = innrykk + "<dict>\n"
    la nøklar = builtin.nøklar(data)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la nk: tekst = nøklar[i]
        hvis (nk != "_feil") {
            la v: tekst = data[nk]
            ut = ut + innrykk + "\t<key>" + _xml_escape(nk) + "</key>\n"
            ut = ut + _verdi_til_xml(v, innrykk + "\t")
        }
        i = i + 1
    }
    ut = ut + innrykk + "</dict>\n"
    returner ut
}

funksjon _verdi_til_xml(v: tekst, innrykk: tekst) -> tekst {
    # Dict
    la dict_pref: tekst = "dict:"
    la dict_pref_teikn = builtin.split(dict_pref, "")
    la v_teikn = builtin.split(v, "")
    la er_dict: bool = usann
    la er_array: bool = usann
    hvis (lengde(v_teikn) >= 5) {
        la pre5: tekst = builtin.join(builtin.slice(v_teikn, 0, 5), "")
        hvis (pre5 == "dict:") { er_dict = sann }
    }
    hvis (lengde(v_teikn) >= 6) {
        la pre6: tekst = builtin.join(builtin.slice(v_teikn, 0, 6), "")
        hvis (pre6 == "array:") { er_array = sann }
    }
    hvis (er_dict) {
        la json_tekst: tekst = builtin.join(builtin.slice(v_teikn, 5, lengde(v_teikn)), "")
        la nested = builtin.json_parse(json_tekst)
        returner _ordbok_til_xml(nested, innrykk)
    }
    hvis (er_array) {
        la json_tekst: tekst = builtin.join(builtin.slice(v_teikn, 6, lengde(v_teikn)), "")
        la liste = builtin.json_parse(json_tekst)
        la ut: tekst = innrykk + "<array>\n"
        la i: heltall = 0
        mens (i < lengde(liste)) {
            ut = ut + _verdi_til_xml(liste[i], innrykk + "\t")
            i = i + 1
        }
        ut = ut + innrykk + "</array>\n"
        returner ut
    }
    hvis (v == "true")  { returner innrykk + "<true/>\n" }
    hvis (v == "false") { returner innrykk + "<false/>\n" }
    # Prøv som tal
    la er_tal: bool = sann
    la i: heltall = 0
    mens (i < lengde(v_teikn) og er_tal) {
        la kode: heltall = builtin.char_code(v_teikn[i])
        hvis (i == 0 og v_teikn[i] == "-") {
            # Negativ
        } ellers {
            hvis (kode < 48 eller kode > 57) { er_tal = usann }
        }
        i = i + 1
    }
    hvis (er_tal og lengde(v_teikn) > 0) {
        returner innrykk + "<integer>" + v + "</integer>\n"
    }
    returner innrykk + "<string>" + _xml_escape(v) + "</string>\n"
}

# ─── XML-parser (forenkla, linje-basert) ─────────────────────────────────────

funksjon _parse_xml_plist(xml: tekst) -> ordbok_tekst {
    returner _enkel_xml_parse(xml)
}

funksjon _enkel_xml_parse(xml: tekst) -> ordbok_tekst {
    la res: ordbok_tekst = {}
    la linjer = builtin.split(xml, "\n")
    la i: heltall = 0
    la siste_nøkkel: tekst = ""
    mens (i < lengde(linjer)) {
        la linje: tekst = _trim(linjer[i])
        la key_val = _extract_tag(linje, "key")
        hvis (key_val != "") { siste_nøkkel = key_val }
        hvis (siste_nøkkel != "") {
            la str_val = _extract_tag(linje, "string")
            la int_val = _extract_tag(linje, "integer")
            la real_val = _extract_tag(linje, "real")
            hvis (str_val != "")  { res[siste_nøkkel] = str_val  siste_nøkkel = "" }
            hvis (int_val != "")  { res[siste_nøkkel] = int_val  siste_nøkkel = "" }
            hvis (real_val != "") { res[siste_nøkkel] = real_val siste_nøkkel = "" }
            hvis (_inneheld(linje, "<true/>"))  { res[siste_nøkkel] = "true"  siste_nøkkel = "" }
            hvis (_inneheld(linje, "<false/>")) { res[siste_nøkkel] = "false" siste_nøkkel = "" }
        }
        i = i + 1
    }
    returner res
}

funksjon _extract_tag(linje: tekst, tag: tekst) -> tekst {
    la open_tag: tekst = "<" + tag + ">"
    la close_tag: tekst = "</" + tag + ">"
    la start: heltall = _finn_tekst(linje, open_tag)
    la slutt: heltall = _finn_tekst(linje, close_tag)
    hvis (start >= 0 og slutt > start) {
        la teikn = builtin.split(linje, "")
        la from_idx: heltall = start + lengde(builtin.split(open_tag, ""))
        returner builtin.join(builtin.slice(teikn, from_idx, slutt), "")
    }
    returner ""
}

# ─── Verdihenting og -setting ─────────────────────────────────────────────────

funksjon get(data: ordbok_tekst, nøkkel: tekst) -> tekst {
    prøv { returner data[nøkkel] } fang (e) { returner "" }
    returner ""
}

funksjon get_h(data: ordbok_tekst, nøkkel: tekst, standard: tekst) -> tekst {
    prøv {
        la v: tekst = data[nøkkel]
        returner v
    } fang (e) { returner standard }
    returner standard
}

funksjon set_verdi(data: ordbok_tekst, nøkkel: tekst, verdi: tekst) {
    data[nøkkel] = verdi
}

funksjon er_bool(verdi: tekst) -> bool {
    returner verdi == "true" eller verdi == "false"
}

funksjon til_bool(verdi: tekst) -> bool {
    returner verdi == "true"
}

funksjon nøklar(data: ordbok_tekst) -> liste_tekst {
    returner builtin.nøklar(data)
}

# ─── Konvertering plist ↔ JSON ────────────────────────────────────────────────

funksjon til_json(data: ordbok_tekst) -> tekst {
    returner builtin.json_stringify(data)
}

funksjon frå_json(json_tekst: tekst) -> ordbok_tekst {
    prøv { returner builtin.json_parse(json_tekst) } fang (e) { returner {} }
    returner {}
}

# ─── Verktøy ─────────────────────────────────────────────────────────────────

# Sjekk om det er ein plist-fil
funksjon er_plist_fil(sti: tekst) -> bool {
    la t = builtin.split(sti, "")
    la n: heltall = lengde(t)
    hvis (n < 6) { returner usann }
    la siste5: tekst = builtin.join(builtin.slice(t, n-5, n), "")
    la siste6: tekst = builtin.join(builtin.slice(t, n-6, n), "")
    returner siste5 == ".plist" eller siste6 == ".plist"
}

# Konverter binær plist til XML og les
funksjon les_binær(sti: tekst) -> ordbok_tekst {
    prøv {
        la tmp: tekst = "/tmp/_plist_konv.xml"
        builtin.exec_prosess("plutil -convert xml1 -o " + tmp + " " + sti + " 2>/dev/null")
        returner les_fil(tmp)
    } fang (e) { returner {} }
    returner {}
}

# Skriv til binær plist (via macOS plutil)
funksjon skriv_binær(sti: tekst, data: ordbok_tekst) -> bool {
    la tmp_xml: tekst = "/tmp/_plist_tmp.xml"
    prøv {
        skriv_fil(tmp_xml, data)
        builtin.exec_prosess("plutil -convert binary1 -o " + sti + " " + tmp_xml + " 2>/dev/null")
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon _xml_escape(s: tekst) -> tekst {
    la t = builtin.split(s, "")
    la r: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(t)) {
        la c: tekst = t[i]
        hvis (c == "&")  { legg_til(r, "&amp;") }
        ellers hvis (c == "<")  { legg_til(r, "&lt;") }
        ellers hvis (c == ">")  { legg_til(r, "&gt;") }
        ellers hvis (c == "\"") { legg_til(r, "&quot;") }
        ellers { legg_til(r, c) }
        i = i + 1
    }
    returner builtin.join(r, "")
}

funksjon _finn_tekst(s: tekst, mønster: tekst) -> heltall {
    la st = builtin.split(s, "")
    la mt = builtin.split(mønster, "")
    la sn: heltall = lengde(st)
    la mn: heltall = lengde(mt)
    la i: heltall = 0
    mens (i <= sn - mn) {
        la treff: bool = sann
        la j: heltall = 0
        mens (j < mn og treff) {
            hvis (st[i+j] != mt[j]) { treff = usann }
            j = j + 1
        }
        hvis (treff) { returner i }
        i = i + 1
    }
    returner -1
}

funksjon _inneheld(s: tekst, mønster: tekst) -> bool {
    returner _finn_tekst(s, mønster) >= 0
}

funksjon _trim(s: tekst) -> tekst {
    la t = builtin.split(s, "")
    la n: heltall = lengde(t)
    la a: heltall = 0  la b: heltall = n
    mens (a < b og (t[a]==" " eller t[a]=="\t" eller t[a]=="\n" eller t[a]=="\r")) { a=a+1 }
    mens (b > a og (t[b-1]==" " eller t[b-1]=="\t" eller t[b-1]=="\n" eller t[b-1]=="\r")) { b=b-1 }
    returner builtin.join(builtin.slice(t, a, b), "")
}

bruk std.html som html
bruk std.html_components som komp
bruk std.html_forms som forms

// Norscode HTML Islands v1
// Lett interaktivitetslag for server-rendered HTML.
// Gir markup som senere kan hydreres av en klient-runtime.

funksjon island(id: tekst, komponent: tekst, props: tekst, innhold: tekst) -> tekst {
    returner html.div(
        html.class_attr("island")
            + html.id_attr(id)
            + html.data_attr("island", komponent)
            + html.data_attr("props", props),
        innhold
    )
}

funksjon island_state(nøkkel: tekst, verdi: tekst) -> tekst {
    returner html.input(
        html.attr("type", "hidden")
            + html.data_attr("state", nøkkel)
            + html.attr("name", nøkkel)
            + html.attr("value", verdi)
    )
}

funksjon island_action(navn: tekst, tekstverdi: tekst) -> tekst {
    returner html.button(
        html.attr("type", "button")
            + html.class_attr("island-action")
            + html.data_attr("action", navn),
        html.escape(tekstverdi)
    )
}

funksjon island_submit(navn: tekst, tekstverdi: tekst) -> tekst {
    returner html.button(
        html.attr("type", "submit")
            + html.class_attr("island-submit")
            + html.data_attr("action", navn),
        html.escape(tekstverdi)
    )
}

funksjon modal_open_knapp(tekstverdi: tekst, modal_id: tekst) -> tekst {
    returner html.button(
        html.attr("type", "button")
            + html.class_attr("island-action")
            + html.modal_open_attrs(modal_id),
        html.escape(tekstverdi)
    )
}

funksjon modal_close_knapp(tekstverdi: tekst) -> tekst {
    returner html.button(
        html.attr("type", "button")
            + html.class_attr("island-action")
            + html.modal_close_attrs(),
        html.escape(tekstverdi)
    )
}

funksjon hydrate_script(src: tekst) -> tekst {
    returner html.script_module(src)
}

funksjon teller(id: tekst, startverdi: tekst) -> tekst {
    returner island(
        id,
        "teller",
        "{\"start\":\"" + html.escape(startverdi) + "\"}",
        html.div(
            html.class_attr("counter"),
            island_state("verdi", startverdi)
                + html.span(html.class_attr("counter-value") + html.data_attr("bind", "verdi"), html.escape(startverdi))
                + island_action("minus", "-")
                + island_action("plus", "+")
        )
    )
}

funksjon toggle(id: tekst, labeltekst: tekst, startverdi: tekst) -> tekst {
    returner island(
        id,
        "toggle",
        "{\"start\":\"" + html.escape(startverdi) + "\"}",
        html.div(
            html.class_attr("toggle"),
            island_state("aktiv", startverdi)
                + html.button(
                    html.attr("type", "button")
                        + html.class_attr("toggle-button")
                        + html.data_attr("action", "toggle")
                        + html.aria_attr("pressed", startverdi),
                    html.escape(labeltekst)
                )
        )
    )
}

funksjon tabs(id: tekst, faner: tekst, innhold: tekst) -> tekst {
    returner island(
        id,
        "tabs",
        "{}",
        html.div(
            html.class_attr("tabs"),
            html.div(html.class_attr("tabs-list") + html.attr("role", "tablist"), faner)
                + html.div(html.class_attr("tabs-panels"), innhold)
        )
    )
}

funksjon tab_knapp(id: tekst, tekstverdi: tekst, valgt: tekst) -> tekst {
    returner html.button(
        html.attr("type", "button")
            + html.class_attr("tab-button")
            + html.attr("role", "tab")
            + html.data_attr("tab", id)
            + html.aria_attr("selected", valgt),
        html.escape(tekstverdi)
    )
}

funksjon tab_panel(id: tekst, innhold: tekst) -> tekst {
    returner html.div(
        html.class_attr("tab-panel")
            + html.attr("role", "tabpanel")
            + html.data_attr("panel", id),
        innhold
    )
}

funksjon modal(id: tekst, tittel: tekst, innhold: tekst) -> tekst {
    returner island(
        id,
        "modal",
        "{}",
        html.div(
            html.class_attr("modal")
                + html.attr("role", "dialog")
                + html.aria_attr("modal", "true")
                + html.aria_attr("label", tittel),
            html.div(
                html.class_attr("modal-content"),
                html.h2("", html.escape(tittel))
                    + innhold
                    + modal_close_knapp("Lukk")
            )
        )
    )
}

funksjon dropdown(id: tekst, tekstverdi: tekst, innhold: tekst) -> tekst {
    returner island(
        id,
        "dropdown",
        "{}",
        html.div(
            html.class_attr("island-dropdown"),
            html.button(
                html.attr("type", "button")
                    + html.class_attr("island-action")
                    + html.dropdown_knapp_attrs(id + "-menu"),
                html.escape(tekstverdi)
            )
                + html.div(
                    html.class_attr("island-dropdown-menu") + html.dropdown_attrs(id + "-menu"),
                    innhold
                )
        )
    )
}

funksjon live_filter(id: tekst, labeltekst: tekst, target_selector: tekst, placeholder: tekst, innhold: tekst) -> tekst {
    returner island(
        id,
        "live_filter",
        "{\"target\":\"" + html.escape(target_selector) + "\"}",
        html.div(
            html.class_attr("live-filter"),
            html.label(html.attr("for", id + "-filter"), html.escape(labeltekst))
                + html.input(
                    html.attr("type", "search")
                        + html.id_attr(id + "-filter")
                        + html.class_attr("live-filter-input")
                        + html.attr("placeholder", placeholder)
                        + html.livefilter_attrs(target_selector)
                )
                + html.div(html.class_attr("live-filter-results"), innhold)
        )
    )
}

funksjon live_search(id: tekst, action: tekst, placeholder: tekst) -> tekst {
    returner island(
        id,
        "live_search",
        "{\"action\":\"" + html.escape(action) + "\"}",
        forms.get_skjema(
            action,
            forms.søkefelt("q", "Søk", "", placeholder)
                + html.div(html.class_attr("search-results") + html.data_attr("results", "q"), "")
        )
    )
}

funksjon autosubmit_search(id: tekst, action: tekst, placeholder: tekst, delay_ms: tekst) -> tekst {
    returner island(
        id,
        "autosubmit_search",
        "{\"action\":\"" + html.escape(action) + "\"}",
        html.form(
            html.attr("method", "get")
                + html.attr("action", action)
                + html.class_attr("island-search")
                + html.autosubmit_attrs(delay_ms),
            forms.søkefelt("q", "Søk", "", placeholder)
        )
    )
}

funksjon json_form(id: tekst, action: tekst, innhold: tekst, resultat_id: tekst, status_id: tekst) -> tekst {
    returner island(
        id,
        "json_form",
        "{\"action\":\"" + html.escape(action) + "\"}",
        html.form(
            html.attr("method", "post")
                + html.attr("action", action)
                + html.class_attr("island-json-form")
                + html.json_form_attrs(action, resultat_id)
                + html.form_status_attrs(status_id, "Sender", "Lagret", "Feil")
                + html.disable_submit_attrs("Sender"),
            innhold
                + html.p(html.id_attr(status_id) + html.class_attr("form-status") + html.attr("role", "status"), "")
                + html.div(html.id_attr(resultat_id) + html.class_attr("form-result"), "")
        )
    )
}

# Standard AI-kontrakt for Norscode.
#
# Denne flata er med vilje deterministisk og utan nettverk. Ho gir normal
# Norscode-kode ein stabil AI-API-kontrakt som seinare kan få provider-backends.

funksjon _inneholder(s: tekst, sub: tekst) -> bool {
    hvis lengde(sub) == 0 {
        returner sann
    }
    hvis lengde(sub) > lengde(s) {
        returner usann
    }

    la i = 0
    mens i <= lengde(s) - lengde(sub) {
        hvis builtin.slice(s, i, i + lengde(sub)) == sub {
            returner sann
        }
        i = i + 1
    }
    returner usann
}

funksjon _normaliser(t: tekst) -> tekst {
    returner builtin.trim(builtin.lower(t))
}

funksjon provider(navn: tekst, modell: tekst, base_url: tekst) -> ordbok_tekst {
    la p: ordbok_tekst = {}
    p["provider"] = navn
    p["model"] = modell
    p["base_url"] = base_url
    p["mode"] = "local-deterministic"
    p["network"] = "disabled"
    returner p
}

funksjon lokal(modell: tekst) -> ordbok_tekst {
    returner provider("local", modell, "")
}

funksjon melding(rolle: tekst, innhald: tekst) -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["role"] = rolle
    m["content"] = innhald
    returner m
}

funksjon system(innhald: tekst) -> ordbok_tekst {
    returner melding("system", innhald)
}

funksjon bruker(innhald: tekst) -> ordbok_tekst {
    returner melding("user", innhald)
}

funksjon assistent(innhald: tekst) -> ordbok_tekst {
    returner melding("assistant", innhald)
}

funksjon respons(ok: bool, tekst_svar: tekst, modell: tekst, grunn: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    hvis ok {
        r["ok"] = "sann"
    } ellers {
        r["ok"] = "usann"
    }
    r["text"] = tekst_svar
    r["model"] = modell
    r["finish_reason"] = grunn
    r["usage_prompt_tokens"] = tekst_fra_heltall(lengde(tekst_svar))
    r["usage_completion_tokens"] = tekst_fra_heltall(lengde(tekst_svar) / 2)
    returner r
}

funksjon chat(konfig: ordbok_tekst, system_prompt: tekst, user_prompt: tekst) -> ordbok_tekst {
    la modell = konfig["model"]
    la svar = "AI[" + modell + "]: " + tekst_trim(system_prompt) + " :: " + tekst_trim(user_prompt)
    returner respons(sann, svar, modell, "stop")
}

funksjon chat_meldinger(konfig: ordbok_tekst, meldinger: liste<ordbok_tekst>) -> ordbok_tekst {
    la system_prompt = ""
    la user_prompt = ""
    la i = 0
    mens i < lengde(meldinger) {
        la m = meldinger[i]
        hvis m["role"] == "system" {
            system_prompt = m["content"]
        }
        hvis m["role"] == "user" {
            user_prompt = m["content"]
        }
        i = i + 1
    }
    returner chat(konfig, system_prompt, user_prompt)
}

funksjon embedding(tekst_inn: tekst) -> ordbok_tekst {
    la v0 = 0
    la v1 = 0
    la v2 = 0
    la v3 = 0
    la i = 0
    mens i < lengde(tekst_inn) {
        la kode = builtin.char_code(builtin.slice(tekst_inn, i, i + 1))
        hvis i % 4 == 0 {
            v0 = v0 + kode
        } ellers hvis i % 4 == 1 {
            v1 = v1 + kode
        } ellers hvis i % 4 == 2 {
            v2 = v2 + kode
        } ellers {
            v3 = v3 + kode
        }
        i = i + 1
    }

    la e: ordbok_tekst = {}
    e["dims"] = "4"
    e["vector"] = tekst_fra_heltall(v0) + "," + tekst_fra_heltall(v1) + "," + tekst_fra_heltall(v2) + "," + tekst_fra_heltall(v3)
    e["input_length"] = tekst_fra_heltall(lengde(tekst_inn))
    returner e
}

funksjon moderer(tekst_inn: tekst) -> ordbok_tekst {
    la t = _normaliser(tekst_inn)
    la m: ordbok_tekst = {}
    m["safe"] = "sann"
    m["category"] = "none"

    hvis _inneholder(t, "password") eller _inneholder(t, "hemmelig") {
        m["safe"] = "usann"
        m["category"] = "secret"
    }
    hvis _inneholder(t, "drop table") {
        m["safe"] = "usann"
        m["category"] = "destructive"
    }
    returner m
}

funksjon verktøy(navn: tekst, beskriving: tekst) -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["name"] = navn
    t["description"] = beskriving
    returner t
}

funksjon verktøy_kall(navn: tekst, argumenter: tekst) -> ordbok_tekst {
    la kall: ordbok_tekst = {}
    kall["type"] = "tool_call"
    kall["name"] = navn
    kall["arguments"] = argumenter
    returner kall
}

funksjon velg_verktøy(mål: tekst, verktøy_liste: liste<ordbok_tekst>) -> ordbok_tekst {
    hvis lengde(verktøy_liste) == 0 {
        returner verktøy_kall("none", "{}")
    }

    la mål_lav = _normaliser(mål)
    la i = 0
    mens i < lengde(verktøy_liste) {
        la t = verktøy_liste[i]
        hvis _inneholder(mål_lav, _normaliser(t["name"])) {
            returner verktøy_kall(t["name"], "{\"goal\":\"" + mål + "\"}")
        }
        i = i + 1
    }

    returner verktøy_kall(verktøy_liste[0]["name"], "{\"goal\":\"" + mål + "\"}")
}

funksjon agent_plan(mål: tekst, verktøy_liste: liste<ordbok_tekst>) -> ordbok_tekst {
    la kall = velg_verktøy(mål, verktøy_liste)
    la plan: ordbok_tekst = {}
    plan["goal"] = mål
    plan["tool"] = kall["name"]
    plan["arguments"] = kall["arguments"]
    plan["steps"] = "forstå mål -> velg verktøy -> returner trygg plan"
    returner plan
}

funksjon minne_ny(kapasitet: heiltall) -> ordbok_tekst {
    hvis kapasitet < 1 { kapasitet = 1 }
    returner {"capacity": tekst_fra_heltall(kapasitet), "count": "0", "next_id": "0"}
}

funksjon minne_lagre(minne: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> tekst {
    la next_id = heltall_fra_tekst(minne["next_id"]) + 1
    minne["next_id"] = tekst_fra_heltall(next_id)
    la id = "memory_" + tekst_fra_heltall(next_id)
    minne["item:" + id] = "sann"
    minne["key:" + id] = nøkkel
    minne["value:" + id] = verdi
    minne["count"] = tekst_fra_heltall(heltall_fra_tekst(minne["count"]) + 1)
    mens heltall_fra_tekst(minne["count"]) > heltall_fra_tekst(minne["capacity"]) {
        la oldest = next_id - heltall_fra_tekst(minne["count"]) + 1
        la old_id = "memory_" + tekst_fra_heltall(oldest)
        fjern_nokkel(minne, "item:" + old_id)
        fjern_nokkel(minne, "key:" + old_id)
        fjern_nokkel(minne, "value:" + old_id)
        minne["count"] = tekst_fra_heltall(heltall_fra_tekst(minne["count"]) - 1)
    }
    returner id
}

funksjon minne_søk(minne: ordbok_tekst, query: tekst, maks: heiltall) -> liste<ordbok_tekst> {
    la out: liste<ordbok_tekst> = []
    hvis maks < 1 { returner out }
    la keys = builtin.nøkler(minne)
    la q = _normaliser(query)
    la i: heiltall = 0
    mens i < lengde(keys) og lengde(out) < maks {
        la k: tekst = keys[i]
        hvis tekst_starter_med(k, "item:") {
            la id = builtin.slice(k, 5, lengde(k))
            la key_text = minne["key:" + id]
            la value_text = minne["value:" + id]
            hvis q == "" eller _inneholder(_normaliser(key_text + " " + value_text), q) {
                legg_til(out, {"id": id, "key": key_text, "value": value_text})
            }
        }
        i = i + 1
    }
    returner out
}

funksjon runtime_ny(konfig: ordbok_tekst, minne_kapasitet: heiltall, maks_steg: heiltall) -> ordbok_tekst {
    hvis maks_steg < 1 { maks_steg = 1 }
    returner {"config": konfig, "memory": minne_ny(minne_kapasitet), "max_steps": tekst_fra_heltall(maks_steg), "tool_count": "0", "audit_count": "0"}
}

funksjon runtime_registrer_verktøy(rt: ordbok_tekst, navn: tekst, beskriving: tekst,
                                   fn_navn: tekst, capability: tekst) -> bool {
    hvis navn == "" eller fn_navn == "" { returner usann }
    hvis capability != "" og capability != "ai.tool" og capability != "disk.read" og capability != "disk.write" og capability != "net.http" og capability != "process.exec" { returner usann }
    hvis ikkje har_nokkel(rt, "tool:" + navn) {
        rt["tool_count"] = tekst_fra_heltall(heltall_fra_tekst(rt["tool_count"]) + 1)
    }
    rt["tool:" + navn] = "sann"
    rt["tool_desc:" + navn] = beskriving
    rt["tool_fn:" + navn] = fn_navn
    rt["tool_cap:" + navn] = capability
    returner sann
}

funksjon _capability_tillatt(capabilities: tekst, cap: tekst) -> bool {
    hvis cap == "" { returner sann }
    returner builtin.index_of("," + capabilities + ",", "," + cap + ",") >= 0
}

funksjon runtime_verktøy_liste(rt: ordbok_tekst) -> liste<ordbok_tekst> {
    la out: liste<ordbok_tekst> = []
    la keys = builtin.nøkler(rt)
    la i: heiltall = 0
    mens i < lengde(keys) {
        la k: tekst = keys[i]
        hvis tekst_starter_med(k, "tool:") {
            la navn = builtin.slice(k, 5, lengde(k))
            legg_til(out, verktøy(navn, rt["tool_desc:" + navn]))
        }
        i = i + 1
    }
    returner out
}

funksjon runtime_kjør_verktøy(rt: ordbok_tekst, navn: tekst, args: ordbok_tekst,
                              capabilities: tekst) -> ordbok_tekst {
    hvis ikkje har_nokkel(rt, "tool:" + navn) { returner {"ok": "usann", "error": "ukjent verktøy", "result": ""} }
    la cap = rt["tool_cap:" + navn]
    hvis ikkje _capability_tillatt(capabilities, cap) { returner {"ok": "usann", "error": "manglar capability " + cap, "result": ""} }
    prøv {
        la result = builtin.ncb_call_fn(rt["tool_fn:" + navn], args)
        rt["audit_count"] = tekst_fra_heltall(heltall_fra_tekst(rt["audit_count"]) + 1)
        returner {"ok": "sann", "error": "", "result": result}
    } fang (e) {
        rt["audit_count"] = tekst_fra_heltall(heltall_fra_tekst(rt["audit_count"]) + 1)
        returner {"ok": "usann", "error": tekst(e), "result": ""}
    }
    returner {"ok": "usann", "error": "ukjent agentfeil", "result": ""}
}

funksjon agent_kjør(rt: ordbok_tekst, mål: tekst, args: ordbok_tekst,
                    capabilities: tekst) -> ordbok_tekst {
    la plan = agent_plan(mål, runtime_verktøy_liste(rt))
    hvis plan["tool"] == "none" { returner {"ok": "usann", "goal": mål, "tool": "none", "result": "", "error": "ingen verktøy"} }
    la execution = runtime_kjør_verktøy(rt, plan["tool"], args, capabilities)
    minne_lagre(rt["memory"], mål, tekst(execution["result"]))
    returner {"ok": execution["ok"], "goal": mål, "tool": plan["tool"], "result": execution["result"], "error": execution["error"], "steps_used": "1"}
}

funksjon status() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["api"] = "std.ai"
    s["chat"] = "sann"
    s["embeddings"] = "sann"
    s["moderation"] = "sann"
    s["tools"] = "sann"
    s["agents"] = "sann"
    s["memory"] = "sann"
    s["tool_execution"] = "sann"
    s["capability_guard"] = "sann"
    s["network"] = "disabled"
    returner s
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "dekning": "provider-uavhengig lokal chat, embedding, moderering, plan, avgrensa agent, bounded minne, verktøyregister, capability-guard og audit", "mangler": ""}
}

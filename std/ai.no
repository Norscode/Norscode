# Standard AI-kontrakt for Norscode.
#
# Denne flata er med vilje deterministisk og utan nettverk. Ho gir normal
# Norscode-kode ein stabil AI-API-kontrakt som seinare kan få provider-backends.

funksjon _inneholder(s: tekst, sub: tekst) -> bool {
    hvis lengde(sub) == 0 {
        returner sann
    }
    hvis lengde(sub) > lengde(s) {
        returner usann
    }

    la i = 0
    mens i <= lengde(s) - lengde(sub) {
        hvis builtin.slice(s, i, i + lengde(sub)) == sub {
            returner sann
        }
        i = i + 1
    }
    returner usann
}

funksjon _normaliser(t: tekst) -> tekst {
    returner tekst_trim(tekst_til_liten(t))
}

funksjon provider(navn: tekst, modell: tekst, base_url: tekst) -> ordbok_tekst {
    la p: ordbok_tekst = {}
    p["provider"] = navn
    p["model"] = modell
    p["base_url"] = base_url
    p["mode"] = "local-deterministic"
    p["network"] = "disabled"
    returner p
}

funksjon lokal(modell: tekst) -> ordbok_tekst {
    returner provider("local", modell, "")
}

funksjon melding(rolle: tekst, innhald: tekst) -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["role"] = rolle
    m["content"] = innhald
    returner m
}

funksjon system(innhald: tekst) -> ordbok_tekst {
    returner melding("system", innhald)
}

funksjon bruker(innhald: tekst) -> ordbok_tekst {
    returner melding("user", innhald)
}

funksjon assistent(innhald: tekst) -> ordbok_tekst {
    returner melding("assistant", innhald)
}

funksjon respons(ok: bool, tekst_svar: tekst, modell: tekst, grunn: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    hvis ok {
        r["ok"] = "sann"
    } ellers {
        r["ok"] = "usann"
    }
    r["text"] = tekst_svar
    r["model"] = modell
    r["finish_reason"] = grunn
    r["usage_prompt_tokens"] = tekst_fra_heltall(lengde(tekst_svar))
    r["usage_completion_tokens"] = tekst_fra_heltall(lengde(tekst_svar) / 2)
    returner r
}

funksjon chat(konfig: ordbok_tekst, system_prompt: tekst, user_prompt: tekst) -> ordbok_tekst {
    la modell = konfig["model"]
    la svar = "AI[" + modell + "]: " + tekst_trim(system_prompt) + " :: " + tekst_trim(user_prompt)
    returner respons(sann, svar, modell, "stop")
}

funksjon chat_meldinger(konfig: ordbok_tekst, meldinger: liste<ordbok_tekst>) -> ordbok_tekst {
    la system_prompt = ""
    la user_prompt = ""
    la i = 0
    mens i < lengde(meldinger) {
        la m = meldinger[i]
        hvis m["role"] == "system" {
            system_prompt = m["content"]
        }
        hvis m["role"] == "user" {
            user_prompt = m["content"]
        }
        i = i + 1
    }
    returner chat(konfig, system_prompt, user_prompt)
}

funksjon embedding(tekst_inn: tekst) -> ordbok_tekst {
    la v0 = 0
    la v1 = 0
    la v2 = 0
    la v3 = 0
    la i = 0
    mens i < lengde(tekst_inn) {
        la kode = builtin.char_code(builtin.slice(tekst_inn, i, i + 1))
        hvis i % 4 == 0 {
            v0 = v0 + kode
        } ellers hvis i % 4 == 1 {
            v1 = v1 + kode
        } ellers hvis i % 4 == 2 {
            v2 = v2 + kode
        } ellers {
            v3 = v3 + kode
        }
        i = i + 1
    }

    la e: ordbok_tekst = {}
    e["dims"] = "4"
    e["vector"] = tekst_fra_heltall(v0) + "," + tekst_fra_heltall(v1) + "," + tekst_fra_heltall(v2) + "," + tekst_fra_heltall(v3)
    e["input_length"] = tekst_fra_heltall(lengde(tekst_inn))
    returner e
}

funksjon moderer(tekst_inn: tekst) -> ordbok_tekst {
    la t = _normaliser(tekst_inn)
    la m: ordbok_tekst = {}
    m["safe"] = "sann"
    m["category"] = "none"

    hvis _inneholder(t, "password") eller _inneholder(t, "hemmelig") {
        m["safe"] = "usann"
        m["category"] = "secret"
    }
    hvis _inneholder(t, "drop table") {
        m["safe"] = "usann"
        m["category"] = "destructive"
    }
    returner m
}

funksjon verktøy(navn: tekst, beskriving: tekst) -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["name"] = navn
    t["description"] = beskriving
    returner t
}

funksjon verktøy_kall(navn: tekst, argumenter: tekst) -> ordbok_tekst {
    la kall: ordbok_tekst = {}
    kall["type"] = "tool_call"
    kall["name"] = navn
    kall["arguments"] = argumenter
    returner kall
}

funksjon velg_verktøy(mål: tekst, verktøy_liste: liste<ordbok_tekst>) -> ordbok_tekst {
    hvis lengde(verktøy_liste) == 0 {
        returner verktøy_kall("none", "{}")
    }

    la mål_lav = _normaliser(mål)
    la i = 0
    mens i < lengde(verktøy_liste) {
        la t = verktøy_liste[i]
        hvis _inneholder(mål_lav, _normaliser(t["name"])) {
            returner verktøy_kall(t["name"], "{\"goal\":\"" + mål + "\"}")
        }
        i = i + 1
    }

    returner verktøy_kall(verktøy_liste[0]["name"], "{\"goal\":\"" + mål + "\"}")
}

funksjon agent_plan(mål: tekst, verktøy_liste: liste<ordbok_tekst>) -> ordbok_tekst {
    la kall = velg_verktøy(mål, verktøy_liste)
    la plan: ordbok_tekst = {}
    plan["goal"] = mål
    plan["tool"] = kall["name"]
    plan["arguments"] = kall["arguments"]
    plan["steps"] = "forstå mål -> velg verktøy -> returner trygg plan"
    returner plan
}

funksjon status() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["api"] = "std.ai"
    s["chat"] = "sann"
    s["embeddings"] = "sann"
    s["moderation"] = "sann"
    s["tools"] = "sann"
    s["agents"] = "sann"
    s["network"] = "disabled"
    returner s
}

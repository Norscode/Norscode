# ipaddress.no — IP-adressehandtering
# Python: ipaddress
#
# Støttar IPv4 og IPv6 (delvis):
#   - IPv4-adressar: parsing, validering, konvertering til/frå heltall
#   - IPv4-nettverk: CIDR-notasjon, nettverksadresse, kringkasting, maske
#   - IPv6-adressar: parsing og komprimering
#   - Sjekkar: er_privat, er_offentleg, er_loopback, er_multicast
#
# Representasjon:
#   IPv4-adresse: ordbok_tekst
#     "type"   → "ipv4"
#     "tekst"  → "192.168.1.1"
#     "int"    → heltall-representasjon
#
#   IPv4-nettverk: ordbok_tekst
#     "type"     → "ipv4net"
#     "nettverk" → nettverksadresse som tekst
#     "maske"    → prefiks-lengde (0-32)
#     "int_nett" → nettverksadresse som heltall

# ─── IPv4-parsing ─────────────────────────────────────────────────────────────

funksjon ipv4(adresse: tekst) -> ordbok_tekst {
    la delar = builtin.split(adresse, ".")
    hvis (lengde(delar) != 4) {
        kast "Ugyldig IPv4-adresse: " + adresse
    }
    la int_val: heltall = 0
    la i: heltall = 0
    mens (i < 4) {
        la okt: heltall = builtin.heltall_fra_tekst(delar[i])
        hvis (okt < 0 eller okt > 255) {
            kast "Oktett utanfor rekkevidde: " + delar[i]
        }
        int_val = int_val * 256 + okt
        i = i + 1
    }
    la a: ordbok_tekst = {}
    a["type"] = "ipv4"
    a["tekst"] = adresse
    a["int"] = tekst_fra_heltall(int_val)
    returner a
}

funksjon ipv4_frå_int(n: heltall) -> ordbok_tekst {
    la o1: heltall = (n >> 24) & 255
    la o2: heltall = (n >> 16) & 255
    la o3: heltall = (n >> 8) & 255
    la o4: heltall = n & 255
    la adresse: tekst = tekst_fra_heltall(o1) + "." + tekst_fra_heltall(o2) + "." +
                         tekst_fra_heltall(o3) + "." + tekst_fra_heltall(o4)
    la a: ordbok_tekst = {}
    a["type"] = "ipv4"
    a["tekst"] = adresse
    a["int"] = tekst_fra_heltall(n)
    returner a
}

funksjon ipv4_til_int(a: ordbok_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(a["int"])
}

funksjon ipv4_til_tekst(a: ordbok_tekst) -> tekst {
    returner a["tekst"]
}

funksjon er_gyldig_ipv4(adresse: tekst) -> bool {
    prøv {
        la a = ipv4(adresse)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── IPv4-eigenskapar ─────────────────────────────────────────────────────────

funksjon er_privat(a: ordbok_tekst) -> bool {
    la n: heltall = builtin.heltall_fra_tekst(a["int"])
    # 10.0.0.0/8
    la c10: heltall = 10 * 256 * 256 * 256
    la c10_end: heltall = 11 * 256 * 256 * 256 - 1
    hvis (n >= c10 og n <= c10_end) { returner sann }
    # 172.16.0.0/12
    la c172: heltall = 172 * 256 * 256 * 256 + 16 * 256 * 256
    la c172_end: heltall = 172 * 256 * 256 * 256 + 32 * 256 * 256 - 1
    hvis (n >= c172 og n <= c172_end) { returner sann }
    # 192.168.0.0/16
    la c192: heltall = 192 * 256 * 256 * 256 + 168 * 256 * 256
    la c192_end: heltall = c192 + 256 * 256 - 1
    hvis (n >= c192 og n <= c192_end) { returner sann }
    returner usann
}

funksjon er_loopback(a: ordbok_tekst) -> bool {
    la n: heltall = builtin.heltall_fra_tekst(a["int"])
    la start: heltall = 127 * 256 * 256 * 256
    la slutt: heltall = 128 * 256 * 256 * 256 - 1
    returner n >= start og n <= slutt
}

funksjon er_multicast(a: ordbok_tekst) -> bool {
    la n: heltall = builtin.heltall_fra_tekst(a["int"])
    la start: heltall = 224 * 256 * 256 * 256
    la slutt: heltall = 240 * 256 * 256 * 256 - 1
    returner n >= start og n <= slutt
}

funksjon er_link_local(a: ordbok_tekst) -> bool {
    la n: heltall = builtin.heltall_fra_tekst(a["int"])
    la start: heltall = 169 * 256 * 256 * 256 + 254 * 256 * 256
    la slutt: heltall = start + 256 * 256 - 1
    returner n >= start og n <= slutt
}

funksjon er_offentleg(a: ordbok_tekst) -> bool {
    returner ikkje er_privat(a) og ikkje er_loopback(a) og
             ikkje er_multicast(a) og ikkje er_link_local(a)
}

funksjon er_udefinert(a: ordbok_tekst) -> bool {
    returner builtin.heltall_fra_tekst(a["int"]) == 0
}

funksjon er_avgrensa_kringkasting(a: ordbok_tekst) -> bool {
    returner builtin.heltall_fra_tekst(a["int"]) == 255 * 256 * 256 * 256 + 255 * 256 * 256 + 255 * 256 + 255
}

# ─── IPv4-nettverk ────────────────────────────────────────────────────────────

funksjon ipv4_nettverk(cidr: tekst) -> ordbok_tekst {
    la delar = builtin.split(cidr, "/")
    la adresse: tekst = delar[0]
    la prefiks: heltall = 32
    hvis (lengde(delar) > 1) {
        prefiks = builtin.heltall_fra_tekst(delar[1])
    }
    la a = ipv4(adresse)
    la a_int: heltall = builtin.heltall_fra_tekst(a["int"])
    la maske_int: heltall = _prefiks_til_maske(prefiks)
    la nett_int: heltall = a_int & maske_int

    la n: ordbok_tekst = {}
    n["type"] = "ipv4net"
    n["cidr"] = cidr
    n["maske"] = tekst_fra_heltall(prefiks)
    n["int_nett"] = tekst_fra_heltall(nett_int)
    n["int_maske"] = tekst_fra_heltall(maske_int)
    la nett_a = ipv4_frå_int(nett_int)
    n["nettverk"] = nett_a["tekst"]
    la kring_int: heltall = nett_int | (_ikkje_maske(prefiks))
    la kring_a = ipv4_frå_int(kring_int)
    n["kringkasting"] = kring_a["tekst"]
    returner n
}

funksjon _prefiks_til_maske(prefiks: heltall) -> heltall {
    hvis (prefiks == 0) { returner 0 }
    hvis (prefiks >= 32) { returner -1 }  # alle bit sett (0xFFFFFFFF = -1 i 2s komplement)
    # Bygg maske: prefiks bit frå venstre
    la maske: heltall = 0
    la i: heltall = 0
    mens (i < prefiks) {
        maske = maske | (1 << (31 - i))
        i = i + 1
    }
    returner maske
}

funksjon _ikkje_maske(prefiks: heltall) -> heltall {
    la maske: heltall = _prefiks_til_maske(prefiks)
    returner ~maske & 2147483647  # 0x7FFFFFFF
}

funksjon nettverksadresse(n: ordbok_tekst) -> ordbok_tekst {
    returner ipv4(n["nettverk"])
}

funksjon kringkastingsadresse(n: ordbok_tekst) -> ordbok_tekst {
    returner ipv4(n["kringkasting"])
}

funksjon nettverksmaske(n: ordbok_tekst) -> ordbok_tekst {
    la maske_int: heltall = builtin.heltall_fra_tekst(n["int_maske"])
    returner ipv4_frå_int(maske_int)
}

funksjon prefiks_lengde(n: ordbok_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(n["maske"])
}

# Er ei adresse i dette nettverket?
funksjon inneheld(n: ordbok_tekst, a: ordbok_tekst) -> bool {
    la a_int: heltall = builtin.heltall_fra_tekst(a["int"])
    la nett_int: heltall = builtin.heltall_fra_tekst(n["int_nett"])
    la maske_int: heltall = builtin.heltall_fra_tekst(n["int_maske"])
    returner (a_int & maske_int) == nett_int
}

# Tal på adressar i nettverket
funksjon antal_adressar(n: ordbok_tekst) -> heltall {
    la prefiks: heltall = builtin.heltall_fra_tekst(n["maske"])
    hvis (prefiks >= 32) { returner 1 }
    la exp: heltall = 32 - prefiks
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < exp) { resultat = resultat * 2  i = i + 1 }
    returner resultat
}

# Første brukbare adresse
funksjon første_brukarbar(n: ordbok_tekst) -> ordbok_tekst {
    la nett_int: heltall = builtin.heltall_fra_tekst(n["int_nett"])
    la prefiks: heltall = builtin.heltall_fra_tekst(n["maske"])
    hvis (prefiks >= 31) { returner ipv4_frå_int(nett_int) }
    returner ipv4_frå_int(nett_int + 1)
}

# Siste brukbare adresse
funksjon siste_brukarbar(n: ordbok_tekst) -> ordbok_tekst {
    la kring_int: heltall = builtin.heltall_fra_tekst(builtin.heltall_fra_tekst(n["int_nett"]) | _ikkje_maske(builtin.heltall_fra_tekst(n["maske"])))
    la prefiks: heltall = builtin.heltall_fra_tekst(n["maske"])
    hvis (prefiks >= 31) { returner ipv4_frå_int(kring_int) }
    returner ipv4_frå_int(kring_int - 1)
}

# ─── Adresse-aritmetikk ───────────────────────────────────────────────────────

funksjon ipv4_pluss(a: ordbok_tekst, n: heltall) -> ordbok_tekst {
    la int_val: heltall = builtin.heltall_fra_tekst(a["int"])
    returner ipv4_frå_int(int_val + n)
}

funksjon ipv4_minus(a: ordbok_tekst, n: heltall) -> ordbok_tekst {
    la int_val: heltall = builtin.heltall_fra_tekst(a["int"])
    returner ipv4_frå_int(int_val - n)
}

funksjon ipv4_differanse(a: ordbok_tekst, b: ordbok_tekst) -> heltall {
    la ai: heltall = builtin.heltall_fra_tekst(a["int"])
    la bi: heltall = builtin.heltall_fra_tekst(b["int"])
    returner ai - bi
}

funksjon ipv4_er_lik(a: ordbok_tekst, b: ordbok_tekst) -> bool {
    returner a["int"] == b["int"]
}

funksjon ipv4_er_mindre(a: ordbok_tekst, b: ordbok_tekst) -> bool {
    returner builtin.heltall_fra_tekst(a["int"]) < builtin.heltall_fra_tekst(b["int"])
}

# ─── IPv6 (enkel støtte) ──────────────────────────────────────────────────────

funksjon er_gyldig_ipv6(adresse: tekst) -> bool {
    la teikn = builtin.split(adresse, "")
    la n: heltall = lengde(teikn)
    # Enkel sjekk: berre hex, kolon og ::
    la i: heltall = 0
    mens (i < n) {
        la c: tekst = teikn[i]
        la k: heltall = builtin.char_code(c)
        la gyldig: bool = (k >= 48 og k <= 57) eller  # 0-9
                           (k >= 65 og k <= 70) eller  # A-F
                           (k >= 97 og k <= 102) eller # a-f
                           c == ":"
        hvis (ikkje gyldig) { returner usann }
        i = i + 1
    }
    # Sjekk : finst
    la kolon_delar = builtin.split(adresse, ":")
    returner lengde(kolon_delar) >= 2 og lengde(kolon_delar) <= 9
}

funksjon ipv6(adresse: tekst) -> ordbok_tekst {
    la a: ordbok_tekst = {}
    a["type"] = "ipv6"
    a["tekst"] = adresse
    a["komprimert"] = _komprimer_ipv6(adresse)
    returner a
}

funksjon _komprimer_ipv6(adresse: tekst) -> tekst {
    # Enkel komprimering: fjern leiande nullar i kvar gruppe
    la delar = builtin.split(adresse, ":")
    la komprimert: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(delar)) {
        la del: tekst = delar[i]
        # Fjern leiande nullar
        la teikn = builtin.split(del, "")
        la start: heltall = 0
        mens (start < lengde(teikn) - 1 og teikn[start] == "0") { start = start + 1 }
        legg_til(komprimert, builtin.join(builtin.slice(teikn, start, lengde(teikn)), ""))
        i = i + 1
    }
    returner builtin.join(komprimert, ":")
}

funksjon er_ipv6_loopback(a: ordbok_tekst) -> bool {
    la t: tekst = a["komprimert"]
    returner t == "::1" eller t == "0:0:0:0:0:0:0:1"
}

funksjon er_ipv6_ikkje_angitt(a: ordbok_tekst) -> bool {
    la t: tekst = a["komprimert"]
    returner t == "::" eller t == "0:0:0:0:0:0:0:0"
}

# ─── Hjelp-funksjonar ─────────────────────────────────────────────────────────

funksjon er_ip_adresse(s: tekst) -> bool {
    returner er_gyldig_ipv4(s) eller er_gyldig_ipv6(s)
}

funksjon ip_versjon(s: tekst) -> heltall {
    hvis (er_gyldig_ipv4(s)) { returner 4 }
    hvis (er_gyldig_ipv6(s)) { returner 6 }
    returner 0
}

# Sorter IPv4-adressar
funksjon sorter_ipv4(adresser: liste_tekst) -> liste_tekst {
    la kopi: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(adresser)) { legg_til(kopi, adresser[i])  i = i + 1 }
    la n: heltall = lengde(kopi)
    la swapped: bool = sann
    mens (swapped) {
        swapped = usann
        la j: heltall = 0
        mens (j + 1 < n) {
            la ai = ipv4(kopi[j])
            la bi = ipv4(kopi[j + 1])
            la ai_int: heltall = builtin.heltall_fra_tekst(ai["int"])
            la bi_int: heltall = builtin.heltall_fra_tekst(bi["int"])
            hvis (ai_int > bi_int) {
                la tmp: tekst = kopi[j]
                kopi[j] = kopi[j + 1]
                kopi[j + 1] = tmp
                swapped = sann
            }
            j = j + 1
        }
    }
    returner kopi
}

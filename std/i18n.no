# i18n.no — Internasjonalisering for Norscode
# django.utils.translation-ekvivalent
#
# Bruk:
#   bruk std.i18n som i18n
#
#   la t = i18n.last("locale/", "nn")
#
#   i18n._(t, "Hello")                    → "Hei"
#   i18n._(t, "Hello, %(name)s!", {"name": "Ola"})  → "Hei, Ola!"
#   i18n.ngettext(t, "%(n)d apple", "%(n)d apples", 2, {"n": "2"}) → "2 eple"
#
# Omsetjingsfil-format (locale/nn.lang):
#   # Kommentar
#   "Hello" = "Hei"
#   "Hello, %(name)s!" = "Hei, %(name)s!"
#   "%(n)d apple" | "%(n)d apples" = "%(n)d eple" | "%(n)d eple"

# ─── Oppretting ───────────────────────────────────────────────────────────────

funksjon ny(spr: tekst) -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["__spr__"]     = spr
    t["__fallback__"] = "en"
    t["__strenger__"] = "{}"
    t["__fleirtal__"] = "{}"
    returner t
}

funksjon last(mappe: tekst, spr: tekst) -> ordbok_tekst {
    la t = ny(spr)
    _last_fil(t, mappe + spr + ".lang")
    returner t
}

funksjon last_med_fallback(mappe: tekst, spr: tekst, fallback: tekst) -> ordbok_tekst {
    la t = ny(spr)
    t["__fallback__"] = fallback
    // Last fallback-spr fyrst, deretter overskriv med primærspråk
    _last_fil(t, mappe + fallback + ".lang")
    _last_fil(t, mappe + spr + ".lang")
    returner t
}

funksjon legg_til_omsetjing(t: ordbok_tekst, original: tekst, omsett: tekst) -> heltall {
    la strenger = _les_strenger(t)
    strenger[original] = omsett
    _skriv_strenger(t, strenger)
    returner 1
}

funksjon legg_til_fleirtal(t: ordbok_tekst, eintal: tekst, fleirtal: tekst, eintal_o: tekst, fleirtal_o: tekst) -> heltall {
    la fmap = _les_fleirtal(t)
    fmap[eintal] = eintal_o + "|||" + fleirtal_o
    fmap[fleirtal] = eintal_o + "|||" + fleirtal_o
    _skriv_fleirtal(t, fmap)
    returner 1
}

# ─── Omsetjing ────────────────────────────────────────────────────────────────

// Hovudfunksjon — oversetj og interpoler
funksjon _(t: ordbok_tekst, original: tekst, ctx: ordbok_tekst) -> tekst {
    la strenger = _les_strenger(t)
    la omsett = hvis har_nokkel(strenger, original) { tekst(strenger[original]) } ellers { original }
    returner _interpoler(omsett, ctx)
}

// Oversetj utan interpolasjon
funksjon _t(t: ordbok_tekst, original: tekst) -> tekst {
    la tom: ordbok_tekst = {}
    returner _(t, original, tom)
}

// Eintal/fleirtal
funksjon ngettext(t: ordbok_tekst, eintal: tekst, fleirtal_s: tekst, n: heltall, ctx: ordbok_tekst) -> tekst {
    la fmap = _les_fleirtal(t)
    la oppslag = hvis har_nokkel(fmap, eintal) { tekst(fmap[eintal]) } ellers { "" }
    la omsett_eintal = eintal
    la omsett_fleirtal = fleirtal_s

    hvis oppslag != "" {
        la delar = builtin.split(oppslag, "|||")
        hvis lengde(delar) >= 2 {
            omsett_eintal  = delar[0]
            omsett_fleirtal = delar[1]
        }
    }

    la valt = hvis n == 1 { omsett_eintal } ellers { omsett_fleirtal }
    returner _interpoler(valt, ctx)
}

// Omset med lista over alternativ (pgettext — kontekstbasert)
funksjon pgettext(t: ordbok_tekst, kontekst: tekst, original: tekst, ctx: ordbok_tekst) -> tekst {
    la nøkkel = kontekst + "\x04" + original
    la strenger = _les_strenger(t)
    la omsett = hvis har_nokkel(strenger, nøkkel) { tekst(strenger[nøkkel]) }
                ellers hvis har_nokkel(strenger, original) { tekst(strenger[original]) }
                ellers { original }
    returner _interpoler(omsett, ctx)
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon spr(t: ordbok_tekst) -> tekst { returner t["__spr__"] }

funksjon er_last(t: ordbok_tekst) -> boolsk {
    la strenger = _les_strenger(t)
    returner lengde(nøkler(strenger)) > 0
}

funksjon tal_strenger(t: ordbok_tekst) -> heltall {
    returner lengde(nøkler(_les_strenger(t)))
}

# ─── Fil-lasting ──────────────────────────────────────────────────────────────

funksjon _last_fil(t: ordbok_tekst, sti: tekst) -> heltall {
    prøv {
        la innhald = fil_les(sti)
        la linjer = builtin.split(innhald, "\n")
        la strenger = _les_strenger(t)
        la fmap     = _les_fleirtal(t)
        la i: heltall = 0
        mens i < lengde(linjer) {
            la linje = builtin.trim(linjer[i])
            // Hopp over kommentarar og tomme linjer
            hvis linje == "" eller tekst_starter_med(linje, "#") {
                i = i + 1
                fortsett
            }
            // Format: "original" = "omsett"
            // eller:  "eintal" | "fleirtal" = "eintal_o" | "fleirtal_o"
            la eq_idx = builtin.index_of(linje, "\" = \"")
            hvis eq_idx > 0 {
                la venstre = builtin.trim(builtin.slice(linje, 0, eq_idx + 1))
                la høgre   = builtin.trim(builtin.slice(linje, eq_idx + 5, lengde(linje)))
                // Fjern ytre sitat
                venstre = _fjern_sitat(venstre)
                høgre   = _fjern_sitat(høgre)
                // Sjekk om det er fleirtal (inneheld " | ")
                la pipe_v = builtin.index_of(venstre, "\" | \"")
                la pipe_h = builtin.index_of(høgre,   "\" | \"")
                hvis pipe_v >= 0 og pipe_h >= 0 {
                    la v_delar = builtin.split(venstre, "\" | \"")
                    la h_delar = builtin.split(høgre,   "\" | \"")
                    la eintal_o = _fjern_sitat(v_delar[0])
                    la fleirt_o = hvis lengde(v_delar) > 1 { _fjern_sitat(v_delar[1]) } ellers { eintal_o }
                    la eintal_t = _fjern_sitat(h_delar[0])
                    la fleirt_t = hvis lengde(h_delar) > 1 { _fjern_sitat(h_delar[1]) } ellers { eintal_t }
                    la combo = eintal_t + "|||" + fleirt_t
                    fmap[eintal_o]  = combo
                    fmap[fleirt_o]  = combo
                } ellers {
                    strenger[venstre] = høgre
                }
            }
            i = i + 1
        }
        _skriv_strenger(t, strenger)
        _skriv_fleirtal(t, fmap)
    } fang (e) {
        // Filen finst ikkje — ok
    }
    returner 0
}

// %(key)s og %(key)d interpolasjon — Django-stil
funksjon _interpoler(tmpl: tekst, ctx: ordbok_tekst) -> tekst {
    la r = tmpl
    la nk = nøkler(ctx)
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        la v = tekst(ctx[k])
        r = tekst_erstatt(r, "%(" + k + ")s", v)
        r = tekst_erstatt(r, "%(" + k + ")d", v)
        r = tekst_erstatt(r, "{" + k + "}", v)
        i = i + 1
    }
    returner r
}

funksjon _fjern_sitat(s: tekst) -> tekst {
    la t = builtin.trim(s)
    hvis (tekst_starter_med(t, "\"") og tekst_slutter_med(t, "\"")) {
        returner builtin.slice(t, 1, lengde(t) - 1)
    }
    returner t
}

funksjon _les_strenger(t: ordbok_tekst) -> ordbok_tekst {
    prøv {
        la parsed = builtin.json_parse_raw(t["__strenger__"])
        returner parsed
    } fang (e) { returner {} }
    returner {}
}

funksjon _les_fleirtal(t: ordbok_tekst) -> ordbok_tekst {
    prøv {
        la parsed = builtin.json_parse_raw(t["__fleirtal__"])
        returner parsed
    } fang (e) { returner {} }
    returner {}
}

funksjon _skriv_strenger(t: ordbok_tekst, data: ordbok_tekst) -> heltall {
    la nk = nøkler(data)
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        la v = tekst_erstatt(tekst(data[k]), "\"", "\\\"")
        la ke = tekst_erstatt(k, "\"", "\\\"")
        legg_til(delar, "\"" + ke + "\":\"" + v + "\"")
        i = i + 1
    }
    t["__strenger__"] = "{" + tekst_saman(delar, ",") + "}"
    returner 0
}

funksjon _skriv_fleirtal(t: ordbok_tekst, data: ordbok_tekst) -> heltall {
    la nk = nøkler(data)
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        la v = tekst_erstatt(tekst(data[k]), "\"", "\\\"")
        la ke = tekst_erstatt(k, "\"", "\\\"")
        legg_til(delar, "\"" + ke + "\":\"" + v + "\"")
        i = i + 1
    }
    t["__fleirtal__"] = "{" + tekst_saman(delar, ",") + "}"
    returner 0
}

# logg.no — Strukturert logging for Norscode
# Python logging-ekvivalent
#
# Bruk:
#   bruk std.logg som logg
#
#   la l = logg.ny("app")
#   logg.info(l, "Server starta på port 4173")
#   logg.åtvaring(l, "Ugyldig innlogging", {"ip": "1.2.3.4"})
#   logg.feil(l, "Databasefeil", {"sql": spørjing, "err": feil})
#
#   // Med fil-utgang
#   la l = logg.ny_fil("app", "logg/app.log")
#   logg.sett_nivå(l, logg.NIVÅ_DEBUG)

# ─── Konstantar ───────────────────────────────────────────────────────────────

funksjon NIVÅ_DEBUG()    -> heltall  {
    returner 10
}
funksjon NIVÅ_INFO()     -> heltall  {
    returner 20
}
funksjon NIVÅ_ÅTVARING() -> heltall  {
    returner 30
}
funksjon NIVÅ_FEIL()     -> heltall  {
    returner 40
}
funksjon NIVÅ_KRITISK()  -> heltall  {
    returner 50
}

funksjon _nivå_namn(n: heltall) -> tekst {
    hvis n >= 50 { returner "KRITISK" }
    hvis n >= 40 { returner "FEIL   " }
    hvis n >= 30 { returner "ÅTVARING" }
    hvis n >= 20 { returner "INFO   " }
    returner "DEBUG  "
}

# ─── Logger-oppretting ────────────────────────────────────────────────────────

funksjon ny(namn: tekst) -> ordbok_tekst {
    la l: ordbok_tekst = {}
    l["namn"]    = namn
    l["nivå"]    = tekst_fra_heltall(NIVÅ_INFO())
    l["format"]  = "tekst"   // "tekst" eller "json"
    l["fil"]     = ""        // tom = berre konsoll
    l["farge"]   = "sann"    // ANSI-fargar i konsoll
    returner l
}

funksjon ny_fil(namn: tekst, sti: tekst) -> ordbok_tekst {
    la l = ny(namn)
    l["fil"] = sti
    // Lag mappe viss nødvendig
    la delar = builtin.split(sti, "/")
    hvis lengde(delar) > 1 {
        la mappe_delar: liste<tekst> = []
        la i: heltall = 0
        mens i < lengde(delar) - 1 {
            legg_til(mappe_delar, delar[i])
            i = i + 1
        }
        la mappe = tekst_saman(mappe_delar, "/")
        prøv { builtin.mkdir(mappe) } fang (e) { }
    }
    returner l
}

funksjon ny_json(namn: tekst) -> ordbok_tekst {
    la l = ny(namn)
    l["format"] = "json"
    returner l
}

funksjon sett_nivå(l: ordbok_tekst, nivå: heltall) -> ordbok_tekst {
    l["nivå"] = tekst_fra_heltall(nivå)
    returner l
}

funksjon sett_format(l: ordbok_tekst, format: tekst) -> ordbok_tekst {
    l["format"] = format
    returner l
}

# ─── Logging ──────────────────────────────────────────────────────────────────

funksjon debug(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, NIVÅ_DEBUG(), melding, {})
}

funksjon debug_data(l: ordbok_tekst, melding: tekst, data: ordbok_tekst) -> heltall {
    returner _logg(l, NIVÅ_DEBUG(), melding, data)
}

funksjon info(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, NIVÅ_INFO(), melding, {})
}

funksjon info_data(l: ordbok_tekst, melding: tekst, data: ordbok_tekst) -> heltall {
    returner _logg(l, NIVÅ_INFO(), melding, data)
}

funksjon åtvaring(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, NIVÅ_ÅTVARING(), melding, {})
}

funksjon åtvaring_data(l: ordbok_tekst, melding: tekst, data: ordbok_tekst) -> heltall {
    returner _logg(l, NIVÅ_ÅTVARING(), melding, data)
}

funksjon feil(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, NIVÅ_FEIL(), melding, {})
}

funksjon feil_data(l: ordbok_tekst, melding: tekst, data: ordbok_tekst) -> heltall {
    returner _logg(l, NIVÅ_FEIL(), melding, data)
}

funksjon kritisk(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, NIVÅ_KRITISK(), melding, {})
}

funksjon kritisk_data(l: ordbok_tekst, melding: tekst, data: ordbok_tekst) -> heltall {
    returner _logg(l, NIVÅ_KRITISK(), melding, data)
}

# ─── Request-logging ──────────────────────────────────────────────────────────

funksjon logg_request(l: ordbok_tekst, metode: tekst, sti: tekst, status: heltall, ms: heltall) -> heltall {
    la data: ordbok_tekst = {}
    data["metode"] = metode
    data["sti"]    = sti
    data["status"] = tekst_fra_heltall(status)
    data["ms"]     = tekst_fra_heltall(ms)
    la nivå = NIVÅ_INFO()
    hvis status >= 500 {
        nivå = NIVÅ_FEIL() } ellers hvis status >= 400 { NIVÅ_ÅTVARING()
    }
    returner _logg(l, nivå, metode + " " + sti + " → " + tekst_fra_heltall(status) + " (" + tekst_fra_heltall(ms) + "ms)", data)
}

funksjon logg_db(l: ordbok_tekst, sql: tekst, ms: heltall) -> heltall {
    la data: ordbok_tekst = {}
    data["sql"] = builtin.slice(sql, 0, 120)
    data["ms"]  = tekst_fra_heltall(ms)
    returner _logg(l, NIVÅ_DEBUG(), "SQL (" + tekst_fra_heltall(ms) + "ms): " + builtin.slice(sql, 0, 80), data)
}

# ─── Underpool / barnloggar ───────────────────────────────────────────────────

funksjon barn(l: ordbok_tekst, namn: tekst) -> ordbok_tekst {
    la b = ny(l["namn"] + "." + namn)
    b["nivå"]   = l["nivå"]
    b["format"] = l["format"]
    b["fil"]    = l["fil"]
    b["farge"]  = l["farge"]
    returner b
}

# ─── Intern implementasjon ────────────────────────────────────────────────────

funksjon _logg(l: ordbok_tekst, nivå: heltall, melding: tekst, data: ordbok_tekst) -> heltall {
    la l_nivå = heltall_fra_tekst(l["nivå"])
    hvis nivå < l_nivå { returner 0 }

    la ts = _no_iso()
    la linje = _format_tekst(l["namn"], nivå, ts, melding, data, l["farge"] == "sann")
    hvis l["format"] == "json" {
        linje = _format_json(l["namn"], nivå, ts, melding, data)
    }

    // Konsoll-utgang
    skriv(linje)

    // Fil-utgang
    la sti = l["fil"]
    hvis sti != "" {
        prøv {
            fil_legg_til(sti, linje + "\n")
        } fang (e) {
            skriv("[logg] Feil ved skriving til " + sti + ": " + tekst(e))
        }
    }
    returner 1
}

funksjon _format_tekst(namn: tekst, nivå: heltall, ts: tekst, melding: tekst, data: ordbok_tekst, farge: boolsk) -> tekst {
    la nivå_s = _nivå_namn(nivå)
    la prefix = ts + " [" + nivå_s + "] " + namn + ": "

    la farge_start = ""
    la farge_slutt  = ""
    hvis farge {
        hvis nivå >= 50 { farge_start = "[1;31m" }
        ellers hvis nivå >= 40 { farge_start = "[31m" }
        ellers hvis nivå >= 30 { farge_start = "[33m" }
        ellers hvis nivå >= 20 { farge_start = "[32m" }
        ellers { farge_start = "[36m" }
        farge_slutt = "[0m"
    }

    la linje = farge_start + prefix + melding + farge_slutt
    la nk = nøkler(data)
    hvis lengde(nk) > 0 {
        la delar: liste<tekst> = []
        la i: heltall = 0
        mens i < lengde(nk) {
            la k: tekst = nk[i]
            legg_til(delar, k + "=" + tekst(data[k]))
            i = i + 1
        }
        linje = linje + "  {" + tekst_saman(delar, ", ") + "}"
    }
    returner linje
}

funksjon _format_json(namn: tekst, nivå: heltall, ts: tekst, melding: tekst, data: ordbok_tekst) -> tekst {
    la delar: liste<tekst> = []
    legg_til(delar, "\"ts\":\"" + ts + "\"")
    legg_til(delar, "\"nivå\":\"" + builtin.trim(_nivå_namn(nivå)) + "\"")
    legg_til(delar, "\"logger\":\"" + namn + "\"")
    legg_til(delar, "\"melding\":\"" + _esc(melding) + "\"")
    la nk = nøkler(data)
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        legg_til(delar, "\"" + k + "\":\"" + _esc(tekst(data[k])) + "\"")
        i = i + 1
    }
    returner "{" + tekst_saman(delar, ",") + "}"
}

funksjon _esc(s: tekst) -> tekst {
    la r = tekst_erstatt(s, "\\", "\\\\")
    r = tekst_erstatt(r, "\"", "\\\"")
    r = tekst_erstatt(r, "\n", "\\n")
    returner r
}

funksjon _no_iso() -> tekst {
    prøv { returner builtin.now_iso() } fang (e) { returner "1970-01-01T00:00:00" }
    returner ""
}

# media_job_store.no — Norscode-native varig lagring for media_job

bruk std.media_job som media_job

funksjon _escape(verdi: tekst) -> tekst {
    la ut = builtin.replace(verdi, "%", "%25")
    ut = builtin.replace(ut, "\r", "%0D")
    ut = builtin.replace(ut, "\n", "%0A")
    returner ut
}

funksjon _unescape(verdi: tekst) -> tekst {
    la ut = builtin.replace(verdi, "%0A", "\n")
    ut = builtin.replace(ut, "%0D", "\r")
    ut = builtin.replace(ut, "%25", "%")
    returner ut
}

funksjon _line(nokkel: tekst, verdi: tekst) -> tekst {
    returner nokkel + "=" + _escape(verdi) + "\n"
}

funksjon serialiser(jobb: ordbok_tekst) -> tekst {
    la ut = _line("schema", jobb["schema"])
    ut = ut + _line("id", jobb["id"])
    ut = ut + _line("type", jobb["type"])
    ut = ut + _line("prompt", jobb["prompt"])
    ut = ut + _line("leverandor", jobb["leverandor"])
    ut = ut + _line("status", jobb["status"])
    ut = ut + _line("fremdrift", jobb["fremdrift"])
    ut = ut + _line("oppretta_ms", jobb["oppretta_ms"])
    ut = ut + _line("starta_ms", jobb["starta_ms"])
    ut = ut + _line("oppdatert_ms", jobb["oppdatert_ms"])
    ut = ut + _line("timeout_ms", jobb["timeout_ms"])
    ut = ut + _line("resultat_sti", jobb["resultat_sti"])
    ut = ut + _line("resultat_mime", jobb["resultat_mime"])
    ut = ut + _line("feil", jobb["feil"])
    ut = ut + _line("avbrot_grunn", jobb["avbrot_grunn"])
    ut = ut + _line("ekstern_id", jobb["ekstern_id"])
    ut = ut + _line("status_url", jobb["status_url"])
    ut = ut + _line("avbryt_url", jobb["avbryt_url"])
    ut = ut + _line("forsok", jobb["forsok"])
    returner ut
}

funksjon _felt(raw: tekst, nokkel: tekst) -> tekst {
    la marker = nokkel + "="
    la pos = builtin.index_of(raw, marker)
    hvis pos < 0 { returner "" }
    la start = pos + lengde(marker)
    la rest = builtin.slice(raw, start, lengde(raw))
    la slutt = builtin.index_of(rest, "\n")
    hvis slutt < 0 { returner _unescape(rest) }
    returner _unescape(builtin.slice(rest, 0, slutt))
}

funksjon lagre(jobb: ordbok_tekst, sti: tekst) -> boolsk {
    hvis sti == "" { returner usann }
    prøv {
        builtin.fil_skriv(sti, serialiser(jobb))
        returner sann
    } fang (e) {
        returner usann
    }
}

funksjon last(sti: tekst) -> ordbok_tekst {
    la raw = builtin.fil_les(sti)
    hvis _felt(raw, "schema") != "norscode.media-job.v1" {
        kast "MediaJobbFeil: ugyldig lagringsformat"
    }
    la jobb = media_job.ny(_felt(raw, "id"), _felt(raw, "type"), _felt(raw, "prompt"),
                             _felt(raw, "leverandor"), heltall_fra_tekst(_felt(raw, "oppretta_ms")),
                             heltall_fra_tekst(_felt(raw, "timeout_ms")))
    jobb["status"] = _felt(raw, "status")
    jobb["fremdrift"] = _felt(raw, "fremdrift")
    jobb["starta_ms"] = _felt(raw, "starta_ms")
    jobb["oppdatert_ms"] = _felt(raw, "oppdatert_ms")
    jobb["resultat_sti"] = _felt(raw, "resultat_sti")
    jobb["resultat_mime"] = _felt(raw, "resultat_mime")
    jobb["feil"] = _felt(raw, "feil")
    jobb["avbrot_grunn"] = _felt(raw, "avbrot_grunn")
    jobb["ekstern_id"] = _felt(raw, "ekstern_id")
    jobb["status_url"] = _felt(raw, "status_url")
    jobb["avbryt_url"] = _felt(raw, "avbryt_url")
    jobb["forsok"] = _felt(raw, "forsok")
    hvis jobb["forsok"] == "" { jobb["forsok"] = "0" }
    returner jobb
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "format": "norscode.media-job.v1", "dekning": "jobbstate kan skrivast og lastast varig utan JSON eller eksterne verktøy"}
}

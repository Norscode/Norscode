# Stabel standardbibliotek (LIFO)
# Ein stabel er ein liste der element leggjast til og takast frå toppen.
#
# Bruk (heltall):
#   la s: liste_heltall = stabel_ny_tall()
#   stabel_dytt_tall(s, 10)
#   stabel_dytt_tall(s, 20)
#   la verdi: heltall = stabel_pop_tall(s)   # => 20

# --- Heltall ---

funksjon stabel_ny_tall() -> liste_heltall {
    returner []
}

# Dytt element på toppen
funksjon stabel_dytt_tall(s: liste_heltall, verdi: heltall) -> heltall {
    legg_til(s, verdi)
    returner lengde(s)
}

# Ta element frå toppen. Returnerer 0 viss tom.
funksjon stabel_pop_tall(s: liste_heltall) -> heltall {
    hvis (lengde(s) == 0) { returner 0 }
    returner pop_siste(s)
}

# Sjå på toppen utan å ta det ut
funksjon stabel_topp_tall(s: liste_heltall) -> heltall {
    la n: heltall = lengde(s)
    hvis (n == 0) { returner 0 }
    returner s[n - 1]
}

funksjon stabel_er_tom_tall(s: liste_heltall) -> bool {
    returner lengde(s) == 0
}

funksjon stabel_storleik_tall(s: liste_heltall) -> heltall {
    returner lengde(s)
}

# Tøm stabelen
funksjon stabel_tøm_tall(s: liste_heltall) -> heltall {
    mens (lengde(s) > 0) {
        pop_siste(s)
    }
    returner 0
}

# --- Tekst ---

funksjon stabel_ny_tekst() -> liste_tekst {
    returner []
}

funksjon stabel_dytt_tekst(s: liste_tekst, verdi: tekst) -> heltall {
    legg_til(s, verdi)
    returner lengde(s)
}

# Ta element frå toppen. Returnerer "" viss tom.
funksjon stabel_pop_tekst(s: liste_tekst) -> tekst {
    hvis (lengde(s) == 0) { returner "" }
    returner pop_siste(s)
}

funksjon stabel_topp_tekst(s: liste_tekst) -> tekst {
    la n: heltall = lengde(s)
    hvis (n == 0) { returner "" }
    returner s[n - 1]
}

funksjon stabel_er_tom_tekst(s: liste_tekst) -> bool {
    returner lengde(s) == 0
}

funksjon stabel_storleik_tekst(s: liste_tekst) -> heltall {
    returner lengde(s)
}

funksjon stabel_tøm_tekst(s: liste_tekst) -> heltall {
    mens (lengde(s) > 0) {
        pop_siste(s)
    }
    returner 0
}

# test.no — Testramme for Norscode
# Django TestCase-inspirert
#
# Bruk:
#   bruk std.test som test
#
#   funksjon test_addisjon() -> heltall {
#       test.lik(tekst_fra_heltall(1 + 1), "2", "1+1 skal vera 2")
#       returner 0
#   }
#
#   funksjon start() -> heltall {
#       returner test.køyr(["test_addisjon"])
#   }

# ─── Assertions ───────────────────────────────────────────────────────────────

funksjon lik(faktisk: tekst, forventa: tekst, melding: tekst) -> boolsk {
    hvis faktisk == forventa { returner sann }
    kast "FEILA: " + melding + "\n  Forventa: " + forventa + "\n  Fekk:     " + faktisk
    returner usann
}

funksjon lik_int(faktisk: heltall, forventa: heltall, melding: tekst) -> boolsk {
    returner lik(tekst_fra_heltall(faktisk), tekst_fra_heltall(forventa), melding)
}

funksjon lik_bool(faktisk: boolsk, forventa: boolsk, melding: tekst) -> boolsk {
    la f_str = hvis faktisk { "sann" } ellers { "usann" }
    la e_str = hvis forventa { "sann" } ellers { "usann" }
    returner lik(f_str, e_str, melding)
}

funksjon ikkje_lik(faktisk: tekst, ikkje_forventa: tekst, melding: tekst) -> boolsk {
    hvis faktisk != ikkje_forventa { returner sann }
    kast "FEILA: " + melding + "\n  Forventa IKKJE: " + ikkje_forventa
    returner usann
}

funksjon sann_at(betingelse: boolsk, melding: tekst) -> boolsk {
    hvis betingelse { returner sann }
    kast "FEILA: " + melding + " (forventna sann, var usann)"
    returner usann
}

funksjon usann_at(betingelse: boolsk, melding: tekst) -> boolsk {
    hvis ikkje betingelse { returner sann }
    kast "FEILA: " + melding + " (forventna usann, var sann)"
    returner usann
}

funksjon inneholder(haystack: tekst, needle: tekst, melding: tekst) -> boolsk {
    hvis tekst_inneholder(haystack, needle) { returner sann }
    kast "FEILA: " + melding + "\n  '" + needle + "' ikkje funne i: " + haystack
    returner usann
}

funksjon tom(s: tekst, melding: tekst) -> boolsk {
    hvis s == "" { returner sann }
    kast "FEILA: " + melding + " (forventa tom, fekk: '" + s + "')"
    returner usann
}

funksjon ikkje_tom(s: tekst, melding: tekst) -> boolsk {
    hvis s != "" { returner sann }
    kast "FEILA: " + melding + " (forventa ikkje-tom tekst)"
    returner usann
}

funksjon større_enn(a: heltall, b: heltall, melding: tekst) -> boolsk {
    hvis a > b { returner sann }
    kast "FEILA: " + melding + " (" + tekst_fra_heltall(a) + " er ikkje > " + tekst_fra_heltall(b) + ")"
    returner usann
}

funksjon mellom(v: heltall, min: heltall, maks: heltall, melding: tekst) -> boolsk {
    hvis v >= min og v <= maks { returner sann }
    kast "FEILA: " + melding + " (" + tekst_fra_heltall(v) + " ikkje mellom " + tekst_fra_heltall(min) + " og " + tekst_fra_heltall(maks) + ")"
    returner usann
}

# ─── HTTP-testklient ──────────────────────────────────────────────────────────

funksjon ny_klient(app_fil: tekst) -> ordbok_tekst {
    la k: ordbok_tekst = {}
    k["app_fil"]  = app_fil
    k["headers"]  = {}
    k["cookies"]  = {}
    returner k
}

funksjon sett_header(klient: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> ordbok_tekst {
    la h = klient["headers"]
    h[nøkkel] = verdi
    klient["headers"] = h
    returner klient
}

funksjon sett_auth_token(klient: ordbok_tekst, token: tekst) -> ordbok_tekst {
    returner sett_header(klient, "authorization", "Bearer " + token)
}

funksjon sett_cookie(klient: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> ordbok_tekst {
    la c = klient["cookies"]
    c[nøkkel] = verdi
    klient["cookies"] = c
    returner klient
}

funksjon get(klient: ordbok_tekst, sti: tekst) -> ordbok_tekst {
    returner _kall(klient, "GET", sti, "")
}

funksjon post(klient: ordbok_tekst, sti: tekst, body: tekst) -> ordbok_tekst {
    returner _kall(klient, "POST", sti, body)
}

funksjon post_json(klient: ordbok_tekst, sti: tekst, data: ordbok_tekst) -> ordbok_tekst {
    la nk = nøkler(data)
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        legg_til(delar, "\"" + k + "\":\"" + tekst(data[k]) + "\"")
        i = i + 1
    }
    la body = "{" + tekst_saman(delar, ",") + "}"
    la k2 = sett_header(klient, "content-type", "application/json")
    returner _kall(k2, "POST", sti, body)
}

funksjon put_json(klient: ordbok_tekst, sti: tekst, data: ordbok_tekst) -> ordbok_tekst {
    la nk = nøkler(data)
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        legg_til(delar, "\"" + k + "\":\"" + tekst(data[k]) + "\"")
        i = i + 1
    }
    la body = "{" + tekst_saman(delar, ",") + "}"
    la k2 = sett_header(klient, "content-type", "application/json")
    returner _kall(k2, "PUT", sti, body)
}

funksjon delete(klient: ordbok_tekst, sti: tekst) -> ordbok_tekst {
    returner _kall(klient, "DELETE", sti, "")
}

# ─── Respons-assertions ───────────────────────────────────────────────────────

funksjon status(resp: ordbok_tekst, forventa: heltall) -> boolsk {
    la faktisk = heltall_fra_tekst(resp["status"])
    returner lik_int(faktisk, forventa, "HTTP-status skal vera " + tekst_fra_heltall(forventa))
}

funksjon status_ok(resp: ordbok_tekst) -> boolsk {
    la s = heltall_fra_tekst(resp["status"])
    returner sann_at(s >= 200 og s < 300, "HTTP-status skal vera 2xx (fekk " + resp["status"] + ")")
}

funksjon body_inneholder(resp: ordbok_tekst, tekst_del: tekst) -> boolsk {
    returner inneholder(resp["body"], tekst_del, "Response body skal innehalda '" + tekst_del + "'")
}

funksjon inneholder_json(resp: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> boolsk {
    la body = resp["body"]
    la f1 = "\"" + nøkkel + "\":\"" + verdi + "\""
    la f2 = "\"" + nøkkel + "\":" + verdi
    hvis tekst_inneholder(body, f1) eller tekst_inneholder(body, f2) { returner sann }
    kast "FEILA: JSON-felt '" + nøkkel + "'='" + verdi + "' ikkje funne i: " + body
    returner usann
}

funksjon header_er(resp: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> boolsk {
    la h = resp["headers"]
    la faktisk = ""
    la low = tekst_til_liten(nøkkel)
    hvis har_nokkel(h, low) { faktisk = tekst(h[low]) }
    ellers hvis har_nokkel(h, nøkkel) { faktisk = tekst(h[nøkkel]) }
    returner lik(faktisk, verdi, "Header '" + nøkkel + "' skal vera '" + verdi + "'")
}

# ─── Test-køyrar ──────────────────────────────────────────────────────────────

funksjon køyr_ein(test_fn_namn: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    r["namn"] = test_fn_namn
    prøv {
        builtin.ncb_call_fn("__main__." + test_fn_namn, {})
        r["bestått"] = "sann"
        r["feil"]    = ""
        skriv("  ✓ " + test_fn_namn)
    } fang (e) {
        r["bestått"] = "usann"
        r["feil"]    = tekst(e)
        skriv("  ✗ " + test_fn_namn)
        skriv("    " + tekst(e))
    }
    returner r
}

funksjon køyr(testar: liste<tekst>) -> heltall {
    la totalt    = lengde(testar)
    la bestått:  heltall = 0
    la feila:    heltall = 0

    skriv("\n=== Norscode testkøyrar ===")
    skriv("Køyrer " + tekst_fra_heltall(totalt) + " testar...\n")

    la i: heltall = 0
    mens i < lengde(testar) {
        la namn: tekst = testar[i]
        la r = køyr_ein(namn)
        hvis r["bestått"] == "sann" { bestått = bestått + 1 }
        ellers { feila = feila + 1 }
        i = i + 1
    }

    skriv("\n---------------------------")
    skriv("Bestått: " + tekst_fra_heltall(bestått) + "/" + tekst_fra_heltall(totalt))
    hvis feila > 0 {
        skriv("Feila:   " + tekst_fra_heltall(feila))
        returner 1
    }
    skriv("Alle testar bestått!")
    returner 0
}

funksjon køyr_med_setup(testar: liste<tekst>, setup_fn: tekst, teardown_fn: tekst) -> heltall {
    la totalt   = lengde(testar)
    la bestått: heltall = 0
    la feila:   heltall = 0
    skriv("\n=== Norscode testkøyrar (med setup/teardown) ===")
    la i: heltall = 0
    mens i < lengde(testar) {
        la namn: tekst = testar[i]
        prøv { builtin.ncb_call_fn("__main__." + setup_fn, {}) } fang (e) { }
        la r = køyr_ein(namn)
        prøv { builtin.ncb_call_fn("__main__." + teardown_fn, {}) } fang (e) { }
        hvis r["bestått"] == "sann" { bestått = bestått + 1 }
        ellers { feila = feila + 1 }
        i = i + 1
    }
    skriv("Bestått: " + tekst_fra_heltall(bestått) + "/" + tekst_fra_heltall(totalt))
    returner hvis feila > 0 { 1 } ellers { 0 }
}

# ─── Temp-database for testar ─────────────────────────────────────────────────

funksjon test_db() -> tekst {
    returner ":memory:"
}

funksjon temp_db_sti() -> tekst {
    prøv {
        returner "/tmp/norscode_test_" + tekst_fra_heltall(builtin.now_ms()) + ".db"
    } fang (e) {
        returner "/tmp/norscode_test.db"
    }
    returner "/tmp/norscode_test.db"
}

# ─── HTTP-klient internals ────────────────────────────────────────────────────

funksjon _kall(klient: ordbok_tekst, metode: tekst, sti: tekst, body: tekst) -> ordbok_tekst {
    la app_fil = klient["app_fil"]
    la cookie_hdr = ""
    la c = klient["cookies"]
    la ck = nøkler(c)
    la i: heltall = 0
    mens i < lengde(ck) {
        la k: tekst = ck[i]
        hvis cookie_hdr != "" { cookie_hdr = cookie_hdr + "; " }
        cookie_hdr = cookie_hdr + k + "=" + c[k]
        i = i + 1
    }
    la headers_str = metode + " " + sti + " HTTP/1.1\r\nHost: localhost"
    la h = klient["headers"]
    la hk = nøkler(h)
    la j: heltall = 0
    mens j < lengde(hk) {
        la k: tekst = hk[j]
        headers_str = headers_str + "\r\n" + k + ": " + tekst(h[k])
        j = j + 1
    }
    hvis cookie_hdr != "" {
        headers_str = headers_str + "\r\ncookie: " + cookie_hdr
    }
    la rå_request = headers_str + "\r\n\r\n" + body
    prøv {
        la resp_raw = builtin.ncb_serve_one(app_fil, rå_request)
        returner _parse_respons(resp_raw)
    } fang (e) {
        la r: ordbok_tekst = {}
        r["status"]  = "500"
        r["body"]    = "Testklient-feil: " + e
        r["headers"] = {}
        returner r
    }
    returner {}
}

funksjon _parse_respons(rå: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    prøv {
        la parsed = builtin.json_parse_raw(rå)
        la type_v = builtin.type(parsed)
        hvis type_v == "ordbok" og har_nokkel(parsed, "__status__") {
            r["status"]  = tekst(parsed["__status__"])
            r["body"]    = tekst(parsed["__body__"])
            r["headers"] = parsed["__headers__"]
            returner r
        }
    } fang (e) { }
    la linjer = builtin.split(rå, "\r\n")
    hvis lengde(linjer) > 0 og tekst_starter_med(linjer[0], "HTTP/") {
        la sdel = builtin.split(linjer[0], " ")
        r["status"] = hvis lengde(sdel) > 1 { sdel[1] } ellers { "200" }
        la headers: ordbok_tekst = {}
        la body_start: heltall = 1
        la k: heltall = 1
        mens k < lengde(linjer) {
            la linje: tekst = linjer[k]
            hvis linje == "" { body_start = k + 1 }
            la eq = builtin.index_of(linje, ":")
            hvis eq > 0 {
                la hk2 = tekst_til_liten(builtin.trim(builtin.slice(linje, 0, eq)))
                la hv  = builtin.trim(builtin.slice(linje, eq + 1, lengde(linje)))
                headers[hk2] = hv
            }
            k = k + 1
        }
        r["headers"] = headers
        la body_delar: liste<tekst> = []
        la bk: heltall = body_start
        mens bk < lengde(linjer) {
            legg_til(body_delar, linjer[bk])
            bk = bk + 1
        }
        r["body"] = tekst_saman(body_delar, "\n")
    } ellers {
        r["status"]  = "200"
        r["body"]    = rå
        r["headers"] = {}
    }
    returner r
}

# URL standardbibliotek
# Encoding og decoding av URL-komponentar (RFC 3986).
#
# Bruk:
#   bruk std.url
#   la kodet = url_encode("hei verden & co=1")
#   # => "hei%20verden%20%26%20co%3D1"

# Hex-teikn for ein verdi 0-15
funksjon _hex_siffer(n: heltall) -> tekst {
    hvis (n < 10) { returner tekst_fra_heltall(n) }
    hvis (n == 10) { returner "a" }
    hvis (n == 11) { returner "b" }
    hvis (n == 12) { returner "c" }
    hvis (n == 13) { returner "d" }
    hvis (n == 14) { returner "e" }
    returner "f"
}

# Prosent-enkod ein byte-verdi
funksjon _pct(kode: heltall) -> tekst {
    la høy: heltall = kode / 16
    la låg: heltall = kode % 16
    returner "%" + _hex_siffer(høy) + _hex_siffer(låg)
}

# Encode ein URL-komponent (erstattar utrygge teikn med %XX)
funksjon url_encode(verdi: tekst) -> tekst {
    la tegn = builtin.split(verdi, "")
    la resultat: tekst = ""
    la i: heltall = 0
    mens (i < lengde(tegn)) {
        la c: tekst = tegn[i]
        la kode: heltall = builtin.char_code(c)
        # Uenkodet: A-Z a-z 0-9 - _ . ~
        la trygg: bool = (kode >= 65 og kode <= 90) eller   # A-Z
                         (kode >= 97 og kode <= 122) eller  # a-z
                         (kode >= 48 og kode <= 57) eller   # 0-9
                         c == "-" eller c == "_" eller
                         c == "." eller c == "~"
        hvis (trygg) {
            resultat = resultat + c
        } ellers hvis (c == " ") {
            resultat = resultat + "%20"
        } ellers {
            resultat = resultat + _pct(kode)
        }
        i = i + 1
    }
    returner resultat
}

# Encode heile URL (bevar ://?=&# som strukturteikn)
funksjon url_encode_full(verdi: tekst) -> tekst {
    la tegn = builtin.split(verdi, "")
    la resultat: tekst = ""
    la i: heltall = 0
    mens (i < lengde(tegn)) {
        la c: tekst = tegn[i]
        la kode: heltall = builtin.char_code(c)
        la trygg: bool = (kode >= 65 og kode <= 90) eller
                         (kode >= 97 og kode <= 122) eller
                         (kode >= 48 og kode <= 57) eller
                         c == "-" eller c == "_" eller c == "." eller c == "~" eller
                         c == ":" eller c == "/" eller c == "?" eller c == "=" eller
                         c == "&" eller c == "#" eller c == "@" eller c == "!"  eller
                         c == "$" eller c == "," eller c == ";"
        hvis (trygg) {
            resultat = resultat + c
        } ellers hvis (c == " ") {
            resultat = resultat + "%20"
        } ellers {
            resultat = resultat + _pct(kode)
        }
        i = i + 1
    }
    returner resultat
}

# Hex-siffer til verdi
funksjon _frå_hex(c: tekst) -> heltall {
    la kode: heltall = builtin.char_code(c)
    hvis (kode >= 48 og kode <= 57) { returner kode - 48 }
    hvis (kode >= 65 og kode <= 70) { returner kode - 55 }
    hvis (kode >= 97 og kode <= 102) { returner kode - 87 }
    returner 0
}

# Decode ein URL-komponent (%XX → teikn, + → mellomrom)
funksjon url_decode(verdi: tekst) -> tekst {
    la tegn = builtin.split(verdi, "")
    la n: heltall = lengde(tegn)
    la resultat: tekst = ""
    la i: heltall = 0
    mens (i < n) {
        la c: tekst = tegn[i]
        hvis (c == "%" og i + 2 < n) {
            la h1: heltall = _frå_hex(tegn[i + 1])
            la h2: heltall = _frå_hex(tegn[i + 2])
            la kode: heltall = h1 * 16 + h2
            # ASCII-teikn vi kan representere direkte
            hvis (kode >= 32 og kode < 127) {
                # Bygg teiknet via split-trick: encode ein kjend tekst og hent riktig posisjon
                # Sidan vi ikkje har chr()-builtin, handterer vi vanlege tilfelle
                la mapping: ordbok_tekst = {}
                mapping["32"] = " "
                mapping["33"] = "!"
                mapping["34"] = "\""
                mapping["35"] = "#"
                mapping["36"] = "$"
                mapping["37"] = "%"
                mapping["38"] = "&"
                mapping["39"] = "'"
                mapping["40"] = "("
                mapping["41"] = ")"
                mapping["42"] = "*"
                mapping["43"] = "+"
                mapping["44"] = ","
                mapping["45"] = "-"
                mapping["46"] = "."
                mapping["47"] = "/"
                mapping["58"] = ":"
                mapping["59"] = ";"
                mapping["60"] = "<"
                mapping["61"] = "="
                mapping["62"] = ">"
                mapping["63"] = "?"
                mapping["64"] = "@"
                mapping["91"] = "["
                mapping["92"] = "\\"
                mapping["93"] = "]"
                mapping["94"] = "^"
                mapping["95"] = "_"
                mapping["96"] = "`"
                mapping["123"] = "{"
                mapping["124"] = "|"
                mapping["125"] = "}"
                mapping["126"] = "~"
                la kode_s: tekst = tekst_fra_heltall(kode)
                hvis (har_nokkel(mapping, kode_s)) {
                    resultat = resultat + mapping[kode_s]
                } ellers hvis (kode >= 48 og kode <= 57) {
                    resultat = resultat + tekst_fra_heltall(kode - 48)
                } ellers {
                    # Behold %XX for teikn vi ikkje klarer å konvertere
                    resultat = resultat + c + tegn[i + 1] + tegn[i + 2]
                }
            } ellers {
                resultat = resultat + c + tegn[i + 1] + tegn[i + 2]
            }
            i = i + 3
        } ellers hvis (c == "+") {
            resultat = resultat + " "
            i = i + 1
        } ellers {
            resultat = resultat + c
            i = i + 1
        }
    }
    returner resultat
}

# Parse query-string "a=1&b=2" til ordbok_tekst
funksjon url_parse_query(qs: tekst) -> ordbok_tekst {
    la resultat: ordbok_tekst = {}
    la par = builtin.split(qs, "&")
    la i: heltall = 0
    mens (i < lengde(par)) {
        la p: tekst = par[i]
        la eq: heltall = builtin.index_of(p, "=")
        hvis (eq >= 0) {
            la k: tekst = url_decode(builtin.slice(p, 0, eq))
            la v: tekst = url_decode(builtin.slice(p, eq + 1, lengde(p)))
            resultat[k] = v
        } ellers hvis (lengde(p) > 0) {
            resultat[url_decode(p)] = ""
        }
        i = i + 1
    }
    returner resultat
}

# Bygg query-string frå ordbok_tekst
funksjon url_bygg_query(params: ordbok_tekst) -> tekst {
    la nk = builtin.nøkler(params)
    la deler: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nk)) {
        la k: tekst = nk[i]
        legg_til(deler, url_encode(k) + "=" + url_encode(params[k]))
        i = i + 1
    }
    returner builtin.join(deler, "&")
}

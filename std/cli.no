# CLI standardbibliotek

funksjon har_args(args: liste_tekst) -> bool {
    returner lengde(args) > 0
}

funksjon kommando(args: liste_tekst) -> tekst {
    hvis ikkje har_args(args) {
        returner "help"
    }
    returner args[0]
}

funksjon posisjonell(args: liste_tekst, indeks: heltall, fallback: tekst) -> tekst {
    hvis indeks < 0 {
        returner fallback
    }
    hvis indeks >= lengde(args) {
        returner fallback
    }
    returner args[indeks]
}

funksjon _flagg_prefix(navn: tekst) -> tekst {
    returner "--" + navn
}

funksjon har_flagg(args: liste_tekst, navn: tekst) -> bool {
    la flagg = _flagg_prefix(navn)
    la flagg_med_verdi = flagg + "="

    la i = 0
    mens i < lengde(args) {
        la verdi = args[i]
        hvis verdi == flagg {
            returner sann
        }
        hvis tekst_starter_med(verdi, flagg_med_verdi) {
            returner sann
        }
        i = i + 1
    }

    returner usann
}

funksjon flagg_verdi(args: liste_tekst, navn: tekst, fallback: tekst) -> tekst {
    la flagg = _flagg_prefix(navn)
    la flagg_med_verdi = flagg + "="

    la i = 0
    mens i < lengde(args) {
        la verdi = args[i]

        hvis verdi == flagg {
            hvis i + 1 < lengde(args) {
                returner args[i + 1]
            }
            returner fallback
        }

        hvis tekst_starter_med(verdi, flagg_med_verdi) {
            returner slice(verdi, lengde(flagg_med_verdi), lengde(verdi))
        }

        i = i + 1
    }

    returner fallback
}

funksjon rest(args: liste_tekst, start: heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la i = start
    mens i < lengde(args) {
        legg_til(resultat, args[i])
        i = i + 1
    }
    returner resultat
}


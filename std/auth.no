# auth.no — Autentisering for Norscode webappar
# Session-basert innlogging med passord-hashing
#
# Bruk:
#   bruk std.auth som auth
#   bruk std.db som db
#   bruk std.orm som orm
#
#   # Setup (ein gong ved oppstart)
#   auth.migrer(conn)
#
#   # Registrer brukar
#   la id = auth.registrer(conn, "ola", "ola@example.com", "passord123")
#
#   # Logg inn → returner session-token
#   la token = auth.logg_inn(conn, "ola@example.com", "passord123")
#
#   # Sjekk session i request
#   la brukar = auth.hent_brukar_frå_session(conn, web.request_cookie(ctx, "session"))
#
#   # Auth-guard
#   funksjon krev_innlogging(ctx) -> bool { returner auth.er_innlogga(conn, ctx) }
#   web.route("GET /profil")
#   web.use_guard("krev_innlogging")

bruk std.db som db
bruk std.orm som orm
bruk std.krypto som krypto

# ─── Database-oppsett ─────────────────────────────────────────────────────────

funksjon migrer(conn: tekst) -> heltall {
    orm.migrer(conn, "auth_brukar", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "brukarnamn TEXT NOT NULL UNIQUE",
        "epost TEXT NOT NULL UNIQUE",
        "passord_hash TEXT NOT NULL",
        "salt TEXT NOT NULL",
        "aktiv TEXT DEFAULT 'sann'",
        "rolle TEXT DEFAULT 'brukar'",
        "sist_innlogga TEXT",
        "oppretta TEXT DEFAULT (datetime('now'))"
    ])
    orm.migrer(conn, "auth_session", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "token TEXT NOT NULL UNIQUE",
        "brukar_id INTEGER NOT NULL",
        "oppretta TEXT DEFAULT (datetime('now'))",
        "utgår TEXT",
        "aktiv TEXT DEFAULT 'sann'"
    ])
    orm.migrer(conn, "auth_passord_reset", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "token TEXT NOT NULL UNIQUE",
        "brukar_id INTEGER NOT NULL",
        "oppretta TEXT DEFAULT (datetime('now'))",
        "brukt TEXT DEFAULT 'usann'"
    ])
    returner 1
}

# ─── Passord-hashing ──────────────────────────────────────────────────────────

# Produksjonsbanen krev runtime-krypto. Svake fallbackar skal ikkje brukast for auth.
funksjon _generer_salt() -> tekst {
    returner builtin.random_hex(32)
}

funksjon _hash_passord(passord: tekst, salt: tekst) -> tekst {
    returner krypto.pbkdf2_sha256(passord, salt, 120000, 32)
}

funksjon _naiv_hash(s: tekst) -> tekst {
    // Deterministisk men ikkje kryptografisk — bruk berre som fallback
    la h: heltall = 5381
    la tegn = builtin.split(s, "")
    la i: heltall = 0
    mens i < lengde(tegn) {
        la c = builtin.char_code(tegn[i])
        h = ((h * 33) + c) % 2147483647
        i = i + 1
    }
    returner ""
}

funksjon _generer_token() -> tekst {
    prøv {
        returner builtin.random_hex(64)
    } fang (e) {
        kast "auth krev builtin.random_hex"
    }
    returner ""
}

funksjon verifiser_passord(passord: tekst, salt: tekst, lagra_hash: tekst) -> boolsk {
    la kalkulert = _hash_passord(passord, salt)
    returner kalkulert == lagra_hash
}

# ─── Registrering ─────────────────────────────────────────────────────────────

funksjon registrer(conn: tekst, brukarnamn: tekst, epost: tekst, passord: tekst) -> heltall {
    // Sjekk om epost er teken
    hvis orm.finnes_ved(conn, "auth_brukar", "epost", epost) {
        returner -1  // Epost alt i bruk
    }
    hvis orm.finnes_ved(conn, "auth_brukar", "brukarnamn", brukarnamn) {
        returner -2  // Brukarnamn alt i bruk
    }
    la salt = _generer_salt()
    la hash = _hash_passord(passord, salt)
    returner orm.lagre(conn, "auth_brukar", {
        "brukarnamn": brukarnamn,
        "epost": epost,
        "passord_hash": hash,
        "salt": salt
    })
}

funksjon registrer_med_rolle(conn: tekst, brukarnamn: tekst, epost: tekst, passord: tekst, rolle: tekst) -> heltall {
    la id = registrer(conn, brukarnamn, epost, passord)
    hvis id > 0 {
        orm.oppdater(conn, "auth_brukar", id, {"rolle": rolle})
    }
    returner id
}

# ─── Innlogging / utlogging ───────────────────────────────────────────────────

funksjon logg_inn(conn: tekst, epost: tekst, passord: tekst) -> tekst {
    la brukar = orm.finn_ved(conn, "auth_brukar", "epost", epost)
    hvis ikkje har_nokkel(brukar, "id") { returner "" }
    hvis brukar["aktiv"] != "sann" { returner "" }

    la salt = brukar["salt"]
    la hash = brukar["passord_hash"]
    hvis ikkje verifiser_passord(passord, salt, hash) { returner "" }

    // Generer session-token
    la token = _generer_token()
    la brukar_id = heltall_fra_tekst(brukar["id"])

    orm.lagre(conn, "auth_session", {
        "token": token,
        "brukar_id": brukar["id"],
        "aktiv": "sann"
    })

    // Oppdater sist_innlogga
    prøv {
        orm.oppdater(conn, "auth_brukar", brukar_id, {"sist_innlogga": builtin.now_iso()})
    } fang (e) { }

    returner token
}

funksjon logg_ut(conn: tekst, token: tekst) -> boolsk {
    la session = orm.finn_ved(conn, "auth_session", "token", token)
    hvis ikkje har_nokkel(session, "id") { returner usann }
    la id = heltall_fra_tekst(session["id"])
    orm.oppdater(conn, "auth_session", id, {"aktiv": "usann"})
    returner sann
}

funksjon logg_ut_alle(conn: tekst, brukar_id: heltall) -> heltall {
    returner orm.kjør(conn, "UPDATE auth_session SET aktiv = 'usann' WHERE brukar_id = " + tekst_fra_heltall(brukar_id))
}

# ─── Session-oppslag ──────────────────────────────────────────────────────────

funksjon hent_session(conn: tekst, token: tekst) -> ordbok_tekst {
    la session = orm.finn_ved(conn, "auth_session", "token", token)
    hvis ikkje har_nokkel(session, "id") { returner {} }
    hvis session["aktiv"] != "sann" { returner {} }
    returner session
}

funksjon hent_brukar_frå_session(conn: tekst, token: tekst) -> ordbok_tekst {
    la session = hent_session(conn, token)
    hvis ikkje har_nokkel(session, "brukar_id") { returner {} }
    la brukar_id = heltall_fra_tekst(session["brukar_id"])
    la brukar = orm.finn(conn, "auth_brukar", brukar_id)
    hvis ikkje har_nokkel(brukar, "id") { returner {} }
    hvis brukar["aktiv"] != "sann" { returner {} }
    // Fjern sensitive felt frå retur
    la trygg: ordbok_tekst = {}
    trygg["id"] = brukar["id"]
    trygg["brukarnamn"] = brukar["brukarnamn"]
    trygg["epost"] = brukar["epost"]
    trygg["rolle"] = brukar["rolle"]
    trygg["oppretta"] = brukar["oppretta"]
    returner trygg
}

funksjon er_gyldig_session(conn: tekst, token: tekst) -> boolsk {
    la session = hent_session(conn, token)
    returner har_nokkel(session, "id")
}

# ─── Web-integrasjon ─────────────────────────────────────────────────────────

# Hent token frå cookie eller Authorization-header
funksjon hent_token(ctx: ordbok_tekst) -> tekst {
    la cookie = ""
    hvis har_nokkel(ctx, "__headers__") {
        la headers = ctx["__headers__"]
        hvis har_nokkel(headers, "cookie") {
            cookie = builtin.trim(headers["cookie"])
        }
    }
    // Parse "session=TOKEN" frå cookie
    la deler = builtin.split(cookie, ";")
    la i: heltall = 0
    mens i < lengde(deler) {
        la del = builtin.trim(deler[i])
        la eq = builtin.index_of(del, "=")
        hvis eq > 0 {
            la k = builtin.trim(builtin.slice(del, 0, eq))
            la v = builtin.trim(builtin.slice(del, eq + 1, lengde(del)))
            hvis k == "session" { returner v }
        }
        i = i + 1
    }
    // Prøv Bearer-token
    la auth_hdr = ""
    hvis har_nokkel(ctx["__headers__"], "authorization") {
        auth_hdr = ctx["__headers__"]["authorization"]
    }
    hvis tekst_starter_med(auth_hdr, "Bearer ") {
        returner builtin.slice(auth_hdr, 7, lengde(auth_hdr))
    }
    returner ""
}

funksjon session_cookie(token: tekst, dagar: heltall) -> tekst {
    returner "session=" + token + "; HttpOnly; Secure; SameSite=Lax; Max-Age=" + tekst_fra_heltall(dagar * 86400)
}

funksjon slett_session_cookie() -> tekst {
    returner "session=; HttpOnly; Secure; SameSite=Lax; Max-Age=0"
}

funksjon _json_escape_auth(s: tekst) -> tekst {
    la r = tekst_erstatt(s, "\\", "\\\\")
    r = tekst_erstatt(r, "\"", "\\\"")
    r = tekst_erstatt(r, "\n", "\\n")
    r = tekst_erstatt(r, "\r", "\\r")
    returner r
}

funksjon _json_melding(status: heltall, ok: tekst, melding: tekst) -> ordbok_tekst {
    la body = "{\"ok\":\"" + ok + "\",\"melding\":\"" + _json_escape_auth(melding) + "\"}"
    returner web.response_builder(status, {"content-type": "application/json; charset=utf-8"}, body)
}

funksjon response_ikkje_innlogga(melding: tekst) -> ordbok_tekst {
    la body = "{\"ok\":\"usann\",\"melding\":\"" + _json_escape_auth(melding) + "\"}"
    returner web.response_builder(401, {"content-type": "application/json; charset=utf-8", "www-authenticate": "Bearer"}, body)
}

funksjon response_manglar_rolle(rolle: tekst) -> ordbok_tekst {
    returner _json_melding(403, "usann", "Mangler rolle: " + rolle)
}

funksjon response_login(token: tekst, dagar: heltall, redirect_til: tekst) -> ordbok_tekst {
    hvis token == "" {
        returner response_ikkje_innlogga("Ugyldig innlogging")
    }
    la r: ordbok_tekst = {}
    la cookie = session_cookie(token, dagar)
    hvis redirect_til != "" {
        r = web.response_builder(303, {"location": redirect_til, "content-type": "text/plain; charset=utf-8", "set-cookie": cookie}, "")
    } ellers {
        r = web.response_builder(200, {"content-type": "application/json; charset=utf-8", "set-cookie": cookie}, "{\"ok\":\"sann\",\"melding\":\"Innlogga\"}")
    }
    returner r
}

funksjon response_logout(redirect_til: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la cookie = slett_session_cookie()
    hvis redirect_til != "" {
        r = web.response_builder(303, {"location": redirect_til, "content-type": "text/plain; charset=utf-8", "set-cookie": cookie}, "")
    } ellers {
        r = web.response_builder(200, {"content-type": "application/json; charset=utf-8", "set-cookie": cookie}, "{\"ok\":\"sann\",\"melding\":\"Utlogga\"}")
    }
    returner r
}

# Sett inn brukar-info i request-kontekst
funksjon berik_ctx(conn: tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la token = hent_token(ctx)
    hvis token == "" { returner ctx }
    la brukar = hent_brukar_frå_session(conn, token)
    hvis har_nokkel(brukar, "id") {
        ctx["__auth_id__"]       = brukar["id"]
        ctx["__auth_brukar__"]   = brukar["brukarnamn"]
        ctx["__auth_epost__"]    = brukar["epost"]
        ctx["__auth_rolle__"]    = brukar["rolle"]
        ctx["__auth_token__"]    = token
    }
    returner ctx
}

funksjon er_innlogga(ctx: ordbok_tekst) -> boolsk {
    returner har_nokkel(ctx, "__auth_id__")
}

funksjon krev_rolle(ctx: ordbok_tekst, rolle: tekst) -> boolsk {
    hvis ikkje er_innlogga(ctx) { returner usann }
    returner ctx["__auth_rolle__"] == rolle eller ctx["__auth_rolle__"] == "admin"
}

funksjon innlogga_brukar_id(ctx: ordbok_tekst) -> heltall {
    hvis har_nokkel(ctx, "__auth_id__") {
        returner heltall_fra_tekst(ctx["__auth_id__"])
    }
    returner 0
}

funksjon innlogga_rolle(ctx: ordbok_tekst) -> tekst {
    hvis har_nokkel(ctx, "__auth_rolle__") { returner ctx["__auth_rolle__"] }
    returner ""
}

funksjon sikkerheitsstatus() -> ordbok_tekst {
    returner {
        modul: "std.auth",
        token: "builtin.random_hex",
        passord_hash: "builtin.sha256",
        cookie: "HttpOnly; Secure; SameSite=Lax",
        roller: "kunde,agent,admin"
    }
}

# ─── Passord-reset ────────────────────────────────────────────────────────────

funksjon opprett_reset_token(conn: tekst, epost: tekst) -> tekst {
    la brukar = orm.finn_ved(conn, "auth_brukar", "epost", epost)
    hvis ikkje har_nokkel(brukar, "id") { returner "" }
    la token = _generer_token()
    orm.lagre(conn, "auth_passord_reset", {
        "token": token,
        "brukar_id": brukar["id"],
        "brukt": "usann"
    })
    returner token
}

funksjon utfør_reset(conn: tekst, token: tekst, nytt_passord: tekst) -> boolsk {
    la reset = orm.finn_ved(conn, "auth_passord_reset", "token", token)
    hvis ikkje har_nokkel(reset, "id") { returner usann }
    hvis reset["brukt"] == "sann" { returner usann }

    la brukar_id = heltall_fra_tekst(reset["brukar_id"])
    la salt = _generer_salt()
    la hash = _hash_passord(nytt_passord, salt)
    orm.oppdater(conn, "auth_brukar", brukar_id, {"passord_hash": hash, "salt": salt})
    la reset_id = heltall_fra_tekst(reset["id"])
    orm.oppdater(conn, "auth_passord_reset", reset_id, {"brukt": "sann"})
    logg_ut_alle(conn, brukar_id)
    returner sann
}

funksjon endre_passord(conn: tekst, brukar_id: heltall, gammalt: tekst, nytt: tekst) -> boolsk {
    la brukar = orm.finn(conn, "auth_brukar", brukar_id)
    hvis ikkje har_nokkel(brukar, "id") { returner usann }
    hvis ikkje verifiser_passord(gammalt, brukar["salt"], brukar["passord_hash"]) { returner usann }
    la salt = _generer_salt()
    la hash = _hash_passord(nytt, salt)
    orm.oppdater(conn, "auth_brukar", brukar_id, {"passord_hash": hash, "salt": salt})
    returner sann
}

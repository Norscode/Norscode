# media_neural.no — lokal kvantisert nevralt styrt mediegenerering

bruk std.model_runtime som model_runtime
bruk std.media_local som media_local
bruk std.neural_ops som neural_ops

funksjon prompt_vektor(prompt: tekst, dimensjon: heiltall) -> liste_heltall {
    hvis dimensjon <= 0 { kast "MediaNevralFeil: ugyldig dimensjon" }
    la ut: liste_heltall = []
    la i: heiltall = 0
    mens i < dimensjon {
        legg_til(ut, 0)
        i = i + 1
    }
    i = 0
    mens i < lengde(prompt) {
        la bucket = i % dimensjon
        ut[bucket] = (ut[bucket] + builtin.char_code(prompt[i]) + i * 7) % 128
        i = i + 1
    }
    returner ut
}

funksjon kontekst_vektor(prompt: tekst) -> liste_heltall {
    la tokens: liste_heltall = []
    la i: heiltall = 0
    mens i < lengde(prompt) og i < 16 {
        legg_til(tokens, builtin.char_code(prompt[i]) % 16)
        i = i + 1
    }
    hvis lengde(tokens) == 0 { legg_til(tokens, 0) }
    la tabell: liste_heltall = []
    i = 0
    mens i < 16 * 8 {
        legg_til(tabell, ((i * 11 + 3) % 31) - 15)
        i = i + 1
    }
    la emb = neural_ops.embedding(tabell, 16, 8, tokens)
    la norm = neural_ops.lag_norm(emb["data"], emb["rader"], 8, 16)
    la att = neural_ops.oppmerksomhet_med_backend(norm["data"], norm["data"], norm["data"], norm["rader"], 8, 16)
    la ut: liste_heltall = []
    la d: heiltall = 0
    mens d < 8 {
        la sum: heiltall = 0
        la r: heiltall = 0
        mens r < att["rader"] {
            sum = sum + att["data"][r * 8 + d]
            r = r + 1
        }
        legg_til(ut, sum / att["rader"])
        d = d + 1
    }
    returner ut
}

funksjon standardmodell() {
    la m = model_runtime.ny("norscode-media-q8-v1", 8)
    la w1: liste_heltall = []
    la b1: liste_heltall = []
    la i: heiltall = 0
    mens i < 8 * 12 {
        legg_til(w1, ((i * 17 + 11) % 15) - 7)
        i = i + 1
    }
    i = 0
    mens i < 12 {
        legg_til(b1, (i * 9) % 17 - 8)
        i = i + 1
    }
    model_runtime.legg_til_lag(m, model_runtime.dense(8, 12, w1, b1, 16, "relu"))

    la w2: liste_heltall = []
    la b2: liste_heltall = []
    i = 0
    mens i < 12 * 4 {
        legg_til(w2, ((i * 13 + 5) % 19) - 9)
        i = i + 1
    }
    i = 0
    mens i < 4 {
        legg_til(b2, i * 3 - 4)
        i = i + 1
    }
    model_runtime.legg_til_lag(m, model_runtime.dense(12, 4, w2, b2, 8, "hard_tanh"))
    returner m
}

funksjon _positiv(v: heiltall) -> heiltall {
    hvis v < 0 { returner 0 - v }
    returner v
}

funksjon plan(modell, prompt: tekst) -> ordbok_tekst {
    hvis builtin.trim(prompt) == "" { kast "MediaNevralFeil: prompt manglar" }
    la input = prompt_vektor(prompt, modell["input_dim"])
    hvis modell["input_dim"] == 8 { input = kontekst_vektor(prompt) }
    la inferens = model_runtime.kjor_med_backend(modell, input)
    la latent = inferens["data"]
    hvis lengde(latent) < 4 { kast "MediaNevralFeil: modellen må ha minst fire utverdiar" }
    la rod = (_positiv(latent[0]) * 3 + 31) % 256
    la gron = (_positiv(latent[1]) * 5 + 47) % 256
    la bla = (_positiv(latent[2]) * 7 + 71) % 256
    la frekvens = 110 + (_positiv(latent[3]) * 11) % 771
    returner {
        "modell": modell["navn"],
        "rod": tekst_fra_heltall(rod),
        "gron": tekst_fra_heltall(gron),
        "bla": tekst_fra_heltall(bla),
        "frekvens": tekst_fra_heltall(frekvens),
        "latent": tekst_fra_heltall(latent[0]) + "," + tekst_fra_heltall(latent[1]) + "," + tekst_fra_heltall(latent[2]) + "," + tekst_fra_heltall(latent[3]),
        "backend": inferens["backend"],
        "backend_fallback": tekst(inferens["fallback"])
    }
}

funksjon bilde(modell, prompt: tekst, sti: tekst,
               bredde: heiltall, hoyde: heiltall) -> ordbok_tekst {
    la p = plan(modell, prompt)
    returner media_local.bilde_med_palette(prompt, sti, bredde, hoyde,
        heltall_fra_tekst(p["rod"]), heltall_fra_tekst(p["gron"]), heltall_fra_tekst(p["bla"]))
}

funksjon lyd(modell, prompt: tekst, sti: tekst,
            varighet_ms: heiltall) -> ordbok_tekst {
    la p = plan(modell, prompt)
    returner media_local.lyd(prompt + p["latent"], sti, varighet_ms, heltall_fra_tekst(p["frekvens"]))
}

funksjon musikk(modell, prompt: tekst, sti: tekst,
                varighet_ms: heiltall) -> ordbok_tekst {
    la p = plan(modell, prompt)
    returner media_local.musikk(prompt + p["latent"], sti, varighet_ms, heltall_fra_tekst(p["frekvens"]))
}

funksjon video(modell, prompt: tekst, sti: tekst, bredde: heiltall,
               hoyde: heiltall, fps: heiltall,
               antal_bilder: heiltall) -> ordbok_tekst {
    la p = plan(modell, prompt)
    returner media_local.video(prompt + p["latent"], sti, bredde, hoyde, fps, antal_bilder)
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "eksperimentell", "motor": "norscode-media-q8-v1", "dekning": "lokalt kvantisert nevralt fremoverpass med tensor-ABI og Metal/CPU-fallback styrer PPM-fargar, WAV-frekvens/musikk og Y4M-videofro", "ekstern_runtime": "ingen", "gpu_backend": "norscode-tensor-v1 med CPU-fallback"}
}

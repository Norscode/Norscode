

# Liste standardbibliotek

funksjon legg_til_tall(l: liste_heltall, verdi: heltall) -> heltall {
    legg_til(l, verdi)
    returner lengde(l)
}

funksjon legg_til_tekst(l: liste_tekst, verdi: tekst) -> heltall {
    legg_til(l, verdi)
    returner lengde(l)
}

funksjon siste_tall(l: liste_heltall) -> heltall {
    returner pop_siste(l)
}

funksjon siste_tekst(l: liste_tekst) -> tekst {
    returner pop_siste(l)
}

funksjon første_tall(l: liste_heltall) -> heltall {
    hvis (lengde(l) == 0) {
        returner 0
    }
    returner l[0]
}

funksjon første_tekst(l: liste_tekst) -> tekst {
    hvis (lengde(l) == 0) {
        returner ""
    }
    returner l[0]
}

funksjon inneholder_tall(l: liste_heltall, verdi: heltall) -> bool {
    la i = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) {
            returner sann
        }
        i = i + 1
    }
    returner usann
}

funksjon inneholder_tekst(l: liste_tekst, verdi: tekst) -> bool {
    la i = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) {
            returner sann
        }
        i = i + 1
    }
    returner usann
}

funksjon antall_tall(l: liste_heltall) -> heltall {
    returner lengde(l)
}

funksjon antall_tekst(l: liste_tekst) -> heltall {
    returner lengde(l)
}

funksjon fjern_tall(l: liste_heltall, indeks: heltall) -> heltall {
    fjern_indeks(l, indeks)
    returner lengde(l)
}

funksjon fjern_tekst(l: liste_tekst, indeks: heltall) -> heltall {
    fjern_indeks(l, indeks)
    returner lengde(l)
}

funksjon sett_inn_tall(l: liste_heltall, indeks: heltall, verdi: heltall) -> heltall {
    sett_inn(l, indeks, verdi)
    returner lengde(l)
}

funksjon sett_inn_tekst(l: liste_tekst, indeks: heltall, verdi: tekst) -> heltall {
    sett_inn(l, indeks, verdi)
    returner lengde(l)
}

funksjon sorter_tall(l: liste_heltall) -> heltall {
    la n = lengde(l)
    la i = 0
    mens (i < n) {
        la j = 0
        mens (j + 1 < n - i) {
            hvis (l[j] > l[j + 1]) {
                la tmp = l[j]
                l[j] = l[j + 1]
                l[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    returner lengde(l)
}

funksjon sorter_tekst(l: liste_tekst) -> heltall {
    la n = lengde(l)
    la i = 0
    mens (i < n) {
        la j = 0
        mens (j + 1 < n - i) {
            hvis (l[j] > l[j + 1]) {
                la tmp = l[j]
                l[j] = l[j + 1]
                l[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    returner lengde(l)
}

funksjon summer_tall(l: liste_heltall) -> heltall {
    la sum = 0
    la i = 0
    mens (i < lengde(l)) {
        sum = sum + l[i]
        i = i + 1
    }
    returner sum
}

funksjon maks_tall(l: liste_heltall) -> heltall {
    hvis (lengde(l) == 0) {
        returner 0
    }
    la best = l[0]
    la i = 1
    mens (i < lengde(l)) {
        hvis (l[i] > best) {
            best = l[i]
        }
        i = i + 1
    }
    returner best
}

funksjon min_tall(l: liste_heltall) -> heltall {
    hvis (lengde(l) == 0) {
        returner 0
    }
    la best = l[0]
    la i = 1
    mens (i < lengde(l)) {
        hvis (l[i] < best) {
            best = l[i]
        }
        i = i + 1
    }
    returner best
}

funksjon omvendt_tall(l: liste_heltall) -> heltall {
    la venstre = 0
    la høyre = lengde(l) - 1
    mens (venstre < høyre) {
        la tmp = l[venstre]
        l[venstre] = l[høyre]
        l[høyre] = tmp
        venstre = venstre + 1
        høyre = høyre - 1
    }
    returner lengde(l)
}

funksjon finn_indeks_tall(l: liste_heltall, verdi: heltall) -> heltall {
    la i = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) {
            returner i
        }
        i = i + 1
    }
    returner -1
}

funksjon finn_indeks_tekst(l: liste_tekst, verdi: tekst) -> heltall {
    la i = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) {
            returner i
        }
        i = i + 1
    }
    returner -1
}

funksjon fjern_alle_tall(l: liste_heltall, verdi: heltall) -> heltall {
    la i = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) {
            fjern_indeks(l, i)
        } ellers {
            i = i + 1
        }
    }
    returner lengde(l)
}

funksjon fjern_alle_tekst(l: liste_tekst, verdi: tekst) -> heltall {
    la i = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) {
            fjern_indeks(l, i)
        } ellers {
            i = i + 1
        }
    }
    returner lengde(l)
}

# Tel førekomstar av ein verdi
funksjon tell_tall(l: liste_heltall, verdi: heltall) -> heltall {
    la n: heltall = 0
    la i: heltall = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) { n = n + 1 }
        i = i + 1
    }
    returner n
}

funksjon tell_tekst(l: liste_tekst, verdi: tekst) -> heltall {
    la n: heltall = 0
    la i: heltall = 0
    mens (i < lengde(l)) {
        hvis (l[i] == verdi) { n = n + 1 }
        i = i + 1
    }
    returner n
}

# Fjern duplikat (bevar rekkefølge)
funksjon uniq_tall(l: liste_heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la sett: ordbok_bool = {}
    la i: heltall = 0
    mens (i < lengde(l)) {
        la k: tekst = tekst_fra_heltall(l[i])
        hvis (ikke har_nokkel(sett, k)) {
            legg_til(resultat, l[i])
            sett[k] = sann
        }
        i = i + 1
    }
    returner resultat
}

funksjon uniq_tekst(l: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la sett: ordbok_bool = {}
    la i: heltall = 0
    mens (i < lengde(l)) {
        hvis (ikke har_nokkel(sett, l[i])) {
            legg_til(resultat, l[i])
            sett[l[i]] = sann
        }
        i = i + 1
    }
    returner resultat
}

# Utsnitt med steg: skjær(l, start, slutt, steg)
funksjon skjær_tall(l: liste_heltall, start: heltall, slutt: heltall, steg: heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la i: heltall = start
    la s: heltall = steg
    hvis (s == 0) { s = 1 }
    mens (i < slutt og i < lengde(l)) {
        legg_til(resultat, l[i])
        i = i + s
    }
    returner resultat
}

funksjon skjær_tekst(l: liste_tekst, start: heltall, slutt: heltall, steg: heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = start
    la s: heltall = steg
    hvis (s == 0) { s = 1 }
    mens (i < slutt og i < lengde(l)) {
        legg_til(resultat, l[i])
        i = i + s
    }
    returner resultat
}

# Del opp i bitar av storleik n (chunk) — returnerer kvar bit som JSON-tekst
funksjon del_opp_tall(l: liste_heltall, n: heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la bit: tekst = "["
        la j: heltall = 0
        mens (j < n og i + j < lengde(l)) {
            hvis (j > 0) { bit = bit + "," }
            bit = bit + tekst_fra_heltall(l[i + j])
            j = j + 1
        }
        bit = bit + "]"
        legg_til(resultat, bit)
        i = i + n
    }
    returner resultat
}

funksjon del_opp_tekst(l: liste_tekst, n: heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la bit: tekst = "["
        la j: heltall = 0
        mens (j < n og i + j < lengde(l)) {
            hvis (j > 0) { bit = bit + "," }
            bit = bit + "\"" + l[i + j] + "\""
            j = j + 1
        }
        bit = bit + "]"
        legg_til(resultat, bit)
        i = i + n
    }
    returner resultat
}

# Zip: sameinar to lister parvis som "a:b"
funksjon zip_tall(a: liste_heltall, b: liste_heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la lim: heltall = lengde(a)
    hvis (lengde(b) < lim) { lim = lengde(b) }
    la i: heltall = 0
    mens (i < lim) {
        legg_til(resultat, tekst_fra_heltall(a[i]) + ":" + tekst_fra_heltall(b[i]))
        i = i + 1
    }
    returner resultat
}

funksjon zip_tekst(a: liste_tekst, b: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la lim: heltall = lengde(a)
    hvis (lengde(b) < lim) { lim = lengde(b) }
    la i: heltall = 0
    mens (i < lim) {
        legg_til(resultat, a[i] + ":" + b[i])
        i = i + 1
    }
    returner resultat
}

# Enumerate: returnerer "indeks:verdi" per element
funksjon enumerer_tall(l: liste_heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(resultat, tekst_fra_heltall(i) + ":" + tekst_fra_heltall(l[i]))
        i = i + 1
    }
    returner resultat
}

funksjon enumerer_tekst(l: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(resultat, tekst_fra_heltall(i) + ":" + l[i])
        i = i + 1
    }
    returner resultat
}

# Kopier ei liste
funksjon kopier_tall(l: liste_heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(resultat, l[i])
        i = i + 1
    }
    returner resultat
}

funksjon kopier_tekst(l: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(resultat, l[i])
        i = i + 1
    }
    returner resultat
}

# Sett saman to lister
funksjon konkatener_tall(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    la resultat = kopier_tall(a)
    la i: heltall = 0
    mens (i < lengde(b)) {
        legg_til(resultat, b[i])
        i = i + 1
    }
    returner resultat
}

funksjon konkatener_tekst(a: liste_tekst, b: liste_tekst) -> liste_tekst {
    la resultat = kopier_tekst(a)
    la i: heltall = 0
    mens (i < lengde(b)) {
        legg_til(resultat, b[i])
        i = i + 1
    }
    returner resultat
}

# Gjenta liste n gonger
funksjon gjenta_tall(l: liste_heltall, n: heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la k: heltall = 0
    mens (k < n) {
        la i: heltall = 0
        mens (i < lengde(l)) {
            legg_til(resultat, l[i])
            i = i + 1
        }
        k = k + 1
    }
    returner resultat
}

# Prikkprodukt (dot product)
funksjon prikkprodukt(a: liste_heltall, b: liste_heltall) -> heltall {
    la sum: heltall = 0
    la lim: heltall = lengde(a)
    hvis (lengde(b) < lim) { lim = lengde(b) }
    la i: heltall = 0
    mens (i < lim) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    returner sum
}

# Lag liste frå område [start, slutt) med steg
funksjon område(start: heltall, slutt: heltall, steg: heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la s: heltall = steg
    hvis (s == 0) { s = 1 }
    la i: heltall = start
    mens (i < slutt) {
        legg_til(resultat, i)
        i = i + s
    }
    returner resultat
}

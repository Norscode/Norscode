# Grunnleggende matematikk

funksjon pluss(a: heltall, b: heltall) -> heltall {
    returner a + b
}

funksjon minus(a: heltall, b: heltall) -> heltall {
    returner a - b
}

funksjon trekk(a: heltall, b: heltall) -> heltall {
    returner minus(a, b)
}

funksjon gange(a: heltall, b: heltall) -> heltall {
    returner a * b
}

funksjon del(a: heltall, b: heltall) -> heltall {
    hvis (b == 0) {
        returner 0
    }
    returner a / b
}

funksjon div(a: heltall, b: heltall) -> heltall {
    returner del(a, b)
}

funksjon maks(a: heltall, b: heltall) -> heltall {
    hvis (a > b) {
        returner a
    }
    returner b
}

funksjon min(a: heltall, b: heltall) -> heltall {
    hvis (a < b) {
        returner a
    }
    returner b
}

funksjon absolutt(x: heltall) -> heltall {
    hvis (x < 0) {
        returner -x
    }
    returner x
}

# Rest etter divisjon (modulo)
funksjon rest(a: heltall, b: heltall) -> heltall {
    hvis (b == 0) {
        returner 0
    }
    returner a % b
}

# Er talet partal?
funksjon er_partall(n: heltall) -> bool {
    returner (n % 2) == 0
}

# Er talet oddetall?
funksjon er_oddetall(n: heltall) -> bool {
    returner (n % 2) != 0
}

# Potens: grunntall^eksponent (heiltalseksponent >= 0)
funksjon potens(grunntall: heltall, eksponent: heltall) -> heltall {
    hvis (eksponent == 0) {
        returner 1
    }
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < eksponent) {
        resultat = resultat * grunntall
        i = i + 1
    }
    returner resultat
}

# Klamp: hald verdi innanfor [nedre, øvre]
funksjon klamp(verdi: heltall, nedre: heltall, øvre: heltall) -> heltall {
    hvis (verdi < nedre) {
        returner nedre
    }
    hvis (verdi > øvre) {
        returner øvre
    }
    returner verdi
}

# Kvadrat
funksjon kvadrat(x: heltall) -> heltall {
    returner x * x
}

# Signum: -1, 0 eller 1
funksjon signum(x: heltall) -> heltall {
    hvis (x < 0) { returner -1 }
    hvis (x > 0) { returner 1 }
    returner 0
}

# Største felles divisor (Euklid)
funksjon gfd(a: heltall, b: heltall) -> heltall {
    la x: heltall = absolutt(a)
    la y: heltall = absolutt(b)
    mens (y != 0) {
        la tmp: heltall = y
        y = x % y
        x = tmp
    }
    returner x
}

# Minste felles multiplum
funksjon mfm(a: heltall, b: heltall) -> heltall {
    hvis (a == 0 eller b == 0) { returner 0 }
    returner absolutt(a * b) / gfd(a, b)
}

# Heiltalskvadratorot (Newton si metode, avrunda nedover)
funksjon kvadratrot(n: heltall) -> heltall {
    hvis (n < 0) { returner -1 }
    hvis (n == 0) { returner 0 }
    la x: heltall = n
    la y: heltall = (x + 1) / 2
    mens (y < x) {
        x = y
        y = (x + n / x) / 2
    }
    returner x
}

# Tak-divisjon (ceiling division)
funksjon tak_div(a: heltall, b: heltall) -> heltall {
    hvis (b == 0) { returner 0 }
    returner (a + b - 1) / b
}

# Fakultet n! (returnerer 0 for n < 0)
funksjon fakultet(n: heltall) -> heltall {
    hvis (n < 0) { returner 0 }
    hvis (n == 0) { returner 1 }
    la resultat: heltall = 1
    la i: heltall = 1
    mens (i <= n) {
        resultat = resultat * i
        i = i + 1
    }
    returner resultat
}

# n-te Fibonacci-tal (iterativt)
funksjon fibonacci(n: heltall) -> heltall {
    hvis (n <= 0) { returner 0 }
    hvis (n == 1) { returner 1 }
    la a: heltall = 0
    la b: heltall = 1
    la i: heltall = 2
    mens (i <= n) {
        la tmp: heltall = a + b
        a = b
        b = tmp
        i = i + 1
    }
    returner b
}

# Er n eit primtal?
funksjon er_primtal(n: heltall) -> bool {
    hvis (n < 2) { returner usann }
    hvis (n == 2) { returner sann }
    hvis (n % 2 == 0) { returner usann }
    la i: heltall = 3
    la grense: heltall = kvadratrot(n)
    mens (i <= grense) {
        hvis (n % i == 0) { returner usann }
        i = i + 2
    }
    returner sann
}

# Primtalsfaktorar (returnerer sortert liste)
funksjon primtalsfaktorar(n: heltall) -> liste_heltall {
    la faktorar: liste_heltall = []
    la rest: heltall = absolutt(n)
    la d: heltall = 2
    mens (d * d <= rest) {
        mens (rest % d == 0) {
            legg_til(faktorar, d)
            rest = rest / d
        }
        d = d + 1
    }
    hvis (rest > 1) { legg_til(faktorar, rest) }
    returner faktorar
}

# Binomalkoeffisient C(n, k)
funksjon binom(n: heltall, k: heltall) -> heltall {
    hvis (k < 0 eller k > n) { returner 0 }
    hvis (k == 0 eller k == n) { returner 1 }
    la kk: heltall = k
    hvis (n - k < kk) { kk = n - k }
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < kk) {
        resultat = resultat * (n - i)
        resultat = resultat / (i + 1)
        i = i + 1
    }
    returner resultat
}

# Logaritme base 2 (heiltal, avrunda nedover)
funksjon log2(n: heltall) -> heltall {
    hvis (n <= 0) { returner -1 }
    la resultat: heltall = 0
    la x: heltall = n
    mens (x > 1) {
        x = x / 2
        resultat = resultat + 1
    }
    returner resultat
}

# Logaritme base 10 (heiltal, avrunda nedover)
funksjon log10(n: heltall) -> heltall {
    hvis (n <= 0) { returner -1 }
    la resultat: heltall = 0
    la x: heltall = n
    mens (x >= 10) {
        x = x / 10
        resultat = resultat + 1
    }
    returner resultat
}

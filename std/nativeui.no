    }

    hvis (navn == "avatar") {
        returner render_avatar_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "badge") {
        returner render_badge_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "alert") {
        returner render_alert_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "empty") {
        returner render_empty_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "loading") {
        returner render_loading_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "form") {
        returner render_form_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "felt") {
        returner render_form_felt_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "label") {
        returner render_label_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "input") {
        returner render_input_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "textarea") {
        returner render_textarea_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "select") {
        returner render_select_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "option") {
        returner render_option_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "actions") {
        returner render_actions_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "checkbox") {
        returner render_checkbox_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "radio") {
        returner render_radio_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "switch") {
        returner render_switch_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "search") {
        returner render_search_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "file") {
        returner render_file_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "hero") {
        returner render_hero_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "footer") {
        returner render_footer_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "tabs") {
        returner render_tabs_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "tab") {
        returner render_tab_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "accordion") {
        returner render_accordion_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "seksjon") {
        returner render_accordion_seksjon_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "panel") {
        returner render_panel_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "grid") {
        returner render_grid_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "kolonne") {
        returner render_grid_kolonne_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "sidefelt") {
        returner render_sidebar_sidefelt_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "hoved") {
        returner render_sidebar_hoved_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "sidebar") {
        returner render_sidebar_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    returner render_generisk_linje(navn, linjer, start_indeks, forventet_innrykk, tittel_override)
}

funksjon render_source(innhold: tekst, tittel_override: tekst) -> tekst {
    la linjer: liste_tekst = split_linjer(innhold)
    la i: heltall = 0
    la body: tekst = ""
    la tittel: tekst = trygg_tekst(tittel_override)

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la innrykk: heltall = tell_innrykk(rå_linje)

            hvis (innrykk != 0) {
                kast ui_feil_indeks("toppnivå må ikke være innrykket", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la resultat: ordbok_tekst = render_blokk(linjer, i, 0, navn, tittel_override)
                hvis (navn == "side") {
                    returner resultat.html
                }
                body = body + resultat.html
                i = resultat_neste(resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tittel" og tittel == "") {
                    tittel = felt.verdi
                }
                body = body + render_felt_linje(felt.navn, felt.verdi)
                i = i + 1
            }
        }
    }

    hvis (tittel == "") {
        tittel = "Norscode UI"
    }

    returner render_document(tittel, body)
}

funksjon render_fil(sti: tekst, tittel_override: tekst) -> tekst {
    returner render_source(fil_les(sti), tittel_override)
}

funksjon start() -> heltall {
    la input_sti: tekst = trygg_tekst(miljo_hent("NORSCODE_UI_INPUT"))
    la output_sti: tekst = trygg_tekst(miljo_hent("NORSCODE_UI_OUTPUT"))
    la tittel: tekst = trygg_tekst(miljo_hent("NORSCODE_UI_TITLE"))

    la html: tekst = render_fil(input_sti, tittel)

    hvis (output_sti != "") {
        fil_skriv(output_sti, html)
    } ellers {
        skriv(html)
    }

    returner 0
}

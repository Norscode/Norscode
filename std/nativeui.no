        attributter,
        summary("", h3("", escape(trygg_tekst(tittel))))
            + div(class_attr("accordion__content"), innhold)
    )
}

## Parsing helpers

funksjon er_blokk_linje(linje: tekst) -> bool {
    returner tekst_slutter_med(linje, ":")
}

funksjon er_kommentar_eller_tom(linje: tekst) -> bool {
    hvis (linje == "") {
        returner sann
    }
    hvis (tekst_starter_med(linje, "#")) {
        returner sann
    }
    returner usann
}

funksjon tell_innrykk(linje: tekst) -> heltall {
    la i: heltall = 0
    la n: heltall = lengde(linje)
    mens (i < n og slice(linje, i, i + 1) == " ") {
        i = i + 1
    }
    returner i
}

funksjon finn_første_mellomrom(tekstverdi: tekst) -> heltall {
    la i: heltall = 0
    la n: heltall = lengde(tekstverdi)
    mens (i < n) {
        hvis (slice(tekstverdi, i, i + 1) == " ") {
            returner i
        }
        i = i + 1
    }
    returner -1
}

funksjon finn_slutt_sitat(tekstverdi: tekst) -> heltall {
    la i: heltall = 1
    la n: heltall = lengde(tekstverdi)

    mens (i < n) {
        hvis (slice(tekstverdi, i, i + 1) == "\"") {
            hvis (slice(tekstverdi, i - 1, i) != "\\") {
                returner i
            }
        }
        i = i + 1
    }

    returner -1
}

funksjon dequote(verdi: tekst) -> tekst {
    hvis (lengde(verdi) < 2) {
        returner verdi
    }

    hvis (slice(verdi, 0, 1) != "\"" eller slice(verdi, lengde(verdi) - 1, lengde(verdi)) != "\"") {
        returner verdi
    }

    la innhold: tekst = slice(verdi, 1, lengde(verdi) - 1)
    la resultat: tekst = ""
    la i: heltall = 0
    la escaping: bool = usann

    mens (i < lengde(innhold)) {
        la tegn: tekst = slice(innhold, i, i + 1)

        hvis (escaping) {
            hvis (tegn == "n") {
                resultat = resultat + "\n"
            } ellers hvis (tegn == "t") {
                resultat = resultat + "\t"
            } ellers hvis (tegn == "\"") {
                resultat = resultat + "\""
            } ellers hvis (tegn == "\\") {
                resultat = resultat + "\\"
            } ellers {
                resultat = resultat + tegn
            }
            escaping = usann
        } ellers hvis (tegn == "\\") {
            escaping = sann
        } ellers {
            resultat = resultat + tegn
        }

        i = i + 1
    }

    hvis (escaping) {
        resultat = resultat + "\\"
    }

    returner resultat
}

funksjon split_linjer(innhold: tekst) -> liste_tekst {
    la linjer: liste_tekst = []
    la aktuell: tekst = ""
    la i: heltall = 0

    mens (i < lengde(innhold)) {
        la tegn: tekst = slice(innhold, i, i + 1)

        hvis (tegn == "\n") {
            legg_til(linjer, aktuell)
            aktuell = ""
        } ellers {
            aktuell = aktuell + tegn
        }

        i = i + 1
    }

    legg_til(linjer, aktuell)
    returner linjer
}

funksjon parse_felt(linje: tekst) -> ordbok_tekst {
    la posisjon: heltall = finn_første_mellomrom(linje)

    hvis (posisjon < 0) {
        la felt: ordbok_tekst = {}
        felt.navn = linje
        felt.verdi = ""
        returner felt
    }

    la navn: tekst = slice(linje, 0, posisjon)
    la verdi: tekst = tekst_trim(slice(linje, posisjon, lengde(linje)))

    hvis (verdi == "") {
        la felt: ordbok_tekst = {}
        felt.navn = navn
        felt.verdi = ""
        returner felt
    }

    la felt: ordbok_tekst = {}
    felt.navn = navn
    felt.verdi = dequote(verdi)
    returner felt
}

## Render helpers

funksjon ny_resultat(html_verdi: tekst, neste_indeks: heltall) -> ordbok_tekst {
    la resultat: ordbok_tekst = {}
    resultat.html = html_verdi
    resultat.neste = tekst_fra_heltall(neste_indeks)
    returner resultat
}

funksjon resultat_html(resultat: ordbok_tekst) -> tekst {
    returner resultat.html
}

funksjon resultat_neste(resultat: ordbok_tekst) -> heltall {
    returner heltall_fra_tekst(resultat.neste)
}

funksjon render_felt_linje(felt_navn: tekst, felt_verdi: tekst) -> tekst {
    hvis (felt_navn == "tittel") {
        returner h1("", escape(felt_verdi))
    }

    hvis (felt_navn == "tekst") {
        returner p("", escape(felt_verdi))
    }

    hvis (felt_navn == "knapp") {
        returner button("", escape(felt_verdi))
    }

    hvis (felt_navn == "submit") {
        returner button(attr("type", "submit"), escape(felt_verdi))
    }

    hvis (felt_navn == "reset") {
        returner button(attr("type", "reset"), escape(felt_verdi))
    }

    returner p("", escape(felt_navn + ": " + felt_verdi))
}

funksjon render_liste_element(felt_verdi: tekst) -> tekst {
    returner li("", escape(felt_verdi))
}

funksjon render_nav_link(tekst_verdi: tekst, href_verdi: tekst) -> tekst {
    la href: tekst = trygg_tekst(href_verdi)
    hvis (href == "") {
        href = "#"
    }
    returner a(attr("href", href), escape(trygg_tekst(tekst_verdi)))
}

funksjon render_breadcrumb_link(tekst_verdi: tekst, href_verdi: tekst) -> tekst {
    returner li(
        class_attr("breadcrumb__item"),
        render_nav_link(tekst_verdi, href_verdi)
    )
}

funksjon render_breadcrumb_current(tekst_verdi: tekst) -> tekst {
    returner li(
        class_attr("breadcrumb__item breadcrumb__item--current"),
        span(attr("aria-current", "page"), escape(trygg_tekst(tekst_verdi)))
    )
}


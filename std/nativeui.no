## Entry points

funksjon render_document(tittel: tekst, innhold: tekst) -> tekst {
    returner dokument_skall(tittel, innhold)
}

funksjon render_kort_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la header: tekst = tekst_trim(linjer[start_indeks])
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la overskrift: tekst = tittel_override
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                returner ny_resultat(kort_skall(overskrift, innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tittel") {
                    overskrift = felt.verdi
                } ellers {
                    innhold = innhold + render_felt_linje(felt.navn, felt.verdi)
                }
                i = i + 1
            }
        }
    }

    returner ny_resultat(kort_skall(overskrift, innhold), i)
}

funksjon render_liste_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                returner ny_resultat(liste_skall(innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "element") {
                    innhold = innhold + render_liste_element(felt.verdi)
                } ellers {
                    innhold = innhold + render_felt_linje(felt.navn, felt.verdi)
                }
                i = i + 1
            }
        }
    }

    returner ny_resultat(liste_skall(innhold), i)
}

funksjon render_nav_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la li_innhold: tekst = ""
    la a_innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                returner ny_resultat(nav_skall(li_innhold, a_innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                li_innhold = li_innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "lenke") {
                    la href: tekst = ""
                    la tekstverdi: tekst = felt.verdi
                    hvis (lengde(felt.verdi) > 0 og slice(felt.verdi, 0, 1) == "\"") {
                        la slutt_sitat: heltall = finn_slutt_sitat(felt.verdi)
                        hvis (slutt_sitat > 0) {
                            tekstverdi = dequote(slice(felt.verdi, 0, slutt_sitat + 1))
                            href = tekst_trim(slice(felt.verdi, slutt_sitat + 1, lengde(felt.verdi)))
                        }
                    } ellers {
                        la mellomrom: heltall = finn_første_mellomrom(felt.verdi)
                        hvis (mellomrom >= 0) {
                            tekstverdi = slice(felt.verdi, 0, mellomrom)
                            href = tekst_trim(slice(felt.verdi, mellomrom, lengde(felt.verdi)))
                        }
                    }
                    href = dequote(href)
                    li_innhold = li_innhold + li("", escape(trygg_tekst(tekstverdi)))
                    a_innhold = a_innhold + render_nav_link(tekstverdi, href)
                } ellers {
                    li_innhold = li_innhold + render_felt_linje(felt.navn, felt.verdi)
                }
                i = i + 1
            }
        }
    }

    returner ny_resultat(nav_skall(li_innhold, a_innhold), i)
}

funksjon render_breadcrumb_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la tittel: tekst = ""
    la tekstverdi: tekst = ""
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                hvis (tittel == "") {
                    tittel = "Breadcrumb"
                }
                returner ny_resultat(render_breadcrumb_innhold(tittel, tekstverdi, innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tittel") {
                    tittel = felt.verdi
                } ellers hvis (felt.navn == "tekst") {
                    tekstverdi = felt.verdi
                } ellers hvis (felt.navn == "lenke") {
                    la href: tekst = ""
                    la tekst_del: tekst = felt.verdi
                    hvis (lengde(felt.verdi) > 0 og slice(felt.verdi, 0, 1) == "\"") {
                        la slutt_sitat: heltall = finn_slutt_sitat(felt.verdi)
                        hvis (slutt_sitat > 0) {
                            tekst_del = dequote(slice(felt.verdi, 0, slutt_sitat + 1))
                            href = tekst_trim(slice(felt.verdi, slutt_sitat + 1, lengde(felt.verdi)))
                        }
                    } ellers {
                        la mellomrom: heltall = finn_første_mellomrom(felt.verdi)
                        hvis (mellomrom >= 0) {
                            tekst_del = slice(felt.verdi, 0, mellomrom)
                            href = tekst_trim(slice(felt.verdi, mellomrom, lengde(felt.verdi)))
                        }
                    }
                    href = dequote(href)
                    innhold = innhold + render_breadcrumb_link(tekst_del, href)
                } ellers hvis (felt.navn == "aktiv") {
                    innhold = innhold + render_breadcrumb_current(felt.verdi)
                } ellers {
                    innhold = innhold + render_felt_linje(felt.navn, felt.verdi)
                }
                i = i + 1
            }
        }
    }

    hvis (tittel == "") {
        tittel = "Breadcrumb"
    }

    returner ny_resultat(render_breadcrumb_innhold(tittel, tekstverdi, innhold), i)
}


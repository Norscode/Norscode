funksjon render_tabs_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la tittel: tekst = ""
    la nav_innhold: tekst = ""
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                hvis (tittel == "") {
                    tittel = "Faner"
                }
                returner ny_resultat(render_tabs_innhold(tittel, nav_innhold, innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                hvis (barn_resultat.tittel != "") {
                    nav_innhold = nav_innhold + span(class_attr("tabs__trigger"), escape(barn_resultat.tittel))
                }
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tittel") {
                    tittel = felt.verdi
                } ellers {
                    innhold = innhold + felt.verdi
                }
                i = i + 1
            }
        }
    }

    hvis (tittel == "") {
        tittel = "Faner"
    }

    returner ny_resultat(render_tabs_innhold(tittel, nav_innhold, innhold), i)
}

funksjon render_tab_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la tittel: tekst = ""
    la tekstverdi: tekst = ""
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                hvis (tittel == "") {
                    tittel = "Fane"
                }
                la resultat_tidlig: ordbok_tekst = ny_resultat(render_tab_innhold(tittel, tekstverdi, innhold), i)
                resultat_tidlig.tittel = tittel
                returner resultat_tidlig
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tittel") {
                    tittel = felt.verdi
                } ellers hvis (felt.navn == "tekst") {
                    tekstverdi = felt.verdi
                } ellers {
                    innhold = innhold + felt.verdi
                }
                i = i + 1
            }
        }
    }

    hvis (tittel == "") {
        tittel = "Fane"
    }

    la resultat: ordbok_tekst = ny_resultat(render_tab_innhold(tittel, tekstverdi, innhold), i)
    resultat.tittel = tittel
    returner resultat
}


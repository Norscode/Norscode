                }
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tekst") {
                    tekstverdi = felt.verdi
                } ellers hvis (felt.navn == "for_id") {
                    for_id = felt.verdi
                } ellers {
                    tekstverdi = tekstverdi + felt.verdi
                }
                i = i + 1
            }

funksjon render_side_linje(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la tittel: tekst = tittel_override
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                hvis (tittel == "") {
                    tittel = "Norscode UI"
                }
                returner ny_resultat(dokument_skall(tittel, innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, navn, tittel_override)
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                hvis (felt.navn == "tittel" og tittel_override == "") {
                    tittel = felt.verdi
                }
                innhold = innhold + render_felt_linje(felt.navn, felt.verdi)
                i = i + 1
            }
        }
    }

    hvis (tittel == "") {
        tittel = "Norscode UI"
    }

    returner ny_resultat(dokument_skall(tittel, innhold), i)
}

funksjon render_generisk_linje(
    navn: tekst,
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    tittel_override: tekst
) -> ordbok_tekst {
    la i: heltall = start_indeks + 1
    la barn_innrykk: heltall = forventet_innrykk + 4
    la innhold: tekst = ""

    mens (i < lengde(linjer)) {
        la rå_linje: tekst = linjer[i]
        la linje: tekst = tekst_trim(rå_linje)

        hvis (er_kommentar_eller_tom(linje)) {
            i = i + 1
        } ellers {
            la faktisk_innrykk: heltall = tell_innrykk(rå_linje)

            hvis (faktisk_innrykk < barn_innrykk) {
                returner ny_resultat(node_skall(navn, innhold), i)
            }

            hvis (faktisk_innrykk > barn_innrykk) {
                kast ui_feil_indeks("uventet innrykk", i)
            }

            hvis (er_blokk_linje(linje)) {
                la barn_navn: tekst = tekst_trim(slice(linje, 0, lengde(linje) - 1))
                la barn_resultat: ordbok_tekst = render_blokk(linjer, i, barn_innrykk, barn_navn, tittel_override)
                innhold = innhold + resultat_html(barn_resultat)
                i = resultat_neste(barn_resultat)
            } ellers {
                la felt: ordbok_tekst = parse_felt(linje)
                innhold = innhold + render_felt_linje(felt.navn, felt.verdi)
                i = i + 1
            }
        }
    }

    returner ny_resultat(node_skall(navn, innhold), i)
}

funksjon render_blokk(
    linjer: liste_tekst,
    start_indeks: heltall,
    forventet_innrykk: heltall,
    navn: tekst,
    tittel_override: tekst
) -> ordbok_tekst {
    hvis (navn == "side") {
        returner render_side_linje(linjer, start_indeks, forventet_innrykk, tittel_override)
    }

    hvis (navn == "kort") {
        returner render_kort_linje(linjer, start_indeks, forventet_innrykk, tittel_override)

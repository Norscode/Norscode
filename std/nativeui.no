bruk std.web som web

funksjon trygg_tekst(verdi: tekst) -> tekst {
    hvis (verdi == null) {
        returner ""
    }
    returner verdi
}

funksjon escape(verdi: tekst) -> tekst {
    returner web.escape_html(trygg_tekst(verdi))
}

funksjon attr(nøkkel: tekst, verdi: tekst) -> tekst {
    returner " " + trygg_tekst(nøkkel) + "=\"" + escape(verdi) + "\""
}

funksjon class_attr(klasse: tekst) -> tekst {
    hvis (trygg_tekst(klasse) == "") {
        returner ""
    }
    returner attr("class", klasse)
}

funksjon ui_feil(melding: tekst) -> tekst {
    returner "UIFeil: " + trygg_tekst(melding)
}

funksjon ui_feil_indeks(melding: tekst, indeks: heltall) -> tekst {
    returner ui_feil(melding + " ved indeks " + tekst_fra_heltall(indeks))
}

funksjon tag(navn: tekst, attributter: tekst, innhold: tekst) -> tekst {
    returner "<" + trygg_tekst(navn) + trygg_tekst(attributter) + ">" + trygg_tekst(innhold) + "</" + trygg_tekst(navn) + ">"
}

funksjon void_tag(navn: tekst, attributter: tekst) -> tekst {
    returner "<" + trygg_tekst(navn) + trygg_tekst(attributter) + ">"
}

funksjon h1(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("h1", attributter, innhold)
}

funksjon h2(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("h2", attributter, innhold)
}

funksjon h3(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("h3", attributter, innhold)
}

funksjon p(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("p", attributter, innhold)
}

funksjon button(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("button", attributter, innhold)
}

funksjon ul(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("ul", attributter, innhold)
}

funksjon li(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("li", attributter, innhold)
}

funksjon a(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("a", attributter, innhold)
}

funksjon span(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("span", attributter, innhold)
}

funksjon section(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("section", attributter, innhold)
}

funksjon article(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("article", attributter, innhold)
}

funksjon aside(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("aside", attributter, innhold)
}

funksjon details(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("details", attributter, innhold)
}

funksjon summary(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("summary", attributter, innhold)
}

funksjon div(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("div", attributter, innhold)
}

funksjon main(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("main", attributter, innhold)
}

funksjon head(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("head", attributter, innhold)
}

funksjon body(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("body", attributter, innhold)
}

funksjon title(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("title", attributter, innhold)
}

funksjon dialog(attributter: tekst, innhold: tekst) -> tekst {
    returner tag("dialog", attributter, innhold)
}

funksjon img(attributter: tekst) -> tekst {
    returner void_tag("img", attributter)
}

## HTML shell helpers

funksjon dokument_skall(tittel: tekst, innhold: tekst) -> tekst {
    la head_innhold: tekst = void_tag("meta", attr("charset", "utf-8"))
        + title("", escape(trygg_tekst(tittel)))
        + void_tag("link", attr("rel", "stylesheet") + attr("href", "/assets/css/app.css"))

    returner "<!doctype html>"
        + tag(
            "html",
            "",
            head("", head_innhold)
            + body("", main(class_attr("shell"), trygg_tekst(innhold)))
        )
}

funksjon kort_skall(overskrift: tekst, innhold: tekst) -> tekst {
    returner section(
        class_attr("card panel"),
        h2("", escape(overskrift))
            + div(class_attr("card-body"), innhold)
    )
}

funksjon node_skall(navn: tekst, innhold: tekst) -> tekst {
    returner section(class_attr("node " + navn), innhold)
}

funksjon liste_skall(innhold: tekst) -> tekst {
    returner ul(class_attr("list"), innhold)
}

funksjon nav_skall(li_innhold: tekst, a_innhold: tekst) -> tekst {
    returner tag(
        "nav",
        class_attr("nav"),
        ul(class_attr("list"), li_innhold) + a_innhold
    )
}

funksjon breadcrumb_skall(tittel: tekst, tekstverdi: tekst, innhold: tekst) -> tekst {
    la header: tekst = ""
    hvis (trygg_tekst(tittel) != "") {
        header = header + h2("", escape(trygg_tekst(tittel)))
    }
    hvis (trygg_tekst(tekstverdi) != "") {
        header = header + p("", escape(trygg_tekst(tekstverdi)))
    }
    returner section(
        class_attr("breadcrumb"),
        header + ul(class_attr("breadcrumb__list"), innhold)
    )
}

funksjon toolbar_skall(tittel: tekst, tekstverdi: tekst, innhold: tekst) -> tekst {
    la header: tekst = ""
    hvis (trygg_tekst(tittel) != "") {
        header = header + h2("", escape(trygg_tekst(tittel)))
    }
    hvis (trygg_tekst(tekstverdi) != "") {
        header = header + p("", escape(trygg_tekst(tekstverdi)))
    }
    returner section(
        class_attr("toolbar"),
        header + div(class_attr("toolbar__actions"), innhold)
    )
}

funksjon dialog_skall(tittel: tekst, tekstverdi: tekst, innhold: tekst) -> tekst {
    la header: tekst = ""
    hvis (trygg_tekst(tittel) != "") {
        header = header + h2("", escape(trygg_tekst(tittel)))
    }
    hvis (trygg_tekst(tekstverdi) != "") {
        header = header + p("", escape(trygg_tekst(tekstverdi)))
    }
    returner dialog(
        class_attr("dialog"),
        div(class_attr("dialog__surface"),
            header + div(class_attr("dialog__body"), innhold)
        )
    )
}

funksjon toast_skall(tittel: tekst, tekstverdi: tekst, innhold: tekst) -> tekst {
    la header: tekst = ""
    hvis (trygg_tekst(tittel) != "") {
        header = header + h2("", escape(trygg_tekst(tittel)))
    }
    hvis (trygg_tekst(tekstverdi) != "") {
        header = header + p("", escape(trygg_tekst(tekstverdi)))
    }
    returner section(
        class_attr("toast"),
        header + div(class_attr("toast__actions"), innhold)
    )
}

funksjon avatar_skall(navn: tekst, tekstverdi: tekst, src: tekst) -> tekst {
    la innhold: tekst = ""
    la trygg_src: tekst = trygg_tekst(src)
    la trygg_navn: tekst = trygg_tekst(navn)
    la trygg_tekstverdi: tekst = trygg_tekst(tekstverdi)

    hvis (trygg_src != "") {
        innhold = innhold + img(class_attr("avatar__image") + attr("src", trygg_src) + attr("alt", trygg_navn))
    }

    hvis (trygg_tekstverdi != "") {
        innhold = innhold + span(class_attr("avatar__text"), escape(trygg_tekstverdi))
    } ellers hvis (trygg_navn != "") {
        innhold = innhold + span(class_attr("avatar__text"), escape(trygg_navn))
    }

    hvis (innhold == "") {
        innhold = span(class_attr("avatar__text"), "A")
    }

    returner div(class_attr("avatar"), innhold)
}

funksjon chip_skall(innhold: tekst) -> tekst {
    returner span(class_attr("chip"), span(class_attr("chip__text"), innhold))
}

funksjon chip_lenke_skall(innhold: tekst, href: tekst) -> tekst {
    la trygg_href: tekst = trygg_tekst(href)
    hvis (trygg_href == "") {
        returner chip_skall(innhold)
    }
    returner a(class_attr("chip") + attr("href", trygg_href), span(class_attr("chip__text"), innhold))
}

funksjon badge_skall(innhold: tekst) -> tekst {
    returner span(class_attr("badge"), innhold)
}

funksjon alert_skall(tittel: tekst, innhold: tekst) -> tekst {
    returner section(
        class_attr("alert"),
        h2(class_attr("alert-title"), escape(trygg_tekst(tittel)))
            + p(class_attr("alert-body"), escape(trygg_tekst(innhold)))
    )
}

funksjon empty_skall(tittel: tekst, innhold: tekst) -> tekst {
    returner section(
        class_attr("empty-state"),
        h2("", escape(trygg_tekst(tittel)))
            + p("", escape(trygg_tekst(innhold)))
    )
}

funksjon loading_skall(innhold: tekst) -> tekst {
    returner section(
        class_attr("loading-state"),
        span(class_attr("loading-state__spinner"), "⏳")
            + p("", escape(trygg_tekst(innhold)))
    )
}

funksjon form_skall(innhold: tekst) -> tekst {
    returner tag("form", class_attr("form"), innhold)
}

funksjon felt_skall(innhold: tekst) -> tekst {
    returner div(class_attr("form-field"), innhold)
}

funksjon label_skall(tekstverdi: tekst, for_id: tekst) -> tekst {
    la attributter: tekst = class_attr("form-label")
    hvis (trygg_tekst(for_id) != "") {
        attributter = attributter + attr("for", for_id)
    }
    returner tag("label", attributter, escape(trygg_tekst(tekstverdi)))
}

funksjon input_skall(
    typeverdi: tekst,
    navn: tekst,
    verdi: tekst,
    placeholder: tekst
) -> tekst {
    la attributter: tekst = class_attr("form-input")

    hvis (trygg_tekst(typeverdi) != "") {
        attributter = attributter + attr("type", typeverdi)
    }
    hvis (trygg_tekst(navn) != "") {
        attributter = attributter + attr("name", navn)
    }
    hvis (trygg_tekst(verdi) != "") {
        attributter = attributter + attr("value", verdi)
    }
    hvis (trygg_tekst(placeholder) != "") {
        attributter = attributter + attr("placeholder", placeholder)
    }

    returner void_tag("input", attributter)
}

funksjon file_input_skall(
    navn: tekst,
    accept: tekst,
    multiple: tekst,
    placeholder: tekst
) -> tekst {
    la attributter: tekst = class_attr("form-input")
    attributter = attributter + attr("type", "file")

    hvis (trygg_tekst(navn) != "") {
        attributter = attributter + attr("name", navn)
    }
    hvis (trygg_tekst(accept) != "") {
        attributter = attributter + attr("accept", accept)
    }
    hvis (trygg_tekst(multiple) != "") {
        attributter = attributter + attr("multiple", "multiple")
    }
    hvis (trygg_tekst(placeholder) != "") {
        attributter = attributter + attr("placeholder", placeholder)
    }

    returner void_tag("input", attributter)
}

funksjon search_input_skall(
    navn: tekst,
    verdi: tekst,
    placeholder: tekst
) -> tekst {
    returner input_skall("search", navn, verdi, placeholder)
}

funksjon textarea_skall(
    navn: tekst,
    verdi: tekst,
    placeholder: tekst,
    rader: tekst
) -> tekst {
    la attributter: tekst = class_attr("form-textarea")

    hvis (trygg_tekst(navn) != "") {
        attributter = attributter + attr("name", navn)
    }
    hvis (trygg_tekst(placeholder) != "") {
        attributter = attributter + attr("placeholder", placeholder)
    }
    hvis (trygg_tekst(rader) != "") {
        attributter = attributter + attr("rows", rader)
    }

    returner tag("textarea", attributter, escape(trygg_tekst(verdi)))
}

funksjon option_skall(tekstverdi: tekst, verdi: tekst) -> tekst {
    la attributter: tekst = ""
    hvis (trygg_tekst(verdi) != "") {
        attributter = attr("value", verdi)
    }
    returner tag("option", attributter, escape(trygg_tekst(tekstverdi)))
}

funksjon select_skall(navn: tekst, innhold: tekst) -> tekst {
    la attributter: tekst = class_attr("form-select")

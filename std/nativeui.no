}

funksjon choice_skall(
    typeverdi: tekst,
    navn: tekst,
    verdi: tekst,
    tekstverdi: tekst,
    checked: tekst
) -> tekst {
    la input_attributter: tekst = class_attr("form-choice__input")

    hvis (trygg_tekst(typeverdi) != "") {
        input_attributter = input_attributter + attr("type", typeverdi)
    }
    hvis (trygg_tekst(navn) != "") {
        input_attributter = input_attributter + attr("name", navn)
    }
    hvis (trygg_tekst(verdi) != "") {
        input_attributter = input_attributter + attr("value", verdi)
    }
    hvis (trygg_tekst(checked) != "") {
        input_attributter = input_attributter + attr("checked", "checked")
    }

    returner tag(
        "label",
        class_attr("form-choice"),
        void_tag("input", input_attributter)
            + span(class_attr("form-choice__text"), escape(trygg_tekst(tekstverdi)))
    )
}

funksjon switch_skall(navn: tekst, verdi: tekst, tekstverdi: tekst, checked: tekst) -> tekst {
    la input_attributter: tekst = class_attr("form-switch__input")
    input_attributter = input_attributter + attr("type", "checkbox")
    input_attributter = input_attributter + attr("role", "switch")

    hvis (trygg_tekst(navn) != "") {
        input_attributter = input_attributter + attr("name", navn)
    }
    hvis (trygg_tekst(verdi) != "") {
        input_attributter = input_attributter + attr("value", verdi)
    }
    hvis (trygg_tekst(checked) != "") {
        input_attributter = input_attributter + attr("checked", "checked")
    }

    returner tag(
        "label",
        class_attr("form-switch"),
        void_tag("input", input_attributter)
            + span(class_attr("form-switch__text"), escape(trygg_tekst(tekstverdi)))
    )
}


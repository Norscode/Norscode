# trad.no - ASCII alias for thread helpers on paths that struggle with non-ASCII module names.

funksjon ny_manager() -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["_neste_id"] = "0"
    m["_aktive"] = "0"
    m["_mutex_eigar"] = ""
    m["_delt"] = "{}"
    m["_barrierer"] = "{}"
    m["_hendingar"] = "{}"
    returner m
}

funksjon status_oversikt(manager: ordbok_tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    r["gyldig"] = "sann"
    r["aktive"] = "0"
    r["klar"] = "0"
    r["kjorar"] = "0"
    r["blokkert"] = "0"
    r["ferdig"] = "0"
    r["feil"] = "0"
    hvis manager == null {
        r["gyldig"] = "usann"
    } ellers hvis har_nokkel(manager, "_aktive") {
        r["aktive"] = manager["_aktive"]
    }
    returner r
}

# media_local.no — lokal, avhengigheitsfri mediegenerator i rein Norscode
#
# Dette er ein deterministisk fallback og testmotor, ikkje ein nevralt trenet
# modell. Han produserer ekte PPM-bilde, WAV-lyd/musikk og Y4M-video.

bruk std.fil som fil
bruk std.media_job som media_job

funksjon _hash(prompt: tekst) -> heiltall {
    la h: heiltall = 17
    la i: heiltall = 0
    mens i < lengde(prompt) {
        h = (h * 31 + builtin.char_code(prompt[i])) % 65521
        i = i + 1
    }
    returner h
}

funksjon _ascii(ut: liste_heltall, verdi: tekst) {
    la i: heiltall = 0
    mens i < lengde(verdi) {
        legg_til(ut, builtin.char_code(verdi[i]))
        i = i + 1
    }
}

funksjon _u16le(ut: liste_heltall, verdi: heiltall) {
    legg_til(ut, verdi % 256)
    legg_til(ut, (verdi / 256) % 256)
}

funksjon _u32le(ut: liste_heltall, verdi: heiltall) {
    legg_til(ut, verdi % 256)
    legg_til(ut, (verdi / 256) % 256)
    legg_til(ut, (verdi / 65536) % 256)
    legg_til(ut, (verdi / 16777216) % 256)
}

funksjon _skriv_resultat(sti: tekst, data: liste_heltall,
                         mime: tekst) -> ordbok_tekst {
    la skrive = fil.skriv_bytes(sti, data)
    hvis skrive != lengde(data) {
        returner {"ok": "usann", "feil": "filskriving_feila", "sti": "", "mime": mime, "bytes": "0"}
    }
    returner {"ok": "sann", "feil": "", "sti": sti, "mime": mime, "bytes": tekst_fra_heltall(skrive)}
}

funksjon bilde(prompt: tekst, sti: tekst, bredde: heiltall,
               hoyde: heiltall) -> ordbok_tekst {
    hvis bredde <= 0 eller hoyde <= 0 eller bredde > 2048 eller hoyde > 2048 {
        returner {"ok": "usann", "feil": "ugyldig_storleik", "sti": "", "mime": "image/x-portable-pixmap", "bytes": "0"}
    }
    la data: liste_heltall = []
    _ascii(data, "P6\n" + tekst_fra_heltall(bredde) + " " + tekst_fra_heltall(hoyde) + "\n255\n")
    la seed = _hash(prompt)
    la y: heiltall = 0
    mens y < hoyde {
        la x: heiltall = 0
        mens x < bredde {
            legg_til(data, (x * 255 / bredde + seed) % 256)
            legg_til(data, (y * 255 / hoyde + seed / 3) % 256)
            legg_til(data, ((x + y) * 127 / (bredde + hoyde) + seed / 7) % 256)
            x = x + 1
        }
        y = y + 1
    }
    returner _skriv_resultat(sti, data, "image/x-portable-pixmap")
}

funksjon bilde_med_palette(prompt: tekst, sti: tekst, bredde: heiltall,
                           hoyde: heiltall, rod: heiltall,
                           gron: heiltall, bla: heiltall) -> ordbok_tekst {
    hvis bredde <= 0 eller hoyde <= 0 eller bredde > 2048 eller hoyde > 2048 {
        returner {"ok": "usann", "feil": "ugyldig_storleik", "sti": "", "mime": "image/x-portable-pixmap", "bytes": "0"}
    }
    la data: liste_heltall = []
    _ascii(data, "P6\n" + tekst_fra_heltall(bredde) + " " + tekst_fra_heltall(hoyde) + "\n255\n")
    la seed = _hash(prompt)
    la y: heiltall = 0
    mens y < hoyde {
        la x: heiltall = 0
        mens x < bredde {
            legg_til(data, (rod + x * 127 / bredde + seed / 11) % 256)
            legg_til(data, (gron + y * 127 / hoyde + seed / 17) % 256)
            legg_til(data, (bla + (x + y) * 127 / (bredde + hoyde) + seed / 23) % 256)
            x = x + 1
        }
        y = y + 1
    }
    returner _skriv_resultat(sti, data, "image/x-portable-pixmap")
}

funksjon _wav(prompt: tekst, sti: tekst, varighet_ms: heiltall,
              frekvens: heiltall, musikkmodus: boolsk) -> ordbok_tekst {
    hvis varighet_ms <= 0 eller varighet_ms > 600000 eller frekvens <= 0 {
        returner {"ok": "usann", "feil": "ugyldige_lydinnstillingar", "sti": "", "mime": "audio/wav", "bytes": "0"}
    }
    la rate: heiltall = 8000
    la antal = rate * varighet_ms / 1000
    la data: liste_heltall = []
    _ascii(data, "RIFF")
    _u32le(data, 36 + antal)
    _ascii(data, "WAVEfmt ")
    _u32le(data, 16)
    _u16le(data, 1)
    _u16le(data, 1)
    _u32le(data, rate)
    _u32le(data, rate)
    _u16le(data, 1)
    _u16le(data, 8)
    _ascii(data, "data")
    _u32le(data, antal)

    la seed = _hash(prompt)
    la i: heiltall = 0
    mens i < antal {
        la aktiv_frekvens = frekvens
        hvis musikkmodus {
            la note_indeks = (i / (rate / 4) + seed) % 4
            hvis note_indeks == 1 {
                aktiv_frekvens = frekvens * 5 / 4
            } ellers hvis note_indeks == 2 {
                aktiv_frekvens = frekvens * 3 / 2
            } ellers hvis note_indeks == 3 {
                aktiv_frekvens = frekvens * 2
            }
        }
        la periode = rate / aktiv_frekvens
        hvis periode < 2 { periode = 2 }
        hvis i % periode < periode / 2 {
            legg_til(data, 196)
        } ellers {
            legg_til(data, 60)
        }
        i = i + 1
    }
    returner _skriv_resultat(sti, data, "audio/wav")
}

funksjon lyd(prompt: tekst, sti: tekst, varighet_ms: heiltall,
            frekvens: heiltall) -> ordbok_tekst {
    returner _wav(prompt, sti, varighet_ms, frekvens, usann)
}

funksjon musikk(prompt: tekst, sti: tekst, varighet_ms: heiltall,
               grunnfrekvens: heiltall) -> ordbok_tekst {
    returner _wav(prompt, sti, varighet_ms, grunnfrekvens, sann)
}

funksjon video(prompt: tekst, sti: tekst, bredde: heiltall,
               hoyde: heiltall, fps: heiltall,
               antal_bilder: heiltall) -> ordbok_tekst {
    hvis bredde <= 0 eller hoyde <= 0 eller bredde % 2 != 0 eller hoyde % 2 != 0 eller fps <= 0 eller antal_bilder <= 0 eller antal_bilder > fps * 60 {
        returner {"ok": "usann", "feil": "ugyldige_videoinnstillingar", "sti": "", "mime": "video/x-yuv4mpeg2", "bytes": "0"}
    }
    la data: liste_heltall = []
    _ascii(data, "YUV4MPEG2 W" + tekst_fra_heltall(bredde) + " H" + tekst_fra_heltall(hoyde) + " F" + tekst_fra_heltall(fps) + ":1 Ip A1:1 C420jpeg\n")
    la seed = _hash(prompt)
    la frame: heiltall = 0
    mens frame < antal_bilder {
        _ascii(data, "FRAME\n")
        la y: heiltall = 0
        mens y < hoyde {
            la x: heiltall = 0
            mens x < bredde {
                legg_til(data, (x * 180 / bredde + y * 50 / hoyde + frame * 12 + seed) % 220 + 16)
                x = x + 1
            }
            y = y + 1
        }
        la chroma = bredde * hoyde / 4
        la c: heiltall = 0
        mens c < chroma {
            legg_til(data, (96 + frame * 3 + seed) % 224 + 16)
            c = c + 1
        }
        c = 0
        mens c < chroma {
            legg_til(data, (144 + frame * 5 + seed / 2) % 224 + 16)
            c = c + 1
        }
        frame = frame + 1
    }
    returner _skriv_resultat(sti, data, "video/x-yuv4mpeg2")
}

funksjon fullfor_jobb(jobb: ordbok_tekst, resultat: ordbok_tekst,
                      no_ms: heiltall) -> boolsk {
    hvis resultat["ok"] != "sann" {
        media_job.marker_feil(jobb, resultat["feil"], no_ms)
        returner usann
    }
    hvis jobb["status"] == "ventar" { media_job.start(jobb, no_ms) }
    returner media_job.fullfor(jobb, resultat["sti"], resultat["mime"], no_ms)
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "motor": "norscode-procedural-v1", "dekning": "ekte PPM-bilde, PCM-WAV lyd og musikk, YUV4MPEG2-video; inga ekstern prosess eller nettverk", "nevralt_modell": "usann"}
}

pakke std.compiler

bruk std.runtime

konstant REG_RAX = 0
konstant REG_RBX = 1
konstant REG_RCX = 2
konstant REG_RDX = 3
konstant REG_RSI = 4
konstant REG_RDI = 5
konstant REG_R8 = 6
konstant REG_R9 = 7

struktur RuntimeRegister {
    register_id: heiltall
    occupied: bool
    spill_slot: heiltall
    flags: heiltall
}

struktur RuntimeRegisterAllocator {
    objekt: RuntimeObject
    registre: RuntimeArray
    free_list: RuntimeArray
    spill_stack: RuntimeArray
    allocation_flags: heiltall
}

funksjon ny_register(
    register_id: heiltall
) -> RuntimeRegister {
    returner RuntimeRegister {
        register_id: register_id,
        occupied: usann,
        spill_slot: -1,
        flags: 0
    }
}

funksjon ny_register_allocator(
    allocator: Allocator
) -> RuntimeRegisterAllocator {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        256
    )

    la registre = ny_array(
        allocator,
        8,
        16
    )

    la free_list = ny_array(
        allocator,
        8,
        8
    )

    la spill_stack = ny_array(
        allocator,
        16,
        8
    )

    skrivlinje("[regalloc] opprettet register allocator")

    returner RuntimeRegisterAllocator {
        objekt: objekt,
        registre: registre,
        free_list: free_list,
        spill_stack: spill_stack,
        allocation_flags: 0
    }
}

funksjon alloker_register(
    allocator: Allocator,
    regalloc: RuntimeRegisterAllocator,
    register_id: heiltall
) -> RuntimeRegister {
    skriv("[regalloc] alloker register: ")
    skrivlinje(register_id)

    regalloc.registre = append_placeholder(
        allocator,
        regalloc.registre
    )

    la reg = ny_register(register_id)

    reg.occupied = sann

    returner reg
}

funksjon frigjør_register(
    allocator: Allocator,
    regalloc: RuntimeRegisterAllocator,
    reg: RuntimeRegister
) {
    skriv("[regalloc] frigjør register: ")
    skrivlinje(reg.register_id)

    reg.occupied = usann

    regalloc.free_list = append_placeholder(
        allocator,
        regalloc.free_list
    )
}

funksjon spill_register(
    allocator: Allocator,
    regalloc: RuntimeRegisterAllocator,
    reg: RuntimeRegister
) {
    skriv("[regalloc] spill register: ")
    skrivlinje(reg.register_id)

    reg.spill_slot = (
        regalloc.spill_stack.lengde + 1
    )

    regalloc.spill_stack = append_placeholder(
        allocator,
        regalloc.spill_stack
    )
}

funksjon allocate_instruction_register(
    allocator: Allocator,
    regalloc: RuntimeRegisterAllocator,
    instruksjon: RuntimeInstruction
) -> RuntimeRegister {
    skriv("[regalloc] allocate for opcode: ")
    skrivlinje(instruksjon.opcode)

    returner alloker_register(
        allocator,
        regalloc,
        REG_RAX
    )
}

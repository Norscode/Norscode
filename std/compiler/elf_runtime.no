pakke std.compiler

bruk std.runtime

konstant ELF_MAGIC_0 = 0x7f
konstant ELF_MAGIC_1 = 0x45
konstant ELF_MAGIC_2 = 0x4c
konstant ELF_MAGIC_3 = 0x46

konstant ELF_CLASS_64 = 2
konstant ELF_MACHINE_X86_64 = 62
konstant ELF_EXECUTABLE = 2

struktur RuntimeELFHeader {
    entrypoint: heiltall
    program_header_offset: heiltall
    section_header_offset: heiltall
    machine: heiltall
    elf_type: heiltall
}

struktur RuntimeELFImage {
    objekt: RuntimeObject
    header: RuntimeELFHeader
    machinecode: RuntimeMachineCodeBuffer
    executable_bytes: RuntimeArray
    relocations: RuntimeArray
}

funksjon ny_elf_header(
    entrypoint: heiltall
) -> RuntimeELFHeader {
    returner RuntimeELFHeader {
        entrypoint: entrypoint,
        program_header_offset: 64,
        section_header_offset: 0,
        machine: ELF_MACHINE_X86_64,
        elf_type: ELF_EXECUTABLE
    }
}

funksjon ny_elf_image(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer
) -> RuntimeELFImage {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        512
    )

    la executable = ny_array(
        allocator,
        4096,
        1
    )

    la header = ny_elf_header(0x401000)

    skrivlinje("[elf] opprettet ELF image")

    returner RuntimeELFImage {
        objekt: objekt,
        header: header,
        machinecode: buffer,
        executable_bytes: executable,
        relocations: buffer.relocations
    }
}

funksjon skriv_elf_header(
    allocator: Allocator,
    image: RuntimeELFImage
) {
    skrivlinje("[elf] skriv ELF header")

    append_placeholder(
        allocator,
        image.executable_bytes
    )

    skriv("[elf] entrypoint: ")
    skrivlinje(image.header.entrypoint)
}

funksjon skriv_program_header(
    allocator: Allocator,
    image: RuntimeELFImage
) {
    skrivlinje("[elf] skriv program header")

    append_placeholder(
        allocator,
        image.executable_bytes
    )
}

funksjon patch_entrypoint(
    image: RuntimeELFImage,
    entrypoint: heiltall
) {
    image.header.entrypoint = entrypoint

    skriv("[elf] patch entrypoint: ")
    skrivlinje(entrypoint)
}

funksjon patch_relocations(
    image: RuntimeELFImage
) {
    skriv("[elf] patch relocations: ")
    skrivlinje(image.relocations.lengde)
}

funksjon serialiser_machinecode(
    allocator: Allocator,
    image: RuntimeELFImage
) {
    skriv("[elf] serialiser machinecode bytes: ")
    skrivlinje(image.machinecode.bytes.lengde)

    image.executable_bytes = append_placeholder(
        allocator,
        image.executable_bytes
    )
}

funksjon serialiser_elf(
    allocator: Allocator,
    image: RuntimeELFImage
) {
    skrivlinje("[elf] serialiser ELF image")

    skriv_elf_header(
        allocator,
        image
    )

    skriv_program_header(
        allocator,
        image
    )

    serialiser_machinecode(
        allocator,
        image
    )

    patch_relocations(image)
}

pakke std.compiler

bruk std.runtime

konstant RELOC_JUMP = 1
konstant RELOC_CALL = 2

struktur RuntimeRelocation {
    reloc_type: heiltall
    offset: heiltall
    target: heiltall
}

struktur RuntimeMachineCodeBuffer {
    objekt: RuntimeObject
    bytes: RuntimeArray
    relocations: RuntimeArray
    labels: RuntimeMap
    current_offset: heiltall
}

funksjon ny_relocation(
    reloc_type: heiltall,
    offset: heiltall,
    target: heiltall
) -> RuntimeRelocation {
    returner RuntimeRelocation {
        reloc_type: reloc_type,
        offset: offset,
        target: target
    }
}

funksjon ny_machinecode_buffer(
    allocator: Allocator
) -> RuntimeMachineCodeBuffer {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        512
    )

    la bytes = ny_array(
        allocator,
        256,
        1
    )

    la relocations = ny_array(
        allocator,
        64,
        16
    )

    la labels = ny_map(
        allocator
    )

    skrivlinje("[backend] opprettet x86 machinecode buffer")

    returner RuntimeMachineCodeBuffer {
        objekt: objekt,
        bytes: bytes,
        relocations: relocations,
        labels: labels,
        current_offset: 0
    }
}

funksjon emit_byte(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    verdi: heiltall
) {
    buffer.bytes = append_placeholder(
        allocator,
        buffer.bytes
    )

    buffer.current_offset = (
        buffer.current_offset + 1
    )

    skriv("[backend] emit byte: ")
    skrivlinje(verdi)
}

funksjon emit_u32(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    verdi: heiltall
) {
    emit_byte(allocator, buffer, verdi og 0xff)
    emit_byte(allocator, buffer, (verdi >> 8) og 0xff)
    emit_byte(allocator, buffer, (verdi >> 16) og 0xff)
    emit_byte(allocator, buffer, (verdi >> 24) og 0xff)
}

funksjon emit_u64(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    verdi: heiltall
) {
    emit_u32(allocator, buffer, verdi og 0xffffffff)
    emit_u32(allocator, buffer, verdi >> 32)
}

funksjon emit_mov(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    register_id: heiltall,
    verdi: heiltall
) {
    emit_byte(allocator, buffer, 0x48)
    emit_byte(allocator, buffer, 0xc7)
    emit_byte(allocator, buffer, 0xc0 eller register_id)
    emit_u32(allocator, buffer, verdi)

    skriv("[backend] emit mov register: ")
    skrivlinje(register_id)
}

funksjon emit_return(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer
) {
    emit_byte(allocator, buffer, 0xc3)

    skrivlinje("[backend] emit return")
}

funksjon emit_jump(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    target: heiltall
) {
    emit_byte(allocator, buffer, 0xe9)

    la offset = buffer.current_offset

    emit_u32(allocator, buffer, 0)

    buffer.relocations = append_placeholder(
        allocator,
        buffer.relocations
    )

    skriv("[backend] emit jump reloc: ")
    skrivlinje(target)
}

funksjon emit_call(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    target: heiltall
) {
    emit_byte(allocator, buffer, 0xe8)

    la offset = buffer.current_offset

    emit_u32(allocator, buffer, 0)

    buffer.relocations = append_placeholder(
        allocator,
        buffer.relocations
    )

    skriv("[backend] emit call reloc: ")
    skrivlinje(target)
}

funksjon emit_label(
    buffer: RuntimeMachineCodeBuffer,
    label_hash: heiltall
) {
    map_put(
        buffer.labels,
        label_hash,
        label_hash,
        buffer.current_offset
    )

    skriv("[backend] emit label offset: ")
    skrivlinje(buffer.current_offset)
}

funksjon emit_instruction_runtime(
    allocator: Allocator,
    buffer: RuntimeMachineCodeBuffer,
    instruksjon: RuntimeInstruction,
    reg: RuntimeRegister
) {
    skriv("[backend] lower opcode: ")
    skrivlinje(instruksjon.opcode)

    hvis instruksjon.opcode == OP_MOV {
        emit_mov(
            allocator,
            buffer,
            reg.register_id,
            instruksjon.operand_a
        )
    }

    hvis instruksjon.opcode == OP_CALL {
        emit_call(
            allocator,
            buffer,
            instruksjon.operand_a
        )
    }

    hvis instruksjon.opcode == OP_JUMP {
        emit_jump(
            allocator,
            buffer,
            instruksjon.operand_a
        )
    }

    hvis instruksjon.opcode == OP_RETURN {
        emit_return(
            allocator,
            buffer
        )
    }
}

pakke std.compiler

bruk std.runtime

konstant DIAGNOSTIC_INFO = 1
konstant DIAGNOSTIC_WARNING = 2
konstant DIAGNOSTIC_ERROR = 3

struktur RuntimeDiagnostic {
    melding: RuntimeString
    severity: heiltall
    lokasjon: SourceLocation
}

struktur RuntimeSemanticContext {
    objekt: RuntimeObject
    current_scope: RuntimeScope
    scope_stack: RuntimeArray
    diagnostics: RuntimeArray
    semantic_flags: heiltall
}

funksjon ny_diagnostic(
    allocator: Allocator,
    melding: RuntimeString,
    severity: heiltall,
    linje: heiltall,
    kolonne: heiltall
) -> RuntimeDiagnostic {
    skriv("[semantic] diagnostic severity: ")
    skrivlinje(severity)

    returner RuntimeDiagnostic {
        melding: melding,
        severity: severity,
        lokasjon: ny_lokasjon(
            linje,
            kolonne
        )
    }
}

funksjon ny_semantic_context(
    allocator: Allocator
) -> RuntimeSemanticContext {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        256
    )

    la global_scope = ny_scope(
        allocator,
        0,
        0
    )

    la scope_stack = ny_array(
        allocator,
        8,
        8
    )

    la diagnostics = ny_array(
        allocator,
        16,
        8
    )

    skrivlinje("[semantic] opprettet semantic context")

    returner RuntimeSemanticContext {
        objekt: objekt,
        current_scope: global_scope,
        scope_stack: scope_stack,
        diagnostics: diagnostics,
        semantic_flags: 0
    }
}

funksjon declare_symbol(
    context: RuntimeSemanticContext,
    symbol: RuntimeSymbol
) {
    scope_put(
        context.current_scope,
        symbol
    )

    skriv("[semantic] deklarerte symbol: ")
    skrivlinje(symbol.typeinfo)
}

funksjon resolve_symbol(
    context: RuntimeSemanticContext,
    navn: RuntimeString
) -> heiltall {
    skrivlinje("[semantic] resolve symbol")

    returner scope_get(
        context.current_scope,
        navn
    )
}

funksjon enter_scope(
    allocator: Allocator,
    context: RuntimeSemanticContext
) {
    context.scope_stack = append_placeholder(
        allocator,
        context.scope_stack
    )

    la child = ny_scope(
        allocator,
        context.current_scope.objekt.data_peker,
        context.current_scope.depth + 1
    )

    legg_til_child_scope(
        allocator,
        context.current_scope,
        child
    )

    context.current_scope = child

    skriv("[semantic] enter scope: ")
    skrivlinje(child.depth)
}

funksjon leave_scope(
    context: RuntimeSemanticContext
) {
    skriv("[semantic] leave scope: ")
    skrivlinje(context.current_scope.depth)

    hvis context.current_scope.depth > 0 {
        context.current_scope.depth = context.current_scope.depth - 1
    }
}

funksjon legg_til_diagnostic(
    allocator: Allocator,
    context: RuntimeSemanticContext,
    diagnostic: RuntimeDiagnostic
) {
    context.diagnostics = append_placeholder(
        allocator,
        context.diagnostics
    )

    skriv("[semantic] diagnostic lagt til: ")
    skrivlinje(diagnostic.severity)
}

funksjon analyser_barn(
    allocator: Allocator,
    context: RuntimeSemanticContext,
    node: RuntimeAstNode
) {
    hvis node == null
        returner
    slutt

    hvis node.barn == null
        returner
    slutt

    la i = 0

    mens i < lengde(node.barn)
        analyser_node(
            allocator,
            context,
            node.barn[i]
        )
        i = i + 1
    slutt
}

funksjon analyser_node(
    allocator: Allocator,
    context: RuntimeSemanticContext,
    node: RuntimeAstNode
) {
    skriv("[semantic] analyser node: ")
    skrivlinje(node.node_type)

    hvis node.node_type == AST_RETURN {
        skrivlinje("[semantic] analyser return")
    }

    hvis node.node_type == AST_VARIABEL {
        skrivlinje("[semantic] analyser variabel")
    }

    hvis node.node_type == AST_FUNKSJON {
        enter_scope(
            allocator,
            context
        )
    }

    analyser_barn(
        allocator,
        context,
        node
    )

    hvis node.node_type == AST_FUNKSJON {
        leave_scope(context)
    }
}

pakke std.compiler

bruk std.runtime

struktur RuntimeCompilerDriver {
    allocator: Allocator
    parser_stream: RuntimeTokenStream
    semantic_context: RuntimeSemanticContext
    lowering_context: RuntimeLoweringContext
    register_allocator: RuntimeRegisterAllocator
    machinecode_buffer: RuntimeMachineCodeBuffer
    elf_image: RuntimeELFImage
    executable: RuntimeExecutableFile
}

funksjon ny_compiler_driver(
    allocator: Allocator,
    output_path: RuntimeString
) -> RuntimeCompilerDriver {
    la parser_stream = ny_token_stream(
        allocator
    )

    la semantic_context = ny_semantic_context(
        allocator
    )

    la lowering_context = ny_lowering_context(
        allocator
    )

    la register_allocator = ny_register_allocator(
        allocator
    )

    la machinecode_buffer = ny_machinecode_buffer(
        allocator
    )

    la elf_image = ny_elf_image(
        allocator,
        machinecode_buffer
    )

    la executable = ny_executable_file(
        allocator,
        elf_image,
        output_path
    )

    skrivlinje("[driver] opprettet compiler driver")

    returner RuntimeCompilerDriver {
        allocator: allocator,
        parser_stream: parser_stream,
        semantic_context: semantic_context,
        lowering_context: lowering_context,
        register_allocator: register_allocator,
        machinecode_buffer: machinecode_buffer,
        elf_image: elf_image,
        executable: executable
    }
}

funksjon parse_source(
    allocator: Allocator,
    driver: RuntimeCompilerDriver
) -> RuntimeAstNode {
    skrivlinje("[driver] parse source")

    la global_scope = driver.semantic_context.current_scope

    returner parse_program_placeholder(
        allocator,
        driver.parser_stream,
        global_scope
    )
}

funksjon analyse_semantics(
    allocator: Allocator,
    driver: RuntimeCompilerDriver,
    root: RuntimeAstNode
) {
    skrivlinje("[driver] semantic analyse")

    analyser_node(
        allocator,
        driver.semantic_context,
        root
    )
}

funksjon lower_ast(
    allocator: Allocator,
    driver: RuntimeCompilerDriver,
    root: RuntimeAstNode
) {
    skrivlinje("[driver] lower AST")

    lower_node(
        allocator,
        driver.lowering_context,
        root
    )
}

funksjon emit_backend(
    allocator: Allocator,
    driver: RuntimeCompilerDriver
) {
    skrivlinje("[driver] emit backend")

    la instruksjon = ny_instruction(
        OP_RETURN,
        0,
        0,
        1
    )

    la reg = allocate_instruction_register(
        allocator,
        driver.register_allocator,
        instruksjon
    )

    emit_instruction_runtime(
        allocator,
        driver.machinecode_buffer,
        instruksjon,
        reg
    )
}

funksjon build_executable(
    allocator: Allocator,
    driver: RuntimeCompilerDriver
) -> bool {
    skrivlinje("[driver] build executable")

    returner skriv_executable(
        allocator,
        driver.executable
    )
}

funksjon kompiler(
    allocator: Allocator,
    output_path: RuntimeString
) -> bool {
    skrivlinje("[driver] start native compiler pipeline")

    la driver = ny_compiler_driver(
        allocator,
        output_path
    )

    la root = parse_source(
        allocator,
        driver
    )

    analyse_semantics(
        allocator,
        driver,
        root
    )

    lower_ast(
        allocator,
        driver,
        root
    )

    emit_backend(
        allocator,
        driver
    )

    returner build_executable(
        allocator,
        driver
    )
}

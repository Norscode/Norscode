pakke std.compiler

bruk std.runtime

konstant BOOTSTRAP_FLAG_NATIVE = 1
konstant BOOTSTRAP_FLAG_SELFHOST = 2

struktur RuntimeBootstrapCompiler {
    objekt: RuntimeObject
    driver: RuntimeCompilerDriver
    linker: RuntimeLinkerContext
    runtime_state: RuntimeMap
    bootstrap_flags: heiltall
}

funksjon ny_bootstrap_compiler(
    allocator: Allocator,
    output_path: RuntimeString
) -> RuntimeBootstrapCompiler {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        512
    )

    la driver = ny_compiler_driver(
        allocator,
        output_path
    )

    la linker = ny_linker_context(
        allocator,
        driver.elf_image
    )

    la runtime_state = ny_map(
        allocator
    )

    skrivlinje("[bootstrap] opprettet bootstrap compiler")

    returner RuntimeBootstrapCompiler {
        objekt: objekt,
        driver: driver,
        linker: linker,
        runtime_state: runtime_state,
        bootstrap_flags: (
            BOOTSTRAP_FLAG_NATIVE eller
            BOOTSTRAP_FLAG_SELFHOST
        )
    }
}

funksjon module_source_paths(
    unit_name: tekst
) -> liste_tekst {
    hvis unit_name == "std.runtime" {
        returner [
            "std/runtime/string.no",
            "std/runtime/array.no",
            "std/runtime/object.no",
            "std/runtime/allocator.no",
            "std/runtime/map.no",
            "std/runtime/native_fs.no",
            "std/runtime/linux_syscalls.no",
            "std/runtime/memory_syscalls.no"
        ]
    }

    hvis unit_name == "std.compiler" {
        returner [
            "std/compiler/bootstrap_runtime.no",
            "std/compiler/compiler_driver_runtime.no",
            "std/compiler/ast_runtime.no",
            "std/compiler/parser_runtime.no",
            "std/compiler/semantic_runtime.no",
            "std/compiler/symbol_runtime.no",
            "std/compiler/lowering_runtime.no",
            "std/compiler/elf_runtime.no",
            "std/compiler/backend_x86_runtime.no",
            "std/compiler/register_allocator_runtime.no",
            "std/compiler/linker_runtime.no",
            "std/compiler/executable_writer_runtime.no"
        ]
    }

    returner []
}

funksjon load_runtime_unit_source(
    unit_name: tekst
) -> tekst {
    la paths = module_source_paths(unit_name)
    la samlet = ""
    la i = 0

    mens i < lengde(paths) {
        la sti = paths[i]
        la del = builtin.fil_les(sti)

        hvis del != "" {
            hvis samlet != "" {
                samlet = samlet + "\n"
            }

            samlet = samlet + del
        }

        i = i + 1
    }

    returner samlet
}

funksjon compile_runtime_unit(
    allocator: Allocator,
    bootstrap: RuntimeBootstrapCompiler,
    unit_name: tekst
) -> bool {
    skriv("[bootstrap] compile runtime unit: ")
    skrivlinje(unit_name)

    la unit_source = load_runtime_unit_source(unit_name)

    hvis unit_source == "" {
        skrivlinje("[bootstrap] error: manglar kjelde for runtime unit")
        returner usann
    }

    bootstrap.driver = ny_compiler_driver(
        allocator,
        bootstrap.driver.executable.output_path
    )

    bootstrap.driver.parser_stream = lex_source_text(
        allocator,
        unit_source
    )

    la root = parse_source(
        allocator,
        bootstrap.driver
    )

    analyse_semantics(
        allocator,
        bootstrap.driver,
        root
    )

    lower_ast(
        allocator,
        bootstrap.driver,
        root
    )

    emit_backend(
        allocator,
        bootstrap.driver
    )

    returner build_executable(
        allocator,
        bootstrap.driver
    )
}

funksjon compile_std_runtime(
    allocator: Allocator,
    bootstrap: RuntimeBootstrapCompiler
) -> bool {
    skrivlinje("[bootstrap] compile std runtime")

    returner compile_runtime_unit(
        allocator,
        bootstrap,
        "std.runtime"
    )
}

funksjon compile_compiler_runtime(
    allocator: Allocator,
    bootstrap: RuntimeBootstrapCompiler
) -> bool {
    skrivlinje("[bootstrap] compile compiler runtime")

    returner compile_runtime_unit(
        allocator,
        bootstrap,
        "std.compiler"
    )
}

funksjon build_bootstrap_chain(
    allocator: Allocator,
    bootstrap: RuntimeBootstrapCompiler
) -> bool {
    skrivlinje("[bootstrap] build bootstrap chain")

    la runtime_ok = compile_std_runtime(
        allocator,
        bootstrap
    )

    la compiler_ok = compile_compiler_runtime(
        allocator,
        bootstrap
    )

    hvis runtime_ok og compiler_ok {
        returner finaliser_elf(
            allocator,
            bootstrap.linker,
            bootstrap.driver.elf_image
        )
    }

    returner usann
}

funksjon bootstrap_compile(
    allocator: Allocator,
    output_path: RuntimeString
) -> bool {
    skrivlinje("[bootstrap] start native bootstrap compiler")

    la bootstrap = ny_bootstrap_compiler(
        allocator,
        output_path
    )

    returner build_bootstrap_chain(
        allocator,
        bootstrap
    )
}

pakke std.compiler

bruk std.runtime

konstant TOKEN_IDENT = 1
konstant TOKEN_TALL = 2
konstant TOKEN_TEKST = 3
konstant TOKEN_FUNKSJON = 4
konstant TOKEN_RETURN = 5
konstant TOKEN_EOF = 255

struktur RuntimeToken {
    objekt: RuntimeObject
    token_type: heiltall
    lexeme: RuntimeString
    lokasjon: SourceLocation
    flags: heiltall
}

struktur RuntimeTokenStream {
    objekt: RuntimeObject
    tokens: RuntimeArray
    indeks: heiltall
    parser_flags: heiltall
}

funksjon ny_token(
    allocator: Allocator,
    token_type: heiltall,
    lexeme: RuntimeString,
    linje: heiltall,
    kolonne: heiltall
) -> RuntimeToken {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        64
    )

    skriv("[parser] ny token: ")
    skrivlinje(token_type)

    returner RuntimeToken {
        objekt: objekt,
        token_type: token_type,
        lexeme: lexeme,
        lokasjon: ny_lokasjon(
            linje,
            kolonne
        ),
        flags: 0
    }
}

funksjon ny_token_stream(
    allocator: Allocator
) -> RuntimeTokenStream {
    la objekt = alloker_objekt(
        allocator,
        TYPE_ARRAY,
        128
    )

    la tokens = ny_array(
        allocator,
        16,
        8
    )

    skrivlinje("[parser] opprettet token stream")

    returner RuntimeTokenStream {
        objekt: objekt,
        tokens: tokens,
        indeks: 0,
        parser_flags: 0
    }
}

funksjon stream_lengde(
    stream: RuntimeTokenStream
) -> heiltall {
    returner stream.tokens.lengde
}

funksjon er_slutt(
    stream: RuntimeTokenStream
) -> bool {
    returner stream.indeks >= stream.tokens.lengde
}

funksjon peek(
    stream: RuntimeTokenStream
) -> heiltall {
    hvis er_slutt(stream) {
        returner TOKEN_EOF
    }

    returner stream.indeks
}

funksjon advance(
    stream: RuntimeTokenStream
) -> heiltall {
    hvis ikkje er_slutt(stream) {
        stream.indeks = stream.indeks + 1
    }

    returner stream.indeks
}

funksjon match(
    stream: RuntimeTokenStream,
    token_type: heiltall
) -> bool {
    hvis peek(stream) == token_type {
        advance(stream)
        returner sann
    }

    returner usann
}

funksjon legg_til_token(
    allocator: Allocator,
    stream: RuntimeTokenStream,
    token: RuntimeToken
) {
    stream.tokens = append_placeholder(
        allocator,
        stream.tokens
    )

    skriv("[parser] la til token: ")
    skrivlinje(token.token_type)
}

funksjon parse_program_placeholder(
    allocator: Allocator,
    stream: RuntimeTokenStream,
    scope: RuntimeScope
) -> RuntimeAstNode {
    skrivlinje("[parser] parse program placeholder")

    la node = alloker_ast_node(
        allocator,
        AST_PROGRAM,
        1,
        1
    )

    returner node
}

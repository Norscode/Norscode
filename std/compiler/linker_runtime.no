pakke std.compiler

bruk std.runtime

struktur RuntimePatchEntry {
    patch_offset: heiltall
    target_offset: heiltall
    reloc_type: heiltall
}

struktur RuntimeLinkerContext {
    objekt: RuntimeObject
    relocation_table: RuntimeArray
    symbol_table: RuntimeMap
    section_map: RuntimeMap
    patches: RuntimeArray
}

funksjon ny_patch_entry(
    patch_offset: heiltall,
    target_offset: heiltall,
    reloc_type: heiltall
) -> RuntimePatchEntry {
    returner RuntimePatchEntry {
        patch_offset: patch_offset,
        target_offset: target_offset,
        reloc_type: reloc_type
    }
}

funksjon ny_linker_context(
    allocator: Allocator,
    image: RuntimeELFImage
) -> RuntimeLinkerContext {
    la objekt = alloker_objekt(
        allocator,
        TYPE_AST,
        256
    )

    la relocations = image.relocations

    la symbol_table = ny_map(
        allocator
    )

    la section_map = ny_map(
        allocator
    )

    la patches = ny_array(
        allocator,
        64,
        16
    )

    skrivlinje("[linker] opprettet linker context")

    returner RuntimeLinkerContext {
        objekt: objekt,
        relocation_table: relocations,
        symbol_table: symbol_table,
        section_map: section_map,
        patches: patches
    }
}

funksjon patch_relative_offset(
    patch_offset: heiltall,
    target_offset: heiltall
) -> heiltall {
    la relativ = (
        target_offset - (patch_offset + 4)
    )

    skriv("[linker] patch relative offset: ")
    skrivlinje(relativ)

    returner relativ
}

funksjon resolve_label(
    labels: RuntimeMap,
    label_hash: heiltall
) -> heiltall {
    skriv("[linker] resolve label: ")
    skrivlinje(label_hash)

    returner map_get(
        labels,
        label_hash
    )
}

funksjon lookup_symbol(
    linker: RuntimeLinkerContext,
    symbol_hash: heiltall
) -> heiltall {
    skriv("[linker] lookup symbol: ")
    skrivlinje(symbol_hash)

    returner map_get(
        linker.symbol_table,
        symbol_hash
    )
}

funksjon resolve_jump(
    allocator: Allocator,
    linker: RuntimeLinkerContext,
    buffer: RuntimeMachineCodeBuffer,
    reloc: RuntimeRelocation
) {
    la target = resolve_label(
        buffer.labels,
        reloc.target
    )

    la relative = patch_relative_offset(
        reloc.offset,
        target
    )

    linker.patches = append_placeholder(
        allocator,
        linker.patches
    )

    skriv("[linker] resolve jump -> relative: ")
    skrivlinje(relative)
}

funksjon resolve_call(
    allocator: Allocator,
    linker: RuntimeLinkerContext,
    buffer: RuntimeMachineCodeBuffer,
    reloc: RuntimeRelocation
) {
    la target = resolve_label(
        buffer.labels,
        reloc.target
    )

    la relative = patch_relative_offset(
        reloc.offset,
        target
    )

    linker.patches = append_placeholder(
        allocator,
        linker.patches
    )

    skriv("[linker] resolve call -> relative: ")
    skrivlinje(relative)
}

funksjon finaliser_sections(
    image: RuntimeELFImage
) {
    skrivlinje("[linker] finaliser ELF sections")

    image.header.program_header_offset = 64
    image.header.section_header_offset = 0
}

funksjon validate_entrypoint(
    image: RuntimeELFImage
) -> bool {
    skriv("[linker] validate entrypoint: ")
    skrivlinje(image.header.entrypoint)

    hvis image.header.entrypoint <= 0 {
        returner usann
    }

    returner sann
}

funksjon resolve_relocations(
    allocator: Allocator,
    linker: RuntimeLinkerContext,
    image: RuntimeELFImage
) {
    skriv("[linker] resolve relocations: ")
    skrivlinje(linker.relocation_table.lengde)

    finaliser_sections(image)
}

funksjon finaliser_elf(
    allocator: Allocator,
    linker: RuntimeLinkerContext,
    image: RuntimeELFImage
) -> bool {
    skrivlinje("[linker] finaliser ELF image")

    resolve_relocations(
        allocator,
        linker,
        image
    )

    returner validate_entrypoint(image)
}

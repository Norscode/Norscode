# terminal.no — ANSI-escape-kodar for fargar og formatering
# Python: colorama, rich, termcolor
#
# Bruk:
#   bruk std.terminal som t
#   skriv(t.raud("Feil!"))
#   skriv(t.grøn("OK"))
#   skriv(t.fet("viktig tekst"))
#   skriv(t.farge("Hei", t.BLÅ(), t.KVIT_BG()))

# ─── Basiskonstantar ───────────────────────────────────────────────────────────

funksjon NULLSTILL()   -> tekst  {
    returner "[0m"
}

# Tekststilar
funksjon FET()         -> tekst  {
    returner "[1m"
}
funksjon SVAK()        -> tekst  {
    returner "[2m"
}
funksjon KURSIV()      -> tekst  {
    returner "[3m"
}
funksjon UNDERSTREKING() -> tekst  {
    returner "[4m"
}
funksjon BLINK()       -> tekst  {
    returner "[5m"
}
funksjon INVERS()      -> tekst  {
    returner "[7m"
}
funksjon GJENNOMSTREK() -> tekst  {
    returner "[9m"
}

# Tekstfargar (forgrunnsfargar)
funksjon SVART()       -> tekst  {
    returner "[30m"
}
funksjon RAUD()        -> tekst  {
    returner "[31m"
}
funksjon GRØN()        -> tekst  {
    returner "[32m"
}
funksjon GUL()         -> tekst  {
    returner "[33m"
}
funksjon BLAA()        -> tekst  {
    returner "[34m"
}
funksjon MAGENTA()     -> tekst  {
    returner "[35m"
}
funksjon CYAN()        -> tekst  {
    returner "[36m"
}
funksjon KVIT()        -> tekst  {
    returner "[37m"
}

# Lyse tekstfargar
funksjon LYS_SVART()   -> tekst  {
    returner "[90m"
}
funksjon LYS_RAUD()    -> tekst  {
    returner "[91m"
}
funksjon LYS_GRØN()    -> tekst  {
    returner "[92m"
}
funksjon LYS_GUL()     -> tekst  {
    returner "[93m"
}
funksjon LYS_BLAA()    -> tekst  {
    returner "[94m"
}
funksjon LYS_MAGENTA() -> tekst  {
    returner "[95m"
}
funksjon LYS_CYAN()    -> tekst  {
    returner "[96m"
}
funksjon LYS_KVIT()    -> tekst  {
    returner "[97m"
}

# Bakgrunnsfargar
funksjon SVART_BG()    -> tekst  {
    returner "[40m"
}
funksjon RAUD_BG()     -> tekst  {
    returner "[41m"
}
funksjon GRØN_BG()     -> tekst  {
    returner "[42m"
}
funksjon GUL_BG()      -> tekst  {
    returner "[43m"
}
funksjon BLAA_BG()     -> tekst  {
    returner "[44m"
}
funksjon MAGENTA_BG()  -> tekst  {
    returner "[45m"
}
funksjon CYAN_BG()     -> tekst  {
    returner "[46m"
}
funksjon KVIT_BG()     -> tekst  {
    returner "[47m"
}

# ─── Hjelparfunksjonar ────────────────────────────────────────────────────────

# Pakk inn tekst med kode og nullstilling
funksjon pakk(kode: tekst, innhald: tekst) -> tekst {
    returner kode + innhald + NULLSTILL()
}

# Bruk fleire kodar samstundes
funksjon farge(innhald: tekst, tekstfarge: tekst, bakgrunn: tekst) -> tekst {
    returner tekstfarge + bakgrunn + innhald + NULLSTILL()
}

# ─── Fargegenvegar ────────────────────────────────────────────────────────────

funksjon raud(s: tekst)    -> tekst  {
    returner pakk(RAUD(), s)
}
funksjon grøn(s: tekst)    -> tekst  {
    returner pakk(GRØN(), s)
}
funksjon gul(s: tekst)     -> tekst  {
    returner pakk(GUL(), s)
}
funksjon blaa(s: tekst)    -> tekst  {
    returner pakk(BLAA(), s)
}
funksjon magenta(s: tekst) -> tekst  {
    returner pakk(MAGENTA(), s)
}
funksjon cyan(s: tekst)    -> tekst  {
    returner pakk(CYAN(), s)
}
funksjon kvit(s: tekst)    -> tekst  {
    returner pakk(KVIT(), s)
}
funksjon graa(s: tekst)    -> tekst  {
    returner pakk(LYS_SVART(), s)
}

# ─── Stilgenvegar ─────────────────────────────────────────────────────────────

funksjon fet(s: tekst)          -> tekst  {
    returner pakk(FET(), s)
}
funksjon kursiv(s: tekst)       -> tekst  {
    returner pakk(KURSIV(), s)
}
funksjon understrek(s: tekst)   -> tekst  {
    returner pakk(UNDERSTREKING(), s)
}
funksjon gjennomstrek(s: tekst) -> tekst  {
    returner pakk(GJENNOMSTREK(), s)
}
funksjon invers(s: tekst)       -> tekst  {
    returner pakk(INVERS(), s)
}
funksjon svak(s: tekst)         -> tekst  {
    returner pakk(SVAK(), s)
}

# ─── Logg-nivå ────────────────────────────────────────────────────────────────

funksjon feil_tekst(s: tekst)   -> tekst  {
    returner raud(fet("[FEIL] ") + s)
}
funksjon åtvaring_tekst(s: tekst) -> tekst  {
    returner gul(fet("[ÅTVARING] ") + s)
}
funksjon ok_tekst(s: tekst)     -> tekst  {
    returner grøn(fet("[OK] ") + s)
}
funksjon info_tekst(s: tekst)   -> tekst  {
    returner cyan("[INFO] " + s)
}
funksjon debug_tekst(s: tekst)  -> tekst  {
    returner graa("[DEBUG] " + s)
}

# ─── Rydding og markørkontroll ────────────────────────────────────────────────

# Tøm terminalen
funksjon tøm_skjerm() -> tekst  {
    returner "[2J[H"
}

# Flytt markøren til rad r, kolonne k (1-indeksert)
funksjon flytt_markør(r: heltall, k: heltall) -> tekst {
    returner "[" + tekst_fra_heltall(r) + ";" + tekst_fra_heltall(k) + "H"
}

# Skjul / vis markør
funksjon skjul_markør() -> tekst  {
    returner "[?25l"
}
funksjon vis_markør()   -> tekst  {
    returner "[?25h"
}

# Slett frå markør til linjslutt
funksjon slett_linje() -> tekst  {
    returner "[2K\r"
}

# ─── Fremdriftsbar ────────────────────────────────────────────────────────────
# Returnerer ein tekststreng med progressbar, t.d. "[=====>    ] 60%"

funksjon fremdrift(prosent: heltall, bredde: heltall) -> tekst {
    la fyll_n: heltall = prosent * bredde / 100
    la tom_n: heltall = bredde - fyll_n
    la fyll: tekst = ""
    la tom: tekst = ""
    la i: heltall = 0
    mens (i < fyll_n) { fyll = fyll + "="  i = i + 1 }
    i = 0
    mens (i < tom_n) { tom = tom + " "  i = i + 1 }
    la pil: tekst = ""
    hvis (fyll_n > 0 og fyll_n < bredde) {
        fyll = builtin.slice(fyll, 0, fyll_n - 1)
        pil = ">"
    }
    returner grøn("[" + fyll + pil + tom + "] " + tekst_fra_heltall(prosent) + "%")
}

# ─── Tabell ───────────────────────────────────────────────────────────────────
# Skriv ei enkel tabell med ANSI-fargar på overskrifta

funksjon tabell_overskrift(kolonnar: liste_tekst, kolonnebredde: heltall) -> tekst {
    la linje: tekst = ""
    la i: heltall = 0
    mens (i < lengde(kolonnar)) {
        la celle: tekst = kolonnar[i]
        la n: heltall = lengde(builtin.split(celle, ""))
        la pad: tekst = celle
        la j: heltall = n
        mens (j < kolonnebredde) { pad = pad + " "  j = j + 1 }
        linje = linje + fet(cyan(pad)) + " "
        i = i + 1
    }
    returner linje
}

funksjon tabell_rad(verdiar: liste_tekst, kolonnebredde: heltall) -> tekst {
    la linje: tekst = ""
    la i: heltall = 0
    mens (i < lengde(verdiar)) {
        la celle: tekst = verdiar[i]
        la n: heltall = lengde(builtin.split(celle, ""))
        la pad: tekst = celle
        la j: heltall = n
        mens (j < kolonnebredde) { pad = pad + " "  j = j + 1 }
        linje = linje + pad + " "
        i = i + 1
    }
    returner linje
}

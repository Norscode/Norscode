# zip.no — Arkivoperasjonar (ZIP og TAR)
# Python: zipfile, tarfile
#
# Krev builtin.zip_* i kompilatoren for faktiske arkivoperasjonar.
# Utan builtin-støtte fungerer API-et som ein virtuell filbeholder.
#
# Virtuell ZIP: ordbok_tekst der nøklar er filnamn og verdiar er innhald.
# Dette gjer det mogleg å byggje og inspisere ZIP-struktur utan OS.
#
# Bruk:
#   bruk std.zip som zp
#   la ark = zp.ny_zip()
#   zp.legg_til_fil(ark, "hallo.txt", "Hallo verd!")
#   zp.skriv_til_disk(ark, "arkiv.zip")
#   la les_ark = zp.les_frå_disk("arkiv.zip")
#   skriv(zp.les_fil(les_ark, "hallo.txt"))

bruk std.bytes som bytes

# ─── Virtuell ZIP (in-memory) ─────────────────────────────────────────────────

funksjon ny_zip() -> ordbok_tekst {
    la ark: ordbok_tekst = {}
    ark["__type__"] = "zip"
    returner ark
}

funksjon legg_til_fil(ark: ordbok_tekst, namn: tekst, innhald: tekst) -> heltall {
    ark[namn] = innhald
    returner 0
}

funksjon les_fil(ark: ordbok_tekst, namn: tekst) -> tekst {
    hvis (har_nokkel(ark, namn)) { returner ark[namn] }
    returner ""
}

funksjon inneheld(ark: ordbok_tekst, namn: tekst) -> bool {
    returner har_nokkel(ark, namn)
}

funksjon lista_filer(ark: ordbok_tekst) -> liste_tekst {
    la nøklar = builtin.nøkler(ark)
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la k: tekst = nøklar[i]
        hvis (k != "__type__") { legg_til(ut, k) }
        i = i + 1
    }
    returner ut
}

funksjon slett_frå_zip(ark: ordbok_tekst, namn: tekst) -> heltall {
    hvis (har_nokkel(ark, namn)) { fjern_nokkel(ark, namn) }
    returner 0
}

funksjon tal_filer(ark: ordbok_tekst) -> heltall {
    la n: heltall = lengde(builtin.nøkler(ark))
    returner n - 1  # minus __type__
}

# ─── Disk-operasjonar (krev builtin) ──────────────────────────────────────────

funksjon skriv_til_disk(ark: ordbok_tekst, sti: tekst) -> bool {
    prøv {
        la res: heltall = builtin.zip_skriv(sti, builtin.json_stringify(ark))
        returner res == 0
    } fang (e) {
        # Fallback: skriv som JSON
        prøv {
            builtin.fil_skriv(sti + ".json", builtin.json_stringify(ark))
            returner sann
        } fang (e2) {
            returner usann
        }
        returner usann
    }
    returner usann
}

funksjon les_frå_disk(sti: tekst) -> ordbok_tekst {
    prøv {
        la data: tekst = builtin.zip_les(sti)
        returner builtin.json_parse(data)
    } fang (e) {
        # Fallback: prøv JSON
        prøv {
            la data: tekst = builtin.fil_les(sti + ".json")
            returner builtin.json_parse(data)
        } fang (e2) {
            returner ny_zip()
        }
        returner ny_zip()
    }
    returner ny_zip()
}

# Pakk ut alle filer til ein katalog
funksjon pakk_ut(ark: ordbok_tekst, katalog: tekst) -> heltall {
    prøv {
        returner builtin.zip_pakk_ut(builtin.json_stringify(ark), katalog)
    } fang (e) {
        # Fallback: skriv filer ein etter ein
        la filer = lista_filer(ark)
        la i: heltall = 0
        mens (i < lengde(filer)) {
            la namn: tekst = filer[i]
            la sti: tekst = katalog + "/" + namn
            prøv { builtin.fil_skriv(sti, ark[namn]) } fang (e2) {}
            i = i + 1
        }
        returner 0
    }
    returner 0
}

# ─── ZIP frå katalog ──────────────────────────────────────────────────────────

funksjon ny_frå_katalog(katalog: tekst) -> ordbok_tekst {
    la ark = ny_zip()
    prøv {
        la data: tekst = builtin.zip_frå_katalog(katalog)
        returner builtin.json_parse(data)
    } fang (e) {
        returner ark
    }
    returner ark
}

# ─── TAR-API (same mønster som ZIP) ──────────────────────────────────────────

funksjon ny_tar() -> ordbok_tekst {
    la ark: ordbok_tekst = {}
    ark["__type__"] = "tar"
    returner ark
}

funksjon tar_legg_til(ark: ordbok_tekst, namn: tekst, innhald: tekst) -> heltall {
    returner legg_til_fil(ark, namn, innhald)
}

funksjon tar_legg_til_bytes(ark: ordbok_tekst, namn: tekst, innhald) -> heltall {
    ark[namn] = innhald
    returner 0
}

funksjon tar_les_fil(ark: ordbok_tekst, namn: tekst) -> tekst {
    returner les_fil(ark, namn)
}

funksjon tar_lista(ark: ordbok_tekst) -> liste_tekst {
    returner lista_filer(ark)
}

funksjon _tar_ascii(data: liste_heltall, offset: heiltall, tekstverdi: tekst, breidde: heiltall) -> heiltall {
    la n = lengde(tekstverdi)
    la i = 0
    mens i < breidde {
        hvis i < n {
            data[offset + i] = builtin.char_code(builtin.slice(tekstverdi, i, i + 1))
        } ellers {
            data[offset + i] = 0
        }
        i = i + 1
    }
    returner 0
}

funksjon _tar_octal(verdi: heiltall, breidde: heiltall) -> tekst {
    la s = ""
    la v = verdi
    hvis v == 0 { s = "0" }
    mens v > 0 {
        la rest = v % 8
        s = builtin.chr(48 + rest) + s
        v = v / 8
    }
    mens lengde(s) < breidde - 1 { s = "0" + s }
    returner s + " "
}

funksjon _tar_byteinnhald(data: liste_heltall, tekstverdi: tekst) -> heiltall {
    la i = 0
    mens i < lengde(tekstverdi) {
        legg_til(data, builtin.char_code(builtin.slice(tekstverdi, i, i + 1)))
        i = i + 1
    }
    returner 0
}

funksjon _tar_innhald_liste(innhald) -> liste_heltall {
    hvis bytes.er_bytes(innhald) { returner bytes.til_liste(innhald) }
    la ut: liste_heltall = []
    _tar_byteinnhald(ut, tekst(innhald))
    returner ut
}

funksjon _tar_fil(data: liste_heltall, namn: tekst, innhald) -> heiltall {
    la innhald_bytes = _tar_innhald_liste(innhald)
    la header: liste_heltall = []
    la hi = 0
    mens hi < 512 {
        legg_til(header, 0)
        hi = hi + 1
    }
    _tar_ascii(header, 0, namn, 100)
    _tar_ascii(header, 100, "0000644", 8)
    _tar_ascii(header, 108, "0000000", 8)
    _tar_ascii(header, 116, "0000000", 8)
    _tar_ascii(header, 124, _tar_octal(lengde(innhald_bytes), 12), 12)
    _tar_ascii(header, 136, "00000000000 ", 12)
    la ci = 148
    mens ci < 156 {
        header[ci] = 32
        ci = ci + 1
    }
    header[156] = 48
    _tar_ascii(header, 257, "ustar", 6)
    _tar_ascii(header, 263, "00", 2)
    la checksum = 0
    ci = 0
    mens ci < 512 {
        checksum = checksum + header[ci]
        ci = ci + 1
    }
    _tar_ascii(header, 148, _tar_octal(checksum, 8), 8)
    ci = 0
    mens ci < 512 {
        legg_til(data, header[ci])
        ci = ci + 1
    }
    la bi = 0
    mens bi < lengde(innhald_bytes) {
        legg_til(data, innhald_bytes[bi])
        bi = bi + 1
    }
    la rest = lengde(innhald_bytes) % 512
    hvis rest > 0 {
        la padding = 512 - rest
        la pi = 0
        mens pi < padding {
            legg_til(data, 0)
            pi = pi + 1
        }
    }
    returner 0
}

funksjon _tar_skriv_pure(ark: ordbok_tekst, sti: tekst) -> bool {
    prøv {
        la data: liste_heltall = []
        la filer = lista_filer(ark)
        la i = 0
        mens i < lengde(filer) {
            _tar_fil(data, filer[i], ark[filer[i]])
            i = i + 1
        }
        la zi = 0
        mens zi < 1024 {
            legg_til(data, 0)
            zi = zi + 1
        }
        builtin.fil_skriv_binær(sti, bytes.fra_liste(data))
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon _tar_crc32(data: liste_heltall) -> heiltall {
    la tabell: liste_heltall = [0, 1996959894, 3993919788, 2567524794,
        124634137, 1886057615, 3915621685, 2657392035,
        249268274, 2044508324, 3772115230, 2547177864,
        162941995, 2125561021, 3887607047, 2428444049]
    la crc = 4294967295
    la i = 0
    mens i < lengde(data) {
        crc = crc ^ data[i]
        crc = (crc >> 4) ^ tabell[crc & 15]
        crc = (crc >> 4) ^ tabell[crc & 15]
        i = i + 1
    }
    returner crc ^ 4294967295
}

funksjon _tar_lagre_data(ark: ordbok_tekst) -> liste_heltall {
    la data: liste_heltall = []
    la filer = lista_filer(ark)
    la i = 0
    mens i < lengde(filer) {
        _tar_fil(data, filer[i], ark[filer[i]])
        i = i + 1
    }
    la zi = 0
    mens zi < 1024 {
        legg_til(data, 0)
        zi = zi + 1
    }
    returner data
}

funksjon _tar_gzip_bytes(data: liste_heltall) -> liste_heltall {
    la out: liste_heltall = [31, 139, 8, 0, 0, 0, 0, 0, 0, 255]
    la pos = 0
    hvis lengde(data) == 0 {
        legg_til(out, 1)
        legg_til(out, 0)
        legg_til(out, 0)
        legg_til(out, 255)
        legg_til(out, 255)
    }
    mens pos < lengde(data) {
        la att = lengde(data) - pos
        hvis att > 65535 { att = 65535 }
        la siste = pos + att >= lengde(data)
        hvis siste { legg_til(out, 1) } ellers { legg_til(out, 0) }
        legg_til(out, att % 256)
        legg_til(out, att / 256)
        la inv = 65535 - att
        legg_til(out, inv % 256)
        legg_til(out, inv / 256)
        la i = 0
        mens i < att {
            legg_til(out, data[pos + i])
            i = i + 1
        }
        pos = pos + att
    }
    la crc = _tar_crc32(data)
    legg_til(out, crc & 255)
    legg_til(out, (crc >> 8) & 255)
    legg_til(out, (crc >> 16) & 255)
    legg_til(out, (crc >> 24) & 255)
    la storleik = lengde(data)
    legg_til(out, storleik & 255)
    legg_til(out, (storleik >> 8) & 255)
    legg_til(out, (storleik >> 16) & 255)
    legg_til(out, (storleik >> 24) & 255)
    returner out
}

funksjon _tar_gzip_skriv_stream(data: liste_heltall, sti: tekst) -> bool {
    prøv {
        builtin.fil_skriv_binær(sti, bytes.fra_liste([31, 139, 8, 0, 0, 0, 0, 0, 0, 255]))
        la pos = 0
        mens pos < lengde(data) {
            la att = lengde(data) - pos
            hvis att > 65535 { att = 65535 }
            la blokk: liste_heltall = []
            hvis pos + att >= lengde(data) { legg_til(blokk, 1) } ellers { legg_til(blokk, 0) }
            legg_til(blokk, att % 256)
            legg_til(blokk, att / 256)
            la inv = 65535 - att
            legg_til(blokk, inv % 256)
            legg_til(blokk, inv / 256)
            la i = 0
            mens i < att {
                legg_til(blokk, data[pos + i])
                i = i + 1
            }
            builtin.fil_append_binary(sti, bytes.fra_liste(blokk))
            pos = pos + att
        }
        la crc = _tar_crc32(data)
        builtin.fil_append_binary(sti, bytes.fra_liste([
            crc & 255, (crc >> 8) & 255, (crc >> 16) & 255, (crc >> 24) & 255,
            lengde(data) & 255, (lengde(data) >> 8) & 255,
            (lengde(data) >> 16) & 255, (lengde(data) >> 24) & 255]))
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon tar_skriv_gzip(ark: ordbok_tekst, sti: tekst) -> bool {
    prøv {
        la data = _tar_lagre_data(ark)
        hvis _tar_gzip_skriv_stream(data, sti) { returner sann }
        builtin.fil_skriv_binær(sti, bytes.fra_liste(_tar_gzip_bytes(data)))
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon tar_skriv(ark: ordbok_tekst, sti: tekst) -> bool {
    prøv {
        la res: heltall = builtin.tar_skriv(sti, builtin.json_stringify(ark))
        hvis res == 0 { returner sann }
        // Native ABI kan vere til stades utan å støtte denne arkivforma;
        // fallback skal då vere like robust som ved manglande symbol.
        returner _tar_skriv_pure(ark, sti)
    } fang (e) {
        returner _tar_skriv_pure(ark, sti)
    }
    returner usann
}

funksjon _tar_gzip_dekomprimer(data: liste_heltall) -> liste_heltall {
    hvis lengde(data) < 18 eller data[0] != 31 eller data[1] != 139 { returner [] }
    la pos = 10
    la ut: liste_heltall = []
    la ferdig = usann
    mens ikkje ferdig og pos < lengde(data) {
        la header = data[pos]
        pos = pos + 1
        ferdig = (header & 1) == 1
        hvis ((header >> 1) & 3) != 0 { returner [] }
        hvis pos + 4 > lengde(data) { returner [] }
        la storleik = data[pos] + (data[pos + 1] << 8)
        la invers = data[pos + 2] + (data[pos + 3] << 8)
        hvis (storleik ^ 65535) != invers { returner [] }
        pos = pos + 4
        hvis pos + storleik > lengde(data) { returner [] }
        la i = 0
        mens i < storleik {
            legg_til(ut, data[pos + i])
            i = i + 1
        }
        pos = pos + storleik
    }
    returner ut
}

funksjon _tar_namn(data: liste_heltall, start: heiltall, breidde: heiltall) -> tekst {
    la ut = ""
    la i = 0
    mens i < breidde og data[start + i] != 0 {
        ut = ut + builtin.chr(data[start + i])
        i = i + 1
    }
    returner ut
}

funksjon _tar_storleik(data: liste_heltall, start: heiltall, breidde: heiltall) -> heiltall {
    la ut = 0
    la i = 0
    mens i < breidde {
        la c = data[start + i]
        hvis c >= 48 og c <= 55 { ut = ut * 8 + c - 48 }
        i = i + 1
    }
    returner ut
}

funksjon _tar_trygg_namn(namn: tekst) -> bool {
    hvis namn == "" eller builtin.starts_with(namn, "/") eller builtin.index_of(namn, "\\") >= 0 { returner usann }
    la delar = builtin.split(namn, "/")
    la i = 0
    mens i < lengde(delar) {
        hvis delar[i] == ".." eller delar[i] == "" { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon _tar_forelder(sti: tekst) -> tekst {
    la pos = -1
    la i = 0
    mens i < lengde(sti) {
        hvis builtin.slice(sti, i, i + 1) == "/" { pos = i }
        i = i + 1
    }
    hvis pos < 0 { returner "" }
    returner builtin.slice(sti, 0, pos)
}

funksjon tar_pakk_ut(sti: tekst, katalog: tekst) -> bool {
    prøv {
        la rå = bytes.til_liste(builtin.fil_les_binær(sti))
        la data = _tar_gzip_dekomprimer(rå)
        hvis lengde(data) == 0 { returner usann }
        la pos = 0
        mens pos + 512 <= lengde(data) {
            hvis data[pos] == 0 { returner sann }
            la namn = _tar_namn(data, pos, 100)
            hvis ikkje _tar_trygg_namn(namn) { returner usann }
            la storleik = _tar_storleik(data, pos + 124, 12)
            la innhald_start = pos + 512
            hvis innhald_start + storleik > lengde(data) { returner usann }
            la innhald: liste_heltall = []
            la i = 0
            mens i < storleik {
                legg_til(innhald, data[innhald_start + i])
                i = i + 1
            }
            la mål = katalog + "/" + namn
            la forelder = _tar_forelder(mål)
            hvis forelder != "" { builtin.mkdir_p(forelder) }
            builtin.fil_skriv_binær(mål, bytes.fra_liste(innhald))
            la blokker = storleik / 512
            hvis storleik % 512 != 0 { blokker = blokker + 1 }
            pos = innhald_start + blokker * 512
        }
    } fang (e) { returner usann }
    returner usann
}

funksjon tar_les(sti: tekst) -> ordbok_tekst {
    prøv {
        la data: tekst = builtin.tar_les(sti)
        returner builtin.json_parse(data)
    } fang (e) {
        returner les_frå_disk(sti)
    }
    returner ny_tar()
}

# ─── Arkivinfo ────────────────────────────────────────────────────────────────

funksjon er_zip(ark: ordbok_tekst) -> bool {
    returner har_nokkel(ark, "__type__") og ark["__type__"] == "zip"
}

funksjon er_tar(ark: ordbok_tekst) -> bool {
    returner har_nokkel(ark, "__type__") og ark["__type__"] == "tar"
}

funksjon total_storleik(ark: ordbok_tekst) -> heltall {
    la filer = lista_filer(ark)
    la total: heltall = 0
    la i: heltall = 0
    mens (i < lengde(filer)) {
        la innhald: tekst = les_fil(ark, filer[i])
        total = total + lengde(builtin.split(innhald, ""))
        i = i + 1
    }
    returner total
}

funksjon er_støtta() -> bool {
    prøv {
        builtin.zip_skriv("__test__.zip", "{}")
        builtin.fil_les("__test__.zip")
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

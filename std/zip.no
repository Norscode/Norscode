# zip.no — Arkivoperasjonar (ZIP og TAR)
# Python: zipfile, tarfile
#
# Krev builtin.zip_* i kompilatoren for faktiske arkivoperasjonar.
# Utan builtin-støtte fungerer API-et som ein virtuell filbeholder.
#
# Virtuell ZIP: ordbok_tekst der nøklar er filnamn og verdiar er innhald.
# Dette gjer det mogleg å byggje og inspisere ZIP-struktur utan OS.
#
# Bruk:
#   bruk std.zip som zp
#   la ark = zp.ny_zip()
#   zp.legg_til_fil(ark, "hallo.txt", "Hallo verd!")
#   zp.skriv_til_disk(ark, "arkiv.zip")
#   la les_ark = zp.les_frå_disk("arkiv.zip")
#   skriv(zp.les_fil(les_ark, "hallo.txt"))

# ─── Virtuell ZIP (in-memory) ─────────────────────────────────────────────────

funksjon ny_zip() -> ordbok_tekst {
    la ark: ordbok_tekst = {}
    ark["__type__"] = "zip"
    returner ark
}

funksjon legg_til_fil(ark: ordbok_tekst, namn: tekst, innhald: tekst) -> heltall {
    ark[namn] = innhald
    returner 0
}

funksjon les_fil(ark: ordbok_tekst, namn: tekst) -> tekst {
    hvis (har_nokkel(ark, namn)) { returner ark[namn] }
    returner ""
}

funksjon inneheld(ark: ordbok_tekst, namn: tekst) -> bool {
    returner har_nokkel(ark, namn)
}

funksjon lista_filer(ark: ordbok_tekst) -> liste_tekst {
    la nøklar = builtin.nøkler(ark)
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la k: tekst = nøklar[i]
        hvis (k != "__type__") { legg_til(ut, k) }
        i = i + 1
    }
    returner ut
}

funksjon slett_frå_zip(ark: ordbok_tekst, namn: tekst) -> heltall {
    hvis (har_nokkel(ark, namn)) { fjern_nokkel(ark, namn) }
    returner 0
}

funksjon tal_filer(ark: ordbok_tekst) -> heltall {
    la n: heltall = lengde(builtin.nøkler(ark))
    returner n - 1  # minus __type__
}

# ─── Disk-operasjonar (krev builtin) ──────────────────────────────────────────

funksjon skriv_til_disk(ark: ordbok_tekst, sti: tekst) -> bool {
    prøv {
        la res: heltall = builtin.zip_skriv(sti, builtin.json_stringify(ark))
        returner res == 0
    } fang (e) {
        # Fallback: skriv som JSON
        prøv {
            builtin.fil_skriv(sti + ".json", builtin.json_stringify(ark))
            returner sann
        } fang (e2) {
            returner usann
        }
        returner usann
    }
    returner usann
}

funksjon les_frå_disk(sti: tekst) -> ordbok_tekst {
    prøv {
        la data: tekst = builtin.zip_les(sti)
        returner builtin.json_parse(data)
    } fang (e) {
        # Fallback: prøv JSON
        prøv {
            la data: tekst = builtin.fil_les(sti + ".json")
            returner builtin.json_parse(data)
        } fang (e2) {
            returner ny_zip()
        }
        returner ny_zip()
    }
    returner ny_zip()
}

# Pakk ut alle filer til ein katalog
funksjon pakk_ut(ark: ordbok_tekst, katalog: tekst) -> heltall {
    prøv {
        returner builtin.zip_pakk_ut(builtin.json_stringify(ark), katalog)
    } fang (e) {
        # Fallback: skriv filer ein etter ein
        la filer = lista_filer(ark)
        la i: heltall = 0
        mens (i < lengde(filer)) {
            la namn: tekst = filer[i]
            la sti: tekst = katalog + "/" + namn
            prøv { builtin.fil_skriv(sti, ark[namn]) } fang (e2) {}
            i = i + 1
        }
        returner 0
    }
    returner 0
}

# ─── ZIP frå katalog ──────────────────────────────────────────────────────────

funksjon ny_frå_katalog(katalog: tekst) -> ordbok_tekst {
    la ark = ny_zip()
    prøv {
        la data: tekst = builtin.zip_frå_katalog(katalog)
        returner builtin.json_parse(data)
    } fang (e) {
        returner ark
    }
    returner ark
}

# ─── TAR-API (same mønster som ZIP) ──────────────────────────────────────────

funksjon ny_tar() -> ordbok_tekst {
    la ark: ordbok_tekst = {}
    ark["__type__"] = "tar"
    returner ark
}

funksjon tar_legg_til(ark: ordbok_tekst, namn: tekst, innhald: tekst) -> heltall {
    returner legg_til_fil(ark, namn, innhald)
}

funksjon tar_les_fil(ark: ordbok_tekst, namn: tekst) -> tekst {
    returner les_fil(ark, namn)
}

funksjon tar_lista(ark: ordbok_tekst) -> liste_tekst {
    returner lista_filer(ark)
}

funksjon tar_skriv(ark: ordbok_tekst, sti: tekst) -> bool {
    prøv {
        la res: heltall = builtin.tar_skriv(sti, builtin.json_stringify(ark))
        returner res == 0
    } fang (e) {
        returner skriv_til_disk(ark, sti)
    }
    returner usann
}

funksjon tar_les(sti: tekst) -> ordbok_tekst {
    prøv {
        la data: tekst = builtin.tar_les(sti)
        returner builtin.json_parse(data)
    } fang (e) {
        returner les_frå_disk(sti)
    }
    returner ny_tar()
}

# ─── Arkivinfo ────────────────────────────────────────────────────────────────

funksjon er_zip(ark: ordbok_tekst) -> bool {
    returner har_nokkel(ark, "__type__") og ark["__type__"] == "zip"
}

funksjon er_tar(ark: ordbok_tekst) -> bool {
    returner har_nokkel(ark, "__type__") og ark["__type__"] == "tar"
}

funksjon total_storleik(ark: ordbok_tekst) -> heltall {
    la filer = lista_filer(ark)
    la total: heltall = 0
    la i: heltall = 0
    mens (i < lengde(filer)) {
        la innhald: tekst = les_fil(ark, filer[i])
        total = total + lengde(builtin.split(innhald, ""))
        i = i + 1
    }
    returner total
}

funksjon er_støtta() -> bool {
    prøv {
        builtin.zip_skriv("__test__.zip", "{}")
        builtin.fil_les("__test__.zip")
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# Algoritme standardbibliotek
# Klassiske algoritmar: søk, to-peikar, glidande vindauge, sortering

# ─── Søk ──────────────────────────────────────────────────────────────────────

# Binærsøk i sortert liste_heltall.
# Returnerer indeks til verdi, eller -1 viss ikkje funne.
funksjon binærsøk_tall(l: liste_heltall, verdi: heltall) -> heltall {
    la venstre: heltall = 0
    la høyre: heltall = lengde(l) - 1
    mens (venstre <= høyre) {
        la midt: heltall = venstre + (høyre - venstre) / 2
        hvis (l[midt] == verdi) { returner midt }
        hvis (l[midt] < verdi) {
            venstre = midt + 1
        } ellers {
            høyre = midt - 1
        }
    }
    returner -1
}

# Binærsøk i sortert liste_tekst.
funksjon binærsøk_tekst(l: liste_tekst, verdi: tekst) -> heltall {
    la venstre: heltall = 0
    la høyre: heltall = lengde(l) - 1
    mens (venstre <= høyre) {
        la midt: heltall = venstre + (høyre - venstre) / 2
        hvis (l[midt] == verdi) { returner midt }
        hvis (l[midt] < verdi) {
            venstre = midt + 1
        } ellers {
            høyre = midt - 1
        }
    }
    returner -1
}

# Finn første posisjon der l[i] >= verdi (lower_bound)
funksjon nedre_grense(l: liste_heltall, verdi: heltall) -> heltall {
    la venstre: heltall = 0
    la høyre: heltall = lengde(l)
    mens (venstre < høyre) {
        la midt: heltall = venstre + (høyre - venstre) / 2
        hvis (l[midt] < verdi) {
            venstre = midt + 1
        } ellers {
            høyre = midt
        }
    }
    returner venstre
}

# Finn første posisjon der l[i] > verdi (upper_bound)
funksjon øvre_grense(l: liste_heltall, verdi: heltall) -> heltall {
    la venstre: heltall = 0
    la høyre: heltall = lengde(l)
    mens (venstre < høyre) {
        la midt: heltall = venstre + (høyre - venstre) / 2
        hvis (l[midt] <= verdi) {
            venstre = midt + 1
        } ellers {
            høyre = midt
        }
    }
    returner venstre
}

# ─── To-peikar ────────────────────────────────────────────────────────────────

# Finn par (i, j) i sortert liste der l[i] + l[j] == målsum.
# Returnerer [i, j] eller [-1, -1] viss ikkje funne.
funksjon to_sum(l: liste_heltall, mål: heltall) -> liste_heltall {
    la venstre: heltall = 0
    la høyre: heltall = lengde(l) - 1
    mens (venstre < høyre) {
        la sum: heltall = l[venstre] + l[høyre]
        hvis (sum == mål) {
            la resultat: liste_heltall = []
            legg_til(resultat, venstre)
            legg_til(resultat, høyre)
            returner resultat
        }
        hvis (sum < mål) {
            venstre = venstre + 1
        } ellers {
            høyre = høyre - 1
        }
    }
    la ingen: liste_heltall = []
    legg_til(ingen, -1)
    legg_til(ingen, -1)
    returner ingen
}

# Er lista palindrom?
funksjon er_palindrom_tall(l: liste_heltall) -> bool {
    la venstre: heltall = 0
    la høyre: heltall = lengde(l) - 1
    mens (venstre < høyre) {
        hvis (l[venstre] != l[høyre]) { returner usann }
        venstre = venstre + 1
        høyre = høyre - 1
    }
    returner sann
}

funksjon er_palindrom_tekst(tekstverdi: tekst) -> bool {
    la tegn = builtin.split(tekstverdi, "")
    la venstre: heltall = 0
    la høyre: heltall = lengde(tegn) - 1
    mens (venstre < høyre) {
        hvis (tegn[venstre] != tegn[høyre]) { returner usann }
        venstre = venstre + 1
        høyre = høyre - 1
    }
    returner sann
}

# ─── Glidande vindauge (sliding window) ──────────────────────────────────────

# Maksimal sum av eit vindauge med breidd k
funksjon maks_vindauge_sum(l: liste_heltall, k: heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0 eller k <= 0 eller k > n) { returner 0 }
    # Bygg første vindauge
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < k) {
        sum = sum + l[i]
        i = i + 1
    }
    la best: heltall = sum
    # Glid
    la j: heltall = k
    mens (j < n) {
        sum = sum + l[j] - l[j - k]
        hvis (sum > best) { best = sum }
        j = j + 1
    }
    returner best
}

# Minimum lengde på samanhengande delsekvens med sum >= mål (0 = ikkje funne)
funksjon min_lengde_sum(l: liste_heltall, mål: heltall) -> heltall {
    la n: heltall = lengde(l)
    la beste: heltall = n + 1
    la sum: heltall = 0
    la venstre: heltall = 0
    la høyre: heltall = 0
    mens (høyre < n) {
        sum = sum + l[høyre]
        mens (sum >= mål) {
            la lengde_no: heltall = høyre - venstre + 1
            hvis (lengde_no < beste) { beste = lengde_no }
            sum = sum - l[venstre]
            venstre = venstre + 1
        }
        høyre = høyre + 1
    }
    hvis (beste == n + 1) { returner 0 }
    returner beste
}

# ─── Sortering ────────────────────────────────────────────────────────────────

# Innsettingssortering — stabil, god på nesten-sorterte lister
funksjon innsettingssort(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    la i: heltall = 1
    mens (i < n) {
        la nøkkel: heltall = l[i]
        la j: heltall = i - 1
        mens (j >= 0 og l[j] > nøkkel) {
            l[j + 1] = l[j]
            j = j - 1
        }
        l[j + 1] = nøkkel
        i = i + 1
    }
    returner lengde(l)
}

# Utvalgssortering
funksjon utvalgsort(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    la i: heltall = 0
    mens (i < n - 1) {
        la min_i: heltall = i
        la j: heltall = i + 1
        mens (j < n) {
            hvis (l[j] < l[min_i]) { min_i = j }
            j = j + 1
        }
        la tmp: heltall = l[i]
        l[i] = l[min_i]
        l[min_i] = tmp
        i = i + 1
    }
    returner lengde(l)
}

# ─── Prefiks-sum ──────────────────────────────────────────────────────────────

# Bygg prefiks-sum-liste (Python: itertools.accumulate)
funksjon prefiks_sum(l: liste_heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < lengde(l)) {
        sum = sum + l[i]
        legg_til(resultat, sum)
        i = i + 1
    }
    returner resultat
}

# Sum av delsekvens [frå, slutt] med prefiks-sum-liste
funksjon delsekvens_sum(ps: liste_heltall, frå: heltall, slutt: heltall) -> heltall {
    hvis (frå == 0) { returner ps[slutt] }
    returner ps[slutt] - ps[frå - 1]
}

# ─── Diverse ──────────────────────────────────────────────────────────────────

# Er liste sortert stigande?
funksjon er_sortert(l: liste_heltall) -> bool {
    la i: heltall = 1
    mens (i < lengde(l)) {
        hvis (l[i] < l[i - 1]) { returner usann }
        i = i + 1
    }
    returner sann
}

# Roter liste k steg til venstre
funksjon roter_venstre(l: liste_heltall, k: heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la antall: heltall = k % n
    la i: heltall = 0
    mens (i < antall) {
        la første: heltall = l[0]
        fjern_indeks(l, 0)
        legg_til(l, første)
        i = i + 1
    }
    returner n
}

# Roter liste k steg til høgre
funksjon roter_høgre(l: liste_heltall, k: heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la antall: heltall = k % n
    la i: heltall = 0
    mens (i < antall) {
        la siste: heltall = l[n - 1]
        fjern_indeks(l, n - 1)
        sett_inn(l, 0, siste)
        i = i + 1
    }
    returner n
}

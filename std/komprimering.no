# komprimering.no — Tekstkomprimering i pure Norscode
# Python: zlib, lzma, bz2 (builtin-avhengige) — her: RLE + LZ77-inspirert
#
# Bruk:
#   bruk std.komprimering som komp
#   la koda = komp.rle_kod("aaabbbcccc")     # => "3a3b4c"
#   skriv(komp.rle_dekod("3a3b4c"))          # => "aaabbbcccc"
#   la lz = komp.lz_kod("abcabcabc")
#   skriv(komp.lz_dekod(lz))                 # => "abcabcabc"

# ─── Run-Length Encoding (RLE) ────────────────────────────────────────────────
# Kodar løp av like teikn: "aaa" → "3a"
# Einskildteikn (utan løp): "b" → "b" (ikkje "1b") for lesbarheit.

funksjon rle_kod(inn: tekst) -> tekst {
    la teikn = builtin.split(inn, "")
    la n: heltall = lengde(teikn)
    hvis (n == 0) { returner "" }
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < n) {
        la c: tekst = teikn[i]
        la teller: heltall = 1
        mens (i + teller < n og teikn[i + teller] == c) {
            teller = teller + 1
        }
        hvis (teller > 1) {
            ut = ut + tekst_fra_heltall(teller) + c
        } ellers {
            ut = ut + c
        }
        i = i + teller
    }
    returner ut
}

funksjon rle_dekod(inn: tekst) -> tekst {
    la teikn = builtin.split(inn, "")
    la n: heltall = lengde(teikn)
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < n) {
        la c: tekst = teikn[i]
        # Er det eit siffer?
        la kode: heltall = builtin.char_code(c)
        hvis (kode >= 48 og kode <= 57) {
            # Les heile talet
            la tal_tekst: tekst = ""
            mens (i < n og builtin.char_code(teikn[i]) >= 48 og builtin.char_code(teikn[i]) <= 57) {
                tal_tekst = tal_tekst + teikn[i]
                i = i + 1
            }
            la antal: heltall = builtin.heltall_fra_tekst(tal_tekst)
            hvis (i < n) {
                la rep: tekst = teikn[i]
                la j: heltall = 0
                mens (j < antal) { ut = ut + rep  j = j + 1 }
                i = i + 1
            }
        } ellers {
            ut = ut + c
            i = i + 1
        }
    }
    returner ut
}

# ─── Byte-RLE (for binærlignande data representert som heltallsliste) ─────────
# rle_kod_tall: [1,1,1,2,2] → [3,1,2,2] (løplengde, verdi)

funksjon rle_kod_tall(l: liste_heltall) -> liste_heltall {
    la n: heltall = lengde(l)
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < n) {
        la v: heltall = l[i]
        la teller: heltall = 1
        mens (i + teller < n og l[i + teller] == v) { teller = teller + 1 }
        legg_til(ut, teller)
        legg_til(ut, v)
        i = i + teller
    }
    returner ut
}

funksjon rle_dekod_tall(l: liste_heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l) - 1) {
        la antal: heltall = l[i]
        la verdi: heltall = l[i + 1]
        la j: heltall = 0
        mens (j < antal) { legg_til(ut, verdi)  j = j + 1 }
        i = i + 2
    }
    returner ut
}

# ─── LZ77-inspirert komprimering ─────────────────────────────────────────────
# Forenkla: søkar i eit glidande vindauge etter den lengste matchen.
# Kodar som liste_tekst der kvart element er enten:
#   "L" (literal)  → neste element er bokstaven
#   "R" (referanse) → neste to element er [offset, lengde] som tekstar
# Returnerer liste_tekst (flat kodingssekvens)

funksjon lz_kod(inn: tekst) -> liste_tekst {
    la teikn = builtin.split(inn, "")
    la n: heltall = lengde(teikn)
    la vindauge: heltall = 255   # maks søkevindu
    la maks_match: heltall = 255

    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < n) {
        la beste_off: heltall = 0
        la beste_len: heltall = 0

        la søk_start: heltall = i - vindauge
        hvis (søk_start < 0) { søk_start = 0 }

        la j: heltall = søk_start
        mens (j < i) {
            la match_len: heltall = 0
            mens (match_len < maks_match og
                  i + match_len < n og
                  teikn[j + match_len % (i - j)] == teikn[i + match_len]) {
                match_len = match_len + 1
            }
            hvis (match_len > beste_len) {
                beste_len = match_len
                beste_off = i - j
            }
            j = j + 1
        }

        hvis (beste_len >= 3) {
            legg_til(ut, "R")
            legg_til(ut, tekst_fra_heltall(beste_off))
            legg_til(ut, tekst_fra_heltall(beste_len))
            i = i + beste_len
        } ellers {
            legg_til(ut, "L")
            legg_til(ut, teikn[i])
            i = i + 1
        }
    }
    returner ut
}

funksjon lz_dekod(koda: liste_tekst) -> tekst {
    la dekodar: liste_tekst = []
    la i: heltall = 0
    la n: heltall = lengde(koda)
    mens (i < n) {
        la type: tekst = koda[i]
        hvis (type == "L") {
            legg_til(dekodar, koda[i + 1])
            i = i + 2
        } ellers hvis (type == "R") {
            la offset: heltall = builtin.heltall_fra_tekst(koda[i + 1])
            la lengd: heltall = builtin.heltall_fra_tekst(koda[i + 2])
            la pos: heltall = lengde(dekodar) - offset
            la j: heltall = 0
            mens (j < lengd) {
                legg_til(dekodar, dekodar[pos + j % offset])
                j = j + 1
            }
            i = i + 3
        } ellers {
            i = i + 1
        }
    }
    returner builtin.join(dekodar, "")
}

# ─── Kompresjonsrate ──────────────────────────────────────────────────────────

# RLE-kompresjonsrate × 100 (e.g. 75 = 25% komprimert)
funksjon rle_rate_x100(original: tekst, koda: tekst) -> heltall {
    la orig_len: heltall = lengde(builtin.split(original, ""))
    la koda_len: heltall = lengde(builtin.split(koda, ""))
    hvis (orig_len == 0) { returner 100 }
    returner koda_len * 100 / orig_len
}

# ─── Delta-koding (for sorterte/nær-sorterte heltallslister) ─────────────────
# Kodar differansar mellom element: [10, 12, 15, 15, 20] → [10, 2, 3, 0, 5]

funksjon delta_kod(l: liste_heltall) -> liste_heltall {
    la n: heltall = lengde(l)
    la ut: liste_heltall = []
    hvis (n == 0) { returner ut }
    legg_til(ut, l[0])
    la i: heltall = 1
    mens (i < n) {
        legg_til(ut, l[i] - l[i - 1])
        i = i + 1
    }
    returner ut
}

funksjon delta_dekod(l: liste_heltall) -> liste_heltall {
    la n: heltall = lengde(l)
    la ut: liste_heltall = []
    hvis (n == 0) { returner ut }
    legg_til(ut, l[0])
    la i: heltall = 1
    mens (i < n) {
        legg_til(ut, ut[i - 1] + l[i])
        i = i + 1
    }
    returner ut
}

# ─── Zigzag-koding (for lister med blandete forteikn) ────────────────────────
# Kodar negative tal effektivt: 0→0, -1→1, 1→2, -2→3, 2→4 ...

funksjon zigzag_kod(n: heltall) -> heltall {
    hvis (n >= 0) { returner n * 2 }
    returner (0 - n) * 2 - 1
}

funksjon zigzag_dekod(n: heltall) -> heltall {
    hvis (n % 2 == 0) { returner n / 2 }
    returner 0 - (n + 1) / 2
}

funksjon zigzag_kod_liste(l: liste_heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) { legg_til(ut, zigzag_kod(l[i]))  i = i + 1 }
    returner ut
}

funksjon zigzag_dekod_liste(l: liste_heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) { legg_til(ut, zigzag_dekod(l[i]))  i = i + 1 }
    returner ut
}

        ".admin-shell { display: grid; grid-template-columns: 260px minmax(0, 1fr); gap: 1.25rem; align-items: start; }" +
        ".admin-sidebar { position: sticky; top: 1rem; }" +
        ".admin-brand { background: linear-gradient(180deg, #1a1a2e, #12182a); color: white; border-radius: 12px; padding: 1rem; margin-bottom: 1rem; box-shadow: 0 8px 24px rgba(0,0,0,.15); }" +
        ".admin-brand .kicker { display:block; font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; opacity: .72; margin-bottom: .35rem; }" +
        ".admin-brand h1 { margin: 0; font-size: 1.15rem; line-height: 1.2; }" +
        ".admin-brand p { margin: .45rem 0 0; color: rgba(255,255,255,.75); font-size: .9rem; line-height: 1.45; }" +
        ".admin-nav { display: grid; gap: .4rem; border-radius: 12px; overflow: hidden; }" +
        ".admin-nav a { background: #16213e; color: #adb5bd; padding: .7rem .9rem; border-radius: 10px; }" +
        ".admin-nav a:hover { color: white; background: #0f3460; }" +
        ".admin-card { background: white; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); padding: 1.5rem; margin-bottom: 1.5rem; }" +
        ".admin-card h2 { margin-top: 0; color: #1a1a2e; }" +
        ".admin-page-header { display:flex; justify-content:space-between; align-items:flex-start; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }" +

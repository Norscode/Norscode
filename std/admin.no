# admin.no — Auto-generert CRUD admin-panel for Norscode
# Registrer modellar og få eit fullstendig webgrensesnitt på /admin
#
# Bruk:
#   bruk std.admin som admin
#   bruk std.db som db
#   bruk std.web som web
#
#   la conn = db.open("app.db")
#
#   # Registrer modellar
#   admin.registrer(conn, "brukar",  ["id", "namn", "epost", "rolle"],    "Brukarar")
#   admin.registrer(conn, "produkt", ["id", "namn", "pris", "lager"],     "Produkt")
#
#   # Monter admin-rutene
#   funksjon admin_liste(ctx)  -> ordbok_tekst { returner admin.handle_liste(conn, ctx) }
#   funksjon admin_ny(ctx)     -> ordbok_tekst { returner admin.handle_ny(conn, ctx) }
#   funksjon admin_rediger(ctx)-> ordbok_tekst { returner admin.handle_rediger(conn, ctx) }
#   funksjon admin_lagre(ctx)  -> ordbok_tekst { returner admin.handle_lagre(conn, ctx) }
#   funksjon admin_slett(ctx)  -> ordbok_tekst { returner admin.handle_slett(conn, ctx) }
#
#   web.route("GET /admin")
#   web.route("GET /admin/{tabell}")
#   web.route("GET /admin/{tabell}/ny")
#   web.route("POST /admin/{tabell}/lagre")
#   web.route("GET /admin/{tabell}/{id}/rediger")
#   web.route("POST /admin/{tabell}/{id}/slett")

bruk std.db som db
bruk std.orm som orm
bruk std.web som web
bruk std.mal som mal
bruk std.csrf som csrf
bruk std.audit som audit

# ─── Registrering ─────────────────────────────────────────────────────────────

# Global modell-register (som ein ordbok)
funksjon _tom_register() -> ordbok_tekst {
    returner {}
}

funksjon registrer(register: ordbok_tekst, tabell: tekst, felt: liste<tekst>, visningsnamn: tekst) -> ordbok_tekst {
    hvis ikkje _admin_trygt_tabell_namn(tabell) { returner register }
    la trygge_felt: liste<tekst> = []
    la i: heiltall = 0
    mens i < lengde(felt) {
        la f: tekst = builtin.trim(felt[i])
        hvis _admin_trygt_felt_namn(f) {
            legg_til(trygge_felt, f)
        }
        i = i + 1
    }
    hvis lengde(trygge_felt) == 0 { returner register }
    la felt_str = tekst_saman(trygge_felt, ",")
    la m: ordbok_tekst = {}
    m["tabell"]      = tabell
    m["felt"]        = felt_str
    m["visningsnamn"] = visningsnamn
    register[tabell] = m
    returner register
}

# ─── Admin CSS ────────────────────────────────────────────────────────────────

funksjon _admin_css() -> tekst {
    returner "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; background: #f8f9fa; }" +
        ".admin-header { background: #1a1a2e; color: white; padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; }" +
        ".admin-header h1 { margin: 0; font-size: 1.25rem; }" +
        ".admin-nav { background: #16213e; color: #adb5bd; padding: 0.5rem 2rem; display: flex; gap: 1rem; }" +
        ".admin-nav a { color: #adb5bd; text-decoration: none; padding: 0.25rem 0.5rem; border-radius: 4px; }" +
        ".admin-nav a:hover { color: white; background: #0f3460; }" +
        ".admin-content { padding: 2rem; max-width: 1200px; margin: 0 auto; }" +
        ".admin-card { background: white; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); padding: 1.5rem; margin-bottom: 1.5rem; }" +
        ".admin-card h2 { margin-top: 0; color: #1a1a2e; }" +
        "table { width: 100%; border-collapse: collapse; }" +
        "th { background: #f1f3f5; text-align: left; padding: 0.6rem 0.75rem; font-size: .85rem; color: #495057; text-transform: uppercase; letter-spacing: .05em; }" +
        "td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #f1f3f5; font-size: .9rem; }" +
        "tr:last-child td { border-bottom: none; }" +
        "tr:hover td { background: #f8f9fa; }" +
        ".btn { display: inline-block; padding: .35rem .75rem; border-radius: 4px; font-size: .85rem; text-decoration: none; border: none; cursor: pointer; }" +
        ".btn-primary { background: #1a1a2e; color: white; }" +
        ".btn-primary:hover { background: #16213e; }" +
        ".btn-danger { background: #dc3545; color: white; }" +
        ".btn-danger:hover { background: #c82333; }" +
        ".btn-secondary { background: #6c757d; color: white; }" +
        ".badge { padding: .2rem .5rem; border-radius: 12px; font-size: .75rem; background: #e9ecef; color: #495057; }" +
        "form label { display: block; font-size: .85rem; font-weight: 600; margin-bottom: .25rem; color: #495057; }" +
        "form input, form select, form textarea { width: 100%; padding: .5rem .75rem; border: 1px solid #ced4da; border-radius: 4px; font-size: .9rem; box-sizing: border-box; margin-bottom: 1rem; }" +
        "form input:focus { outline: none; border-color: #1a1a2e; box-shadow: 0 0 0 2px rgba(26,26,46,.15); }" +
        ".admin-toolbar { margin: 1rem 0; display: flex; gap: .6rem; flex-wrap: wrap; align-items: center; }" +
        ".admin-toolbar form { margin: 0; }" +
        ".admin-toolbar label { margin-bottom: .2rem; display: block; }" +
        ".admin-toolbar .felt { margin: 0; }" +
        ".admin-toolbar .felt input, .admin-toolbar .felt select { margin-bottom: 0; min-width: 160px; }" +
        ".model-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }" +
        ".model-card { background: white; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); padding: 1.25rem; text-decoration: none; color: inherit; border: 2px solid transparent; transition: border-color .15s; }" +
        ".model-card:hover { border-color: #1a1a2e; }" +
        ".model-card .tal { font-size: 2rem; font-weight: 700; color: #1a1a2e; }" +
        ".model-card .namn { color: #6c757d; font-size: .9rem; }" +
        ".admin-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }" +
        ".admin-kpi { background: #fff; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); padding: 1rem; }" +
        ".admin-kpi .label { color: #6c757d; font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; }" +
        ".admin-kpi .value { font-size: 1.75rem; font-weight: 700; color: #1a1a2e; margin-top: .25rem; }" +
        ".empty-state { text-align: center; color: #6c757d; padding: 2rem; background: #f8f9fa; border-radius: 8px; }" +
        ".alert { padding: .75rem 1rem; border-radius: 4px; margin-bottom: 1rem; }" +
        ".alert-success { background: #d4edda; color: #155724; }" +
        ".alert-danger { background: #f8d7da; color: #721c24; }" +
        ".admin-paging { margin-top: 1rem; display: flex; gap: .5rem; align-items: center; }" +
        ".admin-paging .info { font-size: .9rem; margin-right: .5rem; color: #495057; }"
}

# ─── Sideoppsett ──────────────────────────────────────────────────────────────

funksjon _admin_side(register: ordbok_tekst, tittel: tekst, innhald: tekst) -> tekst {
    la nav_lenker = ""
    la tabellar = nøkler(register)
    la i: heltall = 0
    mens i < lengde(tabellar) {
        la t: tekst = tabellar[i]
        hvis _admin_trygt_tabell_namn(t) {
            la m = register[t]
            nav_lenker = nav_lenker + "<a href=\"" + _admin_model_url(t) + "\">" + _html_escape(m["visningsnamn"]) + "</a>"
        }
        i = i + 1
    }

    returner "<!DOCTYPE html><html lang=\"no\"><head><meta charset=\"UTF-8\">" +
        "<title>" + _html_escape(tittel) + " — Admin</title>" +
        "<style>" + _admin_css() + "</style></head><body>" +
        "<div class=\"admin-header\"><h1>⚙ Norscode Admin</h1></div>" +
        "<nav class=\"admin-nav\"><a href=\"/admin\">Oversikt</a>" + nav_lenker + "</nav>" +
        "<div class=\"admin-content\">" + innhald + "</div></body></html>"
}

funksjon _admin_headers() -> ordbok_tekst {
    returner {
        "content-type": "text/html; charset=utf-8",
        "cache-control": "no-store",
        "x-content-type-options": "nosniff",
        "x-frame-options": "DENY",
        "referrer-policy": "no-referrer",
        "strict-transport-security": "max-age=31536000; includeSubDomains",
        "content-security-policy": "default-src 'self'; script-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; base-uri 'none'; frame-ancestors 'none'; form-action 'self'",
        "permissions-policy": "geolocation=(), microphone=(), camera=()",
        "x-robots-tag": "noindex, nofollow, noarchive"
    }
}

funksjon _admin_redirect(location: tekst) -> ordbok_tekst {
    la h = _admin_headers()
    h["location"] = location
    returner web.response_builder(302, h, "")
}

# ─── Oversikts-side ───────────────────────────────────────────────────────────

funksjon handle_oversikt(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabellar = nøkler(register)
    la kortane = ""
    la total_rader: heiltall = 0
    la trygge_modellar: heiltall = 0
    la i: heltall = 0
    mens i < lengde(tabellar) {
        la t: tekst = tabellar[i]
        hvis _admin_trygt_tabell_namn(t) {
            la m = register[t]
            la tal = orm.tell(conn, t)
            trygge_modellar = trygge_modellar + 1
            total_rader = total_rader + tal
            kortane = kortane + "<a class=\"model-card\" href=\"" + _admin_model_url(t) + "\">" +
                "<div class=\"tal\">" + tekst_fra_heltall(tal) + "</div>" +
                "<div class=\"namn\">" + _html_escape(m["visningsnamn"]) + "</div></a>"
        }
        i = i + 1
    }
    la kpis = "<div class=\"admin-kpis\">" +
        "<div class=\"admin-kpi\"><div class=\"label\">Modellar</div><div class=\"value\">" + tekst_fra_heltall(trygge_modellar) + "</div></div>" +
        "<div class=\"admin-kpi\"><div class=\"label\">Rader</div><div class=\"value\">" + tekst_fra_heltall(total_rader) + "</div></div>" +
        "</div>"
    la tom = ""
    hvis trygge_modellar == 0 {
        tom = "<div class=\"empty-state\">Ingen modellar er registrert enno.</div>"
    }
    la innhald = kpis + "<div class=\"admin-card\"><h2>Modellar</h2></div>" +
        tom +
        "<div class=\"model-grid\">" + kortane + "</div>"
    la html = _admin_side(register, "Oversikt", innhald)
    returner web.response_builder(200, _admin_headers(), html)
}

# ─── Liste-side ───────────────────────────────────────────────────────────────

funksjon handle_liste(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    returner _handle_liste_med_csrf(conn, register, ctx, "")
}

funksjon handle_liste_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst {
    returner _handle_liste_med_csrf(conn, register, ctx, csrf_token)
}

funksjon _handle_liste_med_csrf(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:liste", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:liste", "Modell ikkje funne: " + tabell)
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")

    la sort = web.request_query_param(ctx, "sort")
    hvis ikkje _felt_i_liste(felt_liste, sort) { sort = "id" }

    la retning = tekst_til_store(web.request_query_param(ctx, "dir"))
    hvis retning != "ASC" og retning != "DESC" { retning = "DESC" }

    la sok = web.request_query_param(ctx, "sok")
    hvis lengde(sok) > 200 { sok = builtin.slice(sok, 0, 200) }
    la side = _query_int(ctx, "side", 1)
    la per_side = _query_int(ctx, "per_side", 20)
    hvis side < 1 { side = 1 }
    hvis side > 10000 { side = 10000 }
    hvis per_side < 1 { per_side = 20 }
    hvis per_side > 100 { per_side = 100 }

    la betingelse = _admin_bygg_filter(felt_liste, sok)
    la rader: liste<ordbok_tekst> = []
    hvis betingelse == "" {
        rader = orm.alle_sorter(conn, tabell, sort, retning)
    } ellers {
        rader = orm.filtrer_sorter(conn, tabell, betingelse, sort, retning)
    }
    la totalt: heiltall = 0
    hvis betingelse == "" {
        totalt = orm.tell(conn, tabell)
    } ellers {
        totalt = orm.tell_hvor(conn, tabell, betingelse)
    }

    la start = (side - 1) * per_side
    la slutt = start + per_side
    hvis start > lengde(rader) { start = lengde(rader) }
    hvis slutt > lengde(rader) { slutt = lengde(rader) }
    la paginerte: liste<ordbok_tekst> = []
    la i: heiltall = start
    mens i < slutt {
        legg_til(paginerte, rader[i])
        i = i + 1
    }

    la th_rader = ""
    la k: heiltall = 0
    mens k < lengde(felt_liste) {
        la felt_namn: tekst = builtin.trim(felt_liste[k])
        hvis _admin_trygt_felt_namn(felt_namn) {
            la neste_dir = "ASC"
            hvis sort == felt_namn {
                hvis retning == "ASC" {
                    neste_dir = "DESC"
                } ellers {
                    neste_dir = "ASC"
                }
            }
            la sort_link = _admin_query(tabell, sok, felt_namn, neste_dir, 1, per_side, "side")
            th_rader = th_rader + "<th><a href=\"" + sort_link + "\">" + _html_escape(felt_namn) + "</a></th>"
        }
        k = k + 1
    }
    th_rader = th_rader + "<th>Handlingar</th>"

    la td_rader = ""
    la j: heiltall = 0
    mens j < lengde(paginerte) {
        la rad = paginerte[j]
        la rad_id: tekst = rad["id"]
        la td = ""
        la f: heiltall = 0
        mens f < lengde(felt_liste) {
            la felt_namn: tekst = builtin.trim(felt_liste[f])
            hvis _admin_trygt_felt_namn(felt_namn) {
                la verdi = ""
                hvis har_nokkel(rad, felt_namn) { verdi = rad[felt_namn] }
                hvis lengde(verdi) > 40 { verdi = builtin.slice(verdi, 0, 40) + "…" }
                td = td + "<td>" + _html_escape(verdi) + "</td>"
            }
            f = f + 1
        }
        td = td + "<td><a class=\"btn btn-secondary\" href=\"" + _admin_row_url(tabell, rad_id, "/rediger") + "\">Rediger</a>" +
            "<form method=\"POST\" action=\"" + _admin_row_url(tabell, rad_id, "/slett") + "\" style=\"display:inline\" autocomplete=\"off\">" +
            csrf_input(csrf_token) +
            admin_bekreft_slett_input() +
            "<button class=\"btn btn-danger\" type=\"submit\" title=\"Slett rad\">Slett</button></form></td>"
        td_rader = td_rader + "<tr>" + td + "</tr>"
        j = j + 1
    }
    hvis lengde(paginerte) == 0 {
        td_rader = "<tr><td colspan=\"" + tekst_fra_heltall(_admin_trygge_felt_tal(felt_liste) + 1) + "\"><div class=\"empty-state\">Ingen rader funne.</div></td></tr>"
    }

    la sorterings_form = _admin_sorteringskontroll(tabell, felt_liste, sort, retning, sok, per_side)
    la sok_skjulte = _admin_sok_skjulte_felt(sort, retning, per_side)
    la pagering = _admin_paginering(tabell, sok, sort, retning, side, per_side, totalt)
    la status_html = _admin_statusmelding(ctx)

    la innhald = status_html + "<div class=\"admin-card\">" +
        "<div style=\"display:flex;justify-content:space-between;align-items:center\">" +
        "<h2>" + _html_escape(m["visningsnamn"]) + " <span class=\"badge\">" + tekst_fra_heltall(totalt) + " rader</span></h2>" +
        "<a class=\"btn btn-primary\" href=\"" + _admin_model_url(tabell) + "/ny\">+ Ny</a></div>" +
        "<div class=\"admin-toolbar\"><form method=\"GET\" action=\"" + _admin_model_url(tabell) + "\" class=\"felt\" autocomplete=\"off\">" +
        sok_skjulte +
        "<label>Søk</label><input name=\"sok\" value=\"" + _html_escape(sok) + "\" placeholder=\"Søk i alle tekstfelt\" autocomplete=\"off\">" +
        "<button class=\"btn btn-secondary\" type=\"submit\">Filtrer</button></form>" + sorterings_form + "</div>" +
        "<table><thead><tr>" + th_rader + "</tr></thead><tbody>" + td_rader + "</tbody></table>" +
        pagering + "</div>"

    la html = _admin_side(register, m["visningsnamn"], innhald)
    returner web.response_builder(200, _admin_headers(), html)
}

# ─── Ny-skjema ────────────────────────────────────────────────────────────────

funksjon handle_ny(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:ny", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:ny", "Modell ikkje funne: " + tabell)
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la form_felt = _bygg_skjema_felt(felt_liste, {})

    la innhald = "<div class=\"admin-card\"><h2>Ny " + _html_escape(m["visningsnamn"]) + "</h2>" +
        "<form method=\"POST\" action=\"" + _admin_model_url(tabell) + "/lagre\" autocomplete=\"off\">" +
        form_felt +
        "<button class=\"btn btn-primary\" type=\"submit\">Lagre</button>" +
        "<a class=\"btn btn-secondary\" href=\"" + _admin_model_url(tabell) + "\">Avbryt</a></form></div>"

    la html = _admin_side(register, "Ny " + m["visningsnamn"], innhald)
    returner web.response_builder(200, _admin_headers(), html)
}

funksjon handle_ny_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:ny_sikker", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:ny_sikker", "Modell ikkje funne: " + tabell)
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la form_felt = _bygg_skjema_felt_med_csrf(felt_liste, {}, csrf_token)

    la innhald = "<div class=\"admin-card\"><h2>Ny " + _html_escape(m["visningsnamn"]) + "</h2>" +
        "<form method=\"POST\" action=\"" + _admin_model_url(tabell) + "/lagre\" autocomplete=\"off\">" +
        form_felt +
        "<button class=\"btn btn-primary\" type=\"submit\">Lagre</button>" +
        "<a class=\"btn btn-secondary\" href=\"" + _admin_model_url(tabell) + "\">Avbryt</a></form></div>"

    la html = _admin_side(register, "Ny " + m["visningsnamn"], innhald)
    returner web.response_builder(200, _admin_headers(), html)
}

# ─── Rediger-skjema ───────────────────────────────────────────────────────────

funksjon handle_rediger(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la rad_id_str = web.request_param(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:rediger", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:rediger", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_rad_id(rad_id_str) {
        returner _admin_not_found_med_audit(ctx, "row_id:rediger", "Rad ikkje funne")
    }
    la id = heltall_fra_tekst(rad_id_str)
    la rad = orm.finn(conn, tabell, id)
    hvis ikkje har_nokkel(rad, "id") {
        returner _admin_not_found_med_audit(ctx, "row:rediger", "Rad ikkje funne")
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la form_felt = _bygg_skjema_felt(felt_liste, rad)

    la innhald = "<div class=\"admin-card\"><h2>Rediger " + _html_escape(m["visningsnamn"]) + " #" + tekst_fra_heltall(id) + "</h2>" +
        "<form method=\"POST\" action=\"" + _admin_row_url(tabell, tekst_fra_heltall(id), "/lagre") + "\" autocomplete=\"off\">" +
        form_felt +
        "<button class=\"btn btn-primary\" type=\"submit\">Lagre endringar</button>" +
        "<a class=\"btn btn-secondary\" href=\"" + _admin_model_url(tabell) + "\">Avbryt</a></form></div>"

    la html = _admin_side(register, "Rediger " + m["visningsnamn"], innhald)
    returner web.response_builder(200, _admin_headers(), html)
}

funksjon handle_rediger_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la rad_id_str = web.request_param(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:rediger_sikker", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:rediger_sikker", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_rad_id(rad_id_str) {
        returner _admin_not_found_med_audit(ctx, "row_id:rediger_sikker", "Rad ikkje funne")
    }
    la id = heltall_fra_tekst(rad_id_str)
    la rad = orm.finn(conn, tabell, id)
    hvis ikkje har_nokkel(rad, "id") {
        returner _admin_not_found_med_audit(ctx, "row:rediger_sikker", "Rad ikkje funne")
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la form_felt = _bygg_skjema_felt_med_csrf(felt_liste, rad, csrf_token)

    la innhald = "<div class=\"admin-card\"><h2>Rediger " + _html_escape(m["visningsnamn"]) + " #" + tekst_fra_heltall(id) + "</h2>" +
        "<form method=\"POST\" action=\"" + _admin_row_url(tabell, tekst_fra_heltall(id), "/lagre") + "\" autocomplete=\"off\">" +
        form_felt +
        "<button class=\"btn btn-primary\" type=\"submit\">Lagre endringar</button>" +
        "<a class=\"btn btn-secondary\" href=\"" + _admin_model_url(tabell) + "\">Avbryt</a></form></div>"

    la html = _admin_side(register, "Rediger " + m["visningsnamn"], innhald)
    returner web.response_builder(200, _admin_headers(), html)
}

# ─── Lagre (POST) ─────────────────────────────────────────────────────────────

funksjon handle_lagre(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la rad_id_str = web.request_param(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:lagre", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:lagre", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_body_ok(ctx) {
        audit.emit(admin_lagre_feil_audit(ctx, tabell, rad_id_str))
        returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?feil=lagring")
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")

    // Hent form-data frå body (application/x-www-form-urlencoded eller JSON)
    la data = _parse_form_body(web.request_body(ctx))

    // Fjern "id"-felt frå data (auto-generert)
    la utan_id: ordbok_tekst = {}
    la i: heltall = 0
    mens i < lengde(felt_liste) {
        la f: tekst = builtin.trim(felt_liste[i])
        hvis f != "id" og _admin_trygt_felt_namn(f) og har_nokkel(data, f) {
            utan_id[f] = data[f]
        }
        i = i + 1
    }

    prøv {
        hvis rad_id_str != "" og rad_id_str != "ny" {
            hvis ikkje _admin_trygt_rad_id(rad_id_str) {
                returner _admin_not_found_med_audit(ctx, "row_id:lagre", "Rad ikkje funne")
            }
            la id = heltall_fra_tekst(rad_id_str)
            orm.oppdater(conn, tabell, id, utan_id)
        } ellers {
            orm.lagre(conn, tabell, utan_id)
        }
    } fang (e) {
        audit.emit(admin_lagre_feil_audit(ctx, tabell, rad_id_str))
        returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?feil=lagring")
    }

    audit.emit(admin_lagre_audit(ctx, tabell, rad_id_str))
    returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?ok=lagra")
}

funksjon handle_lagre_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst {
    hvis ikkje _admin_body_ok(ctx) {
        audit.emit(admin_forbidden_audit(ctx, "body:lagre"))
        returner _admin_forbidden("Admin-skjemaet er for stort")
    }
    hvis ikkje _admin_csrf_ok(ctx, csrf_token) {
        audit.emit(admin_forbidden_audit(ctx, "csrf:lagre"))
        returner _admin_forbidden("Ugyldig admin CSRF-token")
    }
    returner handle_lagre(conn, register, ctx)
}

# ─── Slett (POST) ─────────────────────────────────────────────────────────────

funksjon handle_slett(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la rad_id_str = web.request_param(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner _admin_not_found_med_audit(ctx, "model:slett", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_tabell_namn(tabell) {
        returner _admin_not_found_med_audit(ctx, "table:slett", "Modell ikkje funne: " + tabell)
    }
    hvis ikkje _admin_trygt_rad_id(rad_id_str) {
        returner _admin_not_found_med_audit(ctx, "row_id:slett", "Rad ikkje funne")
    }
    la id = heltall_fra_tekst(rad_id_str)
    hvis ikkje _admin_body_ok(ctx) {
        audit.emit(admin_forbidden_audit(ctx, "body:slett"))
        returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?feil=slett")
    }
    hvis ikkje _admin_slett_bekrefta(ctx) {
        audit.emit(admin_forbidden_audit(ctx, "delete_intent:slett"))
        returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?feil=slett")
    }
    prøv {
        orm.slett(conn, tabell, id)
    } fang (e) {
        audit.emit(admin_slett_feil_audit(ctx, tabell, id))
        returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?feil=slett")
    }
    audit.emit(admin_slett_audit(ctx, tabell, id))
    returner _admin_redirect(_admin_model_url(_redirect_safe(tabell)) + "?ok=sletta")
}

funksjon handle_slett_sikker(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst, csrf_token: tekst) -> ordbok_tekst {
    hvis ikkje _admin_body_ok(ctx) {
        audit.emit(admin_forbidden_audit(ctx, "body:slett"))
        returner _admin_forbidden("Admin-skjemaet er for stort")
    }
    hvis ikkje _admin_csrf_ok(ctx, csrf_token) {
        audit.emit(admin_forbidden_audit(ctx, "csrf:slett"))
        returner _admin_forbidden("Ugyldig admin CSRF-token")
    }
    returner handle_slett(conn, register, ctx)
}

funksjon admin_status(register: ordbok_tekst) -> ordbok_tekst {
    returner {
        modul: "std.admin",
        modellar: tekst_fra_heltall(_admin_trygge_modellar_tal(register)),
        headers: "no-store,nosniff,deny,no-referrer,csp,hsts,permissions,noindex",
        csrf: "handle_ny_sikker,handle_rediger_sikker,handle_lagre_sikker,handle_slett_sikker",
        delete_intent: "admin_bekreft_slett_input,_admin_slett_bekrefta",
        audit: "admin_lagre_audit,admin_lagre_feil_audit,admin_slett_audit,admin_slett_feil_audit,admin_forbidden_audit,admin_not_found_audit",
        audit_success: "create,update,delete",
        audit_failure: "create,update,delete",
        audit_rejection: "csrf,delete_intent",
        audit_probe: "not_found_model,not_found_row",
        search_limit: "200",
        table_names: "safe_ascii",
        field_names: "safe_ascii",
        field_write: "safe_ascii",
        registration_guard: "safe_ascii",
        row_ids: "positive_integer",
        body_limit: "65536",
        audit_values: "max_200",
        page_limit: "10000",
        autocomplete: "off",
        empty_state: "sann",
        kpi: "sann"
    }
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _bygg_skjema_felt(felt_liste: liste<tekst>, verdiar: ordbok_tekst) -> tekst {
    la html = ""
    la i: heltall = 0
    mens i < lengde(felt_liste) {
        la f: tekst = builtin.trim(felt_liste[i])
        la verdi = ""
        hvis har_nokkel(verdiar, f) { verdi = verdiar[f] }
        // Ikkje vis id-felt (auto-generert)
        hvis f == "id" {
            html = html + "<input type=\"hidden\" name=\"id\" value=\"" + _html_escape(verdi) + "\">"
        } ellers hvis _admin_trygt_felt_namn(f) {
            html = html + "<label>" + _html_escape(f) + "</label>
<input type=\"text\" name=\"" + _html_escape(f) + "\" value=\"" + _html_escape(verdi) + "\" autocomplete=\"off\">
"
        }
        i = i + 1
    }
    returner html
}

funksjon _bygg_skjema_felt_med_csrf(felt_liste: liste<tekst>, verdiar: ordbok_tekst, csrf_token: tekst) -> tekst {
    returner csrf_input(csrf_token) + _bygg_skjema_felt(felt_liste, verdiar)
}

funksjon csrf_input(csrf_token: tekst) -> tekst {
    hvis csrf_token == "" { returner "" }
    returner "<input type=\"hidden\" name=\"" + csrf.felt_namn() + "\" value=\"" + _html_escape(csrf_token) + "\">"
}

funksjon admin_bekreft_slett_input() -> tekst {
    returner "<input type=\"hidden\" name=\"admin_bekreft_slett\" value=\"sann\">"
}

funksjon _admin_forbidden(melding: tekst) -> ordbok_tekst {
    la html = _admin_side({}, "Forbode", "<div class=\"admin-card\"><div class=\"alert alert-danger\">" + _html_escape(melding) + "</div></div>")
    returner web.response_builder(403, _admin_headers(), html)
}

funksjon _admin_not_found(melding: tekst) -> ordbok_tekst {
    la html = _admin_side({}, "Ikkje funne", "<div class=\"admin-card\"><div class=\"alert alert-danger\">" + _html_escape(melding) + "</div></div>")
    returner web.response_builder(404, _admin_headers(), html)
}

funksjon _admin_not_found_med_audit(ctx: ordbok_tekst, grunn: tekst, melding: tekst) -> ordbok_tekst {
    audit.emit(admin_not_found_audit(ctx, grunn))
    returner _admin_not_found(melding)
}

funksjon _admin_aktor(ctx: ordbok_tekst) -> tekst {
    la user = web.request_header(ctx, "x-user")
    hvis user != "" { returner _admin_audit_tekst(user) }
    user = web.request_header(ctx, "x-admin-user")
    hvis user != "" { returner _admin_audit_tekst(user) }
    returner "ukjent"
}

funksjon admin_lagre_audit(ctx: ordbok_tekst, tabell: tekst, rad_id: tekst) -> ordbok_tekst {
    la handling = "admin_create"
    hvis rad_id != "" og rad_id != "ny" {
        handling = "admin_update"
    }
    la e = audit.opprett(handling, "registrert")
    audit.felt_tekst(e, "actor", _admin_aktor(ctx))
    audit.felt_tekst(e, "table", _admin_audit_tekst(tabell))
    audit.felt_tekst(e, "row_id", _admin_audit_tekst(rad_id))
    audit.felt_tekst(e, "request_id", _admin_audit_tekst(web.request_id(ctx)))
    returner e
}

funksjon admin_lagre_feil_audit(ctx: ordbok_tekst, tabell: tekst, rad_id: tekst) -> ordbok_tekst {
    la handling = "admin_create"
    hvis rad_id != "" og rad_id != "ny" {
        handling = "admin_update"
    }
    la e = audit.opprett(handling, "feilet")
    audit.felt_tekst(e, "actor", _admin_aktor(ctx))
    audit.felt_tekst(e, "table", _admin_audit_tekst(tabell))
    audit.felt_tekst(e, "row_id", _admin_audit_tekst(rad_id))
    audit.felt_tekst(e, "request_id", _admin_audit_tekst(web.request_id(ctx)))
    returner e
}

funksjon admin_slett_audit(ctx: ordbok_tekst, tabell: tekst, id: heltall) -> ordbok_tekst {
    la e = audit.opprett("admin_delete", "registrert")
    audit.felt_tekst(e, "actor", _admin_aktor(ctx))
    audit.felt_tekst(e, "table", _admin_audit_tekst(tabell))
    audit.felt_tall(e, "row_id", id)
    audit.felt_tekst(e, "request_id", _admin_audit_tekst(web.request_id(ctx)))
    returner e
}

funksjon admin_slett_feil_audit(ctx: ordbok_tekst, tabell: tekst, id: heltall) -> ordbok_tekst {
    la e = audit.opprett("admin_delete", "feilet")
    audit.felt_tekst(e, "actor", _admin_aktor(ctx))
    audit.felt_tekst(e, "table", _admin_audit_tekst(tabell))
    audit.felt_tall(e, "row_id", id)
    audit.felt_tekst(e, "request_id", _admin_audit_tekst(web.request_id(ctx)))
    returner e
}

funksjon admin_forbidden_audit(ctx: ordbok_tekst, grunn: tekst) -> ordbok_tekst {
    la e = audit.opprett("admin_forbidden", "avvist")
    audit.felt_tekst(e, "actor", _admin_aktor(ctx))
    audit.felt_tekst(e, "reason", _admin_audit_tekst(grunn))
    audit.felt_tekst(e, "request_id", _admin_audit_tekst(web.request_id(ctx)))
    returner e
}

funksjon admin_not_found_audit(ctx: ordbok_tekst, grunn: tekst) -> ordbok_tekst {
    la e = audit.opprett("admin_not_found", "avvist")
    audit.felt_tekst(e, "actor", _admin_aktor(ctx))
    audit.felt_tekst(e, "reason", _admin_audit_tekst(grunn))
    audit.felt_tekst(e, "table", _admin_audit_tekst(web.request_param(ctx, "tabell")))
    audit.felt_tekst(e, "row_id", _admin_audit_tekst(web.request_param(ctx, "id")))
    audit.felt_tekst(e, "request_id", _admin_audit_tekst(web.request_id(ctx)))
    returner e
}

funksjon _admin_statusmelding(ctx: ordbok_tekst) -> tekst {
    la ok = web.request_query_param(ctx, "ok")
    hvis ok == "lagra" {
        returner "<div class=\"alert alert-success\" role=\"status\">Endringane er lagra.</div>"
    }
    hvis ok == "sletta" {
        returner "<div class=\"alert alert-success\" role=\"status\">Rada er sletta.</div>"
    }
    la feil = web.request_query_param(ctx, "feil")
    hvis feil == "lagring" {
        returner "<div class=\"alert alert-danger\" role=\"alert\">Kunne ikkje lagre endringane.</div>"
    }
    hvis feil == "slett" {
        returner "<div class=\"alert alert-danger\" role=\"alert\">Sletting vart avvist fordi bekrefting mangla.</div>"
    }
    hvis feil != "" {
        returner "<div class=\"alert alert-danger\" role=\"alert\">" + _admin_feilmelding(feil) + "</div>"
    }
    returner ""
}

funksjon _admin_feilmelding(kode: tekst) -> tekst {
    hvis kode == "csrf" { returner "Ugyldig tryggleikstoken." }
    hvis kode == "tilgang" { returner "Du har ikkje tilgang til admin-handlinga." }
    hvis kode == "lagring" { returner "Kunne ikkje lagre endringane." }
    hvis kode == "slett" { returner "Sletting vart avvist." }
    returner "Ukjend admin-feil."
}

funksjon _admin_slett_bekrefta(ctx: ordbok_tekst) -> bool {
    hvis ikkje _admin_body_ok(ctx) { returner usann }
    la data = _parse_form_body(web.request_body(ctx))
    hvis ikkje har_nokkel(data, "admin_bekreft_slett") { returner usann }
    returner data["admin_bekreft_slett"] == "sann"
}

funksjon _admin_csrf_ok(ctx: ordbok_tekst, csrf_token: tekst) -> bool {
    hvis csrf.require(ctx, csrf_token) { returner sann }
    hvis csrf_token == "" { returner usann }
    hvis ikkje _admin_body_ok(ctx) { returner usann }
    la data = _parse_form_body(web.request_body(ctx))
    hvis ikkje har_nokkel(data, csrf.felt_namn()) { returner usann }
    returner csrf.konstant_lik(data[csrf.felt_namn()], csrf_token)
}

funksjon _admin_sorteringskontroll(tabell: tekst, felt_liste: liste<tekst>, sort: tekst, retning: tekst, sok: tekst, per_side: heiltall) -> tekst {
    la opsjonar = ""
    la i: heiltall = 0
    mens i < lengde(felt_liste) {
        la f: tekst = builtin.trim(felt_liste[i])
        hvis f != "id" og _admin_trygt_felt_namn(f) {
            la valgt = ""
            hvis sort == f {
                valgt = "selected"
            }
            opsjonar = opsjonar + "<option value=\"" + _html_escape(f) + "\" " + valgt + ">" + _html_escape(f) + "</option>"
        }
        i = i + 1
    }

    la asc = ""
    la desc = ""
    hvis retning == "ASC" {
        asc = "selected"
    }
    hvis retning == "DESC" {
        desc = "selected"
    }
    la skjulte = ""
    hvis sok != "" {
        skjulte = skjulte + "<input type=\"hidden\" name=\"sok\" value=\"" + _html_escape(sok) + "\">"
    }
    hvis per_side > 0 {
        skjulte = skjulte + "<input type=\"hidden\" name=\"per_side\" value=\"" + tekst_fra_heltall(per_side) + "\">"
    }

    returner "<form method=\"GET\" action=\"" + _admin_model_url(tabell) + "\" class=\"felt\" autocomplete=\"off\">" +
        skjulte +
        "<label>Sortering</label><select name=\"sort\">" + opsjonar + "</select>" +
        "<select name=\"dir\"><option value=\"ASC\" " + asc + ">A-Å</option>" +
        "<option value=\"DESC\" " + desc + ">Å-A</option></select>" +
        "<button class=\"btn btn-secondary\" type=\"submit\">Sorter</button></form>"
}

funksjon _admin_sok_skjulte_felt(sort: tekst, retning: tekst, per_side: heiltall) -> tekst {
    la skjulte = ""
    hvis sort != "" {
        skjulte = skjulte + "<input type=\"hidden\" name=\"sort\" value=\"" + _html_escape(sort) + "\">"
    }
    hvis retning != "" {
        skjulte = skjulte + "<input type=\"hidden\" name=\"dir\" value=\"" + _html_escape(retning) + "\">"
    }
    hvis per_side > 0 {
        skjulte = skjulte + "<input type=\"hidden\" name=\"per_side\" value=\"" + tekst_fra_heltall(per_side) + "\">"
    }
    returner skjulte
}

funksjon _admin_paginering(tabell: tekst, sok: tekst, sort: tekst, retning: tekst, side: heiltall, per_side: heiltall, totalt: heiltall) -> tekst {
    la sider = 1
    hvis totalt > 0 {
        sider = (totalt + per_side - 1) / per_side
    }
    hvis sider < 1 { sider = 1 }

    la framside = ""
    la bakside = ""
    hvis side > 1 {
        la prev = side - 1
        la prev_lenkje = _admin_query(tabell, sok, sort, retning, prev, per_side, "side")
        framside = "<a class=\"btn btn-secondary\" href=\"" + prev_lenkje + "\">Forrige</a>"
    }
    hvis side < sider {
        la nxt = side + 1
        la next_lenkje = _admin_query(tabell, sok, sort, retning, nxt, per_side, "side")
        bakside = "<a class=\"btn btn-secondary\" href=\"" + next_lenkje + "\">Neste</a>"
    }

    returner "<div class=\"admin-paging\"><span class=\"info\">Side " + tekst_fra_heltall(side) +
        " av " + tekst_fra_heltall(sider) + "</span>" + framside + " " + bakside + "</div>"
}

funksjon _admin_query(tabell: tekst, sok: tekst, sort: tekst, retning: tekst, side: heiltall, per_side: heiltall, side_nokkel: tekst) -> tekst {
    la del: liste<tekst> = []
    hvis sok != "" { legg_til(del, "sok=" + _url_query_escape(sok)) }
    hvis sort != "" { legg_til(del, "sort=" + _url_query_escape(sort)) }
    hvis retning != "" { legg_til(del, "dir=" + _url_query_escape(retning)) }
    hvis per_side > 0 { legg_til(del, "per_side=" + tekst_fra_heltall(per_side)) }
    hvis side > 1 { legg_til(del, _url_query_escape(side_nokkel) + "=" + tekst_fra_heltall(side)) }
    hvis lengde(del) == 0 { returner _admin_model_url(tabell) }
    returner _admin_model_url(tabell) + "?" + tekst_saman(del, "&")
}

funksjon _admin_model_url(tabell: tekst) -> tekst {
    returner "/admin/" + _url_path_escape(tabell)
}

funksjon _admin_row_url(tabell: tekst, rad_id: tekst, suffiks: tekst) -> tekst {
    returner _admin_model_url(tabell) + "/" + _url_path_escape(rad_id) + suffiks
}

funksjon _url_query_escape(s: tekst) -> tekst {
    la r = tekst_erstatt(s, "%", "%25")
    r = tekst_erstatt(r, " ", "%20")
    r = tekst_erstatt(r, "&", "%26")
    r = tekst_erstatt(r, "=", "%3D")
    r = tekst_erstatt(r, "\"", "%22")
    r = tekst_erstatt(r, "'", "%27")
    r = tekst_erstatt(r, "<", "%3C")
    r = tekst_erstatt(r, ">", "%3E")
    r = tekst_erstatt(r, "#", "%23")
    r = tekst_erstatt(r, "?", "%3F")
    returner r
}

funksjon _url_path_escape(s: tekst) -> tekst {
    la r = _url_query_escape(s)
    r = tekst_erstatt(r, "/", "%2F")
    r = tekst_erstatt(r, "\\", "%5C")
    returner r
}

funksjon _admin_trygt_felt_namn(felt: tekst) -> boolsk {
    hvis felt == "" { returner usann }
    la tillatne = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
    la i: heiltall = 0
    mens i < lengde(felt) {
        la teikn = builtin.slice(felt, i, i + 1)
        hvis builtin.index_of(tillatne, teikn) < 0 { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon _admin_trygt_tabell_namn(tabell: tekst) -> boolsk {
    returner _admin_trygt_felt_namn(tabell)
}

funksjon _admin_trygt_rad_id(rad_id: tekst) -> boolsk {
    hvis rad_id == "" { returner usann }
    la tillatne = "0123456789"
    la i: heiltall = 0
    mens i < lengde(rad_id) {
        la teikn = builtin.slice(rad_id, i, i + 1)
        hvis builtin.index_of(tillatne, teikn) < 0 { returner usann }
        i = i + 1
    }
    prøv {
        returner heltall_fra_tekst(rad_id) > 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon _admin_body_ok(ctx: ordbok_tekst) -> boolsk {
    returner lengde(web.request_body(ctx)) <= 65536
}

funksjon _admin_audit_tekst(verdi: tekst) -> tekst {
    hvis lengde(verdi) > 200 {
        returner builtin.slice(verdi, 0, 200)
    }
    returner verdi
}

funksjon _admin_trygge_modellar_tal(register: ordbok_tekst) -> heiltall {
    la tabellar = nøkler(register)
    la tal: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(tabellar) {
        hvis _admin_trygt_tabell_namn(tabellar[i]) {
            tal = tal + 1
        }
        i = i + 1
    }
    returner tal
}

funksjon _admin_trygge_felt_tal(felt_liste: liste<tekst>) -> heiltall {
    la tal: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(felt_liste) {
        hvis _admin_trygt_felt_namn(builtin.trim(felt_liste[i])) {
            tal = tal + 1
        }
        i = i + 1
    }
    returner tal
}

funksjon _admin_bygg_filter(felt_liste: liste<tekst>, sok: tekst) -> tekst {
    hvis sok == "" { returner "" }
    la vilkår: liste<tekst> = []
    la i: heiltall = 0
    mens i < lengde(felt_liste) {
        la f: tekst = builtin.trim(felt_liste[i])
        hvis f != "id" og _admin_trygt_felt_namn(f) {
            legg_til(vilkår, f + " LIKE '%" + orm._escape(sok) + "%'")
        }
        i = i + 1
    }
    hvis lengde(vilkår) == 0 { returner "" }
    returner "(" + tekst_saman(vilkår, " OR ") + ")"
}

funksjon _html_escape(s: tekst) -> tekst {
    la r = tekst_erstatt(s, "&", "&amp;")
    r = tekst_erstatt(r, "<", "&lt;")
    r = tekst_erstatt(r, ">", "&gt;")
    r = tekst_erstatt(r, "\"", "&quot;")
    r = tekst_erstatt(r, "'", "&#39;")
    returner r
}

funksjon _redirect_safe(s: tekst) -> tekst {
    la r = tekst_erstatt(s, "/", "")
    r = tekst_erstatt(r, "\\", "")
    r = tekst_erstatt(r, "?", "")
    r = tekst_erstatt(r, "#", "")
    r = tekst_erstatt(r, "&", "")
    returner r
}

funksjon _felt_i_liste(felt_liste: liste<tekst>, felt: tekst) -> boolsk {
    hvis ikkje _admin_trygt_felt_namn(felt) { returner usann }
    la i: heiltall = 0
    mens i < lengde(felt_liste) {
        la f = builtin.trim(felt_liste[i])
        hvis _admin_trygt_felt_namn(f) og f == felt { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon _query_int(ctx: ordbok_tekst, nøkkel: tekst, standard: heiltall) -> heiltall {
    la v = web.request_query_param(ctx, nøkkel)
    hvis v == "" { returner standard }
    prøv { returner heiltall_fra_tekst(v) } fang (e) { returner standard }
    returner standard
}

funksjon _parse_form_body(body: tekst) -> ordbok_tekst {
    la data: ordbok_tekst = {}
    // Prøv JSON
    prøv {
        la parsed = builtin.json_parse_raw(body)
        la type_verdi = builtin.type(parsed)
        hvis type_verdi == "ordbok" { returner parsed }
    } fang (e) { }
    // application/x-www-form-urlencoded: "namn=Ola&epost=ola%40example.com"
    la par = builtin.split(body, "&")
    la i: heltall = 0
    mens i < lengde(par) {
        la del = builtin.trim(par[i])
        la eq = builtin.index_of(del, "=")
        hvis eq > 0 {
            la k = _url_decode(builtin.slice(del, 0, eq))
            la v = _url_decode(builtin.slice(del, eq + 1, lengde(del)))
            data[k] = v
        }
        i = i + 1
    }
    returner data
}

funksjon _url_decode(s: tekst) -> tekst {
    // Minimal URL-dekoding: + → mellomrom, %XX → teikn
    la r = tekst_erstatt(s, "+", " ")
    // Naiv %XX-erstatning for vanlege teikn
    r = tekst_erstatt(r, "%40", "@")
    r = tekst_erstatt(r, "%20", " ")
    r = tekst_erstatt(r, "%2F", "/")
    r = tekst_erstatt(r, "%3A", ":")
    r = tekst_erstatt(r, "%3F", "?")
    r = tekst_erstatt(r, "%3D", "=")
    r = tekst_erstatt(r, "%26", "&")
    r = tekst_erstatt(r, "%2B", "+")
    r = tekst_erstatt(r, "%25", "%")
    returner r
}

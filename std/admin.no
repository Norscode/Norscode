# admin.no — Auto-generert CRUD admin-panel for Norscode
# Registrer modellar og få eit fullstendig webgrensesnitt på /admin
#
# Bruk:
#   bruk std.admin som admin
#   bruk std.db som db
#   bruk std.web som web
#
#   la conn = db.open("app.db")
#
#   # Registrer modellar
#   admin.registrer(conn, "brukar",  ["id", "namn", "epost", "rolle"],    "Brukarar")
#   admin.registrer(conn, "produkt", ["id", "namn", "pris", "lager"],     "Produkt")
#
#   # Monter admin-rutene
#   funksjon admin_liste(ctx)  -> ordbok_tekst { returner admin.handle_liste(conn, ctx) }
#   funksjon admin_ny(ctx)     -> ordbok_tekst { returner admin.handle_ny(conn, ctx) }
#   funksjon admin_rediger(ctx)-> ordbok_tekst { returner admin.handle_rediger(conn, ctx) }
#   funksjon admin_lagre(ctx)  -> ordbok_tekst { returner admin.handle_lagre(conn, ctx) }
#   funksjon admin_slett(ctx)  -> ordbok_tekst { returner admin.handle_slett(conn, ctx) }
#
#   web.route("GET /admin")
#   web.route("GET /admin/{tabell}")
#   web.route("GET /admin/{tabell}/ny")
#   web.route("POST /admin/{tabell}/lagre")
#   web.route("GET /admin/{tabell}/{id}/rediger")
#   web.route("POST /admin/{tabell}/{id}/slett")

bruk std.db som db
bruk std.orm som orm
bruk std.opplasting som oppl
bruk std.web som web
bruk std.mal som mal
bruk std.csrf som csrf

# ─── Registrering ─────────────────────────────────────────────────────────────

# Global modell-register (som ein ordbok)
funksjon _tom_register() -> ordbok_tekst {
    returner {}
}

funksjon registrer(register: ordbok_tekst, tabell: tekst, felt: liste<tekst>, visningsnamn: tekst) -> ordbok_tekst {
    la felt_str = _admin_join(felt, ",")
    la m: ordbok_tekst = {}
    m["tabell"]      = tabell
    m["felt"]        = felt_str
    m["visningsnamn"] = visningsnamn
    m["list_display"] = felt_str
    m["search_fields"] = _admin_felt_utan_id(felt)
    m["list_filter"] = ""
    m["readonly_fields"] = "id"
    m["fieldsets"] = "standard:" + felt_str
    m["widgets"] = ""
    m["autocomplete_fields"] = ""
    m["inline_models"] = ""
    m["media_root"] = "media/" + tabell
    m["permissions"] = "admin"
    m["csrf_token"] = "admin-token"
    m["actions"] = "delete_selected"
    m["history"] = "sann"
    m["relations"] = ""
    m["validation_required"] = _admin_felt_utan_id(felt)
    register[tabell] = m
    returner register
}

funksjon registrer_modeladmin(
    register: ordbok_tekst,
    tabell: tekst,
    felt: liste<tekst>,
    visningsnamn: tekst,
    list_display: liste<tekst>,
    search_fields: liste<tekst>,
    list_filter: liste<tekst>,
    readonly_fields: liste<tekst>
) -> ordbok_tekst {
    register = registrer(register, tabell, felt, visningsnamn)
    la m = register[tabell]
    hvis lengde(list_display) > 0 { m["list_display"] = _admin_join(list_display, ",") }
    hvis lengde(search_fields) > 0 { m["search_fields"] = _admin_join(search_fields, ",") }
    hvis lengde(list_filter) > 0 { m["list_filter"] = _admin_join(list_filter, ",") }
    hvis lengde(readonly_fields) > 0 { m["readonly_fields"] = _admin_join(readonly_fields, ",") }
    register[tabell] = m
    returner register
}

funksjon konfigurer(register: ordbok_tekst, tabell: tekst, nøkkel: tekst, verdi: tekst) -> ordbok_tekst {
    hvis ikkje har_nokkel(register, tabell) { returner register }
    la m = register[tabell]
    m[nøkkel] = verdi
    register[tabell] = m
    returner register
}

funksjon legg_til_action(register: ordbok_tekst, tabell: tekst, action: tekst) -> ordbok_tekst {
    hvis ikkje har_nokkel(register, tabell) { returner register }
    la m = register[tabell]
    hvis m["actions"] == "" {
        m["actions"] = action
    } ellers hvis ikkje _csv_inneheld(m["actions"], action) {
        m["actions"] = m["actions"] + "," + action
    }
    register[tabell] = m
    returner register
}

funksjon django_paritet_status() -> ordbok_tekst {
    returner {
        "modeladmin": "sann",
        "list_display": "sann",
        "search_fields": "sann",
        "list_filter": "sann",
        "readonly_fields": "sann",
        "fieldsets": "sann",
        "widgets": "sann",
        "autocomplete": "sann",
        "permissions": "sann",
        "csrf": "sann",
        "actions": "sann",
        "history": "sann",
        "relations": "sann",
        "inline_admin": "delvis",
        "level": "django-like-admin-core"
    }
}


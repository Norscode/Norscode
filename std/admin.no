# admin.no — Auto-generert CRUD admin-panel for Norscode
# Registrer modellar og få eit fullstendig webgrensesnitt på /admin
#
# Bruk:
#   bruk std.admin som admin
#   bruk std.db som db
#   bruk std.web som web
#
#   la conn = db.open("app.db")
#
#   # Registrer modellar
#   admin.registrer(conn, "brukar",  ["id", "namn", "epost", "rolle"],    "Brukarar")
#   admin.registrer(conn, "produkt", ["id", "namn", "pris", "lager"],     "Produkt")
#
#   # Monter admin-rutene
#   funksjon admin_liste(ctx)  -> ordbok_tekst { returner admin.handle_liste(conn, ctx) }
#   funksjon admin_ny(ctx)     -> ordbok_tekst { returner admin.handle_ny(conn, ctx) }
#   funksjon admin_rediger(ctx)-> ordbok_tekst { returner admin.handle_rediger(conn, ctx) }
#   funksjon admin_lagre(ctx)  -> ordbok_tekst { returner admin.handle_lagre(conn, ctx) }
#   funksjon admin_slett(ctx)  -> ordbok_tekst { returner admin.handle_slett(conn, ctx) }
#
#   web.route("GET /admin")
#   web.route("GET /admin/{tabell}")
#   web.route("GET /admin/{tabell}/ny")
#   web.route("POST /admin/{tabell}/lagre")
#   web.route("GET /admin/{tabell}/{id}/rediger")
#   web.route("POST /admin/{tabell}/{id}/slett")

bruk std.db som db
bruk std.orm som orm
bruk std.web som web
bruk std.mal som mal

# ─── Registrering ─────────────────────────────────────────────────────────────

# Global modell-register (som ein ordbok)
funksjon _tom_register() -> ordbok_tekst {
    returner {}
}

funksjon registrer(register: ordbok_tekst, tabell: tekst, felt: liste<tekst>, visningsnamn: tekst) -> ordbok_tekst {
    la felt_str = tekst_saman(felt, ",")
    la m: ordbok_tekst = {}
    m["tabell"]      = tabell
    m["felt"]        = felt_str
    m["visningsnamn"] = visningsnamn
    register[tabell] = m
    returner register
}

# ─── Admin CSS ────────────────────────────────────────────────────────────────

funksjon _admin_css() -> tekst {
    returner "
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; background: #f8f9fa; }
        .admin-header { background: #1a1a2e; color: white; padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; }
        .admin-header h1 { margin: 0; font-size: 1.25rem; }
        .admin-nav { background: #16213e; color: #adb5bd; padding: 0.5rem 2rem; display: flex; gap: 1rem; }
        .admin-nav a { color: #adb5bd; text-decoration: none; padding: 0.25rem 0.5rem; border-radius: 4px; }
        .admin-nav a:hover { color: white; background: #0f3460; }
        .admin-content { padding: 2rem; max-width: 1200px; margin: 0 auto; }
        .admin-card { background: white; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); padding: 1.5rem; margin-bottom: 1.5rem; }
        .admin-card h2 { margin-top: 0; color: #1a1a2e; }
        table { width: 100%; border-collapse: collapse; }
        th { background: #f1f3f5; text-align: left; padding: 0.6rem 0.75rem; font-size: .85rem; color: #495057; text-transform: uppercase; letter-spacing: .05em; }
        td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #f1f3f5; font-size: .9rem; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #f8f9fa; }
        .btn { display: inline-block; padding: .35rem .75rem; border-radius: 4px; font-size: .85rem; text-decoration: none; border: none; cursor: pointer; }
        .btn-primary { background: #1a1a2e; color: white; }
        .btn-primary:hover { background: #16213e; }
        .btn-danger { background: #dc3545; color: white; }
        .btn-danger:hover { background: #c82333; }
        .btn-secondary { background: #6c757d; color: white; }
        .badge { padding: .2rem .5rem; border-radius: 12px; font-size: .75rem; background: #e9ecef; color: #495057; }
        form label { display: block; font-size: .85rem; font-weight: 600; margin-bottom: .25rem; color: #495057; }
        form input, form select, form textarea { width: 100%; padding: .5rem .75rem; border: 1px solid #ced4da; border-radius: 4px; font-size: .9rem; box-sizing: border-box; margin-bottom: 1rem; }
        form input:focus { outline: none; border-color: #1a1a2e; box-shadow: 0 0 0 2px rgba(26,26,46,.15); }
        .model-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
        .model-card { background: white; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.1); padding: 1.25rem; text-decoration: none; color: inherit; border: 2px solid transparent; transition: border-color .15s; }
        .model-card:hover { border-color: #1a1a2e; }
        .model-card .tal { font-size: 2rem; font-weight: 700; color: #1a1a2e; }
        .model-card .namn { color: #6c757d; font-size: .9rem; }
        .alert { padding: .75rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
        .alert-success { background: #d4edda; color: #155724; }
        .alert-danger { background: #f8d7da; color: #721c24; }
    "
}

# ─── Sideoppsett ──────────────────────────────────────────────────────────────

funksjon _admin_side(register: ordbok_tekst, tittel: tekst, innhald: tekst) -> tekst {
    la nav_lenker = ""
    la tabellar = nøkler(register)
    la i: heltall = 0
    mens i < lengde(tabellar) {
        la t: tekst = tabellar[i]
        la m = register[t]
        nav_lenker = nav_lenker + "<a href=\"/admin/" + t + "\">" + m["visningsnamn"] + "</a>"
        i = i + 1
    }

    returner "<!DOCTYPE html><html lang=\"no\"><head><meta charset=\"UTF-8\">
<title>" + tittel + " — Admin</title>
<style>" + _admin_css() + "</style></head>
<body>
<div class=\"admin-header\">
  <h1>⚙ Norscode Admin</h1>
</div>
<nav class=\"admin-nav\">
  <a href=\"/admin\">Oversikt</a>
  " + nav_lenker + "
</nav>
<div class=\"admin-content\">
  " + innhald + "
</div>
</body></html>"
}

# ─── Oversikts-side ───────────────────────────────────────────────────────────

funksjon handle_oversikt(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabellar = nøkler(register)
    la kortane = ""
    la i: heltall = 0
    mens i < lengde(tabellar) {
        la t: tekst = tabellar[i]
        la m = register[t]
        la tal = orm.tell(conn, t)
        kortane = kortane + "<a class=\"model-card\" href=\"/admin/" + t + "\">
  <div class=\"tal\">" + tekst_fra_heltall(tal) + "</div>
  <div class=\"namn\">" + m["visningsnamn"] + "</div>
</a>"
        i = i + 1
    }
    la innhald = "<div class=\"admin-card\"><h2>Modellar</h2></div>
<div class=\"model-grid\">" + kortane + "</div>"
    la html = _admin_side(register, "Oversikt", innhald)
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, html)
}

# ─── Liste-side ───────────────────────────────────────────────────────────────

funksjon handle_liste(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    hvis ikkje har_nokkel(register, tabell) {
        returner web.response_error(404, "Modell ikkje funne: " + tabell)
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la rader = orm.alle_sorter(conn, tabell, "id", "DESC")

    // Bygg tabelloverskrift
    la th_rader = ""
    la i: heltall = 0
    mens i < lengde(felt_liste) {
        th_rader = th_rader + "<th>" + felt_liste[i] + "</th>"
        i = i + 1
    }
    th_rader = th_rader + "<th>Handlingar</th>"

    // Bygg tabellrader
    la td_rader = ""
    la j: heltall = 0
    mens j < lengde(rader) {
        la rad = rader[j]
        la rad_id: tekst = rad["id"]
        la td = ""
        la k: heltall = 0
        mens k < lengde(felt_liste) {
            la felt_namn: tekst = builtin.trim(felt_liste[k])
            la verdi = ""
            hvis har_nokkel(rad, felt_namn) { verdi = rad[felt_namn] }
            // Kutt lange verdiar
            hvis lengde(verdi) > 40 { verdi = builtin.slice(verdi, 0, 40) + "…" }
            td = td + "<td>" + verdi + "</td>"
            k = k + 1
        }
        td = td + "<td>
  <a class=\"btn btn-secondary\" href=\"/admin/" + tabell + "/" + rad_id + "/rediger\">Rediger</a>
  <form method=\"POST\" action=\"/admin/" + tabell + "/" + rad_id + "/slett\" style=\"display:inline\" onsubmit=\"return confirm('Slett?')\">
    <button class=\"btn btn-danger\" type=\"submit\">Slett</button>
  </form>
</td>"
        td_rader = td_rader + "<tr>" + td + "</tr>"
        j = j + 1
    }

    la innhald = "<div class=\"admin-card\">
  <div style=\"display:flex;justify-content:space-between;align-items:center\">
    <h2>" + m["visningsnamn"] + " <span class=\"badge\">" + tekst_fra_heltall(lengde(rader)) + " rader</span></h2>
    <a class=\"btn btn-primary\" href=\"/admin/" + tabell + "/ny\">+ Ny</a>
  </div>
  <table>
    <thead><tr>" + th_rader + "</tr></thead>
    <tbody>" + td_rader + "</tbody>
  </table>
</div>"

    la html = _admin_side(register, m["visningsnamn"], innhald)
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, html)
}

# ─── Ny-skjema ────────────────────────────────────────────────────────────────

funksjon handle_ny(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    hvis ikkje har_nokkel(register, tabell) {
        returner web.response_error(404, "Modell ikkje funne: " + tabell)
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la form_felt = _bygg_skjema_felt(felt_liste, {})

    la innhald = "<div class=\"admin-card\">
  <h2>Ny " + m["visningsnamn"] + "</h2>
  <form method=\"POST\" action=\"/admin/" + tabell + "/lagre\">
    " + form_felt + "
    <button class=\"btn btn-primary\" type=\"submit\">Lagre</button>
    <a class=\"btn btn-secondary\" href=\"/admin/" + tabell + "\">Avbryt</a>
  </form>
</div>"

    la html = _admin_side(register, "Ny " + m["visningsnamn"], innhald)
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, html)
}

# ─── Rediger-skjema ───────────────────────────────────────────────────────────

funksjon handle_rediger(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la id = web.request_param_int(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner web.response_error(404, "Modell ikkje funne: " + tabell)
    }
    la rad = orm.finn(conn, tabell, id)
    hvis ikkje har_nokkel(rad, "id") {
        returner web.response_error(404, "Rad ikkje funne")
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")
    la form_felt = _bygg_skjema_felt(felt_liste, rad)

    la innhald = "<div class=\"admin-card\">
  <h2>Rediger " + m["visningsnamn"] + " #" + tekst_fra_heltall(id) + "</h2>
  <form method=\"POST\" action=\"/admin/" + tabell + "/" + tekst_fra_heltall(id) + "/lagre\">
    " + form_felt + "
    <button class=\"btn btn-primary\" type=\"submit\">Lagre endringar</button>
    <a class=\"btn btn-secondary\" href=\"/admin/" + tabell + "\">Avbryt</a>
  </form>
</div>"

    la html = _admin_side(register, "Rediger " + m["visningsnamn"], innhald)
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, html)
}

# ─── Lagre (POST) ─────────────────────────────────────────────────────────────

funksjon handle_lagre(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la rad_id_str = web.request_param(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner web.response_error(404, "Modell ikkje funne: " + tabell)
    }
    la m = register[tabell]
    la felt_liste = builtin.split(m["felt"], ",")

    // Hent form-data frå body (application/x-www-form-urlencoded eller JSON)
    la data = _parse_form_body(web.request_body(ctx))

    // Fjern "id"-felt frå data (auto-generert)
    la utan_id: ordbok_tekst = {}
    la i: heltall = 0
    mens i < lengde(felt_liste) {
        la f: tekst = builtin.trim(felt_liste[i])
        hvis f != "id" og har_nokkel(data, f) {
            utan_id[f] = data[f]
        }
        i = i + 1
    }

    prøv {
        hvis rad_id_str != "" og rad_id_str != "ny" {
            la id = heltall_fra_tekst(rad_id_str)
            orm.oppdater(conn, tabell, id, utan_id)
        } ellers {
            orm.lagre(conn, tabell, utan_id)
        }
    } fang (e) {
        returner web.response_builder(302, {"location": "/admin/" + tabell + "?feil=" + e}, "")
    }

    returner web.response_builder(302, {"location": "/admin/" + tabell}, "")
}

# ─── Slett (POST) ─────────────────────────────────────────────────────────────

funksjon handle_slett(conn: tekst, register: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la tabell = web.request_param(ctx, "tabell")
    la id = web.request_param_int(ctx, "id")
    hvis ikkje har_nokkel(register, tabell) {
        returner web.response_error(404, "Modell ikkje funne: " + tabell)
    }
    orm.slett(conn, tabell, id)
    returner web.response_builder(302, {"location": "/admin/" + tabell}, "")
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _bygg_skjema_felt(felt_liste: liste<tekst>, verdiar: ordbok_tekst) -> tekst {
    la html = ""
    la i: heltall = 0
    mens i < lengde(felt_liste) {
        la f: tekst = builtin.trim(felt_liste[i])
        la verdi = ""
        hvis har_nokkel(verdiar, f) { verdi = verdiar[f] }
        // Ikkje vis id-felt (auto-generert)
        hvis f == "id" {
            html = html + "<input type=\"hidden\" name=\"id\" value=\"" + verdi + "\">"
        } ellers {
            html = html + "<label>" + f + "</label>
<input type=\"text\" name=\"" + f + "\" value=\"" + verdi + "\">
"
        }
        i = i + 1
    }
    returner html
}

funksjon _parse_form_body(body: tekst) -> ordbok_tekst {
    la data: ordbok_tekst = {}
    // Prøv JSON
    prøv {
        la parsed = builtin.json_parse_raw(body)
        la type_verdi = builtin.type(parsed)
        hvis type_verdi == "ordbok" { returner parsed }
    } fang (e) { }
    // application/x-www-form-urlencoded: "namn=Ola&epost=ola%40example.com"
    la par = builtin.split(body, "&")
    la i: heltall = 0
    mens i < lengde(par) {
        la del = builtin.trim(par[i])
        la eq = builtin.index_of(del, "=")
        hvis eq > 0 {
            la k = _url_decode(builtin.slice(del, 0, eq))
            la v = _url_decode(builtin.slice(del, eq + 1, lengde(del)))
            data[k] = v
        }
        i = i + 1
    }
    returner data
}

funksjon _url_decode(s: tekst) -> tekst {
    // Minimal URL-dekoding: + → mellomrom, %XX → teikn
    la r = tekst_erstatt(s, "+", " ")
    // Naiv %XX-erstatning for vanlege teikn
    r = tekst_erstatt(r, "%40", "@")
    r = tekst_erstatt(r, "%20", " ")
    r = tekst_erstatt(r, "%2F", "/")
    r = tekst_erstatt(r, "%3A", ":")
    r = tekst_erstatt(r, "%3F", "?")
    r = tekst_erstatt(r, "%3D", "=")
    r = tekst_erstatt(r, "%26", "&")
    r = tekst_erstatt(r, "%2B", "+")
    r = tekst_erstatt(r, "%25", "%")
    returner r
}

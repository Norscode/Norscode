# types.no — Typehjelperar og spesialtypar
# Python: types
#
# Implementerer:
#   - SimpleNamespace: fleksibel ordbok-innpakning med attributt-tilgang
#   - MappingProxyType: skriveverna ordbok-innpakning
#   - NoneType / NullVerdi: representasjon av fråverande verdiar
#   - FunctionType-mønster: ordbok med type-tag "funksjon"
#   - ModuleType-mønster: ordbok med type-tag "modul"
#   - GeneratorType-mønster: tilstandsmaskin for lat evaluering
#   - ChainMap: samanslåing av ordbokar (les frå første, skriv til første)
#   - MappingType: testar for ordbok-liknande objekt
#   - DynamicClassAttribute: eigenskap som kan overstyrast i klassar
#
# Bruk:
#   bruk std.types som ty
#   la ns = ty.ny_namespace()
#   ty.ns_set(ns, "namn", "Ola")
#   ty.ns_set(ns, "alder", "30")
#   skriv ty.ns_get(ns, "namn")   # → "Ola"
#   skriv ty.ns_repr(ns)          # → "namespace(namn='Ola', alder='30')"

# ─── SimpleNamespace ──────────────────────────────────────────────────────────

funksjon ny_namespace() -> ordbok_tekst {
    la ns: ordbok_tekst = {}
    ns["_type"] = "namespace"
    ns["_data"] = "{}"
    returner ns
}

# Lag namespace frå ein ordbok
funksjon namespace_frå_ordbok(d: ordbok_tekst) -> ordbok_tekst {
    la ns = ny_namespace()
    la nøklar = builtin.nøklar(d)
    la data = builtin.json_parse(ns["_data"])
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la k: tekst = nøklar[i]
        data[k] = d[k]
        i = i + 1
    }
    ns["_data"] = builtin.json_stringify(data)
    returner ns
}

# Set eigenskap
funksjon ns_set(ns: ordbok_tekst, namn: tekst, verdi: tekst) {
    la data = builtin.json_parse(ns["_data"])
    data[namn] = verdi
    ns["_data"] = builtin.json_stringify(data)
}

# Hent eigenskap
funksjon ns_get(ns: ordbok_tekst, namn: tekst) -> tekst {
    la data = builtin.json_parse(ns["_data"])
    prøv {
        returner data[namn]
    } fang (e) {
        kast "AttributeError: namespace har ikkje eigenskapen '" + namn + "'"
    }
    returner ""
}

# Hent eigenskap med standardverdi
funksjon ns_get_h(ns: ordbok_tekst, namn: tekst, standard: tekst) -> tekst {
    la data = builtin.json_parse(ns["_data"])
    prøv {
        returner data[namn]
    } fang (e) {
        returner standard
    }
    returner standard
}

# Har namespace eigenskapen?
funksjon ns_har(ns: ordbok_tekst, namn: tekst) -> bool {
    la data = builtin.json_parse(ns["_data"])
    la nøklar = builtin.nøklar(data)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        hvis (nøklar[i] == namn) { returner sann }
        i = i + 1
    }
    returner usann
}

# Slett eigenskap
funksjon ns_del(ns: ordbok_tekst, namn: tekst) {
    la data = builtin.json_parse(ns["_data"])
    la ny_data: ordbok_tekst = {}
    la nøklar = builtin.nøklar(data)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la k: tekst = nøklar[i]
        hvis (k != namn) {
            ny_data[k] = data[k]
        }
        i = i + 1
    }
    ns["_data"] = builtin.json_stringify(ny_data)
}

# Alle eigenskap-nøklar
funksjon ns_nøklar(ns: ordbok_tekst) -> liste_tekst {
    la data = builtin.json_parse(ns["_data"])
    returner builtin.nøklar(data)
}

# Konverter namespace til ordbok
funksjon ns_til_ordbok(ns: ordbok_tekst) -> ordbok_tekst {
    returner builtin.json_parse(ns["_data"])
}

# repr-tekst
funksjon ns_repr(ns: ordbok_tekst) -> tekst {
    la data = builtin.json_parse(ns["_data"])
    la nøklar = builtin.nøklar(data)
    la delar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la k: tekst = nøklar[i]
        legg_til(delar, k + "='" + data[k] + "'")
        i = i + 1
    }
    returner "namespace(" + builtin.join(delar, ", ") + ")"
}

# Kopier namespace
funksjon ns_kopier(ns: ordbok_tekst) -> ordbok_tekst {
    la ny_ns = ny_namespace()
    ny_ns["_data"] = ns["_data"]
    returner ny_ns
}

# Samanlikn to namespaces (likt innhald?)
funksjon ns_lik(ns1: ordbok_tekst, ns2: ordbok_tekst) -> bool {
    returner ns1["_data"] == ns2["_data"]
}

# ─── MappingProxyType (skriveverna ordbok) ─────────────────────────────────────

funksjon ny_proxy(d: ordbok_tekst) -> ordbok_tekst {
    la proxy: ordbok_tekst = {}
    proxy["_type"] = "proxy"
    proxy["_data"] = builtin.json_stringify(d)
    returner proxy
}

# Les frå proxy (tillate)
funksjon proxy_get(p: ordbok_tekst, nøkkel: tekst) -> tekst {
    la data = builtin.json_parse(p["_data"])
    prøv {
        returner data[nøkkel]
    } fang (e) {
        kast "KeyError: '" + nøkkel + "'"
    }
    returner ""
}

funksjon proxy_get_h(p: ordbok_tekst, nøkkel: tekst, standard: tekst) -> tekst {
    la data = builtin.json_parse(p["_data"])
    prøv { returner data[nøkkel] } fang (e) { returner standard }
    returner standard
}

funksjon proxy_har(p: ordbok_tekst, nøkkel: tekst) -> bool {
    la data = builtin.json_parse(p["_data"])
    la nøklar = builtin.nøklar(data)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        hvis (nøklar[i] == nøkkel) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon proxy_nøklar(p: ordbok_tekst) -> liste_tekst {
    la data = builtin.json_parse(p["_data"])
    returner builtin.nøklar(data)
}

# Kopierer til ein ny (ikkje-skriveverna) ordbok
funksjon proxy_til_ordbok(p: ordbok_tekst) -> ordbok_tekst {
    returner builtin.json_parse(p["_data"])
}

# Skriving til proxy er IKKJE tillate (kast feil)
funksjon proxy_set(p: ordbok_tekst, nøkkel: tekst, verdi: tekst) {
    kast "TypeError: 'mappingproxy' støttar ikkje item assignment"
}

# ─── NoneType / NullVerdi ─────────────────────────────────────────────────────

funksjon ny_none() -> ordbok_tekst {
    la n: ordbok_tekst = {}
    n["_type"] = "none"
    returner n
}

funksjon er_none(obj: ordbok_tekst) -> bool {
    prøv {
        returner obj["_type"] == "none"
    } fang (e) { returner usann }
    returner usann
}

# ─── FunctionType-mønster ─────────────────────────────────────────────────────

funksjon ny_funksjon(namn: tekst, modul: tekst, dokkstreng: tekst) -> ordbok_tekst {
    la f: ordbok_tekst = {}
    f["_type"] = "funksjon"
    f["__name__"] = namn
    f["__module__"] = modul
    f["__doc__"] = dokkstreng
    f["__qualname__"] = modul + "." + namn
    returner f
}

funksjon er_funksjon(obj: ordbok_tekst) -> bool {
    prøv { returner obj["_type"] == "funksjon" } fang (e) { returner usann }
    returner usann
}

funksjon funksjon_namn(f: ordbok_tekst) -> tekst {
    prøv { returner f["__name__"] } fang (e) { returner "" }
    returner ""
}

# ─── ModuleType-mønster ───────────────────────────────────────────────────────

funksjon ny_modul(namn: tekst, fil: tekst, dokkstreng: tekst) -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["_type"] = "modul"
    m["__name__"] = namn
    m["__file__"] = fil
    m["__doc__"] = dokkstreng
    m["__dict__"] = "{}"
    returner m
}

funksjon er_modul(obj: ordbok_tekst) -> bool {
    prøv { returner obj["_type"] == "modul" } fang (e) { returner usann }
    returner usann
}

funksjon modul_set(m: ordbok_tekst, namn: tekst, verdi: tekst) {
    la d = builtin.json_parse(m["__dict__"])
    d[namn] = verdi
    m["__dict__"] = builtin.json_stringify(d)
}

funksjon modul_get(m: ordbok_tekst, namn: tekst) -> tekst {
    la d = builtin.json_parse(m["__dict__"])
    prøv { returner d[namn] } fang (e) { kast "AttributeError: modul har ikkje '" + namn + "'" }
    returner ""
}

# ─── ChainMap ─────────────────────────────────────────────────────────────────
# Leser frå første ordbok som har nøkkelen, skriv alltid til første.

funksjon ny_chainmap(ordbøker: liste_tekst) -> ordbok_tekst {
    la cm: ordbok_tekst = {}
    cm["_type"] = "chainmap"
    cm["_kart"] = builtin.json_stringify(ordbøker)
    returner cm
}

funksjon cm_get(cm: ordbok_tekst, nøkkel: tekst) -> tekst {
    la kart = builtin.json_parse(cm["_kart"])
    la i: heltall = 0
    mens (i < lengde(kart)) {
        la d = builtin.json_parse(kart[i])
        la nøklar = builtin.nøklar(d)
        la j: heltall = 0
        mens (j < lengde(nøklar)) {
            hvis (nøklar[j] == nøkkel) {
                returner d[nøkkel]
            }
            j = j + 1
        }
        i = i + 1
    }
    kast "KeyError: '" + nøkkel + "'"
    returner ""
}

funksjon cm_get_h(cm: ordbok_tekst, nøkkel: tekst, standard: tekst) -> tekst {
    prøv { returner cm_get(cm, nøkkel) } fang (e) { returner standard }
    returner standard
}

funksjon cm_set(cm: ordbok_tekst, nøkkel: tekst, verdi: tekst) {
    la kart = builtin.json_parse(cm["_kart"])
    hvis (lengde(kart) == 0) {
        kast "KeyError: ingen kart i ChainMap"
    }
    la første = builtin.json_parse(kart[0])
    første[nøkkel] = verdi
    kart[0] = builtin.json_stringify(første)
    cm["_kart"] = builtin.json_stringify(kart)
}

funksjon cm_har(cm: ordbok_tekst, nøkkel: tekst) -> bool {
    prøv { cm_get(cm, nøkkel)  returner sann } fang (e) { returner usann }
    returner usann
}

# Legg til ny ordbok fremst
funksjon cm_ny_barn(cm: ordbok_tekst, ny_ordbok: ordbok_tekst) -> ordbok_tekst {
    la kart = builtin.json_parse(cm["_kart"])
    la ny_liste: liste_tekst = [builtin.json_stringify(ny_ordbok)]
    la i: heltall = 0
    mens (i < lengde(kart)) {
        legg_til(ny_liste, kart[i])
        i = i + 1
    }
    la ny_cm = ny_chainmap(ny_liste)
    returner ny_cm
}

# Samanslå alle kart til eitt
funksjon cm_til_ordbok(cm: ordbok_tekst) -> ordbok_tekst {
    la kart = builtin.json_parse(cm["_kart"])
    la resultat: ordbok_tekst = {}
    # Iterer baklengs: tidlege kart overskygger seinare
    la i: heltall = lengde(kart) - 1
    mens (i >= 0) {
        la d = builtin.json_parse(kart[i])
        la nøklar = builtin.nøklar(d)
        la j: heltall = 0
        mens (j < lengde(nøklar)) {
            resultat[nøklar[j]] = d[nøklar[j]]
            j = j + 1
        }
        i = i - 1
    }
    returner resultat
}

# ─── Typetest-hjelperar ───────────────────────────────────────────────────────

funksjon er_namespace(obj: ordbok_tekst) -> bool {
    prøv { returner obj["_type"] == "namespace" } fang (e) { returner usann }
    returner usann
}

funksjon er_proxy(obj: ordbok_tekst) -> bool {
    prøv { returner obj["_type"] == "proxy" } fang (e) { returner usann }
    returner usann
}

funksjon er_chainmap(obj: ordbok_tekst) -> bool {
    prøv { returner obj["_type"] == "chainmap" } fang (e) { returner usann }
    returner usann
}

# Generell type-tag henting
funksjon type_tag(obj: ordbok_tekst) -> tekst {
    prøv { returner obj["_type"] } fang (e) { returner "ordbok" }
    returner "ordbok"
}

# ─── GeneratorType-mønster (tilstandsmaskin) ─────────────────────────────────

funksjon ny_generator(fn_namn: tekst, start_tilstand: ordbok_tekst) -> ordbok_tekst {
    la gen: ordbok_tekst = {}
    gen["_type"] = "generator"
    gen["_fn"] = fn_namn
    gen["_tilstand"] = builtin.json_stringify(start_tilstand)
    gen["_stansa"] = "usann"
    gen["_siste"] = ""
    returner gen
}

funksjon gen_next(gen: ordbok_tekst) -> tekst {
    hvis (gen["_stansa"] == "sann") {
        kast "StopIteration"
    }
    la tilstand = builtin.json_parse(gen["_tilstand"])
    prøv {
        la resultat = builtin.ncb_call_fn(gen["_fn"], tilstand)
        gen["_siste"] = builtin.json_stringify(resultat)
        returner gen["_siste"]
    } fang (e) {
        gen["_stansa"] = "sann"
        kast "StopIteration"
    }
    returner ""
}

funksjon gen_er_stansa(gen: ordbok_tekst) -> bool {
    returner gen["_stansa"] == "sann"
}

# ─── Konstantar / spesialobjekt ───────────────────────────────────────────────

la NONE_TYPE: tekst = "NoneType"
la BOOL_TYPE: tekst = "bool"
la INT_TYPE: tekst = "heltall"
la STR_TYPE: tekst = "tekst"
la LIST_TYPE: tekst = "liste"
la DICT_TYPE: tekst = "ordbok"
la FUNC_TYPE: tekst = "funksjon"
la MODULE_TYPE: tekst = "modul"

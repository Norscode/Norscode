# side.no — Paginering for Norscode
# Django Paginator-ekvivalent
#
# Bruk:
#   bruk std.side som side
#
#   la p = side.ny(totalt_antal, per_side: 20)
#   la info = side.info(p, side_nr: 3)
#   // info.har_neste, info.har_førre, info.sidetal, info.sider_rundt, ...
#
#   // Frå web-kontekst
#   la p = side.frå_ctx(ctx, totalt_antal, per_side: 20)
#   la html = side.til_html(p, "/brukarar")

bruk std.web som web

# ─── Oppretting ───────────────────────────────────────────────────────────────

funksjon ny(total: heltall, per_side: heltall) -> ordbok_tekst {
    la p: ordbok_tekst = {}
    p["total"]    = tekst_fra_heltall(total)
    p["per_side"] = tekst_fra_heltall(per_side)
    la sider = hvis per_side > 0 { (total + per_side - 1) / per_side } ellers { 1 }
    p["sider"]    = tekst_fra_heltall(sider)
    returner p
}

funksjon frå_ctx(ctx: ordbok_tekst, total: heltall, per_side: heltall) -> ordbok_tekst {
    la p = ny(total, per_side)
    la side_param = web.request_query_param(ctx, "side")
    la side_nr = hvis side_param != "" {
        prøv { heltall_fra_tekst(side_param) } fang (e) { 1 }
    } ellers { 1 }
    p["gjeldande"] = tekst_fra_heltall(_klem(side_nr, 1, heltall_fra_tekst(p["sider"])))
    returner p
}

# ─── Sideinformasjon ─────────────────────────────────────────────────────────

funksjon info(p: ordbok_tekst, side_nr: heltall) -> ordbok_tekst {
    la total    = heltall_fra_tekst(p["total"])
    la per_side = heltall_fra_tekst(p["per_side"])
    la sider    = heltall_fra_tekst(p["sider"])
    la gjeldande = _klem(side_nr, 1, sider)

    la offset = (gjeldande - 1) * per_side
    la til    = _min(offset + per_side, total)

    la r: ordbok_tekst = {}
    r["gjeldande"]  = tekst_fra_heltall(gjeldande)
    r["total"]      = tekst_fra_heltall(total)
    r["per_side"]   = tekst_fra_heltall(per_side)
    r["sider"]      = tekst_fra_heltall(sider)
    r["offset"]     = tekst_fra_heltall(offset)
    r["frå"]        = tekst_fra_heltall(offset + 1)
    r["til"]        = tekst_fra_heltall(til)
    r["har_neste"]  = hvis gjeldande < sider { "sann" } ellers { "usann" }
    r["har_førre"]  = hvis gjeldande > 1     { "sann" } ellers { "usann" }
    r["neste_side"] = tekst_fra_heltall(gjeldande + 1)
    r["førre_side"] = tekst_fra_heltall(gjeldande - 1)
    r["er_fyrste"]  = hvis gjeldande == 1     { "sann" } ellers { "usann" }
    r["er_siste"]   = hvis gjeldande == sider { "sann" } ellers { "usann" }
    returner r
}

funksjon gjeldande_info(p: ordbok_tekst) -> ordbok_tekst {
    la gjeldande = heltall_fra_tekst(hvis har_nokkel(p, "gjeldande") { p["gjeldande"] } ellers { "1" })
    returner info(p, gjeldande)
}

// Offset og limit for SQL
funksjon sql_offset(p: ordbok_tekst, side_nr: heltall) -> heltall {
    la per_side = heltall_fra_tekst(p["per_side"])
    returner (side_nr - 1) * per_side
}

funksjon sql_limit(p: ordbok_tekst) -> heltall {
    returner heltall_fra_tekst(p["per_side"])
}

# ─── Sidetal-generering ───────────────────────────────────────────────────────

// Genererer liste med sidetalsinfo (for HTML-navigasjon)
// Returnerer ordbokliste med: {nr, er_gjeldande, er_ellipse}
funksjon sider_rundt(p: ordbok_tekst, side_nr: heltall, vindauge: heltall) -> liste<ordbok_tekst> {
    la sider    = heltall_fra_tekst(p["sider"])
    la gjeldande = _klem(side_nr, 1, sider)
    la resultat: liste<ordbok_tekst> = []

    la start = _max(1, gjeldande - vindauge)
    la slutt  = _min(sider, gjeldande + vindauge)

    // Fyrste side
    hvis start > 1 {
        _legg_til_side(resultat, 1, gjeldande)
        hvis start > 2 { _legg_til_ellipse(resultat) }
    }

    // Vindauge
    la i: heltall = start
    mens i <= slutt {
        _legg_til_side(resultat, i, gjeldande)
        i = i + 1
    }

    // Siste side
    hvis slutt < sider {
        hvis slutt < sider - 1 { _legg_til_ellipse(resultat) }
        _legg_til_side(resultat, sider, gjeldande)
    }

    returner resultat
}

funksjon _legg_til_side(lst: liste<ordbok_tekst>, nr: heltall, gjeldande: heltall) -> heltall {
    la s: ordbok_tekst = {}
    s["nr"]           = tekst_fra_heltall(nr)
    s["er_gjeldande"] = hvis nr == gjeldande { "sann" } ellers { "usann" }
    s["er_ellipse"]   = "usann"
    legg_til(lst, s)
    returner 0
}

funksjon _legg_til_ellipse(lst: liste<ordbok_tekst>) -> heltall {
    la s: ordbok_tekst = {}
    s["nr"]           = "0"
    s["er_gjeldande"] = "usann"
    s["er_ellipse"]   = "sann"
    legg_til(lst, s)
    returner 0
}

# ─── HTML-generering ──────────────────────────────────────────────────────────

funksjon til_html(p: ordbok_tekst, base_url: tekst) -> tekst {
    la side_nr  = heltall_fra_tekst(hvis har_nokkel(p, "gjeldande") { p["gjeldande"] } ellers { "1" })
    la i_info   = info(p, side_nr)
    la sider    = heltall_fra_tekst(p["sider"])

    hvis sider <= 1 { returner "" }

    la html = "<nav class=\"paginering\" aria-label=\"Sidetal\">\n<ul>\n"

    // Førre
    la har_f = i_info["har_førre"] == "sann"
    la f_cls = hvis har_f { "" } ellers { " disabled" }
    la f_href = hvis har_f { base_url + "?side=" + i_info["førre_side"] } ellers { "#" }
    html = html + "  <li class=\"side-el" + f_cls + "\"><a href=\"" + f_href + "\" aria-label=\"Førre\">&laquo;</a></li>\n"

    // Sidetal
    la sidetal = sider_rundt(p, side_nr, 2)
    la i: heltall = 0
    mens i < lengde(sidetal) {
        la s: ordbok_tekst = sidetal[i]
        hvis s["er_ellipse"] == "sann" {
            html = html + "  <li class=\"side-el ellipse\"><span>&hellip;</span></li>\n"
        } ellers {
            la nr: tekst = s["nr"]
            la aktiv_cls = hvis s["er_gjeldande"] == "sann" { " active" } ellers { "" }
            html = html + "  <li class=\"side-el" + aktiv_cls + "\"><a href=\"" + base_url + "?side=" + nr + "\">" + nr + "</a></li>\n"
        }
        i = i + 1
    }

    // Neste
    la har_n = i_info["har_neste"] == "sann"
    la n_cls = hvis har_n { "" } ellers { " disabled" }
    la n_href = hvis har_n { base_url + "?side=" + i_info["neste_side"] } ellers { "#" }
    html = html + "  <li class=\"side-el" + n_cls + "\"><a href=\"" + n_href + "\" aria-label=\"Neste\">&raquo;</a></li>\n"

    html = html + "</ul>\n</nav>"
    returner html
}

funksjon til_json(p: ordbok_tekst, side_nr: heltall) -> tekst {
    la i_info = info(p, side_nr)
    la nk = nøkler(i_info)
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        legg_til(delar, "\"" + k + "\":\"" + tekst(i_info[k]) + "\"")
        i = i + 1
    }
    returner "{" + tekst_saman(delar, ",") + "}"
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _klem(v: heltall, min: heltall, maks: heltall) -> heltall {
    hvis v < min { returner min }
    hvis v > maks { returner maks }
    returner v
}

funksjon _min(a: heltall, b: heltall) -> heltall {
    hvis a < b { returner a } returner b
}

funksjon _max(a: heltall, b: heltall) -> heltall {
    hvis a > b { returner a } returner b
}

# trie.no — Trie (prefikstre) datastruktur
# Python: pygtrie, datrie — ingen i stdlib, men svært brukt
#
# Implementasjon: flat ordbok_tekst-basert trie.
# Kvar node er ein nøkkel "nodeId:teikn" → barne-nodeId (som tekst).
# Rota er node 0. "slutt"-merkinga: nøkkel "nodeId:$" → "1"
#
# Bruk:
#   bruk std.trie som tr
#   la t = tr.ny()
#   tr.sett_inn(t, "norsk")
#   tr.sett_inn(t, "norske")
#   tr.sett_inn(t, "nord")
#   skriv(tekst_fra_bool(tr.inneheld(t, "norsk")))  # => sann
#   la r = tr.prefix_søk(t, "nor")  # => ["nord", "norsk", "norske"]

# ─── Intern struktur ──────────────────────────────────────────────────────────
# t[0] = neste ledige node-id (tekst)
# t["nodeId:teikn"] = barne-nodeId
# t["nodeId:$"] = "1" viss slutt på ord

funksjon ny() -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["_neste"] = "1"   # node 0 er rota, neste ledige er 1
    returner t
}

funksjon _neste_id(t: ordbok_tekst) -> tekst {
    la id: tekst = t["_neste"]
    la num: heltall = builtin.heltall_fra_tekst(id)
    t["_neste"] = tekst_fra_heltall(num + 1)
    returner id
}

# ─── Innsetting ───────────────────────────────────────────────────────────────

funksjon sett_inn(t: ordbok_tekst, ord: tekst) -> heltall {
    la teikn = builtin.split(ord, "")
    la node: tekst = "0"
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la c: tekst = teikn[i]
        la nøkkel: tekst = node + ":" + c
        hvis (ikkje har_nokkel(t, nøkkel)) {
            la ny_node: tekst = _neste_id(t)
            t[nøkkel] = ny_node
            node = ny_node
        } ellers {
            node = t[nøkkel]
        }
        i = i + 1
    }
    t[node + ":$"] = "1"
    returner builtin.heltall_fra_tekst(t["_neste"]) - 1
}

# ─── Oppslag ──────────────────────────────────────────────────────────────────

# Finst ordet nøyaktig?
funksjon inneheld(t: ordbok_tekst, ord: tekst) -> bool {
    la teikn = builtin.split(ord, "")
    la node: tekst = "0"
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la nøkkel: tekst = node + ":" + teikn[i]
        hvis (ikkje har_nokkel(t, nøkkel)) { returner usann }
        node = t[nøkkel]
        i = i + 1
    }
    returner har_nokkel(t, node + ":$")
}

# Finst prefikset (ein eller fleire ord startar med dette)?
funksjon har_prefix(t: ordbok_tekst, prefix: tekst) -> bool {
    la teikn = builtin.split(prefix, "")
    la node: tekst = "0"
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la nøkkel: tekst = node + ":" + teikn[i]
        hvis (ikkje har_nokkel(t, nøkkel)) { returner usann }
        node = t[nøkkel]
        i = i + 1
    }
    returner sann
}

# ─── Prefix-søk ───────────────────────────────────────────────────────────────
# Returner alle ord med gjeve prefix (DFS frå prefix-noden)

funksjon _saml_ord(t: ordbok_tekst, node: tekst, pre: tekst, ut: liste_tekst) -> heltall {
    hvis (har_nokkel(t, node + ":$")) { legg_til(ut, pre) }
    # Iterer over moglege neste teikn: ASCII 32–126
    la i: heltall = 32
    mens (i <= 126) {
        la c: tekst = builtin.slice(tekst_fra_heltall(i), 0, 1)  # Fallback: vi treng teikn frå kode
        # Sidan vi ikkje har chr(), itererer vi over nøklar som startar med "node:"
        # Alternativ: bruk kjente alfabet-teikn
        i = 127  # Forlat – sjå under
    }
    # Praktisk tilnærming: iterer over nøklane i ordboka
    la nkl = builtin.nøkler(t)
    la prefix_søk: tekst = node + ":"
    la plen: heltall = lengde(builtin.split(prefix_søk, ""))
    la j: heltall = 0
    mens (j < lengde(nkl)) {
        la k: tekst = nkl[j]
        hvis (tekst_starter_med(k, prefix_søk)) {
            la c_del: tekst = builtin.slice(k, plen, lengde(builtin.split(k, "")))
            hvis (c_del != "$" og lengde(builtin.split(c_del, "")) == 1) {
                _saml_ord(t, t[k], pre + c_del, ut)
            }
        }
        j = j + 1
    }
    returner lengde(ut)
}

funksjon prefix_søk(t: ordbok_tekst, prefix: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la teikn = builtin.split(prefix, "")
    la node: tekst = "0"
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la nøkkel: tekst = node + ":" + teikn[i]
        hvis (ikkje har_nokkel(t, nøkkel)) { returner ut }
        node = t[nøkkel]
        i = i + 1
    }
    _saml_ord(t, node, prefix, ut)
    returner ut
}

# ─── Sletting ─────────────────────────────────────────────────────────────────

funksjon slett(t: ordbok_tekst, ord: tekst) -> bool {
    la teikn = builtin.split(ord, "")
    la node: tekst = "0"
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la nøkkel: tekst = node + ":" + teikn[i]
        hvis (ikkje har_nokkel(t, nøkkel)) { returner usann }
        node = t[nøkkel]
        i = i + 1
    }
    la sluttnøkkel: tekst = node + ":$"
    hvis (ikkje har_nokkel(t, sluttnøkkel)) { returner usann }
    fjern_nokkel(t, sluttnøkkel)
    returner sann
}

# ─── Statistikk ───────────────────────────────────────────────────────────────

funksjon tal_ord(t: ordbok_tekst) -> heltall {
    la nkl = builtin.nøkler(t)
    la n: heltall = 0
    la i: heltall = 0
    mens (i < lengde(nkl)) {
        la k: tekst = nkl[i]
        la klen: heltall = lengde(builtin.split(k, ""))
        # Nøklar som endar på ":$" er slutt-markeringar
        hvis (tekst_slutter_med(k, ":$")) { n = n + 1 }
        i = i + 1
    }
    returner n
}

funksjon tal_nodar(t: ordbok_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(t["_neste"])
}

# Alle ord i trie (DFS frå rota)
funksjon alle_ord(t: ordbok_tekst) -> liste_tekst {
    returner prefix_søk(t, "")
}

# ─── Autofullfør ─────────────────────────────────────────────────────────────
# Returnerer dei n første forslagja for eit prefix

funksjon autofullfør(t: ordbok_tekst, prefix: tekst, n: heltall) -> liste_tekst {
    la alle = prefix_søk(t, prefix)
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < n og i < lengde(alle)) {
        legg_til(ut, alle[i])
        i = i + 1
    }
    returner ut
}

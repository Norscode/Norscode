bruk std.html som html
bruk std.html_components som komp
bruk std.html_templates som tmpl

// HTML Router v1
// Lett side-/rute-lag for server-rendret HTML.
// Dette er bevisst tekstbasert og kompatibelt med dagens Norscode runtime.

funksjon route(path: tekst, tittel: tekst, body: tekst) -> tekst {
    returner html.div(
        html.class_attr("route")
            + html.data_attr("path", path)
            + html.data_attr("title", tittel),
        body
    )
}

funksjon route_link(path: tekst, tekstverdi: tekst) -> tekst {
    returner html.a(
        html.class_attr("route-link") + html.href_attr(path),
        html.escape(tekstverdi)
    )
}

funksjon route_link_active(path: tekst, tekstverdi: tekst) -> tekst {
    returner html.a(
        html.class_attr("route-link is-active") + html.href_attr(path) + html.aria_attr("current", "page"),
        html.escape(tekstverdi)
    )
}

funksjon route_link_for(current_path: tekst, path: tekst, tekstverdi: tekst) -> tekst {
    hvis (current_path == path) {
        returner route_link_active(path, tekstverdi)
    }
    returner route_link(path, tekstverdi)
}

funksjon route_nav(lenker: tekst) -> tekst {
    returner html.nav(html.class_attr("route-nav") + html.aria_attr("label", "Hovednavigasjon"), lenker)
}

funksjon route_item(path: tekst, tekstverdi: tekst) -> tekst {
    returner html.li(html.class_attr("route-item"), route_link(path, tekstverdi))
}

funksjon route_item_for(current_path: tekst, path: tekst, tekstverdi: tekst) -> tekst {
    returner html.li(html.class_attr("route-item"), route_link_for(current_path, path, tekstverdi))
}

funksjon route_list(innhold: tekst) -> tekst {
    returner html.ul(html.class_attr("route-list"), innhold)
}

funksjon route_breadcrumb(innhold: tekst) -> tekst {
    returner html.nav(html.class_attr("route-breadcrumb") + html.aria_attr("label", "Brødsmule"), html.ol("", innhold))
}

funksjon route_crumb(path: tekst, tekstverdi: tekst) -> tekst {
    returner html.li("", route_link(path, tekstverdi))
}

funksjon route_crumb_current(tekstverdi: tekst) -> tekst {
    returner html.li("", html.span(html.aria_attr("current", "page"), html.escape(tekstverdi)))
}

funksjon route_not_found(path: tekst) -> tekst {
    returner komp.tom_tilstand(
        "Siden finnes ikke",
        "Fant ingen rute for " + path,
        komp.knappelenke("/", "Til forsiden")
    )
}

funksjon route_redirect(fra: tekst, mål: tekst) -> tekst {
    returner html.div(
        html.class_attr("redirect")
            + html.data_attr("from", fra)
            + html.data_attr("to", mål),
        html.p("", "Omdirigerer mål " + html.escape(mål))
    )
}

funksjon route_page(path: tekst, tittel: tekst, beskrivelse: tekst, body: tekst, css: tekst) -> tekst {
    returner html.page_meta(
        tittel,
        beskrivelse,
        html.canonical(path) + route(path, tittel, body),
        css
    )
}

funksjon route_page_med_nav(path: tekst, tittel: tekst, beskrivelse: tekst, navigasjon: tekst, body: tekst, css: tekst) -> tekst {
    returner html.page_meta(
        tittel,
        beskrivelse,
        html.canonical(path)
            + komp.app_shell(
                komp.side_topp(tittel, route_nav(navigasjon)),
                route(path, tittel, body),
                html.p("", "Bygget med Norscode")
            ),
        css
    )
}

funksjon route_index(tittel: tekst, beskrivelse: tekst, ruter: tekst, css: tekst) -> tekst {
    returner html.page_meta(
        tittel,
        beskrivelse,
        komp.app_shell(
            komp.side_topp(tittel, route_nav(ruter)),
            komp.hero(tittel, beskrivelse, komp.knappelenke("/start", "Kom i gang")),
            html.p("", "Norscode HTML Router")
        ),
        css
    )
}

funksjon simple_site(tittel: tekst, beskrivelse: tekst, innhold: tekst, css: tekst) -> tekst {
    returner html.page_meta(
        tittel,
        beskrivelse,
        komp.app_shell(
            komp.side_topp(
                tittel,
                route_link_for("/", "/", "Hjem")
                    + route_link("/docs", "Dokumentasjon")
                    + route_link("/blogg", "Blogg")
            ),
            innhold,
            html.p("", "Bygget med Norscode")
        ),
        css
    )
}

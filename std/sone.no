# sone.no — Tidssoner (IANA zoneinfo)
# Python: zoneinfo, pytz
#
# Statisk offsettabell for ~60 vanlege tidssoner.
# Ingen DST-bereknad for historiske overgangar — brukar noverande reglar.
# Offset er i minutter frå UTC.
#
# Bruk:
#   bruk std.sone som sone
#   la oslo = sone.hent("Europe/Oslo")
#   la utc_unix = 1700000000
#   la lokal_unix = sone.til_lokal(utc_unix, oslo)
#   skriv(sone.format(lokal_unix, oslo))

# ─── Soneoppslag ──────────────────────────────────────────────────────────────
# Returnerer offset i minuttar frå UTC (CET=+60, CEST=+120 osv.)
# Positive tal: aust for UTC. Negative: vest.

funksjon _sone_offsets() -> ordbok_heltall {
    la o: ordbok_heltall = {}

    # UTC / GMT
    o["UTC"] = 0  o["GMT"] = 0  o["UTC+0"] = 0

    # Europa
    o["Europe/London"] = 0          # GMT/BST — brukar vinteroffset
    o["Europe/Dublin"] = 0
    o["Europe/Lisbon"] = 0
    o["Europe/Reykjavik"] = 0
    o["Europe/Oslo"] = 60           # CET
    o["Europe/Stockholm"] = 60
    o["Europe/Copenhagen"] = 60
    o["Europe/Berlin"] = 60
    o["Europe/Amsterdam"] = 60
    o["Europe/Brussels"] = 60
    o["Europe/Paris"] = 60
    o["Europe/Madrid"] = 60
    o["Europe/Rome"] = 60
    o["Europe/Vienna"] = 60
    o["Europe/Zurich"] = 60
    o["Europe/Warsaw"] = 60
    o["Europe/Prague"] = 60
    o["Europe/Budapest"] = 60
    o["Europe/Bratislava"] = 60
    o["Europe/Ljubljana"] = 60
    o["Europe/Zagreb"] = 60
    o["Europe/Sarajevo"] = 60
    o["Europe/Belgrade"] = 60
    o["Europe/Skopje"] = 60
    o["Europe/Helsinki"] = 120      # EET
    o["Europe/Tallinn"] = 120
    o["Europe/Riga"] = 120
    o["Europe/Vilnius"] = 120
    o["Europe/Athens"] = 120
    o["Europe/Bucharest"] = 120
    o["Europe/Sofia"] = 120
    o["Europe/Kyiv"] = 120
    o["Europe/Istanbul"] = 180      # TRT
    o["Europe/Moscow"] = 180        # MSK
    o["Europe/Minsk"] = 180
    o["Europe/Kaliningrad"] = 120

    # Amerika
    o["America/Sao_Paulo"] = -180   # BRT
    o["America/New_York"] = -300    # EST
    o["America/Detroit"] = -300
    o["America/Chicago"] = -360     # CST
    o["America/Winnipeg"] = -360
    o["America/Denver"] = -420      # MST
    o["America/Phoenix"] = -420
    o["America/Los_Angeles"] = -480 # PST
    o["America/Vancouver"] = -480
    o["America/Anchorage"] = -540   # AKST
    o["America/Honolulu"] = -600    # HST
    o["America/Toronto"] = -300
    o["America/Halifax"] = -240     # AST
    o["America/St_Johns"] = -210    # NST
    o["America/Argentina/Buenos_Aires"] = -180
    o["America/Lima"] = -300        # PET
    o["America/Bogota"] = -300
    o["America/Caracas"] = -240
    o["America/Santiago"] = -180    # CLT (ikkje DST)
    o["America/Mexico_City"] = -360
    o["America/Montevideo"] = -180
    o["America/La_Paz"] = -240
    o["America/Asuncion"] = -240

    # Asia
    o["Asia/Dubai"] = 240           # GST
    o["Asia/Tehran"] = 210          # IRST
    o["Asia/Kabul"] = 270           # AFT
    o["Asia/Karachi"] = 300         # PKT
    o["Asia/Kolkata"] = 330         # IST
    o["Asia/Colombo"] = 330
    o["Asia/Kathmandu"] = 345       # NPT
    o["Asia/Dhaka"] = 360           # BST
    o["Asia/Almaty"] = 360
    o["Asia/Rangoon"] = 390         # MMT
    o["Asia/Bangkok"] = 420         # ICT
    o["Asia/Jakarta"] = 420
    o["Asia/Ho_Chi_Minh"] = 420
    o["Asia/Shanghai"] = 480        # CST
    o["Asia/Hong_Kong"] = 480
    o["Asia/Taipei"] = 480
    o["Asia/Singapore"] = 480
    o["Asia/Manila"] = 480
    o["Asia/Kuala_Lumpur"] = 480
    o["Asia/Seoul"] = 540           # KST
    o["Asia/Tokyo"] = 540           # JST
    o["Asia/Yakutsk"] = 540
    o["Asia/Vladivostok"] = 600
    o["Asia/Magadan"] = 660

    # Oseania
    o["Australia/Perth"] = 480      # AWST
    o["Australia/Adelaide"] = 570   # ACST
    o["Australia/Darwin"] = 570
    o["Australia/Sydney"] = 600     # AEST
    o["Australia/Melbourne"] = 600
    o["Australia/Brisbane"] = 600
    o["Australia/Hobart"] = 600
    o["Pacific/Auckland"] = 720     # NZST
    o["Pacific/Fiji"] = 720
    o["Pacific/Honolulu"] = -600    # same som America/Honolulu

    # Afrika
    o["Africa/Casablanca"] = 0
    o["Africa/Abidjan"] = 0
    o["Africa/Accra"] = 0
    o["Africa/Lagos"] = 60          # WAT
    o["Africa/Kinshasa"] = 60
    o["Africa/Tunis"] = 60
    o["Africa/Cairo"] = 120         # EET
    o["Africa/Johannesburg"] = 120  # SAST
    o["Africa/Harare"] = 120
    o["Africa/Nairobi"] = 180       # EAT
    o["Africa/Addis_Ababa"] = 180
    o["Africa/Mogadishu"] = 180

    returner o
}

# ─── DST-reglar (nøyaktige overgangar) ───────────────────────────────────────
# EU: siste søndag i mars 02:00 → siste søndag i oktober 03:00 (UTC+1/+2)
# US: 2. søndag i mars 02:00 → 1. søndag i november 02:00
# AU: 1. søndag i oktober → 1. søndag i april (sørlege halvkule)
# NZ: siste søndag i september → 1. søndag i april

# Kva vekedag er dag 1 i ein gitt månad/år? (0=mandag .. 6=søndag)
# Basert på Tomohiko Sakamoto-algoritmen
funksjon _veekedag(år: heltall, mnd: heltall, dag: heltall) -> heltall {
    la t: liste_heltall = [0, 3, 2, 5, 0, 3, 5, 1, 4, 6, 2, 4]
    la å: heltall = år
    hvis (mnd < 3) { å = å - 1 }
    la v: heltall = (å + å / 4 - å / 100 + å / 400 + t[mnd - 1] + dag) % 7
    returner v  # 0=søndag, 1=måndag, ..., 6=laurdag
}

# Finn dato (dag i månad) for n-te vekedag wd i mnd/år (n=1,2,3,4 eller -1=siste)
funksjon _finn_dag(år: heltall, mnd: heltall, wd: heltall, n: heltall) -> heltall {
    la mnd_dagar: liste_heltall = [31,28,31,30,31,30,31,31,30,31,30,31]
    la er_sk: bool = (år % 4 == 0 og (år % 100 != 0 eller år % 400 == 0))
    hvis (er_sk) { mnd_dagar[1] = 29 }
    la dagar_i_mnd: heltall = mnd_dagar[mnd - 1]

    hvis (n == -1) {
        # Siste førekomst: start frå slutten
        la dag: heltall = dagar_i_mnd
        mens (dag >= 1) {
            la vd: heltall = _veekedag(år, mnd, dag)
            hvis (vd == wd) { returner dag }
            dag = dag - 1
        }
        returner dagar_i_mnd
    } ellers {
        # n-te førekomst
        la teller: heltall = 0
        la dag: heltall = 1
        mens (dag <= dagar_i_mnd) {
            la vd: heltall = _veekedag(år, mnd, dag)
            hvis (vd == wd) {
                teller = teller + 1
                hvis (teller == n) { returner dag }
            }
            dag = dag + 1
        }
        returner 1
    }
}

# Konverter år/mnd/dag/time/min/sek til unix-tidsstempel (UTC)
funksjon _til_unix(år: heltall, mnd: heltall, dag: heltall,
                   time: heltall, minutt: heltall) -> heltall {
    la dagar: heltall = 0
    la å: heltall = 1970
    mens (å < år) {
        la di: heltall = 365
        la er_sk: bool = (å % 4 == 0 og (å % 100 != 0 eller å % 400 == 0))
        hvis (er_sk) { di = 366 }
        dagar = dagar + di
        å = å + 1
    }
    la mnd_dagar: liste_heltall = [31,28,31,30,31,30,31,31,30,31,30,31]
    la er_sk: bool = (år % 4 == 0 og (år % 100 != 0 eller år % 400 == 0))
    hvis (er_sk) { mnd_dagar[1] = 29 }
    la m: heltall = 0
    mens (m < mnd - 1) { dagar = dagar + mnd_dagar[m]  m = m + 1 }
    dagar = dagar + dag - 1
    returner dagar * 86400 + time * 3600 + minutt * 60
}

# Hent år og månadsdag frå unix-tidsstempel
funksjon _unix_til_ymd(unix: heltall) -> liste_heltall {
    la d: heltall = unix / 86400
    la å: heltall = 1970
    mens (d >= 365) {
        la di: heltall = 365
        la er_sk: bool = (å % 4 == 0 og (å % 100 != 0 eller å % 400 == 0))
        hvis (er_sk) { di = 366 }
        hvis (d < di) { d = d - 1 }
        ellers { d = d - di  å = å + 1 }
    }
    la mnd_dagar: liste_heltall = [31,28,31,30,31,30,31,31,30,31,30,31]
    la er_sk: bool = (å % 4 == 0 og (å % 100 != 0 eller å % 400 == 0))
    hvis (er_sk) { mnd_dagar[1] = 29 }
    la mnd: heltall = 0
    mens (mnd < 12 og d >= mnd_dagar[mnd]) { d = d - mnd_dagar[mnd]  mnd = mnd + 1 }
    la ut: liste_heltall = []
    legg_til(ut, å)
    legg_til(ut, mnd + 1)
    legg_til(ut, d + 1)
    returner ut
}

funksjon _brukar_dst(namn: tekst) -> bool {
    # Europa (unntatt ingen-DST-soner)
    hvis (tekst_starter_med(namn, "Europe/")) {
        returner namn != "Europe/Moscow" og namn != "Europe/Minsk" og
                 namn != "Europe/Reykjavik" og namn != "Europe/Istanbul" og
                 namn != "Europe/Kaliningrad"
    }
    # Nord-Amerika
    hvis (tekst_starter_med(namn, "America/")) {
        returner namn != "America/Phoenix" og namn != "America/Honolulu" og
                 namn != "America/Regina" og namn != "America/La_Paz"
    }
    # Australia
    hvis (tekst_starter_med(namn, "Australia/")) {
        returner namn != "Australia/Perth" og namn != "Australia/Darwin" og
                 namn != "Australia/Brisbane"
    }
    # New Zealand
    hvis (namn == "Pacific/Auckland") { returner sann }
    returner usann
}

funksjon _dst_ekstra(namn: tekst) -> heltall  {
    returner 60
}

funksjon _dst_start_unix(år: heltall, namn: tekst) -> heltall {
    # EU: siste søndag i mars 01:00 UTC
    hvis (tekst_starter_med(namn, "Europe/")) {
        la dag: heltall = _finn_dag(år, 3, 0, -1)  # 0=søndag
        la base: heltall = hent_offset(namn)
        # 02:00 lokal = 02:00 - base_offset i UTC
        returner _til_unix(år, 3, dag, 1, 0) - base * 60
    }
    # US: 2. søndag i mars 02:00 lokal
    hvis (tekst_starter_med(namn, "America/")) {
        la dag: heltall = _finn_dag(år, 3, 0, 2)
        la base: heltall = hent_offset(namn)
        returner _til_unix(år, 3, dag, 2, 0) - base * 60
    }
    # AU/NZ: sørlege halvkule (DST om vinteren nordleg = sommar sørlege)
    hvis (tekst_starter_med(namn, "Australia/")) {
        la dag: heltall = _finn_dag(år, 10, 0, 1)  # 1. søndag oktober
        la base: heltall = hent_offset(namn)
        returner _til_unix(år, 10, dag, 2, 0) - base * 60
    }
    hvis (namn == "Pacific/Auckland") {
        la dag: heltall = _finn_dag(år, 9, 0, -1)  # siste søndag september
        returner _til_unix(år, 9, dag, 2, 0) - 720 * 60
    }
    returner _til_unix(år, 3, 25, 1, 0)
}

funksjon _dst_slutt_unix(år: heltall, namn: tekst) -> heltall {
    # EU: siste søndag i oktober 01:00 UTC
    hvis (tekst_starter_med(namn, "Europe/")) {
        la dag: heltall = _finn_dag(år, 10, 0, -1)
        returner _til_unix(år, 10, dag, 1, 0)
    }
    # US: 1. søndag i november 02:00 lokal
    hvis (tekst_starter_med(namn, "America/")) {
        la dag: heltall = _finn_dag(år, 11, 0, 1)
        la base: heltall = hent_offset(namn)
        returner _til_unix(år, 11, dag, 2, 0) - (base + 60) * 60
    }
    # AU/NZ
    hvis (tekst_starter_med(namn, "Australia/")) {
        la dag: heltall = _finn_dag(år, 4, 0, 1)  # 1. søndag april
        la base: heltall = hent_offset(namn)
        returner _til_unix(år, 4, dag, 3, 0) - (base + 60) * 60
    }
    hvis (namn == "Pacific/Auckland") {
        la dag: heltall = _finn_dag(år, 4, 0, 1)
        returner _til_unix(år, 4, dag, 3, 0) - 780 * 60
    }
    returner _til_unix(år, 10, 28, 1, 0)
}

funksjon er_dst(unix: heltall, namn: tekst) -> bool {
    hvis (ikkje _brukar_dst(namn)) { returner usann }
    la ymd = _unix_til_ymd(unix)
    la år: heltall = ymd[0]
    la start: heltall = _dst_start_unix(år, namn)
    la slutt: heltall = _dst_slutt_unix(år, namn)

    # Nordleg halvkule: DST mellom start og slutt
    hvis (ikkje tekst_starter_med(namn, "Australia/") og
         namn != "Pacific/Auckland") {
        returner unix >= start og unix < slutt
    }
    # Sørlege halvkule: DST utanfor start/slutt (over nyttår)
    returner unix >= start eller unix < slutt
}

# ─── Sone-henting ─────────────────────────────────────────────────────────────

funksjon hent_offset(namn: tekst) -> heltall {
    la offsets = _sone_offsets()
    hvis (har_nokkel(offsets, namn)) { returner offsets[namn] }
    # Prøv abbreviasjonar
    la abbrev: ordbok_heltall = {}
    abbrev["CET"] = 60  abbrev["CEST"] = 120
    abbrev["EET"] = 120 abbrev["EEST"] = 180
    abbrev["WET"] = 0   abbrev["WEST"] = 60
    abbrev["MSK"] = 180 abbrev["IST"] = 330
    abbrev["JST"] = 540 abbrev["CST"] = 480
    abbrev["EST"] = -300 abbrev["EDT"] = -240
    abbrev["PST"] = -480 abbrev["PDT"] = -420
    hvis (har_nokkel(abbrev, namn)) { returner abbrev[namn] }
    returner 0  # Ukjent → UTC
}

# Hent effektivt offset med DST
funksjon effektivt_offset(unix: heltall, namn: tekst) -> heltall {
    la base: heltall = hent_offset(namn)
    hvis (er_dst(unix, namn)) { returner base + _dst_ekstra(namn) }
    returner base
}

# ─── Konvertering ─────────────────────────────────────────────────────────────

# UTC Unix-tid → lokal Unix-tid
funksjon til_lokal(unix_utc: heltall, sonnamn: tekst) -> heltall {
    la offset_min: heltall = effektivt_offset(unix_utc, sonnamn)
    returner unix_utc + offset_min * 60
}

# Lokal Unix-tid → UTC Unix-tid
funksjon til_utc(unix_lokal: heltall, sonnamn: tekst) -> heltall {
    la offset_min: heltall = effektivt_offset(unix_lokal, sonnamn)
    returner unix_lokal - offset_min * 60
}

# ─── Formatering ──────────────────────────────────────────────────────────────

funksjon _pad2(n: heltall) -> tekst {
    la t: tekst = tekst_fra_heltall(n)
    hvis (n < 10) { returner "0" + t }
    returner t
}

funksjon _pad4(n: heltall) -> tekst {
    la t: tekst = tekst_fra_heltall(n)
    mens (lengde(builtin.split(t, "")) < 4) { t = "0" + t }
    returner t
}

# Formater Unix-tid som ISO 8601 med offset
# Returnerer t.d. "2024-03-15T14:32:07+01:00"
funksjon format_iso(unix_utc: heltall, sonnamn: tekst) -> tekst {
    la offset_min: heltall = effektivt_offset(unix_utc, sonnamn)
    la lokal: heltall = unix_utc + offset_min * 60

    # Berekn dato frå lokal unix-tid
    la sek_i_dag: heltall = 86400
    la dagar: heltall = lokal / sek_i_dag
    la dag_sek: heltall = lokal % sek_i_dag
    la time: heltall = dag_sek / 3600
    la minutt: heltall = (dag_sek % 3600) / 60
    la sekund: heltall = dag_sek % 60

    # Gregorisk kalender frå dag 0 = 1970-01-01
    la år: heltall = 1970
    la d: heltall = dagar
    mens (d >= 365) {
        la di: heltall = 365
        la er_sk: bool = (år % 4 == 0 og (år % 100 != 0 eller år % 400 == 0))
        hvis (er_sk) { di = 366 }
        hvis (d < di) { d = d - 1 }
        ellers { d = d - di  år = år + 1 }
    }
    la mnd_d: liste_heltall = [31,28,31,30,31,30,31,31,30,31,30,31]
    la er_sk: bool = (år % 4 == 0 og (år % 100 != 0 eller år % 400 == 0))
    hvis (er_sk) { mnd_d[1] = 29 }
    la mnd: heltall = 0
    mens (mnd < 12 og d >= mnd_d[mnd]) { d = d - mnd_d[mnd]  mnd = mnd + 1 }

    la dato: tekst = _pad4(år) + "-" + _pad2(mnd + 1) + "-" + _pad2(d + 1)
    la kl: tekst = _pad2(time) + ":" + _pad2(minutt) + ":" + _pad2(sekund)

    # Offset-tekst
    la abs_off: heltall = offset_min
    la forteikn: tekst = "+"
    hvis (offset_min < 0) { forteikn = "-"  abs_off = 0 - offset_min }
    la off_t: tekst = forteikn + _pad2(abs_off / 60) + ":" + _pad2(abs_off % 60)

    returner dato + "T" + kl + off_t
}

# ─── Liste kjende soner ───────────────────────────────────────────────────────

funksjon alle_soner() -> liste_tekst {
    la o = _sone_offsets()
    la nøklar = builtin.nøkler(o)
    returner nøklar
}

funksjon soner_for_offset(offset_min: heltall) -> liste_tekst {
    la o = _sone_offsets()
    la nøklar = builtin.nøkler(o)
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la k: tekst = nøklar[i]
        hvis (o[k] == offset_min) { legg_til(resultat, k) }
        i = i + 1
    }
    returner resultat
}

# ─── Norsk tidssone (snarveg) ─────────────────────────────────────────────────

funksjon norsk_offset(unix: heltall) -> heltall {
    returner effektivt_offset(unix, "Europe/Oslo")
}

funksjon norsk_tid(unix_utc: heltall) -> heltall {
    returner til_lokal(unix_utc, "Europe/Oslo")
}

funksjon norsk_iso(unix_utc: heltall) -> tekst {
    returner format_iso(unix_utc, "Europe/Oslo")
}

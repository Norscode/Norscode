# Tilfeldig standardbibliotek
# Brukar ein lineær kongruensiell generator (LCG).
# Funksjoner tek frøet som argument og returnerer nytt frø —
# så tilstanden er eksplisitt og det trengst ingen global variabel.
#
# Bruk:
#   la frø: heltall = 42
#   la resultat = tilfeldig_heltall(frø, 1, 100)
#   la verdi: heltall = resultat[0]   # det tilfeldige talet
#   frø = resultat[1]                 # nytt frø til neste kall

# LCG-steg: returnerer neste frø (intern)
funksjon _neste_frø(frø: heltall) -> heltall {
    # Parametrar frå Numerical Recipes: a=1664525, c=1013904223, m=2^31
    la a: heltall = 1664525
    la c: heltall = 1013904223
    la m: heltall = 2147483648
    returner ((a * frø + c) % m)
}

# Tilfeldig heltall i [min_v, maks_v], returnerer [verdi, nytt_frø]
funksjon tilfeldig_heltall(frø: heltall, min_v: heltall, maks_v: heltall) -> liste_heltall {
    la nytt: heltall = _neste_frø(frø)
    la spenn: heltall = maks_v - min_v + 1
    la verdi: heltall = min_v + (nytt % spenn)
    la resultat: liste_heltall = []
    legg_til(resultat, verdi)
    legg_til(resultat, nytt)
    returner resultat
}

# Tilfeldig bool, returnerer [verdi_som_heltall (0/1), nytt_frø]
funksjon tilfeldig_bool(frø: heltall) -> liste_heltall {
    returner tilfeldig_heltall(frø, 0, 1)
}

# Bland ei liste (Fisher-Yates), returnerer nytt frø
funksjon bland_tall(l: liste_heltall, frø: heltall) -> heltall {
    la n: heltall = lengde(l)
    la i: heltall = n - 1
    la f: heltall = frø
    mens (i > 0) {
        la r = tilfeldig_heltall(f, 0, i)
        la j: heltall = r[0]
        f = r[1]
        la tmp: heltall = l[i]
        l[i] = l[j]
        l[j] = tmp
        i = i - 1
    }
    returner f
}

funksjon bland_tekst(l: liste_tekst, frø: heltall) -> heltall {
    la n: heltall = lengde(l)
    la i: heltall = n - 1
    la f: heltall = frø
    mens (i > 0) {
        la r = tilfeldig_heltall(f, 0, i)
        la j: heltall = r[0]
        f = r[1]
        la tmp: tekst = l[i]
        l[i] = l[j]
        l[j] = tmp
        i = i - 1
    }
    returner f
}

# ─── Normalfordeling (CLT-approksimasjon) ────────────────────────────────────
# Summerer 12 uniforme LCG-verdiar i [0, 1000] og trekker frå 6000.
# Resultatet er ≈ N(0, 1000) — dvs. N(0,1) skalert ×1000 (utan flyttal).
# Returnerer [verdi_x1000, nytt_frø]

funksjon normal_x1000(frø: heltall) -> liste_heltall {
    la f: heltall = frø
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < 12) {
        la r = tilfeldig_heltall(f, 0, 1000)
        sum = sum + r[0]
        f = r[1]
        i = i + 1
    }
    la verdi: heltall = sum - 6000  # ≈ N(0, 1000)
    la ut: liste_heltall = []
    legg_til(ut, verdi)
    legg_til(ut, f)
    returner ut
}

# Normal med gitt gjennomsnitt og standardavvik (x1000-skalerte argument)
# snitt_x1000 = snitt * 1000, sd_x1000 = standardavvik * 1000
# Returnerer [verdi, nytt_frø]
funksjon normal_med_param(frø: heltall, snitt_x1000: heltall, sd_x1000: heltall) -> liste_heltall {
    la r = normal_x1000(frø)
    la z: heltall = r[0]            # ≈ N(0,1000)
    la verdi: heltall = snitt_x1000 + z * sd_x1000 / 1000
    la ut: liste_heltall = []
    legg_til(ut, verdi)
    legg_til(ut, r[1])
    returner ut
}

# ─── Eksponentialfordeling ────────────────────────────────────────────────────
# Approksimasjon: -ln(U) / lambda via log-approksimasjon utan flyttal.
# Brukar: -ln(u) ≈ (1000 - u) * 1000 / u  for u i [1, 999] (grov approksimasjon).
# Returnerer [verdi (i einingar 1/lambda), nytt_frø]

funksjon eksponential(frø: heltall, lambda_x1000: heltall) -> liste_heltall {
    la r = tilfeldig_heltall(frø, 1, 999)
    la u: heltall = r[0]
    # -ln(u/1000) ≈ (1000 - u) * 1000 / u  (første-ordens approksimasjon)
    la neg_ln: heltall = (1000 - u) * 1000 / u
    # verdi = neg_ln / lambda_x1000  (lambda_x1000 = lambda * 1000)
    la verdi: heltall = neg_ln * 1000 / lambda_x1000
    la ut: liste_heltall = []
    legg_til(ut, verdi)
    legg_til(ut, r[1])
    returner ut
}

# ─── Vekta tilfeldig val ──────────────────────────────────────────────────────
# Vel ein indeks frå [0, lengde(vekter)-1] med sannsynleg proporsjonal med vekt.
# vekter: liste_heltall med ikkje-negative heiltalsvekter.
# Returnerer [indeks, nytt_frø]

funksjon vekta_val(frø: heltall, vekter: liste_heltall) -> liste_heltall {
    la total: heltall = 0
    la i: heltall = 0
    mens (i < lengde(vekter)) {
        total = total + vekter[i]
        i = i + 1
    }
    la r = tilfeldig_heltall(frø, 0, total - 1)
    la tall: heltall = r[0]
    la nytt_frø: heltall = r[1]

    la akkumulert: heltall = 0
    i = 0
    mens (i < lengde(vekter)) {
        akkumulert = akkumulert + vekter[i]
        hvis (tall < akkumulert) {
            la ut: liste_heltall = []
            legg_til(ut, i)
            legg_til(ut, nytt_frø)
            returner ut
        }
        i = i + 1
    }
    # Fallback (bør ikkje skje)
    la ut: liste_heltall = []
    legg_til(ut, lengde(vekter) - 1)
    legg_til(ut, nytt_frø)
    returner ut
}

# Vel eit tilfeldig element frå ei liste med heltall, like vekter
funksjon vel_frå_tall(frø: heltall, l: liste_heltall) -> liste_heltall {
    la r = tilfeldig_heltall(frø, 0, lengde(l) - 1)
    la ut: liste_heltall = []
    legg_til(ut, l[r[0]])
    legg_til(ut, r[1])
    returner ut
}

# Vel eit tilfeldig element frå ei liste med tekst, like vekter
funksjon vel_frå_tekst(frø: heltall, l: liste_tekst) -> liste_heltall {
    la r = tilfeldig_heltall(frø, 0, lengde(l) - 1)
    # Returnerer [indeks, nytt_frø] — kall l[resultat[0]] for å hente tekst
    returner r
}

# ─── Geometrisk fordeling ─────────────────────────────────────────────────────
# Antal forsøk til første suksess, p = p_x1000 / 1000.
# Returnerer [antal_forsøk, nytt_frø]

funksjon geometrisk(frø: heltall, p_x1000: heltall) -> liste_heltall {
    la f: heltall = frø
    la forsøk: heltall = 0
    la ferdig: bool = usann
    mens (ikkje ferdig) {
        la r = tilfeldig_heltall(f, 0, 999)
        forsøk = forsøk + 1
        f = r[1]
        hvis (r[0] < p_x1000) { ferdig = sann }
    }
    la ut: liste_heltall = []
    legg_til(ut, forsøk)
    legg_til(ut, f)
    returner ut
}

# ─── Sampel utan attleggjing ──────────────────────────────────────────────────
# Trekkjer k unike indeksar frå [0, n-1].
# Returnerer [idx0, idx1, ..., idxk-1, nytt_frø] (flatt)

funksjon sampel_utan_attleggjing(frø: heltall, n: heltall, k: heltall) -> liste_heltall {
    # Lag indeksliste, bland, ta dei k første
    la indeksar: liste_heltall = []
    la i: heltall = 0
    mens (i < n) { legg_til(indeksar, i)  i = i + 1 }
    la f: heltall = bland_tall(indeksar, frø)
    la ut: liste_heltall = []
    i = 0
    mens (i < k og i < n) {
        legg_til(ut, indeksar[i])
        i = i + 1
    }
    legg_til(ut, f)
    returner ut
}

# Filstandardbibliotek

funksjon les(sti: tekst) -> tekst {
    prøv {
        returner fil_les(sti)
    } fang (e) {
        kast "IOFeil: kunne ikkje lese fil '" + sti + "': " + e
    }
    returner ""
}

funksjon skriv_fil(sti: tekst, innhold: tekst) -> tekst {
    returner fil_skriv(sti, innhold)
}

funksjon append(sti: tekst, innhold: tekst) -> tekst {
    returner fil_append(sti, innhold)
}

funksjon finnes(sti: tekst) -> bool {
    returner fil_finnes(sti)
}

# Les alle linjer til ei liste_tekst
funksjon les_linjer(sti: tekst) -> liste_tekst {
    la innhold: tekst = les(sti)
    returner builtin.split(innhold, "\n")
}

# Skriv liste_tekst som linjer (éin per linje)
funksjon skriv_linjer(sti: tekst, linjer: liste_tekst) -> tekst {
    la innhold: tekst = builtin.join(linjer, "\n")
    returner fil_skriv(sti, innhold)
}

# Legg til ei linje på slutten av fila
funksjon legg_til_linje(sti: tekst, linje: tekst) -> tekst {
    returner fil_append(sti, linje + "\n")
}

# Les fil og parse JSON
funksjon les_json(sti: tekst) -> ordbok_tekst {
    la innhold: tekst = les(sti)
    returner builtin.json_parse(innhold)
}

# Skriv ordbok som JSON-fil
funksjon skriv_json(sti: tekst, data: ordbok_tekst) -> tekst {
    la innhold: tekst = builtin.json_stringify(data)
    returner fil_skriv(sti, innhold)
}

# Kopier fil frå kjelde til mål
funksjon kopier(frå: tekst, til: tekst) -> tekst {
    la innhold: tekst = les(frå)
    returner fil_skriv(til, innhold)
}

# Les fil, returnerer tom tekst viss ikkje funne (trygg versjon)
funksjon les_eller_tom(sti: tekst) -> tekst {
    hvis (ikkje fil_finnes(sti)) { returner "" }
    returner les(sti)
}

# Skriv berre viss innhaldet har endra seg (unngår unødige skrivar)
funksjon skriv_viss_endra(sti: tekst, nytt_innhold: tekst) -> bool {
    hvis (fil_finnes(sti)) {
        la eksisterande: tekst = les(sti)
        hvis (eksisterande == nytt_innhold) { returner usann }
    }
    fil_skriv(sti, nytt_innhold)
    returner sann
}

# Tel linjer i fil
funksjon tel_linjer(sti: tekst) -> heltall {
    la linjer = les_linjer(sti)
    returner lengde(linjer)
}

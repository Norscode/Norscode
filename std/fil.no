# Filstandardbibliotek

funksjon les(sti: tekst) -> tekst {
    prøv {
        returner fil_les(sti)
    } fang (e) {
        kast "IOFeil: kunne ikkje lese fil '" + sti + "': " + e
    }
    returner ""
}

funksjon skriv_fil(sti: tekst, innhold: tekst) -> tekst {
    returner fil_skriv(sti, innhold)
}

funksjon append(sti: tekst, innhold: tekst) -> tekst {
    returner fil_append(sti, innhold)
}

funksjon finnes(sti: tekst) -> bool {
    returner fil_finnes(sti)
}

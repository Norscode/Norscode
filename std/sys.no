# sys.no — Systemparametrar og køyretids-informasjon
# Python: sys
#
# Tilgang til tolk-variablar og systemfunksjonar.
# Hentar rå systemverdiar ved OS-grensa, men reknar argv/path/prefix og
# standardstraumar i Norscode utan shell-dirname eller echo-fallback.
#
# Bruk:
#   bruk std.sys som sys
#   skriv sys.versjon()
#   skriv sys.platform()
#   la args = sys.argv()
#   sys.exit(0)

# ─── Versjon og plattform ─────────────────────────────────────────────────────

funksjon versjon() -> tekst {
    returner "Norscode 1.0.0"
}

funksjon versjon_info() -> ordbok_tekst {
    la info: ordbok_tekst = {}
    info["major"] = "1"
    info["minor"] = "0"
    info["micro"] = "0"
    info["releaselevel"] = "final"
    info["serial"] = "0"
    returner info
}

funksjon platform() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -s 2>/dev/null")
        la delar = builtin.split(res, "\n")
        la s: tekst = _trim(delar[0])
        hvis (s == "Darwin") { returner "darwin" }
        hvis (s == "Linux")  { returner "linux" }
        returner "unknown"
    } fang (e) {
        returner "unknown"
    }
    returner "unknown"
}

funksjon implementation() -> ordbok_tekst {
    la info: ordbok_tekst = {}
    info["name"] = "Norscode"
    info["version"] = "1.0.0"
    returner info
}

# ─── Kommandolinje-argument ────────────────────────────────────────────────────

# Returnerer kommandolinjeargument (henta frå miljøvariabelen NORSCODE_ARGV)
funksjon argv() -> liste_tekst {
    prøv {
        la argv_json: tekst = builtin.miljo_hent("NORSCODE_ARGV")
        la args = builtin.json_parse(argv_json)
        returner args
    } fang (e) {
        returner []
    }
    returner []
}

# Hent eitt spesifikt argument (0-indeksert)
funksjon argv_get(n: heltall) -> tekst {
    la args = argv()
    la l: heltall = lengde(args)
    hvis (n < 0 eller n >= l) { returner "" }
    returner args[n]
}

# ─── Veg (sys.path) ───────────────────────────────────────────────────────────

funksjon path() -> liste_tekst {
    prøv {
        la p: tekst = builtin.miljo_hent("NORSCODE_PATH")
        returner builtin.json_parse(p)
    } fang (e) {
        la std_sti: tekst = "./std"
        prøv {
            la home: tekst = builtin.miljo_hent("HOME")
            returner [std_sti, home + "/.norscode/lib", "/usr/local/lib/norscode"]
        } fang (e2) {
            returner [std_sti]
        }
    }
    returner ["./std"]
}

funksjon path_legg_til(sti: tekst) {
    # Kan ikkje faktisk endre søkjevegen i runtime, men registrerer i env
    prøv {
        la noverande_json: tekst = builtin.miljo_hent("NORSCODE_PATH")
        la noverande = builtin.json_parse(noverande_json)
        legg_til(noverande, sti)
        # I praksis: informer brukar
    } fang (e) {}
}

# ─── Modulregister (sys.modules) ──────────────────────────────────────────────

la _moduler: ordbok_tekst = {}

funksjon register_modul(namn: tekst, sti: tekst) {
    _moduler[namn] = sti
}

funksjon modul_finst(namn: tekst) -> bool {
    la nøklar = builtin.nøklar(_moduler)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        hvis (nøklar[i] == namn) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon alle_moduler() -> liste_tekst {
    returner builtin.nøklar(_moduler)
}

# ─── Standardstraumar (stdin/stdout/stderr) ───────────────────────────────────

# Skriv til stdout (Norscode brukar innebygd skriv, men dette gjev eit objekt)
funksjon stdout() -> ordbok_tekst {
    la f: ordbok_tekst = {}
    f["_type"] = "straum"
    f["namn"] = "stdout"
    f["fn_skriv"] = "builtin.skriv"
    returner f
}

funksjon stderr() -> ordbok_tekst {
    la f: ordbok_tekst = {}
    f["_type"] = "straum"
    f["namn"] = "stderr"
    f["fn_skriv"] = "builtin.feil"
    returner f
}

funksjon stdin() -> ordbok_tekst {
    la f: ordbok_tekst = {}
    f["_type"] = "straum"
    f["namn"] = "stdin"
    returner f
}

# Les éi linje frå stdin.
# Dette er den minimale leseprimitiven som resten av verktøykjeda kan bygge vidare på.
funksjon stdin_linje() -> tekst {
    prøv {
        returner builtin.readline()
    } fang (e) {
        returner ""
    }
}

funksjon stdin_les() -> tekst {
    returner stdin_linje()
}

# Skriv til ein straum
funksjon straum_skriv(straum: ordbok_tekst, innhald: tekst) {
    # I praksis: skriv berre til stdout
    skriv innhald
}

# ─── Avslutning ───────────────────────────────────────────────────────────────

funksjon exit(kode: heltall) {
    # Norscode kan ikkje faktisk kalle exit(), men kan kaste eit spesielt unntak
    kast "SystemExit:" + tekst_fra_heltall(kode)
}

funksjon exit_ok() {
    exit(0)
}

funksjon exit_feil() {
    exit(1)
}

# ─── Minnegrenser og rekkursjon ───────────────────────────────────────────────

# Maks heltall (63-bit positiv)
la maxsize: heltall = 9223372036854775807

# Maks rekkursjonsdjup (Norscode-spesifikk)
la max_rekkursjon: heltall = 1000

funksjon getrecursionlimit() -> heltall {
    returner max_rekkursjon
}

funksjon setrecursionlimit(n: heltall) {
    max_rekkursjon = n
}

# ─── Unntak-informasjon (sys.exc_info-mønster) ─────────────────────────────────

la _siste_unntak: tekst = ""
la _siste_type: tekst = ""

funksjon set_exc_info(type: tekst, verdi: tekst) {
    _siste_unntak = verdi
    _siste_type = type
}

funksjon exc_info() -> ordbok_tekst {
    la info: ordbok_tekst = {}
    info["type"] = _siste_type
    info["verdi"] = _siste_unntak
    info["traceback"] = ""
    returner info
}

funksjon last_exception() -> tekst {
    returner _siste_unntak
}

# ─── Systeminformasjon ────────────────────────────────────────────────────────

funksjon byteorder() -> tekst {
    # Stage-0 Norscode-runtime er definert for little-endian native mål.
    returner "little"
}

funksjon cpu_count() -> heltall {
    prøv {
        la res = builtin.exec_prosess("nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null")
        la delar = builtin.split(res, "\n")
        la n: heltall = builtin.heltall_fra_tekst(_trim(delar[0]))
        returner n
    } fang (e) {
        returner 1
    }
    returner 1
}

funksjon intern_encoding() -> tekst {
    prøv {
        la res = builtin.miljo_hent("LANG")
        la delar = builtin.split(res, ".")
        hvis (lengde(delar) > 1) { returner delar[1] }
    } fang (e) {}
    returner "UTF-8"
}

funksjon getfilesystemencoding() -> tekst {
    returner intern_encoding()
}

# ─── Flagg og konfigurasjon ───────────────────────────────────────────────────

la _flags: ordbok_tekst = {}

funksjon set_flag(namn: tekst, verdi: tekst) {
    _flags[namn] = verdi
}

funksjon get_flag(namn: tekst) -> tekst {
    prøv { returner _flags[namn] } fang (e) { returner "" }
    returner ""
}

# Kjente flagg (tilsv. sys.flags)
funksjon er_debug_modus() -> bool {
    la debug: tekst = get_flag("debug")
    returner debug == "sann"
}

funksjon er_verbose() -> bool {
    la v: tekst = get_flag("verbose")
    returner v == "sann"
}

# ─── Tolk-info ────────────────────────────────────────────────────────────────

funksjon executable() -> tekst {
    prøv {
        la funnen: tekst = _which_norscode()
        hvis (funnen != "") { returner funnen }
    } fang (e) {
        returner "./norscode"
    }
    returner "./norscode"
}

funksjon prefix() -> tekst {
    prøv {
        la funnen: tekst = _which_norscode()
        hvis (funnen != "") { returner _dirname(funnen) }
    } fang (e) {
        returner "/usr/local"
    }
    returner "/usr/local"
}

# ─── Hjelp og info ───────────────────────────────────────────────────────────

funksjon copyright() -> tekst {
    returner "Norscode 1.0.0. Rettane tilhøyrer Norscode-prosjektet."
}

funksjon builtin_module_names() -> liste_tekst {
    returner ["builtin", "json", "os", "sys", "io"]
}

# Systeminformasjon-samling
funksjon info() -> ordbok_tekst {
    la i: ordbok_tekst = {}
    i["versjon"]  = versjon()
    i["platform"] = platform()
    i["encoding"] = intern_encoding()
    i["byteorder"] = byteorder()
    returner i
}

# ─── Intern hjelp ─────────────────────────────────────────────────────────────

funksjon _which_norscode() -> tekst {
    prøv {
        la res = builtin.exec_prosess("which norscode 2>/dev/null")
        la delar = builtin.split(res, "\n")
        returner _trim(delar[0])
    } fang (e) {}
    returner ""
}

funksjon _dirname(sti: tekst) -> tekst {
    la teikn = builtin.split(sti, "")
    la sist: heltall = -1
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        hvis (teikn[i] == "/") { sist = i }
        i = i + 1
    }
    hvis (sist <= 0) {
        hvis (lengde(teikn) > 0 og teikn[0] == "/") { returner "/" }
        returner "."
    }
    returner builtin.join(builtin.slice(teikn, 0, sist), "")
}

funksjon _trim(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la start: heltall = 0
    la slutt: heltall = n
    mens (start < slutt og (teikn[start] == " " eller teikn[start] == "\t" eller teikn[start] == "\n" eller teikn[start] == "\r")) {
        start = start + 1
    }
    mens (slutt > start og (teikn[slutt-1] == " " eller teikn[slutt-1] == "\t" eller teikn[slutt-1] == "\n" eller teikn[slutt-1] == "\r")) {
        slutt = slutt - 1
    }
    returner builtin.join(builtin.slice(teikn, start, slutt), "")
}

# errno.no — POSIX-feilnummerkonstantar
# Python: errno
#
# Alle standardiserte POSIX-feilkodar med namn og beskriving.
# Feilmeldingar kjem frå innebygd Norscode-tabell.
#
# Bruk:
#   bruk std.errno som err
#   skriv err.ENOENT       # → 2
#   skriv err.strerror(2)  # → "No such file or directory"
#   skriv err.errorcode(2) # → "ENOENT"

# ─── Standard POSIX-feilkodar ─────────────────────────────────────────────────

la EPERM:   heltall = 1   # Operation not permitted
la ENOENT:  heltall = 2   # No such file or directory
la ESRCH:   heltall = 3   # No such process
la EINTR:   heltall = 4   # Interrupted system call
la EIO:     heltall = 5   # Input/output error
la ENXIO:   heltall = 6   # No such device or address
la E2BIG:   heltall = 7   # Argument list too long
la ENOEXEC: heltall = 8   # Exec format error
la EBADF:   heltall = 9   # Bad file descriptor
la ECHILD:  heltall = 10  # No child processes
la EAGAIN:  heltall = 11  # Resource temporarily unavailable
la ENOMEM:  heltall = 12  # Cannot allocate memory
la EACCES:  heltall = 13  # Permission denied
la EFAULT:  heltall = 14  # Bad address
la EBUSY:   heltall = 16  # Device or resource busy
la EEXIST:  heltall = 17  # File exists
la EXDEV:   heltall = 18  # Invalid cross-device link
la ENODEV:  heltall = 19  # No such device
la ENOTDIR: heltall = 20  # Not a directory
la EISDIR:  heltall = 21  # Is a directory
la EINVAL:  heltall = 22  # Invalid argument
la ENFILE:  heltall = 23  # Too many open files in system
la EMFILE:  heltall = 24  # Too many open files
la ENOTTY:  heltall = 25  # Inappropriate ioctl for device
la EFBIG:   heltall = 27  # File too large
la ENOSPC:  heltall = 28  # No space left on device
la ESPIPE:  heltall = 29  # Illegal seek
la EROFS:   heltall = 30  # Read-only file system
la EMLINK:  heltall = 31  # Too many links
la EPIPE:   heltall = 32  # Broken pipe
la EDOM:    heltall = 33  # Numerical argument out of domain
la ERANGE:  heltall = 34  # Numerical result out of range
la EDEADLK: heltall = 35  # Resource deadlock avoided
la ENAMETOOLONG: heltall = 36  # File name too long
la ENOLCK:  heltall = 37  # No locks available
la ENOSYS:  heltall = 38  # Function not implemented
la ENOTEMPTY: heltall = 39 # Directory not empty
la ELOOP:   heltall = 40  # Too many levels of symbolic links
la EWOULDBLOCK: heltall = 11  # Same as EAGAIN
la ENOMSG:  heltall = 42  # No message of desired type
la EIDRM:   heltall = 43  # Identifier removed
la ENOSTR:  heltall = 60  # Device not a stream
la ENODATA: heltall = 61  # No data available
la ETIME:   heltall = 62  # Timer expired
la ENOSR:   heltall = 63  # Out of streams resources
la EREMOTE: heltall = 66  # Object is remote
la ENOLINK: heltall = 67  # Link has been severed
la EPROTO:  heltall = 71  # Protocol error
la EMULTIHOP: heltall = 72 # Multihop attempted
la EBADMSG: heltall = 74  # Bad message
la EOVERFLOW: heltall = 75 # Value too large for defined data type
la EILSEQ:  heltall = 84  # Invalid or incomplete multibyte or wide character
la EUSERS:  heltall = 87  # Too many users
la ENOTSOCK: heltall = 88 # Socket operation on non-socket
la EDESTADDRREQ: heltall = 89 # Destination address required
la EMSGSIZE: heltall = 90 # Message too long
la EPROTOTYPE: heltall = 91 # Protocol wrong type for socket
la ENOPROTOOPT: heltall = 92 # Protocol not available
la EPROTONOSUPPORT: heltall = 93 # Protocol not supported
la ESOCKTNOSUPPORT: heltall = 94 # Socket type not supported
la EOPNOTSUPP: heltall = 95 # Operation not supported
la EAFNOSUPPORT: heltall = 97 # Address family not supported
la EADDRINUSE: heltall = 98 # Address already in use
la EADDRNOTAVAIL: heltall = 99 # Cannot assign requested address
la ENETDOWN: heltall = 100 # Network is down
la ENETUNREACH: heltall = 101 # Network is unreachable
la ENETRESET: heltall = 102 # Network dropped connection on reset
la ECONNABORTED: heltall = 103 # Software caused connection abort
la ECONNRESET: heltall = 104 # Connection reset by peer
la ENOBUFS: heltall = 105 # No buffer space available
la EISCONN:  heltall = 106 # Transport endpoint is already connected
la ENOTCONN: heltall = 107 # Transport endpoint is not connected
la ESHUTDOWN: heltall = 108 # Cannot send after transport endpoint shutdown
la ETIMEDOUT: heltall = 110 # Connection timed out
la ECONNREFUSED: heltall = 111 # Connection refused
la EHOSTDOWN: heltall = 112 # Host is down
la EHOSTUNREACH: heltall = 113 # No route to host
la EALREADY: heltall = 114 # Operation already in progress
la EINPROGRESS: heltall = 115 # Operation now in progress
la ESTALE:  heltall = 116 # Stale file handle
la ECANCELED: heltall = 125 # Operation canceled
la EOWNERDEAD: heltall = 130 # Owner died
la ENOTRECOVERABLE: heltall = 131 # State not recoverable

# ─── Oppslag ──────────────────────────────────────────────────────────────────

# Hent standard feilmelding for feilkode
funksjon strerror(kode: heltall) -> tekst {
    returner _innebygd_melding(kode)
}

# Hent feilkode-namn (t.d. 2 → "ENOENT")
funksjon errorcode(kode: heltall) -> tekst {
    la tabell = _kode_tabell()
    la nøklar = builtin.nøklar(tabell)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la nk: tekst = nøklar[i]
        la verdi: tekst = tabell[nk]
        prøv {
            la v: heltall = builtin.heltall_fra_tekst(verdi)
            hvis (v == kode) { returner nk }
        } fang (e) {}
        i = i + 1
    }
    returner "E" + tekst_fra_heltall(kode)
}

# Hent kode frå namn (t.d. "ENOENT" → 2)
funksjon namntil_kode(namn: tekst) -> heltall {
    la tabell = _kode_tabell()
    prøv {
        returner builtin.heltall_fra_tekst(tabell[namn])
    } fang (e) {
        returner -1
    }
    returner -1
}

# Alle kjente feilkodar som ordbok {namn → kode}
funksjon alle_kodar() -> ordbok_tekst {
    returner _kode_tabell()
}

# ─── Samanlikning og sjekk ────────────────────────────────────────────────────

funksjon er_fil_feil(kode: heltall) -> bool {
    returner kode == ENOENT eller kode == ENOTDIR eller kode == EISDIR eller
             kode == EACCES eller kode == EPERM eller kode == EROFS
}

funksjon er_nett_feil(kode: heltall) -> bool {
    returner kode == ECONNREFUSED eller kode == ETIMEDOUT eller kode == ENETUNREACH eller
             kode == ENOTCONN eller kode == ECONNRESET eller kode == EHOSTUNREACH
}

funksjon er_tilgang_feil(kode: heltall) -> bool {
    returner kode == EACCES eller kode == EPERM
}

funksjon er_ressurs_feil(kode: heltall) -> bool {
    returner kode == ENOMEM eller kode == ENOSPC eller kode == EMFILE eller kode == ENFILE
}

# ─── Feil-objekt (for bruk med kast/fang) ─────────────────────────────────────

funksjon ny_feil(kode: heltall) -> ordbok_tekst {
    la feil: ordbok_tekst = {}
    feil["kode"]    = tekst_fra_heltall(kode)
    feil["namn"]    = errorcode(kode)
    feil["melding"] = strerror(kode)
    feil["_type"]   = "OSError"
    returner feil
}

funksjon feil_repr(feil: ordbok_tekst) -> tekst {
    returner "[Errno " + feil["kode"] + "] " + feil["melding"]
}

# ─── Intern tabell ────────────────────────────────────────────────────────────

funksjon _kode_tabell() -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["EPERM"]   = "1"   t["ENOENT"] = "2"   t["ESRCH"]  = "3"
    t["EINTR"]   = "4"   t["EIO"]    = "5"   t["ENXIO"]  = "6"
    t["E2BIG"]   = "7"   t["ENOEXEC"] = "8"  t["EBADF"]  = "9"
    t["ECHILD"]  = "10"  t["EAGAIN"] = "11"  t["ENOMEM"] = "12"
    t["EACCES"]  = "13"  t["EFAULT"] = "14"  t["EBUSY"]  = "16"
    t["EEXIST"]  = "17"  t["EXDEV"]  = "18"  t["ENODEV"] = "19"
    t["ENOTDIR"] = "20"  t["EISDIR"] = "21"  t["EINVAL"] = "22"
    t["ENFILE"]  = "23"  t["EMFILE"] = "24"  t["ENOTTY"] = "25"
    t["EFBIG"]   = "27"  t["ENOSPC"] = "28"  t["ESPIPE"] = "29"
    t["EROFS"]   = "30"  t["EMLINK"] = "31"  t["EPIPE"]  = "32"
    t["EDOM"]    = "33"  t["ERANGE"] = "34"  t["EDEADLK"] = "35"
    t["ENAMETOOLONG"] = "36"  t["ENOLCK"] = "37"  t["ENOSYS"] = "38"
    t["ENOTEMPTY"] = "39"  t["ELOOP"] = "40"  t["ENOMSG"] = "42"
    t["ENOTSOCK"] = "88"  t["ECONNREFUSED"] = "111"  t["ETIMEDOUT"] = "110"
    t["ECONNRESET"] = "104"  t["EADDRINUSE"] = "98"  t["EACCES"] = "13"
    t["ENETUNREACH"] = "101"  t["EHOSTUNREACH"] = "113"  t["EINPROGRESS"] = "115"
    t["EALREADY"] = "114"  t["ENOTCONN"] = "107"  t["ENOBUFS"] = "105"
    t["OVERFLOW"] = "75"  t["ECANCELED"] = "125"
    returner t
}

funksjon _innebygd_melding(kode: heltall) -> tekst {
    la meldingar: ordbok_tekst = {}
    meldingar["1"]  = "Operation not permitted"
    meldingar["2"]  = "No such file or directory"
    meldingar["3"]  = "No such process"
    meldingar["4"]  = "Interrupted system call"
    meldingar["5"]  = "Input/output error"
    meldingar["6"]  = "No such device or address"
    meldingar["7"]  = "Argument list too long"
    meldingar["8"]  = "Exec format error"
    meldingar["9"]  = "Bad file descriptor"
    meldingar["10"] = "No child processes"
    meldingar["11"] = "Resource temporarily unavailable"
    meldingar["12"] = "Cannot allocate memory"
    meldingar["13"] = "Permission denied"
    meldingar["14"] = "Bad address"
    meldingar["16"] = "Device or resource busy"
    meldingar["17"] = "File exists"
    meldingar["18"] = "Invalid cross-device link"
    meldingar["19"] = "No such device"
    meldingar["20"] = "Not a directory"
    meldingar["21"] = "Is a directory"
    meldingar["22"] = "Invalid argument"
    meldingar["23"] = "Too many open files in system"
    meldingar["24"] = "Too many open files"
    meldingar["27"] = "File too large"
    meldingar["28"] = "No space left on device"
    meldingar["29"] = "Illegal seek"
    meldingar["30"] = "Read-only file system"
    meldingar["31"] = "Too many links"
    meldingar["32"] = "Broken pipe"
    meldingar["33"] = "Numerical argument out of domain"
    meldingar["34"] = "Numerical result out of range"
    meldingar["36"] = "File name too long"
    meldingar["38"] = "Function not implemented"
    meldingar["39"] = "Directory not empty"
    meldingar["40"] = "Too many levels of symbolic links"
    meldingar["75"] = "Value too large for defined data type"
    meldingar["88"] = "Socket operation on non-socket"
    meldingar["98"] = "Address already in use"
    meldingar["101"] = "Network is unreachable"
    meldingar["104"] = "Connection reset by peer"
    meldingar["105"] = "No buffer space available"
    meldingar["107"] = "Transport endpoint is not connected"
    meldingar["110"] = "Connection timed out"
    meldingar["111"] = "Connection refused"
    meldingar["113"] = "No route to host"
    meldingar["114"] = "Operation already in progress"
    meldingar["115"] = "Operation now in progress"
    meldingar["125"] = "Operation canceled"

    la kode_str: tekst = tekst_fra_heltall(kode)
    prøv {
        returner meldingar[kode_str]
    } fang (e) {
        returner "Unknown error " + kode_str
    }
    returner "Unknown error"
}

funksjon _trim(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la start: heltall = 0
    la slutt: heltall = n
    mens (start < slutt og (teikn[start] == " " eller teikn[start] == "\t" eller teikn[start] == "\n" eller teikn[start] == "\r")) {
        start = start + 1
    }
    mens (slutt > start og (teikn[slutt-1] == " " eller teikn[slutt-1] == "\t" eller teikn[slutt-1] == "\n" eller teikn[slutt-1] == "\r")) {
        slutt = slutt - 1
    }
    returner builtin.join(builtin.slice(teikn, start, slutt), "")
}

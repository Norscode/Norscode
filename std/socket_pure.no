# socket_pure.no — 100% Pure Norscode Socket Implementation
# No Python, No C, Pure Norscode TCP/HTTP abstraction
#
# Denne implementasjonen er skrevet heilt i Norscode
# og kan erstatte Python-wrapperen fullstendig
#
# Bruk:
#   bruk std.socket_pure som sock
#   la server = sock.ny_server(8000)
#   returner sock.kjor_server(server)

# ─── Socket Types ───────────────────────────────────────────────────────────

funksjon ny_server(port: heltall) -> ordbok_tekst {
    la server: ordbok_tekst = {}
    server["port"] = port
    server["port_str"] = tekst(port)
    server["host"] = "127.0.0.1"
    server["routes"] = {}
    server["is_running"] = sant
    server["requests_total"] = 0
    server["uptime_start"] = "2026-06-14T00:00:00Z"
    returner server
}

funksjon ny_request(metode: tekst, sti: tekst, headers: ordbok_tekst, body: tekst) -> ordbok_tekst {
    la req: ordbok_tekst = {}
    req["metode"] = metode
    req["sti"] = sti
    req["headers"] = headers
    req["body"] = body
    req["timestamp"] = "2026-06-14T12:00:00Z"
    returner req
}

funksjon ny_response(status: heltall, headers: ordbok_tekst, body: tekst) -> ordbok_tekst {
    la resp: ordbok_tekst = {}
    resp["status"] = status
    resp["status_text"] = hvis status == 200 { "OK" } ellers hvis status == 404 { "Not Found" } ellers { "Error" }
    resp["headers"] = headers
    resp["body"] = body
    returner resp
}

# ─── Route Registration ──────────────────────────────────────────────────────

funksjon route(server: ordbok_tekst, metode: tekst, sti: tekst, handler_namn: tekst) -> ordbok_tekst {
    la nøkkel = metode + " " + sti
    server["routes"][nøkkel] = handler_namn
    returner server
}

# ─── HTTP Request Parsing (Pure Norscode) ────────────────────────────────────

funksjon parse_http_request_raw(raw_data: tekst) -> ordbok_tekst {
    // Parse raw HTTP request without external dependencies

    la linjer = builtin.split(raw_data, "\n")
    hvis lengde(linjer) < 1 {
        returner {}
    }

    // Parse request line: "GET /path HTTP/1.1"
    la request_linje = builtin.trim(linjer[0])
    la deler = builtin.split(request_linje, " ")

    hvis lengde(deler) < 3 {
        returner {}
    }

    la metode = deler[0]
    la sti_og_query = deler[1]

    // Parse sti og query
    la spørsmål_pos = builtin.index_of(sti_og_query, "?")
    la sti: tekst = ""
    la query_str: tekst = ""

    hvis spørsmål_pos >= 0 {
        sti = builtin.slice(sti_og_query, 0, spørsmål_pos)
        query_str = builtin.slice(sti_og_query, spørsmål_pos + 1, lengde(sti_og_query))
    } ellers {
        sti = sti_og_query
    }

    // Parse headers
    la headers: ordbok_tekst = {}
    la i: heltall = 1
    la body_start: heltall = 0

    mens i < lengde(linjer) {
        la linje = builtin.trim(linjer[i])

        hvis linje == "" {
            body_start = i + 1
            i = lengde(linjer)  // Break
        } ellers {
            la kolon_pos = builtin.index_of(linje, ":")
            hvis kolon_pos > 0 {
                la nøkkel = tekst_til_liten(builtin.slice(linje, 0, kolon_pos))
                la verdi = builtin.trim(builtin.slice(linje, kolon_pos + 1, lengde(linje)))
                headers[nøkkel] = verdi
            }
        }

        i = i + 1
    }

    // Parse body
    la body: tekst = ""
    i = body_start
    mens i < lengde(linjer) {
        body = body + linjer[i]
        hvis i < lengde(linjer) - 1 {
            body = body + "\n"
        }
        i = i + 1
    }

    // Build request object
    la req = ny_request(metode, sti, headers, builtin.trim(body))
    returner req
}

# ─── Response Building (Pure Norscode) ────────────────────────────────────────

funksjon build_http_response(status: heltall, body: tekst) -> tekst {
    la status_text: tekst = hvis status == 200 { "OK" } ellers hvis status == 404 { "Not Found" } ellers { "Error" }

    la response: tekst = ""
    response = response + "HTTP/1.1 " + tekst(status) + " " + status_text + "\r\n"
    response = response + "Content-Type: application/json\r\n"
    response = response + "Content-Length: " + tekst(lengde(body)) + "\r\n"
    response = response + "Connection: close\r\n"
    response = response + "Access-Control-Allow-Origin: *\r\n"
    response = response + "\r\n"
    response = response + body

    returner response
}

# ─── Request Router (Pure Norscode) ────────────────────────────────────────────

funksjon route_request(server: ordbok_tekst, metode: tekst, sti: tekst) -> tekst {
    // Route request to handler based on path

    la routes = server["routes"]
    la nøkkel = metode + " " + sti

    // Exact match
    hvis har_nokkel(routes, nøkkel) {
        returner routes[nøkkel]
    }

    // Pattern match for {id:int}
    la rute_nøklar = nøkler(routes)
    la i: heltall = 0

    mens i < lengde(rute_nøklar) {
        la rute = rute_nøklar[i]
        hvis _rute_matcher(rute, metode, sti) {
            returner routes[rute]
        }
        i = i + 1
    }

    returner ""
}

funksjon _rute_matcher(rute_mønster: tekst, metode: tekst, sti: tekst) -> boolsk {
    la deler = builtin.split(rute_mønster, " ")
    hvis lengde(deler) < 2 {
        returner usann
    }

    la rute_metode = deler[0]
    la rute_sti = deler[1]

    hvis rute_metode != metode {
        returner usann
    }

    // Simple pattern: /users/{id:int} matches /users/123
    la mønster = rute_sti
    mønster = builtin.replace(mønster, "{id:int}", "[0-9]+")
    mønster = builtin.replace(mønster, "{id}", "[^/]+")

    returner _enkel_match(mønster, sti)
}

funksjon _enkel_match(mønster: tekst, tekst: tekst) -> boolsk {
    hvis mønster == tekst {
        returner sant
    }

    la wildcard = builtin.index_of(mønster, "[")
    hvis wildcard < 0 {
        returner usann
    }

    la prefiks = builtin.slice(mønster, 0, wildcard)
    returner tekst_starter_med(tekst, prefiks)
}

# ─── Server Execution (Pure Norscode) ──────────────────────────────────────────

funksjon kjor_server(server: ordbok_tekst) -> heltall {
    la port_str = server["port_str"]
    la port: heltall = builtin.heltall_fra_tekst(port_str)
    la host = server["host"]

    // Åpne server-socket
    la srv = builtin.socket_listen(host, port)
    hvis srv < 0 {
        skriv("FEIL: Kunne ikke åpne port " + port_str)
        returner 1
    }

    // Banner
    skriv("")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("Norscode Pure Native HTTP Server")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("")
    skriv("📍 http://" + host + ":" + port_str)
    skriv("🚀 Mode:   100% Pure Norscode (no Python, no dependencies)")
    skriv("")
    skriv("🔗 Registrerte ruter:")
    la route_keys = nøkler(server["routes"])
    la ri: heltall = 0
    mens ri < lengde(route_keys) {
        skriv("   " + route_keys[ri])
        ri = ri + 1
    }
    skriv("")
    skriv("────────────────────────────────────────────────────────────────")
    skriv("")

    // Hovedløkke
    la running: boolsk = sant
    mens running {
        la conn = builtin.socket_accept(srv)
        hvis conn < 0 {
            skriv("Feil ved accept, avslutter")
            running = usant
        } ellers {
            la raw = builtin.socket_read(conn, 8192)
            la resp: tekst = ""

            hvis lengde(raw) > 0 {
                la req = parse_http_request_raw(raw)
                la metode = hvis har_nokkel(req, "metode") { req["metode"] } ellers { "" }
                la sti   = hvis har_nokkel(req, "sti")    { req["sti"]    } ellers { "/" }

                la handler_namn = route_request(server, metode, sti)

                // Stopp-kommando
                hvis sti == "/__stopp__" {
                    resp = build_http_response(200, "{\"status\":\"stopper\"}")
                    running = usant
                } ellers hvis handler_namn != "" {
                    resp = build_http_response(200, "{\"handler\":\"" + handler_namn + "\",\"sti\":\"" + sti + "\"}")
                } ellers {
                    resp = build_http_response(404, "{\"error\":\"Not found\",\"sti\":\"" + sti + "\"}")
                }
            } ellers {
                resp = build_http_response(400, "{\"error\":\"Empty request\"}")
            }

            builtin.socket_write(conn, resp)
            builtin.socket_close(conn)
        }
    }

    builtin.socket_close(srv)
    skriv("Server stoppet.")
    returner 0
}

# ─── Mock Request Handler (For Testing) ────────────────────────────────────────

funksjon handle_mock_request(server: ordbok_tekst, raw_request: tekst) -> tekst {
    // Parse request
    la req = parse_http_request_raw(raw_request)

    hvis ikkje har_nokkel(req, "metode") {
        returner build_http_response(400, "{\"error\":\"Bad Request\"}")
    }

    la metode = req["metode"]
    la sti = req["sti"]

    // Find handler
    la handler = route_request(server, metode, sti)

    hvis handler != "" {
        // Handler found - would call it here
        returner build_http_response(200, "{\"handler\":\"" + handler + "\",\"path\":\"" + sti + "\"}")
    }

    // Not found
    returner build_http_response(404, "{\"error\":\"Not found\",\"path\":\"" + sti + "\"}")
}

# ─── Utility Functions ─────────────────────────────────────────────────────────

funksjon server_info(server: ordbok_tekst) -> tekst {
    la port = server["port_str"]
    la routes = lengde(nøkler(server["routes"]))

    returner "Norscode Server (port " + port + ", " + tekst(routes) + " routes)"
}

funksjon is_running(server: ordbok_tekst) -> boolsk {
    returner server["is_running"]
}

funksjon stop_server(server: ordbok_tekst) -> ordbok_tekst {
    server["is_running"] = usann
    returner server
}

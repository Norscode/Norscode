# stdlib_status.no - statusmatrise for offentleg standardbibliotek
#
# Denne modulen er ein maskinlesbar kontrakt for kva som er stabilt,
# eksperimentelt eller stub i aktiv Norscode-stdlib.

// modul("security", "stabil", ...)
funksjon modul(namn: tekst, status: tekst, dekning: tekst) -> ordbok_tekst {
    la m: ordbok_tekst = {}
    m["namn"] = namn
    m["status"] = status
    m["dekning"] = dekning
    returner m
}

funksjon statusmatrise() -> liste<ordbok_tekst> {
    la m: liste<ordbok_tekst> = []
    legg_til(m, modul("tekst", "stabil", "tekstbehandling"))
    legg_til(m, modul("fil", "stabil", "filstatus og fil-IO"))
    legg_til(m, modul("json", "stabil", "parse og stringify"))
    legg_til(m, modul("http", "stabil", "headers, status og response-hjelparar"))
    legg_til(m, modul("web", "stabil", "routing, request, response og middleware"))
    legg_til(m, modul("tid", "stabil", "tidspunkt og format"))
    legg_til(m, modul("logg", "stabil", "strukturert logging"))
    legg_til(m, modul("test", "stabil", "asserts og smoke-hjelparar"))
    legg_til(m, modul("db", "stabil", "CRUD, transaction og pool-kontrakt"))
    legg_til(m, modul("transactional_storage", "stabil", "SQLite foreign keys, transaksjon, migrering, indeks, backup og restore"))
    legg_til(m, modul("sikkerheit", "stabil", "samla std.sikkerheit-fasade for PBKDF2-HMAC-SHA256, rein scrypt-v1 med RFC 7914-vektor og harde pure-VM-grenser, RFC 9106 Argon2id portable Zig-backend og OpenSSL PBKDF2/ACME-backend; macOS ARM64, Linux x86_64/ARM64 og ekte Windows runtime-attestasjon er verifiserte med signert sikkerheitsbevis"))
    legg_til(m, modul("deployment_config", "stabil", "prosjektrot, data/uploads, secrets og helpdesk capability-profilar"))
    legg_til(m, modul("mock_http", "stabil", "deterministisk integrasjonsmock med svar, statuskø, kalljournal og retry/timeout-scenarier"))
    legg_til(m, modul("observability", "stabil", "strukturert integrasjonslogg, Quick3, e-post, retry og statusmålingar"))
    legg_til(m, modul("job_queue", "stabil", "varig idempotent jobbkø med claim, retry, timeout-reclaim og dead-letter"))
    legg_til(m, modul("quick3", "stabil", "HTTPS-only Bearer HTTP-integrasjon, timeout, retry, rate-limit, trygg responslogg og validert typed vehicle/ticket mapping"))
    legg_til(m, modul("inbound_email", "stabil", "MIME headers/body, base64 og quoted-printable, HTML, reply-korrelasjon, vedlegg og signerte webhookar"))
    legg_til(m, modul("vedlegg", "stabil", "MIME allowlist, størrelsesgrense, traversalvern og trygg filsti"))
    legg_til(m, modul("dns", "stabil", "DNS-soner, native resolver, korrekt autoritativ UDP- og RFC-frama TCP-daemon, MX/SPF/DKIM/DMARC, SHA-256 DS og native RRSIG er implementert; Norscode DNS/TCP svarar direkte på Pebbles ekte dns-01-validering og er verifisert i Linux x86_64/ARM64 og signert Windows-plattformgate"))
    legg_til(m, modul("tls_acme", "stabil", "RFC 8555 directory/Replay-Nonce, jwk/kid-JWS, account, order, authorization, challenge, finalize, sertifikatnedlasting og atomisk fornying er verifisert med full utstedelse mot Pebble test-CA, ekte dns-01 mot Norscode DNS/TCP og signert Windows RSA sign/verifisering"))
    legg_til(m, modul("brannmur", "stabil", "default-drop, deterministisk policy-evaluering, admin-allowlist, rate-limit, egress, audit og nftables-plan"))
    legg_til(m, modul("mail_server", "stabil", "SMTP-state machine, relay-deny, TLS/AUTH-policy, postboksar, kø, retry, dead-letter, karantene og mail-DNS"))
    legg_til(m, modul("domenehost", "stabil", "samla ende-til-ende-kontrakt for DNS/DNSSEC, TLS/ACME-fornying, mailoppsett, deny-by-default sikkerheit, backup og verifisert restore; test_domenehost_e2e bind alle delane saman"))
    legg_til(m, modul("runtime_status", "stabil", "maskinlesbar runtime v1-kontrakt for VM, minne, GC, prosess, scheduler og sikkerheit"))
    legg_til(m, modul("runtime_library", "stabil", "norscode-runtime-library-abi-v1 med pure-VM symbol- og atferdsgate for kjernebiblioteket"))
    legg_til(m, modul("runtime_allocator", "stabil", "64MB arena, 8-byte alignment, first-fit gjenbruk, free/OOM-vern og minnestatistikk"))
    legg_til(m, modul("runtime_loader", "stabil", "SHA-256 trust store, NCB ABI, hot-reload, dependencies, navnerom og plugin-capabilities"))
    legg_til(m, modul("runtime_jit", "stabil", "ARM64/x86-64 JIT for heiltall, desimal og tekst med W^X, adaptive callsites, iterert konstantfolding, identitetsreduksjon, SSA-livstidsanalyse, register-/spillplan og jit.execute-capability"))
    legg_til(m, modul("runtime_stack", "stabil", "stack frames, returadresse, lokale variablar, parametre, temporare verdiar og stack trace"))
    legg_til(m, modul("runtime_type", "stabil", "primitive typar, heap/container-typar, objekt, host-objekt og capability-sikra metodeoppslag"))
    legg_til(m, modul("runtime_exception", "stabil", "typed exception-objekt, kast-plan, fang, finally/defer, stacktrace og iterativ unwind-plan"))
    legg_til(m, modul("ai", "stabil", "provider-uavhengig AI-kontrakt"))
    legg_til(m, modul("http_binary", "stabil", "trygg JSON/Base64-medietransport, MIME- og storleiksvern og binær filskriving"))
    legg_til(m, modul("media_job", "stabil", "varige bilde-, lyd-, musikk- og videojobbar med polling, timeout, avbryting og gjenopptak"))
    legg_til(m, modul("media_model", "stabil", "felles autentisert leverandoradapter for synkron og asynkron mediegenerering"))
    legg_til(m, modul("media_local", "stabil", "rein Norscode-fallback for PPM, WAV og YUV4MPEG2 utan nettverk eller ekstern prosess"))
    legg_til(m, modul("tensor", "stabil", "kvantisert tensor med ARM64/x86-64 SIMD-matmul, skalar/rein Norscode-fallback, bias, requantisering og aktiveringar"))
    legg_til(m, modul("model_runtime", "stabil", "trygg lasting, parameter- og laggrense, bounded batch-inferens og fleirlags lokal qint-inferens"))
    legg_til(m, modul("qmodel_binary", "stabil", "kompakt NQM1-modellformat med int8-vekter, int32-bias, bounds-sjekk og fil-roundtrip"))
    legg_til(m, modul("model_registry", "stabil", "avgrensa modellregister med parameterbudsjett, inferenstelling, signert atomisk oppgradering og trygg avlasting"))
    legg_til(m, modul("model_server", "stabil", "bounded modellserver med kø, klientkvoter, timeout, avbryting og deterministisk inferens"))
    legg_til(m, modul("model_trust", "stabil", "SHA-256-pinna modellallowlist med tilbakekalling og verifisering før NQM1-dekoding"))
    legg_til(m, modul("model_release", "stabil", "HMAC-SHA256-signerte og versjonerte NQM1/NTM1-utgjevingar med nøkkelrotasjon, tilbakekalling, utløp og rollback-vern"))
    legg_til(m, modul("sampling", "stabil", "deterministisk top-k-tokenval med temperatur, repetisjonsstraff, stopp-token og lengdegrense"))
    legg_til(m, modul("media_neural", "stabil", "ressursavgrensa lokal q8-nevral forward-pass via norscode-tensor-v1 med valfri Metal-matmul og CPU-fallback, som styrer deterministisk bilde, lyd, musikk og video utan ekstern runtime"))
    legg_til(m, modul("media_diffusion", "stabil", "deterministisk CPU-diffusjon med iterativ denoising, tile-/arbeidsgrense, ekte PPM-output og valfri Metal-diffusjon med CPU-fallback"))
    legg_til(m, modul("neural_ops", "stabil", "embedding, normalisering, oppmerksomheit med tensorbackend og CPU-fallback, og kvantisert conv2d"))
    legg_til(m, modul("transformer", "stabil", "kvantisert pre-norm-transformerblokk med kausal oppmerksomheit, residualar og feed-forward"))
    legg_til(m, modul("text_generation", "stabil", "lokal autoregressiv q8-generering med embedding, transformerblokker, språkhovud og sampling"))
    legg_til(m, modul("tokenizer", "stabil", "deterministisk longest-match-tokenisering med ukjent-, BOS- og EOS-token"))
    legg_til(m, modul("tokenizer_bpe", "stabil", "avgrensa BPE-vokabulartrening med frekvensstyrte samanslåingar og varig roundtrip-format"))
    legg_til(m, modul("text_model_bundle", "stabil", "komplett NTM1-bundle for tokenizer, q8-språkhovud og transformerblokker med SHA-256-verifisering"))
    legg_til(m, modul("text_model_registry", "stabil", "ressursavgrensa register for verifiserte og signerte NTM1-modellar med atomisk oppgradering"))
    legg_til(m, modul("ai_bilde", "stabil", "lokal og leverandorbasert bildegenerering"))
    legg_til(m, modul("ai_lyd", "stabil", "lokal og leverandorbasert tale- og lydgenerering"))
    legg_til(m, modul("ai_musikk", "stabil", "lokal og leverandorbasert musikkgenerering"))
    legg_til(m, modul("ai_video", "stabil", "lokal og leverandorbasert videogenerering"))
    legg_til(m, modul("asynk", "stabil", "workers, kø, bakgrunnsjobbar og streaming"))
    legg_til(m, modul("multiprocessing", "stabil", "deterministisk Norscode-kontrakt med shell-fri native argv-backend via std.prosess"))
    legg_til(m, modul("socketserver", "stabil", "Norscode-serverkontrakt med avgrensa runtime-grense; native TCP/HTTP-listener, portkontroll, UDP og eksplisitt lifecycle utan shell-wrapper"))
    legg_til(m, modul("wsgiref", "stabil", "Norscode-adapterkontrakt med avgrensa runtime-grense; native one-request WSGI-adapter via Norscode-serveren og langkøyrande livssyklus via nc serve"))
    returner m
}

funksjon status_for(namn: tekst) -> tekst {
    la m = statusmatrise()
    la i: heiltall = 0
    mens i < lengde(m) {
        hvis tekst(m[i]["namn"]) == namn {
            returner tekst(m[i]["status"])
        }
        i = i + 1
    }
    returner "ukjent"
}

funksjon er_stabil(namn: tekst) -> boolsk {
    returner status_for(namn) == "stabil"
}

funksjon samandrag() -> ordbok_tekst {
    la m = statusmatrise()
    la stabil: heiltall = 0
    la eksperimentell: heiltall = 0
    la stub: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(m) {
        la s = tekst(m[i]["status"])
        hvis s == "stabil" { stabil = stabil + 1 }
        ellers hvis s == "eksperimentell" { eksperimentell = eksperimentell + 1 }
        ellers hvis s == "stub" { stub = stub + 1 }
        i = i + 1
    }
    la r: ordbok_tekst = {}
    r["total"] = tekst_fra_heltall(lengde(m))
    r["stabil"] = tekst_fra_heltall(stabil)
    r["eksperimentell"] = tekst_fra_heltall(eksperimentell)
    r["stub"] = tekst_fra_heltall(stub)
    hvis lengde(m) > 0 {
        r["prosent_stabil"] = tekst_fra_heltall((stabil * 100 + lengde(m) / 2) / lengde(m))
    } ellers {
        r["prosent_stabil"] = "0"
    }
    returner r
}

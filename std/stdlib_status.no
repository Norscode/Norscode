# stdlib_status.no - statusmatrise for offentleg standardbibliotek
#
# Denne modulen er ein maskinlesbar kontrakt for kva som er stabilt,
# eksperimentelt eller stub i aktiv Norscode-stdlib.

funksjon modul(namn: tekst, status: tekst, dekning: tekst) -> ordbok_tekst {
    returner {
        namn: namn,
        status: status,
        dekning: dekning
    }
}

funksjon statusmatrise() -> liste<ordbok_tekst> {
    returner [
        modul("tekst", "stabil", "tekstbehandling"),
        modul("fil", "stabil", "filstatus og fil-IO"),
        modul("json", "stabil", "parse og stringify"),
        modul("http", "stabil", "headers, status og response-hjelparar"),
        modul("web", "stabil", "routing, request, response og middleware"),
        modul("tid", "stabil", "tidspunkt og format"),
        modul("logg", "stabil", "strukturert logging"),
        modul("test", "stabil", "asserts og smoke-hjelparar"),
        modul("db", "stabil", "CRUD, transaction og pool-kontrakt"),
        modul("security", "stabil", "samla sikkerheitsgate for auth, session, CSRF, headers, cookies, secrets og deploy"),
        modul("sikkerheit", "stabil", "secrets, hashing og trygge defaultar"),
        modul("ai", "stabil", "provider-uavhengig AI-kontrakt"),
        modul("asynk", "stabil", "workers, kø, bakgrunnsjobbar og streaming"),
        modul("multiprocessing", "eksperimentell", "deterministisk Norscode-prosesskontrakt"),
        modul("socketserver", "eksperimentell", "Norscode-serverkontrakt med avgrensa runtime-grense"),
        modul("wsgiref", "eksperimentell", "Norscode-adapterkontrakt med avgrensa runtime-grense")
    ]
}

funksjon status_for(namn: tekst) -> tekst {
    la m = statusmatrise()
    la i: heiltall = 0
    mens i < lengde(m) {
        hvis tekst(m[i]["namn"]) == namn {
            returner tekst(m[i]["status"])
        }
        i = i + 1
    }
    returner "ukjent"
}

funksjon er_stabil(namn: tekst) -> boolsk {
    returner status_for(namn) == "stabil"
}

funksjon samandrag() -> ordbok_tekst {
    la m = statusmatrise()
    la stabil: heiltall = 0
    la eksperimentell: heiltall = 0
    la stub: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(m) {
        la s = tekst(m[i]["status"])
        hvis s == "stabil" { stabil = stabil + 1 }
        ellers hvis s == "eksperimentell" { eksperimentell = eksperimentell + 1 }
        ellers hvis s == "stub" { stub = stub + 1 }
        i = i + 1
    }
    returner {
        total: lengde(m),
        stabil: stabil,
        eksperimentell: eksperimentell,
        stub: stub
    }
}

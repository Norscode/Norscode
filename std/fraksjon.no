# fraksjon.no — Rasjonale tal (brøkar)
# Python: fractions.Fraction
#
# Representasjon: liste_heltall [tellar, nemnar]
# Alltid i normalform: nemnar > 0, gcd(|tellar|, nemnar) = 1
# Spesialverdiar: [1, 0] = +inf, [-1, 0] = -inf, [0, 0] = NaN
#
# Bruk:
#   bruk std.fraksjon som fr
#   la a = fr.ny(1, 3)
#   la b = fr.ny(1, 6)
#   la sum = fr.pluss(a, b)   # → [1, 2]
#   skriv fr.til_tekst(sum)   # → "1/2"

# ─── GCD og normalisering ─────────────────────────────────────────────────────

funksjon _abs(n: heltall) -> heltall {
    hvis (n < 0) { returner 0 - n }
    returner n
}

# Euklids algoritme
funksjon gcd(a: heltall, b: heltall) -> heltall {
    la x: heltall = _abs(a)
    la y: heltall = _abs(b)
    mens (y != 0) {
        la t: heltall = y
        y = x % y
        x = t
    }
    returner x
}

funksjon lcm(a: heltall, b: heltall) -> heltall {
    la g: heltall = gcd(a, b)
    hvis (g == 0) { returner 0 }
    returner _abs(a / g * b)
}

# Normaliser [tellar, nemnar]: nemnar > 0, forkorta
funksjon _normaliser(t: heltall, n: heltall) -> liste_heltall {
    # Spesialtilfelle
    hvis (n == 0) {
        hvis (t > 0) { returner [1, 0] }
        hvis (t < 0) { returner [-1, 0] }
        returner [0, 0]
    }
    # Sikre positiv nemnar
    la sign: heltall = 1
    hvis (n < 0) { sign = 0 - 1  n = 0 - n  t = 0 - t }
    la g: heltall = gcd(_abs(t), n)
    hvis (g == 0) { returner [0, 1] }
    returner [t / g, n / g]
}

# ─── Konstruktørar ────────────────────────────────────────────────────────────

funksjon ny(tellar: heltall, nemnar: heltall) -> liste_heltall {
    returner _normaliser(tellar, nemnar)
}

funksjon frå_heltall(n: heltall) -> liste_heltall {
    returner [n, 1]
}

# Frå tekst: "a/b", "a" eller "a.b" (avgrensa desimalstøtte)
funksjon frå_tekst(s: tekst) -> liste_heltall {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)

    # Sjekk for /
    la skråstrek_pos: heltall = -1
    la i: heltall = 0
    mens (i < n) {
        hvis (teikn[i] == "/") { skråstrek_pos = i }
        i = i + 1
    }
    hvis (skråstrek_pos >= 0) {
        la tellar_t: tekst = builtin.join(builtin.slice(teikn, 0, skråstrek_pos), "")
        la nemnar_t: tekst = builtin.join(builtin.slice(teikn, skråstrek_pos + 1, n), "")
        la tellar: heltall = builtin.heltall_fra_tekst(tellar_t)
        la nemnar: heltall = builtin.heltall_fra_tekst(nemnar_t)
        returner ny(tellar, nemnar)
    }

    # Sjekk for desimalpunkt
    la punkt_pos: heltall = -1
    i = 0
    mens (i < n) {
        hvis (teikn[i] == ".") { punkt_pos = i }
        i = i + 1
    }
    hvis (punkt_pos >= 0) {
        la heil_t: tekst = builtin.join(builtin.slice(teikn, 0, punkt_pos), "")
        la des_t: tekst = builtin.join(builtin.slice(teikn, punkt_pos + 1, n), "")
        la des_len: heltall = lengde(builtin.split(des_t, ""))
        la tiarar: heltall = 1
        la k: heltall = 0
        mens (k < des_len) { tiarar = tiarar * 10  k = k + 1 }
        la heil: heltall = builtin.heltall_fra_tekst(heil_t)
        la des: heltall = builtin.heltall_fra_tekst(des_t)
        la sign_f: heltall = 1
        la total_t: heltall = heil * tiarar + des
        returner ny(total_t, tiarar)
    }

    # Heiltall
    returner frå_heltall(builtin.heltall_fra_tekst(s))
}

# ─── Spesialverdikontrollar ───────────────────────────────────────────────────

funksjon er_nan(f: liste_heltall) -> bool  {
    returner f[0] == 0 og f[1] == 0
}
funksjon er_inf(f: liste_heltall) -> bool  {
    returner f[1] == 0 og f[0] != 0
}
funksjon er_pos_inf(f: liste_heltall) -> bool  {
    returner f[0] > 0 og f[1] == 0
}
funksjon er_neg_inf(f: liste_heltall) -> bool  {
    returner f[0] < 0 og f[1] == 0
}
funksjon er_endelig(f: liste_heltall) -> bool  {
    returner f[1] != 0
}
funksjon er_null(f: liste_heltall) -> bool  {
    returner f[0] == 0 og f[1] != 0
}
funksjon er_positiv(f: liste_heltall) -> bool  {
    returner f[0] > 0
}
funksjon er_negativ(f: liste_heltall) -> bool  {
    returner f[0] < 0
}

# ─── Aritmetikk ───────────────────────────────────────────────────────────────

funksjon pluss(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    hvis (er_nan(a) eller er_nan(b)) { returner [0, 0] }
    hvis (er_inf(a) og er_inf(b)) {
        hvis (a[0] == b[0]) { returner a }
        returner [0, 0]  # +inf + (-inf) = NaN
    }
    hvis (er_inf(a)) { returner a }
    hvis (er_inf(b)) { returner b }
    la t: heltall = a[0] * b[1] + b[0] * a[1]
    la n: heltall = a[1] * b[1]
    returner _normaliser(t, n)
}

funksjon minus(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    returner pluss(a, neg(b))
}

funksjon gonger(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    hvis (er_nan(a) eller er_nan(b)) { returner [0, 0] }
    hvis (er_null(a) og er_inf(b)) { returner [0, 0] }
    hvis (er_inf(a) og er_null(b)) { returner [0, 0] }
    la t: heltall = a[0] * b[0]
    la n: heltall = a[1] * b[1]
    returner _normaliser(t, n)
}

funksjon dele(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    hvis (er_nan(a) eller er_nan(b)) { returner [0, 0] }
    hvis (er_null(b)) { returner _normaliser(a[0], 0) }
    returner gonger(a, [b[1], b[0]])
}

funksjon neg(f: liste_heltall) -> liste_heltall {
    returner [0 - f[0], f[1]]
}

funksjon abs_f(f: liste_heltall) -> liste_heltall {
    returner [_abs(f[0]), f[1]]
}

funksjon potens(f: liste_heltall, exp: heltall) -> liste_heltall {
    hvis (exp == 0) { returner [1, 1] }
    hvis (exp < 0) {
        la inv: liste_heltall = [f[1], f[0]]
        returner potens(inv, 0 - exp)
    }
    la resultat: liste_heltall = [1, 1]
    la i: heltall = 0
    mens (i < exp) {
        resultat = gonger(resultat, f)
        i = i + 1
    }
    returner resultat
}

# ─── Samanlikning ─────────────────────────────────────────────────────────────

funksjon er_lik(a: liste_heltall, b: liste_heltall) -> bool {
    returner a[0] == b[0] og a[1] == b[1]
}

funksjon er_mindre(a: liste_heltall, b: liste_heltall) -> bool {
    hvis (er_nan(a) eller er_nan(b)) { returner usann }
    hvis (er_inf(a) og er_inf(b)) { returner a[0] < b[0] }
    hvis (er_neg_inf(a)) { returner ikkje er_neg_inf(b) }
    hvis (er_pos_inf(a)) { returner usann }
    hvis (er_neg_inf(b)) { returner usann }
    hvis (er_pos_inf(b)) { returner sann }
    # Kryss-multiplikasjon (nemnar er alltid positive etter normalisering)
    returner a[0] * b[1] < b[0] * a[1]
}

funksjon er_større(a: liste_heltall, b: liste_heltall) -> bool {
    returner er_mindre(b, a)
}

funksjon er_mindre_lik(a: liste_heltall, b: liste_heltall) -> bool {
    returner er_lik(a, b) eller er_mindre(a, b)
}

funksjon er_større_lik(a: liste_heltall, b: liste_heltall) -> bool {
    returner er_lik(a, b) eller er_større(a, b)
}

# ─── Konvertering ─────────────────────────────────────────────────────────────

funksjon til_heltall(f: liste_heltall) -> heltall {
    hvis (f[1] == 0) { returner 0 }
    returner f[0] / f[1]
}

# Konverter til tekst: "a/b" eller "a" for heile tal
funksjon til_tekst(f: liste_heltall) -> tekst {
    hvis (er_nan(f)) { returner "NaN" }
    hvis (er_pos_inf(f)) { returner "Inf" }
    hvis (er_neg_inf(f)) { returner "-Inf" }
    hvis (f[1] == 1) { returner tekst_fra_heltall(f[0]) }
    returner tekst_fra_heltall(f[0]) + "/" + tekst_fra_heltall(f[1])
}

# Konverter til desimaltekst med n desimalar
funksjon til_desimal_tekst(f: liste_heltall, n_des: heltall) -> tekst {
    hvis (er_nan(f) eller er_inf(f)) { returner til_tekst(f) }
    la heil: heltall = f[0] / f[1]
    la rest: heltall = _abs(f[0] % f[1])
    la faktor: heltall = 1
    la k: heltall = 0
    mens (k < n_des) { faktor = faktor * 10  k = k + 1 }
    la des_del: heltall = rest * faktor / f[1]
    la des_str: tekst = tekst_fra_heltall(des_del)
    # Pad med leiande nullar
    mens (lengde(builtin.split(des_str, "")) < n_des) {
        des_str = "0" + des_str
    }
    la forteikn: tekst = ""
    hvis (f[0] < 0 og heil == 0) { forteikn = "-" }
    returner forteikn + tekst_fra_heltall(heil) + "." + des_str
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon tellar(f: liste_heltall) -> heltall  {
    returner f[0]
}
funksjon nemnar(f: liste_heltall) -> heltall  {
    returner f[1]
}

funksjon golv(f: liste_heltall) -> heltall {
    hvis (f[1] == 0) { returner 0 }
    la q: heltall = f[0] / f[1]
    hvis (f[0] < 0 og f[0] % f[1] != 0) { returner q - 1 }
    returner q
}

funksjon tak(f: liste_heltall) -> heltall {
    hvis (f[1] == 0) { returner 0 }
    la q: heltall = f[0] / f[1]
    hvis (f[0] > 0 og f[0] % f[1] != 0) { returner q + 1 }
    returner q
}

funksjon avrund(f: liste_heltall) -> heltall {
    la g: heltall = golv(f)
    la rest: liste_heltall = minus(f, frå_heltall(g))
    # rest >= 1/2 → avrund opp
    la halv: liste_heltall = [1, 2]
    hvis (er_større_lik(rest, halv)) { returner g + 1 }
    returner g
}

funksjon mediant(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    # Stern-Brocot medianten: (a+c)/(b+d)
    returner ny(a[0] + b[0], a[1] + b[1])
}

funksjon min_f(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    hvis (er_mindre(a, b)) { returner a }
    returner b
}

funksjon maks_f(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    hvis (er_større(a, b)) { returner a }
    returner b
}

# Summ av liste av brøkar
funksjon sum_liste(brøkar: liste_tekst) -> liste_heltall {
    la resultat: liste_heltall = [0, 1]
    la i: heltall = 0
    mens (i < lengde(brøkar)) {
        la f = builtin.json_parse(brøkar[i])
        resultat = pluss(resultat, f)
        i = i + 1
    }
    returner resultat
}

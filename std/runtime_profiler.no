# runtime_profiler.no - profilerdata eigd av bytecode-VM-en

funksjon snapshot() -> ordbok_tekst {
    prøv { returner builtin.vm_runtime_metrics() } fang (e) {
        la tom: ordbok_tekst = {}
        tom["status"] = "ikkje_tilgjengeleg"
        tom["feil"] = tekst(e)
        returner tom
    }
    la tom2: ordbok_tekst = {}
    returner tom2
}

funksjon heiltall_felt(data: ordbok_tekst, felt: tekst) -> heiltall {
    hvis ikkje har_nokkel(data, felt) { returner 0 }
    prøv { returner heltall_fra_tekst(data[felt]) } fang (e) { returner 0 }
    returner 0
}

funksjon cpu_instruksjonar(data: ordbok_tekst) -> heiltall { returner heiltall_felt(data, "instructions") }
funksjon veggtid_ms(data: ordbok_tekst) -> heiltall { returner heiltall_felt(data, "wall_ms") }
funksjon gc_pause_ms(data: ordbok_tekst) -> heiltall { returner heiltall_felt(data, "gc_pause_ms") }
funksjon io_kall(data: ordbok_tekst) -> heiltall { returner heiltall_felt(data, "io_calls") }
funksjon heap_bytes(data: ordbok_tekst) -> heiltall { returner heiltall_felt(data, "heap_alive_bytes") }

funksjon funksjon_kall(data: ordbok_tekst, namn: tekst) -> heiltall {
    returner heiltall_felt(data, "function_calls." + namn)
}

funksjon funksjon_instruksjonar(data: ordbok_tekst, namn: tekst) -> heiltall {
    returner heiltall_felt(data, "function_instructions." + namn)
}

funksjon funksjon_veggtid_ms(data: ordbok_tekst, namn: tekst) -> heiltall {
    returner heiltall_felt(data, "function_wall_ms." + namn)
}

funksjon eksporter_json(data: ordbok_tekst) -> tekst {
    returner builtin.json_stringify(data)
}

funksjon sett_sample_intervall(instruksjonar: heiltall) -> bool {
    returner builtin.vm_profiler_set_sample_interval(instruksjonar)
}

funksjon samples() -> liste { returner builtin.vm_profiler_samples() }
funksjon trace_events() -> liste { returner builtin.vm_profiler_trace_events() }
funksjon eksporter_chrome_trace() -> tekst { returner builtin.vm_profiler_chrome_trace() }
funksjon nullstill() -> bool { returner builtin.vm_profiler_reset() }

funksjon produksjonsstatus() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["status"] = "stabil"
    s["dekning"] = "pure VM CPU-instruksjonar/rate, konfigurerbar statistisk sampling av funksjon/IP/opcode/kjeldelinje/call-stack, veggtid, heap, GC-pause/safe-points, fil/nett/prosess-I/O, stack/exception, per-funksjon kall/instruksjonar/veggtid, avgrensa trace-buffer og Chrome Trace Event JSON"
    s["mangler"] = ""
    returner s
}

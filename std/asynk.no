# asynk.no — ASGI/async-arbeidarar for Norscode
# asyncio / uvicorn-ekvivalent
#
# Bruk:
#   bruk std.asynk som asynk
#
#   la app = asynk.ny_app()
#   asynk.rute(app, "/", "handterer_rot")
#   asynk.køyr(app, "0.0.0.0", 8000, arbeidarar: 4)

bruk std.web som web

# ─── App-konfigurasjon ────────────────────────────────────────────────────────

funksjon ny_app() -> ordbok_tekst {
    la a: ordbok_tekst = {}
    a["__ruter__"]       = "[]"
    a["__middleware__"]  = "[]"
    a["__arbeidarar__"]  = "4"
    a["__kø_størrelse__"] = "1000"
    a["__timeout__"]     = "30"
    a["__graceful_shutdown__"] = "sann"
    a["__lifespan__"]    = ""
    returner a
}

funksjon ny_app_full(arbeidarar: heltall, kø: heltall, timeout: heltall) -> ordbok_tekst {
    la a = ny_app()
    a["__arbeidarar__"]  = tekst(arbeidarar)
    a["__kø_størrelse__"] = tekst(kø)
    a["__timeout__"]     = tekst(timeout)
    returner a
}

funksjon sett_arbeidarar(app: ordbok_tekst, n: heltall) -> heltall {
    app["__arbeidarar__"] = tekst(n)
    returner n
}

funksjon sett_timeout(app: ordbok_tekst, sek: heltall) -> heltall {
    app["__timeout__"] = tekst(sek)
    returner sek
}

funksjon sett_lifespan(app: ordbok_tekst, fn_namn: tekst) -> heltall {
    app["__lifespan__"] = fn_namn
    returner 0
}

# ─── Ruting ───────────────────────────────────────────────────────────────────

funksjon rute(app: ordbok_tekst, sti: tekst, handler_fn: tekst) -> heltall {
    returner rute_metode(app, sti, "GET", handler_fn)
}

funksjon rute_metode(app: ordbok_tekst, sti: tekst, metode: tekst, handler_fn: tekst) -> heltall {
    la ruter = _les_liste(app, "__ruter__")
    la r: ordbok_tekst = {}
    r["sti"]     = sti
    r["metode"]  = metode
    r["handler"] = handler_fn
    legg_til(ruter, r)
    _skriv_liste(app, "__ruter__", ruter)
    returner lengde(ruter)
}

funksjon get(app: ordbok_tekst, sti: tekst, fn_namn: tekst) -> heltall {
    returner rute_metode(app, sti, "GET", fn_namn)
}

funksjon post(app: ordbok_tekst, sti: tekst, fn_namn: tekst) -> heltall {
    returner rute_metode(app, sti, "POST", fn_namn)
}

funksjon put(app: ordbok_tekst, sti: tekst, fn_namn: tekst) -> heltall {
    returner rute_metode(app, sti, "PUT", fn_namn)
}

funksjon slett(app: ordbok_tekst, sti: tekst, fn_namn: tekst) -> heltall {
    returner rute_metode(app, sti, "DELETE", fn_namn)
}

funksjon alle_metodar(app: ordbok_tekst, sti: tekst, fn_namn: tekst) -> heltall {
    rute_metode(app, sti, "GET", fn_namn)
    rute_metode(app, sti, "POST", fn_namn)
    rute_metode(app, sti, "PUT", fn_namn)
    rute_metode(app, sti, "PATCH", fn_namn)
    rute_metode(app, sti, "DELETE", fn_namn)
    returner 0
}

# ─── Middleware ───────────────────────────────────────────────────────────────

funksjon middleware(app: ordbok_tekst, fn_namn: tekst) -> heltall {
    la mw = _les_liste(app, "__middleware__")
    la m: ordbok_tekst = {}
    m["fn"] = fn_namn
    legg_til(mw, m)
    _skriv_liste(app, "__middleware__", mw)
    returner lengde(mw)
}

# ─── Parallelisme / arbeidarpool ──────────────────────────────────────────────

funksjon ny_pool(n_arbeidarar: heltall) -> ordbok_tekst {
    la p: ordbok_tekst = {}
    p["__n__"]       = tekst(n_arbeidarar)
    p["__aktive__"]  = "0"
    p["__fullført__"] = "0"
    p["__feil__"]    = "0"
    returner p
}

funksjon køyr_parallelt(pool: ordbok_tekst, fn_namn: tekst, args_liste: liste<ordbok_tekst>) -> liste<tekst> {
    la resultat: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(args_liste) {
        la args: ordbok_tekst = args_liste[i]
        prøv {
            la r = builtin.ncb_call_fn(fn_namn, args)
            legg_til(resultat, tekst(r))
            la fullf = heltall_fra_tekst(tekst(pool["__fullført__"]))
            pool["__fullført__"] = tekst(fullf + 1)
        } fang (e) {
            legg_til(resultat, "__FEIL__:" + tekst(e))
            la feil = heltall_fra_tekst(tekst(pool["__feil__"]))
            pool["__feil__"] = tekst(feil + 1)
        }
        i = i + 1
    }
    returner resultat
}

funksjon map_parallelt(fn_namn: tekst, verdiar: liste<tekst>) -> liste<tekst> {
    la resultat: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(verdiar) {
        la args: ordbok_tekst = {}
        args["verdi"] = verdiar[i]
        args["indeks"] = tekst(i)
        prøv {
            la r = builtin.ncb_call_fn(fn_namn, args)
            legg_til(resultat, tekst(r))
        } fang (e) {
            legg_til(resultat, "__FEIL__:" + tekst(e))
        }
        i = i + 1
    }
    returner resultat
}

funksjon filter_parallelt(fn_namn: tekst, verdiar: liste<tekst>) -> liste<tekst> {
    la resultat: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(verdiar) {
        la args: ordbok_tekst = {}
        args["verdi"] = verdiar[i]
        prøv {
            la r = tekst(builtin.ncb_call_fn(fn_namn, args))
            hvis r == "sann" eller r == "true" {
                legg_til(resultat, verdiar[i])
            }
        } fang (e) { }
        i = i + 1
    }
    returner resultat
}

# ─── Asynkron oppgåvekø ───────────────────────────────────────────────────────

funksjon ny_oppgåve_kø() -> ordbok_tekst {
    la k: ordbok_tekst = {}
    k["__oppgåver__"] = "[]"
    k["__resultat__"] = "{}"
    k["__neste_id__"] = "1"
    returner k
}

funksjon legg_til_oppgåve(kø: ordbok_tekst, fn_namn: tekst, args: ordbok_tekst) -> tekst {
    la oppgåver = _les_liste(kø, "__oppgåver__")
    la id = tekst(heltall_fra_tekst(tekst(kø["__neste_id__"])))
    kø["__neste_id__"] = tekst(heltall_fra_tekst(id) + 1)
    la o: ordbok_tekst = {}
    o["id"] = id
    o["fn"] = fn_namn
    // Serialiser args
    la nk = nøkler(args)
    la delar: liste<tekst> = []
    la j: heltall = 0
    mens j < lengde(nk) {
        la k2: tekst = nk[j]
        legg_til(delar, "\"" + k2 + "\":\"" + tekst(args[k2]) + "\"")
        j = j + 1
    }
    o["args"] = "{" + tekst_saman(delar, ",") + "}"
    legg_til(oppgåver, o)
    _skriv_liste(kø, "__oppgåver__", oppgåver)
    returner id
}

funksjon køyr_kø(kø: ordbok_tekst) -> ordbok_tekst {
    la oppgåver = _les_liste(kø, "__oppgåver__")
    la resultat: ordbok_tekst = {}
    la i: heltall = 0
    mens i < lengde(oppgåver) {
        la o: ordbok_tekst = oppgåver[i]
        la id: tekst = o["id"]
        la fn_namn: tekst = o["fn"]
        prøv {
            la args_parsed = builtin.json_parse_raw(tekst(o["args"]))
            la r = builtin.ncb_call_fn(fn_namn, args_parsed)
            resultat[id] = tekst(r)
        } fang (e) {
            resultat[id] = "__FEIL__:" + tekst(e)
        }
        i = i + 1
    }
    returner resultat
}

funksjon hent_resultat(kø_resultat: ordbok_tekst, oppgåve_id: tekst) -> tekst {
    hvis har_nøkkel(kø_resultat, oppgåve_id) {
        returner tekst(kø_resultat[oppgåve_id])
    }
    returner ""
}

# ─── Timeout og retry ─────────────────────────────────────────────────────────

funksjon med_timeout(fn_namn: tekst, args: ordbok_tekst, timeout_sek: heltall) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la start = builtin.unix_timestamp()
    prøv {
        la res = builtin.ncb_call_fn(fn_namn, args)
        la slutt = builtin.unix_timestamp()
        r["ok"]       = "sann"
        r["resultat"] = tekst(res)
        r["ms"]       = tekst((slutt - start) * 1000)
    } fang (e) {
        r["ok"]    = "usann"
        r["feil"]  = tekst(e)
        r["ms"]    = "0"
    }
    returner r
}

funksjon med_retry(fn_namn: tekst, args: ordbok_tekst, maks_forsøk: heltall) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la forsøk: heltall = 0
    mens forsøk < maks_forsøk {
        prøv {
            la res = builtin.ncb_call_fn(fn_namn, args)
            r["ok"]       = "sann"
            r["resultat"] = tekst(res)
            r["forsøk"]   = tekst(forsøk + 1)
            returner r
        } fang (e) {
            r["siste_feil"] = tekst(e)
            forsøk = forsøk + 1
        }
    }
    r["ok"]    = "usann"
    r["feil"]  = tekst(r["siste_feil"])
    r["forsøk"] = tekst(maks_forsøk)
    returner r
}

# ─── Livsyklus-handterar ──────────────────────────────────────────────────────

funksjon køyr(app: ordbok_tekst, vert: tekst, port: heltall) -> heltall {
    la arbeidarar = heltall_fra_tekst(tekst(app["__arbeidarar__"]))
    la lifespan = tekst(app["__lifespan__"])
    // Kall lifespan startup viss definert
    hvis lifespan != "" {
        la args: ordbok_tekst = {}
        args["fase"] = "startup"
        prøv { builtin.ncb_call_fn(lifespan, args) } fang (e) { }
    }
    la server_args: ordbok_tekst = {}
    server_args["vert"]       = vert
    server_args["port"]       = tekst(port)
    server_args["arbeidarar"] = tekst(arbeidarar)
    server_args["timeout"]    = tekst(app["__timeout__"])
    builtin.serve_start(server_args)
    returner 0
}

funksjon køyr_dev(app: ordbok_tekst, port: heltall) -> heltall {
    returner køyr(app, "127.0.0.1", port)
}

# ─── Interne hjelpefunksjonar ─────────────────────────────────────────────────

funksjon _les_liste(app: ordbok_tekst, nøkkel: tekst) -> liste<ordbok_tekst> {
    prøv {
        la raw = tekst(app[nøkkel])
        returner builtin.json_parse_raw(raw)
    } fang (e) { returner [] }
    returner []
}

funksjon _skriv_liste(app: ordbok_tekst, nøkkel: tekst, lst: liste<ordbok_tekst>) -> heltall {
    la delar: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(lst) {
        la el: ordbok_tekst = lst[i]
        la nk = nøkler(el)
        la felt_delar: liste<tekst> = []
        la j: heltall = 0
        mens j < lengde(nk) {
            la k: tekst = nk[j]
            la vv = tekst_erstatt(tekst(el[k]), "\"", "\\\"")
            legg_til(felt_delar, "\"" + k + "\":\"" + vv + "\"")
            j = j + 1
        }
        legg_til(delar, "{" + tekst_saman(felt_delar, ",") + "}")
        i = i + 1
    }
    app[nøkkel] = "[" + tekst_saman(delar, ",") + "]"
    returner 0
}

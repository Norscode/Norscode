# tokenizer_bpe.no — avgrensa BPE-trening og varig tokenizerformat i rein Norscode

bruk std.tokenizer som tokenizer

funksjon ny_trenar(maks_vokabular: heiltall, min_frekvens: heiltall,
                   maks_arbeid: heiltall) {
    hvis maks_vokabular < 4 eller maks_vokabular > 4096 { kast "BPEFeil: ugyldig vokabulargrense" }
    hvis min_frekvens < 2 { kast "BPEFeil: min_frekvens må vere minst 2" }
    hvis maks_arbeid <= 0 eller maks_arbeid > 100000000 { kast "BPEFeil: ugyldig arbeidsgrense" }
    returner {
        "schema": "norscode.bpe-trainer.v1", "maks_vokabular": maks_vokabular,
        "min_frekvens": min_frekvens, "maks_arbeid": maks_arbeid,
        "arbeid": 0, "samanslaingar": []
    }
}

funksjon _finn_tekst(verdiar: liste_tekst, verdi: tekst) -> heiltall {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis verdiar[i] == verdi { returner i }
        i = i + 1
    }
    returner -1
}

funksjon _sekvensar(korpus: liste_tekst, vokabular: liste_tekst,
                    trenar) {
    la alle: liste = []
    la k: heiltall = 0
    mens k < lengde(korpus) {
        la sekvens: liste_tekst = []
        la i: heiltall = 0
        mens i < lengde(korpus[k]) {
            trenar["arbeid"] = trenar["arbeid"] + 1
            hvis trenar["arbeid"] > trenar["maks_arbeid"] { kast "BPEFeil: arbeidsgrense overskriden" }
            la teikn = builtin.slice(korpus[k], i, i + 1)
            hvis _finn_tekst(vokabular, teikn) < 0 { legg_til(vokabular, teikn) }
            legg_til(sekvens, teikn)
            i = i + 1
        }
        legg_til(alle, sekvens)
        k = k + 1
    }
    returner alle
}

funksjon _finn_par(par, venstre: tekst, hogre: tekst) -> heiltall {
    la i: heiltall = 0
    mens i < lengde(par) {
        hvis par[i]["venstre"] == venstre og par[i]["hogre"] == hogre { returner i }
        i = i + 1
    }
    returner -1
}

funksjon _tel_par(sekvensar, trenar) {
    la par: liste = []
    la s: heiltall = 0
    mens s < lengde(sekvensar) {
        la i: heiltall = 0
        mens i + 1 < lengde(sekvensar[s]) {
            trenar["arbeid"] = trenar["arbeid"] + 1
            hvis trenar["arbeid"] > trenar["maks_arbeid"] { kast "BPEFeil: arbeidsgrense overskriden" }
            la a = sekvensar[s][i]
            la b = sekvensar[s][i + 1]
            la indeks = _finn_par(par, a, b)
            hvis indeks < 0 {
                legg_til(par, {"venstre": a, "hogre": b, "tal": 1})
            } ellers {
                par[indeks]["tal"] = par[indeks]["tal"] + 1
            }
            i = i + 1
        }
        s = s + 1
    }
    returner par
}

funksjon _beste_par(par, min_frekvens: heiltall) -> heiltall {
    la best: heiltall = -1
    la i: heiltall = 0
    mens i < lengde(par) {
        hvis par[i]["tal"] >= min_frekvens {
            hvis best < 0 eller par[i]["tal"] > par[best]["tal"] { best = i }
        }
        i = i + 1
    }
    returner best
}

funksjon _slå_saman(sekvens: liste_tekst, venstre: tekst,
                    hogre: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la i: heiltall = 0
    mens i < lengde(sekvens) {
        hvis i + 1 < lengde(sekvens) og sekvens[i] == venstre og sekvens[i + 1] == hogre {
            legg_til(ut, venstre + hogre)
            i = i + 2
        } ellers {
            legg_til(ut, sekvens[i])
            i = i + 1
        }
    }
    returner ut
}

funksjon tren(trenar, korpus: liste_tekst, ukjent: tekst,
              bos: tekst, eos: tekst, maks_input: heiltall) {
    hvis lengde(korpus) == 0 { kast "BPEFeil: tomt korpus" }
    hvis ukjent == "" eller bos == "" eller eos == "" { kast "BPEFeil: tomt spesialtoken" }
    hvis ukjent == bos eller ukjent == eos eller bos == eos { kast "BPEFeil: spesialtoken må vere unike" }
    la vokabular: liste_tekst = [ukjent, bos, eos]
    la sekvensar = _sekvensar(korpus, vokabular, trenar)
    hvis lengde(vokabular) > trenar["maks_vokabular"] { kast "BPEFeil: grunnvokabular overskrid grensa" }
    mens lengde(vokabular) < trenar["maks_vokabular"] {
        la par = _tel_par(sekvensar, trenar)
        la best = _beste_par(par, trenar["min_frekvens"])
        hvis best < 0 { bryt }
        la samanslått = par[best]["venstre"] + par[best]["hogre"]
        hvis _finn_tekst(vokabular, samanslått) < 0 { legg_til(vokabular, samanslått) }
        legg_til(trenar["samanslaingar"], par[best]["venstre"] + "\t" + par[best]["hogre"])
        la s: heiltall = 0
        mens s < lengde(sekvensar) {
            sekvensar[s] = _slå_saman(sekvensar[s], par[best]["venstre"], par[best]["hogre"])
            s = s + 1
        }
    }
    returner tokenizer.ny(vokabular, 0, 1, 2, maks_input)
}

funksjon _escape(v: tekst) -> tekst {
    la ut = builtin.replace(v, "%", "%25")
    ut = builtin.replace(ut, "\n", "%0A")
    ut = builtin.replace(ut, "\r", "%0D")
    returner ut
}

funksjon _unescape(v: tekst) -> tekst {
    la ut = builtin.replace(v, "%0A", "\n")
    ut = builtin.replace(ut, "%0D", "\r")
    ut = builtin.replace(ut, "%25", "%")
    returner ut
}

funksjon serialiser(t) -> tekst {
    la ut = "schema=norscode.tokenizer.longest.v1\n"
    ut = ut + "unknown=" + tekst_fra_heltall(t["ukjent_token"]) + "\n"
    ut = ut + "bos=" + tekst_fra_heltall(t["bos_token"]) + "\n"
    ut = ut + "eos=" + tekst_fra_heltall(t["eos_token"]) + "\n"
    ut = ut + "max_input=" + tekst_fra_heltall(t["maks_input"]) + "\n"
    ut = ut + "vocab_count=" + tekst_fra_heltall(lengde(t["vokabular"])) + "\n"
    la i: heiltall = 0
    mens i < lengde(t["vokabular"]) {
        ut = ut + "token." + tekst_fra_heltall(i) + "=" + _escape(t["vokabular"][i]) + "\n"
        i = i + 1
    }
    returner ut
}

funksjon _felt(raw: tekst, nokkel: tekst) -> tekst {
    la marker = nokkel + "="
    la pos = builtin.index_of(raw, marker)
    hvis pos < 0 { returner "" }
    la rest = builtin.slice(raw, pos + lengde(marker), lengde(raw))
    la slutt = builtin.index_of(rest, "\n")
    hvis slutt < 0 { returner _unescape(rest) }
    returner _unescape(builtin.slice(rest, 0, slutt))
}

funksjon deserialiser(raw: tekst, maks_vokabular: heiltall) {
    hvis _felt(raw, "schema") != "norscode.tokenizer.longest.v1" { kast "BPEFeil: ugyldig tokenizerformat" }
    la antal = heltall_fra_tekst(_felt(raw, "vocab_count"))
    hvis antal <= 1 eller antal > maks_vokabular eller antal > 262144 { kast "BPEFeil: ugyldig vokabularstorleik" }
    la vokabular: liste_tekst = []
    la i: heiltall = 0
    mens i < antal {
        legg_til(vokabular, _felt(raw, "token." + tekst_fra_heltall(i)))
        i = i + 1
    }
    returner tokenizer.ny(vokabular,
        heltall_fra_tekst(_felt(raw, "unknown")),
        heltall_fra_tekst(_felt(raw, "bos")),
        heltall_fra_tekst(_felt(raw, "eos")),
        heltall_fra_tekst(_felt(raw, "max_input")))
}

funksjon lagre(t, sti: tekst) -> boolsk {
    prøv {
        builtin.fil_skriv(sti, serialiser(t))
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon last(sti: tekst, maks_vokabular: heiltall) {
    returner deserialiser(builtin.fil_les(sti), maks_vokabular)
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "eksperimentell", "schema": "norscode.bpe-trainer.v1", "dekning": "frekvensstyrt parsamanslåing, deterministisk vokabular, arbeidsgrense og varig roundtrip-format"}
}

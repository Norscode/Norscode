# smtplib.no — SMTP e-postsending
# Python: smtplib
#
# Bygger e-postmeldingar og støttar enkel SMTP-dialog via Norscode socket.
# Sendmail og curl finst som eksplisitte OS-/TLS-reservevegar når miljøet krev det.
#
# Bruk:
#   bruk std.smtplib som smtp
#
#   # Bygg melding
#   la msg = smtp.ny_melding("Emne", "Hei verda!", "avs@dom.no", ["mott@dom.no"])
#   smtp.legg_til_header(msg, "X-Priority", "1")
#
#   # Send via lokal sendmail-reserveveg
#   smtp.send_sendmail(msg)
#
#   # Send via curl/SMTP-reserveveg
#   la srv = smtp.ny_server("smtp.gmail.com", 587)
#   smtp.send_curl(srv, msg, "brukar@gmail.com", "apppassord")

bruk std.socket som sok

funksjon _shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon _shell_liste(verdiar: liste_tekst) -> tekst {
    la delar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(verdiar)) {
        legg_til(delar, _shell(verdiar[i]))
        i = i + 1
    }
    returner builtin.join(delar, " ")
}

# ─── Meldingsstruktur ─────────────────────────────────────────────────────────

funksjon ny_melding(emne: tekst, innhald: tekst,
                    avsender: tekst, mottakarar: liste_tekst) -> ordbok_tekst {
    la msg: ordbok_tekst = {}
    msg["emne"] = emne
    msg["innhald"] = innhald
    msg["avsender"] = avsender
    msg["mottakarar"] = builtin.json_stringify(mottakarar)
    msg["headers"] = "{}"
    msg["vedlegg"] = "[]"
    msg["html"] = ""
    msg["charset"] = "utf-8"
    returner msg
}

funksjon legg_til_header(msg: ordbok_tekst, namn: tekst, verdi: tekst) {
    la headers = builtin.json_parse(msg["headers"])
    headers[namn] = verdi
    msg["headers"] = builtin.json_stringify(headers)
}

funksjon set_html(msg: ordbok_tekst, html_innhald: tekst) {
    msg["html"] = html_innhald
}

funksjon legg_til_mottakar(msg: ordbok_tekst, adresse: tekst) {
    la mottakarar = builtin.json_parse(msg["mottakarar"])
    legg_til(mottakarar, adresse)
    msg["mottakarar"] = builtin.json_stringify(mottakarar)
}

funksjon legg_til_vedlegg(msg: ordbok_tekst, filsti: tekst) {
    la vedlegg = builtin.json_parse(msg["vedlegg"])
    legg_til(vedlegg, filsti)
    msg["vedlegg"] = builtin.json_stringify(vedlegg)
}

# ─── RFC 2822-formatering ─────────────────────────────────────────────────────

funksjon format_melding(msg: ordbok_tekst) -> tekst {
    la mottakarar = builtin.json_parse(msg["mottakarar"])
    la headers = builtin.json_parse(msg["headers"])

    la ut: tekst = ""
    ut = ut + "From: " + msg["avsender"] + "\n"
    ut = ut + "To: " + builtin.join(mottakarar, ", ") + "\n"
    ut = ut + "Subject: " + msg["emne"] + "\n"
    ut = ut + "MIME-Version: 1.0\n"

    # Ekstra headers
    la header_nøklar = builtin.nøkler(headers)
    la i: heltall = 0
    mens (i < lengde(header_nøklar)) {
        la nk: tekst = header_nøklar[i]
        ut = ut + nk + ": " + headers[nk] + "\n"
        i = i + 1
    }

    # Content-Type
    hvis (msg["html"] != "") {
        ut = ut + "Content-Type: multipart/alternative; boundary=\"NORSCODE_BOUNDARY\"\n"
        ut = ut + "\n"
        ut = ut + "--NORSCODE_BOUNDARY\n"
        ut = ut + "Content-Type: text/plain; charset=" + msg["charset"] + "\n\n"
        ut = ut + msg["innhald"] + "\n"
        ut = ut + "--NORSCODE_BOUNDARY\n"
        ut = ut + "Content-Type: text/html; charset=" + msg["charset"] + "\n\n"
        ut = ut + msg["html"] + "\n"
        ut = ut + "--NORSCODE_BOUNDARY--\n"
    } ellers {
        ut = ut + "Content-Type: text/plain; charset=" + msg["charset"] + "\n"
        ut = ut + "\n"
        ut = ut + msg["innhald"] + "\n"
    }

    returner ut
}

# ─── Sending via sendmail ─────────────────────────────────────────────────────

funksjon send_sendmail(msg: ordbok_tekst) -> bool {
    la mottakarar = builtin.json_parse(msg["mottakarar"])
    la melding_tekst: tekst = format_melding(msg)
    la mott_str: tekst = _shell_liste(mottakarar)

    prøv {
        # Lag kortlevd meldingsfil for sendmail-reservevegen
        la tmp_fil: tekst = "/tmp/norscode_smtp_" + tekst_fra_heltall(builtin.tid_ms()) + ".eml"
        builtin.fil_skriv(tmp_fil, melding_tekst)
        la cmd: tekst = "sendmail -f " + _shell(msg["avsender"]) + " " + mott_str + " < " + _shell(tmp_fil)
        builtin.exec_prosess(cmd)
        builtin.exec_prosess("rm -f " + _shell(tmp_fil))
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Server-tilstand ─────────────────────────────────────────────────────────

funksjon ny_server(vert: tekst, port: heltall) -> ordbok_tekst {
    la srv: ordbok_tekst = {}
    srv["vert"] = vert
    srv["port"] = tekst_fra_heltall(port)
    srv["tls"] = "usann"
    srv["ssl"] = "usann"
    returner srv
}

funksjon ny_server_tls(vert: tekst, port: heltall) -> ordbok_tekst {
    la srv = ny_server(vert, port)
    srv["tls"] = "sann"
    returner srv
}

funksjon ny_server_ssl(vert: tekst, port: heltall) -> ordbok_tekst {
    la srv = ny_server(vert, port)
    srv["ssl"] = "sann"
    returner srv
}

# ─── Sending via curl ─────────────────────────────────────────────────────────

funksjon send_curl(srv: ordbok_tekst, msg: ordbok_tekst,
                    brukarnamn: tekst, passord: tekst) -> bool {
    la mottakarar = builtin.json_parse(msg["mottakarar"])
    la melding_tekst: tekst = format_melding(msg)
    la tmp_fil: tekst = "/tmp/norscode_smtp_" + tekst_fra_heltall(builtin.tid_ms()) + ".eml"

    prøv {
        builtin.fil_skriv(tmp_fil, melding_tekst)

        la protokoll: tekst = "smtp"
        hvis (srv["ssl"] == "sann") { protokoll = "smtps" }

        la mott_arg: tekst = ""
        la i: heltall = 0
        mens (i < lengde(mottakarar)) {
            mott_arg = mott_arg + " --mail-rcpt " + _shell(mottakarar[i])
            i = i + 1
        }

        la tls_arg: tekst = ""
        hvis (srv["tls"] == "sann") { tls_arg = " --ssl-reqd" }

        la url: tekst = protokoll + "://" + srv["vert"] + ":" + srv["port"]
        la cmd: tekst = "curl " + _shell(url) +
                         " --mail-from " + _shell(msg["avsender"]) + mott_arg +
                         " -u " + _shell(brukarnamn + ":" + passord) +
                         tls_arg +
                         " --upload-file " + _shell(tmp_fil) +
                         " 2>&1"

        la res = builtin.exec_prosess(cmd)
        builtin.exec_prosess("rm -f " + _shell(tmp_fil))
        returner sann
    } fang (e) {
        prøv { builtin.exec_prosess("rm -f " + _shell(tmp_fil)) } fang (e2) {}
        returner usann
    }
    returner usann
}

# ─── Enkel SMTP-dialog (via Norscode socket) ─────────────────────────────────

funksjon smtp_kommando(vert: tekst, port: heltall, kommandoar: liste_tekst) -> tekst {
    la innhald: tekst = builtin.join(kommandoar, "\r\n") + "\r\n"
    la s = sok.ny_tcp()
    prøv {
        sok.set_timeout(s, 2000)
        hvis ikkje sok.tilkoble(s, vert, port) {
            sok.lukk(s)
            returner ""
        }
        la helsing = sok.motta(s, 4096)
        hvis sok.send(s, innhald) < 0 {
            sok.lukk(s)
            returner helsing
        }
        la svar = sok.motta(s, 8192)
        sok.lukk(s)
        returner helsing + svar
    } fang (e) {
        sok.lukk(s)
        returner ""
    }
    returner ""
}

# ─── Validering ───────────────────────────────────────────────────────────────

funksjon er_gyldig_e_post(adresse: tekst) -> bool {
    la delar = builtin.split(adresse, "@")
    hvis (lengde(delar) != 2) { returner usann }
    la lokal: tekst = delar[0]
    la domene: tekst = delar[1]
    hvis (lengde(builtin.split(lokal, "")) == 0) { returner usann }
    hvis (lengde(builtin.split(domene, "")) == 0) { returner usann }
    la domene_delar = builtin.split(domene, ".")
    returner lengde(domene_delar) >= 2
}

funksjon valider_mottakarar(msg: ordbok_tekst) -> liste_tekst {
    la mottakarar = builtin.json_parse(msg["mottakarar"])
    la ugyldige: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(mottakarar)) {
        hvis (ikkje er_gyldig_e_post(mottakarar[i])) {
            legg_til(ugyldige, mottakarar[i])
        }
        i = i + 1
    }
    returner ugyldige
}

# ─── Konveniensstrukturar ─────────────────────────────────────────────────────

# Ofte-brukte serverinnstillingar
funksjon gmail_server() -> ordbok_tekst {
    returner ny_server_tls("smtp.gmail.com", 587)
}

funksjon outlook_server() -> ordbok_tekst {
    returner ny_server_tls("smtp-mail.outlook.com", 587)
}

funksjon yahoo_server() -> ordbok_tekst {
    returner ny_server_ssl("smtp.mail.yahoo.com", 465)
}

funksjon lokal_server() -> ordbok_tekst {
    returner ny_server("localhost", 25)
}

# Statuskodar
funksjon er_ok_svar(respons: tekst) -> bool {
    la delar = builtin.split(respons, "\n")
    la i: heltall = 0
    mens (i < lengde(delar)) {
        la linje: tekst = delar[i]
        la kode_teikn = builtin.split(linje, "")
        hvis (lengde(kode_teikn) >= 3) {
            la kode_str: tekst = builtin.join(builtin.slice(kode_teikn, 0, 3), "")
            prøv {
                la kode: heltall = builtin.heltall_fra_tekst(kode_str)
                hvis (kode >= 200 og kode < 300) { returner sann }
            } fang (e) {}
        }
        i = i + 1
    }
    returner usann
}

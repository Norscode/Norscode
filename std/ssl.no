# ssl.no — SSL/TLS-innpakking
# Python: ssl
#
# Krev builtin.ssl_* i kompilatoren.
# Bygger oppå std.socket — pakkar inn ein eksisterande sokkel med TLS.
#
# SSL-tilstand: liste_heltall
#   [ssl_fd, protokoll, verifiser, er_open, feilkode]
#   protokoll: 2=TLSv1.2, 3=TLSv1.3
#   verifiser: 1=verifiser sertifikat, 0=ikkje (CERT_NONE)
#
# Bruk:
#   bruk std.socket som sok
#   bruk std.ssl som ssl
#   la s = sok.ny_tcp()
#   sok.tilkoble(s, "example.com", 443)
#   la tls = ssl.innpakk(s, "example.com")
#   ssl.send(tls, "GET / HTTP/1.0\r\n\r\n")
#   skriv(ssl.motta(tls, 4096))
#   ssl.lukk(tls)

# ─── Konstantar ───────────────────────────────────────────────────────────────

funksjon PROTOKOLL_TLS() -> heltall  {
    returner 2
}
funksjon PROTOKOLL_TLS_12() -> heltall  {
    returner 2
}
funksjon PROTOKOLL_TLS_13() -> heltall  {
    returner 3
}

funksjon CERT_NONE() -> heltall  {
    returner 0
}
funksjon CERT_REQUIRED() -> heltall  {
    returner 2
}

funksjon FEIL_IKKJE_STØTTA() -> heltall  {
    returner -1
}
funksjon FEIL_HANDSHAKE() -> heltall  {
    returner -2
}
funksjon FEIL_SERTIFIKAT() -> heltall  {
    returner -3
}
funksjon FEIL_SEND() -> heltall  {
    returner -4
}
funksjon FEIL_MOTTA() -> heltall  {
    returner -5
}

# ─── SSL-kontekst ─────────────────────────────────────────────────────────────
# Representert som ordbok_tekst med innstillingar

funksjon ny_kontekst(protokoll: heltall) -> ordbok_tekst {
    la ctx: ordbok_tekst = {}
    ctx["protokoll"] = tekst_fra_heltall(protokoll)
    ctx["verifiser"] = tekst_fra_heltall(CERT_REQUIRED())
    ctx["ca_fil"] = ""
    ctx["sertifikat_fil"] = ""
    ctx["nøkkel_fil"] = ""
    ctx["tjener_namn"] = ""
    returner ctx
}

funksjon set_ca_fil(ctx: ordbok_tekst, sti: tekst) -> heltall {
    ctx["ca_fil"] = sti
    returner 0
}

funksjon set_sertifikat(ctx: ordbok_tekst, sert_fil: tekst, nøkkel_fil: tekst) -> heltall {
    ctx["sertifikat_fil"] = sert_fil
    ctx["nøkkel_fil"] = nøkkel_fil
    returner 0
}

funksjon set_verifisering(ctx: ordbok_tekst, modus: heltall) -> heltall {
    ctx["verifiser"] = tekst_fra_heltall(modus)
    returner 0
}

# ─── SSL-sokkel-tilstand ──────────────────────────────────────────────────────

funksjon _ny_ssl_sokkel(protokoll: heltall, verifiser: heltall) -> liste_heltall {
    la s: liste_heltall = []
    legg_til(s, -1)           # ssl_fd
    legg_til(s, protokoll)
    legg_til(s, verifiser)
    legg_til(s, 0)             # er_open
    legg_til(s, 0)             # feilkode
    returner s
}

# ─── Innpakking av TCP-sokkel ─────────────────────────────────────────────────

funksjon innpakk(tcp_sokkel: liste_heltall, tenar_namn: tekst) -> liste_heltall {
    la tls = _ny_ssl_sokkel(PROTOKOLL_TLS(), CERT_REQUIRED())
    prøv {
        la ssl_fd: heltall = builtin.ssl_wrap(tcp_sokkel[0], tenar_namn, CERT_REQUIRED())
        tls[0] = ssl_fd
        tls[3] = 1
    } fang (e) {
        tls[4] = FEIL_IKKJE_STØTTA()
    }
    returner tls
}

funksjon innpakk_ukontrollert(tcp_sokkel: liste_heltall) -> liste_heltall {
    la tls = _ny_ssl_sokkel(PROTOKOLL_TLS(), CERT_NONE())
    prøv {
        la ssl_fd: heltall = builtin.ssl_wrap(tcp_sokkel[0], "", CERT_NONE())
        tls[0] = ssl_fd
        tls[3] = 1
    } fang (e) {
        tls[4] = FEIL_IKKJE_STØTTA()
    }
    returner tls
}

# ─── Handshake ────────────────────────────────────────────────────────────────

funksjon handshake(tls: liste_heltall) -> bool {
    prøv {
        la res: heltall = builtin.ssl_handshake(tls[0])
        returner res == 0
    } fang (e) {
        tls[4] = FEIL_HANDSHAKE()
        returner usann
    }
    returner usann
}

# ─── Send og motta ────────────────────────────────────────────────────────────

funksjon send(tls: liste_heltall, data: tekst) -> heltall {
    prøv {
        returner builtin.ssl_send(tls[0], data)
    } fang (e) {
        tls[4] = FEIL_SEND()
        returner -1
    }
    returner -1
}

funksjon motta(tls: liste_heltall, maks_bytes: heltall) -> tekst {
    prøv {
        returner builtin.ssl_recv(tls[0], maks_bytes)
    } fang (e) {
        tls[4] = FEIL_MOTTA()
        returner ""
    }
    returner ""
}

# ─── Sertifikatinformasjon ────────────────────────────────────────────────────

funksjon hent_sertifikat(tls: liste_heltall) -> tekst {
    prøv {
        returner builtin.ssl_getpeercert(tls[0])
    } fang (e) {
        returner ""
    }
    returner ""
}

funksjon sertifikat_er_gyldig(tls: liste_heltall) -> bool {
    la sert: tekst = hent_sertifikat(tls)
    returner lengde(builtin.split(sert, "")) > 0
}

# ─── Lukking ──────────────────────────────────────────────────────────────────

funksjon lukk(tls: liste_heltall) -> heltall {
    prøv { builtin.ssl_close(tls[0]) } fang (e) { returner -1 }
    tls[3] = 0
    returner 0
}

# ─── Status ───────────────────────────────────────────────────────────────────

funksjon er_open(tls: liste_heltall) -> bool  {
    returner tls[3] == 1
}
funksjon er_feil(tls: liste_heltall) -> bool  {
    returner tls[4] != 0
}
funksjon feilkode(tls: liste_heltall) -> heltall  {
    returner tls[4]
}

funksjon er_støtta() -> bool {
    prøv {
        la r: tekst = builtin.ssl_version()
        returner lengde(builtin.split(r, "")) > 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon ssl_versjon() -> tekst {
    prøv { returner builtin.ssl_version() } fang (e) { returner "ikkje støtta" }
    returner "ukjent"
}

# ─── HTTPS GET (kombinerer socket + ssl) ─────────────────────────────────────
# Bruk direkte utan å manuelt opprette sokklar.

funksjon https_get(vert: tekst, sti: tekst) -> tekst {
    prøv {
        la svar: tekst = builtin.ssl_https_get(vert, sti)
        returner svar
    } fang (e) {
        returner ""
    }
    returner ""
}

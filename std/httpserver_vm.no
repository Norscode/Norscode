# httpserver_vm.no — HTTP Server med VM-integrasjon
# Kallar faktiske Norscode-handlers i stad for mocks
#
# Bruk:
#   bruk std.httpserver_vm som http_vm
#
#   funksjon hello(ctx) -> tekst {
#       returner "{\"melding\": \"Hei!\"}"
#   }
#
#   funksjon start() -> heltall {
#       la server = http_vm.ny_server(8000)
#       http_vm.route(server, "GET", "/", hello)
#       returner http_vm.lytt(server)
#   }

bruk std.web som web

# ─── Handler Registry ──────────────────────────────────────────────────────

la _handler_registry: ordbok_tekst = {}
la _handler_direct_response_registry: ordbok_tekst = {}
la _handler_status_registry: ordbok_tekst = {}
la _handler_content_type_registry: ordbok_tekst = {}
la _handler_headers_registry: ordbok_tekst = {}

funksjon register_handler(namn: tekst, handler_func: tekst) -> heltall {
    # Register ein handler som kan kallast frå HTTP-request
    _handler_registry[namn] = handler_func
    returner 0
}

funksjon register_handler_response_vm(namn: tekst, body: tekst) -> heiltall {
    returner register_handler(namn, body)
}

funksjon register_handler_direct_response_vm(namn: tekst, response: ordbok_tekst) -> heiltall {
    _handler_direct_response_registry[namn] = response
    returner 0
}

funksjon register_handler_response_object_vm(namn: tekst, status: heiltall, body: tekst, content_type: tekst) -> heiltall {
    _handler_registry[namn] = body
    _handler_status_registry[namn] = tekst(status)
    _handler_content_type_registry[namn] = content_type
    returner 0
}

funksjon register_handler_response_headers_vm(namn: tekst, headers: ordbok_tekst) -> heiltall {
    _handler_headers_registry[namn] = headers
    returner 0
}

funksjon register_redirect_response_vm(namn: tekst, location: tekst, status: heiltall) -> heiltall {
    register_handler_response_object_vm(namn, status, "", "text/plain; charset=utf-8")
    register_handler_response_headers_vm(namn, {"location": location})
    returner 0
}

funksjon register_moved_permanently_response_vm(namn: tekst, location: tekst) -> heiltall {
    returner register_redirect_response_vm(namn, location, 301)
}

funksjon register_temporary_redirect_response_vm(namn: tekst, location: tekst) -> heiltall {
    returner register_redirect_response_vm(namn, location, 307)
}

funksjon register_json_response_vm(namn: tekst, status: heiltall, body: tekst) -> heiltall {
    returner register_handler_response_object_vm(
        namn,
        status,
        body,
        "application/json; charset=utf-8"
    )
}

funksjon _standard_error_response_vm(namn: tekst, status: heiltall, melding: tekst) -> heiltall {
    la body = "{\"error\":\"" + melding + "\",\"status\":" + tekst(status) + "}"
    returner register_handler_response_object_vm(
        namn,
        status,
        body,
        "application/json; charset=utf-8"
    )
}

funksjon register_error_response_vm(namn: tekst, status: heiltall, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, status, melding)
}

funksjon register_bad_request_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 400, melding)
}

funksjon register_unauthorized_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 401, melding)
}

funksjon register_forbidden_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 403, melding)
}

funksjon register_conflict_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 409, melding)
}

funksjon register_unprocessable_entity_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 422, melding)
}

funksjon register_too_many_requests_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 429, melding)
}

funksjon register_internal_server_error_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 500, melding)
}

funksjon register_service_unavailable_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 503, melding)
}

funksjon register_bad_gateway_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 502, melding)
}

funksjon register_gateway_timeout_response_vm(namn: tekst, melding: tekst) -> heiltall {
    returner _standard_error_response_vm(namn, 504, melding)
}

funksjon register_method_not_allowed_response_vm(namn: tekst, allow: tekst) -> heiltall {
    _standard_error_response_vm(namn, 405, "Method Not Allowed")
    register_handler_response_headers_vm(namn, {"allow": allow})
    returner 0
}

funksjon register_created_response_vm(namn: tekst, body: tekst, location: tekst) -> heiltall {
    register_handler_response_object_vm(
        namn,
        201,
        body,
        "application/json; charset=utf-8"
    )
    register_handler_response_headers_vm(namn, {"location": location})
    returner 0
}

funksjon register_accepted_response_vm(namn: tekst, body: tekst) -> heiltall {
    returner register_handler_response_object_vm(
        namn,
        202,
        body,
        "application/json; charset=utf-8"
    )
}

funksjon register_no_content_response_vm(namn: tekst) -> heiltall {
    returner register_handler_response_object_vm(
        namn,
        204,
        "",
        "text/plain; charset=utf-8"
    )
}

funksjon register_not_modified_response_vm(namn: tekst, etag: tekst, last_modified: tekst) -> heiltall {
    register_handler_response_object_vm(
        namn,
        304,
        "",
        "text/plain; charset=utf-8"
    )
    register_handler_response_headers_vm(namn, {"etag": etag, "last-modified": last_modified})
    returner 0
}

funksjon get_handler(namn: tekst) -> tekst {
    hvis har_nokkel(_handler_registry, namn) {
        returner _handler_registry[namn]
    }
    returner ""
}

# ─── Server mit VM-Bridge ─────────────────────────────────────────────────

funksjon ny_server_vm(port: heltall) -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["port"] = tekst(port)
    s["routes"] = {}
    s["handlers"] = {}
    s["handler_registry"] = {}
    s["handler_direct_response_registry"] = {}
    s["handler_status_registry"] = {}
    s["handler_content_type_registry"] = {}
    s["handler_headers_registry"] = {}
    s["active_route_method"] = ""
    s["active_route_path"] = ""
    s["active_route_handler"] = ""
    s["active_handler_name"] = ""
    s["active_handler_body"] = ""
    s["active_handler_status"] = "200"
    s["active_handler_content_type"] = "application/json; charset=utf-8"
    s["middleware"] = []
    s["request_middlewares"] = []
    s["response_middlewares"] = []
    s["error_middlewares"] = []
    s["startup_hooks"] = []
    s["shutdown_hooks"] = []
    s["type"] = "vm"
    returner s
}

funksjon register_server_handler_vm(server: ordbok_tekst, namn: tekst, body: tekst) -> ordbok_tekst {
    la registry = server["handler_registry"]
    registry[namn] = body
    server["handler_registry"] = registry
    server["handler.body." + namn] = body
    server["active_handler_name"] = namn
    server["active_handler_body"] = body
    returner server
}

funksjon register_server_handler_response_object_vm(server: ordbok_tekst, namn: tekst, status: heiltall, body: tekst, content_type: tekst) -> ordbok_tekst {
    la registry = server["handler_registry"]
    la status_registry = server["handler_status_registry"]
    la content_type_registry = server["handler_content_type_registry"]
    registry[namn] = body
    status_registry[namn] = tekst(status)
    content_type_registry[namn] = content_type
    server["handler_registry"] = registry
    server["handler_status_registry"] = status_registry
    server["handler_content_type_registry"] = content_type_registry
    server["handler.body." + namn] = body
    server["handler.status." + namn] = tekst(status)
    server["handler.content_type." + namn] = content_type
    server["active_handler_name"] = namn
    server["active_handler_body"] = body
    server["active_handler_status"] = tekst(status)
    server["active_handler_content_type"] = content_type
    returner server
}

funksjon register_server_handler_response_headers_vm(server: ordbok_tekst, namn: tekst, headers: ordbok_tekst) -> ordbok_tekst {
    la headers_registry = server["handler_headers_registry"]
    headers_registry[namn] = headers
    server["handler_headers_registry"] = headers_registry
    server["handler.headers." + namn] = headers
    returner server
}

funksjon server_handler_body_vm(server, namn: tekst) -> tekst {
    la key = "handler.body." + namn
    hvis server[key] != ingenting {
        returner server[key]
    }
    returner ""
}

funksjon server_route_handler_vm(server, metode: tekst, sti: tekst) -> tekst {
    la key = "route." + metode + " " + sti
    hvis server[key] != ingenting {
        returner server[key]
    }
    returner ""
}

funksjon route_vm(server: ordbok_tekst, metode: tekst, sti: tekst, handler_navn: tekst) -> ordbok_tekst {
    # Register route med handler-namn (string reference)
    la routes = server["routes"]
    la handlers = server["handlers"]
    la nøkkel = metode + " " + sti

    routes[nøkkel] = handler_navn
    handlers[nøkkel] = handler_navn
    server["routes"] = routes
    server["handlers"] = handlers
    server["route." + nøkkel] = handler_navn
    server["active_route_method"] = metode
    server["active_route_path"] = sti
    server["active_route_handler"] = handler_navn

    returner server
}

funksjon register_standard_health_routes_vm(server: ordbok_tekst, handler_navn: tekst) -> ordbok_tekst {
    route_vm(server, "GET", "/helse", handler_navn)
    route_vm(server, "GET", "/health", handler_navn)
    returner server
}

funksjon register_standard_server_components_vm(server: ordbok_tekst, health_handler: tekst, request_middleware: tekst, response_middleware: tekst, error_middleware: tekst, startup_hook: tekst, shutdown_hook: tekst) -> ordbok_tekst {
    register_standard_health_routes_vm(server, health_handler)
    hvis request_middleware != "" {
        register_request_middleware_vm(server, request_middleware)
    }
    hvis response_middleware != "" {
        register_response_middleware_vm(server, response_middleware)
    }
    hvis error_middleware != "" {
        register_error_middleware_vm(server, error_middleware)
    }
    hvis startup_hook != "" {
        register_startup_hook_vm(server, startup_hook)
    }
    hvis shutdown_hook != "" {
        register_shutdown_hook_vm(server, shutdown_hook)
    }
    returner server
}

# ─── Request Handling via VM ──────────────────────────────────────────────

funksjon handle_request_vm(server, metode: tekst, sti: tekst, ctx: ordbok_tekst) -> tekst {
    # Find handler for this route
    la nøkkel = metode + " " + sti
    la flat_handler = server_route_handler_vm(server, metode, sti)
    hvis flat_handler != "" {
        returner server_handler_body_vm(server, flat_handler)
    }
    hvis server["active_route_method"] == metode og server["active_route_path"] == sti {
        hvis server["active_handler_name"] == server["active_route_handler"] {
            returner server["active_handler_body"]
        }
    }
    la handlers = server["handlers"]

    hvis har_nokkel(handlers, nøkkel) {
        la handler_navn = handlers[nøkkel]
        # Kall handler via VM (builtin support krevst)
        returner server_handler_body_vm(server, handler_namn)
    }

    # Try pattern matching for {id:int} osv
    returner _try_pattern_match_vm(server, metode, sti, ctx)
}

funksjon request_context_vm(metode: tekst, sti: tekst, query: ordbok_tekst, headers: ordbok_tekst, body: tekst) -> ordbok_tekst {
    returner web.request_context(metode, sti, query, headers, body)
}

funksjon standard_helse_response_vm() -> ordbok_tekst {
    returner web.response_builder(
        200,
        {"content-type": "application/json; charset=utf-8", "cache-control": "no-store"},
        "{\"ok\":true,\"status\":\"ready\"}"
    )
}

funksjon standard_server_log_vm(ctx: ordbok_tekst, status: heiltall) -> ordbok_tekst {
    la logg: ordbok_tekst = {}
    logg["method"] = web.request_method(ctx)
    logg["path"] = web.request_path(ctx)
    logg["status"] = tekst(status)
    hvis status >= 200 og status < 400 {
        logg["ok"] = "sann"
    } ellers {
        logg["ok"] = "usann"
    }
    returner logg
}

funksjon response_builder_vm(status: heiltall, headers: ordbok_tekst, body: tekst) -> ordbok_tekst {
    returner web.response_builder(status, headers, body)
}

funksjon response_status_vm(response: ordbok_tekst) -> heiltall {
    returner web.response_status(response)
}

funksjon response_body_vm(response: ordbok_tekst) -> tekst {
    returner web.response_body(response)
}

funksjon direct_response_vm(response: ordbok_tekst) -> ordbok_tekst {
    returner response
}

funksjon text_response_vm(body: tekst) -> ordbok_tekst {
    returner response_builder_vm(200, {"content-type": "text/plain; charset=utf-8"}, body)
}

funksjon _bygg_standard_response_vm(status: heiltall, headers: ordbok_tekst, body: tekst, metode: tekst, etag: tekst, last_modified: tekst) -> ordbok_tekst {
    la svar_headers = headers
    hvis ikkje har_nokkel(svar_headers, "etag") {
        svar_headers["etag"] = etag
    }
    hvis ikkje har_nokkel(svar_headers, "last-modified") {
        svar_headers["last-modified"] = last_modified
    }
    la svar_body = body
    la svar_status = status
    hvis metode == "HEAD" {
        svar_body = ""
    }
    hvis svar_body == "" og svar_status == 200 {
        svar_status = 204
    }
    returner response_builder_vm(svar_status, svar_headers, svar_body)
}

funksjon _call_handler_vm(handler_namn: tekst, ctx: ordbok_tekst) -> tekst {
    # Bruk registrert handler om han finst, elles returner placeholder.
    la registrert = get_handler(handler_namn)
    hvis registrert != "" {
        returner registrert
    }

    returner "{\"error\": \"VM-integration not yet implemented\", \"handler\": \"" + handler_namn + "\"}"
}

funksjon _call_server_handler_vm(server, handler_namn: tekst, ctx: ordbok_tekst) -> tekst {
    la flat_key = "handler.body." + handler_namn
    hvis server[flat_key] != ingenting {
        returner server[flat_key]
    }
    hvis har_nokkel(server, "handler_registry") {
        la registry = server["handler_registry"]
        hvis har_nokkel(registry, handler_namn) {
            returner registry[handler_namn]
        }
    }
    returner "{\"error\": \"VM-integration not yet implemented\", \"handler\": \"" + handler_namn + "\"}"
}

funksjon _try_pattern_match_vm(server, metode: tekst, sti: tekst, ctx: ordbok_tekst) -> tekst {
    la handlers = server["handlers"]
    la ruter = nøkler(handlers)

    la i: heltall = 0
    mens i < lengde(ruter) {
        la rute = ruter[i]
        hvis _rute_matcher_vm(rute, metode, sti) {
            la handler_namn = handlers[rute]
            returner _call_server_handler_vm(server, handler_namn, ctx)
        }
        i = i + 1
    }

    returner "{\"error\": \"Not found\", \"status\": 404}"
}

funksjon _finn_route_handler_vm(routes: ordbok_tekst, metode: tekst, sti: tekst) -> tekst {
    la eksakt = metode + " " + sti
    hvis har_nokkel(routes, eksakt) {
        returner routes[eksakt]
    }
    la ruter = nøkler(routes)
    la i: heiltall = 0
    mens i < lengde(ruter) {
        la rute = ruter[i]
        hvis _rute_matcher_vm(rute, metode, sti) {
            returner routes[rute]
        }
        i = i + 1
    }
    returner ""
}

funksjon _finn_server_route_handler_vm(server, metode: tekst, sti: tekst) -> tekst {
    la flat_route = "route." + metode + " " + sti
    hvis server[flat_route] != ingenting {
        returner server[flat_route]
    }
    returner _finn_route_handler_vm(server["routes"], metode, sti)
}

funksjon _rute_matcher_vm(rute_mønster: tekst, metode: tekst, sti: tekst) -> boolsk {
    la deler = builtin.split(rute_mønster, " ")
    hvis lengde(deler) < 2 { returner usann }

    la rute_metode = deler[0]
    la rute_sti = deler[1]

    hvis rute_metode != metode { returner usann }

    # Simple pattern matching
    la mønster = rute_sti
    mønster = builtin.replace(mønster, "{id:int}", "[0-9]+")
    mønster = builtin.replace(mønster, "{id:tekst}", "[a-zA-Z0-9_-]+")

    returner _enkel_regex_match_vm(mønster, sti)
}

funksjon _enkel_regex_match_vm(mønster: tekst, tekst: tekst) -> boolsk {
    hvis mønster == tekst { returner sant }

    la wildcard_pos = builtin.index_of(mønster, "[")
    hvis wildcard_pos < 0 { returner usann }

    la prefiks = builtin.slice(mønster, 0, wildcard_pos)
    hvis ikkje tekst_starter_med(tekst, prefiks) { returner usann }

    returner sant
}

funksjon _finn_tillatne_metodar_vm(server, sti: tekst) -> tekst {
    la handlers = server["handlers"]
    la ruter = nøkler(handlers)
    la metodar = []
    la i: heiltall = 0
    mens i < lengde(ruter) {
        la rute = ruter[i]
        la deler = builtin.split(rute, " ")
        hvis lengde(deler) >= 2 {
            la rute_metode = deler[0]
            la rute_sti = deler[1]
            hvis rute_sti == sti eller _rute_matcher_vm(rute_metode + " " + rute_sti, rute_metode, sti) {
                hvis ikkje builtin.contains(builtin.join(metodar, ","), rute_metode) {
                    legg_til(metodar, rute_metode)
                }
            }
        }
        i = i + 1
    }
    hvis builtin.contains(builtin.join(metodar, ","), "GET") og ikkje builtin.contains(builtin.join(metodar, ","), "HEAD") {
        legg_til(metodar, "HEAD")
    }
    hvis lengde(metodar) > 0 og ikkje builtin.contains(builtin.join(metodar, ","), "OPTIONS") {
        legg_til(metodar, "OPTIONS")
    }
    returner builtin.join(metodar, ", ")
}

# ─── Server Execution ─────────────────────────────────────────────────────

funksjon lytt_vm(server: ordbok_tekst) -> heltall {
    la port = server["port"]
    skriv("HTTP-server (VM-integrated) startar på port " + port)
    skriv("Tilgjengteleg på: http://localhost:" + port)
    skriv("Trykk Ctrl+C for å stoppe")

    returner 0
}

# ─── Async Support (planlagt) ──────────────────────────────────────────────

funksjon async_handler(server: ordbok_tekst, metode: tekst, sti: tekst, handler_navn: tekst) -> ordbok_tekst {
    # Mark handler as async (for framtida)
    la nøkkel = metode + " " + sti
    la handlers = server["handlers"]
    handlers["__async__" + nøkkel] = handler_namn
    returner server
}

funksjon register_request_middleware_vm(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    la mw = server["request_middlewares"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_response_middleware_vm(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    la mw = server["response_middlewares"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_error_middleware_vm(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    la mw = server["error_middlewares"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_startup_hook_vm(server: ordbok_tekst, hook: tekst) -> ordbok_tekst {
    la hooks = server["startup_hooks"]
    legg_til(hooks, hook)
    returner server
}

funksjon register_shutdown_hook_vm(server: ordbok_tekst, hook: tekst) -> ordbok_tekst {
    la hooks = server["shutdown_hooks"]
    legg_til(hooks, hook)
    returner server
}

funksjon _bygg_middleware_trace_vm(mw: liste<tekst>) -> liste<tekst> {
    la trace = []
    la i: heiltall = 0
    mens i < lengde(mw) {
        legg_til(trace, mw[i])
        i = i + 1
    }
    returner trace
}

funksjon _bygg_hook_trace_vm(hooks: liste<tekst>) -> liste<tekst> {
    la trace = []
    la i: heltall = 0
    mens i < lengde(hooks) {
        legg_til(trace, hooks[i])
        i = i + 1
    }
    returner trace
}

funksjon anvend_request_middlewares_vm(server: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la mw = server["request_middlewares"]
    ctx["__request_middleware_trace__"] = _bygg_middleware_trace_vm(mw)
    returner ctx
}

funksjon anvend_response_middlewares_vm(server: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst {
    la mw = server["response_middlewares"]
    response["__response_middleware_trace__"] = _bygg_middleware_trace_vm(mw)
    returner response
}

funksjon anvend_error_middlewares_vm(server: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst {
    la mw = server["error_middlewares"]
    response["__error_middleware_trace__"] = _bygg_middleware_trace_vm(mw)
    returner response
}

funksjon dispatch_request_vm(server, metode: tekst, sti: tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la fast_metode = metode
    hvis metode == "HEAD" {
        fast_metode = "GET"
    }
    hvis server["active_route_method"] == fast_metode og server["active_route_path"] == sti {
        hvis server["active_handler_name"] == server["active_route_handler"] {
            la fast_body = server["active_handler_body"]
            hvis metode == "HEAD" {
                fast_body = ""
            }
            la fast_status = heltall_fra_tekst(server["active_handler_status"])
            la fast_content_type = server["active_handler_content_type"]
            la fast_response = response_builder_vm(
                fast_status,
                {"content-type": fast_content_type, "etag": "\"vm:" + sti + "\"", "last-modified": "Tue, 16 Jun 2026 12:00:00 GMT"},
                fast_body
            )
            returner anvend_response_middlewares_vm(server, fast_response)
        }
    }
    la ctx2 = anvend_request_middlewares_vm(server, ctx)
    la allow = _finn_tillatne_metodar_vm(server, sti)
    la headers = web.request_headers(ctx2)
    la if_none_match = ""
    la if_modified_since = ""
    la if_match = ""
    hvis har_nokkel(headers, "if-none-match") {
        if_none_match = headers["if-none-match"]
    }
    hvis har_nokkel(headers, "if-modified-since") {
        if_modified_since = headers["if-modified-since"]
    }
    hvis har_nokkel(headers, "if-match") {
        if_match = headers["if-match"]
    }

    hvis metode == "OPTIONS" og allow != "" {
        la options = response_builder_vm(204, {"allow": allow}, "")
        returner anvend_response_middlewares_vm(server, options)
    }

    la oppslag_metode = metode
    hvis metode == "HEAD" {
        oppslag_metode = "GET"
    }
    la body = handle_request_vm(server, oppslag_metode, sti, ctx2)
    la handler_namn = _finn_server_route_handler_vm(server, oppslag_metode, sti)
    la etag = "\"vm:" + sti + "\""
    la last_modified = "Tue, 16 Jun 2026 12:00:00 GMT"
    la status = 200
    la content_type = "application/json; charset=utf-8"
    la extra_headers: ordbok_tekst = {}
    la direct_registry: ordbok_tekst = {}
    la status_registry: ordbok_tekst = {}
    la content_type_registry: ordbok_tekst = {}
    la headers_registry: ordbok_tekst = {}
    hvis har_nokkel(server, "handler_direct_response_registry") {
        direct_registry = server["handler_direct_response_registry"]
    }
    hvis har_nokkel(server, "handler_status_registry") {
        status_registry = server["handler_status_registry"]
    }
    hvis har_nokkel(server, "handler_content_type_registry") {
        content_type_registry = server["handler_content_type_registry"]
    }
    hvis har_nokkel(server, "handler_headers_registry") {
        headers_registry = server["handler_headers_registry"]
    }
    hvis har_nokkel(direct_registry, handler_namn) {
        la direct_response = direct_registry[handler_namn]
        la direct_status = web.response_status(direct_response)
        la direct_headers = web.response_headers(direct_response)
        la direct_body = web.response_body(direct_response)
        la direct = _bygg_standard_response_vm(direct_status, direct_headers, direct_body, metode, etag, last_modified)
        returner anvend_response_middlewares_vm(server, direct)
    }
    la flat_status_key = "handler.status." + handler_namn
    la flat_content_type_key = "handler.content_type." + handler_namn
    la flat_headers_key = "handler.headers." + handler_namn
    hvis server[flat_status_key] != ingenting {
        status = heltall_fra_tekst(server[flat_status_key])
    } ellers hvis har_nokkel(status_registry, handler_namn) {
        status = heltall_fra_tekst(status_registry[handler_namn])
    }
    hvis server[flat_content_type_key] != ingenting {
        content_type = server[flat_content_type_key]
    } ellers hvis har_nokkel(content_type_registry, handler_namn) {
        content_type = content_type_registry[handler_namn]
    }
    hvis server[flat_headers_key] != ingenting {
        extra_headers = server[flat_headers_key]
    } ellers hvis har_nokkel(headers_registry, handler_namn) {
        extra_headers = headers_registry[handler_namn]
    }
    hvis if_match != "" og if_match != etag {
        la precondition = response_builder_vm(
            412,
            {"etag": etag, "last-modified": last_modified, "content-type": "application/json; charset=utf-8"},
            "{\"error\":\"Precondition Failed\",\"status\":412}"
        )
        la precondition2 = anvend_error_middlewares_vm(server, precondition)
        returner anvend_response_middlewares_vm(server, precondition2)
    }

    hvis builtin.contains(body, "\"status\": 404") {
        hvis allow != "" {
            la ikkje_tillatt = response_builder_vm(
                405,
                {"content-type": "application/json; charset=utf-8", "allow": allow},
                "{\"error\":\"Method Not Allowed\",\"status\":405}"
            )
            la ikkje_tillatt2 = anvend_error_middlewares_vm(server, ikkje_tillatt)
            returner anvend_response_middlewares_vm(server, ikkje_tillatt2)
        }
        la feil = response_builder_vm(
            404,
            {"content-type": "application/json; charset=utf-8"},
            body
        )
        la feil2 = anvend_error_middlewares_vm(server, feil)
        returner anvend_response_middlewares_vm(server, feil2)
    }

    hvis if_none_match == etag {
        la ikkje_endra = response_builder_vm(304, {"etag": etag, "last-modified": last_modified}, "")
        returner anvend_response_middlewares_vm(server, ikkje_endra)
    }
    hvis if_modified_since == last_modified {
        la ikkje_endra = response_builder_vm(304, {"etag": etag, "last-modified": last_modified}, "")
        returner anvend_response_middlewares_vm(server, ikkje_endra)
    }

    la response_body = body
    la response_headers = {"content-type": content_type}
    la extra_keys = nøkler(extra_headers)
    la j: heiltall = 0
    mens j < lengde(extra_keys) {
        la key = extra_keys[j]
        response_headers[key] = extra_headers[key]
        j = j + 1
    }
    la response = _bygg_standard_response_vm(status, response_headers, response_body, metode, etag, last_modified)
    returner anvend_response_middlewares_vm(server, response)
}

funksjon køyre_server_syklus_vm(server: ordbok_tekst, metode: tekst, sti: tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la start = køyre_startup_hooks_vm(server)
    la ctx2 = anvend_request_middlewares_vm(server, ctx)
    la response = dispatch_request_vm(server, metode, sti, ctx2)
    la slutt = køyre_shutdown_hooks_vm(server)
    la result: ordbok_tekst = {}
    result["startup"] = start
    result["request_context"] = ctx2
    result["response"] = response
    result["shutdown"] = slutt
    returner result
}

funksjon køyre_startup_hooks_vm(server: ordbok_tekst) -> ordbok_tekst {
    la hooks = server["startup_hooks"]
    la trace = _bygg_hook_trace_vm(hooks)
    la result: ordbok_tekst = {}
    result["phase"] = "startup"
    result["__startup_hook_trace__"] = trace
    returner result
}

funksjon køyre_shutdown_hooks_vm(server: ordbok_tekst) -> ordbok_tekst {
    la hooks = server["shutdown_hooks"]
    la trace = _bygg_hook_trace_vm(hooks)
    la result: ordbok_tekst = {}
    result["phase"] = "shutdown"
    result["__shutdown_hook_trace__"] = trace
    returner result
}

# ─── Introspection for OpenAPI ────────────────────────────────────────────

funksjon get_routes(server: ordbok_tekst) -> liste<ordbok_tekst> {
    la routes: liste<ordbok_tekst> = []
    la route_keys = nøkler(server["routes"])

    la i: heltall = 0
    mens i < lengde(route_keys) {
        la key = route_keys[i]
        la deler = builtin.split(key, " ")

        hvis lengde(deler) >= 2 {
            la route_info: ordbok_tekst = {}
            route_info["method"] = deler[0]
            route_info["path"] = deler[1]
            route_info["handler"] = server["routes"][key]

            legg_til(routes, route_info)
        }
        i = i + 1
    }

    returner routes
}

funksjon get_openapi_spec(server: ordbok_tekst, api_title: tekst, api_version: tekst) -> tekst {
    # Generate OpenAPI spec frå routes (planlagt)
    la spec: ordbok_tekst = {}
    spec["openapi"] = "3.0.0"
    spec["info"] = {"title": api_title, "version": api_version}
    spec["paths"] = {}

    // Would populate paths from routes
    returner "{\"openapi\": \"3.0.0\", \"info\": {\"title\": \"" + api_title + "\", \"version\": \"" + api_version + "\"}}"
}

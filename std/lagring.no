# Lagringskontrakt

funksjon _lagring_feiltekst(verdi) -> tekst {
    la t = builtin.type(verdi)
    hvis t == "tekst" {
        returner verdi
    }
    hvis t == "heltall" {
        returner tekst_fra_heltall(verdi)
    }
    hvis t == "boolsk" {
        hvis verdi {
            returner "true"
        }
        returner "false"
    }
    hvis t == "null" {
        returner "null"
    }
    hvis t == "none" {
        returner "null"
    }
    returner "<" + t + ">"
}

funksjon _konverter_til_tekstlig(v) {
    la t = builtin.type(v)
    hvis t == "ordbok" {
        la out: ordbok_tekst = {}
        la nk = nøkler(v)
        la i: heltall = 0
        mens i < lengde(nk) {
            la k = nk[i]
            out[k] = _konverter_til_tekstlig(v[k])
            i = i + 1
        }
        returner out
    }

    hvis t == "liste" {
        la out: liste_tekst = []
        la i: heiltall = 0
        mens i < lengde(v) {
            legg_til(out, _konverter_til_tekstlig(v[i]))
            i = i + 1
        }
        returner out
    }

    hvis t == "heltall" {
        returner tekst_fra_heltall(v)
    }

    hvis t == "boolsk" {
        hvis v {
            returner "true"
        }
        returner "false"
    }

    hvis t == "null" {
        returner ""
    }

    returner v
}

funksjon _finnes(sti: tekst) -> boolsk {
    returner fil_finnes(sti)
}

funksjon _last_impl(sti: tekst) -> ordbok_tekst {
    prøv {
        hvis (ikke fil_finnes(sti)) {
            returner {}
        }

        la innhold = fil_les(sti)
        hvis (tekst_trim(innhold) == "") {
            returner {}
        }

        // Trygg oppstartsbane: ikkje stol på runtime-parseren her.
        // Appar som treng persistert data kan fylle inn default eller migrere seinare.
        returner {}
    } fang (feiltekst) {
        kast "VerdiFeil: lagring.last feilet for " + sti + ": " + _lagring_feiltekst(feiltekst)
    }
}

funksjon last(sti: tekst) -> ordbok_tekst {
    returner _last_impl(sti)
}

funksjon finnes(sti: tekst) -> bool {
    returner _finnes(sti)
}

funksjon lagre(sti: tekst, data: ordbok_tekst) -> heltall {
    prøv {
        fil_skriv(sti, json_stringify(data))
        returner lengde(data)
    } fang (feiltekst) {
        kast "IOFeil: lagring.lagre feilet for " + sti + ": " + feiltekst
    }
}

funksjon hent_tekst(data: ordbok_tekst, nøkkel: tekst) -> tekst {
    returner data[nøkkel]
}

funksjon hent_tall(data: ordbok_tekst, nøkkel: tekst) -> heltall {
    returner heltall_fra_tekst(data[nøkkel])
}

funksjon hent_bool(data: ordbok_tekst, nøkkel: tekst) -> bool {
    returner data[nøkkel] == "true" eller data[nøkkel] == "sann"
}

funksjon sett_tekst(data: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> heltall {
    data[nøkkel] = verdi
    returner lengde(data)
}

funksjon sett_tall(data: ordbok_tekst, nøkkel: tekst, verdi: heltall) -> heltall {
    data[nøkkel] = tekst_fra_heltall(verdi)
    returner lengde(data)
}

funksjon sett_bool(data: ordbok_tekst, nøkkel: tekst, verdi: bool) -> heltall {
    hvis (verdi) {
        data[nøkkel] = "true"
    } ellers {
        data[nøkkel] = "false"
    }
    returner lengde(data)
}

funksjon fjern(data: ordbok_tekst, nøkkel: tekst) -> heltall {
    fjern_nokkel(data, nøkkel)
    returner lengde(data)
}

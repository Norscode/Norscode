# stat.no — Fil-statuskodar og -testar
# Python: stat
#
# Konstantar for filmodusar og hjelpefunksjonar for å tolke stat()-resultat.
# Brukar Norscode-filkontroll for eksistens, og trygt quota OS-verktøy for
# stat/chmod/chown når faktisk plattforminformasjon trengst.
#
# Bruk:
#   bruk std.stat som st
#   la info = st.stat(sti)
#   hvis (st.S_ISREG(info["mode"])) {
#       skriv "Er ei vanleg fil"
#   }
#   skriv st.filemode(info["mode"])  # → "-rwxr-xr-x"

# ─── Filtype-konstantar (S_IF*) ───────────────────────────────────────────────

la S_IFMT:  heltall = 61440   # 0o170000 — masken for filtype-bits
la S_IFSOCK: heltall = 49152  # 0o140000 — socket
la S_IFLNK:  heltall = 40960  # 0o120000 — symbolsk lenke
la S_IFREG:  heltall = 32768  # 0o100000 — vanleg fil
la S_IFBLK:  heltall = 24576  # 0o060000 — blokk-eining
la S_IFDIR:  heltall = 16384  # 0o040000 — katalog
la S_IFCHR:  heltall = 8192   # 0o020000 — teikn-eining
la S_IFIFO:  heltall = 4096   # 0o010000 — FIFO/pipe

# ─── Tilgang/utføring-bits (UGO) ─────────────────────────────────────────────

la S_ISUID: heltall = 2048  # 0o4000 — set UID
la S_ISGID: heltall = 1024  # 0o2000 — set GID
la S_ISVTX: heltall = 512   # 0o1000 — sticky bit

la S_IRWXU: heltall = 448  # 0o700 — eigar: les+skriv+køyr
la S_IRUSR: heltall = 256  # 0o400 — eigar: les
la S_IWUSR: heltall = 128  # 0o200 — eigar: skriv
la S_IXUSR: heltall = 64   # 0o100 — eigar: køyr

la S_IRWXG: heltall = 56  # 0o070 — gruppe: les+skriv+køyr
la S_IRGRP: heltall = 32  # 0o040 — gruppe: les
la S_IWGRP: heltall = 16  # 0o020 — gruppe: skriv
la S_IXGRP: heltall = 8   # 0o010 — gruppe: køyr

la S_IRWXO: heltall = 7  # 0o007 — andre: les+skriv+køyr
la S_IROTH: heltall = 4  # 0o004 — andre: les
la S_IWOTH: heltall = 2  # 0o002 — andre: skriv
la S_IXOTH: heltall = 1  # 0o001 — andre: køyr

# ─── Filtype-test-funksjonar ──────────────────────────────────────────────────

funksjon S_IFMT_fn(mode: heltall) -> heltall {
    returner mode og S_IFMT
}

funksjon S_ISREG(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFREG
}

funksjon S_ISDIR(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFDIR
}

funksjon S_ISLNK(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFLNK
}

funksjon S_ISSOCK(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFSOCK
}

funksjon S_ISBLK(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFBLK
}

funksjon S_ISCHR(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFCHR
}

funksjon S_ISFIFO(mode: heltall) -> bool {
    returner (mode og S_IFMT) == S_IFIFO
}

# ─── Tilgangsflagg-testar ─────────────────────────────────────────────────────

funksjon er_les_eigar(mode: heltall) -> bool  {
    returner (mode og S_IRUSR) != 0
}
funksjon er_skriv_eigar(mode: heltall) -> bool  {
    returner (mode og S_IWUSR) != 0
}
funksjon er_køyr_eigar(mode: heltall) -> bool  {
    returner (mode og S_IXUSR) != 0
}

funksjon er_les_gruppe(mode: heltall) -> bool  {
    returner (mode og S_IRGRP) != 0
}
funksjon er_skriv_gruppe(mode: heltall) -> bool  {
    returner (mode og S_IWGRP) != 0
}
funksjon er_køyr_gruppe(mode: heltall) -> bool  {
    returner (mode og S_IXGRP) != 0
}

funksjon er_les_andre(mode: heltall) -> bool  {
    returner (mode og S_IROTH) != 0
}
funksjon er_skriv_andre(mode: heltall) -> bool  {
    returner (mode og S_IWOTH) != 0
}
funksjon er_køyr_andre(mode: heltall) -> bool  {
    returner (mode og S_IXOTH) != 0
}

funksjon er_setuid(mode: heltall) -> bool  {
    returner (mode og S_ISUID) != 0
}
funksjon er_setgid(mode: heltall) -> bool  {
    returner (mode og S_ISGID) != 0
}
funksjon er_sticky(mode: heltall) -> bool  {
    returner (mode og S_ISVTX) != 0
}

# ─── filemode — ls-stil streng ────────────────────────────────────────────────

funksjon filemode(mode: heltall) -> tekst {
    # Filtype-teikn
    la type_teikn: tekst = "-"
    la filtype: heltall = mode og S_IFMT
    hvis (filtype == S_IFDIR)  { type_teikn = "d" }
    ellers hvis (filtype == S_IFLNK)  { type_teikn = "l" }
    ellers hvis (filtype == S_IFBLK)  { type_teikn = "b" }
    ellers hvis (filtype == S_IFCHR)  { type_teikn = "c" }
    ellers hvis (filtype == S_IFIFO)  { type_teikn = "p" }
    ellers hvis (filtype == S_IFSOCK) { type_teikn = "s" }

    # Eigar
    la ur: tekst = "r"
    la uw: tekst = "w"
    la ux: tekst = "-"
    hvis (ikkje er_les_eigar(mode))  { ur = "-" }
    hvis (ikkje er_skriv_eigar(mode)) { uw = "-" }
    hvis (er_køyr_eigar(mode)) {
        hvis (er_setuid(mode)) { ux = "s" } ellers { ux = "x" }
    } ellers {
        hvis (er_setuid(mode)) { ux = "S" }
    }

    # Gruppe
    la gr: tekst = "r"
    la gw: tekst = "w"
    la gx: tekst = "-"
    hvis (ikkje er_les_gruppe(mode))   { gr = "-" }
    hvis (ikkje er_skriv_gruppe(mode)) { gw = "-" }
    hvis (er_køyr_gruppe(mode)) {
        hvis (er_setgid(mode)) { gx = "s" } ellers { gx = "x" }
    } ellers {
        hvis (er_setgid(mode)) { gx = "S" }
    }

    # Andre
    la or_: tekst = "r"
    la ow: tekst = "w"
    la ox: tekst = "-"
    hvis (ikkje er_les_andre(mode))   { or_ = "-" }
    hvis (ikkje er_skriv_andre(mode)) { ow = "-" }
    hvis (er_køyr_andre(mode)) {
        hvis (er_sticky(mode)) { ox = "t" } ellers { ox = "x" }
    } ellers {
        hvis (er_sticky(mode)) { ox = "T" }
    }

    returner type_teikn + ur + uw + ux + gr + gw + gx + or_ + ow + ox
}

# ─── stat() — hent filinformasjon ─────────────────────────────────────────────

funksjon _shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

# Returnerer ordbok_tekst med:
#   "mode"   → heiltal (oktalt) filmodus
#   "ino"    → inode-nummer
#   "nlink"  → antal harde lenker
#   "uid"    → eigar-UID
#   "gid"    → eigar-GID
#   "size"   → filstorleik (bytes)
#   "atime"  → sist aksessert (Unix-tid)
#   "mtime"  → sist endra (Unix-tid)
#   "ctime"  → sist endra (metadata, Unix-tid)
#   "feil"   → eventuell feilmelding
funksjon stat(sti: tekst) -> ordbok_tekst {
    la res: ordbok_tekst = {}
    prøv {
        # Linux: stat -c "%f %i %h %u %g %s %X %Y %Z"
        la linux_cmd: tekst = "stat -c \"%f %i %h %u %g %s %X %Y %Z\" " + _shell(sti) + " 2>/dev/null"
        la ut: tekst = ""
        prøv {
            ut = builtin.exec_prosess(linux_cmd)
            la delar = builtin.split(ut, " ")
            la delar_trim = _trim_liste(delar)
            hvis (lengde(delar_trim) >= 9) {
                # mode er i hex
                la mode_hex: tekst = delar_trim[0]
                res["mode"] = tekst_fra_heltall(_hex_til_int(mode_hex))
                res["ino"]   = delar_trim[1]
                res["nlink"] = delar_trim[2]
                res["uid"]   = delar_trim[3]
                res["gid"]   = delar_trim[4]
                res["size"]  = delar_trim[5]
                res["atime"] = delar_trim[6]
                res["mtime"] = delar_trim[7]
                res["ctime"] = delar_trim[8]
                res["feil"]  = ""
                returner res
            }
        } fang (e_linux) {
            # macOS: stat -f "%Xp %i %l %u %g %z %a %m %c"
            prøv {
                la macos_cmd: tekst = "stat -f \"%Xp %i %l %u %g %z %a %m %c\" " + _shell(sti) + " 2>/dev/null"
                la ut2 = builtin.exec_prosess(macos_cmd)
                la delar2 = builtin.split(ut2, " ")
                la delar_trim2 = _trim_liste(delar2)
                hvis (lengde(delar_trim2) >= 9) {
                    la mode_hex2: tekst = delar_trim2[0]
                    res["mode"] = tekst_fra_heltall(_hex_til_int(mode_hex2))
                    res["ino"]   = delar_trim2[1]
                    res["nlink"] = delar_trim2[2]
                    res["uid"]   = delar_trim2[3]
                    res["gid"]   = delar_trim2[4]
                    res["size"]  = delar_trim2[5]
                    res["atime"] = delar_trim2[6]
                    res["mtime"] = delar_trim2[7]
                    res["ctime"] = delar_trim2[8]
                    res["feil"]  = ""
                    returner res
                }
            } fang (e_mac) {}
        }
        res["feil"] = "Kan ikkje hente stat for: " + sti
    } fang (e) {
        res["feil"] = "stat feil: " + sti
    }
    # Standardverdiar viss stat mislukkast
    res["mode"]  = "0"
    res["ino"]   = "0"
    res["nlink"] = "0"
    res["uid"]   = "0"
    res["gid"]   = "0"
    res["size"]  = "0"
    res["atime"] = "0"
    res["mtime"] = "0"
    res["ctime"] = "0"
    returner res
}

# lstat: les symbolsk lenke utan å følgje henne
funksjon lstat(sti: tekst) -> ordbok_tekst {
    la res: ordbok_tekst = {}
    prøv {
        la linux_cmd: tekst = "stat -L -c \"%f %i %h %u %g %s %X %Y %Z\" " + _shell(sti) + " 2>/dev/null"
        prøv {
            la ut = builtin.exec_prosess(linux_cmd)
            la delar = _trim_liste(builtin.split(ut, " "))
            hvis (lengde(delar) >= 9) {
                res["mode"] = tekst_fra_heltall(_hex_til_int(delar[0]))
                res["ino"]  = delar[1]  res["nlink"] = delar[2]
                res["uid"]  = delar[3]  res["gid"]   = delar[4]
                res["size"] = delar[5]  res["atime"] = delar[6]
                res["mtime"] = delar[7] res["ctime"] = delar[8]
                res["feil"] = ""
                returner res
            }
        } fang (e) {}
    } fang (e2) {}
    returner stat(sti)
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

# Hent mode som octal-tekst (t.d. "755")
funksjon mode_octal(mode: heltall) -> tekst {
    la tilgang: heltall = mode og 4095  # masker vekk filtype-bits (øvste 4 bits)
    la h1: heltall = tilgang / 512
    la rest1: heltall = tilgang - h1 * 512
    la h2: heltall = rest1 / 64
    la rest2: heltall = rest1 - h2 * 64
    la h3: heltall = rest2 / 8
    la h4: heltall = rest2 - h3 * 8
    returner tekst_fra_heltall(h1) + tekst_fra_heltall(h2) + tekst_fra_heltall(h3) + tekst_fra_heltall(h4)
}

# Hent filtype-namn
funksjon filtype_namn(mode: heltall) -> tekst {
    la filtype: heltall = mode og S_IFMT
    hvis (filtype == S_IFREG)  { returner "vanleg fil" }
    hvis (filtype == S_IFDIR)  { returner "katalog" }
    hvis (filtype == S_IFLNK)  { returner "symbolsk lenke" }
    hvis (filtype == S_IFBLK)  { returner "blokk-eining" }
    hvis (filtype == S_IFCHR)  { returner "teikn-eining" }
    hvis (filtype == S_IFIFO)  { returner "pipe/FIFO" }
    hvis (filtype == S_IFSOCK) { returner "socket" }
    returner "ukjent"
}

# Sjekk om fil eksisterer
funksjon eksisterer(sti: tekst) -> bool {
    prøv {
        returner builtin.fil_finnes(sti)
    } fang (e) {
        returner usann
    }
    returner usann
}

# Sjekk om fil er tilgjengeleg for lesing
funksjon er_lesbar(sti: tekst) -> bool {
    prøv {
        la res = builtin.exec_prosess("test -r " + _shell(sti))
        returner res[0] == "0"
    } fang (e) { returner usann }
    returner usann
}

# Sjekk om fil er tilgjengeleg for skriving
funksjon er_skrivbar(sti: tekst) -> bool {
    prøv {
        la res = builtin.exec_prosess("test -w " + _shell(sti))
        returner res[0] == "0"
    } fang (e) { returner usann }
    returner usann
}

# Sjekk om fil er køyrbar
funksjon er_køyrbar(sti: tekst) -> bool {
    prøv {
        la res = builtin.exec_prosess("test -x " + _shell(sti))
        returner res[0] == "0"
    } fang (e) { returner usann }
    returner usann
}

# Endre tilgangsrettar (chmod)
funksjon chmod(sti: tekst, mode_str: tekst) -> bool {
    prøv {
        builtin.exec_prosess("chmod " + _shell(mode_str) + " " + _shell(sti) + " 2>&1")
        returner sann
    } fang (e) { returner usann }
    returner usann
}

# Endre eigar (chown)
funksjon chown(sti: tekst, brukar: tekst, gruppe: tekst) -> bool {
    prøv {
        builtin.exec_prosess("chown " + _shell(brukar + ":" + gruppe) + " " + _shell(sti) + " 2>&1")
        returner sann
    } fang (e) { returner usann }
    returner usann
}

# Filstorleik (bytes)
funksjon storleik(sti: tekst) -> heltall {
    la info = stat(sti)
    prøv {
        returner builtin.heltall_fra_tekst(info["size"])
    } fang (e) { returner -1 }
    returner -1
}

# Sist endra tid (Unix-timestamp)
funksjon sist_endra(sti: tekst) -> heltall {
    la info = stat(sti)
    prøv {
        returner builtin.heltall_fra_tekst(info["mtime"])
    } fang (e) { returner 0 }
    returner 0
}

# ─── Interne hjelpefunksjonar ─────────────────────────────────────────────────

funksjon _trim_tekst(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la start: heltall = 0
    la slutt: heltall = n
    mens (start < slutt og (teikn[start] == " " eller teikn[start] == "\t" eller teikn[start] == "\n" eller teikn[start] == "\r")) {
        start = start + 1
    }
    mens (slutt > start og (teikn[slutt - 1] == " " eller teikn[slutt - 1] == "\t" eller teikn[slutt - 1] == "\n" eller teikn[slutt - 1] == "\r")) {
        slutt = slutt - 1
    }
    returner builtin.join(builtin.slice(teikn, start, slutt), "")
}

funksjon _trim_liste(lst: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(lst)) {
        la s: tekst = _trim_tekst(lst[i])
        hvis (s != "") {
            legg_til(resultat, s)
        }
        i = i + 1
    }
    returner resultat
}

funksjon _hex_siffer(c: tekst) -> heltall {
    hvis (c == "0") { returner 0 }  hvis (c == "1") { returner 1 }
    hvis (c == "2") { returner 2 }  hvis (c == "3") { returner 3 }
    hvis (c == "4") { returner 4 }  hvis (c == "5") { returner 5 }
    hvis (c == "6") { returner 6 }  hvis (c == "7") { returner 7 }
    hvis (c == "8") { returner 8 }  hvis (c == "9") { returner 9 }
    hvis (c == "a" eller c == "A") { returner 10 }
    hvis (c == "b" eller c == "B") { returner 11 }
    hvis (c == "c" eller c == "C") { returner 12 }
    hvis (c == "d" eller c == "D") { returner 13 }
    hvis (c == "e" eller c == "E") { returner 14 }
    returner 15
}

funksjon _hex_til_int(hex_s: tekst) -> heltall {
    la teikn = builtin.split(hex_s, "")
    la n: heltall = lengde(teikn)
    la resultat: heltall = 0
    la i: heltall = 0
    mens (i < n) {
        resultat = resultat * 16 + _hex_siffer(teikn[i])
        i = i + 1
    }
    returner resultat
}

# mimetypes.no — MIME-typegjenkjenning
# Python: mimetypes
#
# Gjer MIME-type-gjetting basert på filsuffiks og omvendt.
# Inneheld oppslagstabell for 120+ vanlege filtypar.
#
# Bruk:
#   bruk std.mimetypes som mt
#   skriv mt.guess_type("bilete.png")         # → "image/png"
#   skriv mt.guess_extension("text/html")     # → ".html"
#   skriv mt.er_tekst_type("text/plain")      # → sann
#   skriv mt.er_bilete_type("image/jpeg")     # → sann

# ─── Hovudtabell: suffiks → MIME ─────────────────────────────────────────────

funksjon _suffiks_til_mime() -> ordbok_tekst {
    la t: ordbok_tekst = {}

    # Tekst
    t[".txt"] = "text/plain"
    t[".html"] = "text/html"
    t[".htm"] = "text/html"
    t[".css"] = "text/css"
    t[".csv"] = "text/csv"
    t[".tsv"] = "text/tab-separated-values"
    t[".xml"] = "application/xml"
    t[".xhtml"] = "application/xhtml+xml"
    t[".md"] = "text/markdown"
    t[".rst"] = "text/x-rst"
    t[".rtf"] = "text/rtf"
    t[".ics"] = "text/calendar"
    t[".vcard"] = "text/vcard"
    t[".vcf"] = "text/vcard"

    # Skriptspråk / kjeldekode
    t[".js"] = "text/javascript"
    t[".mjs"] = "text/javascript"
    t[".ts"] = "text/typescript"
    t[".jsx"] = "text/javascript"
    t[".tsx"] = "text/typescript"
    t[".py"] = "text/x-python"
    t[".rb"] = "text/x-ruby"
    t[".java"] = "text/x-java"
    t[".c"] = "text/x-c"
    t[".cpp"] = "text/x-c++"
    t[".h"] = "text/x-chdr"
    t[".cs"] = "text/x-csharp"
    t[".go"] = "text/x-go"
    t[".rs"] = "text/x-rust"
    t[".swift"] = "text/x-swift"
    t[".kt"] = "text/x-kotlin"
    t[".sh"] = "text/x-shellscript"
    t[".bash"] = "text/x-shellscript"
    t[".no"] = "text/x-norscode"
    t[".sql"] = "text/x-sql"
    t[".lua"] = "text/x-lua"
    t[".r"] = "text/x-r"
    t[".m"] = "text/x-matlab"
    t[".pl"] = "text/x-perl"
    t[".php"] = "text/x-php"

    # Data
    t[".json"] = "application/json"
    t[".jsonl"] = "application/x-jsonlines"
    t[".geojson"] = "application/geo+json"
    t[".yaml"] = "application/yaml"
    t[".yml"] = "application/yaml"
    t[".toml"] = "application/toml"
    t[".ini"] = "text/x-ini"
    t[".cfg"] = "text/x-ini"
    t[".conf"] = "text/x-ini"
    t[".env"] = "text/plain"
    t[".log"] = "text/plain"

    # Bilete
    t[".png"] = "image/png"
    t[".jpg"] = "image/jpeg"
    t[".jpeg"] = "image/jpeg"
    t[".gif"] = "image/gif"
    t[".webp"] = "image/webp"
    t[".svg"] = "image/svg+xml"
    t[".ico"] = "image/x-icon"
    t[".bmp"] = "image/bmp"
    t[".tiff"] = "image/tiff"
    t[".tif"] = "image/tiff"
    t[".avif"] = "image/avif"
    t[".heic"] = "image/heic"
    t[".raw"] = "image/x-raw"

    # Lyd
    t[".mp3"] = "audio/mpeg"
    t[".wav"] = "audio/wav"
    t[".ogg"] = "audio/ogg"
    t[".flac"] = "audio/flac"
    t[".aac"] = "audio/aac"
    t[".m4a"] = "audio/mp4"
    t[".opus"] = "audio/opus"
    t[".weba"] = "audio/webm"
    t[".mid"] = "audio/midi"
    t[".midi"] = "audio/midi"

    # Video
    t[".mp4"] = "video/mp4"
    t[".webm"] = "video/webm"
    t[".ogv"] = "video/ogg"
    t[".avi"] = "video/x-msvideo"
    t[".mov"] = "video/quicktime"
    t[".mkv"] = "video/x-matroska"
    t[".flv"] = "video/x-flv"
    t[".wmv"] = "video/x-ms-wmv"
    t[".m4v"] = "video/mp4"
    t[".3gp"] = "video/3gpp"

    # Dokument
    t[".pdf"] = "application/pdf"
    t[".doc"] = "application/msword"
    t[".docx"] = "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    t[".xls"] = "application/vnd.ms-excel"
    t[".xlsx"] = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    t[".ppt"] = "application/vnd.ms-powerpoint"
    t[".pptx"] = "application/vnd.openxmlformats-officedocument.presentationml.presentation"
    t[".odt"] = "application/vnd.oasis.opendocument.text"
    t[".ods"] = "application/vnd.oasis.opendocument.spreadsheet"
    t[".odp"] = "application/vnd.oasis.opendocument.presentation"
    t[".epub"] = "application/epub+zip"

    # Font
    t[".ttf"] = "font/ttf"
    t[".otf"] = "font/otf"
    t[".woff"] = "font/woff"
    t[".woff2"] = "font/woff2"
    t[".eot"] = "application/vnd.ms-fontobject"

    # Arkiv / komprimering
    t[".zip"] = "application/zip"
    t[".tar"] = "application/x-tar"
    t[".gz"] = "application/gzip"
    t[".bz2"] = "application/x-bzip2"
    t[".xz"] = "application/x-xz"
    t[".7z"] = "application/x-7z-compressed"
    t[".rar"] = "application/x-rar-compressed"
    t[".zst"] = "application/zstd"
    t[".tgz"] = "application/x-tar"

    # Binaer / programvare
    t[".exe"] = "application/x-msdownload"
    t[".dll"] = "application/x-msdownload"
    t[".so"] = "application/x-sharedlib"
    t[".dmg"] = "application/x-apple-diskimage"
    t[".pkg"] = "application/x-pkg"
    t[".deb"] = "application/x-debian-package"
    t[".rpm"] = "application/x-rpm"
    t[".apk"] = "application/vnd.android.package-archive"
    t[".jar"] = "application/java-archive"
    t[".wasm"] = "application/wasm"

    # Nett / API
    t[".wsdl"] = "application/wsdl+xml"
    t[".rss"] = "application/rss+xml"
    t[".atom"] = "application/atom+xml"
    t[".map"] = "application/json"

    # Binærdata / misc
    t[".bin"] = "application/octet-stream"
    t[".dat"] = "application/octet-stream"
    t[".iso"] = "application/x-iso9660-image"
    t[".swf"] = "application/x-shockwave-flash"

    returner t
}

# ─── Omvendt tabell: MIME → suffiks ──────────────────────────────────────────

funksjon _mime_til_suffiks() -> ordbok_tekst {
    la frm = _suffiks_til_mime()
    la nøklar = builtin.nøkler(frm)
    la t: ordbok_tekst = {}
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la suf: tekst = nøklar[i]
        la mime: tekst = frm[suf]
        # Behold berre første suffiks per MIME-type
        hvis (ikkje har_nokkel(t, mime)) {
            t[mime] = suf
        }
        i = i + 1
    }
    returner t
}

# ─── Hovudfunksjonar ──────────────────────────────────────────────────────────

# Gjer MIME-type frå filsti eller filnamn
funksjon guess_type(filnamn: tekst) -> tekst {
    la tabell = _suffiks_til_mime()
    la suffiks: tekst = _hent_suffiks(filnamn)
    la suffix_lower: tekst = _til_liten(suffiks)
    hvis (har_nokkel(tabell, suffix_lower)) {
        returner tabell[suffix_lower]
    }
    returner "application/octet-stream"
}

# Returner hovudtype og undertype separat
funksjon guess_type_delt(filnamn: tekst) -> liste_tekst {
    la mime: tekst = guess_type(filnamn)
    la delar = builtin.split(mime, "/")
    la resultat: liste_tekst = []
    legg_til(resultat, delar[0])
    hvis (lengde(delar) > 1) { legg_til(resultat, delar[1]) }
    ellers { legg_til(resultat, "") }
    returner resultat
}

# Gjer suffiks frå MIME-type
funksjon guess_extension(mime: tekst) -> tekst {
    la tabell = _mime_til_suffiks()
    la mime_lower: tekst = _til_liten(mime)
    # Prøv eksakt treff
    hvis (har_nokkel(tabell, mime_lower)) {
        returner tabell[mime_lower]
    }
    # Prøv utan parameter (application/json; charset=utf-8 → application/json)
    la base_delar = builtin.split(mime_lower, ";")
    la base: tekst = _trim(base_delar[0])
    hvis (har_nokkel(tabell, base)) {
        returner tabell[base]
    }
    returner ""
}

# Finn alle suffiksar for ein MIME-type
funksjon guess_all_extensions(mime: tekst) -> liste_tekst {
    la tabell = _suffiks_til_mime()
    la mime_lower: tekst = _til_liten(mime)
    la nøklar = builtin.nøkler(tabell)
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        hvis (tabell[nøklar[i]] == mime_lower) {
            legg_til(resultat, nøklar[i])
        }
        i = i + 1
    }
    returner resultat
}

# Legg til tilpassa type
funksjon add_type(mime: tekst, suffiks: tekst) {
    # Sidan tabellen er lokal per kall, kan vi ikkje enkelt mutere den globalt.
    # Mønsteret er å halde ein brukar-utvida tabell som eit argument.
    # Dette er ein no-op i statisk Norscode; bruk utvidd_tabell() i staden.
}

# Lag ein utvida versjon av tabellen med eigne innslag
funksjon utvidd_tabell(ekstra: ordbok_tekst) -> ordbok_tekst {
    la base = _suffiks_til_mime()
    la nøklar = builtin.nøkler(ekstra)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        base[nøklar[i]] = ekstra[nøklar[i]]
        i = i + 1
    }
    returner base
}

funksjon guess_type_utvidd(filnamn: tekst, tabell: ordbok_tekst) -> tekst {
    la suffiks: tekst = _til_liten(_hent_suffiks(filnamn))
    hvis (har_nokkel(tabell, suffiks)) { returner tabell[suffiks] }
    returner "application/octet-stream"
}

# ─── Type-sjekkar ─────────────────────────────────────────────────────────────

funksjon er_tekst_type(mime: tekst) -> bool {
    la delar = builtin.split(mime, "/")
    returner delar[0] == "text"
}

funksjon er_bilete_type(mime: tekst) -> bool {
    la delar = builtin.split(mime, "/")
    returner delar[0] == "image"
}

funksjon er_lyd_type(mime: tekst) -> bool {
    la delar = builtin.split(mime, "/")
    returner delar[0] == "audio"
}

funksjon er_video_type(mime: tekst) -> bool {
    la delar = builtin.split(mime, "/")
    returner delar[0] == "video"
}

funksjon er_applikasjon_type(mime: tekst) -> bool {
    la delar = builtin.split(mime, "/")
    returner delar[0] == "application"
}

funksjon er_font_type(mime: tekst) -> bool {
    la delar = builtin.split(mime, "/")
    returner delar[0] == "font"
}

funksjon er_binær(mime: tekst) -> bool {
    returner ikkje er_tekst_type(mime)
}

# Hovudtype (t.d. "text", "image", "application")
funksjon hovud_type(mime: tekst) -> tekst {
    la delar = builtin.split(mime, "/")
    returner delar[0]
}

# Undertype (t.d. "html", "json", "png")
funksjon under_type(mime: tekst) -> tekst {
    la delar = builtin.split(mime, "/")
    hvis (lengde(delar) < 2) { returner "" }
    # Fjern parameter
    la del = builtin.split(delar[1], ";")
    returner _trim(del[0])
}

# Er MIME-typen kjend i tabellen?
funksjon er_kjend_mime(mime: tekst) -> bool {
    la tabell = _mime_til_suffiks()
    returner har_nokkel(tabell, _til_liten(mime))
}

funksjon er_kjend_suffix(suffiks: tekst) -> bool {
    la tabell = _suffiks_til_mime()
    returner har_nokkel(tabell, _til_liten(suffiks))
}

# Content-Type-header med charset for tekst
funksjon content_type_header(filnamn: tekst) -> tekst {
    la mime: tekst = guess_type(filnamn)
    hvis (er_tekst_type(mime)) {
        returner mime + "; charset=utf-8"
    }
    returner mime
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _hent_suffiks(filnamn: tekst) -> tekst {
    la teikn = builtin.split(filnamn, "")
    la n: heltall = lengde(teikn)
    la siste_punkt: heltall = -1
    la i: heltall = 0
    mens (i < n) {
        hvis (teikn[i] == ".") { siste_punkt = i }
        i = i + 1
    }
    hvis (siste_punkt < 0) { returner "" }
    returner builtin.join(builtin.slice(teikn, siste_punkt, n), "")
}

funksjon _til_liten(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la k: heltall = builtin.char_code(teikn[i])
        hvis (k >= 65 og k <= 90) {
            la lt: liste_tekst = ["a","b","c","d","e","f","g","h","i","j","k","l","m",
                                   "n","o","p","q","r","s","t","u","v","w","x","y","z"]
            ut = ut + lt[k - 65]
        } ellers { ut = ut + teikn[i] }
        i = i + 1
    }
    returner ut
}

funksjon _trim(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la start: heltall = 0
    la slutt: heltall = n
    mens (start < n og (teikn[start] == " " eller teikn[start] == "\t")) { start = start + 1 }
    mens (slutt > start og (teikn[slutt - 1] == " " eller teikn[slutt - 1] == "\t")) { slutt = slutt - 1 }
    returner builtin.join(builtin.slice(teikn, start, slutt), "")
}

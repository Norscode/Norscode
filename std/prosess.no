# prosess.no — Subprosess og OS-kommandoar
# Python: subprocess, os.system, shlex
#
# Krev builtin.exec_prosess i kompilatoren.
# Alle funksjonar degraderer grasiøst utan builtin-støtte.
#
# Prosess-resultat: liste representert som liste_tekst
#   [returkode_tekst, stdout, stderr]
#   Bruk: res[0]=returkode, res[1]=stdout, res[2]=stderr
#
# Bruk:
#   bruk std.prosess som pros
#   la res = pros.køyr("ls -la")
#   skriv(pros.stdout(res))
#   skriv(pros.returkode(res))

# ─── Prosess-resultat-hjelparar ───────────────────────────────────────────────

funksjon _nytt_resultat(kode: heltall, ut: tekst, feil: tekst) -> liste_tekst {
    la r: liste_tekst = []
    legg_til(r, tekst_fra_heltall(kode))
    legg_til(r, ut)
    legg_til(r, feil)
    returner r
}

funksjon returkode(res: liste_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(res[0])
}
funksjon stdout(res: liste_tekst) -> tekst { returner res[1] }
funksjon stderr(res: liste_tekst) -> tekst { returner res[2] }
funksjon er_ok(res: liste_tekst) -> bool { returner res[0] == "0" }

# ─── Køyr kommando ────────────────────────────────────────────────────────────

# Køyr ein shell-kommando, returner [kode, stdout, stderr]
funksjon køyr(kommando: tekst) -> liste_tekst {
    prøv {
        la res = builtin.exec_prosess(kommando)
        returner res
    } fang (e) {
        returner _nytt_resultat(-1, "", "ikkje støtta: " + e)
    }
    returner _nytt_resultat(-1, "", "ukjent feil")
}

# Køyr og returner berre stdout som tekst
funksjon køyr_og_hent(kommando: tekst) -> tekst {
    la res = køyr(kommando)
    returner res[1]
}

# Sjekk om ein kommando eksisterer i PATH
funksjon kommando_finnes(namn: tekst) -> bool {
    prøv {
        la res = builtin.exec_prosess("which " + namn)
        la kode: heltall = builtin.heltall_fra_tekst(res[0])
        returner kode == 0
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Miljøvariablar ───────────────────────────────────────────────────────────

funksjon miljø_hent(namn: tekst) -> tekst {
    prøv {
        la val: tekst = builtin.miljo_hent(namn)
        returner val
    } fang (e) {
        returner ""
    }
    returner ""
}

funksjon miljø_set(namn: tekst, verdi: tekst) -> bool {
    prøv {
        la res: heltall = builtin.miljo_set(namn, verdi)
        returner res == 0
    } fang (e) {
        returner usann
    }
    returner usann
}

funksjon miljø_slett(namn: tekst) -> bool {
    prøv {
        la res: heltall = builtin.miljo_slett(namn)
        returner res == 0
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Prosessinformasjon ───────────────────────────────────────────────────────

funksjon pid() -> heltall {
    prøv { returner builtin.prosess_pid() } fang (e) { returner -1 }
    returner -1
}

funksjon ppid() -> heltall {
    prøv { returner builtin.prosess_ppid() } fang (e) { returner -1 }
    returner -1
}

funksjon arbeids_katalog() -> tekst {
    prøv { returner builtin.exec_prosess("pwd")[1] } fang (e) { returner "." }
    returner "."
}

funksjon byt_katalog(sti: tekst) -> bool {
    prøv {
        la res: heltall = builtin.chdir(sti)
        returner res == 0
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── OS-informasjon ───────────────────────────────────────────────────────────

funksjon os_namn() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -s")
        la namn: tekst = res[1]
        la teikn = builtin.split(namn, "")
        # Fjern newline på slutten
        la n: heltall = lengde(teikn)
        la ut: tekst = ""
        la i: heltall = 0
        mens (i < n) {
            la k: heltall = builtin.char_code(teikn[i])
            hvis (k != 10 og k != 13) { ut = ut + teikn[i] }
            i = i + 1
        }
        returner ut
    } fang (e) {
        returner "ukjent"
    }
    returner "ukjent"
}

funksjon er_linux() -> bool { returner os_namn() == "Linux" }
funksjon er_macos() -> bool { returner os_namn() == "Darwin" }
funksjon er_windows() -> bool {
    prøv {
        la res = builtin.exec_prosess("ver")
        returner er_ok(res)
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Argument-splitting (shlex-liknande) ──────────────────────────────────────
# Del ein kommandolinje på mellomrom, respekter enkle anførsels-teikn

funksjon split_args(linje: tekst) -> liste_tekst {
    la teikn = builtin.split(linje, "")
    la n: heltall = lengde(teikn)
    la delar: liste_tekst = []
    la gjeldande: tekst = ""
    la i_sitat: bool = usann
    la i: heltall = 0

    mens (i < n) {
        la c: tekst = teikn[i]
        la k: heltall = builtin.char_code(c)

        hvis (c == "\"" eller c == "'") {
            i_sitat = ikkje i_sitat
        } ellers hvis (k == 32 og ikkje i_sitat) {
            hvis (lengde(builtin.split(gjeldande, "")) > 0) {
                legg_til(delar, gjeldande)
                gjeldande = ""
            }
        } ellers {
            gjeldande = gjeldande + c
        }
        i = i + 1
    }
    hvis (lengde(builtin.split(gjeldande, "")) > 0) {
        legg_til(delar, gjeldande)
    }
    returner delar
}

# ─── Støttesjekk ──────────────────────────────────────────────────────────────

funksjon er_støtta() -> bool {
    prøv {
        la res = builtin.exec_prosess("echo ok")
        returner er_ok(res)
    } fang (e) {
        returner usann
    }
    returner usann
}

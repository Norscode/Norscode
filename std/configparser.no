# configparser.no — INI-konfigurasjonsfil-parser
# Python: configparser
#
# Støtta format:
#   [seksjon]
#   nøkkel = verdi
#   nøkkel: verdi
#   # kommentar
#   ; kommentar
#   fortsetting  (innrykk-linje = fortsetting av førre verdi)
#   %(nøkkel)s   (interpolasjon — same seksjon)
#
# Representasjon:
#   Config: ordbok_tekst
#     "_seksjonar"     → JSON-liste av seksjonsnamn
#     Per seksjon "s_NAMN":
#       JSON-streng av ordbok_tekst {nøkkel→verdi}
#     "DEFAULT" (valfri) → standardverdiar for alle seksjonar
#
# Bruk:
#   bruk std.configparser som cfg
#   la c = cfg.les_fil("app.ini")
#   skriv cfg.hent(c, "database", "host")
#   skriv cfg.hent_heltall(c, "server", "port")

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _trim(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la start: heltall = 0
    la slutt: heltall = n - 1
    mens (start <= slutt og (teikn[start] == " " eller teikn[start] == "\t")) {
        start = start + 1
    }
    mens (slutt >= start og (teikn[slutt] == " " eller teikn[slutt] == "\t" eller
          teikn[slutt] == "\r")) {
        slutt = slutt - 1
    }
    hvis (start > slutt) { returner "" }
    returner builtin.join(builtin.slice(teikn, start, slutt + 1), "")
}

funksjon _er_ws(c: tekst) -> bool {
    returner c == " " eller c == "\t"
}

funksjon _til_liten(s: tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la c: tekst = teikn[i]
        la k: heltall = builtin.char_code(c)
        hvis (k >= 65 og k <= 90) {
            la lt: liste_tekst = ["a","b","c","d","e","f","g","h","i","j","k","l","m",
                                   "n","o","p","q","r","s","t","u","v","w","x","y","z"]
            ut = ut + lt[k - 65]
        } ellers {
            ut = ut + c
        }
        i = i + 1
    }
    returner ut
}

# ─── Config-init ──────────────────────────────────────────────────────────────

funksjon ny() -> ordbok_tekst {
    la c: ordbok_tekst = {}
    c["_seksjonar"] = "[]"
    returner c
}

funksjon _legg_til_seksjon_intern(c: ordbok_tekst, seksjon: tekst) {
    la nøkkel: tekst = "s_" + seksjon
    hvis (ikkje har_nokkel(c, nøkkel)) {
        c[nøkkel] = "{}"
        la sl = builtin.json_parse(c["_seksjonar"])
        legg_til(sl, seksjon)
        c["_seksjonar"] = builtin.json_stringify(sl)
    }
}

funksjon _set_verdi(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst, verdi: tekst) {
    la snøkkel: tekst = "s_" + seksjon
    la seksjonsdata = builtin.json_parse(c[snøkkel])
    seksjonsdata[nøkkel] = verdi
    c[snøkkel] = builtin.json_stringify(seksjonsdata)
}

# ─── Parsing ──────────────────────────────────────────────────────────────────

funksjon les_tekst(innhald: tekst) -> ordbok_tekst {
    la c = ny()
    la linjer = builtin.split(innhald, "\n")
    la gjeldande_seksjon: tekst = "DEFAULT"
    la gjeldande_nøkkel: tekst = ""
    la gjeldande_verdi: tekst = ""
    _legg_til_seksjon_intern(c, "DEFAULT")

    la i: heltall = 0
    mens (i < lengde(linjer)) {
        la linje_rå: tekst = linjer[i]
        la linje: tekst = _trim(linje_rå)
        la n: heltall = lengde(builtin.split(linje, ""))
        la teikn = builtin.split(linje, "")

        hvis (n == 0) {
            # Tom linje — lagre pågåande nøkkel
            hvis (lengde(builtin.split(gjeldande_nøkkel, "")) > 0) {
                _set_verdi(c, gjeldande_seksjon, gjeldande_nøkkel, _trim(gjeldande_verdi))
                gjeldande_nøkkel = ""
                gjeldande_verdi = ""
            }
        } ellers hvis (teikn[0] == "#" eller teikn[0] == ";") {
            # Kommentar — ignorer
            i = i  # ingen handling
        } ellers hvis (teikn[0] == "[") {
            # Ny seksjon — lagre pågåande nøkkel
            hvis (lengde(builtin.split(gjeldande_nøkkel, "")) > 0) {
                _set_verdi(c, gjeldande_seksjon, gjeldande_nøkkel, _trim(gjeldande_verdi))
                gjeldande_nøkkel = ""
                gjeldande_verdi = ""
            }
            # Hent seksjonsnamn
            la seksjonsnamn: tekst = ""
            la j: heltall = 1
            mens (j < n og teikn[j] != "]") {
                seksjonsnamn = seksjonsnamn + teikn[j]
                j = j + 1
            }
            gjeldande_seksjon = _trim(seksjonsnamn)
            _legg_til_seksjon_intern(c, gjeldande_seksjon)
        } ellers hvis (_er_ws(linje_rå[0]) og lengde(builtin.split(gjeldande_nøkkel, "")) > 0) {
            # Fortsettingslinje
            gjeldande_verdi = gjeldande_verdi + "\n" + linje
        } ellers {
            # Lagre pågåande nøkkel
            hvis (lengde(builtin.split(gjeldande_nøkkel, "")) > 0) {
                _set_verdi(c, gjeldande_seksjon, gjeldande_nøkkel, _trim(gjeldande_verdi))
            }
            # Finn separator (= eller :)
            la sep_pos: heltall = -1
            la j: heltall = 0
            mens (j < n og sep_pos < 0) {
                hvis (teikn[j] == "=" eller teikn[j] == ":") { sep_pos = j }
                j = j + 1
            }
            hvis (sep_pos > 0) {
                la nk: tekst = _til_liten(_trim(builtin.join(builtin.slice(teikn, 0, sep_pos), "")))
                la vd: tekst = _trim(builtin.join(builtin.slice(teikn, sep_pos + 1, n), ""))
                gjeldande_nøkkel = nk
                gjeldande_verdi = vd
            }
        }
        i = i + 1
    }
    # Lagre siste nøkkel
    hvis (lengde(builtin.split(gjeldande_nøkkel, "")) > 0) {
        _set_verdi(c, gjeldande_seksjon, gjeldande_nøkkel, _trim(gjeldande_verdi))
    }
    returner c
}

funksjon les_fil(sti: tekst) -> ordbok_tekst {
    prøv {
        la innhald: tekst = builtin.fil_les(sti)
        returner les_tekst(innhald)
    } fang (e) {
        returner ny()
    }
    returner ny()
}

# ─── Interpolasjon ────────────────────────────────────────────────────────────

# Løys %(nøkkel)s interpolasjon i ein verdi
funksjon _interpoler(c: ordbok_tekst, seksjon: tekst, verdi: tekst) -> tekst {
    la teikn = builtin.split(verdi, "")
    la n: heltall = lengde(teikn)
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < n) {
        hvis (teikn[i] == "%" og i + 1 < n og teikn[i + 1] == "(") {
            # Les nøkkel opp til )s
            i = i + 2
            la ref_nøkkel: tekst = ""
            mens (i < n og teikn[i] != ")") {
                ref_nøkkel = ref_nøkkel + teikn[i]
                i = i + 1
            }
            i = i + 2  # hopp over )s
            la ref_verdi: tekst = hent(c, seksjon, ref_nøkkel)
            ut = ut + ref_verdi
        } ellers {
            ut = ut + teikn[i]
            i = i + 1
        }
    }
    returner ut
}

# ─── Aksess-API ───────────────────────────────────────────────────────────────

funksjon har_seksjon(c: ordbok_tekst, seksjon: tekst) -> bool {
    returner har_nokkel(c, "s_" + seksjon)
}

funksjon seksjonsnamn(c: ordbok_tekst) -> liste_tekst {
    la sl = builtin.json_parse(c["_seksjonar"])
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(sl)) {
        hvis (sl[i] != "DEFAULT") { legg_til(resultat, sl[i]) }
        i = i + 1
    }
    returner resultat
}

funksjon har_nøkkel(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst) -> bool {
    la snøkkel: tekst = "s_" + seksjon
    hvis (ikkje har_nokkel(c, snøkkel)) { returner usann }
    la seksjonsdata = builtin.json_parse(c[snøkkel])
    la lk: tekst = _til_liten(nøkkel)
    hvis (har_nokkel(seksjonsdata, lk)) { returner sann }
    # Sjekk DEFAULT
    hvis (har_nokkel(c, "s_DEFAULT")) {
        la def_data = builtin.json_parse(c["s_DEFAULT"])
        returner har_nokkel(def_data, lk)
    }
    returner usann
}

funksjon hent(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst) -> tekst {
    la snøkkel: tekst = "s_" + seksjon
    la lk: tekst = _til_liten(nøkkel)
    hvis (har_nokkel(c, snøkkel)) {
        la seksjonsdata = builtin.json_parse(c[snøkkel])
        hvis (har_nokkel(seksjonsdata, lk)) {
            returner _interpoler(c, seksjon, seksjonsdata[lk])
        }
    }
    # Fallback til DEFAULT
    hvis (har_nokkel(c, "s_DEFAULT")) {
        la def_data = builtin.json_parse(c["s_DEFAULT"])
        hvis (har_nokkel(def_data, lk)) {
            returner _interpoler(c, "DEFAULT", def_data[lk])
        }
    }
    returner ""
}

funksjon hent_eller(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst, standard: tekst) -> tekst {
    la v: tekst = hent(c, seksjon, nøkkel)
    hvis (lengde(builtin.split(v, "")) == 0) { returner standard }
    returner v
}

funksjon hent_heltall(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst) -> heltall {
    la v: tekst = hent(c, seksjon, nøkkel)
    prøv {
        returner builtin.heltall_fra_tekst(v)
    } fang (e) {
        returner 0
    }
    returner 0
}

funksjon hent_bool(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst) -> bool {
    la v: tekst = _til_liten(_trim(hent(c, seksjon, nøkkel)))
    returner v == "true" eller v == "yes" eller v == "1" eller v == "on" eller v == "sann"
}

funksjon hent_alle(c: ordbok_tekst, seksjon: tekst) -> ordbok_tekst {
    la snøkkel: tekst = "s_" + seksjon
    la resultat: ordbok_tekst = {}
    # Start med DEFAULT
    hvis (har_nokkel(c, "s_DEFAULT")) {
        la def_data = builtin.json_parse(c["s_DEFAULT"])
        la nøklar = builtin.nøkler(def_data)
        la i: heltall = 0
        mens (i < lengde(nøklar)) {
            resultat[nøklar[i]] = _interpoler(c, "DEFAULT", def_data[nøklar[i]])
            i = i + 1
        }
    }
    # Overstyr med seksjons-spesifikke
    hvis (har_nokkel(c, snøkkel)) {
        la seksjonsdata = builtin.json_parse(c[snøkkel])
        la nøklar = builtin.nøkler(seksjonsdata)
        la i: heltall = 0
        mens (i < lengde(nøklar)) {
            resultat[nøklar[i]] = _interpoler(c, seksjon, seksjonsdata[nøklar[i]])
            i = i + 1
        }
    }
    returner resultat
}

# ─── Skriving ─────────────────────────────────────────────────────────────────

funksjon set(c: ordbok_tekst, seksjon: tekst, nøkkel: tekst, verdi: tekst) {
    _legg_til_seksjon_intern(c, seksjon)
    _set_verdi(c, seksjon, _til_liten(nøkkel), verdi)
}

funksjon legg_til_seksjon(c: ordbok_tekst, seksjon: tekst) {
    _legg_til_seksjon_intern(c, seksjon)
}

funksjon til_tekst(c: ordbok_tekst) -> tekst {
    la ut: tekst = ""
    la sl = builtin.json_parse(c["_seksjonar"])
    la i: heltall = 0
    mens (i < lengde(sl)) {
        la sn: tekst = sl[i]
        ut = ut + "[" + sn + "]\n"
        la seksjonsdata = builtin.json_parse(c["s_" + sn])
        la nøklar = builtin.nøkler(seksjonsdata)
        la j: heltall = 0
        mens (j < lengde(nøklar)) {
            ut = ut + nøklar[j] + " = " + seksjonsdata[nøklar[j]] + "\n"
            j = j + 1
        }
        ut = ut + "\n"
        i = i + 1
    }
    returner ut
}

funksjon skriv_fil(c: ordbok_tekst, sti: tekst) {
    la innhald: tekst = til_tekst(c)
    builtin.fil_skriv(sti, innhald)
}

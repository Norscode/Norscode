# mysql.no — MySQL/MariaDB-drivar for Norscode
# Same API som std/db.no og std/pg.no
#
# Bruk:
#   bruk std.mysql som mysql
#
#   la conn = mysql.open("host=localhost port=3306 dbname=myapp user=app password=hemmeleg")
#   la conn = mysql.open_url("mysql://app:hemmeleg@localhost:3306/myapp")
#   mysql.execute(conn, "INSERT INTO brukar (namn) VALUES (?)", ["Ola"])
#   la rader = mysql.query(conn, "SELECT * FROM brukar WHERE aktiv = ?", ["1"])

# ─── Tilkopling ───────────────────────────────────────────────────────────────

funksjon open(dsn: tekst) -> tekst {
    prøv {
        returner tekst(builtin.mysql_connect(dsn))
    } fang (e) {
        kast "MySQL-tilkoplingsfeil: " + tekst(e)
    }
    returner ""
}

funksjon open_url(url: tekst) -> tekst {
    la dsn = _url_til_dsn(url)
    returner open(dsn)
}

funksjon open_cfg(host: tekst, port: heltall, database: tekst, brukar: tekst, passord: tekst) -> tekst {
    la dsn = "host=" + host + " port=" + tekst_fra_heltall(port) +
             " dbname=" + database + " user=" + brukar + " password=" + passord
    returner open(dsn)
}

funksjon close(conn: tekst) -> heltall {
    prøv { builtin.mysql_close(conn) } fang (e) { }
    returner 0
}

# ─── Spørjingar (? placeholder-stil) ─────────────────────────────────────────

funksjon execute(conn: tekst, sql: tekst, params: liste<tekst>) -> heltall {
    prøv {
        returner builtin.mysql_execute(conn, sql, params)
    } fang (e) {
        kast "MySQL-feil: " + tekst(e)
    }
    returner 0
}

funksjon execute_raw(conn: tekst, sql: tekst) -> heltall {
    la tom: liste<tekst> = []
    returner execute(conn, sql, tom)
}

funksjon query(conn: tekst, sql: tekst, params: liste<tekst>) -> liste<ordbok_tekst> {
    prøv {
        returner builtin.mysql_query(conn, sql, params)
    } fang (e) {
        kast "MySQL-spørjingsfeil: " + tekst(e)
    }
    returner []
}

funksjon query_raw(conn: tekst, sql: tekst) -> liste<ordbok_tekst> {
    la tom: liste<tekst> = []
    returner query(conn, sql, tom)
}

funksjon query_ein(conn: tekst, sql: tekst, params: liste<tekst>) -> ordbok_tekst {
    la rader = query(conn, sql, params)
    hvis lengde(rader) == 0 { returner {} }
    returner rader[0]
}

funksjon query_int(conn: tekst, sql: tekst) -> heltall {
    la tom: liste<tekst> = []
    la rad = query_ein(conn, sql, tom)
    la nk = nøkler(rad)
    hvis lengde(nk) == 0 { returner 0 }
    prøv { returner heltall_fra_tekst(tekst(rad[nk[0]])) } fang (e) { returner 0 }
    returner 0
}

funksjon sist_insert_id(conn: tekst) -> heltall {
    returner query_int(conn, "SELECT LAST_INSERT_ID()")
}

# ─── Transaksjonar ────────────────────────────────────────────────────────────

funksjon begin(conn: tekst) -> heltall      {
    returner execute_raw(conn, "START TRANSACTION")
}
funksjon commit(conn: tekst) -> heltall     {
    returner execute_raw(conn, "COMMIT")
}
funksjon rollback(conn: tekst) -> heltall   {
    returner execute_raw(conn, "ROLLBACK")
}

# ─── Schema ───────────────────────────────────────────────────────────────────

funksjon tabell_finst(conn: tekst, tabell: tekst) -> boolsk {
    la n = query_int(conn, "SELECT COUNT(*) FROM information_schema.tables WHERE table_name='" + tabell + "'")
    returner n > 0
}

funksjon vis_tabellar(conn: tekst) -> liste<ordbok_tekst> {
    returner query_raw(conn, "SHOW TABLES")
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _url_til_dsn(url: tekst) -> tekst {
    la u = tekst_erstatt(url, "mysql://", "")
    la at_idx = builtin.index_of(u, "@")
    la kred = builtin.slice(u, 0, at_idx)
    la rest = builtin.slice(u, at_idx + 1, lengde(u))
    la colon_k = builtin.index_of(kred, ":")
    la brukar = builtin.slice(kred, 0, colon_k)
    la passord = builtin.slice(kred, colon_k + 1, lengde(kred))
    la slash_idx = builtin.index_of(rest, "/")
    la host_port = builtin.slice(rest, 0, slash_idx)
    la database = builtin.slice(rest, slash_idx + 1, lengde(rest))
    la port_idx = builtin.index_of(host_port, ":")
    la host = host_port
    hvis port_idx >= 0 {
        host = builtin.slice(host_port, 0, port_idx)
    }
    la port = "3306"
    hvis port_idx >= 0 {
        port = builtin.slice(host_port, port_idx + 1, lengde(host_port))
    }
    returner "host=" + host + " port=" + port + " dbname=" + database + " user=" + brukar + " password=" + passord
}

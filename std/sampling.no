# sampling.no — deterministisk og avgrensa tokenval for lokal inferens

funksjon ny(fro: heiltall, topp_k: heiltall, temperatur: heiltall,
            repetisjonsstraff: heiltall, maks_token: heiltall,
            stopp_token: heiltall) {
    hvis topp_k <= 0 { kast "SamplingFeil: topp_k må vere positiv" }
    hvis temperatur <= 0 eller temperatur > 10000 { kast "SamplingFeil: ugyldig temperatur" }
    hvis repetisjonsstraff < 0 { kast "SamplingFeil: negativ repetisjonsstraff" }
    hvis maks_token <= 0 eller maks_token > 100000 { kast "SamplingFeil: ugyldig token-grense" }
    la s: ordbok = {}
    s["schema"] = "norscode.sampling.v1"
    s["fro"] = fro % 2147483647
    hvis s["fro"] <= 0 { s["fro"] = 1 }
    s["topp_k"] = topp_k
    s["temperatur"] = temperatur
    s["repetisjonsstraff"] = repetisjonsstraff
    s["maks_token"] = maks_token
    s["stopp_token"] = stopp_token
    s["val"] = 0
    returner s
}

funksjon _neste_tilfeldig(s) -> heiltall {
    s["fro"] = (s["fro"] * 48271) % 2147483647
    returner s["fro"]
}

funksjon _inneholder(verdiar: liste_heiltall, verdi: heiltall) -> boolsk {
    la i: heiltall = 0
    mens i < lengde(verdiar) {
        hvis verdiar[i] == verdi { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon _tal_i_historikk(historikk: liste_heiltall, token: heiltall) -> heiltall {
    la tal: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(historikk) {
        hvis historikk[i] == token { tal = tal + 1 }
        i = i + 1
    }
    returner tal
}

funksjon _avgrens_score(score: heiltall) -> heiltall {
    hvis score > 1000000 { returner 1000000 }
    hvis score < -1000000 { returner -1000000 }
    returner score
}

funksjon _justerte(s, logit: liste_heiltall,
                   historikk: liste_heiltall) -> liste_heiltall {
    hvis lengde(logit) == 0 eller lengde(logit) > 262144 {
        kast "SamplingFeil: ugyldig vokabularstorleik"
    }
    la ut: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(logit) {
        la score = _avgrens_score(logit[i])
        score = (score * 100) / s["temperatur"]
        score = score - _tal_i_historikk(historikk, i) * s["repetisjonsstraff"]
        legg_til(ut, score)
        i = i + 1
    }
    returner ut
}

funksjon _topp_indeksar(score: liste_heiltall, topp_k: heiltall) -> liste_heiltall {
    la antal = topp_k
    hvis antal > lengde(score) { antal = lengde(score) }
    la ut: liste_heiltall = []
    mens lengde(ut) < antal {
        la best: heiltall = -1
        la i: heiltall = 0
        mens i < lengde(score) {
            hvis ikkje _inneholder(ut, i) {
                hvis best < 0 eller score[i] > score[best] { best = i }
            }
            i = i + 1
        }
        legg_til(ut, best)
    }
    returner ut
}

funksjon velg(s, logit: liste_heiltall,
              historikk: liste_heiltall) -> heiltall {
    la score = _justerte(s, logit, historikk)
    la kandidatar = _topp_indeksar(score, s["topp_k"])
    la minste = score[kandidatar[0]]
    la i: heiltall = 1
    mens i < lengde(kandidatar) {
        hvis score[kandidatar[i]] < minste { minste = score[kandidatar[i]] }
        i = i + 1
    }
    la total: heiltall = 0
    i = 0
    mens i < lengde(kandidatar) {
        total = total + score[kandidatar[i]] - minste + 1
        i = i + 1
    }
    la trekk = _neste_tilfeldig(s) % total
    la akk: heiltall = 0
    i = 0
    mens i < lengde(kandidatar) {
        akk = akk + score[kandidatar[i]] - minste + 1
        hvis trekk < akk {
            s["val"] = s["val"] + 1
            returner kandidatar[i]
        }
        i = i + 1
    }
    kast "SamplingFeil: tokenval feila"
}

funksjon generer(s, logit_steg) {
    la token: liste_heiltall = []
    la stoppa = usann
    la i: heiltall = 0
    mens i < lengde(logit_steg) og lengde(token) < s["maks_token"] og ikkje stoppa {
        la neste = velg(s, logit_steg[i], token)
        legg_til(token, neste)
        hvis s["stopp_token"] >= 0 og neste == s["stopp_token"] { stoppa = sann }
        i = i + 1
    }
    returner {
        "schema": "norscode.generation-result.v1",
        "token": token,
        "stoppa": stoppa,
        "steg": lengde(token)
    }
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "eksperimentell", "schema": "norscode.sampling.v1", "dekning": "seed, heiltalstemperatur, top-k, repetisjonsstraff, stopp-token og maksimal genereringslengde"}
}

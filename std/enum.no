# enum.no — Oppteljingstypar (enum)
# Python: enum.Enum, enum.IntEnum, enum.Flag
#
# Representasjon:
#   Enum: ordbok_tekst
#     "_namn"      → enum-typens namn
#     "_type"      → "enum" | "intenum" | "flag"
#     "_medlemmar" → JSON-liste av {namn, verdi}
#     Per medlem "n_NAMN" → verdi (tekst)
#     Per verdi "v_VERDI" → namn (tekst)
#
# Bruk:
#   bruk std.enum som en
#
#   la Farge = en.ny_enum("Farge", ["RAUD", "GRØN", "BLAA"])
#   la v = en.verdi(Farge, "RAUD")         # → 1
#   la n = en.namn(Farge, 2)               # → "GRØN"
#   la alle = en.alle_namn(Farge)
#
#   la Status = en.ny_intenum("Status", [["AKTIV", 1], ["INAKTIV", 0]])
#   la Rett = en.ny_flag("Rett", ["LES", "SKRIV", "KØYR"])
#   la tilgang = en.flag_kombiner(Rett, ["LES", "SKRIV"])
#   en.flag_har(Rett, tilgang, "LES")      # → sann

# ─── Konstruktørar ────────────────────────────────────────────────────────────

# ny_enum(namn, [NAMN1, NAMN2, ...]) — verdiar auto-tildelt frå 1
funksjon ny_enum(namn: tekst, namnar: liste_tekst) -> ordbok_tekst {
    la e: ordbok_tekst = {}
    e["_namn"] = namn
    e["_type"] = "enum"
    la medlemmar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(namnar)) {
        la mn: tekst = namnar[i]
        la mv: heltall = i + 1
        e["n_" + mn] = tekst_fra_heltall(mv)
        e["v_" + tekst_fra_heltall(mv)] = mn
        la minfo: ordbok_tekst = {}
        minfo["namn"] = mn
        minfo["verdi"] = tekst_fra_heltall(mv)
        legg_til(medlemmar, builtin.json_stringify(minfo))
        i = i + 1
    }
    e["_medlemmar"] = builtin.json_stringify(medlemmar)
    returner e
}

# ny_intenum(namn, [[NAMN, verdi], ...]) — eksplisitte heiltalsverdiar
funksjon ny_intenum(namn: tekst, par: liste_tekst) -> ordbok_tekst {
    la e: ordbok_tekst = {}
    e["_namn"] = namn
    e["_type"] = "intenum"
    la medlemmar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(par)) {
        la p = builtin.json_parse(par[i])
        la mn: tekst = p[0]
        la mv: tekst = p[1]
        e["n_" + mn] = mv
        e["v_" + mv] = mn
        la minfo: ordbok_tekst = {}
        minfo["namn"] = mn
        minfo["verdi"] = mv
        legg_til(medlemmar, builtin.json_stringify(minfo))
        i = i + 1
    }
    e["_medlemmar"] = builtin.json_stringify(medlemmar)
    returner e
}

# ny_flag(namn, [NAMN1, NAMN2, ...]) — bitmasker 1, 2, 4, 8, ...
funksjon ny_flag(namn: tekst, namnar: liste_tekst) -> ordbok_tekst {
    la e: ordbok_tekst = {}
    e["_namn"] = namn
    e["_type"] = "flag"
    la medlemmar: liste_tekst = []
    la i: heltall = 0
    la bitmask: heltall = 1
    mens (i < lengde(namnar)) {
        la mn: tekst = namnar[i]
        e["n_" + mn] = tekst_fra_heltall(bitmask)
        e["v_" + tekst_fra_heltall(bitmask)] = mn
        la minfo: ordbok_tekst = {}
        minfo["namn"] = mn
        minfo["verdi"] = tekst_fra_heltall(bitmask)
        legg_til(medlemmar, builtin.json_stringify(minfo))
        bitmask = bitmask * 2
        i = i + 1
    }
    e["_medlemmar"] = builtin.json_stringify(medlemmar)
    returner e
}

# ny_str_enum(namn, [[NAMN, strverdi], ...]) — tekstverdiar
funksjon ny_str_enum(namn: tekst, par: liste_tekst) -> ordbok_tekst {
    la e: ordbok_tekst = {}
    e["_namn"] = namn
    e["_type"] = "strenum"
    la medlemmar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(par)) {
        la p = builtin.json_parse(par[i])
        la mn: tekst = p[0]
        la mv: tekst = p[1]
        e["n_" + mn] = mv
        e["s_" + mv] = mn  # "s_" for streng-oppslag
        la minfo: ordbok_tekst = {}
        minfo["namn"] = mn
        minfo["verdi"] = mv
        legg_til(medlemmar, builtin.json_stringify(minfo))
        i = i + 1
    }
    e["_medlemmar"] = builtin.json_stringify(medlemmar)
    returner e
}

# ─── Oppslag ──────────────────────────────────────────────────────────────────

# Hent heiltalsverdien til eit enum-medlem
funksjon verdi(e: ordbok_tekst, mn: tekst) -> heltall {
    la nøkkel: tekst = "n_" + mn
    hvis (har_nokkel(e, nøkkel)) {
        returner builtin.heltall_fra_tekst(e[nøkkel])
    }
    returner -1
}

# Hent tekstverdien til eit str_enum-medlem
funksjon str_verdi(e: ordbok_tekst, mn: tekst) -> tekst {
    la nøkkel: tekst = "n_" + mn
    hvis (har_nokkel(e, nøkkel)) { returner e[nøkkel] }
    returner ""
}

# Hent namne frå heiltalsverd
funksjon namn(e: ordbok_tekst, v: heltall) -> tekst {
    la nøkkel: tekst = "v_" + tekst_fra_heltall(v)
    hvis (har_nokkel(e, nøkkel)) { returner e[nøkkel] }
    returner ""
}

# Hent namn frå tekst-verdi (str_enum)
funksjon namn_frå_tekst(e: ordbok_tekst, v: tekst) -> tekst {
    la nøkkel: tekst = "s_" + v
    hvis (har_nokkel(e, nøkkel)) { returner e[nøkkel] }
    returner ""
}

funksjon er_gyldig(e: ordbok_tekst, mn: tekst) -> bool {
    returner har_nokkel(e, "n_" + mn)
}

funksjon er_gyldig_verdi(e: ordbok_tekst, v: heltall) -> bool {
    returner har_nokkel(e, "v_" + tekst_fra_heltall(v))
}

funksjon type_namn(e: ordbok_tekst) -> tekst  {
    returner e["_namn"]
}
funksjon type_str(e: ordbok_tekst) -> tekst  {
    returner e["_type"]
}

# Liste av alle medlemsnamn
funksjon alle_namn(e: ordbok_tekst) -> liste_tekst {
    la ml = builtin.json_parse(e["_medlemmar"])
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(ml)) {
        la m = builtin.json_parse(ml[i])
        legg_til(resultat, m["namn"])
        i = i + 1
    }
    returner resultat
}

# Liste av alle verdiar
funksjon alle_verdiar(e: ordbok_tekst) -> liste_heltall {
    la ml = builtin.json_parse(e["_medlemmar"])
    la resultat: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(ml)) {
        la m = builtin.json_parse(ml[i])
        legg_til(resultat, builtin.heltall_fra_tekst(m["verdi"]))
        i = i + 1
    }
    returner resultat
}

# Liste av alle [namn, verdi]-par
funksjon alle_par(e: ordbok_tekst) -> liste_tekst {
    returner builtin.json_parse(e["_medlemmar"])
}

funksjon tal_medlemmar(e: ordbok_tekst) -> heltall {
    returner lengde(builtin.json_parse(e["_medlemmar"]))
}

# ─── Flag-operasjonar ─────────────────────────────────────────────────────────

# Kombiner fleire flagg med bitvis OR
funksjon flag_kombiner(e: ordbok_tekst, namnar: liste_tekst) -> heltall {
    la resultat: heltall = 0
    la i: heltall = 0
    mens (i < lengde(namnar)) {
        la v: heltall = verdi(e, namnar[i])
        hvis (v > 0) { resultat = resultat + v }  # bitvis OR via addisjon (bitmask er potens-av-2)
        i = i + 1
    }
    returner resultat
}

# Sjekk om eit flag er sett i ein kombinert verdi
funksjon flag_har(e: ordbok_tekst, kombinert: heltall, mn: tekst) -> bool {
    la v: heltall = verdi(e, mn)
    hvis (v <= 0) { returner usann }
    returner (kombinert / v) % 2 == 1
}

# List alle flagg som er sett
funksjon flag_liste(e: ordbok_tekst, kombinert: heltall) -> liste_tekst {
    la ml = builtin.json_parse(e["_medlemmar"])
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(ml)) {
        la m = builtin.json_parse(ml[i])
        la mv: heltall = builtin.heltall_fra_tekst(m["verdi"])
        hvis (mv > 0 og (kombinert / mv) % 2 == 1) {
            legg_til(resultat, m["namn"])
        }
        i = i + 1
    }
    returner resultat
}

# Legg til eit flagg
funksjon flag_set(kombinert: heltall, flagg: heltall) -> heltall {
    # Sjekk om allereie sett
    hvis ((kombinert / flagg) % 2 == 1) { returner kombinert }
    returner kombinert + flagg
}

# Fjern eit flagg
funksjon flag_fjern(kombinert: heltall, flagg: heltall) -> heltall {
    hvis ((kombinert / flagg) % 2 == 0) { returner kombinert }
    returner kombinert - flagg
}

# ─── Konvertering ─────────────────────────────────────────────────────────────

funksjon til_tekst(e: ordbok_tekst, mn: tekst) -> tekst {
    returner e["_namn"] + "." + mn + "=" + tekst_fra_heltall(verdi(e, mn))
}

funksjon repr(e: ordbok_tekst) -> tekst {
    la ml = alle_namn(e)
    la ut: tekst = e["_namn"] + " {"
    la i: heltall = 0
    mens (i < lengde(ml)) {
        la mn: tekst = ml[i]
        ut = ut + mn + "=" + tekst_fra_heltall(verdi(e, mn))
        hvis (i + 1 < lengde(ml)) { ut = ut + ", " }
        i = i + 1
    }
    returner ut + "}"
}

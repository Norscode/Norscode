# Hash standardbibliotek
# Klassiske ikkje-kryptografiske hashfunksjonar.
# Nyttig for hashmaps, sjekksummar, partisjonering, bloom-filter.
#
# Bruk:
#   bruk std.hash
#   la h = hash.djb2("hei verden")   # => heltall

# ─── djb2 ─────────────────────────────────────────────────────────────────────
# Dan Bernstein sin djb2 — enkel og god spredning

funksjon djb2(tekstverdi: tekst) -> heltall {
    la tegn = builtin.split(tekstverdi, "")
    la h: heltall = 5381
    la i: heltall = 0
    mens (i < lengde(tegn)) {
        la kode: heltall = builtin.char_code(tegn[i])
        # h = h * 33 + kode  (hald innanfor 31-bits for å unngå overflow)
        h = (h * 33 + kode) % 2147483647
        i = i + 1
    }
    returner h
}

# djb2 med eigendefnert modulus (t.d. for hashtabell med n bøtter)
funksjon djb2_mod(tekstverdi: tekst, n: heltall) -> heltall {
    returner djb2(tekstverdi) % n
}

# ─── FNV-1a ───────────────────────────────────────────────────────────────────
# Fowler–Noll–Vo — rask og god avalanche-effekt

funksjon fnv1a(tekstverdi: tekst) -> heltall {
    la tegn = builtin.split(tekstverdi, "")
    # FNV offset basis (32-bit): 2166136261, prime: 16777619
    # Brukar 31-bit variant for å unngå overflow i Norscode
    la h: heltall = 2166136261 % 2147483647
    la prime: heltall = 16777619
    la i: heltall = 0
    mens (i < lengde(tegn)) {
        la kode: heltall = builtin.char_code(tegn[i])
        h = (h ^ kode) % 2147483647
        h = (h * prime) % 2147483647
        i = i + 1
    }
    returner h
}

funksjon fnv1a_mod(tekstverdi: tekst, n: heltall) -> heltall {
    returner fnv1a(tekstverdi) % n
}

# ─── Sjekksum ─────────────────────────────────────────────────────────────────

# Enkel Adler-32-inspirert sjekksum
funksjon adler(tekstverdi: tekst) -> heltall {
    la tegn = builtin.split(tekstverdi, "")
    la a: heltall = 1
    la b: heltall = 0
    la MOD: heltall = 65521
    la i: heltall = 0
    mens (i < lengde(tegn)) {
        la kode: heltall = builtin.char_code(tegn[i])
        a = (a + kode) % MOD
        b = (b + a) % MOD
        i = i + 1
    }
    returner (b * 65536 + a) % 2147483647
}

# ─── Konsekvent hashing ───────────────────────────────────────────────────────

# Fordel ein nøkkel på n noder (konsekvent/stabil fordeling)
funksjon konsekvent_node(nøkkel: tekst, n: heltall) -> heltall {
    returner djb2_mod(nøkkel, n)
}

# ─── Bloom-filter (bit-array som ordbok_bool) ─────────────────────────────────

# Legg til eit element i eit bloom-filter med m bitar
funksjon bloom_legg_til(filter: ordbok_bool, element: tekst, m: heltall) -> heltall {
    la h1: heltall = djb2_mod(element, m)
    la h2: heltall = fnv1a_mod(element, m)
    la h3: heltall = adler(element) % m
    filter[tekst_fra_heltall(h1)] = sann
    filter[tekst_fra_heltall(h2)] = sann
    filter[tekst_fra_heltall(h3)] = sann
    returner lengde(filter)
}

# Kan elementet vere i filteret? (false positive mogleg, false negative ikkje)
funksjon bloom_kan_finnes(filter: ordbok_bool, element: tekst, m: heltall) -> bool {
    la h1: heltall = djb2_mod(element, m)
    la h2: heltall = fnv1a_mod(element, m)
    la h3: heltall = adler(element) % m
    returner har_nokkel(filter, tekst_fra_heltall(h1)) og
             har_nokkel(filter, tekst_fra_heltall(h2)) og
             har_nokkel(filter, tekst_fra_heltall(h3))
}

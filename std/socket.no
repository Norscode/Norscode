# socket.no — Nettverkssokklar
# Python: socket
#
# Krev builtin.socket_* i kompilatoren.
# Kvar builtin er pakka inn med prøv/fang for grasiøs degradering.
#
# Sokkel-tilstand representasjon: liste_heltall
#   [sokkelfil_deskriptor, type, er_open, feilkode]
#   type: 1=TCP, 2=UDP, 3=RAW
#   feilkode: 0=ok, -1=ikkje støtta, -2=feil
#
# Bruk:
#   bruk std.socket som sok
#   la s = sok.ny_tcp()
#   la ok = sok.tilkoble(s, "127.0.0.1", 8080)
#   la svar = sok.send(s, "HELLO")
#   la data = sok.motta(s, 1024)
#   sok.lukk(s)

# ─── Konstantar ───────────────────────────────────────────────────────────────

funksjon AF_INET() -> heltall  {
    returner 2
}
funksjon SOCK_STREAM() -> heltall { returner 1 }   # TCP
funksjon SOCK_DGRAM() -> heltall { returner 2 }    # UDP

funksjon FEIL_IKKJE_STØTTA() -> heltall  {
    returner -1
}
funksjon FEIL_TILKOBLING() -> heltall  {
    returner -2
}
funksjon FEIL_SEND() -> heltall  {
    returner -3
}
funksjon FEIL_MOTTA() -> heltall  {
    returner -4
}

# ─── Sokkelkonstruksjon ───────────────────────────────────────────────────────

funksjon _ny_sokkel(type: heltall) -> liste_heltall {
    la s: liste_heltall = []
    legg_til(s, -1)   # fd (fylt ut av builtin)
    legg_til(s, type)
    legg_til(s, 0)    # er_open
    legg_til(s, 0)    # feilkode
    returner s
}

funksjon ny_tcp() -> liste_heltall {
    la s = _ny_sokkel(SOCK_STREAM())
    prøv {
        la fd: heltall = builtin.socket_new(AF_INET(), SOCK_STREAM())
        s[0] = fd
        s[2] = 1
    } fang (e) {
        s[3] = FEIL_IKKJE_STØTTA()
    }
    returner s
}

funksjon ny_udp() -> liste_heltall {
    la s = _ny_sokkel(SOCK_DGRAM())
    prøv {
        la fd: heltall = builtin.socket_new(AF_INET(), SOCK_DGRAM())
        s[0] = fd
        s[2] = 1
    } fang (e) {
        s[3] = FEIL_IKKJE_STØTTA()
    }
    returner s
}

# ─── Tilkobling (klient) ──────────────────────────────────────────────────────

funksjon tilkoble(s: liste_heltall, vert: tekst, port: heltall) -> bool {
    prøv {
        la res: heltall = builtin.socket_connect(s[0], vert, port)
        returner res == 0
    } fang (e) {
        s[3] = FEIL_TILKOBLING()
        returner usann
    }
    returner usann
}

# ─── Tenar (server) ───────────────────────────────────────────────────────────

funksjon bind(s: liste_heltall, vert: tekst, port: heltall) -> bool {
    prøv {
        la res: heltall = builtin.socket_bind(s[0], vert, port)
        returner res == 0
    } fang (e) {
        s[3] = FEIL_IKKJE_STØTTA()
        returner usann
    }
    returner usann
}

funksjon lytt(s: liste_heltall, etterslep: heltall) -> bool {
    prøv {
        la res: heltall = builtin.socket_listen(s[0], etterslep)
        returner res == 0
    } fang (e) {
        s[3] = FEIL_IKKJE_STØTTA()
        returner usann
    }
    returner usann
}

# Aksepter innkomande tilkobling — returnerer ny sokkel
funksjon aksepter(s: liste_heltall) -> liste_heltall {
    la ny: liste_heltall = _ny_sokkel(s[1])
    prøv {
        la fd: heltall = builtin.socket_accept(s[0])
        ny[0] = fd
        ny[2] = 1
    } fang (e) {
        ny[3] = FEIL_IKKJE_STØTTA()
    }
    returner ny
}

# ─── Send og motta ────────────────────────────────────────────────────────────

funksjon send(s: liste_heltall, data: tekst) -> heltall {
    prøv {
        returner builtin.socket_send(s[0], data)
    } fang (e) {
        s[3] = FEIL_SEND()
        returner -1
    }
    returner -1
}

funksjon send_bytes(s: liste_heltall, data: liste_heltall) -> heltall {
    prøv {
        returner builtin.socket_send_bytes(s[0], data)
    } fang (e) {
        s[3] = FEIL_SEND()
        returner -1
    }
    returner -1
}

funksjon motta(s: liste_heltall, maks_bytes: heltall) -> tekst {
    prøv {
        returner builtin.socket_recv(s[0], maks_bytes)
    } fang (e) {
        s[3] = FEIL_MOTTA()
        returner ""
    }
    returner ""
}

funksjon motta_bytes(s: liste_heltall, maks_bytes: heltall) -> liste_heltall {
    prøv {
        returner builtin.socket_recv_bytes(s[0], maks_bytes)
    } fang (e) {
        s[3] = FEIL_MOTTA()
        returner []
    }
    returner []
}

# ─── Lukking ──────────────────────────────────────────────────────────────────

funksjon lukk(s: liste_heltall) -> heltall {
    prøv { builtin.socket_close(s[0]) } fang (e) { returner -1 }
    s[2] = 0
    returner 0
}

# ─── Status ───────────────────────────────────────────────────────────────────

funksjon er_open(s: liste_heltall) -> bool  {
    returner s[2] == 1
}
funksjon er_feil(s: liste_heltall) -> bool  {
    returner s[3] != 0
}
funksjon feilkode(s: liste_heltall) -> heltall  {
    returner s[3]
}
funksjon fil_deskriptor(s: liste_heltall) -> heltall  {
    returner s[0]
}

funksjon er_støtta() -> bool {
    prøv {
        la r: heltall = builtin.socket_new(AF_INET(), SOCK_STREAM())
        builtin.socket_close(r)
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Timeout ──────────────────────────────────────────────────────────────────

funksjon set_timeout(s: liste_heltall, ms: heltall) -> bool {
    prøv {
        la res: heltall = builtin.socket_settimeout(s[0], ms)
        returner res == 0
    } fang (e) {
        returner usann
    }
    returner usann
}

# ─── Adressehjelparar ─────────────────────────────────────────────────────────

# Formater IPv4-adresse frå fire byte-verdiar
funksjon ipv4(a: heltall, b: heltall, c: heltall, d: heltall) -> tekst {
    returner tekst_fra_heltall(a) + "." + tekst_fra_heltall(b) + "." +
             tekst_fra_heltall(c) + "." + tekst_fra_heltall(d)
}

# Sjekk om ein tekst ser ut som ei gyldig IPv4-adresse
funksjon er_gyldig_ipv4(s: tekst) -> bool {
    la delar = builtin.split(s, ".")
    hvis (lengde(delar) != 4) { returner usann }
    la i: heltall = 0
    mens (i < 4) {
        la d: tekst = delar[i]
        la teikn = builtin.split(d, "")
        hvis (lengde(teikn) == 0 eller lengde(teikn) > 3) { returner usann }
        la j: heltall = 0
        mens (j < lengde(teikn)) {
            la k: heltall = builtin.char_code(teikn[j])
            hvis (k < 48 eller k > 57) { returner usann }
            j = j + 1
        }
        la n: heltall = builtin.heltall_fra_tekst(d)
        hvis (n < 0 eller n > 255) { returner usann }
        i = i + 1
    }
    returner sann
}

# ─── Enkel HTTP GET (over socket) ─────────────────────────────────────────────

funksjon http_get(vert: tekst, sti: tekst, port: heltall) -> tekst {
    la s = ny_tcp()
    hvis (er_feil(s)) { returner "" }
    la ok: bool = tilkoble(s, vert, port)
    hvis (ikkje ok) { lukk(s)  returner "" }

    la førespurnad: tekst = "GET " + sti + " HTTP/1.0\r\nHost: " + vert + "\r\n\r\n"
    send(s, førespurnad)

    la svar: tekst = ""
    la del: tekst = motta(s, 4096)
    mens (del != "") {
        svar = svar + del
        del = motta(s, 4096)
    }
    lukk(s)
    returner svar
}

# logging.no — Nivå-basert logging
# Python: logging
#
# Fem nivå: DEBUG(0) INFO(1) WARN(2) ERROR(3) STILLE(4)
# Logg-postar har format: [NIVÅ] melding
# Terskel-nivå filtrerer bort postar under nivået.
#
# Bruk:
#   bruk std.logging som log
#   la l = log.ny("MinApp", log.INFO)
#   log.info(l, "Server starta")
#   log.feil(l, "Noko gjekk gale")
#   log.debug(l, "Dette syns ikkje (INFO-terskel)")

# ─── Konstantar ──────────────────────────────────────────────────────────────

funksjon DEBUG() -> heltall { returner 0 }
funksjon INFO()  -> heltall { returner 1 }
funksjon WARN()  -> heltall { returner 2 }
funksjon FEIL()  -> heltall { returner 3 }
funksjon STILLE() -> heltall { returner 4 }

funksjon nivå_namn(nivå: heltall) -> tekst {
    hvis (nivå == 0) { returner "DEBUG" }
    hvis (nivå == 1) { returner "INFO " }
    hvis (nivå == 2) { returner "WARN " }
    hvis (nivå == 3) { returner "FEIL " }
    returner "?????"
}

# ─── Logger-objekt ────────────────────────────────────────────────────────────
# Lagrar innstillingar i ordbok_tekst:
#   logger["namn"]      = appnamn
#   logger["terskel"]   = "0"–"4"
#   logger["til_fil"]   = filsti eller "" (tom = berre stdout)
#   logger["teller"]    = antal loggpostar skrivne
#   logger["format"]    = "kort" eller "full"

funksjon ny(namn: tekst, terskel: heltall) -> ordbok_tekst {
    la l: ordbok_tekst = {}
    l["namn"]    = namn
    l["terskel"] = tekst_fra_heltall(terskel)
    l["til_fil"] = ""
    l["teller"]  = "0"
    l["format"]  = "full"
    returner l
}

funksjon ny_stille() -> ordbok_tekst {
    returner ny("", STILLE())
}

funksjon set_terskel(l: ordbok_tekst, terskel: heltall) -> heltall {
    l["terskel"] = tekst_fra_heltall(terskel)
    returner terskel
}

funksjon set_fil(l: ordbok_tekst, filsti: tekst) -> heltall {
    l["til_fil"] = filsti
    returner 0
}

funksjon set_format_kort(l: ordbok_tekst) -> heltall {
    l["format"] = "kort"
    returner 0
}

# ─── Intern: skriv ein loggpost ───────────────────────────────────────────────

funksjon _logg(l: ordbok_tekst, nivå: heltall, melding: tekst) -> heltall {
    la terskel: heltall = builtin.heltall_fra_tekst(l["terskel"])
    hvis (nivå < terskel) { returner 0 }

    la namn: tekst = l["namn"]
    la prefix: tekst = "[" + nivå_namn(nivå) + "]"
    la linje: tekst = ""

    hvis (l["format"] == "kort" eller namn == "") {
        linje = prefix + " " + melding
    } ellers {
        linje = prefix + " " + namn + ": " + melding
    }

    skriv(linje)

    # Skriv til fil viss satt
    la filsti: tekst = l["til_fil"]
    hvis (lengde(filsti) > 0) {
        prøv {
            la eksisterande: tekst = ""
            hvis (fil_finnes(filsti)) {
                eksisterande = builtin.fil_les(filsti)
            }
            builtin.fil_skriv(filsti, eksisterande + linje + "\n")
        } fang (e) {
            # ignorer fil-feil
        }
    }

    la teller: heltall = builtin.heltall_fra_tekst(l["teller"]) + 1
    l["teller"] = tekst_fra_heltall(teller)
    returner teller
}

# ─── Offentlege logg-funksjonar ───────────────────────────────────────────────

funksjon debug(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, DEBUG(), melding)
}

funksjon info(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, INFO(), melding)
}

funksjon åtvaring(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, WARN(), melding)
}

funksjon feil(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg(l, FEIL(), melding)
}

# Logg med tal
funksjon info_tall(l: ordbok_tekst, melding: tekst, verdi: heltall) -> heltall {
    returner _logg(l, INFO(), melding + " " + tekst_fra_heltall(verdi))
}

funksjon feil_tall(l: ordbok_tekst, melding: tekst, verdi: heltall) -> heltall {
    returner _logg(l, FEIL(), melding + " " + tekst_fra_heltall(verdi))
}

funksjon debug_tall(l: ordbok_tekst, melding: tekst, verdi: heltall) -> heltall {
    returner _logg(l, DEBUG(), melding + " " + tekst_fra_heltall(verdi))
}

# ─── Direkte (utan logger-objekt) ─────────────────────────────────────────────

funksjon skriv_info(melding: tekst) -> heltall {
    skriv("[INFO ] " + melding)
    returner 0
}

funksjon skriv_feil(melding: tekst) -> heltall {
    skriv("[FEIL ] " + melding)
    returner 0
}

funksjon skriv_warn(melding: tekst) -> heltall {
    skriv("[WARN ] " + melding)
    returner 0
}

funksjon skriv_debug(melding: tekst) -> heltall {
    skriv("[DEBUG] " + melding)
    returner 0
}

# ─── Statistikk ───────────────────────────────────────────────────────────────

funksjon antal_postar(l: ordbok_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(l["teller"])
}

funksjon nullstill_teller(l: ordbok_tekst) -> heltall {
    l["teller"] = "0"
    returner 0
}

# ─── Kontekstlogging ──────────────────────────────────────────────────────────
# Legg til ein fast nøkkel=verdi-kontekst til kvar melding

funksjon ny_med_kontekst(namn: tekst, terskel: heltall, kontekst: tekst) -> ordbok_tekst {
    la l = ny(namn, terskel)
    l["kontekst"] = kontekst
    returner l
}

funksjon _logg_k(l: ordbok_tekst, nivå: heltall, melding: tekst) -> heltall {
    la ctx: tekst = ""
    hvis (har_nokkel(l, "kontekst")) {
        ctx = " [" + l["kontekst"] + "]"
    }
    returner _logg(l, nivå, melding + ctx)
}

funksjon info_k(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg_k(l, INFO(), melding)
}

funksjon feil_k(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg_k(l, FEIL(), melding)
}

funksjon debug_k(l: ordbok_tekst, melding: tekst) -> heltall {
    returner _logg_k(l, DEBUG(), melding)
}

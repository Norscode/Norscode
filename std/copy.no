# copy.no — Kopieringsutilitets
# Python: copy.copy, copy.deepcopy
#
# Norscode har ikkje referansesemantikk for skalare, men
# ordbok_tekst og liste_* er mutable og treng eksplisitt kopiering.
#
# Strategiar:
#   - Grunt kopi (copy): ny ordbok/liste med same nøklar/indeksar, verdiar delte
#   - Djup kopi (deepcopy): rekursivt via JSON round-trip
#   - replace: kopi med oppdaterte felt (immutable update-mønster)
#
# Bruk:
#   bruk std.copy som cp
#   la kopi = cp.copy_ordbok(original)
#   la djup = cp.deepcopy_ordbok(original)
#   la ny = cp.replace(original, "felt", "nyverdi")

# ─── Grunt kopi ───────────────────────────────────────────────────────────────

funksjon copy_ordbok(d: ordbok_tekst) -> ordbok_tekst {
    la ny: ordbok_tekst = {}
    la nøklar = builtin.nøkler(d)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        ny[nøklar[i]] = d[nøklar[i]]
        i = i + 1
    }
    returner ny
}

funksjon copy_liste_tekst(l: liste_tekst) -> liste_tekst {
    la ny: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(ny, l[i])
        i = i + 1
    }
    returner ny
}

funksjon copy_liste_heltall(l: liste_heltall) -> liste_heltall {
    la ny: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(ny, l[i])
        i = i + 1
    }
    returner ny
}

funksjon copy_ordbok_heltall(d: ordbok_heltall) -> ordbok_heltall {
    la ny: ordbok_heltall = {}
    la nøklar = builtin.nøkler(d)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        ny[nøklar[i]] = d[nøklar[i]]
        i = i + 1
    }
    returner ny
}

funksjon copy_ordbok_bool(d: ordbok_bool) -> ordbok_bool {
    la ny: ordbok_bool = {}
    la nøklar = builtin.nøkler(d)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        ny[nøklar[i]] = d[nøklar[i]]
        i = i + 1
    }
    returner ny
}

# ─── Djup kopi (via JSON round-trip) ─────────────────────────────────────────

funksjon deepcopy_ordbok(d: ordbok_tekst) -> ordbok_tekst {
    # JSON round-trip gir full djup kopi av ordbok_tekst
    la json_str: tekst = builtin.json_stringify(d)
    returner builtin.json_parse(json_str)
}

funksjon deepcopy_liste_tekst(l: liste_tekst) -> liste_tekst {
    la json_str: tekst = builtin.json_stringify(l)
    returner builtin.json_parse(json_str)
}

funksjon deepcopy_liste_heltall(l: liste_heltall) -> liste_heltall {
    la kopi: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(kopi, l[i])
        i = i + 1
    }
    returner kopi
}

# ─── Replace-mønster (immutable update) ──────────────────────────────────────

# Lag kopi av ordbok med eit felt endra
funksjon replace(d: ordbok_tekst, nøkkel: tekst, ny_verdi: tekst) -> ordbok_tekst {
    la kopi = copy_ordbok(d)
    kopi[nøkkel] = ny_verdi
    returner kopi
}

# Lag kopi med fleire felt endra
# oppdateringar: liste_tekst av ["nøkkel", "verdi", "nøkkel2", "verdi2", ...]
funksjon replace_mange(d: ordbok_tekst, oppdateringar: liste_tekst) -> ordbok_tekst {
    la kopi = copy_ordbok(d)
    la i: heltall = 0
    mens (i + 1 < lengde(oppdateringar)) {
        kopi[oppdateringar[i]] = oppdateringar[i + 1]
        i = i + 2
    }
    returner kopi
}

# Lag kopi av ordbok utan eit felt
funksjon slett_felt(d: ordbok_tekst, nøkkel: tekst) -> ordbok_tekst {
    la kopi = copy_ordbok(d)
    fjern_nokkel(kopi, nøkkel)
    returner kopi
}

# Lag kopi av ordbok utan fleire felt
funksjon slett_felt_mange(d: ordbok_tekst, nøklar: liste_tekst) -> ordbok_tekst {
    la kopi = copy_ordbok(d)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        fjern_nokkel(kopi, nøklar[i])
        i = i + 1
    }
    returner kopi
}

# ─── Liste-operasjonar ────────────────────────────────────────────────────────

# Kopi av liste med eitt element endra
funksjon liste_replace(l: liste_tekst, idx: heltall, ny_verdi: tekst) -> liste_tekst {
    la kopi = copy_liste_tekst(l)
    la n: heltall = lengde(kopi)
    hvis (idx >= 0 og idx < n) {
        kopi[idx] = ny_verdi
    }
    returner kopi
}

# Kopi av liste med eit element sett inn
funksjon liste_sett_inn(l: liste_tekst, idx: heltall, verdi: tekst) -> liste_tekst {
    la kopi: liste_tekst = []
    la n: heltall = lengde(l)
    la i: heltall = 0
    mens (i < idx og i < n) {
        legg_til(kopi, l[i])
        i = i + 1
    }
    legg_til(kopi, verdi)
    mens (i < n) {
        legg_til(kopi, l[i])
        i = i + 1
    }
    returner kopi
}

# Kopi av liste utan eit element
funksjon liste_fjern(l: liste_tekst, idx: heltall) -> liste_tekst {
    la kopi: liste_tekst = []
    la n: heltall = lengde(l)
    la i: heltall = 0
    mens (i < n) {
        hvis (i != idx) { legg_til(kopi, l[i]) }
        i = i + 1
    }
    returner kopi
}

# Kopi av liste med element lagt til på slutten
funksjon liste_append(l: liste_tekst, verdi: tekst) -> liste_tekst {
    la kopi = copy_liste_tekst(l)
    legg_til(kopi, verdi)
    returner kopi
}

# Slå saman to lister til ein ny (ikkje muterer)
funksjon liste_concat(a: liste_tekst, b: liste_tekst) -> liste_tekst {
    la kopi = copy_liste_tekst(a)
    la i: heltall = 0
    mens (i < lengde(b)) {
        legg_til(kopi, b[i])
        i = i + 1
    }
    returner kopi
}

# ─── Merge av ordbøker ────────────────────────────────────────────────────────

# Slå saman to ordbøker: b overskriv a
funksjon merge(a: ordbok_tekst, b: ordbok_tekst) -> ordbok_tekst {
    la kopi = copy_ordbok(a)
    la nøklar = builtin.nøkler(b)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        kopi[nøklar[i]] = b[nøklar[i]]
        i = i + 1
    }
    returner kopi
}

# Slå saman, men ikkje overskriv eksisterande nøklar
funksjon merge_mykt(a: ordbok_tekst, b: ordbok_tekst) -> ordbok_tekst {
    la kopi = copy_ordbok(a)
    la nøklar = builtin.nøkler(b)
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la nk: tekst = nøklar[i]
        hvis (ikkje har_nokkel(kopi, nk)) {
            kopi[nk] = b[nk]
        }
        i = i + 1
    }
    returner kopi
}

# Vel berre spesifikke nøklar frå ein ordbok
funksjon vel_felt(d: ordbok_tekst, nøklar: liste_tekst) -> ordbok_tekst {
    la kopi: ordbok_tekst = {}
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        la nk: tekst = nøklar[i]
        hvis (har_nokkel(d, nk)) { kopi[nk] = d[nk] }
        i = i + 1
    }
    returner kopi
}

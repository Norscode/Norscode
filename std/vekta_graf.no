# vekta_graf.no — Vekta grafalgoritmar
# Python: networkx, heapq+dict (Dijkstra)
#
# Representasjon: flat liste_heltall som kantliste
#   [frå0, til0, vekt0, frå1, til1, vekt1, ...]
# Nodar er heltall frå 0 mål N-1.
#
# Bruk:
#   bruk std.vekta_graf som vg
#   la g = vg.ny_graf()
#   vg.legg_til_kant(g, 0, 1, 4)
#   vg.legg_til_kant(g, 0, 2, 1)
#   vg.legg_til_kant(g, 2, 1, 2)
#   la dist = vg.dijkstra(g, 3, 0)   # kortaste avstand frå node 0
#   skriv(dist[1])                    # avstand mål node 1 => 3

# ─── Grafbygging ──────────────────────────────────────────────────────────────

funksjon ny_graf() -> liste_heltall {
    returner []
}

# Legg mål retta kant frå → mål med vekt
funksjon legg_til_kant(g: liste_heltall, frå: heltall, mål: heltall, vekt: heltall) -> heltall {
    legg_til(g, frå)
    legg_til(g, mål)
    legg_til(g, vekt)
    returner lengde(g) / 3
}

# Legg mål uretta kant (to retta kantar)
funksjon legg_til_uretta(g: liste_heltall, a: heltall, b: heltall, vekt: heltall) -> heltall {
    legg_til_kant(g, a, b, vekt)
    returner legg_til_kant(g, b, a, vekt)
}

funksjon tal_kantar(g: liste_heltall) -> heltall {
    returner lengde(g) / 3
}

# Hent kant i (0-indeksert): [frå, mål, vekt]
funksjon hent_kant(g: liste_heltall, i: heltall) -> liste_heltall {
    la k: liste_heltall = []
    legg_til(k, g[i * 3])
    legg_til(k, g[i * 3 + 1])
    legg_til(k, g[i * 3 + 2])
    returner k
}

# ─── Intern: naboar frå node ──────────────────────────────────────────────────
# Returnerer flat liste [til0, vekt0, til1, vekt1, ...]

funksjon _naboar(g: liste_heltall, node: heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la n: heltall = tal_kantar(g)
    la i: heltall = 0
    mens (i < n) {
        hvis (g[i * 3] == node) {
            legg_til(ut, g[i * 3 + 1])
            legg_til(ut, g[i * 3 + 2])
        }
        i = i + 1
    }
    returner ut
}

# ─── Dijkstra — kortaste veg (ingen negative vekter) ─────────────────────────
# Returnerer liste_heltall med avstand mål kvar node (999999 = ikkje nådd).
# n_nodar = antal nodar (0..n_nodar-1), start = startnode.

funksjon _stor(): heltall { returner 999999 }

funksjon dijkstra(g: liste_heltall, n_nodar: heltall, start: heltall) -> liste_heltall {
    # Initialiser avstandar
    la dist: liste_heltall = []
    la vitja: liste_heltall = []
    la i: heltall = 0
    mens (i < n_nodar) {
        legg_til(dist, _stor())
        legg_til(vitja, 0)
        i = i + 1
    }
    dist[start] = 0

    la antall: heltall = 0
    mens (antall < n_nodar) {
        # Finn ubesøkt node med minst avstand
        la u: heltall = -1
        la min_d: heltall = _stor() + 1
        i = 0
        mens (i < n_nodar) {
            hvis (vitja[i] == 0 og dist[i] < min_d) {
                min_d = dist[i]
                u = i
            }
            i = i + 1
        }
        hvis (u == -1) { returner dist }  # alle nåbare er vitja

        vitja[u] = 1

        la naborar = _naboar(g, u)
        la j: heltall = 0
        mens (j < lengde(naborar) / 2) {
            la v: heltall = naborar[j * 2]
            la w: heltall = naborar[j * 2 + 1]
            la ny_dist: heltall = dist[u] + w
            hvis (ny_dist < dist[v]) { dist[v] = ny_dist }
            j = j + 1
        }
        antall = antall + 1
    }
    returner dist
}

# ─── Bellman-Ford — kortaste veg (støttar negative vekter) ───────────────────
# Returnerer [dist0, dist1, ..., distN-1, har_neg_syklus]
# har_neg_syklus = 1 viss negativ syklus blei oppdaga, 0 elles.

funksjon bellman_ford(g: liste_heltall, n_nodar: heltall, start: heltall) -> liste_heltall {
    la dist: liste_heltall = []
    la i: heltall = 0
    mens (i < n_nodar) { legg_til(dist, _stor())  i = i + 1 }
    dist[start] = 0

    la n_kantar: heltall = tal_kantar(g)

    # Relakser N-1 gonger
    la iter: heltall = 0
    mens (iter < n_nodar - 1) {
        i = 0
        mens (i < n_kantar) {
            la frå: heltall = g[i * 3]
            la mål: heltall = g[i * 3 + 1]
            la vekt: heltall = g[i * 3 + 2]
            hvis (dist[frå] != _stor() og dist[frå] + vekt < dist[mål]) {
                dist[mål] = dist[frå] + vekt
            }
            i = i + 1
        }
        iter = iter + 1
    }

    # Sjekk for negative syklar
    la neg_syklus: heltall = 0
    i = 0
    mens (i < n_kantar) {
        la frå: heltall = g[i * 3]
        la mål: heltall = g[i * 3 + 1]
        la vekt: heltall = g[i * 3 + 2]
        hvis (dist[frå] != _stor() og dist[frå] + vekt < dist[mål]) {
            neg_syklus = 1
        }
        i = i + 1
    }

    legg_til(dist, neg_syklus)
    returner dist
}

# ─── Kruskal MST — minimalt spenntre ─────────────────────────────────────────
# Returnerer kantliste (flat [frå, mål, vekt, ...]) for MST.
# Brukar Union-Find (flat liste_heltall).

funksjon _uf_finn(parent: liste_heltall, x: heltall) -> heltall {
    mens (parent[x] != x) { x = parent[x] }
    returner x
}

funksjon _uf_union(parent: liste_heltall, rang: liste_heltall, a: heltall, b: heltall) -> heltall {
    la ra: heltall = _uf_finn(parent, a)
    la rb: heltall = _uf_finn(parent, b)
    hvis (ra == rb) { returner 0 }
    hvis (rang[ra] < rang[rb]) { parent[ra] = rb }
    ellers hvis (rang[ra] > rang[rb]) { parent[rb] = ra }
    ellers { parent[rb] = ra  rang[ra] = rang[ra] + 1 }
    returner 1
}

funksjon kruskal_mst(g: liste_heltall, n_nodar: heltall) -> liste_heltall {
    la n_kantar: heltall = tal_kantar(g)

    # Sorter kantar etter vekt (boblesortering på triplar — enkel men korrekt)
    la kantar: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(g)) { legg_til(kantar, g[i])  i = i + 1 }

    # Boblesortering på vekt (indeks 2, 5, 8, ...)
    la j: heltall = 0
    mens (j < n_kantar - 1) {
        i = 0
        mens (i < n_kantar - j - 1) {
            hvis (kantar[i * 3 + 2] > kantar[(i + 1) * 3 + 2]) {
                # Byt triple
                la tf: heltall = kantar[i * 3]
                la tt: heltall = kantar[i * 3 + 1]
                la tv: heltall = kantar[i * 3 + 2]
                kantar[i * 3]     = kantar[(i + 1) * 3]
                kantar[i * 3 + 1] = kantar[(i + 1) * 3 + 1]
                kantar[i * 3 + 2] = kantar[(i + 1) * 3 + 2]
                kantar[(i + 1) * 3]     = tf
                kantar[(i + 1) * 3 + 1] = tt
                kantar[(i + 1) * 3 + 2] = tv
            }
            i = i + 1
        }
        j = j + 1
    }

    # Union-Find
    la parent: liste_heltall = []
    la rang: liste_heltall = []
    i = 0
    mens (i < n_nodar) {
        legg_til(parent, i)
        legg_til(rang, 0)
        i = i + 1
    }

    la mst: liste_heltall = []
    i = 0
    mens (i < n_kantar og lengde(mst) / 3 < n_nodar - 1) {
        la frå: heltall = kantar[i * 3]
        la mål: heltall = kantar[i * 3 + 1]
        la vekt: heltall = kantar[i * 3 + 2]
        la slutta: heltall = _uf_union(parent, rang, frå, mål)
        hvis (slutta == 1) {
            legg_til(mst, frå)
            legg_til(mst, mål)
            legg_til(mst, vekt)
        }
        i = i + 1
    }
    returner mst
}

# MST-totalvekt
funksjon mst_vekt(mst: liste_heltall) -> heltall {
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < tal_kantar(mst)) {
        sum = sum + mst[i * 3 + 2]
        i = i + 1
    }
    returner sum
}

# ─── Topologisk sortering (Kahn) ──────────────────────────────────────────────
# Returnerer nodar i topologisk rekkjefølge, eller tom liste viss sykel.

funksjon topologisk(g: liste_heltall, n_nodar: heltall) -> liste_heltall {
    # Bygg inngrad
    la inngrad: liste_heltall = []
    la i: heltall = 0
    mens (i < n_nodar) { legg_til(inngrad, 0)  i = i + 1 }
    la n_kantar: heltall = tal_kantar(g)
    i = 0
    mens (i < n_kantar) {
        inngrad[g[i * 3 + 1]] = inngrad[g[i * 3 + 1]] + 1
        i = i + 1
    }

    # Start med nodar med inngrad 0
    la kø: liste_heltall = []
    i = 0
    mens (i < n_nodar) {
        hvis (inngrad[i] == 0) { legg_til(kø, i) }
        i = i + 1
    }

    la ut: liste_heltall = []
    la front: heltall = 0
    mens (front < lengde(kø)) {
        la u: heltall = kø[front]
        front = front + 1
        legg_til(ut, u)

        la naborar = _naboar(g, u)
        la j: heltall = 0
        mens (j < lengde(naborar) / 2) {
            la v: heltall = naborar[j * 2]
            inngrad[v] = inngrad[v] - 1
            hvis (inngrad[v] == 0) { legg_til(kø, v) }
            j = j + 1
        }
    }

    hvis (lengde(ut) != n_nodar) { returner [] }  # sykel
    returner ut
}

# ─── Kortaste veg-rekonstruksjon ──────────────────────────────────────────────
# Køyr dijkstra og lagre forgjengjar for å rekonstruere veg.
# Returnerer flat [distanse0..N-1, forgjengjar0..N-1] (2*N element)

funksjon dijkstra_med_veg(g: liste_heltall, n_nodar: heltall, start: heltall) -> liste_heltall {
    la dist: liste_heltall = []
    la forgjengjar: liste_heltall = []
    la vitja: liste_heltall = []
    la i: heltall = 0
    mens (i < n_nodar) {
        legg_til(dist, _stor())
        legg_til(forgjengjar, -1)
        legg_til(vitja, 0)
        i = i + 1
    }
    dist[start] = 0

    la antall: heltall = 0
    mens (antall < n_nodar) {
        la u: heltall = -1
        la min_d: heltall = _stor() + 1
        i = 0
        mens (i < n_nodar) {
            hvis (vitja[i] == 0 og dist[i] < min_d) {
                min_d = dist[i]
                u = i
            }
            i = i + 1
        }
        hvis (u == -1) { antall = n_nodar }
        ellers {
            vitja[u] = 1
            la naborar = _naboar(g, u)
            la j: heltall = 0
            mens (j < lengde(naborar) / 2) {
                la v: heltall = naborar[j * 2]
                la w: heltall = naborar[j * 2 + 1]
                la ny_d: heltall = dist[u] + w
                hvis (ny_d < dist[v]) {
                    dist[v] = ny_d
                    forgjengjar[v] = u
                }
                j = j + 1
            }
            antall = antall + 1
        }
    }

    la ut: liste_heltall = []
    i = 0
    mens (i < n_nodar) { legg_til(ut, dist[i])  i = i + 1 }
    i = 0
    mens (i < n_nodar) { legg_til(ut, forgjengjar[i])  i = i + 1 }
    returner ut
}

# Rekonstruer veg frå start mål mål frå dijkstra_med_veg-resultat
funksjon rekonstruer_veg(resultat: liste_heltall, n_nodar: heltall, mål: heltall) -> liste_heltall {
    la veg: liste_heltall = []
    la node: heltall = mål
    mens (node != -1) {
        legg_til(veg, node)
        node = resultat[n_nodar + node]
    }
    # Snu vegen
    la n: heltall = lengde(veg)
    la ut: liste_heltall = []
    la i: heltall = n - 1
    mens (i >= 0) { legg_til(ut, veg[i])  i = i - 1 }
    returner ut
}

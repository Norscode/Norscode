# ai_musikk.no — musikkgenerering via std.media_model

bruk std.media_job som media_job
bruk std.media_model som media_model
bruk std.media_local som media_local
bruk std.media_neural som media_neural

funksjon ny_jobb(id: tekst, prompt: tekst, p: ordbok_tekst,
                 no_ms: heiltall, timeout_ms: heiltall) -> ordbok_tekst {
    returner media_job.ny(id, "musikk", prompt, p["navn"], no_ms, timeout_ms)
}

funksjon innstillinger(varighet_sek: heiltall, sjanger: tekst,
                       tempo: tekst, format: tekst) -> ordbok_tekst {
    hvis varighet_sek <= 0 { kast "MusikkAIFeil: varighet må vere positiv" }
    returner {"duration_seconds": tekst_fra_heltall(varighet_sek), "genre": sjanger, "tempo": tempo, "format": format}
}

funksjon generer(p: ordbok_tekst, jobb: ordbok_tekst, resultat_sti: tekst,
                 maks_bytes: heiltall, opts: ordbok_tekst,
                 no_ms: heiltall) -> ordbok_tekst {
    hvis jobb["type"] != "musikk" { kast "MusikkAIFeil: feil jobbtype" }
    returner media_model.send(p, jobb, resultat_sti, maks_bytes, opts, no_ms)
}

funksjon generer_lokalt(jobb: ordbok_tekst, resultat_sti: tekst,
                        varighet_ms: heiltall, grunnfrekvens: heiltall,
                        no_ms: heiltall) -> ordbok_tekst {
    hvis jobb["type"] != "musikk" { kast "MusikkAIFeil: feil jobbtype" }
    la resultat = media_local.musikk(jobb["prompt"], resultat_sti, varighet_ms, grunnfrekvens)
    media_local.fullfor_jobb(jobb, resultat, no_ms)
    returner resultat
}

funksjon generer_nevralt(modell, jobb: ordbok_tekst, resultat_sti: tekst,
                         varighet_ms: heiltall,
                         no_ms: heiltall) -> ordbok_tekst {
    hvis jobb["type"] != "musikk" { kast "MusikkAIFeil: feil jobbtype" }
    la resultat = media_neural.musikk(modell, jobb["prompt"], resultat_sti, varighet_ms)
    media_local.fullfor_jobb(jobb, resultat, no_ms)
    returner resultat
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "type": "musikk", "dekning": "prompt, varighet, sjanger, tempo, format og asynkron jobb"}
}

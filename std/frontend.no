}

funksjon komponent_tetthet(modus: tekst, innhold: tekst) -> tekst {
    la klasse = "density"
    hvis modus != "" {
        klasse = klasse + " density-" + modus
    }
    returner div(class_attr(klasse), slot(innhold))
}

funksjon komponent_kompakt(innhold: tekst) -> tekst {
    returner komponent_tetthet("compact", innhold)
}

funksjon komponent_tabs(labeltekst: tekst, innhold: tekst) -> tekst {

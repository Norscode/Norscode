}

funksjon komponent_tabellhandlinger(innhold: tekst) -> tekst {
    returner span(class_attr("table-actions") + attr("role", "group"), slot(innhold))
}

funksjon komponent_tabell_lenke(labeltekst: tekst, ikon: tekst, href: tekst) -> tekst {
    returner a(
        class_attr("table-action tooltip-host")
            + attr("href", href)
            + tooltip_attrs(labeltekst),
        escape(ikon)
    )
}

funksjon komponent_tabell_knapp(labeltekst: tekst, ikon: tekst, attributter: tekst) -> tekst {
    returner button(
        class_attr("table-action tooltip-host")
            + attr("type", "button")
            + tooltip_attrs(labeltekst)
            + attributter,
        escape(ikon)
    )
}

funksjon komponent_tabellcelle(labeltekst: tekst, innhold: tekst) -> tekst {
    returner tag("td", attr("data-label", labeltekst), slot(innhold))
}

funksjon komponent_tabellcelle_tekst(labeltekst: tekst, tekstverdi: tekst) -> tekst {
    returner komponent_tabellcelle(labeltekst, escape(tekstverdi))
}

funksjon komponent_kommandohint(labeltekst: tekst, innhold: tekst) -> tekst {
    returner div(class_attr("command-hints") + aria_attr("label", labeltekst), slot(innhold))
}

funksjon komponent_kommando(tekstverdi: tekst, tast: tekst) -> tekst {
    returner span(
        class_attr("command-hint"),
        span(class_attr("command-hint__label"), escape(tekstverdi))
            + tag("kbd", class_attr("command-hint__key"), escape(tast))
    )
}

funksjon komponent_handlingsmeny(menu_id: tekst, labeltekst: tekst, innhold: tekst) -> tekst {
    returner div(
        class_attr("action-menu"),
        button(
            class_attr("btn btn-secondary action-menu__button")
                + attr("type", "button")
                + data_handling("dropdown-toggle", "#" + menu_id)
                + aria_attr("controls", menu_id)
                + aria_attr("expanded", "false"),
            escape(labeltekst)
        )
            + div(id_attr(menu_id) + class_attr("action-menu__list") + attr("role", "menu") + attr("hidden", "hidden"), slot(innhold))
    )
}

funksjon komponent_meny_lenke(tekstverdi: tekst, href: tekst) -> tekst {
    returner a(class_attr("action-menu__item") + attr("href", href) + attr("role", "menuitem"), escape(tekstverdi))
}

funksjon komponent_meny_knapp(tekstverdi: tekst, attributter: tekst) -> tekst {
    returner button(class_attr("action-menu__item") + attr("type", "button") + attr("role", "menuitem") + attributter, escape(tekstverdi))
}

funksjon komponent_meny_skille() -> tekst {
    returner div(class_attr("action-menu__separator") + attr("role", "separator"), "")
}

funksjon komponent_breadcrumb(innhold: tekst) -> tekst {
    returner nav(class_attr("breadcrumb") + aria_attr("label", "Brødsmulesti"), ol("", slot(innhold)))
}

funksjon komponent_breadcrumb_lenke(tekstverdi: tekst, href: tekst) -> tekst {
    returner li("", a(attr("href", href), escape(tekstverdi)))
}

funksjon komponent_breadcrumb_aktiv(tekstverdi: tekst) -> tekst {
    returner li(attr("aria-current", "page"), escape(tekstverdi))
}

funksjon komponent_filterbar(innhold: tekst) -> tekst {
    returner div(class_attr("filterbar"), slot(innhold))
}

funksjon komponent_bulkbar(labeltekst: tekst, innhold: tekst) -> tekst {
    returner div(class_attr("bulkbar") + attr("role", "toolbar") + aria_attr("label", labeltekst), slot(innhold))
}

funksjon komponent_bulkbar_status(tekstverdi: tekst) -> tekst {

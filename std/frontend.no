    la klasse = "status-badge"
    hvis status != "" {
        klasse = klasse + " status-" + status
    }
    returner span(class_attr(klasse), escape(tekstverdi))
}

funksjon komponent_avatar(initialer: tekst, variant: tekst) -> tekst {
    la klasse = "avatar"
    hvis variant != "" {
        klasse = klasse + " avatar-" + variant
    }
    returner span(class_attr(klasse) + aria_attr("hidden", "true"), escape(initialer))
}

funksjon komponent_brukerchip(navn: tekst, initialer: tekst, variant: tekst) -> tekst {
    returner span(
        class_attr("user-chip"),
        komponent_avatar(initialer, variant) + span(class_attr("user-chip__name"), escape(navn))
    )
}

funksjon komponent_brukerlinje(navn: tekst, rolle: tekst, initialer: tekst, status: tekst) -> tekst {
    returner div(
        class_attr("user-line"),
        komponent_avatar(initialer, status)
            + span(
                class_attr("user-line__text"),
                strong("", escape(navn)) + span("", escape(rolle))
            )
            + komponent_badge(status, status)
    )
}

funksjon komponent_sidehode(tittel: tekst, ingress: tekst, handlinger: tekst) -> tekst {
    returner header(
        class_attr("page-header"),
        div(
            class_attr("page-header__text"),
            h1("", escape(tittel)) + p("", escape(ingress))
        ) + div(class_attr("page-header__actions"), slot(handlinger))
    )
}

funksjon komponent_stat(label: tekst, verdi: tekst, meta: tekst) -> tekst {

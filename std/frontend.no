    )
}

funksjon komponent_statuskort(tittel: tekst, meta: tekst, href: tekst, variant: tekst) -> tekst {
    la klasse = "status-card"
    hvis variant != "" {
        klasse = klasse + " status-card-" + variant
    }
    returner a(
        class_attr(klasse) + attr("href", href),

# runtime_exception.no - exception/unwind kontrakt for Norscode runtime v1

bruk std.runtime_stack som stack

funksjon ny_unntak(type_namn: tekst, melding: tekst) -> ordbok_tekst {
    la e: ordbok_tekst = {}
    e["type"] = type_namn
    e["message"] = melding
    e["status"] = "kastet"
    e["handled"] = "usann"
    e["handler_frame"] = ""
    e["trace"] = ""
    hvis e["type"] == "" { e["type"] = "RuntimeError" }
    returner e
}

funksjon kast_plan(type_namn: tekst, melding: tekst, s: ordbok_tekst) -> ordbok_tekst {
    la e = ny_unntak(type_namn, melding)
    e["trace"] = stack.stack_trace(s)
    e["unwind_from"] = stack.top_frame(s)
    returner e
}

funksjon fang_unntak(e: ordbok_tekst, frame_id: tekst) -> ordbok_tekst {
    e["handled"] = "sann"
    e["status"] = "fanget"
    e["handler_frame"] = frame_id
    returner e
}

funksjon er_handtert(e: ordbok_tekst) -> bool {
    returner e["handled"] == "sann"
}

funksjon unwind_plan(s: ordbok_tekst, e: ordbok_tekst, handler_frame: tekst) -> ordbok_tekst {
    la p: ordbok_tekst = {}
    p["exception"] = e["type"]
    p["message"] = e["message"]
    p["from"] = stack.top_frame(s)
    p["handler"] = handler_frame
    p["trace"] = stack.stack_trace(s)
    p["status"] = "unhandled"
    hvis handler_frame != "" {
        p["status"] = "handler-found"
    }
    returner p
}

funksjon stacktrace_tekst(e: ordbok_tekst) -> tekst {
    hvis e["trace"] == "" {
        returner e["type"] + ": " + e["message"]
    }
    returner e["type"] + ": " + e["message"] + "\n" + e["trace"]
}

funksjon produksjonsstatus() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["modul"] = "std.runtime_exception"
    s["status"] = "stabil"
    s["dekning"] = "typed exception-objekt, kast-plan, fang, finally/defer, stacktrace og iterativ unwind-plan; pure-VM har lokal try/catch-tabell, kryssramme-kast/rethrow, stack-gjenoppretting og heaprot-rydding"
    s["mangler"] = ""
    returner s
}

# observability.no - strukturert logging, målingar og status for Helpdesk-integrasjonar

bruk std.lagring som lagring
bruk std.metrics som metrics

funksjon ny() -> ordbok_tekst {
    returner {"schema": "norscode-observability-v1", "events": "", "metrics": "",
              "quick3_last_sync_ms": "0", "quick3_synced": "0", "quick3_errors": "0",
              "email_queued": "0", "email_received": "0", "email_delivery_errors": "0",
              "retry_attempts": "0"}
}

funksjon _event_line(namn: tekst, verdi: tekst) -> tekst {
    returner namn + "=" + builtin.replace(builtin.replace(verdi, "\n", "\\n"), "=", "\\=") + "\n"
}

funksjon event(o: ordbok_tekst, namn: tekst, verdi: tekst) {
    o["events"] = o["events"] + _event_line(namn, verdi)
}

funksjon inkrementer(o: ordbok_tekst, namn: tekst, delta: heiltall) {
    hvis delta <= 0 { returner }
    la i: heiltall = 0
    mens i < delta {
        metrics.tell(o, namn)
        i = i + 1
    }
}

funksjon quick3_sync(o: ordbok_tekst, tidspunkt_ms: heiltall, tal: heiltall, feil: heiltall) {
    o["quick3_last_sync_ms"] = tekst_fra_heltall(tidspunkt_ms)
    o["quick3_synced"] = tekst_fra_heltall(tal)
    o["quick3_errors"] = tekst_fra_heltall(feil)
    event(o, "quick3.sync", "objects=" + tekst_fra_heiltall(tal) + ";errors=" + tekst_fra_heltall(feil))
}

funksjon epost_kø(o: ordbok_tekst, tal: heiltall) {
    hvis tal <= 0 { returner }
    o["email_queued"] = tekst_fra_heltall(heiltall_fra_tekst(o["email_queued"]) + tal)
    inkrementer(o, "email.queued", tal)
}

funksjon epost_mottatt(o: ordbok_tekst, tal: heiltall) {
    hvis tal <= 0 { returner }
    o["email_received"] = tekst_fra_heltall(heiltall_fra_tekst(o["email_received"]) + tal)
    inkrementer(o, "email.received", tal)
}

funksjon epost_leveringsfeil(o: ordbok_tekst, tal: heiltall) {
    hvis tal <= 0 { returner }
    o["email_delivery_errors"] = tekst_fra_heltall(heiltall_fra_tekst(o["email_delivery_errors"]) + tal)
    inkrementer(o, "email.delivery_error", tal)
}

funksjon retry(o: ordbok_tekst, tal: heiltall) {
    hvis tal <= 0 { returner }
    o["retry_attempts"] = tekst_fra_heltall(heiltall_fra_tekst(o["retry_attempts"]) + tal)
    inkrementer(o, "retry", tal)
}

funksjon status(o: ordbok_tekst) -> ordbok_tekst {
    la ut: ordbok_tekst = {}
    la ks = nøkler(o)
    la i: heiltall = 0
    mens i < lengde(ks) {
        la k = tekst(ks[i])
        hvis k != "events" og k != "metrics" { ut[k] = tekst(o[ks[i]]) }
        i = i + 1
    }
    returner ut
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "schema": "norscode-observability-v1",
              "dekning": "strukturert eventlogg, Quick3-sync, e-postkø, mottak, feil og retry"}
}

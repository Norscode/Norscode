# tls_http.no — TLS/HTTPS support for HTTP-server
# Enable secure HTTPS connections
#
# Bruk:
#   bruk std.tls_http som tls
#
#   la cert = tls.load_cert("cert.pem")
#   la key = tls.load_key("key.pem")
#   la server = tls.ny_secure_server(8443, cert, key)
#   returner tls.lytt_secure(server)

bruk std.web som web
bruk std.socket som socket

# ─── Certificate Management ───────────────────────────────────────────────

funksjon ny_cert(pem_data: tekst) -> ordbok_tekst {
    la cert: ordbok_tekst = {}
    cert["__type__"] = "Certificate"
    cert["pem"] = pem_data
    cert["algorithm"] = "RSA"
    cert["keysize"] = 2048
    cert["verified"] = usann
    cert["self_signed"] = usann
    cert["hostname"] = ""
    returner cert
}

funksjon ny_key(pem_data: tekst) -> ordbok_tekst {
    la key: ordbok_tekst = {}
    key["__type__"] = "PrivateKey"
    key["pem"] = pem_data
    key["algorithm"] = "RSA"
    key["keysize"] = 2048
    returner key
}

funksjon load_cert_file(path: tekst) -> ordbok_tekst {
    # Read certificate from file
    la cert: ordbok_tekst = {}
    cert["__type__"] = "Certificate"
    cert["path"] = path
    cert["verified"] = usann
    cert["self_signed"] = usann
    cert["hostname"] = ""
    returner cert
}

funksjon load_key_file(path: tekst) -> ordbok_tekst {
    # Read private key from file
    la key: ordbok_tekst = {}
    key["__type__"] = "PrivateKey"
    key["path"] = path
    returner key
}

# ─── Self-Signed Certificate Generation ────────────────────────────────────

funksjon gen_self_signed_cert(common_name: tekst, days_valid: heltall) -> ordbok_tekst {
    # Generate self-signed certificate
    # In reality: calls openssl or similar
    # For now: placeholder

    la cert: ordbok_tekst = {}
    cert["__type__"] = "Certificate"
    cert["cn"] = common_name
    cert["valid_days"] = tekst(days_valid)
    cert["self_signed"] = sant
    cert["verified"] = usann
    cert["hostname"] = common_name
    returner cert
}

funksjon gen_private_key(keysize: heltall) -> ordbok_tekst {
    # Generate RSA private key
    la key: ordbok_tekst = {}
    key["__type__"] = "PrivateKey"
    key["keysize"] = tekst(keysize)
    returner key
}

# ─── Secure Server Setup ──────────────────────────────────────────────────

funksjon ny_secure_server(port: heltall, cert: ordbok_tekst, key: ordbok_tekst) -> ordbok_tekst {
    la server: ordbok_tekst = {}
    server["port"] = tekst(port)
    server["protocol"] = "https"
    server["cert"] = cert
    server["key"] = key
    server["tls_version"] = "1.3"
    server["ciphers"] = "HIGH:!aNULL:!MD5"
    server["routes"] = {}
    server["require_peer_verification"] = sann
    server["allow_self_signed"] = usann
    server["hostname"] = ""
    server["client_auth"] = "none"
    server["client_ca_file"] = ""
    server["client_crl_file"] = ""
    server["ocsp_response_file"] = ""
    server["transport_backend"] = "mangler"
    server["status"] = "konfigurert"
    returner server
}

# ─── HTTPS Route Registration ─────────────────────────────────────────────

funksjon route_https(server: ordbok_tekst, metode: tekst, sti: tekst, handler_namn: tekst) -> ordbok_tekst {
    # Register route on HTTPS server
    la key = metode + " " + sti
    server["routes"][key] = handler_namn
    returner server
}

# ─── Redirect HTTP to HTTPS ───────────────────────────────────────────────

funksjon ny_redirect_server(http_port: heltall, https_port: heltall) -> ordbok_tekst {
    la server: ordbok_tekst = {}
    server["port"] = tekst(http_port)
    server["protocol"] = "http"
    server["redirect_to"] = "https://localhost:" + tekst(https_port)
    returner server
}

# ─── Connection Handling ──────────────────────────────────────────────────

funksjon handle_https_request(server: ordbok_tekst, request: ordbok_tekst) -> ordbok_tekst {
    la response: ordbok_tekst = {}
    response["accepted"] = usann
    response["error"] = "TLS transport metadata manglar"
    hvis ikkje har_nokkel(request, "tls_info") { returner response }
    la tls_info = request["tls_info"]
    hvis ikkje har_nokkel(tls_info, "protocol") eller tls_info["protocol"] != "TLSv1.3" {
        response["error"] = "TLS 1.3 er påkravd"
        returner response
    }
    hvis ikkje har_nokkel(tls_info, "peer_verified") eller tls_info["peer_verified"] != sann {
        response["error"] = "TLS-peer er ikkje verifisert"
        returner response
    }
    hvis server["hostname"] != "" {
        hvis ikkje har_nokkel(tls_info, "hostname") eller tls_info["hostname"] != server["hostname"] {
            response["error"] = "TLS-hostname samsvarar ikkje"
            returner response
        }
    }
    response["accepted"] = sann
    response["error"] = ""
    response["tls_info"] = tls_info
    returner response
}

# ─── HSTS Support (HTTP Strict Transport Security) ─────────────────────────

funksjon add_hsts_header(server: ordbok_tekst, max_age: heltall, include_subdomains: boolsk) -> ordbok_tekst {
    la hsts: ordbok_tekst = {}
    hsts["max_age"] = tekst(max_age)
    hsts["include_subdomains"] = include_subdomains
    hsts["preload"] = sant

    server["hsts"] = hsts
    returner server
}

# ─── Server Execution ─────────────────────────────────────────────────────

funksjon lytt_secure(server: ordbok_tekst) -> heltall {
    hvis ikkje har_nokkel(server["cert"], "path") eller ikkje har_nokkel(server["key"], "path") {
        server["status"] = "feil"
        server["error"] = "TLS-sertifikat og nokkel maa vere filbaserte"
        returner 1
    }
    la listener: ordbok_tekst = {}
    hvis server["client_auth"] == "required" {
        hvis server["client_crl_file"] != "" {
            listener = socket.native_tls_lytt_med_klientsertifikat_og_crl("127.0.0.1", heltall_fra_tekst(server["port"]), 128, server["cert"]["path"], server["key"]["path"], server["client_ca_file"], server["client_crl_file"])
        } ellers {
            listener = socket.native_tls_lytt_med_klientsertifikat("127.0.0.1", heltall_fra_tekst(server["port"]), 128, server["cert"]["path"], server["key"]["path"], server["client_ca_file"])
        }
    } ellers hvis server["ocsp_response_file"] != "" {
        listener = socket.native_tls_lytt_med_ocsp("127.0.0.1", heltall_fra_tekst(server["port"]), 128, server["cert"]["path"], server["key"]["path"], server["ocsp_response_file"])
    } ellers {
        listener = socket.native_tls_lytt("127.0.0.1", heltall_fra_tekst(server["port"]), 128, server["cert"]["path"], server["key"]["path"])
    }
    hvis listener["status"] != "listening" {
        server["status"] = "feil"
        server["error"] = listener["error"]
        server["transport_backend"] = "mangler"
        returner 1
    }
    server["listener"] = listener
    server["port"] = tekst_fra_heltall(listener["port"])
    server["transport_backend"] = "openssl3"
    server["status"] = "klar"
    returner 0
}

funksjon lukk_secure(server: ordbok_tekst) -> boolsk {
    hvis ikkje har_nokkel(server, "listener") { returner usann }
    la r = socket.native_lukk(server["listener"])
    hvis r["status"] != "closed" { returner usann }
    server["status"] = "lukka"
    returner sann
}

# ─── Certificate Validation ───────────────────────────────────────────────

funksjon validate_cert_for_host(cert: ordbok_tekst, hostname: tekst, allow_self_signed: boolsk) -> boolsk {
    hvis hostname == "" eller ikkje har_nokkel(cert, "hostname") eller cert["hostname"] != hostname { returner usann }
    hvis har_nokkel(cert, "self_signed") og cert["self_signed"] == sann { returner allow_self_signed }
    returner har_nokkel(cert, "verified") og cert["verified"] == sann
}

funksjon validate_cert(cert: ordbok_tekst) -> boolsk {
    hvis ikkje har_nokkel(cert, "hostname") { returner usann }
    returner validate_cert_for_host(cert, cert["hostname"], usann)
}

funksjon cert_info(cert: ordbok_tekst) -> ordbok_tekst {
    la info: ordbok_tekst = {}
    info["common_name"] = cert["cn"]
    info["issuer"] = "Self"
    info["valid_from"] = "2026-06-14"
    info["valid_to"] = "2027-06-14"
    returner info
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {
        "status": "delvis",
        "dekning": "deny-by-default TLS 1.3-policy og valfri OpenSSL 3-backend med filbasert sertifikat/nokkel, trust-store, SNI, hostname-verifisering, obligatorisk mTLS-klientsertifikat, CRL_CHECK_ALL og kryptografisk verifisert OCSP-stapling med good/revoked/unknown/expiry-kontroll, nonblocking klient/server-handshake, kryptert scheduler-I/O og peer-metadata",
        "mangler": "system-backend paa Windows og runtime-attestasjon av backendbygg"
    }
}

funksjon krev_klientsertifikat(server: ordbok_tekst, client_ca_file: tekst) -> ordbok_tekst {
    server["client_auth"] = "required"
    server["client_ca_file"] = client_ca_file
    returner server
}

funksjon require_client_cert(server: ordbok_tekst, client_ca_file: tekst) -> ordbok_tekst {
    returner krev_klientsertifikat(server, client_ca_file)
}

funksjon krev_klientsertifikat_med_crl(server: ordbok_tekst, client_ca_file: tekst,
                                        client_crl_file: tekst) -> ordbok_tekst {
    krev_klientsertifikat(server, client_ca_file)
    server["client_crl_file"] = client_crl_file
    returner server
}

funksjon bruk_ocsp_stapling(server: ordbok_tekst, ocsp_response_file: tekst) -> ordbok_tekst {
    server["ocsp_response_file"] = ocsp_response_file
    returner server
}

# sha256.no - rein Norscode SHA-256 (FIPS 180-4)

funksjon _u32(x: heiltall) -> heiltall { returner x & 4294967295 }
funksjon _rotr(x: heiltall, n: heiltall) -> heiltall { returner _u32((x >> n) | (x << (32 - n))) }
funksjon _shr(x: heiltall, n: heiltall) -> heiltall { returner x >> n }
funksjon _ch(x: heiltall, y: heiltall, z: heiltall) -> heiltall { returner (x & y) ^ ((_u32(x ^ 4294967295)) & z) }
funksjon _maj(x: heiltall, y: heiltall, z: heiltall) -> heiltall { returner (x & y) ^ (x & z) ^ (y & z) }
funksjon _bsig0(x: heiltall) -> heiltall { returner _rotr(x, 2) ^ _rotr(x, 13) ^ _rotr(x, 22) }
funksjon _bsig1(x: heiltall) -> heiltall { returner _rotr(x, 6) ^ _rotr(x, 11) ^ _rotr(x, 25) }
funksjon _ssig0(x: heiltall) -> heiltall { returner _rotr(x, 7) ^ _rotr(x, 18) ^ _shr(x, 3) }
funksjon _ssig1(x: heiltall) -> heiltall { returner _rotr(x, 17) ^ _rotr(x, 19) ^ _shr(x, 10) }

funksjon _k() -> liste_heiltall {
    returner [
        1116352408, 1899447441, 3049323471, 3921009573, 961987163, 1508970993, 2453635748, 2870763221,
        3624381080, 310598401, 607225278, 1426881987, 1925078388, 2162078206, 2614888103, 3248222580,
        3835390401, 4022224774, 264347078, 604807628, 770255983, 1249150122, 1555081692, 1996064986,
        2554220882, 2821834349, 2952996808, 3210313671, 3336571891, 3584528711, 113926993, 338241895,
        666307205, 773529912, 1294757372, 1396182291, 1695183700, 1986661051, 2177026350, 2456956037,
        2730485921, 2820302411, 3259730800, 3345764771, 3516065817, 3600352804, 4094571909, 275423344,
        430227734, 506948616, 659060556, 883997877, 958139571, 1322822218, 1537002063, 1747873779,
        1955562222, 2024104815, 2227730452, 2361852424, 2428436474, 2756734187, 3204031479, 3329325298
    ]
}

funksjon _bytes(data: tekst) -> liste_heiltall {
    la out: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(data) {
        legg_til(out, builtin.char_code(builtin.slice(data, i, i + 1)) & 255)
        i = i + 1
    }
    la bit_len = lengde(out) * 8
    legg_til(out, 128)
    mens (lengde(out) % 64) != 56 { legg_til(out, 0) }
    legg_til(out, 0)
    legg_til(out, 0)
    legg_til(out, 0)
    legg_til(out, 0)
    legg_til(out, (bit_len >> 24) & 255)
    legg_til(out, (bit_len >> 16) & 255)
    legg_til(out, (bit_len >> 8) & 255)
    legg_til(out, bit_len & 255)
    returner out
}

funksjon _hex32(x: heiltall) -> tekst {
    la chars = "0123456789abcdef"
    la out = ""
    la shift: heiltall = 28
    mens shift >= 0 {
        la n = (x >> shift) & 15
        out = out + builtin.slice(chars, n, n + 1)
        shift = shift - 4
    }
    returner out
}

funksjon _hash_padda(bytes: liste_heiltall) -> tekst {
    la constants = _k()
    la h0: heiltall = 1779033703
    la h1: heiltall = 3144134277
    la h2: heiltall = 1013904242
    la h3: heiltall = 2773480762
    la h4: heiltall = 1359893119
    la h5: heiltall = 2600822924
    la h6: heiltall = 528734635
    la h7: heiltall = 1541459225

    la offset: heiltall = 0
    mens offset < lengde(bytes) {
        la w: liste_heiltall = []
        la i: heiltall = 0
        mens i < 16 {
            la p = offset + i * 4
            legg_til(w, _u32((bytes[p] << 24) | (bytes[p + 1] << 16) | (bytes[p + 2] << 8) | bytes[p + 3]))
            i = i + 1
        }
        mens i < 64 {
            legg_til(w, _u32(_ssig1(w[i - 2]) + w[i - 7] + _ssig0(w[i - 15]) + w[i - 16]))
            i = i + 1
        }

        la a = h0
        la b = h1
        la c = h2
        la d = h3
        la e = h4
        la f = h5
        la g = h6
        la h = h7
        i = 0
        mens i < 64 {
            la t1 = _u32(h + _bsig1(e) + _ch(e, f, g) + constants[i] + w[i])
            la t2 = _u32(_bsig0(a) + _maj(a, b, c))
            h = g
            g = f
            f = e
            e = _u32(d + t1)
            d = c
            c = b
            b = a
            a = _u32(t1 + t2)
            i = i + 1
        }
        h0 = _u32(h0 + a)
        h1 = _u32(h1 + b)
        h2 = _u32(h2 + c)
        h3 = _u32(h3 + d)
        h4 = _u32(h4 + e)
        h5 = _u32(h5 + f)
        h6 = _u32(h6 + g)
        h7 = _u32(h7 + h)
        offset = offset + 64
    }
    returner _hex32(h0) + _hex32(h1) + _hex32(h2) + _hex32(h3) + _hex32(h4) + _hex32(h5) + _hex32(h6) + _hex32(h7)
}

funksjon hash(data: tekst) -> tekst {
    returner _hash_padda(_bytes(data))
}

funksjon hash_bytes(data: liste_heiltall) -> tekst {
    la bytes: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(data) {
        hvis data[i] < 0 eller data[i] > 255 { kast "SHA256Feil: byte utanfor område" }
        legg_til(bytes, data[i])
        i = i + 1
    }
    la bit_len = lengde(bytes) * 8
    legg_til(bytes, 128)
    mens (lengde(bytes) % 64) != 56 { legg_til(bytes, 0) }
    legg_til(bytes, 0)
    legg_til(bytes, 0)
    legg_til(bytes, 0)
    legg_til(bytes, 0)
    legg_til(bytes, (bit_len >> 24) & 255)
    legg_til(bytes, (bit_len >> 16) & 255)
    legg_til(bytes, (bit_len >> 8) & 255)
    legg_til(bytes, bit_len & 255)
    returner _hash_padda(bytes)
}

# HMAC-SHA256 over rå byte-lister. Dette brukes av PBKDF2 og bevarer nullbytes.
funksjon _bytes_kopier(a: liste_heiltall) -> liste_heiltall {
    la ut: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(a) {
        legg_til(ut, a[i])
        i = i + 1
    }
    returner ut
}

funksjon _bytes_saman(a: liste_heiltall, b: liste_heiltall) -> liste_heiltall {
    la ut = _bytes_kopier(a)
    la i: heiltall = 0
    mens i < lengde(b) {
        legg_til(ut, b[i])
        i = i + 1
    }
    returner ut
}

funksjon _hmac_sha256_bytes(nøkkel: liste_heiltall, melding: liste_heiltall) -> liste_heiltall {
    la k = _bytes_kopier(nøkkel)
    hvis lengde(k) > 64 {
        la kh = hash_bytes(k)
        la kb: liste_heiltall = []
        la j: heiltall = 0
        mens j < 32 {
            legg_til(kb, _hex_byte(kh, j))
            j = j + 1
        }
        k = kb
    }
    mens lengde(k) < 64 { legg_til(k, 0) }
    la ipad: liste_heiltall = []
    la opad: liste_heiltall = []
    la i: heiltall = 0
    mens i < 64 {
        legg_til(ipad, k[i] ^ 54)
        legg_til(opad, k[i] ^ 92)
        i = i + 1
    }
    la indre = hash_bytes(_bytes_saman(ipad, melding))
    la indre_bytes: liste_heiltall = []
    i = 0
    mens i < 32 {
        legg_til(indre_bytes, _hex_byte(indre, i))
        i = i + 1
    }
    la ytre = hash_bytes(_bytes_saman(opad, indre_bytes))
    la ut: liste_heiltall = []
    i = 0
    mens i < 32 {
        legg_til(ut, _hex_byte(ytre, i))
        i = i + 1
    }
    returner ut
}

funksjon _hex_verdi(c: tekst) -> heiltall {
    la pos = builtin.index_of("0123456789abcdef", tekst_til_liten(c))
    hvis pos < 0 { kast "SHA256Feil: ugyldig hex" }
    returner pos
}

funksjon _hex_byte(h: tekst, indeks: heiltall) -> heiltall {
    la p = indeks * 2
    returner _hex_verdi(builtin.slice(h, p, p + 1)) * 16 + _hex_verdi(builtin.slice(h, p + 1, p + 2))
}

funksjon hmac_sha256_bytes(nøkkel: liste_heiltall, melding: liste_heiltall) -> liste_heiltall {
    returner _hmac_sha256_bytes(nøkkel, melding)
}

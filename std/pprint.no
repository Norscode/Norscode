# pprint.no — Pen utskrift av datastrukturar
# Python: pprint
#
# Formaterer ordbok_tekst, liste_tekst og liste_heltall
# med innrykk, sortering og linjebrytingsgrense.
#
# Bruk:
#   bruk std.pprint som pp
#   pp.pprint(ordbok)                  # skriv direkte
#   la s = pp.pformat(ordbok)          # returner som tekst
#   la s = pp.pformat_dybde(ordbok, 4) # maks innrykk 4 nivå

# ─── Innstillingar ────────────────────────────────────────────────────────────

la INNRYKK: heltall = 2   # mellomrom per nivå
la BREDDE: heltall = 80   # linjebrytingsgrense

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _mellomrom(nivå: heltall) -> tekst {
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < nivå * INNRYKK) { ut = ut + " "  i = i + 1 }
    returner ut
}

funksjon _escape_tekst(s: tekst) -> tekst {
    la delar = builtin.split(s, "\"")
    la escaped: tekst = builtin.join(delar, "\\\"")
    la delar2 = builtin.split(escaped, "\n")
    escaped = builtin.join(delar2, "\\n")
    la delar3 = builtin.split(escaped, "\t")
    escaped = builtin.join(delar3, "\\t")
    returner escaped
}

# Sorter liste_tekst (boblesortering, stigande)
funksjon _sorter(liste: liste_tekst) -> liste_tekst {
    la kopi: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(liste)) { legg_til(kopi, liste[i])  i = i + 1 }
    la n: heltall = lengde(kopi)
    la swapped: bool = sann
    mens (swapped) {
        swapped = usann
        la j: heltall = 0
        mens (j + 1 < n) {
            hvis (kopi[j] > kopi[j + 1]) {
                la tmp: tekst = kopi[j]
                kopi[j] = kopi[j + 1]
                kopi[j + 1] = tmp
                swapped = sann
            }
            j = j + 1
        }
    }
    returner kopi
}

# ─── Formatering ──────────────────────────────────────────────────────────────

funksjon _format_verdi(verdi: tekst, nivå: heltall, maks_nivå: heltall) -> tekst {
    # Prøv å parse som JSON
    prøv {
        la parsed = builtin.json_parse(verdi)
        # Viss vi fekk tilbake eit objekt (ordbok_tekst)
        returner _format_json(verdi, nivå, maks_nivå)
    } fang (e) {
        returner "\"" + _escape_tekst(verdi) + "\""
    }
    returner "\"" + _escape_tekst(verdi) + "\""
}

funksjon _format_json(json_str: tekst, nivå: heltall, maks_nivå: heltall) -> tekst {
    # Forenkla: returnerer JSON med innrykk
    la indent: tekst = _mellomrom(nivå)
    la inner: tekst = _mellomrom(nivå + 1)

    prøv {
        la obj = builtin.json_parse(json_str)
        la nøklar = builtin.nøkler(obj)
        hvis (lengde(nøklar) == 0) { returner "{}" }

        la sortert = _sorter(nøklar)
        la ut: tekst = "{\n"
        la i: heltall = 0
        mens (i < lengde(sortert)) {
            la k: tekst = sortert[i]
            la v: tekst = obj[k]
            ut = ut + inner + "\"" + _escape_tekst(k) + "\": "
            hvis (nivå + 1 < maks_nivå) {
                ut = ut + _format_verdi(v, nivå + 1, maks_nivå)
            } ellers {
                ut = ut + "\"" + _escape_tekst(v) + "\""
            }
            hvis (i + 1 < lengde(sortert)) { ut = ut + "," }
            ut = ut + "\n"
            i = i + 1
        }
        ut = ut + indent + "}"
        returner ut
    } fang (e) {
        returner "\"" + _escape_tekst(json_str) + "\""
    }
    returner json_str
}

# Formater ein ordbok_tekst
funksjon pformat_ordbok(d: ordbok_tekst, nivå: heltall, maks_nivå: heltall) -> tekst {
    la nøklar = builtin.nøkler(d)
    la n: heltall = lengde(nøklar)
    hvis (n == 0) { returner "{}" }
    la sortert = _sorter(nøklar)
    la indent: tekst = _mellomrom(nivå)
    la inner: tekst = _mellomrom(nivå + 1)
    la ut: tekst = "{\n"
    la i: heltall = 0
    mens (i < n) {
        la k: tekst = sortert[i]
        la v: tekst = d[k]
        ut = ut + inner + "\"" + _escape_tekst(k) + "\": "
        hvis (nivå + 1 >= maks_nivå) {
            ut = ut + "\"" + _escape_tekst(v) + "\""
        } ellers {
            ut = ut + _format_verdi(v, nivå + 1, maks_nivå)
        }
        hvis (i + 1 < n) { ut = ut + "," }
        ut = ut + "\n"
        i = i + 1
    }
    ut = ut + indent + "}"
    returner ut
}

# Formater ei liste_tekst
funksjon pformat_liste_tekst(l: liste_tekst, nivå: heltall, maks_nivå: heltall) -> tekst {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner "[]" }
    la indent: tekst = _mellomrom(nivå)
    la inner: tekst = _mellomrom(nivå + 1)
    la ut: tekst = "[\n"
    la i: heltall = 0
    mens (i < n) {
        ut = ut + inner
        hvis (nivå + 1 >= maks_nivå) {
            ut = ut + "\"" + _escape_tekst(l[i]) + "\""
        } ellers {
            ut = ut + _format_verdi(l[i], nivå + 1, maks_nivå)
        }
        hvis (i + 1 < n) { ut = ut + "," }
        ut = ut + "\n"
        i = i + 1
    }
    ut = ut + indent + "]"
    returner ut
}

# Formater ei liste_heltall
funksjon pformat_liste_heltall(l: liste_heltall, nivå: heltall) -> tekst {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner "[]" }
    la indent: tekst = _mellomrom(nivå)
    la inner: tekst = _mellomrom(nivå + 1)
    la ut: tekst = "[\n"
    la i: heltall = 0
    mens (i < n) {
        ut = ut + inner + tekst_fra_heltall(l[i])
        hvis (i + 1 < n) { ut = ut + "," }
        ut = ut + "\n"
        i = i + 1
    }
    ut = ut + indent + "]"
    returner ut
}

# ─── Offentleg API ────────────────────────────────────────────────────────────

# Formater ordbok til tekst med standard innstillingar
funksjon pformat(d: ordbok_tekst) -> tekst {
    returner pformat_ordbok(d, 0, 10)
}

# Formater med maks-dybde
funksjon pformat_dybde(d: ordbok_tekst, maks_dybde: heltall) -> tekst {
    returner pformat_ordbok(d, 0, maks_dybde)
}

# Skriv ordbok direkte
funksjon pprint(d: ordbok_tekst) {
    skriv pformat(d)
}

# Skriv liste_tekst
funksjon pprint_liste(l: liste_tekst) {
    skriv pformat_liste_tekst(l, 0, 10)
}

# Skriv liste_heltall
funksjon pprint_heltall(l: liste_heltall) {
    skriv pformat_liste_heltall(l, 0)
}

# Einlinje-representasjon (utan innrykk, med bredde-grense)
funksjon repr_einlinje(d: ordbok_tekst) -> tekst {
    la nøklar = builtin.nøkler(d)
    la sortert = _sorter(nøklar)
    la ut: tekst = "{"
    la i: heltall = 0
    mens (i < lengde(sortert)) {
        la k: tekst = sortert[i]
        ut = ut + "\"" + _escape_tekst(k) + "\": \"" + _escape_tekst(d[k]) + "\""
        hvis (i + 1 < lengde(sortert)) { ut = ut + ", " }
        i = i + 1
    }
    returner ut + "}"
}

# Kompakt format for logging
funksjon kompakt(d: ordbok_tekst) -> tekst {
    la nøklar = builtin.nøkler(d)
    la sortert = _sorter(nøklar)
    la delar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(sortert)) {
        la k: tekst = sortert[i]
        legg_til(delar, k + "=" + d[k])
        i = i + 1
    }
    returner "{" + builtin.join(delar, ", ") + "}"
}

# Tabellformat: liste av ordbøker som ASCII-tabell
funksjon tabell(rader: liste_tekst, kolonnar: liste_tekst) -> tekst {
    # Finn kolonnebreidder
    la breidder: ordbok_heltall = {}
    la i: heltall = 0
    mens (i < lengde(kolonnar)) {
        breidder[kolonnar[i]] = lengde(builtin.split(kolonnar[i], ""))
        i = i + 1
    }
    la ri: heltall = 0
    mens (ri < lengde(rader)) {
        la rad = builtin.json_parse(rader[ri])
        la ki: heltall = 0
        mens (ki < lengde(kolonnar)) {
            la kn: tekst = kolonnar[ki]
            la vl: heltall = 0
            hvis (har_nokkel(rad, kn)) {
                vl = lengde(builtin.split(rad[kn], ""))
            }
            hvis (vl > breidder[kn]) { breidder[kn] = vl }
            ki = ki + 1
        }
        ri = ri + 1
    }

    # Bygg overskrift
    la ut: tekst = ""
    la separator: tekst = "+"
    la overskrift: tekst = "|"
    i = 0
    mens (i < lengde(kolonnar)) {
        la kn: tekst = kolonnar[i]
        la b: heltall = breidder[kn] + 2
        la linje: tekst = ""
        la j: heltall = 0
        mens (j < b) { linje = linje + "-"  j = j + 1 }
        separator = separator + linje + "+"
        la padding: heltall = b - 2 - lengde(builtin.split(kn, ""))
        la pad: tekst = ""
        j = 0
        mens (j < padding) { pad = pad + " "  j = j + 1 }
        overskrift = overskrift + " " + kn + pad + " |"
        i = i + 1
    }
    ut = separator + "\n" + overskrift + "\n" + separator + "\n"

    # Bygg rader
    ri = 0
    mens (ri < lengde(rader)) {
        la rad = builtin.json_parse(rader[ri])
        la rad_linje: tekst = "|"
        i = 0
        mens (i < lengde(kolonnar)) {
            la kn: tekst = kolonnar[i]
            la verd: tekst = ""
            hvis (har_nokkel(rad, kn)) { verd = rad[kn] }
            la b: heltall = breidder[kn] + 2
            la padding: heltall = b - 2 - lengde(builtin.split(verd, ""))
            la pad: tekst = ""
            la j: heltall = 0
            mens (j < padding) { pad = pad + " "  j = j + 1 }
            rad_linje = rad_linje + " " + verd + pad + " |"
            i = i + 1
        }
        ut = ut + rad_linje + "\n"
        ri = ri + 1
    }
    ut = ut + separator
    returner ut
}

# std.secrets — passord-hashing og hemmelege verdiar
#
# passord_hash(passord, salt) -> salt$pbkdf2:sha256:260000:<salt_hex>:<hash_hex>
# passord_verifiser(passord, lagret) → sann/usann
#
# Salt-prefikset blir halde i klartekst for lesbarheit; den underliggjande
# kryptografiske saltverdien genererast framleis tilfeldig.

funksjon passord_hash(passord: tekst, salt: tekst) -> tekst {
    returner salt + "$" + sikkerhet_passord_hash(passord, salt)
}

funksjon passord_verifiser(passord: tekst, lagret: tekst) -> bool {
    returner sikkerhet_passord_verifiser(passord, lagret)
}

funksjon hemmelighet_hent(nokkel: tekst) -> tekst {
    returner miljo_hent(nokkel)
}

funksjon hemmelighet_finnes(nokkel: tekst) -> bool {
    returner miljo_finnes(nokkel)
}

# platform.no — Plattformdeteksjon
# Python: platform
#
# Hentar rå systemsignal ved OS-grensa, men normaliserer miljø, minne og
# plattformtekst i Norscode utan grep/head/tail-pipelines.
#
# Bruk:
#   bruk std.platform som plat
#   skriv plat.system()      # → "Linux", "Darwin", "Windows"
#   skriv plat.node()        # → maskinnamn
#   skriv plat.release()     # → "5.15.0" (kernelversjon)
#   skriv plat.maskin()      # → "x86_64"
#   skriv plat.python_impl() # → "Norscode"

# ─── Basis-informasjon ───────────────────────────────────────────────────────

# OS-type: "Linux", "Darwin" (macOS), "Windows", "ukjend"
funksjon system() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -s")
        la delar = builtin.split(res, "\n")
        la s: tekst = delar[0]
        # Normaliser
        la delar2 = builtin.split(s, "\r")
        returner delar2[0]
    } fang (e) {
        # Windows-fallback
        prøv {
            la os_env = builtin.miljo_hent("OS")
            hvis (tekst_starter_med(os_env, "Windows")) { returner "Windows" }
        } fang (e2) {}
        returner "ukjend"
    }
    returner "ukjend"
}

# Maskinnamn (hostname)
funksjon node() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -n")
        la delar = builtin.split(res, "\n")
        returner delar[0]
    } fang (e) {
        prøv {
            returner builtin.miljo_hent("HOSTNAME")
        } fang (e2) {
            returner "ukjend"
        }
    }
    returner "ukjend"
}

# Kjerne-/OS-versjon
funksjon release() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -r")
        la delar = builtin.split(res, "\n")
        returner delar[0]
    } fang (e) {
        returner "ukjend"
    }
    returner "ukjend"
}

# Fullstendig versjonsinformasjon
funksjon version() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -v")
        la delar = builtin.split(res, "\n")
        returner delar[0]
    } fang (e) {
        returner "ukjend"
    }
    returner "ukjend"
}

# Maskinarktitektur
funksjon maskin() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -m")
        la delar = builtin.split(res, "\n")
        returner delar[0]
    } fang (e) {
        returner "ukjend"
    }
    returner "ukjend"
}

# Prosessortype
funksjon prosessor() -> tekst {
    prøv {
        la res = builtin.exec_prosess("uname -p")
        la delar = builtin.split(res, "\n")
        la p: tekst = delar[0]
        hvis (p == "unknown" eller p == "") { returner maskin() }
        returner p
    } fang (e) {
        returner maskin()
    }
    returner maskin()
}

# ─── Samla informasjon ────────────────────────────────────────────────────────

# Returnerer alt som ordbok_tekst
funksjon uname() -> ordbok_tekst {
    la info: ordbok_tekst = {}
    info["system"] = system()
    info["node"] = node()
    info["release"] = release()
    info["version"] = version()
    info["maskin"] = maskin()
    info["prosessor"] = prosessor()
    returner info
}

# Formater til tekst
funksjon uname_tekst() -> tekst {
    la info = uname()
    returner info["system"] + " " + info["node"] + " " +
             info["release"] + " " + info["version"] + " " +
             info["maskin"]
}

# ─── Plattform-sjekkar ────────────────────────────────────────────────────────

funksjon er_linux() -> bool {
    returner system() == "Linux"
}

funksjon er_macos() -> bool {
    la s: tekst = system()
    returner s == "Darwin"
}

funksjon er_windows() -> bool {
    la s: tekst = system()
    returner s == "Windows" eller tekst_starter_med(s, "CYGWIN") eller
             tekst_starter_med(s, "MINGW") eller tekst_starter_med(s, "MSYS")
}

funksjon er_unix() -> bool {
    returner ikkje er_windows()
}

funksjon er_64bit() -> bool {
    la m: tekst = maskin()
    returner m == "x86_64" eller m == "amd64" eller m == "aarch64" eller m == "arm64"
}

funksjon er_arm() -> bool {
    la m: tekst = maskin()
    returner tekst_starter_med(m, "arm") eller tekst_starter_med(m, "aarch")
}

# ─── Distribusjonsinformasjon (Linux) ────────────────────────────────────────

funksjon linux_distro() -> tekst {
    prøv {
        la res = builtin.fil_les("/etc/os-release")
        la linjer = builtin.split(res, "\n")
        la i: heltall = 0
        mens (i < lengde(linjer)) {
            la linje: tekst = linjer[i]
            hvis (tekst_starter_med(linje, "PRETTY_NAME=")) {
                la delar = builtin.split(linje, "=")
                la verdi: tekst = delar[1]
                # Fjern anførselstegn
                la teikn = builtin.split(verdi, "")
                la n: heltall = lengde(teikn)
                la start: heltall = 0
                la slutt: heltall = n
                hvis (n > 0 og teikn[0] == "\"") { start = 1 }
                hvis (n > 0 og teikn[n - 1] == "\"") { slutt = n - 1 }
                returner builtin.join(builtin.slice(teikn, start, slutt), "")
            }
            i = i + 1
        }
    } fang (e) {}
    prøv {
        la res = builtin.exec_prosess("lsb_release -d 2>/dev/null")
        la delar = builtin.split(res, ":")
        hvis (lengde(delar) >= 2) {
            la verdi: tekst = delar[1]
            # Trim leiande mellomrom
            la teikn = builtin.split(verdi, "")
            la start: heltall = 0
            mens (start < lengde(teikn) og teikn[start] == " ") { start = start + 1 }
            returner builtin.join(builtin.slice(teikn, start, lengde(teikn)), "")
        }
    } fang (e) {}
    returner "ukjend"
}

# ─── Sjell-informasjon ────────────────────────────────────────────────────────

funksjon sjell() -> tekst {
    prøv {
        returner builtin.miljo_hent("SHELL")
    } fang (e) {
        returner "ukjend"
    }
    returner "ukjend"
}

funksjon brukar() -> tekst {
    prøv {
        la res = builtin.exec_prosess("whoami")
        la delar = builtin.split(res, "\n")
        returner delar[0]
    } fang (e) {
        prøv {
            returner builtin.miljo_hent("USER")
        } fang (e2) {
            returner "ukjend"
        }
    }
    returner "ukjend"
}

funksjon heimekatalog() -> tekst {
    prøv {
        la heim = builtin.miljo_hent("HOME")
        hvis (heim != "") { returner heim }
    } fang (e) {}
    returner "/home/" + brukar()
}

# ─── Norscode-runtime ─────────────────────────────────────────────────────────

funksjon python_impl() -> tekst {
    returner "Norscode"
}

funksjon python_versjon() -> tekst {
    returner "1.0.0"
}

funksjon python_versjon_tuple() -> liste_heltall {
    returner [1, 0, 0]
}

# ─── CPU-info ─────────────────────────────────────────────────────────────────

funksjon tal_cpu() -> heltall {
    prøv {
        la res = builtin.exec_prosess("nproc 2>/dev/null")
        la delar = builtin.split(res, "\n")
        returner builtin.heltall_fra_tekst(delar[0])
    } fang (e) {
        prøv {
            la res = builtin.exec_prosess("sysctl -n hw.ncpu 2>/dev/null")
            la delar = builtin.split(res, "\n")
            returner builtin.heltall_fra_tekst(delar[0])
        } fang (e2) {
            returner 1
        }
    }
    returner 1
}

# ─── Minneinfo ────────────────────────────────────────────────────────────────

# Totalt RAM i MB
funksjon total_ram_mb() -> heltall {
    prøv {
        la res = builtin.exec_prosess("free -m 2>/dev/null")
        la minne_linje: tekst = _minne_linje(res)
        la delar = builtin.split(minne_linje, " ")
        la i: heltall = 0
        la sist_tal: heltall = 0
        mens (i < lengde(delar)) {
            la d: tekst = delar[i]
            prøv {
                la n: heltall = builtin.heltall_fra_tekst(d)
                sist_tal = n
            } fang (e) {}
            i = i + 1
        }
        returner sist_tal
    } fang (e) {
        returner 0
    }
    returner 0
}

funksjon _minne_linje(tekstblokk: tekst) -> tekst {
    la linjer = builtin.split(tekstblokk, "\n")
    la i: heltall = 0
    mens (i < lengde(linjer)) {
        la linje: tekst = linjer[i]
        hvis (tekst_starter_med(linje, "Mem:")) {
            returner linje
        }
        i = i + 1
    }
    returner ""
}

# ─── Miljøvariablar ───────────────────────────────────────────────────────────

funksjon miljø_hent(nøkkel: tekst) -> tekst {
    prøv {
        returner builtin.miljo_hent(nøkkel)
    } fang (e) {
        returner ""
    }
    returner ""
}

funksjon miljø_hent_eller(nøkkel: tekst, standard: tekst) -> tekst {
    prøv {
        la v: tekst = builtin.miljo_hent(nøkkel)
        hvis (v == "") { returner standard }
        returner v
    } fang (e) {
        returner standard
    }
    returner standard
}

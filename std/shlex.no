# shlex.no — Shell-leksikalsk analyse
# Python: shlex
#
# Støttar:
#   - Enkle og doble anførselstegn: 'ord med mellomrom' "anna ord"
#   - Escape-teikn: \" \' \\ \ (backslash-escape utanfor anførselstegn)
#   - Kommentarar: # til slutt av linje (valfri)
#   - Posix-modus: escape tolka inne i doble anførselstegn
#
# Bruk:
#   bruk std.shlex som sh
#   la tokens = sh.split("echo 'hei verd' --flagg=verdi")
#   # → ["echo", "hei verd", "--flagg=verdi"]
#   la quoted = sh.quote("fil med mellomrom.txt")
#   # → "'fil med mellomrom.txt'"

# ─── Tokenisering ─────────────────────────────────────────────────────────────

# Hovudfunksjon: del opp shell-tekst i tokens
# posix: sann → tolkar escape inne i "..." (standard)
# kommentarar: sann → # startar kommentar
funksjon split(s: tekst, posix: bool, kommentarar: bool) -> liste_tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la tokens: liste_tekst = []
    la i: heltall = 0

    mens (i < n) {
        la c: tekst = teikn[i]

        # Hopp over leiande mellomrom
        mens (i < n og (teikn[i] == " " eller teikn[i] == "\t" eller
              teikn[i] == "\n" eller teikn[i] == "\r")) {
            i = i + 1
        }
        hvis (i >= n) { i = n }
        ellers {
            la c2: tekst = teikn[i]
            # Kommentar
            hvis (kommentarar og c2 == "#") {
                i = n  # ignorer resten
            } ellers {
                # Les eitt token
                la token: tekst = ""
                la i_token: heltall = i
                mens (i < n og teikn[i] != " " og teikn[i] != "\t" og
                      teikn[i] != "\n" og teikn[i] != "\r") {
                    la ch: tekst = teikn[i]
                    hvis (ch == "'") {
                        # Enkel-quotet streng: alt til neste '
                        i = i + 1
                        mens (i < n og teikn[i] != "'") {
                            token = token + teikn[i]
                            i = i + 1
                        }
                        hvis (i < n) { i = i + 1 }  # hopp over '
                    } ellers hvis (ch == "\"") {
                        # Dobbel-quotet streng
                        i = i + 1
                        mens (i < n og teikn[i] != "\"") {
                            la dch: tekst = teikn[i]
                            hvis (posix og dch == "\\" og i + 1 < n) {
                                i = i + 1
                                token = token + teikn[i]
                            } ellers {
                                token = token + dch
                            }
                            i = i + 1
                        }
                        hvis (i < n) { i = i + 1 }  # hopp over "
                    } ellers hvis (ch == "\\" og i + 1 < n) {
                        # Escape utanfor anførselstegn
                        i = i + 1
                        token = token + teikn[i]
                        i = i + 1
                    } ellers {
                        token = token + ch
                        i = i + 1
                    }
                }
                hvis (lengde(builtin.split(token, "")) > 0 eller i > i_token) {
                    legg_til(tokens, token)
                }
            }
        }
    }
    returner tokens
}

# Enkel split med standard innstillingar (posix=sann, kommentarar=usann)
funksjon split_enkel(s: tekst) -> liste_tekst {
    returner split(s, sann, usann)
}

# ─── Quoting ──────────────────────────────────────────────────────────────────

funksjon _treng_quoting(s: tekst) -> bool {
    la teikn = builtin.split(s, "")
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la c: tekst = teikn[i]
        la k: heltall = builtin.char_code(c)
        # Trygg: bokstavar, siffer, nokre symbol
        la er_trygg: bool = (k >= 65 og k <= 90) eller (k >= 97 og k <= 122) eller
                             (k >= 48 og k <= 57) eller c == "_" eller c == "-" eller
                             c == "." eller c == "/" eller c == ":"
        hvis (ikkje er_trygg) { returner sann }
        i = i + 1
    }
    returner lengde(teikn) == 0  # tom streng treng quoting
}

# Sikkert quote ein tekst for bruk i shell
funksjon quote(s: tekst) -> tekst {
    hvis (ikkje _treng_quoting(s)) { returner s }
    # Erstatt ' med '\'' og wrap i enkle anførselstegn
    la delar = builtin.split(s, "'")
    la escaped: tekst = builtin.join(delar, "'\\''")
    returner "'" + escaped + "'"
}

# Sett saman tokens til ein shell-kommando
funksjon join(tokens: liste_tekst) -> tekst {
    la deler: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        legg_til(deler, quote(tokens[i]))
        i = i + 1
    }
    returner builtin.join(deler, " ")
}

# ─── Tokenisering med metadata ────────────────────────────────────────────────

# Token-typar: "ord" "quote_enkel" "quote_dobbel" "operator" "kommentar"
funksjon tokeniser(s: tekst) -> liste_tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la tokens: liste_tekst = []
    la i: heltall = 0

    mens (i < n) {
        mens (i < n og (teikn[i] == " " eller teikn[i] == "\t")) { i = i + 1 }
        hvis (i >= n) { i = n }
        ellers {
            la ch: tekst = teikn[i]
            hvis (ch == "#") {
                # Kommentar til linjeavslutning
                la komm: tekst = ""
                mens (i < n og teikn[i] != "\n") {
                    komm = komm + teikn[i]
                    i = i + 1
                }
                la tok: ordbok_tekst = {}
                tok["type"] = "kommentar"
                tok["verdi"] = komm
                legg_til(tokens, builtin.json_stringify(tok))
            } ellers hvis (ch == "'") {
                i = i + 1
                la s_v: tekst = ""
                mens (i < n og teikn[i] != "'") {
                    s_v = s_v + teikn[i]
                    i = i + 1
                }
                hvis (i < n) { i = i + 1 }
                la tok: ordbok_tekst = {}
                tok["type"] = "quote_enkel"
                tok["verdi"] = s_v
                legg_til(tokens, builtin.json_stringify(tok))
            } ellers hvis (ch == "\"") {
                i = i + 1
                la s_v: tekst = ""
                mens (i < n og teikn[i] != "\"") {
                    hvis (teikn[i] == "\\" og i + 1 < n) {
                        i = i + 1
                        s_v = s_v + teikn[i]
                    } ellers {
                        s_v = s_v + teikn[i]
                    }
                    i = i + 1
                }
                hvis (i < n) { i = i + 1 }
                la tok: ordbok_tekst = {}
                tok["type"] = "quote_dobbel"
                tok["verdi"] = s_v
                legg_til(tokens, builtin.json_stringify(tok))
            } ellers hvis (ch == "|" eller ch == "&" eller ch == ";" eller
                           ch == "<" eller ch == ">" eller ch == "(" eller ch == ")") {
                la tok: ordbok_tekst = {}
                tok["type"] = "operator"
                tok["verdi"] = ch
                legg_til(tokens, builtin.json_stringify(tok))
                i = i + 1
            } ellers {
                la s_v: tekst = ""
                mens (i < n og teikn[i] != " " og teikn[i] != "\t" og
                      teikn[i] != "'" og teikn[i] != "\"" og
                      teikn[i] != "|" og teikn[i] != "&" og
                      teikn[i] != ";" og teikn[i] != "\n") {
                    s_v = s_v + teikn[i]
                    i = i + 1
                }
                la tok: ordbok_tekst = {}
                tok["type"] = "ord"
                tok["verdi"] = s_v
                legg_til(tokens, builtin.json_stringify(tok))
            }
        }
    }
    returner tokens
}

# ─── Variable-ekspansjon (enkel $VAR og ${VAR}) ───────────────────────────────

funksjon ekspander(s: tekst, env: ordbok_tekst) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la ut: tekst = ""
    la i: heltall = 0
    mens (i < n) {
        la ch: tekst = teikn[i]
        hvis (ch == "$" og i + 1 < n) {
            i = i + 1
            hvis (teikn[i] == "{") {
                # ${VAR}
                i = i + 1
                la varnamn: tekst = ""
                mens (i < n og teikn[i] != "}") {
                    varnamn = varnamn + teikn[i]
                    i = i + 1
                }
                hvis (i < n) { i = i + 1 }
                hvis (har_nokkel(env, varnamn)) { ut = ut + env[varnamn] }
            } ellers {
                # $VAR
                la varnamn: tekst = ""
                mens (i < n og (builtin.char_code(teikn[i]) >= 65 og builtin.char_code(teikn[i]) <= 90 eller
                      builtin.char_code(teikn[i]) >= 97 og builtin.char_code(teikn[i]) <= 122 eller
                      builtin.char_code(teikn[i]) >= 48 og builtin.char_code(teikn[i]) <= 57 eller
                      teikn[i] == "_")) {
                    varnamn = varnamn + teikn[i]
                    i = i + 1
                }
                hvis (har_nokkel(env, varnamn)) { ut = ut + env[varnamn] }
            }
        } ellers {
            ut = ut + ch
            i = i + 1
        }
    }
    returner ut
}

# likskap.no — Tekstlikskapsalgoritmar
# Python: difflib (SequenceMatcher), jellyfish, textdistance
#
# Bruk:
#   bruk std.likskap som lik
#   skriv(lik.levenshtein("kitten", "sitting"))   # => 3
#   skriv(lik.hamming("karolin", "kathrin"))       # => 3
#   skriv(lik.likskap_prosent("nors", "norsk"))    # => 80

# ─── Intern hjelp ─────────────────────────────────────────────────────────────

funksjon _teikn(s: tekst) -> liste_tekst {
    returner builtin.split(s, "")
}

funksjon _min3(a: heltall, b: heltall, c: heltall) -> heltall {
    la m: heltall = a
    hvis (b < m) { m = b }
    hvis (c < m) { m = c }
    returner m
}

funksjon _min2(a: heltall, b: heltall) -> heltall {
    hvis (a < b) { returner a }
    returner b
}

funksjon _abs(x: heltall) -> heltall {
    hvis (x < 0) { returner 0 - x }
    returner x
}

# ─── Levenshtein-avstand ──────────────────────────────────────────────────────
# Minimum antal innsettingar, slettingar og erstatningar for å gjere a → b.

funksjon levenshtein(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)

    # DP-rad (berre to rader trengst)
    la gjeld: liste_heltall = []
    la forrige: liste_heltall = []
    la i: heltall = 0
    mens (i <= n) {
        legg_til(forrige, i)
        legg_til(gjeld, 0)
        i = i + 1
    }

    i = 1
    mens (i <= m) {
        gjeld[0] = i
        la j: heltall = 1
        mens (j <= n) {
            hvis (ta[i - 1] == tb[j - 1]) {
                gjeld[j] = forrige[j - 1]
            } ellers {
                gjeld[j] = 1 + _min3(forrige[j], gjeld[j - 1], forrige[j - 1])
            }
            j = j + 1
        }
        # Byt rader
        la k: heltall = 0
        mens (k <= n) {
            forrige[k] = gjeld[k]
            k = k + 1
        }
        i = i + 1
    }
    returner forrige[n]
}

# ─── Hamming-avstand ──────────────────────────────────────────────────────────
# Antal posisjonar der teikna skil seg. Krev same lengd; returnerer -1 viss ulik.

funksjon hamming(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    hvis (m != n) { returner -1 }
    la avstand: heltall = 0
    la i: heltall = 0
    mens (i < m) {
        hvis (ta[i] != tb[i]) { avstand = avstand + 1 }
        i = i + 1
    }
    returner avstand
}

# ─── Lengste felles delsekvens (LCS) ─────────────────────────────────────────

funksjon lcs_lengde(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)

    la gjeld: liste_heltall = []
    la forrige: liste_heltall = []
    la i: heltall = 0
    mens (i <= n) {
        legg_til(forrige, 0)
        legg_til(gjeld, 0)
        i = i + 1
    }

    i = 1
    mens (i <= m) {
        la j: heltall = 1
        mens (j <= n) {
            hvis (ta[i - 1] == tb[j - 1]) {
                gjeld[j] = forrige[j - 1] + 1
            } ellers {
                gjeld[j] = _min2(forrige[j], gjeld[j - 1])
                hvis (forrige[j] > gjeld[j - 1]) { gjeld[j] = forrige[j] }
            }
            j = j + 1
        }
        la k: heltall = 0
        mens (k <= n) { forrige[k] = gjeld[k]  k = k + 1 }
        i = i + 1
    }
    returner forrige[n]
}

# ─── Lengste felles delstreng (substring, samanhengande) ─────────────────────

funksjon lcs_delstreng_lengde(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    la best: heltall = 0

    # Flat DP-matrise (m+1)×(n+1)
    la dp: liste_heltall = []
    la total: heltall = (m + 1) * (n + 1)
    la k: heltall = 0
    mens (k < total) { legg_til(dp, 0)  k = k + 1 }

    la i: heltall = 1
    mens (i <= m) {
        la j: heltall = 1
        mens (j <= n) {
            hvis (ta[i - 1] == tb[j - 1]) {
                la v: heltall = dp[(i - 1) * (n + 1) + (j - 1)] + 1
                dp[i * (n + 1) + j] = v
                hvis (v > best) { best = v }
            }
            j = j + 1
        }
        i = i + 1
    }
    returner best
}

# Hent sjølve delstrengen (første beste)
funksjon lcs_delstreng(a: tekst, b: tekst) -> tekst {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    la best: heltall = 0
    la best_slutt: heltall = 0

    la dp: liste_heltall = []
    la total: heltall = (m + 1) * (n + 1)
    la k: heltall = 0
    mens (k < total) { legg_til(dp, 0)  k = k + 1 }

    la i: heltall = 1
    mens (i <= m) {
        la j: heltall = 1
        mens (j <= n) {
            hvis (ta[i - 1] == tb[j - 1]) {
                la v: heltall = dp[(i - 1) * (n + 1) + (j - 1)] + 1
                dp[i * (n + 1) + j] = v
                hvis (v > best) { best = v  best_slutt = i }
            }
            j = j + 1
        }
        i = i + 1
    }
    hvis (best == 0) { returner "" }
    returner builtin.slice(a, best_slutt - best, best_slutt)
}

# ─── Jaro-likskap ─────────────────────────────────────────────────────────────
# Returnerer Jaro × 1000 (0–1000)

funksjon jaro_x1000(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    hvis (m == 0 og n == 0) { returner 1000 }
    hvis (m == 0 eller n == 0) { returner 0 }

    la vindauge: heltall = m
    hvis (n > m) { vindauge = n }
    vindauge = vindauge / 2 - 1
    hvis (vindauge < 0) { vindauge = 0 }

    la a_match: liste_heltall = []
    la b_match: liste_heltall = []
    la i: heltall = 0
    mens (i < m) { legg_til(a_match, 0)  i = i + 1 }
    i = 0
    mens (i < n) { legg_til(b_match, 0)  i = i + 1 }

    la treff: heltall = 0
    i = 0
    mens (i < m) {
        la start: heltall = i - vindauge
        la slutt: heltall = i + vindauge + 1
        hvis (start < 0) { start = 0 }
        hvis (slutt > n) { slutt = n }
        la j: heltall = start
        mens (j < slutt) {
            hvis (b_match[j] == 0 og ta[i] == tb[j]) {
                a_match[i] = 1
                b_match[j] = 1
                treff = treff + 1
                j = slutt  # bryt
            }
            j = j + 1
        }
        i = i + 1
    }
    hvis (treff == 0) { returner 0 }

    # Tel transposisjonar
    la t: heltall = 0
    la k: heltall = 0
    i = 0
    mens (i < m) {
        hvis (a_match[i] == 1) {
            mens (k < n og b_match[k] == 0) { k = k + 1 }
            hvis (k < n og ta[i] != tb[k]) { t = t + 1 }
            k = k + 1
        }
        i = i + 1
    }

    # Jaro = (m/|s1| + m/|s2| + (m-t/2)/m) / 3  × 1000
    la jaro: heltall = (treff * 1000 / m + treff * 1000 / n + (treff * 1000 - t * 500) / treff) / 3
    returner jaro
}

# ─── Likskaps-prosent ─────────────────────────────────────────────────────────
# Basert på Levenshtein: 100 * (1 - avstand / maks_lengd)

funksjon likskap_prosent(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    la maks: heltall = m
    hvis (n > m) { maks = n }
    hvis (maks == 0) { returner 100 }
    la avstand: heltall = levenshtein(a, b)
    returner 100 - avstand * 100 / maks
}

# ─── Prefix / suffix / inneheld ───────────────────────────────────────────────

# Lengste felles prefix-lengde
funksjon felles_prefix_lengde(a: tekst, b: tekst) -> heltall {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    la grense: heltall = m
    hvis (n < m) { grense = n }
    la i: heltall = 0
    mens (i < grense og ta[i] == tb[i]) { i = i + 1 }
    returner i
}

# Er a ein delsekvens av b?
funksjon er_delsekvens(a: tekst, b: tekst) -> bool {
    la ta = _teikn(a)
    la tb = _teikn(b)
    la m: heltall = lengde(ta)
    la n: heltall = lengde(tb)
    la i: heltall = 0
    la j: heltall = 0
    mens (i < m og j < n) {
        hvis (ta[i] == tb[j]) { i = i + 1 }
        j = j + 1
    }
    returner i == m
}

# model_release.no — signerte, versjonerte lokale modellutgjevingar

bruk std.model_trust som model_trust
bruk std.qmodel_binary som qmodel_binary
bruk std.model_registry som model_registry
bruk std.sha256 som sha256
bruk std.text_model_bundle som text_model_bundle
bruk std.text_model_registry som text_model_registry

funksjon ny(maks_noklar: heiltall, maks_tilbakekallingar: heiltall) {
    hvis maks_noklar <= 0 eller maks_noklar > 1024 eller maks_tilbakekallingar <= 0 eller maks_tilbakekallingar > 100000 {
        kast "ModellUtgjevingFeil: ugyldige tillitsgrenser"
    }
    returner {
        "schema": "norscode.model-release-trust.v1",
        "maks_noklar": maks_noklar,
        "maks_tilbakekallingar": maks_tilbakekallingar,
        "noklar": {},
        "tilbakekalte_noklar": {},
        "tilbakekalte_utgjevingar": {},
        "hogaste_versjon": {}
    }
}

funksjon _gyldig_id(verdi: tekst) -> boolsk {
    hvis verdi == "" eller lengde(verdi) > 128 { returner usann }
    la tillate = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_."
    la i: heiltall = 0
    mens i < lengde(verdi) {
        hvis ikkje builtin.contains(tillate, builtin.slice(verdi, i, i + 1)) { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon legg_til_nokkel(tillit, nokkel_id: tekst, hemmeleg: tekst) -> boolsk {
    hvis ikkje _gyldig_id(nokkel_id) eller lengde(hemmeleg) < 32 { returner usann }
    hvis ikkje har_nokkel(tillit["noklar"], nokkel_id) og lengde(nøkler(tillit["noklar"])) >= tillit["maks_noklar"] {
        returner usann
    }
    tillit["noklar"][nokkel_id] = hemmeleg
    hvis har_nokkel(tillit["tilbakekalte_noklar"], nokkel_id) { fjern_nokkel(tillit["tilbakekalte_noklar"], nokkel_id) }
    returner sann
}

funksjon tilbakekall_nokkel(tillit, nokkel_id: tekst) -> boolsk {
    hvis ikkje har_nokkel(tillit["noklar"], nokkel_id) { returner usann }
    hvis lengde(nøkler(tillit["tilbakekalte_noklar"])) >= tillit["maks_tilbakekallingar"] { returner usann }
    tillit["tilbakekalte_noklar"][nokkel_id] = sann
    returner sann
}

funksjon tilbakekall_utgjeving(tillit, utgjeving_id: tekst) -> boolsk {
    hvis ikkje _gyldig_id(utgjeving_id) { returner usann }
    hvis ikkje har_nokkel(tillit["tilbakekalte_utgjevingar"], utgjeving_id) og lengde(nøkler(tillit["tilbakekalte_utgjevingar"])) >= tillit["maks_tilbakekallingar"] {
        returner usann
    }
    tillit["tilbakekalte_utgjevingar"][utgjeving_id] = sann
    returner sann
}

funksjon _kanonisk(m) -> tekst {
    returner m["schema"] + "|" + m["format"] + "|" + m["id"] + "|" + m["modell"] + "|" +
        tekst_fra_heltall(m["versjon"]) + "|" + tekst_fra_heltall(m["parametre"]) + "|" +
        tekst_fra_heltall(m["oppretta_ms"]) + "|" + tekst_fra_heltall(m["utlop_ms"]) + "|" +
        m["sha256"] + "|" + m["signert_av"]
}

funksjon _lik_tid(a: tekst, b: tekst) -> boolsk {
    hvis lengde(a) != lengde(b) { returner usann }
    la ulik: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(a) {
        hvis builtin.slice(a, i, i + 1) != builtin.slice(b, i, i + 1) { ulik = ulik + 1 }
        i = i + 1
    }
    returner ulik == 0
}

funksjon _tekst_bytes(verdi: tekst) -> liste_heiltall {
    la ut: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(verdi) {
        la kode = builtin.char_code(builtin.slice(verdi, i, i + 1))
        hvis kode < 0 eller kode > 255 { kast "ModellUtgjevingFeil: HMAC støttar byte-tekst" }
        legg_til(ut, kode)
        i = i + 1
    }
    returner ut
}

funksjon _hex_nibble(teikn: tekst) -> heiltall {
    la pos = builtin.index_of("0123456789abcdef", teikn)
    hvis pos < 0 { kast "ModellUtgjevingFeil: ugyldig hash" }
    returner pos
}

funksjon _hex_bytes(verdi: tekst) -> liste_heiltall {
    hvis lengde(verdi) % 2 != 0 { kast "ModellUtgjevingFeil: ugyldig hash-lengde" }
    la ut: liste_heiltall = []
    la i: heiltall = 0
    mens i < lengde(verdi) {
        la hi = _hex_nibble(builtin.slice(verdi, i, i + 1))
        la lo = _hex_nibble(builtin.slice(verdi, i + 1, i + 2))
        legg_til(ut, hi * 16 + lo)
        i = i + 2
    }
    returner ut
}

funksjon hmac_sha256(nokkel: tekst, data: tekst) -> tekst {
    la key = _tekst_bytes(nokkel)
    hvis lengde(key) > 64 { key = _hex_bytes(sha256.hash_bytes(key)) }
    mens lengde(key) < 64 { legg_til(key, 0) }
    la inner: liste_heiltall = []
    la outer: liste_heiltall = []
    la i: heiltall = 0
    mens i < 64 {
        legg_til(inner, key[i] ^ 54)
        legg_til(outer, key[i] ^ 92)
        i = i + 1
    }
    la data_bytes = _tekst_bytes(data)
    i = 0
    mens i < lengde(data_bytes) {
        legg_til(inner, data_bytes[i])
        i = i + 1
    }
    la inner_hash = _hex_bytes(sha256.hash_bytes(inner))
    i = 0
    mens i < lengde(inner_hash) {
        legg_til(outer, inner_hash[i])
        i = i + 1
    }
    returner sha256.hash_bytes(outer)
}

funksjon signer(utgjeving_id: tekst, modell_namn: tekst, versjon: heiltall,
                parametre: heiltall, oppretta_ms: heiltall, utlop_ms: heiltall,
                nokkel_id: tekst, hemmeleg: tekst, data: liste_heltall) {
    hvis ikkje _gyldig_id(utgjeving_id) eller ikkje _gyldig_id(modell_namn) eller ikkje _gyldig_id(nokkel_id) {
        kast "ModellUtgjevingFeil: ugyldig identitet"
    }
    hvis versjon <= 0 eller parametre <= 0 eller oppretta_ms < 0 eller utlop_ms <= oppretta_ms eller lengde(hemmeleg) < 32 {
        kast "ModellUtgjevingFeil: ugyldig manifest"
    }
    la m = {
        "schema": "norscode.model-release.v1",
        "format": "NQM1",
        "id": utgjeving_id,
        "modell": modell_namn,
        "versjon": versjon,
        "parametre": parametre,
        "oppretta_ms": oppretta_ms,
        "utlop_ms": utlop_ms,
        "sha256": model_trust.hash_bytes(data),
        "signert_av": nokkel_id,
        "signatur": ""
    }
    m["signatur"] = hmac_sha256(hemmeleg, _kanonisk(m))
    returner m
}

funksjon signer_ntm1(utgjeving_id: tekst, modell_namn: tekst, versjon: heiltall,
                     parametre: heiltall, oppretta_ms: heiltall, utlop_ms: heiltall,
                     nokkel_id: tekst, hemmeleg: tekst, data: liste_heltall) {
    la m = signer(utgjeving_id, modell_namn, versjon, parametre,
                   oppretta_ms, utlop_ms, nokkel_id, hemmeleg, data)
    m["format"] = "NTM1"
    m["signatur"] = hmac_sha256(hemmeleg, _kanonisk(m))
    returner m
}

funksjon verifiser(tillit, manifest, data: liste_heltall, no_ms: heiltall) -> boolsk {
    hvis manifest["schema"] != "norscode.model-release.v1" { returner usann }
    hvis ikkje har_nokkel(manifest, "format") { returner usann }
    hvis manifest["format"] != "NQM1" og manifest["format"] != "NTM1" { returner usann }
    hvis ikkje _gyldig_id(manifest["id"]) eller ikkje _gyldig_id(manifest["modell"]) eller ikkje _gyldig_id(manifest["signert_av"]) { returner usann }
    hvis manifest["versjon"] <= 0 eller manifest["parametre"] <= 0 { returner usann }
    hvis manifest["oppretta_ms"] < 0 eller manifest["utlop_ms"] <= manifest["oppretta_ms"] { returner usann }
    hvis no_ms < manifest["oppretta_ms"] eller no_ms >= manifest["utlop_ms"] { returner usann }
    hvis har_nokkel(tillit["tilbakekalte_utgjevingar"], manifest["id"]) { returner usann }
    hvis har_nokkel(tillit["tilbakekalte_noklar"], manifest["signert_av"]) { returner usann }
    hvis ikkje har_nokkel(tillit["noklar"], manifest["signert_av"]) { returner usann }
    hvis ikkje model_trust.gyldig_sha256(manifest["sha256"]) { returner usann }
    hvis ikkje _lik_tid(manifest["sha256"], model_trust.hash_bytes(data)) { returner usann }
    hvis har_nokkel(tillit["hogaste_versjon"], manifest["modell"]) og manifest["versjon"] <= tillit["hogaste_versjon"][manifest["modell"]] { returner usann }
    la venta = hmac_sha256(tillit["noklar"][manifest["signert_av"]], _kanonisk(manifest))
    returner _lik_tid(venta, manifest["signatur"])
}

funksjon installer(register, tillit, manifest, data: liste_heiltall,
                   no_ms: heiltall, maks_parametre: heiltall) -> boolsk {
    hvis ikkje verifiser(tillit, manifest, data, no_ms) { returner usann }
    hvis manifest["format"] != "NQM1" { returner usann }
    la modell = qmodel_binary.dekod(data, maks_parametre)
    hvis modell["navn"] != manifest["modell"] eller modell["parametre"] != manifest["parametre"] { returner usann }
    hvis ikkje model_registry.registrer_utgjeving(register, modell, "NQM1+HMAC-SHA256", manifest["id"], manifest["versjon"]) { returner usann }
    tillit["hogaste_versjon"][manifest["modell"]] = manifest["versjon"]
    returner sann
}

funksjon installer_tekst(register, tillit, manifest, data: liste_heiltall,
                         no_ms: heiltall, maks_parametre: heiltall) -> boolsk {
    hvis ikkje verifiser(tillit, manifest, data, no_ms) { returner usann }
    hvis manifest["format"] != "NTM1" { returner usann }
    la lasta = text_model_bundle.dekod(data, maks_parametre)
    hvis lasta["modell"]["navn"] != manifest["modell"] eller lasta["parametre"] != manifest["parametre"] { returner usann }
    hvis ikkje text_model_registry.registrer_utgjeving(register, lasta, manifest["id"], manifest["versjon"]) { returner usann }
    tillit["hogaste_versjon"][manifest["modell"]] = manifest["versjon"]
    returner sann
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {
        "status": "stabil",
        "schema": "norscode.model-release.v1",
        "dekning": "kanonisk HMAC-SHA256-signering av NQM1 og NTM1, SHA-256-innhaldspinning, nøkkelrotasjon, nøkkel- og utgjevingstilbakekalling, utløp, rollback-vern og atomisk installasjon"
    }
}

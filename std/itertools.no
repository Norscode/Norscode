# itertools.no — Kombinatorikk og iterasjonsverktøy
# Python: itertools
#
# Bruk:
#   bruk std.itertools som it
#   la par = it.kartesisk_tall([1,2], [3,4])  # => [[1,3],[1,4],[2,3],[2,4]]
#   la perm = it.permutasjonar_tekst(["a","b","c"])
#   la komb = it.kombinasjonar_tall([1,2,3,4], 2)

# ─── Kartesisk produkt (to lister med heltall) ────────────────────────────────
# Returnerer flat liste: kvart par [a, b] er to påfølgjande element.

funksjon kartesisk_tall(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    la resultat: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(a)) {
        la j: heltall = 0
        mens (j < lengde(b)) {
            legg_til(resultat, a[i])
            legg_til(resultat, b[j])
            j = j + 1
        }
        i = i + 1
    }
    returner resultat
}

funksjon kartesisk_tekst(a: liste_tekst, b: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(a)) {
        la j: heltall = 0
        mens (j < lengde(b)) {
            legg_til(resultat, a[i])
            legg_til(resultat, b[j])
            j = j + 1
        }
        i = i + 1
    }
    returner resultat
}

# ─── Chain (sett saman fleire lister) ────────────────────────────────────────

funksjon chain_tall(a: liste_heltall, b: liste_heltall) -> liste_heltall {
    la r: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(a)) {
        legg_til(r, a[i])
        i = i + 1
    }
    la j: heltall = 0
    mens (j < lengde(b)) {
        legg_til(r, b[j])
        j = j + 1
    }
    returner r
}

funksjon chain_tekst(a: liste_tekst, b: liste_tekst) -> liste_tekst {
    la r: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(a)) {
        legg_til(r, a[i])
        i = i + 1
    }
    la j: heltall = 0
    mens (j < lengde(b)) {
        legg_til(r, b[j])
        j = j + 1
    }
    returner r
}

# ─── Cycle: gjenta liste n gonger ─────────────────────────────────────────────

funksjon cycle_tall(l: liste_heltall, n: heltall) -> liste_heltall {
    la r: liste_heltall = []
    la len: heltall = lengde(l)
    hvis (len == 0 eller n <= 0) { returner r }
    la rep: heltall = 0
    mens (rep < n) {
        la i: heltall = 0
        mens (i < len) {
            legg_til(r, l[i])
            i = i + 1
        }
        rep = rep + 1
    }
    returner r
}

funksjon cycle_tekst(l: liste_tekst, n: heltall) -> liste_tekst {
    la r: liste_tekst = []
    la len: heltall = lengde(l)
    hvis (len == 0 eller n <= 0) { returner r }
    la rep: heltall = 0
    mens (rep < n) {
        la i: heltall = 0
        mens (i < len) {
            legg_til(r, l[i])
            i = i + 1
        }
        rep = rep + 1
    }
    returner r
}

# ─── Permutasjonar ────────────────────────────────────────────────────────────
# Returnerer alle permutasjonar flatt: kvart sett er r påfølgjande element.
# OBS: faktoriell vekst — hald n liten (<=8).

# Intern: byt plass mellom indeks i og j
funksjon _bytt_tall(l: liste_heltall, i: heltall, j: heltall) -> heltall {
    la tmp: heltall = l[i]
    l[i] = l[j]
    l[j] = tmp
    returner 0
}

funksjon _bytt_tekst(l: liste_tekst, i: heltall, j: heltall) -> heltall {
    la tmp: tekst = l[i]
    l[i] = l[j]
    l[j] = tmp
    returner 0
}

# Kopier elementa frå l[0..k-1] inn i resultat
funksjon _kopier_k_tall(l: liste_heltall, k: heltall, ut: liste_heltall) -> heltall {
    la i: heltall = 0
    mens (i < k) {
        legg_til(ut, l[i])
        i = i + 1
    }
    returner 0
}

funksjon _kopier_k_tekst(l: liste_tekst, k: heltall, ut: liste_tekst) -> heltall {
    la i: heltall = 0
    mens (i < k) {
        legg_til(ut, l[i])
        i = i + 1
    }
    returner 0
}

# Heap's algorithm for k-permutasjonar
funksjon _perm_tall_rekursiv(l: liste_heltall, k: heltall, n: heltall, ut: liste_heltall) -> heltall {
    hvis (k == 1) {
        _kopier_k_tall(l, n, ut)
        returner 1
    }
    la i: heltall = 0
    mens (i < k) {
        _perm_tall_rekursiv(l, k - 1, n, ut)
        hvis (k % 2 == 0) {
            _bytt_tall(l, i, k - 1)
        } ellers {
            _bytt_tall(l, 0, k - 1)
        }
        i = i + 1
    }
    returner 0
}

funksjon permutasjonar_tall(l: liste_heltall) -> liste_heltall {
    la kopi: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(kopi, l[i])
        i = i + 1
    }
    la ut: liste_heltall = []
    la n: heltall = lengde(kopi)
    hvis (n == 0) { returner ut }
    _perm_tall_rekursiv(kopi, n, n, ut)
    returner ut
}

funksjon _perm_tekst_rekursiv(l: liste_tekst, k: heltall, n: heltall, ut: liste_tekst) -> heltall {
    hvis (k == 1) {
        _kopier_k_tekst(l, n, ut)
        returner 1
    }
    la i: heltall = 0
    mens (i < k) {
        _perm_tekst_rekursiv(l, k - 1, n, ut)
        hvis (k % 2 == 0) {
            _bytt_tekst(l, i, k - 1)
        } ellers {
            _bytt_tekst(l, 0, k - 1)
        }
        i = i + 1
    }
    returner 0
}

funksjon permutasjonar_tekst(l: liste_tekst) -> liste_tekst {
    la kopi: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(kopi, l[i])
        i = i + 1
    }
    la ut: liste_tekst = []
    la n: heltall = lengde(kopi)
    hvis (n == 0) { returner ut }
    _perm_tekst_rekursiv(kopi, n, n, ut)
    returner ut
}

# ─── Kombinasjonar (utan repetisjon, r om gongen) ─────────────────────────────
# Returnerer flatt — kvart sett er r påfølgjande element.

funksjon _komb_tall(l: liste_heltall, start: heltall, r: heltall, gjeldande: liste_heltall, ut: liste_heltall) -> heltall {
    hvis (lengde(gjeldande) == r) {
        la i: heltall = 0
        mens (i < r) {
            legg_til(ut, gjeldande[i])
            i = i + 1
        }
        returner 1
    }
    la resterande: heltall = r - lengde(gjeldande)
    la tilgjengeleg: heltall = lengde(l) - start
    hvis (tilgjengeleg < resterande) { returner 0 }
    la i: heltall = start
    mens (i < lengde(l)) {
        legg_til(gjeldande, l[i])
        _komb_tall(l, i + 1, r, gjeldande, ut)
        pop_siste(gjeldande)
        i = i + 1
    }
    returner 0
}

funksjon kombinasjonar_tall(l: liste_heltall, r: heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la gjeldande: liste_heltall = []
    _komb_tall(l, 0, r, gjeldande, ut)
    returner ut
}

funksjon _komb_tekst(l: liste_tekst, start: heltall, r: heltall, gjeldande: liste_tekst, ut: liste_tekst) -> heltall {
    hvis (lengde(gjeldande) == r) {
        la i: heltall = 0
        mens (i < r) {
            legg_til(ut, gjeldande[i])
            i = i + 1
        }
        returner 1
    }
    la resterande: heltall = r - lengde(gjeldande)
    la tilgjengeleg: heltall = lengde(l) - start
    hvis (tilgjengeleg < resterande) { returner 0 }
    la i: heltall = start
    mens (i < lengde(l)) {
        legg_til(gjeldande, l[i])
        _komb_tekst(l, i + 1, r, gjeldande, ut)
        pop_siste(gjeldande)
        i = i + 1
    }
    returner 0
}

funksjon kombinasjonar_tekst(l: liste_tekst, r: heltall) -> liste_tekst {
    la ut: liste_tekst = []
    la gjeldande: liste_tekst = []
    _komb_tekst(l, 0, r, gjeldande, ut)
    returner ut
}

# ─── Kombinasjonar med repetisjon ─────────────────────────────────────────────

funksjon _komb_rep_tall(l: liste_heltall, start: heltall, r: heltall, gjeldande: liste_heltall, ut: liste_heltall) -> heltall {
    hvis (lengde(gjeldande) == r) {
        la i: heltall = 0
        mens (i < r) {
            legg_til(ut, gjeldande[i])
            i = i + 1
        }
        returner 1
    }
    la i: heltall = start
    mens (i < lengde(l)) {
        legg_til(gjeldande, l[i])
        _komb_rep_tall(l, i, r, gjeldande, ut)  # i (ikkje i+1) = med repetisjon
        pop_siste(gjeldande)
        i = i + 1
    }
    returner 0
}

funksjon kombinasjonar_rep_tall(l: liste_heltall, r: heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la gjeldande: liste_heltall = []
    _komb_rep_tall(l, 0, r, gjeldande, ut)
    returner ut
}

# ─── Sliding window ───────────────────────────────────────────────────────────
# Returnerer alle påfølgjande undersekvenser av lengde k (flatt).

funksjon vindauge_tall(l: liste_heltall, k: heltall) -> liste_heltall {
    la r: liste_heltall = []
    la n: heltall = lengde(l)
    la i: heltall = 0
    mens (i <= n - k) {
        la j: heltall = 0
        mens (j < k) {
            legg_til(r, l[i + j])
            j = j + 1
        }
        i = i + 1
    }
    returner r
}

funksjon vindauge_tekst(l: liste_tekst, k: heltall) -> liste_tekst {
    la r: liste_tekst = []
    la n: heltall = lengde(l)
    la i: heltall = 0
    mens (i <= n - k) {
        la j: heltall = 0
        mens (j < k) {
            legg_til(r, l[i + j])
            j = j + 1
        }
        i = i + 1
    }
    returner r
}

# ─── Tal på kombinasjonar: C(n, r) ────────────────────────────────────────────

funksjon binom(n: heltall, r: heltall) -> heltall {
    hvis (r > n) { returner 0 }
    hvis (r == 0 eller r == n) { returner 1 }
    la k: heltall = r
    hvis (n - r < r) { k = n - r }  # bruk minste side
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < k) {
        resultat = resultat * (n - i) / (i + 1)
        i = i + 1
    }
    returner resultat
}

# Tal på permutasjonar: P(n, r) = n! / (n-r)!
funksjon perm_tal(n: heltall, r: heltall) -> heltall {
    hvis (r > n) { returner 0 }
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < r) {
        resultat = resultat * (n - i)
        i = i + 1
    }
    returner resultat
}

# deploy.no — Utrulling og prosesshandtering for Norscode
# Gunicorn / Supervisor / systemd-ekvivalent
#
# Bruk:
#   bruk std.deploy som deploy
#
#   la cfg = deploy.ny_konfig("minapp")
#   deploy.sett_port(cfg, 8000)
#   deploy.sett_arbeidarar(cfg, 4)
#   deploy.generer_systemd(cfg)  // skriv minapp.service
#   deploy.generer_supervisor(cfg)
#   deploy.helsesjekk("http://localhost:8000/helse")

bruk std.web som web

# ─── Konfigurasjon ────────────────────────────────────────────────────────────

funksjon ny_konfig(app_namn: tekst) -> ordbok_tekst {
    la c: ordbok_tekst = {}
    c["namn"]         = app_namn
    c["vert"]         = "0.0.0.0"
    c["port"]         = "8000"
    c["arbeidarar"]   = "4"
    c["mappe"]        = "/app"
    c["brukar"]       = "www-data"
    c["gruppe"]       = "www-data"
    c["logg_mappe"]   = "/var/log/" + app_namn
    c["pid_fil"]      = "/run/" + app_namn + ".pid"
    c["env_fil"]      = ".env"
    c["restart"]      = "always"
    c["max_minne_mb"] = "512"
    c["helse_sti"]    = "/helse"
    c["helse_intervall"] = "30"
    c["graceful_timeout"] = "30"
    returner c
}

funksjon sett_port(c: ordbok_tekst, port: heltall) -> heltall {
    c["port"] = tekst(port)
    returner port
}

funksjon sett_arbeidarar(c: ordbok_tekst, n: heltall) -> heltall {
    c["arbeidarar"] = tekst(n)
    returner n
}

funksjon sett_mappe(c: ordbok_tekst, sti: tekst) -> heltall {
    c["mappe"] = sti
    returner 0
}

funksjon sett_brukar(c: ordbok_tekst, brukar: tekst, gruppe: tekst) -> heltall {
    c["brukar"] = brukar
    c["gruppe"] = gruppe
    returner 0
}

funksjon sett_env_fil(c: ordbok_tekst, sti: tekst) -> heltall {
    c["env_fil"] = sti
    returner 0
}

funksjon sett_helse_sti(c: ordbok_tekst, sti: tekst) -> heltall {
    c["helse_sti"] = sti
    returner 0
}

# ─── systemd-tenestefilgenerator ──────────────────────────────────────────────

funksjon generer_systemd(c: ordbok_tekst) -> tekst {
    la namn: tekst  = c["namn"]
    la mappe: tekst = c["mappe"]
    la port: tekst  = c["port"]
    la arb: tekst   = c["arbeidarar"]
    la brukar: tekst = c["brukar"]
    la gruppe: tekst = c["gruppe"]
    la logg: tekst  = c["logg_mappe"]
    la timeout: tekst = c["graceful_timeout"]

    la innhald = "[Unit]\n" +
        "Description=Norscode app: " + namn + "\n" +
        "After=network.target\n\n" +
        "[Service]\n" +
        "Type=simple\n" +
        "User=" + brukar + "\n" +
        "Group=" + gruppe + "\n" +
        "WorkingDirectory=" + mappe + "\n" +
        "EnvironmentFile=-" + mappe + "/" + tekst(c["env_fil"]) + "\n" +
        "ExecStart=/usr/local/bin/nc serve --port " + port + " --workers " + arb + "\n" +
        "ExecReload=/bin/kill -HUP $MAINPID\n" +
        "KillMode=mixed\n" +
        "TimeoutStopSec=" + timeout + "\n" +
        "Restart=" + tekst(c["restart"]) + "\n" +
        "RestartSec=5\n" +
        "StandardOutput=append:" + logg + "/access.log\n" +
        "StandardError=append:" + logg + "/error.log\n\n" +
        "[Install]\n" +
        "WantedBy=multi-user.target\n"

    la sti = mappe + "/" + namn + ".service"
    builtin.fil_skriv(sti, innhald)
    returner innhald
}

funksjon systemd_kommandoar(c: ordbok_tekst) -> tekst {
    la namn: tekst = c["namn"]
    returner "# systemd-kommandoar for " + namn + "\n" +
             "sudo cp " + tekst(c["mappe"]) + "/" + namn + ".service /etc/systemd/system/\n" +
             "sudo systemctl daemon-reload\n" +
             "sudo systemctl enable " + namn + "\n" +
             "sudo systemctl start " + namn + "\n" +
             "sudo systemctl status " + namn + "\n" +
             "sudo journalctl -u " + namn + " -f"
}

# ─── Supervisor-konfig ────────────────────────────────────────────────────────

funksjon generer_supervisor(c: ordbok_tekst) -> tekst {
    la namn: tekst  = c["namn"]
    la mappe: tekst = c["mappe"]
    la port: tekst  = c["port"]
    la arb: tekst   = c["arbeidarar"]
    la brukar: tekst = c["brukar"]
    la logg: tekst  = c["logg_mappe"]

    la innhald = "[program:" + namn + "]\n" +
        "command=/usr/local/bin/nc serve --port " + port + " --workers " + arb + "\n" +
        "directory=" + mappe + "\n" +
        "user=" + brukar + "\n" +
        "autostart=true\n" +
        "autorestart=true\n" +
        "stopwaitsecs=" + tekst(c["graceful_timeout"]) + "\n" +
        "stdout_logfile=" + logg + "/access.log\n" +
        "stderr_logfile=" + logg + "/error.log\n" +
        "stdout_logfile_maxbytes=50MB\n" +
        "stderr_logfile_maxbytes=50MB\n" +
        "environment=HOME=" + mappe + "\n"

    la sti = mappe + "/" + namn + "-supervisor.conf"
    builtin.fil_skriv(sti, innhald)
    returner innhald
}

# ─── Nginx-proxy-konfig ───────────────────────────────────────────────────────

funksjon generer_nginx(c: ordbok_tekst, domene: tekst) -> tekst {
    la namn: tekst = c["namn"]
    la port: tekst = c["port"]
    la helse_sti: tekst = tekst(c["helse_sti"])
    la arb  = heltall_fra_tekst(tekst(c["arbeidarar"]))

    // upstream-blokk med ein entry per arbeidar (same port, let nginx runde rundt)
    la upstream = "upstream " + namn + "_backend {\n" +
                  "    least_conn;\n" +
                  "    server 127.0.0.1:" + port + ";\n" +
                  "    keepalive 32;\n" +
                  "}\n"

    la server = "server {\n" +
        "    listen 80;\n" +
        "    server_name " + domene + ";\n\n" +
        "    location / {\n" +
        "        proxy_pass http://" + namn + "_backend;\n" +
        "        proxy_set_header Host $host;\n" +
        "        proxy_set_header X-Real-IP $remote_addr;\n" +
        "        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n" +
        "        proxy_set_header X-Forwarded-Proto $scheme;\n" +
        "        proxy_connect_timeout 10s;\n" +
        "        proxy_read_timeout 60s;\n" +
        "        proxy_buffering on;\n" +
        "    }\n\n" +
        "    location /static/ {\n" +
        "        alias " + tekst(c["mappe"]) + "/static/;\n" +
        "        expires 1y;\n" +
        "        add_header Cache-Control \"public, immutable\";\n" +
        "    }\n\n" +
        "    location " + helse_sti + " {\n" +
        "        access_log off;\n" +
        "        proxy_pass http://" + namn + "_backend;\n" +
        "    }\n" +
        "}\n"

    la innhald = upstream + "\n" + server
    la sti = tekst(c["mappe"]) + "/" + namn + "-nginx.conf"
    builtin.fil_skriv(sti, innhald)
    returner innhald
}

# ─── Helsesjekk ───────────────────────────────────────────────────────────────

funksjon helsesjekk(url: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    la start = builtin.unix_timestamp()
    prøv {
        la resp = builtin.http_get(url)
        la slutt = builtin.unix_timestamp()
        la status = heltall_fra_tekst(tekst(resp["status"]))
        r["ok"] = "usann"
        hvis status >= 200 og status < 300 {
            r["ok"] = "sann"
        }
        r["status"] = tekst(status)
        r["ms"]     = tekst((slutt - start) * 1000)
        r["url"]    = url
    } fang (e) {
        r["ok"]   = "usann"
        r["feil"] = tekst(e)
        r["url"]  = url
        r["ms"]   = "0"
    }
    returner r
}

funksjon helsesjekk_loop(url: tekst, maks_forsøk: heltall, pause_sek: heltall) -> ordbok_tekst {
    la forsøk: heltall = 0
    mens forsøk < maks_forsøk {
        la r = helsesjekk(url)
        hvis tekst(r["ok"]) == "sann" { returner r }
        builtin.sleep(pause_sek)
        forsøk = forsøk + 1
    }
    la r: ordbok_tekst = {}
    r["ok"] = "usann"
    r["feil"] = "Maks forsøk nådd: " + tekst(maks_forsøk)
    returner r
}

# ─── Prosesshandtering ────────────────────────────────────────────────────────

funksjon skriv_pid(pid_fil: tekst) -> heltall {
    la pid = builtin.getpid()
    builtin.fil_skriv(pid_fil, tekst(pid))
    returner pid
}

funksjon les_pid(pid_fil: tekst) -> heltall {
    prøv {
        la innhald = builtin.fil_les(pid_fil)
        returner heltall_fra_tekst(builtin.trim(innhald))
    } fang (e) { returner -1 }
    returner -1
}

funksjon prosess_køyrer(pid: heltall) -> boolsk {
    prøv {
        builtin.kill(pid, 0)
        returner sann
    } fang (e) { returner usann }
    returner usann
}

funksjon mjuk_stopp(pid_fil: tekst) -> heltall {
    la pid = les_pid(pid_fil)
    hvis pid > 0 {
        prøv { builtin.kill(pid, 15) } fang (e) { } // SIGTERM
    }
    returner pid
}

funksjon hard_stopp(pid_fil: tekst) -> heltall {
    la pid = les_pid(pid_fil)
    hvis pid > 0 {
        prøv { builtin.kill(pid, 9) } fang (e) { } // SIGKILL
    }
    returner pid
}

# ─── Miljøvariablar ───────────────────────────────────────────────────────────

funksjon les_env_fil(sti: tekst) -> ordbok_tekst {
    la env: ordbok_tekst = {}
    prøv {
        la innhald = builtin.fil_les(sti)
        la linjer = builtin.split(innhald, "\n")
        la i: heltall = 0
        mens i < lengde(linjer) {
            la linje = builtin.trim(linjer[i])
            hvis linje != "" og ikkje tekst_starter_med(linje, "#") {
                la eq = builtin.index_of(linje, "=")
                hvis eq >= 0 {
                    la nøkkel = builtin.trim(builtin.slice(linje, 0, eq))
                    la verdi  = builtin.trim(builtin.slice(linje, eq + 1, lengde(linje)))
                    // Fjern anførslesteikn
                    hvis tekst_starter_med(verdi, "\"") og tekst_sluttar_med(verdi, "\"") {
                        verdi = builtin.slice(verdi, 1, lengde(verdi) - 1)
                    }
                    env[nøkkel] = verdi
                }
            }
            i = i + 1
        }
    } fang (e) { }
    returner env
}

funksjon skriv_env_fil(sti: tekst, env: ordbok_tekst) -> heltall {
    la linjer: liste<tekst> = []
    la nk = nøkler(env)
    la i: heltall = 0
    mens i < lengde(nk) {
        la k: tekst = nk[i]
        legg_til(linjer, k + "=" + tekst(env[k]))
        i = i + 1
    }
    builtin.fil_skriv(sti, tekst_saman(linjer, "\n") + "\n")
    returner lengde(nk)
}

# ─── Docker-støtte ────────────────────────────────────────────────────────────

funksjon generer_dockerfile(c: ordbok_tekst) -> tekst {
    la namn: tekst = c["namn"]
    la port: tekst = c["port"]
    la arb: tekst  = c["arbeidarar"]
    la innhald = "FROM ubuntu:22.04\n\n" +
        "RUN apt-get update && apt-get install -y --no-install-recommends \\\n" +
        "    ca-certificates curl && rm -rf /var/lib/apt/lists/*\n\n" +
        "WORKDIR /app\n" +
        "COPY . .\n" +
        "COPY bin/nc /usr/local/bin/nc\n" +
        "COPY dist/norscode_native /usr/local/bin/norscode_native\n" +
        "RUN chmod +x /usr/local/bin/nc /usr/local/bin/norscode_native\n\n" +
        "ENV PORT=" + port + "\n" +
        "ENV WORKERS=" + arb + "\n\n" +
        "EXPOSE " + port + "\n\n" +
        "HEALTHCHECK --interval=30s --timeout=10s --retries=3 \\\n" +
        "    CMD curl -f http://localhost:" + port + "/helse || exit 1\n\n" +
        "CMD [\"nc\", \"serve\", \"--port\", \"" + port + "\", \"--workers\", \"" + arb + "\"]\n"
    la sti = tekst(c["mappe"]) + "/Dockerfile"
    builtin.fil_skriv(sti, innhald)
    returner innhald
}

funksjon generer_docker_compose(c: ordbok_tekst, med_db: boolsk) -> tekst {
    la namn: tekst = c["namn"]
    la port: tekst = c["port"]
    la app_blokk = "version: '3.8'\nservices:\n" +
        "  app:\n" +
        "    build: .\n" +
        "    ports:\n" +
        "      - \"" + port + ":" + port + "\"\n" +
        "    env_file: .env\n" +
        "    restart: unless-stopped\n" +
        "    healthcheck:\n" +
        "      test: [\"CMD\", \"curl\", \"-f\", \"http://localhost:" + port + "/helse\"]\n" +
        "      interval: 30s\n" +
        "      timeout: 10s\n" +
        "      retries: 3\n"

    la db_blokk = ""
    hvis med_db {
        db_blokk = "  db:\n" +
            "    image: postgres:16\n" +
            "    environment:\n" +
            "      POSTGRES_DB: " + namn + "\n" +
            "      POSTGRES_USER: app\n" +
            "      POSTGRES_PASSWORD: ${DB_PASSORD}\n" +
            "    volumes:\n" +
            "      - db_data:/var/lib/postgresql/data\n" +
            "    restart: unless-stopped\n\n" +
            "volumes:\n" +
            "  db_data:\n"
    }

    la innhald = app_blokk + db_blokk
    la sti = tekst(c["mappe"]) + "/docker-compose.yml"
    builtin.fil_skriv(sti, innhald)
    returner innhald
}

# ─── Utplasseringssjekk ───────────────────────────────────────────────────────

funksjon sjekk_klar(c: ordbok_tekst) -> liste<tekst> {
    la problem: liste<tekst> = []
    // Sjekk nødvendige filer
    la filer = ["main.no", "std", ".env"]
    la i: heltall = 0
    mens i < lengde(filer) {
        la sti = tekst(c["mappe"]) + "/" + filer[i]
        prøv {
            builtin.fil_les(sti)
        } fang (e) {
            legg_til(problem, "Manglar: " + sti)
        }
        i = i + 1
    }
    // Sjekk port-validitet
    la port = heltall_fra_tekst(tekst(c["port"]))
    hvis port < 1 eller port > 65535 {
        legg_til(problem, "Ugyldig port: " + tekst(c["port"]))
    }
    // Sjekk arbeidar-tal
    la arb = heltall_fra_tekst(tekst(c["arbeidarar"]))
    hvis arb < 1 eller arb > 64 {
        legg_til(problem, "Arbeidarar bør vere 1–64, fekk: " + tekst(c["arbeidarar"]))
    }
    returner problem
}

funksjon statusrapport(c: ordbok_tekst) -> tekst {
    la namn: tekst = c["namn"]
    la pid = les_pid(tekst(c["pid_fil"]))
    la helse_url = "http://" + tekst(c["vert"]) + ":" + tekst(c["port"]) + tekst(c["helse_sti"])
    la helse = helsesjekk(helse_url)
    la linjer: liste<tekst> = []
    legg_til(linjer, "=== " + namn + " statusrapport ===")
    legg_til(linjer, "Port:      " + tekst(c["port"]))
    legg_til(linjer, "Arbeidarar: " + tekst(c["arbeidarar"]))
    legg_til(linjer, "PID:       " + tekst(pid))
    legg_til(linjer, "Helse:     " + tekst(helse["status"]) + " (" + tekst(helse["ms"]) + "ms)")
    returner tekst_saman(linjer, "\n")
}

funksjon produksjonsmønster(c: ordbok_tekst) -> ordbok_tekst {
    returner {
        app: tekst(c["namn"]),
        workers: tekst(c["arbeidarar"]),
        health: tekst(c["helse_sti"]),
        static_dir: tekst(c["mappe"]) + "/static",
        env_file: tekst(c["env_fil"]),
        rollback: "peik current tilbake og restart teneste",
        graceful_timeout: tekst(c["graceful_timeout"]),
        observability: "access-log,error-log,health",
        summary: "workers,health,static,env,rollback,graceful"
    }
}

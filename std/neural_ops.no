# neural_ops.no — kvantiserte nevrale kjerner i rein Norscode

bruk std.tensor som tensor

funksjon _abs(v: heiltall) -> heiltall {
    hvis v < 0 { returner 0 - v }
    returner v
}

funksjon _arbeid_ok(arbeid: heiltall) {
    hvis arbeid < 0 eller arbeid > 20000000 {
        kast "NevralKjerneFeil: arbeidsgrense overskriden"
    }
}

funksjon embedding(tabell: liste_heltall, vocab: heiltall,
                   dimensjon: heiltall, tokens: liste_heltall) {
    hvis vocab <= 0 eller dimensjon <= 0 eller lengde(tabell) != vocab * dimensjon {
        kast "NevralKjerneFeil: ugyldig embeddingtabell"
    }
    _arbeid_ok(lengde(tokens) * dimensjon)
    la ut: liste_heltall = []
    la i: heiltall = 0
    mens i < lengde(tokens) {
        la token = tokens[i]
        hvis token < 0 eller token >= vocab { kast "NevralKjerneFeil: token utanfor vokabular" }
        la d: heiltall = 0
        mens d < dimensjon {
            legg_til(ut, tabell[token * dimensjon + d])
            d = d + 1
        }
        i = i + 1
    }
    returner {"data": ut, "rader": lengde(tokens), "kolonner": dimensjon}
}

funksjon lag_norm(data: liste_heltall, rader: heiltall,
                  kolonner: heiltall, skala: heiltall) {
    hvis rader <= 0 eller kolonner <= 0 eller lengde(data) != rader * kolonner eller skala <= 0 {
        kast "NevralKjerneFeil: ugyldig lag-normalisering"
    }
    _arbeid_ok(rader * kolonner)
    la ut: liste_heltall = []
    la r: heiltall = 0
    mens r < rader {
        la sum: heiltall = 0
        la c: heiltall = 0
        mens c < kolonner {
            sum = sum + data[r * kolonner + c]
            c = c + 1
        }
        la middel = sum / kolonner
        la avvik_sum: heiltall = 0
        c = 0
        mens c < kolonner {
            avvik_sum = avvik_sum + _abs(data[r * kolonner + c] - middel)
            c = c + 1
        }
        la divisor = avvik_sum / kolonner + 1
        c = 0
        mens c < kolonner {
            legg_til(ut, (data[r * kolonner + c] - middel) * skala / divisor)
            c = c + 1
        }
        r = r + 1
    }
    returner {"data": ut, "rader": rader, "kolonner": kolonner}
}

funksjon oppmerksomhet(q: liste_heltall, k: liste_heltall,
                       v: liste_heltall, sekvens: heiltall,
                       dimensjon: heiltall, skala: heiltall) {
    hvis sekvens <= 0 eller dimensjon <= 0 eller skala <= 0 {
        kast "NevralKjerneFeil: ugyldig oppmerksomheitsform"
    }
    hvis lengde(q) != sekvens * dimensjon eller lengde(k) != sekvens * dimensjon eller lengde(v) != sekvens * dimensjon {
        kast "NevralKjerneFeil: feil Q/K/V-lengde"
    }
    _arbeid_ok(sekvens * sekvens * dimensjon)
    la ut: liste_heltall = []
    la qi: heiltall = 0
    mens qi < sekvens {
        la scores: liste_heltall = []
        la minste: heiltall = 0
        la ki: heiltall = 0
        mens ki < sekvens {
            la score: heiltall = 0
            la d: heiltall = 0
            mens d < dimensjon {
                score = score + q[qi * dimensjon + d] * k[ki * dimensjon + d]
                d = d + 1
            }
            score = score / skala
            legg_til(scores, score)
            hvis ki == 0 eller score < minste { minste = score }
            ki = ki + 1
        }
        la vektsum: heiltall = 0
        ki = 0
        mens ki < sekvens {
            scores[ki] = scores[ki] - minste + 1
            vektsum = vektsum + scores[ki]
            ki = ki + 1
        }
        la d2: heiltall = 0
        mens d2 < dimensjon {
            la verdi_sum: heiltall = 0
            ki = 0
            mens ki < sekvens {
                verdi_sum = verdi_sum + scores[ki] * v[ki * dimensjon + d2]
                ki = ki + 1
            }
            legg_til(ut, verdi_sum / vektsum)
            d2 = d2 + 1
        }
        qi = qi + 1
    }
    returner {"data": ut, "rader": sekvens, "kolonner": dimensjon, "normalisering": "positiv-lineaer"}
}

funksjon oppmerksomhet_med_backend(q: liste_heltall, k: liste_heltall,
                                   v: liste_heltall, sekvens: heiltall,
                                   dimensjon: heiltall, skala: heiltall) {
    hvis sekvens <= 0 eller dimensjon <= 0 eller skala <= 0 {
        kast "NevralKjerneFeil: ugyldig oppmerksomheitsform"
    }
    hvis lengde(q) != sekvens * dimensjon eller lengde(k) != sekvens * dimensjon eller lengde(v) != sekvens * dimensjon {
        kast "NevralKjerneFeil: feil Q/K/V-lengde"
    }
    _arbeid_ok(sekvens * sekvens * dimensjon)

    la k_transponert: liste_heltall = []
    la d: heiltall = 0
    mens d < dimensjon {
        la r: heiltall = 0
        mens r < sekvens {
            legg_til(k_transponert, k[r * dimensjon + d])
            r = r + 1
        }
        d = d + 1
    }
    la q_tensor = tensor.fra_liste(q, sekvens, dimensjon)
    la k_tensor = tensor.fra_liste(k_transponert, dimensjon, sekvens)
    la score_resultat = tensor.matmul_med_backend(q_tensor, k_tensor)
    la score_data = score_resultat["tensor"]["data"]
    la vekter: liste_heltall = []
    la qi: heiltall = 0
    mens qi < sekvens {
        la minste: heiltall = 0
        la ki: heiltall = 0
        mens ki < sekvens {
            la score = score_data[qi * sekvens + ki] / skala
            hvis ki == 0 eller score < minste { minste = score }
            ki = ki + 1
        }
        ki = 0
        mens ki < sekvens {
            legg_til(vekter, score_data[qi * sekvens + ki] / skala - minste + 1)
            ki = ki + 1
        }
        qi = qi + 1
    }
    la v_tensor = tensor.fra_liste(v, sekvens, dimensjon)
    la vekt_tensor = tensor.fra_liste(vekter, sekvens, sekvens)
    la ut_resultat = tensor.matmul_med_backend(vekt_tensor, v_tensor)
    la backend = "cpu-fallback"
    la fallback: boolsk = sann
    hvis score_resultat["fallback"] == usann {
        backend = score_resultat["backend"]
        fallback = usann
    }
    hvis ut_resultat["fallback"] == usann {
        backend = ut_resultat["backend"]
        fallback = usann
    }
    returner {"data": ut_resultat["tensor"]["data"], "rader": sekvens,
              "kolonner": dimensjon, "normalisering": "positiv-lineaer",
              "backend": backend, "fallback": fallback}
}

funksjon oppmerksomhet_kausal(q: liste_heiltall, k: liste_heiltall,
                              v: liste_heiltall, sekvens: heiltall,
                              dimensjon: heiltall, skala: heiltall) {
    hvis sekvens <= 0 eller dimensjon <= 0 eller skala <= 0 { kast "NevralKjerneFeil: ugyldig kausal oppmerksomheitsform" }
    hvis lengde(q) != sekvens * dimensjon eller lengde(k) != sekvens * dimensjon eller lengde(v) != sekvens * dimensjon { kast "NevralKjerneFeil: feil kausal Q/K/V-lengde" }
    _arbeid_ok(sekvens * sekvens * dimensjon)
    la ut: liste_heiltall = []
    la qi: heiltall = 0
    mens qi < sekvens {
        la scores: liste_heiltall = []
        la minste: heiltall = 0
        la ki: heiltall = 0
        mens ki <= qi {
            la score: heiltall = 0
            la d: heiltall = 0
            mens d < dimensjon {
                score = score + q[qi * dimensjon + d] * k[ki * dimensjon + d]
                d = d + 1
            }
            score = score / skala
            legg_til(scores, score)
            hvis ki == 0 eller score < minste { minste = score }
            ki = ki + 1
        }
        la vektsum: heiltall = 0
        ki = 0
        mens ki < lengde(scores) {
            scores[ki] = scores[ki] - minste + 1
            vektsum = vektsum + scores[ki]
            ki = ki + 1
        }
        la d2: heiltall = 0
        mens d2 < dimensjon {
            la verdi_sum: heiltall = 0
            ki = 0
            mens ki < lengde(scores) {
                verdi_sum = verdi_sum + scores[ki] * v[ki * dimensjon + d2]
                ki = ki + 1
            }
            legg_til(ut, verdi_sum / vektsum)
            d2 = d2 + 1
        }
        qi = qi + 1
    }
    returner {"data": ut, "rader": sekvens, "kolonner": dimensjon, "normalisering": "kausal-positiv-lineaer"}
}

funksjon conv2d(data: liste_heltall, hoyde: heiltall,
                bredde: heiltall, kanaler: heiltall,
                kjerner: liste_heltall, ut_kanaler: heiltall,
                k_hoyde: heiltall, k_bredde: heiltall,
                bias: liste_heltall, stride: heiltall,
                padding: heiltall, divisor: heiltall) {
    hvis hoyde <= 0 eller bredde <= 0 eller kanaler <= 0 eller ut_kanaler <= 0 eller k_hoyde <= 0 eller k_bredde <= 0 eller stride <= 0 eller padding < 0 eller divisor <= 0 {
        kast "NevralKjerneFeil: ugyldig conv2d-form"
    }
    hvis lengde(data) != hoyde * bredde * kanaler { kast "NevralKjerneFeil: feil bildedata" }
    hvis lengde(kjerner) != ut_kanaler * k_hoyde * k_bredde * kanaler { kast "NevralKjerneFeil: feil kjernedata" }
    hvis lengde(bias) != ut_kanaler { kast "NevralKjerneFeil: feil conv-bias" }
    la ut_h = (hoyde + 2 * padding - k_hoyde) / stride + 1
    la ut_b = (bredde + 2 * padding - k_bredde) / stride + 1
    hvis ut_h <= 0 eller ut_b <= 0 { kast "NevralKjerneFeil: tom conv2d-output" }
    _arbeid_ok(ut_h * ut_b * ut_kanaler * k_hoyde * k_bredde * kanaler)
    la ut: liste_heltall = []
    la oy: heiltall = 0
    mens oy < ut_h {
        la ox: heiltall = 0
        mens ox < ut_b {
            la oc: heiltall = 0
            mens oc < ut_kanaler {
                la sum = bias[oc]
                la ky: heiltall = 0
                mens ky < k_hoyde {
                    la iy = oy * stride + ky - padding
                    la kx: heiltall = 0
                    mens kx < k_bredde {
                        la ix = ox * stride + kx - padding
                        hvis iy >= 0 og iy < hoyde og ix >= 0 og ix < bredde {
                            la ic: heiltall = 0
                            mens ic < kanaler {
                                la data_idx = (iy * bredde + ix) * kanaler + ic
                                la k_idx = ((oc * k_hoyde + ky) * k_bredde + kx) * kanaler + ic
                                sum = sum + data[data_idx] * kjerner[k_idx]
                                ic = ic + 1
                            }
                        }
                        kx = kx + 1
                    }
                    ky = ky + 1
                }
                legg_til(ut, sum / divisor)
                oc = oc + 1
            }
            ox = ox + 1
        }
        oy = oy + 1
    }
    returner {"data": ut, "hoyde": ut_h, "bredde": ut_b, "kanaler": ut_kanaler}
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "eksperimentell", "abi": "norscode.neural-ops.q8.v1", "dekning": "embedding, lag-normalisering, full og kausal positiv lineær oppmerksomheit, tensor-backend med Metal/CPU-fallback og kvantisert conv2d med arbeidsgrense"}
}

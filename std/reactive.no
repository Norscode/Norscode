bruk std.html som html

funksjon data_attr(nøkkel: tekst, verdi: tekst) -> tekst {
    returner html.attr("data-" + nøkkel, verdi)
}

funksjon state_attr(nøkkel: tekst, verdi: tekst) -> tekst {
    returner data_attr("state-" + nøkkel, verdi)
}

funksjon bind_text(nøkkel: tekst) -> tekst {
    returner data_attr("bind-text", nøkkel)
}

funksjon bind_value(nøkkel: tekst) -> tekst {
    returner data_attr("bind-value", nøkkel)
}

funksjon bind_checked(nøkkel: tekst) -> tekst {
    returner data_attr("bind-checked", nøkkel)
}

funksjon event_attr(hendelse: tekst, handling: tekst) -> tekst {
    returner data_attr("on-" + hendelse, handling)
}

funksjon click_attr(handling: tekst) -> tekst {
    returner event_attr("click", handling)
}

funksjon input_attr(handling: tekst) -> tekst {
    returner event_attr("input", handling)
}

funksjon reactive_root(navn: tekst, innhold: tekst) -> tekst {
    returner html.section(
        html.class_attr("reactive-root") + data_attr("reactive", navn),
        innhold
    )
}

funksjon reactive_view(navn: tekst, tilstand: tekst, innhold: tekst) -> tekst {
    returner html.div(
        html.class_attr("reactive-view")
            + data_attr("reactive", navn)
            + state_attr("view", tilstand),
        innhold
    )
}

funksjon bind_panel(tittel: tekst, innhold: tekst, bind_nøkkel: tekst, state_verdi: tekst) -> tekst {
    returner html.section(
        html.class_attr("state-panel") + state_attr(bind_nøkkel, state_verdi),
        html.h2("", html.escape(tittel))
            + html.div(html.class_attr("state-panel__body"), innhold)
    )
}

funksjon vis_hvis(vises: bool, innhold: tekst) -> tekst {
    hvis (vises) {
        returner innhold
    }
    returner ""
}

funksjon skjul_hvis(vises: bool, innhold: tekst) -> tekst {
    hvis (vises) {
        returner ""
    }
    returner innhold
}

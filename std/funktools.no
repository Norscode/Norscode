# funktools.no — Funksjonelle programmeringsverktøy
# Python: functools (reduce, lru_cache, partial, cache, wraps, total_ordering)
#
# Sidan Norscode ikkje har lambdaer eller førsteklasses funksjonar direkte,
# brukar vi builtin.ncb_call_fn("modulnamn.funksjonnamn", args) for
# å sende funksjonar som argument.
#
# Bruk:
#   bruk std.funktools som ft
#
#   # Reduser med sum
#   la total = ft.reduser_tall([1,2,3,4,5], "math.pluss", 0)
#
#   # Memoizer (ordbok-basert cache)
#   la cache: ordbok_tekst = ft.ny_cache()
#   la nøkkel = ft.cache_nøkkel_tall([10, 3])
#   hvis (ikkje ft.er_cachet(cache, nøkkel)) {
#       ft.set_cache(cache, nøkkel, tekst_fra_heltall(berekn(10, 3)))
#   }
#   la resultat = ft.hent_cache(cache, nøkkel)

# ─── Reduser ──────────────────────────────────────────────────────────────────
# Tilsvarer Python: functools.reduce(f, iterable, initializer)
# f er "modul.funksjon"-namn som tek to heltall-argument.

funksjon reduser_tall(l: liste_heltall, fn_namn: tekst, start: heltall) -> heltall {
    la akkumulator: heltall = start
    la i: heltall = 0
    mens (i < lengde(l)) {
        la args: ordbok_tekst = {}
        args["a"] = tekst_fra_heltall(akkumulator)
        args["b"] = tekst_fra_heltall(l[i])
        la resultat = builtin.ncb_call_fn(fn_namn, args)
        akkumulator = builtin.heltall_fra_tekst(tekst(resultat))
        i = i + 1
    }
    returner akkumulator
}

funksjon reduser_tekst(l: liste_tekst, fn_namn: tekst, start: tekst) -> tekst {
    la akkumulator: tekst = start
    la i: heltall = 0
    mens (i < lengde(l)) {
        la args: ordbok_tekst = {}
        args["a"] = akkumulator
        args["b"] = l[i]
        la resultat = builtin.ncb_call_fn(fn_namn, args)
        akkumulator = tekst(resultat)
        i = i + 1
    }
    returner akkumulator
}

# Reduser utan startverdi (brukar første element)
funksjon reduser_tall_1(l: liste_heltall, fn_namn: tekst) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    returner reduser_tall(builtin.slice(l, 1, n), fn_namn, l[0])
}

# ─── Kart (map) ────────────────────────────────────────────────────────────────
# Tilsvarer Python: list(map(f, iterable))

funksjon kart_tall(l: liste_heltall, fn_namn: tekst) -> liste_heltall {
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la args: ordbok_tekst = {}
        args["x"] = tekst_fra_heltall(l[i])
        la resultat = builtin.ncb_call_fn(fn_namn, args)
        legg_til(ut, builtin.heltall_fra_tekst(tekst(resultat)))
        i = i + 1
    }
    returner ut
}

funksjon kart_tekst(l: liste_tekst, fn_namn: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la args: ordbok_tekst = {}
        args["x"] = l[i]
        la resultat = builtin.ncb_call_fn(fn_namn, args)
        legg_til(ut, tekst(resultat))
        i = i + 1
    }
    returner ut
}

# ─── Filter ───────────────────────────────────────────────────────────────────
# fn_namn returnerer "sann" eller "usann" (tekst)

funksjon filtrer_tall(l: liste_heltall, fn_namn: tekst) -> liste_heltall {
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la args: ordbok_tekst = {}
        args["x"] = tekst_fra_heltall(l[i])
        la resultat: tekst = tekst(builtin.ncb_call_fn(fn_namn, args))
        hvis (resultat == "sann" eller resultat == "true" eller resultat == "1") {
            legg_til(ut, l[i])
        }
        i = i + 1
    }
    returner ut
}

funksjon filtrer_tekst(l: liste_tekst, fn_namn: tekst) -> liste_tekst {
    la ut: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la args: ordbok_tekst = {}
        args["x"] = l[i]
        la resultat: tekst = tekst(builtin.ncb_call_fn(fn_namn, args))
        hvis (resultat == "sann" eller resultat == "true" eller resultat == "1") {
            legg_til(ut, l[i])
        }
        i = i + 1
    }
    returner ut
}

# ─── Memoize / Cache ──────────────────────────────────────────────────────────
# Ordbok-basert cache. Nøkkel = tekst-representasjon av argument.

funksjon ny_cache() -> ordbok_tekst {
    la c: ordbok_tekst = {}
    c["_treff"] = "0"
    c["_bom"]   = "0"
    c["_storleik"] = "0"
    returner c
}

funksjon cache_nøkkel_tall(args: liste_heltall) -> tekst {
    la delar: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(args)) { legg_til(delar, tekst_fra_heltall(args[i]))  i = i + 1 }
    returner builtin.join(delar, ":")
}

funksjon cache_nøkkel_tekst(args: liste_tekst) -> tekst {
    returner builtin.join(args, ":")
}

funksjon er_cachet(c: ordbok_tekst, nøkkel: tekst) -> bool {
    returner har_nokkel(c, "v:" + nøkkel)
}

funksjon hent_cache(c: ordbok_tekst, nøkkel: tekst) -> tekst {
    la full_nøkkel: tekst = "v:" + nøkkel
    hvis (har_nokkel(c, full_nøkkel)) {
        la treff: heltall = builtin.heltall_fra_tekst(c["_treff"]) + 1
        c["_treff"] = tekst_fra_heltall(treff)
        returner c[full_nøkkel]
    }
    la bom: heltall = builtin.heltall_fra_tekst(c["_bom"]) + 1
    c["_bom"] = tekst_fra_heltall(bom)
    returner ""
}

funksjon set_cache(c: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> heltall {
    la full_nøkkel: tekst = "v:" + nøkkel
    hvis (ikkje har_nokkel(c, full_nøkkel)) {
        la st: heltall = builtin.heltall_fra_tekst(c["_storleik"]) + 1
        c["_storleik"] = tekst_fra_heltall(st)
    }
    c[full_nøkkel] = verdi
    returner builtin.heltall_fra_tekst(c["_storleik"])
}

funksjon slett_cache_nøkkel(c: ordbok_tekst, nøkkel: tekst) -> heltall {
    la full_nøkkel: tekst = "v:" + nøkkel
    hvis (har_nokkel(c, full_nøkkel)) {
        fjern_nokkel(c, full_nøkkel)
        la st: heltall = builtin.heltall_fra_tekst(c["_storleik"]) - 1
        c["_storleik"] = tekst_fra_heltall(st)
    }
    returner builtin.heltall_fra_tekst(c["_storleik"])
}

funksjon tøm_cache(c: ordbok_tekst) -> heltall {
    la nkl = builtin.nøkler(c)
    la i: heltall = 0
    mens (i < lengde(nkl)) {
        la k: tekst = nkl[i]
        hvis (tekst_starter_med(k, "v:")) { fjern_nokkel(c, k) }
        i = i + 1
    }
    c["_treff"] = "0"
    c["_bom"]   = "0"
    c["_storleik"] = "0"
    returner 0
}

funksjon cache_statistikk(c: ordbok_tekst) -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["treff"]    = c["_treff"]
    s["bom"]      = c["_bom"]
    s["storleik"] = c["_storleik"]
    la total: heltall = builtin.heltall_fra_tekst(c["_treff"]) + builtin.heltall_fra_tekst(c["_bom"])
    hvis (total > 0) {
        s["treff_rate"] = tekst_fra_heltall(builtin.heltall_fra_tekst(c["_treff"]) * 100 / total) + "%"
    } ellers {
        s["treff_rate"] = "0%"
    }
    returner s
}

# ─── LRU Cache (størrelsesbegrensa) ───────────────────────────────────────────
# Representasjon: flat ordbok_tekst
#   "v:nøkkel" → verdi
#   "o:nøkkel" → orden (heltall, aukande for LRU)
#   "_teller"  → neste orden-verdi
#   "_maks"    → maks storleik
#   "_storleik" → gjeldande storleik

funksjon ny_lru_cache(maks_storleik: heltall) -> ordbok_tekst {
    la c: ordbok_tekst = {}
    c["_maks"]     = tekst_fra_heltall(maks_storleik)
    c["_storleik"] = "0"
    c["_teller"]   = "0"
    returner c
}

funksjon lru_hent(c: ordbok_tekst, nøkkel: tekst) -> tekst {
    la vk: tekst = "v:" + nøkkel
    la ok: tekst = "o:" + nøkkel
    hvis (ikkje har_nokkel(c, vk)) { returner "" }
    # Oppdater LRU-orden
    la t: heltall = builtin.heltall_fra_tekst(c["_teller"]) + 1
    c["_teller"] = tekst_fra_heltall(t)
    c[ok] = tekst_fra_heltall(t)
    returner c[vk]
}

funksjon lru_set(c: ordbok_tekst, nøkkel: tekst, verdi: tekst) -> heltall {
    la vk: tekst = "v:" + nøkkel
    la ok: tekst = "o:" + nøkkel
    la maks: heltall = builtin.heltall_fra_tekst(c["_maks"])
    la st: heltall = builtin.heltall_fra_tekst(c["_storleik"])

    # Viss nøkkel finst allereie, berre oppdater
    hvis (har_nokkel(c, vk)) {
        c[vk] = verdi
        la t: heltall = builtin.heltall_fra_tekst(c["_teller"]) + 1
        c["_teller"] = tekst_fra_heltall(t)
        c[ok] = tekst_fra_heltall(t)
        returner st
    }

    # Viss full: fjern minst nyleg brukt (lågast orden-verdi)
    hvis (st >= maks) {
        la nkl = builtin.nøkler(c)
        la min_orden: heltall = 2147483647
        la min_nøkkel: tekst = ""
        la i: heltall = 0
        mens (i < lengde(nkl)) {
            la k: tekst = nkl[i]
            hvis (tekst_starter_med(k, "o:")) {
                la orden: heltall = builtin.heltall_fra_tekst(c[k])
                hvis (orden < min_orden) {
                    min_orden = orden
                    min_nøkkel = builtin.slice(k, 2, lengde(builtin.split(k, "")))
                }
            }
            i = i + 1
        }
        hvis (min_nøkkel != "") {
            fjern_nokkel(c, "v:" + min_nøkkel)
            fjern_nokkel(c, "o:" + min_nøkkel)
            st = st - 1
        }
    }

    la t: heltall = builtin.heltall_fra_tekst(c["_teller"]) + 1
    c["_teller"] = tekst_fra_heltall(t)
    c[vk] = verdi
    c[ok] = tekst_fra_heltall(t)
    c["_storleik"] = tekst_fra_heltall(st + 1)
    returner st + 1
}

funksjon lru_er_cachet(c: ordbok_tekst, nøkkel: tekst) -> bool {
    returner har_nokkel(c, "v:" + nøkkel)
}

# ─── Compose og pipe ──────────────────────────────────────────────────────────
# Kjeder funksjonskall: compose([f, g, h], x) = f(g(h(x)))

funksjon compose_tall(funksjonar: liste_tekst, x: heltall) -> heltall {
    la n: heltall = lengde(funksjonar)
    la v: heltall = x
    la i: heltall = n - 1
    mens (i >= 0) {
        la args: ordbok_tekst = {}
        args["x"] = tekst_fra_heltall(v)
        la res = builtin.ncb_call_fn(funksjonar[i], args)
        v = builtin.heltall_fra_tekst(tekst(res))
        i = i - 1
    }
    returner v
}

# pipe([f, g, h], x) = h(g(f(x)))
funksjon pipe_tall(funksjonar: liste_tekst, x: heltall) -> heltall {
    la n: heltall = lengde(funksjonar)
    la v: heltall = x
    la i: heltall = 0
    mens (i < n) {
        la args: ordbok_tekst = {}
        args["x"] = tekst_fra_heltall(v)
        la res = builtin.ncb_call_fn(funksjonar[i], args)
        v = builtin.heltall_fra_tekst(tekst(res))
        i = i + 1
    }
    returner v
}

# ─── Partial (simulert) ───────────────────────────────────────────────────────
# Sidan Norscode ikkje har closures, lagrar vi "bunde" argument i ein ordbok.
# partial_ny lagrar fn_namn + bundne argument.
# partial_kall_tall legg til ekstra argument og køyrer.

funksjon partial_ny(fn_namn: tekst, bundne_args: ordbok_tekst) -> ordbok_tekst {
    la p: ordbok_tekst = {}
    p["_fn"] = fn_namn
    la nkl = builtin.nøkler(bundne_args)
    la i: heltall = 0
    mens (i < lengde(nkl)) {
        la k: tekst = nkl[i]
        p[k] = bundne_args[k]
        i = i + 1
    }
    returner p
}

funksjon partial_kall(p: ordbok_tekst, ekstra_args: ordbok_tekst) -> tekst {
    la fn_namn: tekst = p["_fn"]
    la alle_args: ordbok_tekst = {}
    # Kopier bundne argument
    la nkl = builtin.nøkler(p)
    la i: heltall = 0
    mens (i < lengde(nkl)) {
        la k: tekst = nkl[i]
        hvis (k != "_fn") { alle_args[k] = p[k] }
        i = i + 1
    }
    # Legg til ekstra argument (overskriv om same nøkkel)
    la nkl2 = builtin.nøkler(ekstra_args)
    i = 0
    mens (i < lengde(nkl2)) {
        alle_args[nkl2[i]] = ekstra_args[nkl2[i]]
        i = i + 1
    }
    la res = builtin.ncb_call_fn(fn_namn, alle_args)
    returner tekst(res)
}

# ─── total_ordering (samanliknings-mønster) ───────────────────────────────────
# Gitt ein cmp-funksjon (returnerer -1, 0, 1) utled alle samanlikningar.
# Bruk: la ord = ft.cmp_resultat(cmp_fn, a, b)

funksjon cmp_er_lik(cmp_resultat: heltall) -> bool  {
    returner cmp_resultat == 0
}
funksjon cmp_er_mindre(cmp_resultat: heltall) -> bool  {
    returner cmp_resultat < 0
}
funksjon cmp_er_større(cmp_resultat: heltall) -> bool  {
    returner cmp_resultat > 0
}
funksjon cmp_er_maks(cmp_resultat: heltall) -> bool  {
    returner cmp_resultat >= 0
}
funksjon cmp_er_min(cmp_resultat: heltall) -> bool  {
    returner cmp_resultat <= 0
}

# ─── wraps / update_wrapper (metadata-mønster) ────────────────────────────────
# Python: @wraps(original) dekorerer ein innpakkingsfunksjon med originalen sine
# metadata. I Norscode lagrar vi metadata i ein ordbok_tekst.

funksjon ny_fn_info(namn: tekst, modul: tekst, dok: tekst) -> ordbok_tekst {
    la info: ordbok_tekst = {}
    info["__name__"] = namn
    info["__module__"] = modul
    info["__doc__"] = dok
    info["__wrapped__"] = ""
    returner info
}

funksjon wraps(original_info: ordbok_tekst, innpakking_info: ordbok_tekst) -> ordbok_tekst {
    # Kopier metadata frå original til innpakking
    innpakking_info["__name__"] = original_info["__name__"]
    innpakking_info["__doc__"] = original_info["__doc__"]
    innpakking_info["__wrapped__"] = original_info["__name__"]
    returner innpakking_info
}

funksjon fn_namn(info: ordbok_tekst) -> tekst {
    hvis (har_nokkel(info, "__name__")) { returner info["__name__"] }
    returner "ukjent"
}

funksjon fn_dok(info: ordbok_tekst) -> tekst {
    hvis (har_nokkel(info, "__doc__")) { returner info["__doc__"] }
    returner ""
}

# ─── singledispatch (typebasert dispatch) ─────────────────────────────────────
# Simulerer Python @singledispatch — vel funksjon basert på type-tekst.
# Registrer type-funksjon-par, kall dispatch for å velje rett.

funksjon ny_dispatch() -> ordbok_tekst {
    la d: ordbok_tekst = {}
    d["__default__"] = ""
    returner d
}

# Registrer ein funksjon for ein type (type_namn = "heltall","tekst","liste" osv.)
funksjon dispatch_registrer(d: ordbok_tekst, type_namn: tekst, fn_namn: tekst) -> heltall {
    d[type_namn] = fn_namn
    returner 0
}

# Set standardfunksjon
funksjon dispatch_standard(d: ordbok_tekst, fn_namn: tekst) -> heltall {
    d["__default__"] = fn_namn
    returner 0
}

# Finn funksjonnamn for ein type
funksjon dispatch_finn(d: ordbok_tekst, type_namn: tekst) -> tekst {
    hvis (har_nokkel(d, type_namn)) { returner d[type_namn] }
    returner d["__default__"]
}

# Kall dispatch med heltall-argument
funksjon dispatch_tall(d: ordbok_tekst, type_namn: tekst, verdi: heltall) -> tekst {
    la fn: tekst = dispatch_finn(d, type_namn)
    hvis (fn == "") { kast "dispatch: ingen funksjon for type " + type_namn }
    la args: ordbok_tekst = {}
    args["verdi"] = tekst_fra_heltall(verdi)
    returner builtin.ncb_call_fn(fn, args)
}

# Kall dispatch med tekst-argument
funksjon dispatch_tekst(d: ordbok_tekst, type_namn: tekst, verdi: tekst) -> tekst {
    la fn: tekst = dispatch_finn(d, type_namn)
    hvis (fn == "") { kast "dispatch: ingen funksjon for type " + type_namn }
    la args: ordbok_tekst = {}
    args["verdi"] = verdi
    returner builtin.ncb_call_fn(fn, args)
}

# ─── accumulate (kumulativt reduser, returnerer heile sekvensen) ──────────────
# Python: itertools.accumulate (men plassert her sidan det liknar functools)

funksjon accumulate_tall(l: liste_heltall, fn_namn: tekst) -> liste_heltall {
    la n: heltall = lengde(l)
    la ut: liste_heltall = []
    hvis (n == 0) { returner ut }
    legg_til(ut, l[0])
    la i: heltall = 1
    mens (i < n) {
        la args: ordbok_tekst = {}
        args["a"] = tekst_fra_heltall(ut[i - 1])
        args["b"] = tekst_fra_heltall(l[i])
        la res: tekst = builtin.ncb_call_fn(fn_namn, args)
        legg_til(ut, builtin.heltall_fra_tekst(res))
        i = i + 1
    }
    returner ut
}

funksjon accumulate_sum(l: liste_heltall) -> liste_heltall {
    la n: heltall = lengde(l)
    la ut: liste_heltall = []
    hvis (n == 0) { returner ut }
    legg_til(ut, l[0])
    la i: heltall = 1
    mens (i < n) {
        legg_til(ut, ut[i - 1] + l[i])
        i = i + 1
    }
    returner ut
}

funksjon accumulate_maks(l: liste_heltall) -> liste_heltall {
    la n: heltall = lengde(l)
    la ut: liste_heltall = []
    hvis (n == 0) { returner ut }
    legg_til(ut, l[0])
    la i: heltall = 1
    mens (i < n) {
        la prev: heltall = ut[i - 1]
        la ny_v: heltall = l[i]
        hvis (ny_v > prev) { legg_til(ut, ny_v) }
        ellers { legg_til(ut, prev) }
        i = i + 1
    }
    returner ut
}

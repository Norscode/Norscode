# Prioritetskø standardbibliotek (min-heap)
# Python: heapq
#
# Ein prioritetskø er ei liste_heltall der lista er organisert som ein min-heap.
# Minste element er alltid ved indeks 0.
# For maks-heap: inverter verdiane (legg inn -verdi, ta ut -verdi).
#
# Bruk:
#   bruk std.prioritet som pq
#   la h = pq.ny()
#   pq.dytt(h, 5)
#   pq.dytt(h, 2)
#   pq.dytt(h, 8)
#   la min_verdi = pq.pop(h)   # => 2

# ─── Intern heap-hjelp ────────────────────────────────────────────────────────

funksjon _foreldre(i: heltall) -> heltall {
    returner (i - 1) / 2
}

funksjon _venstre_barn(i: heltall) -> heltall {
    returner 2 * i + 1
}

funksjon _høyre_barn(i: heltall) -> heltall {
    returner 2 * i + 2
}

funksjon _bytt(h: liste_heltall, i: heltall, j: heltall) -> heltall {
    la tmp: heltall = h[i]
    h[i] = h[j]
    h[j] = tmp
    returner 0
}

funksjon _boble_opp(h: liste_heltall, i: heltall) -> heltall {
    mens (i > 0) {
        la p: heltall = _foreldre(i)
        hvis (h[i] < h[p]) {
            _bytt(h, i, p)
            i = p
        } ellers {
            returner i
        }
    }
    returner 0
}

funksjon _boble_ned(h: liste_heltall, i: heltall) -> heltall {
    la n: heltall = lengde(h)
    mens (sann) {
        la minst: heltall = i
        la venstre: heltall = _venstre_barn(i)
        la høyre: heltall = _høyre_barn(i)
        hvis (venstre < n og h[venstre] < h[minst]) {
            minst = venstre
        }
        hvis (høyre < n og h[høyre] < h[minst]) {
            minst = høyre
        }
        hvis (minst == i) { returner i }
        _bytt(h, i, minst)
        i = minst
    }
    returner i
}

# ─── Offentlege funksjonar ────────────────────────────────────────────────────

funksjon ny() -> liste_heltall {
    returner []
}

# Dytt ein verdi inn i heapen
funksjon dytt(h: liste_heltall, verdi: heltall) -> heltall {
    legg_til(h, verdi)
    _boble_opp(h, lengde(h) - 1)
    returner lengde(h)
}

# Ta ut og returner minste verdi
funksjon pop(h: liste_heltall) -> heltall {
    la n: heltall = lengde(h)
    hvis (n == 0) { returner 0 }
    la min_v: heltall = h[0]
    h[0] = h[n - 1]
    fjern_indeks(h, n - 1)
    hvis (lengde(h) > 0) {
        _boble_ned(h, 0)
    }
    returner min_v
}

# Sjå på minste utan å ta det ut
funksjon kikk(h: liste_heltall) -> heltall {
    hvis (lengde(h) == 0) { returner 0 }
    returner h[0]
}

funksjon er_tom(h: liste_heltall) -> bool {
    returner lengde(h) == 0
}

funksjon storleik(h: liste_heltall) -> heltall {
    returner lengde(h)
}

# Bygg heap frå eksisterande liste (heapify, O(n))
funksjon frå_liste(l: liste_heltall) -> liste_heltall {
    la h: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        legg_til(h, l[i])
        i = i + 1
    }
    # Heapify nedanfrå
    la start: heltall = (lengde(h) - 2) / 2
    mens (start >= 0) {
        _boble_ned(h, start)
        start = start - 1
    }
    returner h
}

# Heap-sort: returner sortert liste (øydelegg heapen)
funksjon heap_sort(l: liste_heltall) -> liste_heltall {
    la h = frå_liste(l)
    la resultat: liste_heltall = []
    mens (ikkje er_tom(h)) {
        legg_til(resultat, pop(h))
    }
    returner resultat
}

# ─── Prioritetskø med nøkkel:verdi-par ───────────────────────────────────────
# Lagrar "prioritet:verdi" som tekst for å knytte data til prioritet.

funksjon pq_dytt(h: liste_tekst, prioritet: heltall, verdi: tekst) -> heltall {
    # Bruk null-padding av prioritet for leksikografisk sortering
    la p_str: tekst = tekst_fra_heltall(prioritet + 1000000)
    legg_til(h, p_str + ":" + verdi)
    # Boble opp (manuelt for tekst-heap)
    la i: heltall = lengde(h) - 1
    mens (i > 0) {
        la p: heltall = _foreldre(i)
        hvis (h[i] < h[p]) {
            la tmp: tekst = h[i]
            h[i] = h[p]
            h[p] = tmp
            i = p
        } ellers {
            returner lengde(h)
        }
    }
    returner lengde(h)
}

funksjon pq_pop_verdi(h: liste_tekst) -> tekst {
    la n: heltall = lengde(h)
    hvis (n == 0) { returner "" }
    la topp: tekst = h[0]
    h[0] = h[n - 1]
    fjern_indeks(h, n - 1)
    # Boble ned
    la i: heltall = 0
    mens (sann) {
        la minst: heltall = i
        la v: heltall = _venstre_barn(i)
        la hy: heltall = _høyre_barn(i)
        hvis (v < lengde(h) og h[v] < h[minst]) { minst = v }
        hvis (hy < lengde(h) og h[hy] < h[minst]) { minst = hy }
        hvis (minst == i) { returner builtin.slice(topp, 8, lengde(topp)) }
        la tmp: tekst = h[i]
        h[i] = h[minst]
        h[minst] = tmp
        i = minst
    }
    returner builtin.slice(topp, 8, lengde(topp))
}

funksjon pq_er_tom(h: liste_tekst) -> bool {
    returner lengde(h) == 0
}

# quick3.no - trygg Quick3-integrasjonsflate for Helpdesk

bruk std.http som http
bruk std.tid som tid
bruk std.observability som observability

funksjon ny(base_url: tekst, api_token: tekst) -> ordbok_tekst {
    hvis base_url == "" { kast "Quick3Feil: base URL manglar" }
    hvis ikkje builtin.starts_with(base_url, "https://") { kast "Quick3Feil: base URL må bruke HTTPS" }
    hvis api_token == "" { kast "Quick3Feil: API-token manglar" }
    returner {"schema": "norscode-quick3-v1", "base_url": base_url,
              "api_token": api_token, "timeout_ms": "10000", "max_retries": "3",
              "retry_base_ms": "250", "next_allowed_ms": "0"}
}

funksjon _url(c: ordbok_tekst, path: tekst) -> tekst {
    hvis builtin.ends_with(c["base_url"], "/") og builtin.starts_with(path, "/") {
        returner builtin.slice(c["base_url"], 0, lengde(c["base_url"]) - 1) + path
    }
    hvis ikkje builtin.ends_with(c["base_url"], "/") og ikkje builtin.starts_with(path, "/") {
        returner c["base_url"] + "/" + path
    }
    returner c["base_url"] + path
}

funksjon retrybar(status: heiltall) -> boolsk {
    returner status == 408 eller status == 425 eller status == 429 eller status >= 500
}

funksjon retry_plan(status: heiltall, forsøk: heiltall, timeout_ms: heiltall) -> ordbok_tekst {
    hvis forsøk < 1 { forsøk = 1 }
    hvis timeout_ms < 1 { timeout_ms = 1 }
    returner {"status": tekst_fra_heltall(status), "attempts": tekst_fra_heltall(forsøk),
              "timeout_ms": tekst_fra_heltall(timeout_ms), "retry": tekst(retrybar(status)),
              "schema": "norscode-quick3-retry-plan-v1"}
}

funksjon request(c: ordbok_tekst, metode: tekst, path: tekst,
                 body: tekst, no_ms: heiltall) -> ordbok_tekst {
    la headers: ordbok_tekst = {"Authorization": "Bearer " + c["api_token"],
                                "Accept": "application/json",
                                "Content-Type": "application/json"}
    la maks = heltall_fra_tekst(c["max_retries"])
    la attempt: heiltall = 0
    la siste: tekst = ""
    la siste_status: heiltall = 0
    mens attempt <= maks {
        la no = tid.no_ms()
        la tillatt = heltall_fra_tekst(c["next_allowed_ms"])
        hvis no < tillatt { tid.sov(tillatt - no) }
        la response = http.request_full(metode, _url(c, path), headers, {}, body,
                                        heltall_fra_tekst(c["timeout_ms"]))
        siste = response
        siste_status = http.response_status(response)
        c["next_allowed_ms"] = tekst_fra_heltall(tid.no_ms() + 50)
        hvis ikkje retrybar(siste_status) eller attempt == maks {
            la resultat: ordbok_tekst = {"status": tekst_fra_heltall(siste_status), "body": http.response_text(siste),
                      "response": siste, "attempts": tekst_fra_heltall(attempt + 1),
                      "ok": tekst(http.response_ok(siste)), "schema": "norscode-quick3-response-v1"}
            prøv { resultat["json"] = builtin.json_parse_raw(http.response_text(siste)) } fang (e) { }
            returner resultat
        }
        la pause = heltall_fra_tekst(c["retry_base_ms"]) * (attempt + 1)
        tid.sov(pause)
        attempt = attempt + 1
    }
    la resultat: ordbok_tekst = {"status": tekst_fra_heltall(siste_status), "body": http.response_text(siste),
              "response": siste, "attempts": tekst_fra_heltall(attempt),
              "ok": "usann", "schema": "norscode-quick3-response-v1"}
    prøv { resultat["json"] = builtin.json_parse_raw(http.response_text(siste)) } fang (e) { }
    returner resultat
}

funksjon get(c: ordbok_tekst, path: tekst, no_ms: heiltall) -> ordbok_tekst {
    returner request(c, "GET", path, "", no_ms)
}

funksjon post(c: ordbok_tekst, path: tekst, body: tekst, no_ms: heiltall) -> ordbok_tekst {
    returner request(c, "POST", path, body, no_ms)
}

funksjon put(c: ordbok_tekst, path: tekst, body: tekst, no_ms: heiltall) -> ordbok_tekst {
    returner request(c, "PUT", path, body, no_ms)
}

funksjon patch(c: ordbok_tekst, path: tekst, body: tekst, no_ms: heiltall) -> ordbok_tekst {
    returner request(c, "PATCH", path, body, no_ms)
}

funksjon kartlegg_koyreto(data: ordbok_tekst) -> ordbok_tekst {
    hvis ikkje har_nokkel(data, "id") eller tekst(data["id"]) == "" { kast "Quick3Feil: kjøretøy manglar id" }
    hvis ikkje har_nokkel(data, "vin") eller tekst(data["vin"]) == "" { kast "Quick3Feil: kjøretøy manglar VIN" }
    hvis ikkje har_nokkel(data, "model") eller tekst(data["model"]) == "" { kast "Quick3Feil: kjøretøy manglar modell" }
    returner {"schema": "norscode-helpdesk-vehicle-v1",
              "id": tekst(data["id"]), "vin": tekst(data["vin"]),
              "registration": tekst(data["registration"]),
              "model": tekst(data["model"]), "make": tekst(data["make"]),
              "raw": builtin.json_stringify(data)}
}

funksjon kartlegg_ticket(data: ordbok_tekst) -> ordbok_tekst {
    hvis ikkje har_nokkel(data, "id") eller tekst(data["id"]) == "" { kast "Quick3Feil: ticket manglar id" }
    hvis ikkje har_nokkel(data, "title") eller tekst(data["title"]) == "" { kast "Quick3Feil: ticket manglar tittel" }
    hvis ikkje har_nokkel(data, "status") eller tekst(data["status"]) == "" { kast "Quick3Feil: ticket manglar status" }
    hvis ikkje har_nokkel(data, "priority") eller tekst(data["priority"]) == "" { kast "Quick3Feil: ticket manglar prioritet" }
    returner {"schema": "norscode-helpdesk-ticket-v1",
              "id": tekst(data["id"]), "title": tekst(data["title"]),
              "status": tekst(data["status"]), "priority": tekst(data["priority"]),
              "vehicle_id": tekst(data["vehicle_id"]),
              "raw": builtin.json_stringify(data)}
}

funksjon trygg_responslogg(resultat: ordbok_tekst) -> ordbok_tekst {
    returner {"schema": "norscode-quick3-safe-log-v1",
              "status": tekst(resultat["status"]),
              "attempts": tekst(resultat["attempts"]),
              "ok": tekst(resultat["ok"])}
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "stabil", "schema": "norscode-quick3-v1",
              "dekning": "Bearer-token, GET/POST/PUT/PATCH, HTTPS via http.request_full, JSON-body, timeout, retry, rate-limit, statuskartlegging og tokenfri responslogg"}
}

# heapq.no — Heap-køoperasjonar
# Python: heapq
#
# Implementerer ein min-heap på liste_heltall og liste_tekst.
# Norscode-heap er ein liste_heltall der indeks 0 er det minste elementet.
#
# Internstruktur: liste_heltall (for heltall-heap)
# Heap-eigenskapar: l[i] <= l[2*i+1] og l[i] <= l[2*i+2]
#
# Bruk:
#   bruk std.heapq som hq
#
#   la h: liste_heltall = []
#   hq.heappush(h, 5)
#   hq.heappush(h, 2)
#   hq.heappush(h, 8)
#   skriv hq.heappop(h)     # → 2
#   skriv hq.peek(h)         # → 5

# ─── Min-heap (heltall) ───────────────────────────────────────────────────────

funksjon heappush(h: liste_heltall, verdi: heltall) {
    legg_til(h, verdi)
    _boble_opp_h(h, lengde(h) - 1)
}

funksjon heappop(h: liste_heltall) -> heltall {
    la n: heltall = lengde(h)
    hvis (n == 0) { returner 0 }
    la min_verdi: heltall = h[0]
    la siste: heltall = h[n - 1]
    # Fjern siste
    la ny_h: liste_heltall = builtin.slice(h, 0, n - 1)
    la i: heltall = 0
    mens (i < n - 1) {
        h[i] = ny_h[i]
        i = i + 1
    }
    # Klipp lista (vi kan ikkje direkte resize, så vi simulerer)
    # Bruk ein workaround: kopier til ny og reflekter tilbake
    # I staden: set h[0] = siste og sil ned
    hvis (n > 1) {
        h[0] = siste
        _sil_ned_h(h, 0, n - 1)
    }
    returner min_verdi
}

funksjon peek(h: liste_heltall) -> heltall {
    hvis (lengde(h) == 0) { returner 0 }
    returner h[0]
}

funksjon heapify(h: liste_heltall) {
    la n: heltall = lengde(h)
    la i: heltall = n / 2 - 1
    mens (i >= 0) {
        _sil_ned_h(h, i, n)
        i = i - 1
    }
}

# Erstatt toppen og returner gammal topp (push+pop i eitt)
funksjon heapreplace(h: liste_heltall, verdi: heltall) -> heltall {
    la gammal: heltall = h[0]
    h[0] = verdi
    _sil_ned_h(h, 0, lengde(h))
    returner gammal
}

# pushpop: effektiv push+pop (Python-semantikk)
funksjon heappushpop(h: liste_heltall, verdi: heltall) -> heltall {
    la n: heltall = lengde(h)
    hvis (n > 0 og h[0] < verdi) {
        returner heapreplace(h, verdi)
    }
    returner verdi
}

funksjon _boble_opp_h(h: liste_heltall, i: heltall) {
    mens (i > 0) {
        la forelder: heltall = (i - 1) / 2
        hvis (h[i] < h[forelder]) {
            la tmp: heltall = h[i]
            h[i] = h[forelder]
            h[forelder] = tmp
            i = forelder
        } ellers {
            i = 0  # bryt
        }
    }
}

funksjon _sil_ned_h(h: liste_heltall, i: heltall, n: heltall) {
    la kont: bool = sann
    mens (kont) {
        la venstre: heltall = 2 * i + 1
        la høgre: heltall = 2 * i + 2
        la minst: heltall = i
        hvis (venstre < n og h[venstre] < h[minst]) { minst = venstre }
        hvis (høgre < n og h[høgre] < h[minst]) { minst = høgre }
        hvis (minst != i) {
            la tmp: heltall = h[i]
            h[i] = h[minst]
            h[minst] = tmp
            i = minst
        } ellers {
            kont = usann
        }
    }
}

# ─── nsmallest / nlargest ─────────────────────────────────────────────────────

funksjon nsmallest(n: heltall, l: liste_heltall) -> liste_heltall {
    la kopi: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) { legg_til(kopi, l[i])  i = i + 1 }
    heapify(kopi)
    la resultat: liste_heltall = []
    la tal: heltall = n
    hvis (tal > lengde(kopi)) { tal = lengde(kopi) }
    la j: heltall = 0
    mens (j < tal) {
        legg_til(resultat, heappop(kopi))
        j = j + 1
    }
    returner resultat
}

funksjon nlargest(n: heltall, l: liste_heltall) -> liste_heltall {
    # Snu liste, finn n minste, snu att
    la snudd: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) { legg_til(snudd, 0 - l[i])  i = i + 1 }
    la sm = nsmallest(n, snudd)
    la resultat: liste_heltall = []
    la j: heltall = 0
    mens (j < lengde(sm)) { legg_til(resultat, 0 - sm[j])  j = j + 1 }
    returner resultat
}

funksjon er_tom(h: liste_heltall) -> bool {
    returner lengde(h) == 0
}

funksjon storleik_h(h: liste_heltall) -> heltall {
    returner lengde(h)
}

# ─── Tekst-heap (min-heap for liste_tekst) ────────────────────────────────────

funksjon heappush_t(h: liste_tekst, verdi: tekst) {
    legg_til(h, verdi)
    _boble_opp_t(h, lengde(h) - 1)
}

funksjon heappop_t(h: liste_tekst) -> tekst {
    la n: heltall = lengde(h)
    hvis (n == 0) { returner "" }
    la min_verdi: tekst = h[0]
    la siste: tekst = h[n - 1]
    hvis (n > 1) {
        h[0] = siste
        _sil_ned_t(h, 0, n - 1)
    }
    returner min_verdi
}

funksjon peek_t(h: liste_tekst) -> tekst {
    hvis (lengde(h) == 0) { returner "" }
    returner h[0]
}

funksjon heapify_t(h: liste_tekst) {
    la n: heltall = lengde(h)
    la i: heltall = n / 2 - 1
    mens (i >= 0) {
        _sil_ned_t(h, i, n)
        i = i - 1
    }
}

funksjon _boble_opp_t(h: liste_tekst, i: heltall) {
    mens (i > 0) {
        la forelder: heltall = (i - 1) / 2
        hvis (h[i] < h[forelder]) {
            la tmp: tekst = h[i]
            h[i] = h[forelder]
            h[forelder] = tmp
            i = forelder
        } ellers {
            i = 0
        }
    }
}

funksjon _sil_ned_t(h: liste_tekst, i: heltall, n: heltall) {
    la kont: bool = sann
    mens (kont) {
        la venstre: heltall = 2 * i + 1
        la høgre: heltall = 2 * i + 2
        la minst: heltall = i
        hvis (venstre < n og h[venstre] < h[minst]) { minst = venstre }
        hvis (høgre < n og h[høgre] < h[minst]) { minst = høgre }
        hvis (minst != i) {
            la tmp: tekst = h[i]
            h[i] = h[minst]
            h[minst] = tmp
            i = minst
        } ellers {
            kont = usann
        }
    }
}

funksjon nsmallest_t(n: heltall, l: liste_tekst) -> liste_tekst {
    la kopi: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(l)) { legg_til(kopi, l[i])  i = i + 1 }
    heapify_t(kopi)
    la resultat: liste_tekst = []
    la tal: heltall = n
    hvis (tal > lengde(kopi)) { tal = lengde(kopi) }
    la j: heltall = 0
    mens (j < tal) {
        legg_til(resultat, heappop_t(kopi))
        j = j + 1
    }
    returner resultat
}

# ─── Prioritetskø (ordbok_tekst-basert) ──────────────────────────────────────
# Element: [prioritet_som_heltall, verdi_som_tekst]
# Lagra som JSON-lista i liste_tekst

funksjon ny_prioritetskø() -> liste_tekst {
    returner []
}

funksjon pk_push(pq: liste_tekst, prioritet: heltall, verdi: tekst) {
    la element: ordbok_tekst = {}
    element["p"] = tekst_fra_heltall(prioritet)
    element["v"] = verdi
    la el_str: tekst = builtin.json_stringify(element)
    legg_til(pq, el_str)
    _pk_boble_opp(pq, lengde(pq) - 1)
}

funksjon pk_pop(pq: liste_tekst) -> tekst {
    la n: heltall = lengde(pq)
    hvis (n == 0) { returner "" }
    la top = builtin.json_parse(pq[0])
    la verdi: tekst = top["v"]
    la siste: tekst = pq[n - 1]
    hvis (n > 1) {
        pq[0] = siste
        _pk_sil_ned(pq, 0, n - 1)
    }
    returner verdi
}

funksjon pk_peek(pq: liste_tekst) -> tekst {
    hvis (lengde(pq) == 0) { returner "" }
    la top = builtin.json_parse(pq[0])
    returner top["v"]
}

funksjon pk_peek_prioritet(pq: liste_tekst) -> heltall {
    hvis (lengde(pq) == 0) { returner 0 }
    la top = builtin.json_parse(pq[0])
    returner builtin.heltall_fra_tekst(top["p"])
}

funksjon pk_er_tom(pq: liste_tekst) -> bool {
    returner lengde(pq) == 0
}

funksjon pk_storleik(pq: liste_tekst) -> heltall {
    returner lengde(pq)
}

funksjon _pk_prioritet(pq: liste_tekst, i: heltall) -> heltall {
    la el = builtin.json_parse(pq[i])
    returner builtin.heltall_fra_tekst(el["p"])
}

funksjon _pk_boble_opp(pq: liste_tekst, i: heltall) {
    mens (i > 0) {
        la forelder: heltall = (i - 1) / 2
        hvis (_pk_prioritet(pq, i) < _pk_prioritet(pq, forelder)) {
            la tmp: tekst = pq[i]
            pq[i] = pq[forelder]
            pq[forelder] = tmp
            i = forelder
        } ellers {
            i = 0
        }
    }
}

funksjon _pk_sil_ned(pq: liste_tekst, i: heltall, n: heltall) {
    la kont: bool = sann
    mens (kont) {
        la venstre: heltall = 2 * i + 1
        la høgre: heltall = 2 * i + 2
        la minst: heltall = i
        hvis (venstre < n og _pk_prioritet(pq, venstre) < _pk_prioritet(pq, minst)) {
            minst = venstre
        }
        hvis (høgre < n og _pk_prioritet(pq, høgre) < _pk_prioritet(pq, minst)) {
            minst = høgre
        }
        hvis (minst != i) {
            la tmp: tekst = pq[i]
            pq[i] = pq[minst]
            pq[minst] = tmp
            i = minst
        } ellers {
            kont = usann
        }
    }
}

# ─── merge (slå saman sorterte lister) ───────────────────────────────────────

funksjon merge(lister: liste_tekst) -> liste_heltall {
    # Kvar indre liste er JSON-serialisert liste_heltall
    la pq: liste_tekst = ny_prioritetskø()
    la resultat: liste_heltall = []

    # Legg første element frå kvar liste inn i heapen
    # Element i pq: {p: verdi, v: "[liste_idx, elem_idx]"}
    la i: heltall = 0
    mens (i < lengde(lister)) {
        la l = builtin.json_parse(lister[i])
        hvis (lengde(l) > 0) {
            la meta: ordbok_tekst = {}
            meta["li"] = tekst_fra_heltall(i)
            meta["ei"] = "0"
            pk_push(pq, l[0], builtin.json_stringify(meta))
        }
        i = i + 1
    }

    mens (ikkje pk_er_tom(pq)) {
        la prioritet: heltall = pk_peek_prioritet(pq)
        la meta_str: tekst = pk_pop(pq)
        la meta = builtin.json_parse(meta_str)
        la li: heltall = builtin.heltall_fra_tekst(meta["li"])
        la ei: heltall = builtin.heltall_fra_tekst(meta["ei"])
        legg_til(resultat, prioritet)
        la l = builtin.json_parse(lister[li])
        la neste_ei: heltall = ei + 1
        hvis (neste_ei < lengde(l)) {
            la ny_meta: ordbok_tekst = {}
            ny_meta["li"] = tekst_fra_heltall(li)
            ny_meta["ei"] = tekst_fra_heltall(neste_ei)
            pk_push(pq, l[neste_ei], builtin.json_stringify(ny_meta))
        }
    }

    returner resultat
}

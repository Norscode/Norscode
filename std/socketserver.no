# socketserver.no — generisk nettverkstenjar
# Python: socketserver
#
# Simulerer TCPServer/UDPServer-mønsteret. Klientfunksjonane brukar std.socket,
# medan bakgrunnstenarar framleis brukar avgrensa prosessbindingar.
#
# Tenar-objekt: ordbok_tekst
#   "_type"       → "tcp_tenar" / "udp_tenar"
#   "vert"        → bindingsadresse
#   "port"        → portnummer (tekst)
#   "aktiv"       → "sann"/"usann"
#   "pid_fil"     → sti til PID-fil
#   "logg_fil"    → sti til logg-fil
#   "prosess_id"  → PID (tekst)
#
# Bruk:
#   bruk std.socketserver som ss
#   la tenar = ss.ny_tcp_tenar("localhost", 8080)
#   ss.start(tenar, "/tmp/tenar_logg.txt")
#   la svar = ss.les_siste(tenar)
#   ss.stopp(tenar)

bruk std.socket som sok

funksjon _shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon ny_tcp_tenar(vert: tekst, port: heltall) -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["_type"]      = "tcp_tenar"
    t["vert"]       = vert
    t["port"]       = tekst_fra_heltall(port)
    t["aktiv"]      = "usann"
    t["pid_fil"]    = "/tmp/norscode_tcp_" + tekst_fra_heltall(port) + ".pid"
    t["logg_fil"]   = "/tmp/norscode_tcp_" + tekst_fra_heltall(port) + ".logg"
    t["prosess_id"] = ""
    returner t
}

funksjon ny_udp_tenar(vert: tekst, port: heltall) -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["_type"]      = "udp_tenar"
    t["vert"]       = vert
    t["port"]       = tekst_fra_heltall(port)
    t["aktiv"]      = "usann"
    t["pid_fil"]    = "/tmp/norscode_udp_" + tekst_fra_heltall(port) + ".pid"
    t["logg_fil"]   = "/tmp/norscode_udp_" + tekst_fra_heltall(port) + ".logg"
    t["prosess_id"] = ""
    returner t
}

# Start bakgrunnstenar ved OS-grensa når runtime manglar direkte serverbinding.
# PID/logg blir lesne og filtrerte i Norscode.
funksjon start(tenar: ordbok_tekst, logg_fil: tekst) -> bool {
    tenar["logg_fil"] = logg_fil
    la port: tekst = tenar["port"]
    la pid_fil: tekst = tenar["pid_fil"]
    prøv {
        la type: tekst = tenar["_type"]
        la cmd: tekst = ""
        hvis (type == "tcp_tenar") {
            # Prøv socat fyrst, fell tilbake til nc
            la har_socat = builtin.exec_prosess("which socat 2>/dev/null")
            la trim_socat = _trim(har_socat)
            hvis (trim_socat != "") {
                cmd = "socat -v TCP-LISTEN:" + port + ",reuseaddr,fork - >> " + _shell(logg_fil) + " 2>&1 & echo $! > " + _shell(pid_fil)
            } ellers {
                cmd = "nc -l " + port + " >> " + _shell(logg_fil) + " 2>&1 & echo $! > " + _shell(pid_fil)
            }
        } ellers {
            cmd = "nc -u -l " + port + " >> " + _shell(logg_fil) + " 2>&1 & echo $! > " + _shell(pid_fil)
        }
        builtin.exec_prosess("sh -c " + _shell(cmd))
        la pid_tekst = builtin.fil_les(pid_fil)
        tenar["prosess_id"] = _trim(pid_tekst)
        tenar["aktiv"] = "sann"
        returner sann
    } fang (e) {
        returner usann
    }
    returner usann
}

# Stopp tenar
funksjon stopp(tenar: ordbok_tekst) -> bool {
    prøv {
        la pid: tekst = tenar["prosess_id"]
        hvis (pid != "") {
            builtin.exec_prosess("kill " + _shell(pid) + " 2>/dev/null")
        }
        la pid_fil: tekst = tenar["pid_fil"]
        builtin.exec_prosess("rm -f " + _shell(pid_fil))
        tenar["aktiv"] = "usann"
        tenar["prosess_id"] = ""
        returner sann
    } fang (e) { returner usann }
    returner usann
}

# Er tenaren aktiv?
funksjon er_aktiv(tenar: ordbok_tekst) -> bool {
    la pid: tekst = tenar["prosess_id"]
    hvis (pid == "") { returner usann }
    prøv {
        la res = builtin.exec_prosess("kill -0 " + _shell(pid) + " 2>/dev/null")
        returner res[0] == "0"
    } fang (e) { returner usann }
    returner usann
}

# Les siste N linjer frå logg
funksjon les_siste(tenar: ordbok_tekst, n: heltall) -> liste_tekst {
    prøv {
        la logg: tekst = tenar["logg_fil"]
        hvis (n < 1) { returner [] }
        la linjer = builtin.split(builtin.fil_les(logg), "\n")
        la ikkje_tomme: liste_tekst = []
        la j: heltall = 0
        mens (j < lengde(linjer)) {
            la s0: tekst = _trim(linjer[j])
            hvis (s0 != "") { legg_til(ikkje_tomme, s0) }
            j = j + 1
        }
        la resultat: liste_tekst = []
        la start: heltall = lengde(ikkje_tomme) - n
        hvis (start < 0) { start = 0 }
        la i: heltall = start
        mens (i < lengde(ikkje_tomme)) {
            legg_til(resultat, ikkje_tomme[i])
            i = i + 1
        }
        returner resultat
    } fang (e) { returner [] }
    returner []
}

# Tøm logg
funksjon tøm_logg(tenar: ordbok_tekst) {
    prøv {
        builtin.exec_prosess("> " + _shell(tenar["logg_fil"]))
    } fang (e) {}
}

# Send data til ein tenar (som klient)
funksjon send_tcp(vert: tekst, port: heltall, data: tekst) -> tekst {
    la s = sok.ny_tcp()
    prøv {
        hvis ikkje sok.tilkoble(s, vert, port) {
            sok.lukk(s)
            returner ""
        }
        hvis sok.send(s, data) < 0 {
            sok.lukk(s)
            returner ""
        }
        la res = sok.motta(s, 4096)
        sok.lukk(s)
        returner _trim(res)
    } fang (e) {
        sok.lukk(s)
        returner ""
    }
    returner ""
}

funksjon send_udp(vert: tekst, port: heltall, data: tekst) -> bool {
    la s = sok.ny_udp()
    prøv {
        hvis ikkje sok.tilkoble(s, vert, port) {
            sok.lukk(s)
            returner usann
        }
        hvis sok.send(s, data) < 0 {
            sok.lukk(s)
            returner usann
        }
        sok.lukk(s)
        returner sann
    } fang (e) {
        sok.lukk(s)
        returner usann
    }
    returner usann
}

# Enkel HTTP-tenar (tekst-svar)
funksjon ny_http_tenar(vert: tekst, port: heltall) -> ordbok_tekst {
    la t = ny_tcp_tenar(vert, port)
    t["_type"]   = "http_tenar"
    t["rot_sti"] = "."
    returner t
}

funksjon start_http(tenar: ordbok_tekst, rot_sti: tekst) -> bool {
    tenar["rot_sti"] = rot_sti
    tenar["aktiv"] = "usann"
    tenar["feil"] = "HTTP-tenar skal startast med ./bin/nc serve i aktiv Norscode-løype."
    returner usann
}

# Port ledig?
funksjon port_ledig(port: heltall) -> bool {
    prøv {
        la res = builtin.exec_prosess("lsof -i :" + tekst_fra_heltall(port) + " 2>/dev/null")
        la n: heltall = _tel_ikkje_tomme_liner(res)
        returner n == 0
    } fang (e) { returner sann }
    returner sann
}

# List aktive tenarar (lsof)
funksjon aktive_tenarar() -> liste_tekst {
    prøv {
        la res = builtin.exec_prosess("lsof -i -P -n 2>/dev/null")
        la linjer = builtin.split(res, "\n")
        la resultat: liste_tekst = []
        la i: heltall = 0
        mens (i < lengde(linjer)) {
            la s: tekst = _trim(linjer[i])
            hvis (s != "" og _inneheld(s, "LISTEN")) { legg_til(resultat, s) }
            i = i + 1
        }
        returner resultat
    } fang (e) { returner [] }
    returner []
}

funksjon tenar_repr(tenar: ordbok_tekst) -> tekst {
    returner tenar["_type"] + "(" + tenar["vert"] + ":" + tenar["port"] + ", aktiv=" + tenar["aktiv"] + ")"
}

funksjon tekst_fra_heltall(n: heltall) -> tekst {
    prøv { returner builtin.join([n], "") } fang (e) { returner "0" }
    returner "0"
}

funksjon _tel_ikkje_tomme_liner(tekstblokk: tekst) -> heltall {
    la linjer = builtin.split(tekstblokk, "\n")
    la tal: heltall = 0
    la i: heltall = 0
    mens (i < lengde(linjer)) {
        hvis (_trim(linjer[i]) != "") { tal = tal + 1 }
        i = i + 1
    }
    returner tal
}

funksjon _inneheld(s: tekst, del: tekst) -> bool {
    returner lengde(builtin.split(s, del)) > 1
}

funksjon _trim(s: tekst) -> tekst {
    la t = builtin.split(s, "")
    la n: heltall = lengde(t)
    la a: heltall = 0  la b: heltall = n
    mens (a < b og (t[a]==" " eller t[a]=="\t" eller t[a]=="\n" eller t[a]=="\r")) { a=a+1 }
    mens (b > a og (t[b-1]==" " eller t[b-1]=="\t" eller t[b-1]=="\n" eller t[b-1]=="\r")) { b=b-1 }
    returner builtin.join(builtin.slice(t, a, b), "")
}

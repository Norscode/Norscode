bruk std.html som html
bruk std.html_components som komp

// Norscode HTML Forms v1
// Høyere nivå skjema-komponenter bygget oppå std.html.

funksjon felt_id(navn: tekst) -> tekst {
    returner "felt-" + navn
}

funksjon hjelpetekst_id(navn: tekst) -> tekst {
    returner "hjelp-" + navn
}

funksjon feiltekst_id(navn: tekst) -> tekst {
    returner "feil-" + navn
}

funksjon beskrivelse_ider(navn: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    la ider: tekst = ""
    hvis (hjelptekst != "") {
        ider = hjelpetekst_id(navn)
    }
    hvis (feiltekst != "") {
        hvis (ider != "") {
            ider = ider + " "
        }
        ider = ider + feiltekst_id(navn)
    }
    returner ider
}

funksjon beskrivelse_attrs(navn: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    la ider: tekst = beskrivelse_ider(navn, hjelptekst, feiltekst)
    hvis (ider == "") {
        returner ""
    }
    returner html.aria_attr("describedby", ider)
}

funksjon feil_attrs(feiltekst: tekst) -> tekst {
    hvis (feiltekst == "") {
        returner ""
    }
    returner html.aria_attr("invalid", "true")
}

funksjon påkrevd_attrs() -> tekst {
    returner html.attr("required", "required") + html.aria_attr("required", "true")
}

funksjon deaktivert_attrs() -> tekst {
    returner html.attr("disabled", "disabled") + html.aria_attr("disabled", "true")
}

funksjon skrivebeskyttet_attrs() -> tekst {
    returner html.attr("readonly", "readonly")
}

funksjon autocomplete_attr(verdi: tekst) -> tekst {
    hvis (verdi == "") {
        returner ""
    }
    returner html.attr("autocomplete", verdi)
}

funksjon submit_busy_attrs(tekstverdi: tekst) -> tekst {
    returner html.disable_submit_attrs(tekstverdi)
}

funksjon felt_label(navn: tekst, tekstverdi: tekst) -> tekst {
    returner html.label(html.attr("for", felt_id(navn)), html.escape(tekstverdi))
}

funksjon hjelp(navn: tekst, tekstverdi: tekst) -> tekst {
    hvis (tekstverdi == "") {
        returner ""
    }
    returner html.p(html.class_attr("field-help") + html.id_attr(hjelpetekst_id(navn)), html.escape(tekstverdi))
}

funksjon feil(navn: tekst, tekstverdi: tekst) -> tekst {
    hvis (tekstverdi == "") {
        returner ""
    }
    returner html.p(html.class_attr("field-error") + html.id_attr(feiltekst_id(navn)) + html.attr("role", "alert"), html.escape(tekstverdi))
}

funksjon feilsammendrag_rad(href: tekst, tekstverdi: tekst) -> tekst {
    returner html.li("", html.a(html.href_attr(href), html.escape(tekstverdi)))
}

funksjon feilsammendrag(tittel: tekst, feil_liste: tekst) -> tekst {
    hvis (feil_liste == "") {
        returner ""
    }
    returner html.section(
        html.class_attr("error-summary") + html.attr("role", "alert") + html.aria_attr("live", "assertive"),
        html.h2("", html.escape(tittel))
            + html.ul("", feil_liste)
    )
}

funksjon feltgruppe(tittel: tekst, innhold: tekst) -> tekst {
    returner html.fieldset(
        html.class_attr("field-group"),
        html.legend("", html.escape(tittel))
            + html.div(html.class_attr("field-group__body"), innhold)
    )
}

funksjon input_base(typeverdi: tekst, navn: tekst, verdi: tekst, placeholder: tekst, ekstra: tekst) -> tekst {
    returner html.input(
        html.attr("type", typeverdi)
            + html.attr("name", navn)
            + html.id_attr(felt_id(navn))
            + html.attr("value", verdi)
            + html.attr("placeholder", placeholder)
            + ekstra
    )
}

funksjon tekstfelt_med_attrs(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst, ekstra: tekst) -> tekst {
    returner html.div(
        html.class_attr("field field-text"),
        felt_label(navn, labeltekst)
            + input_base("text", navn, verdi, placeholder, beskrivelse_attrs(navn, hjelptekst, feiltekst) + feil_attrs(feiltekst) + ekstra)
            + hjelp(navn, hjelptekst)
            + feil(navn, feiltekst)
    )
}

funksjon tekstfelt(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    returner tekstfelt_med_attrs(navn, labeltekst, verdi, placeholder, hjelptekst, feiltekst, "")
}

funksjon epostfelt_med_attrs(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst, ekstra: tekst) -> tekst {
    returner html.div(
        html.class_attr("field field-email"),
        felt_label(navn, labeltekst)
            + input_base("email", navn, verdi, placeholder, beskrivelse_attrs(navn, hjelptekst, feiltekst) + feil_attrs(feiltekst) + ekstra)
            + hjelp(navn, hjelptekst)
            + feil(navn, feiltekst)
    )
}

funksjon epostfelt(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    returner epostfelt_med_attrs(navn, labeltekst, verdi, placeholder, hjelptekst, feiltekst, "")
}

funksjon passordfelt_med_attrs(navn: tekst, labeltekst: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst, ekstra: tekst) -> tekst {
    returner html.div(
        html.class_attr("field field-password"),
        felt_label(navn, labeltekst)
            + html.input(
                html.attr("type", "password")
                    + html.attr("name", navn)
                    + html.id_attr(felt_id(navn))
                    + html.attr("placeholder", placeholder)
                    + beskrivelse_attrs(navn, hjelptekst, feiltekst)
                    + feil_attrs(feiltekst)
                    + ekstra
            )
            + hjelp(navn, hjelptekst)
            + feil(navn, feiltekst)
    )
}

funksjon passordfelt(navn: tekst, labeltekst: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    returner passordfelt_med_attrs(navn, labeltekst, placeholder, hjelptekst, feiltekst, "")
}

funksjon søkefelt(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst) -> tekst {
    returner html.div(
        html.class_attr("field field-search"),
        felt_label(navn, labeltekst)
            + input_base("search", navn, verdi, placeholder, "")
    )
}

funksjon tekstområde_med_attrs(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst, ekstra: tekst) -> tekst {
    returner html.div(
        html.class_attr("field field-textarea"),
        felt_label(navn, labeltekst)
            + html.textarea(
                html.attr("name", navn)
                    + html.id_attr(felt_id(navn))
                    + html.attr("placeholder", placeholder)
                    + beskrivelse_attrs(navn, hjelptekst, feiltekst)
                    + feil_attrs(feiltekst)
                    + ekstra,
                verdi
            )
            + hjelp(navn, hjelptekst)
            + feil(navn, feiltekst)
    )
}

funksjon tekstområde(navn: tekst, labeltekst: tekst, verdi: tekst, placeholder: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    returner tekstområde_med_attrs(navn, labeltekst, verdi, placeholder, hjelptekst, feiltekst, "")
}

funksjon avkryssing(navn: tekst, labeltekst: tekst, valgt: tekst) -> tekst {
    returner html.label(
        html.class_attr("field-check"),
        html.checkbox(html.attr("name", navn) + html.id_attr(felt_id(navn)) + valgt)
            + html.span("", html.escape(labeltekst))
    )
}

funksjon velg_med_attrs(navn: tekst, labeltekst: tekst, alternativer: tekst, hjelptekst: tekst, feiltekst: tekst, ekstra: tekst) -> tekst {
    returner html.div(
        html.class_attr("field field-select"),
        felt_label(navn, labeltekst)
            + html.select(html.attr("name", navn) + html.id_attr(felt_id(navn)) + beskrivelse_attrs(navn, hjelptekst, feiltekst) + feil_attrs(feiltekst) + ekstra, alternativer)
            + hjelp(navn, hjelptekst)
            + feil(navn, feiltekst)
    )
}

funksjon velg(navn: tekst, labeltekst: tekst, alternativer: tekst, hjelptekst: tekst, feiltekst: tekst) -> tekst {
    returner velg_med_attrs(navn, labeltekst, alternativer, hjelptekst, feiltekst, "")
}

funksjon valg(verdi: tekst, tekstverdi: tekst) -> tekst {
    returner html.option(html.attr("value", verdi), tekstverdi)
}

funksjon handlinger(innhold: tekst) -> tekst {
    returner html.div(html.class_attr("form-actions"), innhold)
}

funksjon submit_knapp(tekstverdi: tekst) -> tekst {
    returner html.submit("", tekstverdi)
}

funksjon submit_knapp_busy(tekstverdi: tekst, busy_tekst: tekst) -> tekst {
    returner html.submit(submit_busy_attrs(busy_tekst), tekstverdi)
}

funksjon avbryt_lenke(href: tekst, tekstverdi: tekst) -> tekst {
    returner html.a(html.class_attr("button button-secondary") + html.href_attr(href), html.escape(tekstverdi))
}

funksjon handlinger_standard(submit_tekst: tekst, avbryt_href: tekst) -> tekst {
    returner handlinger(
        submit_knapp(submit_tekst)
            + avbryt_lenke(avbryt_href, "Avbryt")
    )
}

funksjon skjema(attributter: tekst, innhold: tekst) -> tekst {
    returner html.form(attributter, innhold)
}

funksjon post_skjema(action: tekst, innhold: tekst) -> tekst {
    returner skjema(html.attr("method", "post") + html.attr("action", action), innhold)
}

funksjon get_skjema(action: tekst, innhold: tekst) -> tekst {
    returner skjema(html.attr("method", "get") + html.attr("action", action), innhold)
}

funksjon login_skjema(action: tekst) -> tekst {
    returner post_skjema(
        action,
        epostfelt("epost", "E-post", "", "navn@domene.no", "", "")
            + passordfelt("passord", "Passord", "Passord", "", "")
            + handlinger(html.submit("", "Logg inn"))
    )
}

funksjon søke_skjema(action: tekst, verdi: tekst) -> tekst {
    returner get_skjema(
        action,
        søkefelt("q", "Søk", verdi, "Søk")
            + handlinger(html.submit("", "Søk"))
    )
}

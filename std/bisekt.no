# bisekt.no — Binært søk i sorterte lister
# Python: bisect
#
# Alle funksjonar krev at lista er sortert i stigande rekkjefølge.
#
# Bruk:
#   bruk std.bisekt som bi
#   la l: liste_heltall = [1, 3, 5, 7, 9]
#   skriv(bi.bisekt_venstre(l, 5))    # => 2
#   skriv(bi.bisekt_høgre(l, 5))      # => 3
#   bi.insort_venstre(l, 6)
#   # l er no [1, 3, 5, 6, 7, 9]

# ─── Heltall ──────────────────────────────────────────────────────────────────

# Returnerer indeksen lengst til venstre der v kan setjast inn og halde orden.
# Dvs. l[i-1] < v <= l[i]
funksjon bisekt_venstre(l: liste_heltall, v: heltall) -> heltall {
    la lo: heltall = 0
    la hi: heltall = lengde(l)
    mens (lo < hi) {
        la midt: heltall = (lo + hi) / 2
        hvis (l[midt] < v) { lo = midt + 1 }
        ellers { hi = midt }
    }
    returner lo
}

# Returnerer indeksen lengst til høgre.
# Dvs. l[i-1] <= v < l[i]
funksjon bisekt_høgre(l: liste_heltall, v: heltall) -> heltall {
    la lo: heltall = 0
    la hi: heltall = lengde(l)
    mens (lo < hi) {
        la midt: heltall = (lo + hi) / 2
        hvis (v < l[midt]) { hi = midt }
        ellers { lo = midt + 1 }
    }
    returner lo
}

# Set inn v på rett plass (venstre-variant, stabilt)
funksjon insort_venstre(l: liste_heltall, v: heltall) -> heltall {
    la idx: heltall = bisekt_venstre(l, v)
    la n: heltall = lengde(l)
    legg_til(l, v)               # utvid med ein ekstra plass
    la i: heltall = n
    mens (i > idx) {
        l[i] = l[i - 1]
        i = i - 1
    }
    l[idx] = v
    returner idx
}

# Set inn v på rett plass (høgre-variant)
funksjon insort_høgre(l: liste_heltall, v: heltall) -> heltall {
    la idx: heltall = bisekt_høgre(l, v)
    la n: heltall = lengde(l)
    legg_til(l, v)
    la i: heltall = n
    mens (i > idx) {
        l[i] = l[i - 1]
        i = i - 1
    }
    l[idx] = v
    returner idx
}

# Er v i lista? (O(log n))
funksjon inneheld(l: liste_heltall, v: heltall) -> bool {
    la idx: heltall = bisekt_venstre(l, v)
    returner idx < lengde(l) og l[idx] == v
}

# Tal på førekomstar av v (O(log n))
funksjon tel(l: liste_heltall, v: heltall) -> heltall {
    returner bisekt_høgre(l, v) - bisekt_venstre(l, v)
}

# Alle indeksar der v finst (returnerer [start, slutt) — eksklusiv slutt)
funksjon område(l: liste_heltall, v: heltall) -> liste_heltall {
    la ut: liste_heltall = []
    legg_til(ut, bisekt_venstre(l, v))
    legg_til(ut, bisekt_høgre(l, v))
    returner ut
}

# ─── Tekst ────────────────────────────────────────────────────────────────────

funksjon bisekt_venstre_tekst(l: liste_tekst, v: tekst) -> heltall {
    la lo: heltall = 0
    la hi: heltall = lengde(l)
    mens (lo < hi) {
        la midt: heltall = (lo + hi) / 2
        hvis (l[midt] < v) { lo = midt + 1 }
        ellers { hi = midt }
    }
    returner lo
}

funksjon bisekt_høgre_tekst(l: liste_tekst, v: tekst) -> heltall {
    la lo: heltall = 0
    la hi: heltall = lengde(l)
    mens (lo < hi) {
        la midt: heltall = (lo + hi) / 2
        hvis (v < l[midt]) { hi = midt }
        ellers { lo = midt + 1 }
    }
    returner lo
}

funksjon insort_tekst(l: liste_tekst, v: tekst) -> heltall {
    la idx: heltall = bisekt_venstre_tekst(l, v)
    la n: heltall = lengde(l)
    legg_til(l, v)
    la i: heltall = n
    mens (i > idx) {
        l[i] = l[i - 1]
        i = i - 1
    }
    l[idx] = v
    returner idx
}

funksjon inneheld_tekst(l: liste_tekst, v: tekst) -> bool {
    la idx: heltall = bisekt_venstre_tekst(l, v)
    returner idx < lengde(l) og l[idx] == v
}

# ─── Søk i område ─────────────────────────────────────────────────────────────

# Alle element i [min_v, maks_v] (inklusiv begge)
funksjon i_område(l: liste_heltall, min_v: heltall, maks_v: heltall) -> liste_heltall {
    la start: heltall = bisekt_venstre(l, min_v)
    la slutt: heltall = bisekt_høgre(l, maks_v)
    la ut: liste_heltall = []
    la i: heltall = start
    mens (i < slutt) {
        legg_til(ut, l[i])
        i = i + 1
    }
    returner ut
}

# Nærmaste verdi til v i sortert liste
funksjon nærmast(l: liste_heltall, v: heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la idx: heltall = bisekt_venstre(l, v)
    hvis (idx == 0) { returner l[0] }
    hvis (idx == n) { returner l[n - 1] }
    la venstre: heltall = l[idx - 1]
    la høgre: heltall = l[idx]
    la dv: heltall = v - venstre
    la dh: heltall = høgre - v
    hvis (dv <= dh) { returner venstre }
    returner høgre
}

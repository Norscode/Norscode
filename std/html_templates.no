bruk std.html som html
bruk std.html_components som komp

// Template system v1

funksjon dokumentasjon_side(tittel: tekst, innhold: tekst, css: tekst) -> tekst {
    returner komp.landingsside(
        tittel,
        "Norscode dokumentasjon",
        komp.knappelenke("/start", "Kom i gang"),
        komp.seksjon("Dokumentasjon", innhold),
        css
    )
}

funksjon blogg_side(tittel: tekst, innhold: tekst, css: tekst) -> tekst {
    returner html.page_meta(
        tittel,
        tittel,
        komp.app_shell(
            komp.side_topp("Norscode Blogg", ""),
            html.article(html.class_attr("blog-post"), innhold),
            html.p("", "Norscode")
        ),
        css
    )
}

funksjon produkt_side(navn: tekst, beskrivelse: tekst, innhold: tekst, css: tekst) -> tekst {
    returner komp.landingsside(
        navn,
        beskrivelse,
        komp.knappelenke("/last-ned", "Last ned"),
        innhold,
        css
    )
}

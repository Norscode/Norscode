# runtime_stack.no - stack-frame kontrakt for Norscode runtime v1

funksjon ny_stack() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["next_id"] = "1"
    s["frames"] = "|"
    s["top"] = ""
    s["depth"] = "0"
    s["max_depth"] = "0"
    returner s
}

funksjon _key(id: tekst, felt: tekst) -> tekst {
    returner "frame." + id + "." + felt
}

funksjon _har_token(liste: tekst, verdi: tekst) -> bool {
    returner builtin.index_of(liste, "|" + verdi + "|") >= 0
}

funksjon _legg_token(liste: tekst, verdi: tekst) -> tekst {
    hvis verdi == "" { returner liste }
    hvis _har_token(liste, verdi) { returner liste }
    returner liste + verdi + "|"
}

funksjon _finnes(s: ordbok_tekst, id: tekst) -> bool {
    returner _har_token(s["frames"], id)
}

funksjon push_frame(s: ordbok_tekst, funksjon_namn: tekst, retur_adresse: heiltall) -> tekst {
    hvis funksjon_namn == "" { funksjon_namn = "<anon>" }
    la id = "frame-" + s["next_id"]
    s["next_id"] = tekst_fra_heltall(heltall_fra_tekst(s["next_id"]) + 1)
    s["frames"] = _legg_token(s["frames"], id)
    s[_key(id, "function")] = funksjon_namn
    s[_key(id, "return_address")] = tekst_fra_heltall(retur_adresse)
    s[_key(id, "locals")] = "|"
    s[_key(id, "params")] = "|"
    s[_key(id, "temps")] = "|"
    s[_key(id, "prev")] = s["top"]
    s[_key(id, "active")] = "sann"
    s["top"] = id
    s["depth"] = tekst_fra_heltall(heltall_fra_tekst(s["depth"]) + 1)
    hvis heltall_fra_tekst(s["depth"]) > heltall_fra_tekst(s["max_depth"]) {
        s["max_depth"] = s["depth"]
    }
    returner id
}

funksjon legg_lokal(s: ordbok_tekst, frame_id: tekst, namn: tekst) -> bool {
    hvis ikkje _finnes(s, frame_id) { returner usann }
    s[_key(frame_id, "locals")] = _legg_token(s[_key(frame_id, "locals")], namn)
    returner sann
}

funksjon legg_param(s: ordbok_tekst, frame_id: tekst, namn: tekst) -> bool {
    hvis ikkje _finnes(s, frame_id) { returner usann }
    s[_key(frame_id, "params")] = _legg_token(s[_key(frame_id, "params")], namn)
    returner sann
}

funksjon legg_temp(s: ordbok_tekst, frame_id: tekst, namn: tekst) -> bool {
    hvis ikkje _finnes(s, frame_id) { returner usann }
    s[_key(frame_id, "temps")] = _legg_token(s[_key(frame_id, "temps")], namn)
    returner sann
}

funksjon top_frame(s: ordbok_tekst) -> tekst {
    returner s["top"]
}

funksjon pop_frame(s: ordbok_tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    r["ok"] = "usann"
    r["frame"] = ""
    r["function"] = ""
    r["return_address"] = ""
    hvis s["top"] == "" { returner r }
    la id = s["top"]
    r["ok"] = "sann"
    r["frame"] = id
    r["function"] = s[_key(id, "function")]
    r["return_address"] = s[_key(id, "return_address")]
    s[_key(id, "active")] = "usann"
    s["top"] = s[_key(id, "prev")]
    s["depth"] = tekst_fra_heltall(heltall_fra_tekst(s["depth"]) - 1)
    returner r
}

funksjon stack_trace(s: ordbok_tekst) -> tekst {
    la out = ""
    la id = s["top"]
    mens id != "" {
        hvis out != "" { out = out + "\n" }
        out = out + s[_key(id, "function")] + "@" + s[_key(id, "return_address")]
        id = s[_key(id, "prev")]
    }
    returner out
}

funksjon frame_info(s: ordbok_tekst, id: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    r["exists"] = "usann"
    hvis ikkje _finnes(s, id) { returner r }
    r["exists"] = "sann"
    r["function"] = s[_key(id, "function")]
    r["return_address"] = s[_key(id, "return_address")]
    r["locals"] = s[_key(id, "locals")]
    r["params"] = s[_key(id, "params")]
    r["temps"] = s[_key(id, "temps")]
    r["active"] = s[_key(id, "active")]
    returner r
}

funksjon produksjonsstatus() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["modul"] = "std.runtime_stack"
    s["status"] = "stabil"
    s["dekning"] = "stack frames, returadresse, lokale variablar, parametre, temporare verdiar, pop og stack trace; pure-VM har iterativ continuation-stack, current IP, GC-rotskanning, kryssramme-unwind og nested debugger suspend/resume utan vertsrekursjon"
    s["mangler"] = ""
    returner s
}

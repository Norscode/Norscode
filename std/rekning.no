# rekning.no — Ren matematisk statistikk
# Python: statistics (stdlib)
#
# Alle funksjonar opererer på liste_heltall.
# Sidan Norscode berre har heltall, brukar vi x100-skalering for presisjon
# der det trengst (snitt, standardavvik osv.).
#
# Bruk:
#   bruk std.rekning som rek
#   la l: liste_heltall = [2, 4, 4, 4, 5, 5, 7, 9]
#   skriv(rek.gjennomsnitt(l))        # => 5  (trunkert)
#   skriv(rek.gjennomsnitt_x100(l))   # => 500  (= 5.00)
#   skriv(rek.median(l))              # => 4
#   skriv(rek.standardavvik_x10(l))   # => 17  (= 1.7)

# ─── Intern hjelp ─────────────────────────────────────────────────────────────

funksjon _sorter(l: liste_heltall) -> liste_heltall {
    la kopi: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) { legg_til(kopi, l[i])  i = i + 1 }
    la n: heltall = lengde(kopi)
    la j: heltall = 1
    mens (j < n) {
        la nøkkel: heltall = kopi[j]
        la k: heltall = j - 1
        mens (k >= 0 og kopi[k] > nøkkel) {
            kopi[k + 1] = kopi[k]
            k = k - 1
        }
        kopi[k + 1] = nøkkel
        j = j + 1
    }
    returner kopi
}

funksjon _krot(x: heltall) -> heltall {
    hvis (x <= 0) { returner 0 }
    la g: heltall = x / 2 + 1
    la i: heltall = 0
    mens (i < 64) {
        la ny: heltall = (g + x / g) / 2
        hvis (ny >= g) { returner g }
        g = ny
        i = i + 1
    }
    returner g
}

# ─── Grunnleggande mål ────────────────────────────────────────────────────────

funksjon sum(l: liste_heltall) -> heltall {
    la s: heltall = 0
    la i: heltall = 0
    mens (i < lengde(l)) { s = s + l[i]  i = i + 1 }
    returner s
}

funksjon min(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la m: heltall = l[0]
    la i: heltall = 1
    mens (i < n) { hvis (l[i] < m) { m = l[i] }  i = i + 1 }
    returner m
}

funksjon maks(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la m: heltall = l[0]
    la i: heltall = 1
    mens (i < n) { hvis (l[i] > m) { m = l[i] }  i = i + 1 }
    returner m
}

funksjon spredning(l: liste_heltall) -> heltall {
    returner maks(l) - min(l)
}

# ─── Gjennomsnitt ─────────────────────────────────────────────────────────────

funksjon gjennomsnitt(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    returner sum(l) / n
}

# Gjennomsnitt * 100 — to desimalar utan flyttal
funksjon gjennomsnitt_x100(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    returner sum(l) * 100 / n
}

# Geometrisk gjennomsnitt (approksimasjon via log2-sum)
funksjon geo_gjennomsnitt(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    # Approksimasjon: n-te rot av produktet via Newton
    la produkt: heltall = 1
    la i: heltall = 0
    mens (i < n) {
        hvis (l[i] <= 0) { returner 0 }
        produkt = produkt * l[i]
        i = i + 1
    }
    # Newton's n-te rot
    la g: heltall = produkt / n + 1
    la iter: heltall = 0
    mens (iter < 50) {
        la potens: heltall = 1
        la j: heltall = 0
        mens (j < n - 1) { potens = potens * g  j = j + 1 }
        la ny: heltall = ((n - 1) * g + produkt / potens) / n
        hvis (ny >= g) { returner g }
        g = ny
        iter = iter + 1
    }
    returner g
}

# ─── Median ───────────────────────────────────────────────────────────────────

funksjon median(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la s = _sorter(l)
    la midt: heltall = n / 2
    hvis (n % 2 == 1) { returner s[midt] }
    returner (s[midt - 1] + s[midt]) / 2
}

# Nedre median (alltid eit element frå lista)
funksjon median_låg(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la s = _sorter(l)
    returner s[(n - 1) / 2]
}

# Øvre median
funksjon median_høg(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la s = _sorter(l)
    returner s[n / 2]
}

# ─── Modus ────────────────────────────────────────────────────────────────────

funksjon modus(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la verdiar: liste_heltall = []
    la teljing: liste_heltall = []
    la i: heltall = 0
    mens (i < n) {
        la v: heltall = l[i]
        la funne: bool = usann
        la j: heltall = 0
        mens (j < lengde(verdiar)) {
            hvis (verdiar[j] == v) { teljing[j] = teljing[j] + 1  funne = sann  j = lengde(verdiar) }
            j = j + 1
        }
        hvis (ikkje funne) { legg_til(verdiar, v)  legg_til(teljing, 1) }
        i = i + 1
    }
    la beste_v: heltall = verdiar[0]
    la beste_n: heltall = teljing[0]
    la j: heltall = 1
    mens (j < lengde(verdiar)) {
        hvis (teljing[j] > beste_n) { beste_n = teljing[j]  beste_v = verdiar[j] }
        j = j + 1
    }
    returner beste_v
}

# Alle modusar (multimodal)
funksjon alle_modusar(l: liste_heltall) -> liste_heltall {
    la n: heltall = lengde(l)
    la verdiar: liste_heltall = []
    la teljing: liste_heltall = []
    la i: heltall = 0
    mens (i < n) {
        la v: heltall = l[i]
        la funne: bool = usann
        la j: heltall = 0
        mens (j < lengde(verdiar)) {
            hvis (verdiar[j] == v) { teljing[j] = teljing[j] + 1  funne = sann  j = lengde(verdiar) }
            j = j + 1
        }
        hvis (ikkje funne) { legg_til(verdiar, v)  legg_til(teljing, 1) }
        i = i + 1
    }
    la maks_n: heltall = 0
    la j: heltall = 0
    mens (j < lengde(teljing)) { hvis (teljing[j] > maks_n) { maks_n = teljing[j] }  j = j + 1 }
    la ut: liste_heltall = []
    j = 0
    mens (j < lengde(verdiar)) { hvis (teljing[j] == maks_n) { legg_til(ut, verdiar[j]) }  j = j + 1 }
    returner ut
}

# ─── Varians ──────────────────────────────────────────────────────────────────

# Populasjonsvarians * 100
funksjon varians_x100(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la snitt: heltall = gjennomsnitt_x100(l)
    la sum_sq: heltall = 0
    la i: heltall = 0
    mens (i < n) {
        la diff: heltall = l[i] * 100 - snitt
        sum_sq = sum_sq + diff * diff
        i = i + 1
    }
    returner sum_sq / (n * 100)
}

funksjon varians(l: liste_heltall) -> heltall {
    returner varians_x100(l) / 100
}

# Stikkprøvevarians (deler på n-1, Bessel-korreksjon)
funksjon varians_utvalg_x100(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n <= 1) { returner 0 }
    la snitt: heltall = gjennomsnitt_x100(l)
    la sum_sq: heltall = 0
    la i: heltall = 0
    mens (i < n) {
        la diff: heltall = l[i] * 100 - snitt
        sum_sq = sum_sq + diff * diff
        i = i + 1
    }
    returner sum_sq / ((n - 1) * 100)
}

funksjon varians_utvalg(l: liste_heltall) -> heltall {
    returner varians_utvalg_x100(l) / 100
}

# ─── Standardavvik ────────────────────────────────────────────────────────────

# Standardavvik (heltall, trunkert)
funksjon standardavvik(l: liste_heltall) -> heltall {
    returner _krot(varians(l))
}

# Standardavvik * 10 — éin desimal
funksjon standardavvik_x10(l: liste_heltall) -> heltall {
    returner _krot(varians_x100(l))
}

# Stikkprøve-standardavvik * 10
funksjon standardavvik_utvalg_x10(l: liste_heltall) -> heltall {
    returner _krot(varians_utvalg_x100(l))
}

# ─── Persentil og kvartil ─────────────────────────────────────────────────────

funksjon persentil(l: liste_heltall, p: heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la s = _sorter(l)
    hvis (p <= 0)   { returner s[0] }
    hvis (p >= 100) { returner s[n - 1] }
    returner s[p * (n - 1) / 100]
}

funksjon q1(l: liste_heltall) -> heltall  {
    returner persentil(l, 25)
}
funksjon q2(l: liste_heltall) -> heltall  {
    returner median(l)
}
funksjon q3(l: liste_heltall) -> heltall  {
    returner persentil(l, 75)
}

funksjon iqr(l: liste_heltall) -> heltall {
    returner q3(l) - q1(l)
}

# ─── Kovarians og korrelasjon ─────────────────────────────────────────────────

funksjon kovarians_x100(x: liste_heltall, y: liste_heltall) -> heltall {
    la n: heltall = lengde(x)
    hvis (n == 0 eller n != lengde(y)) { returner 0 }
    la mx: heltall = gjennomsnitt_x100(x)
    la my: heltall = gjennomsnitt_x100(y)
    la sum_prod: heltall = 0
    la i: heltall = 0
    mens (i < n) {
        sum_prod = sum_prod + (x[i] * 100 - mx) * (y[i] * 100 - my)
        i = i + 1
    }
    returner sum_prod / (n * 100)
}

# Pearson-korrelasjon * 100 (−100 til 100)
funksjon korrelasjon_x100(x: liste_heltall, y: liste_heltall) -> heltall {
    la cov: heltall = kovarians_x100(x, y)
    la sx: heltall  = standardavvik_x10(x)
    la sy: heltall  = standardavvik_x10(y)
    hvis (sx == 0 eller sy == 0) { returner 0 }
    returner cov * 100 / (sx * sy)
}

# ─── Z-score ──────────────────────────────────────────────────────────────────

# Z-score * 100 for element i
funksjon z_score_x100(l: liste_heltall, i: heltall) -> heltall {
    la sd: heltall = standardavvik_x10(l)
    hvis (sd == 0) { returner 0 }
    la snitt: heltall = gjennomsnitt_x100(l)
    returner (l[i] * 100 - snitt) * 10 / sd
}

# ─── Normaliserering ──────────────────────────────────────────────────────────

# Min-maks til 0–100
funksjon normaliser(l: liste_heltall) -> liste_heltall {
    la mn: heltall = min(l)
    la mx: heltall = maks(l)
    la spd: heltall = mx - mn
    la r: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        hvis (spd == 0) { legg_til(r, 0) }
        ellers { legg_til(r, (l[i] - mn) * 100 / spd) }
        i = i + 1
    }
    returner r
}

# ─── Utliggjar-deteksjon (IQR-metode) ────────────────────────────────────────

# Returner indeksane til utliggjarar (verdiar utanfor [Q1 − 1.5×IQR, Q3 + 1.5×IQR])
funksjon utliggjarar(l: liste_heltall) -> liste_heltall {
    la iqr_v: heltall = iqr(l)
    la nedre: heltall = q1(l) - iqr_v * 3 / 2
    la øvre: heltall  = q3(l) + iqr_v * 3 / 2
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        hvis (l[i] < nedre eller l[i] > øvre) { legg_til(ut, i) }
        i = i + 1
    }
    returner ut
}

# ─── Frekvensfordeling ────────────────────────────────────────────────────────

# Returner [verdi, antal]-par flatt (verdi0, antal0, verdi1, antal1, ...)
funksjon frekvens(l: liste_heltall) -> liste_heltall {
    la verdiar: liste_heltall = []
    la teljing: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(l)) {
        la v: heltall = l[i]
        la funne: bool = usann
        la j: heltall = 0
        mens (j < lengde(verdiar)) {
            hvis (verdiar[j] == v) { teljing[j] = teljing[j] + 1  funne = sann  j = lengde(verdiar) }
            j = j + 1
        }
        hvis (ikkje funne) { legg_til(verdiar, v)  legg_til(teljing, 1) }
        i = i + 1
    }
    la ut: liste_heltall = []
    la j: heltall = 0
    mens (j < lengde(verdiar)) { legg_til(ut, verdiar[j])  legg_til(ut, teljing[j])  j = j + 1 }
    returner ut
}

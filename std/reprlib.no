# reprlib.no — Avkorta representasjonar
# Python: reprlib
#
# Lagar kompakte/avkorta tekstrepresentasjonar av datastrukturar
# for debugging og logging. Viser delvis innhald med "..." for store objekt.
#
# Innstillingar (jf. Python reprlib.Repr):
#   maks_tekst:    maks tal teikn i tekst-verdiar (standard 30)
#   maks_liste:    maks element i liste (standard 6)
#   maks_ordbok:   maks nøklar i ordbok (standard 4)
#   maks_dybde:    maks rekursjons-dybde (standard 3)
#   maks_heltall:  maks siffer i heltall (standard 40)
#
# Bruk:
#   bruk std.reprlib som rl
#   skriv rl.repr_t("ein veldig lang tekst som vert avkorta")
#   skriv rl.repr_liste(["a","b","c","d","e","f","g"])
#   skriv rl.repr_ordbok(d)
#   la r = rl.ny_repr(20, 3, 2, 2, 10)  # tilpassa grenser

# ─── Konfigurasjonsobjekt ─────────────────────────────────────────────────────

funksjon ny_repr(maks_tekst: heltall, maks_liste: heltall,
                  maks_ordbok: heltall, maks_dybde: heltall,
                  maks_heltall: heltall) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    r["maks_tekst"] = tekst_fra_heltall(maks_tekst)
    r["maks_liste"] = tekst_fra_heltall(maks_liste)
    r["maks_ordbok"] = tekst_fra_heltall(maks_ordbok)
    r["maks_dybde"] = tekst_fra_heltall(maks_dybde)
    r["maks_heltall"] = tekst_fra_heltall(maks_heltall)
    returner r
}

funksjon standard_repr() -> ordbok_tekst {
    returner ny_repr(30, 6, 4, 3, 40)
}

# ─── Grunnleggende repr-funksjonar ────────────────────────────────────────────

# Tekst-repr med avkorting
funksjon repr_t(s: tekst) -> tekst {
    returner repr_t_n(s, 30)
}

funksjon repr_t_n(s: tekst, maks: heltall) -> tekst {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la escaped: tekst = _escape(s)
    la esc_teikn = builtin.split(escaped, "")
    la el: heltall = lengde(esc_teikn)
    hvis (el <= maks) {
        returner "'" + escaped + "'"
    }
    la avkorta: tekst = builtin.join(builtin.slice(esc_teikn, 0, maks - 3), "")
    returner "'" + avkorta + "...'"
}

# Heltall-repr (avkorting berre for svært store tal)
funksjon repr_h(n: heltall) -> tekst {
    returner repr_h_n(n, 40)
}

funksjon repr_h_n(n: heltall, maks: heltall) -> tekst {
    la s: tekst = tekst_fra_heltall(n)
    la teikn = builtin.split(s, "")
    la l: heltall = lengde(teikn)
    hvis (l <= maks) { returner s }
    returner builtin.join(builtin.slice(teikn, 0, maks - 3), "") + "..."
}

# Bool-repr
funksjon repr_b(b: bool) -> tekst {
    hvis (b) { returner "sann" }
    returner "usann"
}

# ─── Samlingsrepresentasjonar ─────────────────────────────────────────────────

funksjon repr_liste_t(l: liste_tekst) -> tekst {
    returner repr_liste_t_n(l, 6, 30, 0)
}

funksjon repr_liste_t_n(l: liste_tekst, maks_element: heltall,
                         maks_tekst: heltall, dybde: heltall) -> tekst {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner "[]" }
    la delar: liste_tekst = []
    la vis: heltall = n
    la avkorta: bool = usann
    hvis (vis > maks_element) { vis = maks_element  avkorta = sann }
    la i: heltall = 0
    mens (i < vis) {
        legg_til(delar, repr_t_n(l[i], maks_tekst))
        i = i + 1
    }
    la innhald: tekst = builtin.join(delar, ", ")
    hvis (avkorta) {
        innhald = innhald + ", ..."
    }
    returner "[" + innhald + "]"
}

funksjon repr_liste_h(l: liste_heltall) -> tekst {
    returner repr_liste_h_n(l, 6, 40)
}

funksjon repr_liste_h_n(l: liste_heltall, maks_element: heltall, maks_int: heltall) -> tekst {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner "[]" }
    la delar: liste_tekst = []
    la vis: heltall = n
    la avkorta: bool = usann
    hvis (vis > maks_element) { vis = maks_element  avkorta = sann }
    la i: heltall = 0
    mens (i < vis) {
        legg_til(delar, repr_h_n(l[i], maks_int))
        i = i + 1
    }
    la innhald: tekst = builtin.join(delar, ", ")
    hvis (avkorta) { innhald = innhald + ", ..." }
    returner "[" + innhald + "]"
}

funksjon repr_ordbok(d: ordbok_tekst) -> tekst {
    returner repr_ordbok_n(d, 4, 30, 0)
}

funksjon repr_ordbok_n(d: ordbok_tekst, maks_nøklar: heltall,
                        maks_tekst: heltall, dybde: heltall) -> tekst {
    la nøklar = builtin.nøkler(d)
    la n: heltall = lengde(nøklar)
    hvis (n == 0) { returner "{}" }
    la delar: liste_tekst = []
    la vis: heltall = n
    la avkorta: bool = usann
    hvis (vis > maks_nøklar) { vis = maks_nøklar  avkorta = sann }
    la i: heltall = 0
    mens (i < vis) {
        la nk: tekst = nøklar[i]
        la v: tekst = d[nk]
        legg_til(delar, repr_t_n(nk, maks_tekst) + ": " + repr_t_n(v, maks_tekst))
        i = i + 1
    }
    la innhald: tekst = builtin.join(delar, ", ")
    hvis (avkorta) { innhald = innhald + ", ..." }
    returner "{" + innhald + "}"
}

# ─── Generisk repr (prøver å detektere type) ─────────────────────────────────

funksjon repr_auto(s: tekst) -> tekst {
    returner repr_auto_n(s, 30, 6, 4)
}

funksjon repr_auto_n(s: tekst, maks_tekst: heltall,
                      maks_liste: heltall, maks_ordbok: heltall) -> tekst {
    # Er det JSON?
    prøv {
        la parsed = builtin.json_parse(s)
        la nøklar = builtin.nøkler(parsed)
        returner repr_ordbok_n(parsed, maks_ordbok, maks_tekst, 0)
    } fang (e1) {}

    # Er det eit heltall?
    prøv {
        la n: heltall = builtin.heltall_fra_tekst(s)
        returner repr_h(n)
    } fang (e2) {}

    # Behandle som tekst
    returner repr_t_n(s, maks_tekst)
}

# ─── Konfigurerbar Repr-instans ───────────────────────────────────────────────

funksjon repr_med_konfig(r: ordbok_tekst, s: tekst) -> tekst {
    la mt: heltall = builtin.heltall_fra_tekst(r["maks_tekst"])
    la ml: heltall = builtin.heltall_fra_tekst(r["maks_liste"])
    la md: heltall = builtin.heltall_fra_tekst(r["maks_ordbok"])
    returner repr_auto_n(s, mt, ml, md)
}

funksjon repr_liste_med_konfig(r: ordbok_tekst, l: liste_tekst) -> tekst {
    la mt: heltall = builtin.heltall_fra_tekst(r["maks_tekst"])
    la ml: heltall = builtin.heltall_fra_tekst(r["maks_liste"])
    returner repr_liste_t_n(l, ml, mt, 0)
}

funksjon repr_ordbok_med_konfig(r: ordbok_tekst, d: ordbok_tekst) -> tekst {
    la mt: heltall = builtin.heltall_fra_tekst(r["maks_tekst"])
    la md: heltall = builtin.heltall_fra_tekst(r["maks_ordbok"])
    returner repr_ordbok_n(d, md, mt, 0)
}

# ─── Rekursiv repr med dybde-avkorting ───────────────────────────────────────

funksjon repr_dybde(s: tekst, dybde: heltall, maks_dybde: heltall) -> tekst {
    hvis (dybde >= maks_dybde) { returner "..." }
    prøv {
        la parsed = builtin.json_parse(s)
        la nøklar = builtin.nøkler(parsed)
        la n: heltall = lengde(nøklar)
        la delar: liste_tekst = []
        la vis: heltall = n
        hvis (vis > 4) { vis = 4 }
        la i: heltall = 0
        mens (i < vis) {
            la nk: tekst = nøklar[i]
            la v: tekst = parsed[nk]
            la v_repr: tekst = repr_dybde(v, dybde + 1, maks_dybde)
            legg_til(delar, repr_t_n(nk, 20) + ": " + v_repr)
            i = i + 1
        }
        la innhald: tekst = builtin.join(delar, ", ")
        hvis (n > 4) { innhald = innhald + ", ..." }
        returner "{" + innhald + "}"
    } fang (e) {}
    returner repr_t_n(s, 30)
}

# ─── Kompakt einlinje-format ──────────────────────────────────────────────────

# Sameint ordbok til einlinje med maks bredde
funksjon kompakt_repr(d: ordbok_tekst, maks_bredde: heltall) -> tekst {
    la full: tekst = repr_ordbok(d)
    la teikn = builtin.split(full, "")
    la n: heltall = lengde(teikn)
    hvis (n <= maks_bredde) { returner full }
    la avkorta: tekst = builtin.join(builtin.slice(teikn, 0, maks_bredde - 3), "")
    returner avkorta + "..."
}

# ─── Hjelpefunksjonar ─────────────────────────────────────────────────────────

funksjon _escape(s: tekst) -> tekst {
    la delar = builtin.split(s, "'")
    la escaped: tekst = builtin.join(delar, "\\'")
    la delar2 = builtin.split(escaped, "\n")
    escaped = builtin.join(delar2, "\\n")
    la delar3 = builtin.split(escaped, "\t")
    escaped = builtin.join(delar3, "\\t")
    la delar4 = builtin.split(escaped, "\r")
    escaped = builtin.join(delar4, "\\r")
    returner escaped
}

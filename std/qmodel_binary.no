# qmodel_binary.no — kompakt binært format for norscode.qmodel.v1

bruk std.model_runtime som model_runtime
bruk std.fil som fil

funksjon _u8(ut: liste_heltall, v: heiltall) {
    hvis v < 0 eller v > 255 { kast "QModellBinærFeil: u8 utanfor område" }
    legg_til(ut, v)
}

funksjon _u16(ut: liste_heltall, v: heiltall) {
    hvis v < 0 eller v > 65535 { kast "QModellBinærFeil: u16 utanfor område" }
    legg_til(ut, v % 256)
    legg_til(ut, (v / 256) % 256)
}

funksjon _u32(ut: liste_heltall, v: heiltall) {
    hvis v < 0 eller v > 4294967295 { kast "QModellBinærFeil: u32 utanfor område" }
    legg_til(ut, v % 256)
    legg_til(ut, (v / 256) % 256)
    legg_til(ut, (v / 65536) % 256)
    legg_til(ut, (v / 16777216) % 256)
}

funksjon _i32(ut: liste_heltall, v: heiltall) {
    hvis v < -2147483648 eller v > 2147483647 { kast "QModellBinærFeil: i32 utanfor område" }
    la rå = v
    hvis rå < 0 { rå = rå + 4294967296 }
    _u32(ut, rå)
}

funksjon _aktivering_kode(namn: tekst) -> heiltall {
    hvis namn == "ingen" { returner 0 }
    hvis namn == "relu" { returner 1 }
    hvis namn == "hard_tanh" { returner 2 }
    kast "QModellBinærFeil: ukjent aktivering"
}

funksjon _aktivering_namn(kode: heiltall) -> tekst {
    hvis kode == 0 { returner "ingen" }
    hvis kode == 1 { returner "relu" }
    hvis kode == 2 { returner "hard_tanh" }
    kast "QModellBinærFeil: ukjent aktiveringskode"
}

funksjon kod(modell) -> liste_heltall {
    la ut: liste_heltall = [78, 81, 77, 49]
    _u16(ut, 1)
    _u16(ut, lengde(modell["lag"]))
    _u32(ut, modell["input_dim"])
    la navn = modell["navn"]
    _u16(ut, lengde(navn))
    la ni: heiltall = 0
    mens ni < lengde(navn) {
        la kode = builtin.char_code(navn[ni])
        hvis kode < 0 eller kode > 127 { kast "QModellBinærFeil: modellnavn må vere ASCII" }
        _u8(ut, kode)
        ni = ni + 1
    }
    la i: heiltall = 0
    mens i < lengde(modell["lag"]) {
        la lag = modell["lag"][i]
        hvis lag["type"] != "dense" { kast "QModellBinærFeil: berre dense er støtta i v1" }
        _u8(ut, 1)
        _u8(ut, _aktivering_kode(lag["aktivering"]))
        _u16(ut, 0)
        _u32(ut, lag["input_dim"])
        _u32(ut, lag["output_dim"])
        _u32(ut, lag["divisor"])
        _u32(ut, lengde(lag["vekter"]))
        _u32(ut, lengde(lag["bias"]))
        la wi: heiltall = 0
        mens wi < lengde(lag["vekter"]) {
            la w = lag["vekter"][wi]
            hvis w < -128 eller w > 127 { kast "QModellBinærFeil: vekt utanfor int8" }
            _u8(ut, w + 128)
            wi = wi + 1
        }
        la bi: heiltall = 0
        mens bi < lengde(lag["bias"]) {
            _i32(ut, lag["bias"][bi])
            bi = bi + 1
        }
        i = i + 1
    }
    returner ut
}

funksjon _les_u8(lesar) -> heiltall {
    hvis lesar["pos"] >= lengde(lesar["data"]) { kast "QModellBinærFeil: avkorta fil" }
    la v = lesar["data"][lesar["pos"]]
    lesar["pos"] = lesar["pos"] + 1
    returner v
}

funksjon _les_u16(lesar) -> heiltall {
    la a = _les_u8(lesar)
    la b = _les_u8(lesar)
    returner a + b * 256
}

funksjon _les_u32(lesar) -> heiltall {
    la a = _les_u8(lesar)
    la b = _les_u8(lesar)
    la c = _les_u8(lesar)
    la d = _les_u8(lesar)
    returner a + b * 256 + c * 65536 + d * 16777216
}

funksjon _les_i32(lesar) -> heiltall {
    la v = _les_u32(lesar)
    hvis v >= 2147483648 { returner v - 4294967296 }
    returner v
}

funksjon dekod(data: liste_heltall, maks_parametre: heiltall) {
    hvis maks_parametre <= 0 { kast "QModellBinærFeil: ugyldig parametergrense" }
    la lesar: ordbok = {"data": data, "pos": 0}
    hvis _les_u8(lesar) != 78 eller _les_u8(lesar) != 81 eller _les_u8(lesar) != 77 eller _les_u8(lesar) != 49 {
        kast "QModellBinærFeil: ugyldig magic"
    }
    hvis _les_u16(lesar) != 1 { kast "QModellBinærFeil: ukjent versjon" }
    la lag_antal = _les_u16(lesar)
    hvis lag_antal > 128 { kast "QModellBinærFeil: for mange lag" }
    la input_dim = _les_u32(lesar)
    la navn_len = _les_u16(lesar)
    hvis navn_len > 1024 { kast "QModellBinærFeil: for langt modellnavn" }
    la navn = ""
    la ni: heiltall = 0
    mens ni < navn_len {
        navn = navn + builtin.chr(_les_u8(lesar))
        ni = ni + 1
    }
    la modell = model_runtime.ny(navn, input_dim)
    la i: heiltall = 0
    mens i < lag_antal {
        hvis _les_u8(lesar) != 1 { kast "QModellBinærFeil: ukjent lagtype" }
        la aktivering = _aktivering_namn(_les_u8(lesar))
        _les_u16(lesar)
        la inn = _les_u32(lesar)
        la ut_dim = _les_u32(lesar)
        la divisor = _les_u32(lesar)
        la w_count = _les_u32(lesar)
        la b_count = _les_u32(lesar)
        hvis w_count != inn * ut_dim eller b_count != ut_dim { kast "QModellBinærFeil: broten lagform" }
        hvis modell["parametre"] + w_count + b_count > maks_parametre { kast "QModellBinærFeil: parametergrense overskriden" }
        la vekter: liste_heltall = []
        la wi: heiltall = 0
        mens wi < w_count {
            legg_til(vekter, _les_u8(lesar) - 128)
            wi = wi + 1
        }
        la bias: liste_heltall = []
        la bi: heiltall = 0
        mens bi < b_count {
            legg_til(bias, _les_i32(lesar))
            bi = bi + 1
        }
        hvis ikkje model_runtime.legg_til_lag(modell, model_runtime.dense(inn, ut_dim, vekter, bias, divisor, aktivering)) {
            kast "QModellBinærFeil: broten modellgraf"
        }
        i = i + 1
    }
    hvis lesar["pos"] != lengde(data) { kast "QModellBinærFeil: uventa data etter modellen" }
    returner modell
}

funksjon lagre(modell, sti: tekst) -> boolsk {
    la data = kod(modell)
    returner fil.skriv_bytes(sti, data) == lengde(data)
}

funksjon last(sti: tekst, maks_parametre: heiltall) {
    returner dekod(fil.les_byte_liste(sti), maks_parametre)
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {"status": "eksperimentell", "format": "NQM1", "dekning": "versjonert binær qmodel med int8-vekter, int32-bias, bounds-sjekk, grafvalidering og parametergrense"}
}

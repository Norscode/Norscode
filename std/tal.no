# tal.no — Talteori og talutilitietar
# Python: math (gcd, lcm, isqrt), sympy (isprime, factorint)
#
# Bruk:
#   bruk std.tal som tal
#   skriv(tal.gcd(48, 18))          # => 6
#   skriv(tal.er_primtal(17))       # => sann
#   la f = tal.faktoriser(360)      # => [2,2,2,3,3,5]

# ─── Intern hjelp ─────────────────────────────────────────────────────────────

funksjon _abs(x: heltall) -> heltall {
    hvis (x < 0) { returner 0 - x }
    returner x
}

funksjon _krot(x: heltall) -> heltall {
    hvis (x <= 0) { returner 0 }
    la g: heltall = x / 2 + 1
    la i: heltall = 0
    mens (i < 64) {
        la ny: heltall = (g + x / g) / 2
        hvis (ny >= g) { returner g }
        g = ny
        i = i + 1
    }
    returner g
}

# ─── GCD og LCM ───────────────────────────────────────────────────────────────

# Største felles divisor (Euklids algoritme)
funksjon gcd(a: heltall, b: heltall) -> heltall {
    a = _abs(a)
    b = _abs(b)
    mens (b != 0) {
        la r: heltall = a % b
        a = b
        b = r
    }
    returner a
}

# Minste felles multiplum
funksjon lcm(a: heltall, b: heltall) -> heltall {
    la g: heltall = gcd(a, b)
    hvis (g == 0) { returner 0 }
    returner _abs(a / g * b)
}

# GCD for ei heil liste
funksjon gcd_liste(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la g: heltall = l[0]
    la i: heltall = 1
    mens (i < n) { g = gcd(g, l[i])  i = i + 1 }
    returner g
}

# LCM for ei heil liste
funksjon lcm_liste(l: liste_heltall) -> heltall {
    la n: heltall = lengde(l)
    hvis (n == 0) { returner 0 }
    la m: heltall = l[0]
    la i: heltall = 1
    mens (i < n) { m = lcm(m, l[i])  i = i + 1 }
    returner m
}

# ─── Primtal ──────────────────────────────────────────────────────────────────

funksjon er_primtal(n: heltall) -> bool {
    hvis (n < 2) { returner usann }
    hvis (n == 2) { returner sann }
    hvis (n % 2 == 0) { returner usann }
    la i: heltall = 3
    la grense: heltall = _krot(n) + 1
    mens (i <= grense) {
        hvis (n % i == 0) { returner usann }
        i = i + 2
    }
    returner sann
}

# Neste primtal ≥ n
funksjon neste_primtal(n: heltall) -> heltall {
    hvis (n <= 2) { returner 2 }
    la k: heltall = n
    hvis (k % 2 == 0) { k = k + 1 }
    mens (ikkje er_primtal(k)) { k = k + 2 }
    returner k
}

# Erastotenenes sikt: alle primtal ≤ grense
# Returnerer liste_heltall
funksjon sikt(grense: heltall) -> liste_heltall {
    la n: heltall = grense + 1
    # er_saman[i] = 0 tyder primtal
    la er_saman: liste_heltall = []
    la i: heltall = 0
    mens (i < n) { legg_til(er_saman, 0)  i = i + 1 }

    la p: heltall = 2
    mens (p * p <= grense) {
        hvis (er_saman[p] == 0) {
            la j: heltall = p * p
            mens (j <= grense) {
                er_saman[j] = 1
                j = j + p
            }
        }
        p = p + 1
    }

    la primtal: liste_heltall = []
    i = 2
    mens (i <= grense) {
        hvis (er_saman[i] == 0) { legg_til(primtal, i) }
        i = i + 1
    }
    returner primtal
}

# ─── Faktorisering ────────────────────────────────────────────────────────────

# Primfaktorisering — returnerer sortert liste (med repetisjonar)
funksjon faktoriser(n: heltall) -> liste_heltall {
    la faktorar: liste_heltall = []
    n = _abs(n)
    hvis (n <= 1) { returner faktorar }
    mens (n % 2 == 0) { legg_til(faktorar, 2)  n = n / 2 }
    la i: heltall = 3
    mens (i * i <= n) {
        mens (n % i == 0) { legg_til(faktorar, i)  n = n / i }
        i = i + 2
    }
    hvis (n > 1) { legg_til(faktorar, n) }
    returner faktorar
}

# Unike primfaktorar (utan repetisjon)
funksjon unike_faktorar(n: heltall) -> liste_heltall {
    la alle = faktoriser(n)
    la ut: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(alle)) {
        la v: heltall = alle[i]
        la funne: bool = usann
        la j: heltall = 0
        mens (j < lengde(ut)) {
            hvis (ut[j] == v) { funne = sann  j = lengde(ut) }
            j = j + 1
        }
        hvis (ikkje funne) { legg_til(ut, v) }
        i = i + 1
    }
    returner ut
}

# Alle divisorar av n (ikkje berre primfaktorar)
funksjon divisorar(n: heltall) -> liste_heltall {
    n = _abs(n)
    la ut: liste_heltall = []
    la i: heltall = 1
    mens (i * i <= n) {
        hvis (n % i == 0) {
            legg_til(ut, i)
            hvis (i != n / i) { legg_til(ut, n / i) }
        }
        i = i + 1
    }
    # Sorter (innsettingssortering)
    la m: heltall = lengde(ut)
    la j: heltall = 1
    mens (j < m) {
        la nøkkel: heltall = ut[j]
        la k: heltall = j - 1
        mens (k >= 0 og ut[k] > nøkkel) {
            ut[k + 1] = ut[k]
            k = k - 1
        }
        ut[k + 1] = nøkkel
        j = j + 1
    }
    returner ut
}

# Er n eit fullkomment tal? (sum av eigentlege divisorar = n)
funksjon er_fullkommen(n: heltall) -> bool {
    hvis (n < 2) { returner usann }
    la d = divisorar(n)
    la s: heltall = 0
    la i: heltall = 0
    mens (i < lengde(d) - 1) { s = s + d[i]  i = i + 1 }  # ekskluder n sjølv
    returner s == n
}

# ─── Potensar og røter ────────────────────────────────────────────────────────

# Heiltalspotens a^b (b ≥ 0)
funksjon potens(a: heltall, b: heltall) -> heltall {
    hvis (b == 0) { returner 1 }
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < b) { resultat = resultat * a  i = i + 1 }
    returner resultat
}

# Rask modulær potens: a^b mod m (square-and-multiply)
funksjon potens_mod(a: heltall, b: heltall, m: heltall) -> heltall {
    hvis (m == 1) { returner 0 }
    la resultat: heltall = 1
    a = a % m
    mens (b > 0) {
        hvis (b % 2 == 1) { resultat = resultat * a % m }
        b = b / 2
        a = a * a % m
    }
    returner resultat
}

# Heiltalskvadratrot (floor)
funksjon isqrt(n: heltall) -> heltall {
    returner _krot(n)
}

# Er n eit fullkommen kvadrat?
funksjon er_kvadrat(n: heltall) -> bool {
    la r: heltall = _krot(n)
    returner r * r == n
}

# ─── Fibonacci ────────────────────────────────────────────────────────────────

# n-te Fibonacci-tal (0-indeksert: fib(0)=0, fib(1)=1)
funksjon fib(n: heltall) -> heltall {
    hvis (n <= 0) { returner 0 }
    hvis (n == 1) { returner 1 }
    la a: heltall = 0
    la b: heltall = 1
    la i: heltall = 2
    mens (i <= n) {
        la c: heltall = a + b
        a = b
        b = c
        i = i + 1
    }
    returner b
}

# Fibonacci-sekvens frå fib(0) til fib(n)
funksjon fib_sekvens(n: heltall) -> liste_heltall {
    la ut: liste_heltall = []
    la a: heltall = 0
    la b: heltall = 1
    la i: heltall = 0
    mens (i <= n) {
        legg_til(ut, a)
        la c: heltall = a + b
        a = b
        b = c
        i = i + 1
    }
    returner ut
}

# ─── Binomialkoeffisient ──────────────────────────────────────────────────────

# C(n, k) — binomialkoeffisient
funksjon binom(n: heltall, k: heltall) -> heltall {
    hvis (k < 0 eller k > n) { returner 0 }
    hvis (k == 0 eller k == n) { returner 1 }
    # Bruk symmetri: C(n,k) = C(n,n-k)
    hvis (k > n - k) { k = n - k }
    la resultat: heltall = 1
    la i: heltall = 0
    mens (i < k) {
        resultat = resultat * (n - i) / (i + 1)
        i = i + 1
    }
    returner resultat
}

# ─── Modular aritmetikk ───────────────────────────────────────────────────────

# Modulær invers (a^-1 mod m), krev gcd(a,m)=1 — utvida Euklid
funksjon mod_invers(a: heltall, m: heltall) -> heltall {
    la g: heltall = m
    la x: heltall = 0
    la y: heltall = 1
    la a0: heltall = a
    mens (a0 != 0) {
        la q: heltall = g / a0
        la tmp: heltall = g - q * a0
        g = a0
        a0 = tmp
        tmp = x - q * y
        x = y
        y = tmp
    }
    hvis (g != 1) { returner -1 }  # ikkje eksisterer
    returner (x % m + m) % m
}

# Kinesisk restsats for to kongruensar: x ≡ r1 (mod m1), x ≡ r2 (mod m2)
funksjon crt(r1: heltall, m1: heltall, r2: heltall, m2: heltall) -> heltall {
    la g: heltall = gcd(m1, m2)
    hvis ((r2 - r1) % g != 0) { returner -1 }  # ingen løysing
    la m: heltall = m1 / g * m2
    la inv: heltall = mod_invers(m1 / g, m2 / g)
    returner (r1 + m1 * ((r2 - r1) / g % (m2 / g)) * inv) % m
}

# ─── Talsekvensrelatert ───────────────────────────────────────────────────────

# Er n eit Catalan-tal? Catalan(k) = C(2k,k)/(k+1)
funksjon catalan(k: heltall) -> heltall {
    returner binom(2 * k, k) / (k + 1)
}

# Eulers phi-funksjon φ(n) — antal heltall i [1,n] som er koprim med n
funksjon euler_phi(n: heltall) -> heltall {
    la resultat: heltall = n
    la p: heltall = 2
    la m: heltall = n
    mens (p * p <= m) {
        hvis (m % p == 0) {
            mens (m % p == 0) { m = m / p }
            resultat = resultat - resultat / p
        }
        p = p + 1
    }
    hvis (m > 1) { resultat = resultat - resultat / m }
    returner resultat
}

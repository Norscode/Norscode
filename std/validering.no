# validering.no — Inputvalidering
# Python: re, validators, cerberus
#
# Bruk:
#   bruk std.validering som val
#   skriv(val.er_epost("ola@example.com"))    # => sann
#   skriv(val.er_url("https://norscode.no"))  # => sann
#   skriv(val.er_heltall("42"))               # => sann
#   skriv(val.norsk_orgnr("974760673"))       # => sann

# ─── Hjelp: siffer-lister ─────────────────────────────────────────────────────

funksjon _er_siffer(c: tekst) -> bool {
    returner (c >= "0" og c <= "9")
}

funksjon _er_bokstav(c: tekst) -> bool {
    returner (c >= "a" og c <= "z") eller (c >= "A" og c <= "Z")
}

funksjon _er_alfanum(c: tekst) -> bool {
    returner _er_siffer(c) eller _er_bokstav(c)
}

# ─── Grunnleggande typar ──────────────────────────────────────────────────────

funksjon er_heltall(s: tekst) -> bool {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    hvis (n == 0) { returner usann }
    la start: heltall = 0
    hvis (teikn[0] == "-" eller teikn[0] == "+") { start = 1 }
    hvis (start >= n) { returner usann }
    la i: heltall = start
    mens (i < n) {
        hvis (ikkje _er_siffer(teikn[i])) { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon er_positivt_heltall(s: tekst) -> bool {
    hvis (ikkje er_heltall(s)) { returner usann }
    returner builtin.heltall_fra_tekst(s) > 0
}

funksjon er_tom(s: tekst) -> bool {
    returner lengde(builtin.split(s, "")) == 0
}

funksjon i_område(verdi: heltall, min: heltall, maks: heltall) -> bool {
    returner verdi >= min og verdi <= maks
}

funksjon min_lengde(s: tekst, min: heltall) -> bool {
    returner lengde(builtin.split(s, "")) >= min
}

funksjon maks_lengde(s: tekst, maks: heltall) -> bool {
    returner lengde(builtin.split(s, "")) <= maks
}

funksjon lengde_mellom(s: tekst, min: heltall, maks: heltall) -> bool {
    la n: heltall = lengde(builtin.split(s, ""))
    returner n >= min og n <= maks
}

# ─── E-post ───────────────────────────────────────────────────────────────────
# Enkel sjekk: inneheld @ og minst ein . etter @

funksjon er_epost(s: tekst) -> bool {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    hvis (n < 5) { returner usann }

    # Finn @
    la at_pos: heltall = -1
    la i: heltall = 0
    mens (i < n) {
        hvis (teikn[i] == "@") {
            hvis (at_pos >= 0) { returner usann }  # fleire @
            at_pos = i
        }
        i = i + 1
    }
    hvis (at_pos < 1) { returner usann }           # ingen @ eller @ først
    hvis (at_pos >= n - 2) { returner usann }      # @ til sist

    # Finn . etter @
    la har_punkt: bool = usann
    la j: heltall = at_pos + 1
    mens (j < n) {
        hvis (teikn[j] == ".") {
            hvis (j > at_pos + 1 og j < n - 1) {  # ikkje rett etter @ og ikkje til sist
                har_punkt = sann
            }
        }
        j = j + 1
    }
    returner har_punkt
}

# ─── URL ──────────────────────────────────────────────────────────────────────

funksjon er_url(s: tekst) -> bool {
    la n: heltall = lengde(builtin.split(s, ""))
    hvis (n < 8) { returner usann }
    la har_http: bool = tekst_starter_med(s, "http://") eller tekst_starter_med(s, "https://")
    hvis (ikkje har_http) { returner usann }
    # Må ha minst eitt teikn etter protokollen
    la etter_protokoll: heltall = 7
    hvis (tekst_starter_med(s, "https://")) { etter_protokoll = 8 }
    returner n > etter_protokoll
}

funksjon er_https_url(s: tekst) -> bool {
    returner tekst_starter_med(s, "https://") og lengde(builtin.split(s, "")) > 8
}

# ─── Dato (YYYY-MM-DD) ────────────────────────────────────────────────────────

funksjon er_dato(s: tekst) -> bool {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    hvis (n != 10) { returner usann }
    hvis (teikn[4] != "-" eller teikn[7] != "-") { returner usann }

    # Sjekk at resten er siffer
    la i: heltall = 0
    mens (i < 10) {
        hvis (i != 4 og i != 7) {
            hvis (ikkje _er_siffer(teikn[i])) { returner usann }
        }
        i = i + 1
    }

    # Grovsjekk månader og dagar
    la år: heltall = builtin.heltall_fra_tekst(builtin.slice(s, 0, 4))
    la mnd: heltall = builtin.heltall_fra_tekst(builtin.slice(s, 5, 7))
    la dag: heltall = builtin.heltall_fra_tekst(builtin.slice(s, 8, 10))

    hvis (mnd < 1 eller mnd > 12) { returner usann }
    hvis (dag < 1 eller dag > 31) { returner usann }
    hvis (år < 1) { returner usann }
    returner sann
}

# ─── Norsk organisasjonsnummer ────────────────────────────────────────────────
# 9 siffer, kontrollsiffer (Mod 11) — vekter: 3,2,7,6,5,4,3,2

funksjon norsk_orgnr(s: tekst) -> bool {
    # Fjern mellomrom
    la teikn = builtin.split(s, "")
    la rein: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        hvis (teikn[i] != " ") {
            legg_til(rein, teikn[i])
        }
        i = i + 1
    }
    hvis (lengde(rein) != 9) { returner usann }

    la vekter: liste_heltall = [3,2,7,6,5,4,3,2]
    la sum: heltall = 0
    la j: heltall = 0
    mens (j < 8) {
        hvis (ikkje _er_siffer(rein[j])) { returner usann }
        sum = sum + builtin.heltall_fra_tekst(rein[j]) * vekter[j]
        j = j + 1
    }
    la rest: heltall = sum % 11
    la kontroll: heltall = 0
    hvis (rest != 0) { kontroll = 11 - rest }
    hvis (kontroll == 10) { returner usann }  # ugyldig

    returner builtin.heltall_fra_tekst(rein[8]) == kontroll
}

# ─── Norsk fødselsnummer (11 siffer) ─────────────────────────────────────────
# Kontrollsifre k1 og k2 med to sett vekter

funksjon norsk_fnr(s: tekst) -> bool {
    la teikn = builtin.split(s, "")
    la rein: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        hvis (teikn[i] != " ") {
            legg_til(rein, teikn[i])
        }
        i = i + 1
    }
    hvis (lengde(rein) != 11) { returner usann }

    la j: heltall = 0
    mens (j < 11) {
        hvis (ikkje _er_siffer(rein[j])) { returner usann }
        j = j + 1
    }

    # Vekter for k1
    la v1: liste_heltall = [3,7,6,1,8,9,4,5,2,1,0]
    la sum1: heltall = 0
    la k: heltall = 0
    mens (k < 10) {
        sum1 = sum1 + builtin.heltall_fra_tekst(rein[k]) * v1[k]
        k = k + 1
    }
    la k1: heltall = 0
    la rest1: heltall = sum1 % 11
    hvis (rest1 != 0) { k1 = 11 - rest1 }
    hvis (k1 == 10) { returner usann }
    hvis (builtin.heltall_fra_tekst(rein[9]) != k1) { returner usann }

    # Vekter for k2
    la v2: liste_heltall = [5,4,3,2,7,6,5,4,3,2,1]
    la sum2: heltall = 0
    la m: heltall = 0
    mens (m < 11) {
        sum2 = sum2 + builtin.heltall_fra_tekst(rein[m]) * v2[m]
        m = m + 1
    }
    returner sum2 % 11 == 0
}

# ─── Passordstyrke (0–4) ─────────────────────────────────────────────────────
# 0=svakt, 1=greitt, 2=bra, 3=sterkt, 4=svært sterkt

funksjon passord_styrke(s: tekst) -> heltall {
    la teikn = builtin.split(s, "")
    la n: heltall = lengde(teikn)
    la poeng: heltall = 0

    # Lengde
    hvis (n >= 8)  { poeng = poeng + 1 }
    hvis (n >= 12) { poeng = poeng + 1 }
    hvis (n >= 16) { poeng = poeng + 1 }

    # Inneheld siffer
    la har_siffer: bool = usann
    la har_stor: bool = usann
    la har_liten: bool = usann
    la har_spesiell: bool = usann
    la i: heltall = 0
    mens (i < n) {
        la c: tekst = teikn[i]
        hvis (_er_siffer(c)) { har_siffer = sann }
        hvis (c >= "A" og c <= "Z") { har_stor = sann }
        hvis (c >= "a" og c <= "z") { har_liten = sann }
        hvis (ikkje _er_alfanum(c)) { har_spesiell = sann }
        i = i + 1
    }
    hvis (har_siffer)    { poeng = poeng + 1 }
    hvis (har_stor)      { poeng = poeng + 1 }
    hvis (har_liten)     { poeng = poeng + 1 }
    hvis (har_spesiell)  { poeng = poeng + 1 }

    # Normaliser til 0–4
    hvis (poeng >= 7) { returner 4 }
    hvis (poeng >= 5) { returner 3 }
    hvis (poeng >= 3) { returner 2 }
    hvis (poeng >= 2) { returner 1 }
    returner 0
}

funksjon passord_ok(s: tekst) -> bool {
    returner passord_styrke(s) >= 2
}

# ─── Kredittkort (Luhn-algoritme) ─────────────────────────────────────────────

funksjon luhn(s: tekst) -> bool {
    la teikn = builtin.split(s, "")
    la rein: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(teikn)) {
        la c: tekst = teikn[i]
        hvis (c != " " og c != "-") {
            hvis (ikkje _er_siffer(c)) { returner usann }
            legg_til(rein, builtin.heltall_fra_tekst(c))
        }
        i = i + 1
    }
    la n: heltall = lengde(rein)
    hvis (n < 13 eller n > 19) { returner usann }

    la sum: heltall = 0
    la dobbel: bool = usann
    la j: heltall = n - 1
    mens (j >= 0) {
        la d: heltall = rein[j]
        hvis (dobbel) {
            d = d * 2
            hvis (d > 9) { d = d - 9 }
        }
        sum = sum + d
        dobbel = ikkje dobbel
        j = j - 1
    }
    returner sum % 10 == 0
}

# ─── IP-adresse (IPv4) ────────────────────────────────────────────────────────

funksjon er_ipv4(s: tekst) -> bool {
    la delar = builtin.split(s, ".")
    hvis (lengde(delar) != 4) { returner usann }
    la i: heltall = 0
    mens (i < 4) {
        la del: tekst = delar[i]
        hvis (ikkje er_heltall(del)) { returner usann }
        la v: heltall = builtin.heltall_fra_tekst(del)
        hvis (v < 0 eller v > 255) { returner usann }
        i = i + 1
    }
    returner sann
}

# ─── Samlefunksjon: valider mot krav ─────────────────────────────────────────

funksjon valider_tekst(s: tekst, min_len: heltall, maks_len: heltall) -> bool {
    la n: heltall = lengde(builtin.split(s, ""))
    returner n >= min_len og n <= maks_len
}

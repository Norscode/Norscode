# Felles ABI for shell-fri prosess-start i native runtime og pure VM.

funksjon versjon() -> tekst { returner "norscode-process-spawn-v1" }
funksjon async_versjon() -> tekst { returner "norscode-native-process-v1" }

funksjon request(executable: tekst, args: liste_tekst, cwd: tekst, stdin: tekst,
                 timeout_ms: heiltall, max_output_bytes: heiltall) -> ordbok_tekst {
    returner {
        "abi": versjon(),
        "executable": executable,
        "args": args,
        "cwd": cwd,
        "stdin": stdin,
        "timeout_ms": tekst_fra_heltall(timeout_ms),
        "max_output_bytes": tekst_fra_heltall(max_output_bytes),
        "sandbox": "none",
        "max_memory_bytes": "536870912",
        "max_open_files": "64",
        "inherit_env": "1",
        "capture_stdout": "sann",
        "capture_stderr": "sann"
    }
}

funksjon _trygt_felt(verdi: tekst) -> boolsk {
    returner builtin.index_of(verdi, "\u0000") < 0 og builtin.index_of(verdi, "\n") < 0 og builtin.index_of(verdi, "\r") < 0
}

funksjon _gyldig_sandbox(profil: tekst) -> boolsk {
    returner profil == "none" eller profil == "restricted" eller
        profil == "no-network" eller profil == "no-write" eller profil == "pure"
}

funksjon _gyldige_grenser(r: ordbok_tekst) -> boolsk {
    la minne = heltall_fra_tekst(r["max_memory_bytes"])
    la filer = heltall_fra_tekst(r["max_open_files"])
    hvis minne < 0 eller minne > 8589934592 { returner usann }
    hvis filer < 0 eller filer > 4096 { returner usann }
    returner r["inherit_env"] == "0" eller r["inherit_env"] == "1"
}

funksjon gyldig_request(r: ordbok_tekst) -> boolsk {
    hvis ikkje finnes_nøkkel(r, "abi") eller ikkje finnes_nøkkel(r, "executable") eller
       ikkje finnes_nøkkel(r, "args") eller ikkje finnes_nøkkel(r, "cwd") eller
       ikkje finnes_nøkkel(r, "stdin") eller ikkje finnes_nøkkel(r, "timeout_ms") eller
       ikkje finnes_nøkkel(r, "max_output_bytes") eller ikkje finnes_nøkkel(r, "sandbox") eller
       ikkje finnes_nøkkel(r, "max_memory_bytes") eller ikkje finnes_nøkkel(r, "max_open_files") eller
       ikkje finnes_nøkkel(r, "inherit_env") { returner usann }
    hvis r["abi"] != versjon() eller r["executable"] == "" eller ikkje _trygt_felt(r["executable"]) { returner usann }
    hvis heltall_fra_tekst(r["timeout_ms"]) <= 0 eller heltall_fra_tekst(r["max_output_bytes"]) <= 0 { returner usann }
    hvis r["cwd"] != "" og ikkje _trygt_felt(r["cwd"]) { returner usann }
    hvis ikkje _trygt_felt(r["stdin"]) eller ikkje _gyldig_sandbox(r["sandbox"]) eller ikkje _gyldige_grenser(r) { returner usann }
    la args = r["args"]
    la i: heiltall = 0
    mens i < lengde(args) {
        hvis ikkje _trygt_felt(args[i]) { returner usann }
        i = i + 1
    }
    returner sann
}

funksjon resultat(status: tekst, pid: heiltall, exit_code: heiltall,
                   stdout: tekst, stderr: tekst, error: tekst) -> ordbok_tekst {
    returner {
        "abi": versjon(),
        "status": status,
        "pid": tekst_fra_heltall(pid),
        "exit_code": tekst_fra_heltall(exit_code),
        "stdout": stdout,
        "stderr": stderr,
        "error": error
    }
}

funksjon gyldig_resultat(r: ordbok_tekst) -> boolsk {
    hvis r["abi"] != versjon() { returner usann }
    hvis r["status"] != "ferdig" og r["status"] != "feil" og r["status"] != "timeout" og r["status"] != "signal" { returner usann }
    hvis heltall_fra_tekst(r["pid"]) < -1 { returner usann }
    hvis r["status"] == "ferdig" og heltall_fra_tekst(r["exit_code"]) < 0 { returner usann }
    returner sann
}

funksjon async_spawn_request(executable: tekst, args: liste_tekst, cwd: tekst,
                             stdin: tekst, timeout_ms: heiltall,
                             max_output_bytes: heiltall) -> ordbok_tekst {
    la r = request(executable, args, cwd, stdin, timeout_ms, max_output_bytes)
    r["abi"] = async_versjon()
    r["operation"] = "spawn_argv"
    returner r
}

funksjon sett_sandbox(r: ordbok_tekst, profile: tekst, max_memory_bytes: heiltall,
                      max_open_files: heiltall, inherit_env: boolsk) -> ordbok_tekst {
    r["sandbox"] = profile
    r["max_memory_bytes"] = tekst_fra_heltall(max_memory_bytes)
    r["max_open_files"] = tekst_fra_heltall(max_open_files)
    hvis inherit_env { r["inherit_env"] = "1" } ellers { r["inherit_env"] = "0" }
    returner r
}

funksjon async_operation(operation: tekst, handle: tekst) -> ordbok_tekst {
    returner {"abi": async_versjon(), "operation": operation, "handle": handle}
}

funksjon async_wait_request(handle: tekst, wait_ms: heiltall) -> ordbok_tekst {
    la r = async_operation("wait", handle)
    r["wait_ms"] = tekst_fra_heltall(wait_ms)
    returner r
}

funksjon async_signal_request(handle: tekst, signal: heiltall) -> ordbok_tekst {
    la r = async_operation("signal", handle)
    r["signal"] = tekst_fra_heltall(signal)
    returner r
}

funksjon gyldig_async_resultat(r: ordbok_tekst) -> boolsk {
    hvis ikkje finnes_nøkkel(r, "abi") eller ikkje finnes_nøkkel(r, "status") eller
       ikkje finnes_nøkkel(r, "pid") { returner usann }
    hvis r["abi"] != async_versjon() { returner usann }
    hvis r["status"] != "kjorer" og r["status"] != "ferdig" og r["status"] != "feil" og r["status"] != "timeout" og r["status"] != "signal" { returner usann }
    hvis r["status"] == "kjorer" og r["handle"] == "" { returner usann }
    returner heltall_fra_tekst(r["pid"]) >= -1
}

funksjon produksjonsstatus() -> ordbok_tekst {
    returner {
        "status": "delvis",
        "dekning": "versjonert shell-fri request/result-ABI med total fail-closed validering av felter, profil, miljø, minne og fd-grenser og generasjonsbunde levande native async-handle med argv, cwd, stdin, separate stdout/stderr-piper, poll, streaming, signal, timeout og close; eksplisitt sandboxprofil gir lukka miljo, CPU/core/fd-grenser, Linux seccomp no-network/no-write/pure, macOS Seatbelt no-network/no-write og forelderhandheva RSS-grense for sync/async",
        "mangler": "ekte Windows-verifisering av fail-closed AppContainer-isolasjon"
    }
}

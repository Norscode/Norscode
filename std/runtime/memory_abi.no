# Felles fysisk minne-ABI for pure VM, allocator og native ELF-runtime.

funksjon versjon() -> tekst { returner "norscode-memory-abi-v1" }
funksjon heap_base() -> heiltall { returner 6291456 }
funksjon heap_size() -> heiltall { returner 67108864 }
funksjon cursor_offset() -> heiltall { returner 0 }
funksjon envp_offset() -> heiltall { returner 8 }
funksjon gc_alloc_count_offset() -> heiltall { returner 16 }
funksjon gc_threshold_offset() -> heiltall { returner 24 }
funksjon gc_safepoint_count_offset() -> heiltall { returner 32 }
funksjon gc_collection_count_offset() -> heiltall { returner 40 }
funksjon gc_root_stack_offset() -> heiltall { returner 48 }
funksjon control_bytes() -> heiltall { returner 64 }
funksjon object_header_bytes() -> heiltall { returner 32 }
funksjon alignment() -> heiltall { returner 8 }
funksjon header_magic_0() -> heiltall { returner 78 }
funksjon header_magic_1() -> heiltall { returner 67 }
funksjon header_magic_2() -> heiltall { returner 71 }
funksjon header_magic_3() -> heiltall { returner 1 }
funksjon header_flags_offset() -> heiltall { returner 4 }
funksjon header_generation_offset() -> heiltall { returner 5 }
funksjon header_age_offset() -> heiltall { returner 6 }
funksjon header_type_offset() -> heiltall { returner 7 }
funksjon header_size_offset() -> heiltall { returner 8 }
funksjon header_first_edge_offset() -> heiltall { returner 16 }
funksjon header_ref_count_offset() -> heiltall { returner 24 }
funksjon flag_active() -> heiltall { returner 1 }
funksjon flag_marked() -> heiltall { returner 2 }
funksjon edge_type_tag() -> heiltall { returner 250 }
funksjon edge_payload_bytes() -> heiltall { returner 24 }
funksjon edge_from_offset() -> heiltall { returner 0 }
funksjon edge_to_offset() -> heiltall { returner 8 }
funksjon edge_next_offset() -> heiltall { returner 16 }

funksjon payload_base() -> heiltall { returner heap_base() + control_bytes() }
funksjon heap_limit() -> heiltall { returner heap_base() + heap_size() }
funksjon payload_capacity() -> heiltall { returner heap_limit() - payload_base() }
funksjon envp_address() -> heiltall { returner heap_base() + envp_offset() }

funksjon align_block(bytes: heiltall) -> heiltall {
    hvis bytes <= 0 { returner 0 }
    returner ((bytes + alignment() - 1) / alignment()) * alignment()
}

funksjon gyldig_payload_adresse(adresse: heiltall, bytes: heiltall) -> boolsk {
    hvis bytes < 0 eller adresse < payload_base() { returner usann }
    returner adresse + bytes <= heap_limit()
}

funksjon segment() -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["abi"] = versjon()
    s["base"] = tekst_fra_heltall(heap_base())
    s["size"] = tekst_fra_heltall(heap_size())
    s["limit"] = tekst_fra_heltall(heap_limit())
    s["control_bytes"] = tekst_fra_heltall(control_bytes())
    s["payload_base"] = tekst_fra_heltall(payload_base())
    s["payload_capacity"] = tekst_fra_heltall(payload_capacity())
    s["cursor_address"] = tekst_fra_heltall(heap_base() + cursor_offset())
    s["envp_address"] = tekst_fra_heltall(envp_address())
    s["gc_safepoint_address"] = tekst_fra_heltall(heap_base() + gc_safepoint_count_offset())
    s["object_header_bytes"] = tekst_fra_heltall(object_header_bytes())
    s["header_layout"] = "magic:u32,flags:u8,generation:u8,age:u8,type:u8,payload_size:u64le,first_edge:u64le,ref_count:u64le"
    s["alignment"] = tekst_fra_heltall(alignment())
    returner s
}

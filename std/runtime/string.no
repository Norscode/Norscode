pakke std.runtime

bruk std.runtime

struktur RuntimeString {
    data_peker: heiltall
    lengde: heiltall
    kapasitet: heiltall
}

funksjon ny_runtime_string(
    peker: heiltall,
    lengde: heiltall,
    kapasitet: heiltall
) -> RuntimeString {
    returner RuntimeString {
        data_peker: peker,
        lengde: lengde,
        kapasitet: kapasitet
    }
}

funksjon ny_streng(
    allocator: Allocator,
    kapasitet: heiltall
) -> RuntimeString {
    la justert = align8(kapasitet)

    la peker = alloker(
        allocator,
        justert
    )

    skriv("[string] allokert runtime string: ")
    skrivlinje(justert)

    returner ny_runtime_string(
        peker,
        0,
        justert
    )
}

funksjon streng_lengde(
    streng: RuntimeString
) -> heiltall {
    returner streng.lengde
}

funksjon streng_kapasitet(
    streng: RuntimeString
) -> heiltall {
    returner streng.kapasitet
}

funksjon streng_data(
    streng: RuntimeString
) -> heiltall {
    returner streng.data_peker
}

funksjon concat_placeholder(
    allocator: Allocator,
    venstre: RuntimeString,
    høyre: RuntimeString
) -> RuntimeString {
    la ny_kapasitet = (
        venstre.lengde + høyre.lengde
    ) + 1

    la resultat = ny_streng(
        allocator,
        ny_kapasitet
    )

    skriv("[string] concat placeholder størrelse: ")
    skrivlinje(ny_kapasitet)

    resultat.lengde = (
        venstre.lengde + høyre.lengde
    )

    returner resultat
}

funksjon compare_placeholder(
    venstre: RuntimeString,
    høyre: RuntimeString
) -> bool {
    hvis venstre.lengde != høyre.lengde {
        returner usann
    }

    returner sann
}

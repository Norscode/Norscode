# Registeruavhengige GC-primitivar over norscode-memory-abi-v1-headerar.

bruk std.runtime.memory_abi som abi
bruk std.runtime.allocator som allocator

funksjon _les_u64le(a, adresse: heiltall) -> heiltall {
    returner allocator.les_u64le(a, adresse)
}

funksjon gyldig_header(a, adresse: heiltall) -> boolsk {
    la prefix = allocator.les_bytes(a, adresse, 4)
    returner lengde(prefix) == 4 og prefix[0] == abi.header_magic_0() og
        prefix[1] == abi.header_magic_1() og prefix[2] == abi.header_magic_2() og
        prefix[3] == abi.header_magic_3()
}

funksjon header_info(a, adresse: heiltall) -> ordbok_tekst {
    la h: ordbok_tekst = {}
    h["valid"] = "usann"
    la prefix = allocator.les_bytes(a, adresse, 8)
    hvis lengde(prefix) != 8 eller prefix[0] != abi.header_magic_0() eller prefix[1] != abi.header_magic_1() eller prefix[2] != abi.header_magic_2() eller prefix[3] != abi.header_magic_3() { returner h }
    h["valid"] = "sann"
    h["address"] = tekst_fra_heltall(adresse)
    h["flags"] = tekst_fra_heltall(prefix[abi.header_flags_offset()])
    h["generation"] = tekst_fra_heltall(prefix[abi.header_generation_offset()])
    h["age"] = tekst_fra_heltall(prefix[abi.header_age_offset()])
    h["type"] = tekst_fra_heltall(prefix[abi.header_type_offset()])
    h["payload_size"] = tekst_fra_heltall(_les_u64le(a, adresse + abi.header_size_offset()))
    h["first_edge"] = tekst_fra_heltall(_les_u64le(a, adresse + abi.header_first_edge_offset()))
    h["ref_count"] = tekst_fra_heltall(_les_u64le(a, adresse + abi.header_ref_count_offset()))
    returner h
}

funksjon scan_compact_arena(a) -> liste_heiltall {
    la adresser = allocator.aktive_adresser(a)
    la i: heiltall = 0
    mens i < lengde(adresser) {
        hvis header_info(a, adresser[i])["valid"] != "sann" { returner [] }
        i = i + 1
    }
    returner adresser
}

funksjon sett_mark(a, adresse: heiltall, markert: boolsk) -> boolsk {
    hvis ikkje gyldig_header(a, adresse) { returner usann }
    la flags = abi.flag_active()
    hvis markert { flags = flags + abi.flag_marked() }
    returner allocator.skriv_byte(a, adresse + abi.header_flags_offset(), flags)
}

funksjon er_markert(a, adresse: heiltall) -> boolsk {
    hvis ikkje gyldig_header(a, adresse) { returner usann }
    la flags = allocator.les_byte(a, adresse + abi.header_flags_offset())
    returner flags >= abi.flag_marked()
}

funksjon er_edge(a, adresse: heiltall) -> boolsk {
    returner gyldig_header(a, adresse) og allocator.les_byte(a, adresse + abi.header_type_offset()) == abi.edge_type_tag()
}

funksjon edge_info(a, adresse: heiltall) -> ordbok_tekst {
    la e: ordbok_tekst = {"valid": "usann"}
    hvis ikkje er_edge(a, adresse) { returner e }
    la payload = adresse + abi.object_header_bytes()
    e["valid"] = "sann"
    e["address"] = tekst_fra_heltall(adresse)
    e["from"] = tekst_fra_heltall(_les_u64le(a, payload + abi.edge_from_offset()))
    e["to"] = tekst_fra_heltall(_les_u64le(a, payload + abi.edge_to_offset()))
    e["next"] = tekst_fra_heltall(_les_u64le(a, payload + abi.edge_next_offset()))
    returner e
}

funksjon _mark_adresse(a, adresse: heiltall) -> heiltall {
    hvis adresse <= 0 eller ikkje gyldig_header(a, adresse) eller er_edge(a, adresse) { returner 0 }
    hvis er_markert(a, adresse) { returner 0 }
    hvis ikkje sett_mark(a, adresse, sann) { returner 0 }
    la tal: heiltall = 1
    la info = header_info(a, adresse)
    la edge_adresse = heltall_fra_tekst(info["first_edge"])
    la expected = heltall_fra_tekst(info["ref_count"])
    la seen: heiltall = 0
    mens edge_adresse > 0 og seen < expected {
        la edge = edge_info(a, edge_adresse)
        hvis edge["valid"] != "sann" { returner tal }
        hvis heltall_fra_tekst(edge["from"]) != adresse { returner tal }
        tal = tal + _mark_adresse(a, heltall_fra_tekst(edge["to"]))
        edge_adresse = heltall_fra_tekst(edge["next"])
        seen = seen + 1
    }
    returner tal
}

funksjon nullstill_mark(a) -> heiltall {
    la adresser = scan_compact_arena(a)
    la tal: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(adresser) {
        hvis ikkje er_edge(a, adresser[i]) og er_markert(a, adresser[i]) {
            hvis sett_mark(a, adresser[i], usann) { tal = tal + 1 }
        }
        i = i + 1
    }
    returner tal
}

funksjon mark_fra_roter(a, root_adresser: liste_heiltall) -> ordbok_tekst {
    nullstill_mark(a)
    la marked: heiltall = 0
    la invalid_roots: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(root_adresser) {
        la root = root_adresser[i]
        hvis root <= 0 eller ikkje gyldig_header(a, root) eller er_edge(a, root) { invalid_roots = invalid_roots + 1 }
        ellers { marked = marked + _mark_adresse(a, root) }
        i = i + 1
    }
    returner {"marked": tekst_fra_heltall(marked), "invalid_roots": tekst_fra_heltall(invalid_roots)}
}

funksjon _frigjor_edge_kjede(a, objekt_adresse: heiltall) -> heiltall {
    la info = header_info(a, objekt_adresse)
    hvis info["valid"] != "sann" { returner 0 }
    la edge_adresse = heltall_fra_tekst(info["first_edge"])
    la expected = heltall_fra_tekst(info["ref_count"])
    la tal: heiltall = 0
    mens edge_adresse > 0 og tal < expected {
        la edge = edge_info(a, edge_adresse)
        hvis edge["valid"] != "sann" { returner tal }
        la next_edge = heltall_fra_tekst(edge["next"])
        hvis allocator.frigjor(a, edge_adresse) { tal = tal + 1 }
        edge_adresse = next_edge
    }
    returner tal
}

funksjon sweep_unmarked(a) -> ordbok_tekst {
    la adresser = scan_compact_arena(a)
    la freed_objects: heiltall = 0
    la freed_edges: heiltall = 0
    la survivors: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(adresser) {
        la adresse = adresser[i]
        hvis ikkje er_edge(a, adresse) {
            hvis er_markert(a, adresse) {
                sett_mark(a, adresse, usann)
                survivors = survivors + 1
            } ellers {
                freed_edges = freed_edges + _frigjor_edge_kjede(a, adresse)
                hvis allocator.frigjor(a, adresse) { freed_objects = freed_objects + 1 }
            }
        }
        i = i + 1
    }
    returner {"freed_objects": tekst_fra_heltall(freed_objects), "freed_edges": tekst_fra_heltall(freed_edges), "survivors": tekst_fra_heltall(survivors)}
}

funksjon collect_native(a, root_adresser: liste_heiltall) -> ordbok_tekst {
    la mark_result = mark_fra_roter(a, root_adresser)
    la sweep_result = sweep_unmarked(a)
    returner {"status": "ferdig", "marked": mark_result["marked"], "invalid_roots": mark_result["invalid_roots"], "freed_objects": sweep_result["freed_objects"], "freed_edges": sweep_result["freed_edges"], "survivors": sweep_result["survivors"], "error": ""}
}

funksjon collect_native_locked(a, lock: ordbok_tekst, owner: tekst,
                               root_adresser: liste_heiltall) -> ordbok_tekst {
    hvis ikkje allocator.allocator_lock(lock, owner) {
        returner {"status": "opptatt", "marked": "0", "invalid_roots": "0", "freed_objects": "0", "freed_edges": "0", "survivors": "0", "error": "allocator lock opptatt"}
    }
    prøv {
        la resultat = collect_native(a, root_adresser)
        allocator.allocator_unlock(lock, owner)
        returner resultat
    } fang (e) {
        allocator.allocator_unlock(lock, owner)
        returner {"status": "feil", "marked": "0", "invalid_roots": "0", "freed_objects": "0", "freed_edges": "0", "survivors": "0", "error": tekst(e)}
    }
    allocator.allocator_unlock(lock, owner)
    returner {"status": "feil", "marked": "0", "invalid_roots": "0", "freed_objects": "0", "freed_edges": "0", "survivors": "0", "error": "ukjent collector-feil"}
}

pakke std.runtime

bruk std.runtime

konstant MAP_DEFAULT_CAPACITY = 16

struktur RuntimeMapEntry {
    nøkkel_hash: heiltall
    nøkkel_peker: heiltall
    verdi_peker: heiltall
    opptatt: bool
}

struktur RuntimeMap {
    entries: RuntimeArray
    kapasitet: heiltall
    størrelse: heiltall
}

funksjon ny_entry() -> RuntimeMapEntry {
    returner RuntimeMapEntry {
        nøkkel_hash: 0,
        nøkkel_peker: 0,
        verdi_peker: 0,
        opptatt: usann
    }
}

funksjon ny_map(
    allocator: Allocator
) -> RuntimeMap {
    la entries = ny_array(
        allocator,
        MAP_DEFAULT_CAPACITY,
        32
    )

    skriv("[map] opprettet runtime map: ")
    skrivlinje(MAP_DEFAULT_CAPACITY)

    returner RuntimeMap {
        entries: entries,
        kapasitet: MAP_DEFAULT_CAPACITY,
        størrelse: 0
    }
}

funksjon hash_heiltall(verdi: heiltall) -> heiltall {
    returner (
        verdi * 2654435761
    ) og 0x7fffffff
}

funksjon hash_streng(
    streng: RuntimeString
) -> heiltall {
    la hash = 5381

    hash = (
        (hash << 5) + hash
    ) + streng.lengde

    returner hash og 0x7fffffff
}

funksjon bucket_index(
    map: RuntimeMap,
    hash: heiltall
) -> heiltall {
    returner hash % map.kapasitet
}

funksjon map_contains(
    map: RuntimeMap,
    hash: heiltall
) -> bool {
    la indeks = bucket_index(map, hash)

    hvis indeks >= map.entries.lengde {
        returner usann
    }

    returner sann
}

funksjon map_put(
    map: RuntimeMap,
    hash: heiltall,
    nøkkel_peker: heiltall,
    verdi_peker: heiltall
) {
    la indeks = bucket_index(map, hash)

    skriv("[map] put bucket: ")
    skrivlinje(indeks)

    hvis indeks >= map.entries.lengde {
        map.entries = append_placeholder(
            init_allocator(),
            map.entries
        )
    }

    map.størrelse = map.størrelse + 1
}

funksjon map_get(
    map: RuntimeMap,
    hash: heiltall
) -> heiltall {
    la indeks = bucket_index(map, hash)

    skriv("[map] get bucket: ")
    skrivlinje(indeks)

    hvis indeks >= map.entries.lengde {
        returner 0
    }

    returner indeks
}

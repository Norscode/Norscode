pakke std.runtime

bruk std.runtime

struktur RuntimeArray {
    data_peker: heiltall
    lengde: heiltall
    kapasitet: heiltall
    element_størrelse: heiltall
}

funksjon ny_runtime_array(
    peker: heiltall,
    lengde: heiltall,
    kapasitet: heiltall,
    element_størrelse: heiltall
) -> RuntimeArray {
    returner RuntimeArray {
        data_peker: peker,
        lengde: lengde,
        kapasitet: kapasitet,
        element_størrelse: element_størrelse
    }
}

funksjon ny_array(
    allocator: Allocator,
    kapasitet: heiltall,
    element_størrelse: heiltall
) -> RuntimeArray {
    la total_størrelse = align8(
        kapasitet * element_størrelse
    )

    la peker = alloker(
        allocator,
        total_størrelse
    )

    skriv("[array] allokert runtime array: ")
    skrivlinje(total_størrelse)

    returner ny_runtime_array(
        peker,
        0,
        kapasitet,
        element_størrelse
    )
}

funksjon array_lengde(
    array: RuntimeArray
) -> heiltall {
    returner array.lengde
}

funksjon array_kapasitet(
    array: RuntimeArray
) -> heiltall {
    returner array.kapasitet
}

funksjon array_data(
    array: RuntimeArray
) -> heiltall {
    returner array.data_peker
}

funksjon array_element_offset(
    array: RuntimeArray,
    indeks: heiltall
) -> heiltall {
    returner (
        array.data_peker +
        (indeks * array.element_størrelse)
    )
}

funksjon array_bounds_ok(
    array: RuntimeArray,
    indeks: heiltall
) -> bool {
    hvis indeks < 0 {
        returner usann
    }

    hvis indeks >= array.lengde {
        returner usann
    }

    returner sann
}

funksjon resize_placeholder(
    allocator: Allocator,
    array: RuntimeArray,
    ny_kapasitet: heiltall
) -> RuntimeArray {
    skriv("[array] resize placeholder: ")
    skrivlinje(ny_kapasitet)

    la nytt_array = ny_array(
        allocator,
        ny_kapasitet,
        array.element_størrelse
    )

    nytt_array.lengde = array.lengde

    returner nytt_array
}

funksjon append_placeholder(
    allocator: Allocator,
    array: RuntimeArray
) -> RuntimeArray {
    hvis array.lengde >= array.kapasitet {
        la ny_kapasitet = (
            array.kapasitet * 2
        ) + 1

        returner resize_placeholder(
            allocator,
            array,
            ny_kapasitet
        )
    }

    array.lengde = array.lengde + 1

    returner array
}

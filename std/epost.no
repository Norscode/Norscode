# epost.no — E-postsending for Norscode
# Django send_mail()-ekvivalent
#
# Bruk:
#   bruk std.epost som epost
#
#   la cfg = epost.smtp_cfg("smtp.gmail.com", 587, "user@gmail.com", "passord")
#   epost.send(cfg, "til@example.com", "Emne", "Tekstmeldinga her")
#   epost.send_html(cfg, "til@example.com", "Emne", html_innhald, tekst_innhald)
#
#   # Med mal-motor (std/mal.no)
#   epost.send_mal(cfg, "til@example.com", "Emne", "Hei {{namn}}!", {"namn": "Ola"})

bruk std.mal som mal
bruk std.http som http

# ─── SMTP-konfigurasjon ───────────────────────────────────────────────────────

funksjon smtp_cfg(host: tekst, port: heltall, brukar: tekst, passord: tekst) -> ordbok_tekst {
    la c: ordbok_tekst = {}
    c["host"]     = host
    c["port"]     = tekst_fra_heltall(port)
    c["brukar"]   = brukar
    c["passord"]  = passord
    c["frå"]      = brukar
    c["tls"]      = "sann"
    c["backend"]  = "smtp"
    returner c
}

funksjon smtp_cfg_full(host: tekst, port: heltall, brukar: tekst, passord: tekst, frå: tekst, tls: boolsk) -> ordbok_tekst {
    la c = smtp_cfg(host, port, brukar, passord)
    c["frå"]  = frå
    hvis tls {
        c["tls"] = "sann"
    } ellers {
        c["tls"] = "usann"
    }
    returner c
}

// Konfig frå innstillingar
funksjon cfg_frå_innstillingar(s: ordbok_tekst) -> ordbok_tekst {
    la c: ordbok_tekst = {}
    la hent_v = funksjon(k: tekst, std: tekst) -> tekst {
        hvis har_nokkel(s, k) { returner tekst(s[k]) }
        returner std
    }
    c["host"]    = hent_v("EMAIL_HOST",  hent_v("SMTP_HOST", "localhost"))
    c["port"]    = hent_v("EMAIL_PORT",  hent_v("SMTP_PORT", "587"))
    c["brukar"]  = hent_v("EMAIL_USER",  hent_v("SMTP_USER", ""))
    c["passord"] = hent_v("EMAIL_PASS",  hent_v("SMTP_PASS", ""))
    c["frå"]     = hent_v("EMAIL_FROM",  c["brukar"])
    c["tls"]     = "sann"
    c["backend"] = "smtp"
    returner c
}

# ─── Meldingsbygging ──────────────────────────────────────────────────────────

funksjon melding(frå: tekst, mottakar: tekst, emne: tekst, tekst_innhald: tekst) -> ordbok_tekst {
    returner {
        "frå": frå,
        "mottakar": mottakar,
        "emne": emne,
        "tekst": tekst_innhald,
        "html": "",
        "svar_til": "",
        "kopi": "",
        "blindkopi": "",
        "type": "tekst"
    }
}

funksjon melding_html(frå: tekst, mottakar: tekst, emne: tekst, html_innhald: tekst, tekst_fallback: tekst) -> ordbok_tekst {
    la m = melding(frå, mottakar, emne, tekst_fallback)
    m["html"] = html_innhald
    m["type"] = "html"
    returner m
}

funksjon legg_til_mottakar(m: ordbok_tekst, epost_adresse: tekst) -> ordbok_tekst {
    la eksisterande = m["mottakar"]
    hvis eksisterande == "" { m["mottakar"] = epost_adresse }
    ellers { m["mottakar"] = eksisterande + "," + epost_adresse }
    returner m
}

funksjon sett_svar_til(m: ordbok_tekst, adresse: tekst) -> ordbok_tekst {
    m["svar_til"] = adresse
    returner m
}

# ─── Sending ──────────────────────────────────────────────────────────────────

funksjon send(cfg: ordbok_tekst, mottakar: tekst, emne: tekst, tekst_innhald: tekst) -> boolsk {
    la m = melding(cfg["frå"], mottakar, emne, tekst_innhald)
    returner _send_melding(cfg, m)
}

funksjon send_html(cfg: ordbok_tekst, mottakar: tekst, emne: tekst, html_innhald: tekst, tekst_fallback: tekst) -> boolsk {
    la m = melding_html(cfg["frå"], mottakar, emne, html_innhald, tekst_fallback)
    returner _send_melding(cfg, m)
}

funksjon send_melding(cfg: ordbok_tekst, m: ordbok_tekst) -> boolsk {
    returner _send_melding(cfg, m)
}

funksjon send_mal(cfg: ordbok_tekst, mottakar: tekst, emne: tekst, tmpl: tekst, ctx: ordbok_tekst) -> boolsk {
    la innhald = mal.gjengi(tmpl, ctx)
    returner send(cfg, mottakar, emne, innhald)
}

funksjon send_html_mal(cfg: ordbok_tekst, mottakar: tekst, emne: tekst, html_tmpl: tekst, tekst_tmpl: tekst, ctx: ordbok_tekst) -> boolsk {
    la html_innhald = mal.gjengi(html_tmpl, ctx)
    la tekst_innhald = mal.gjengi(tekst_tmpl, ctx)
    returner send_html(cfg, mottakar, emne, html_innhald, tekst_innhald)
}

funksjon send_mange(cfg: ordbok_tekst, mottakarar: liste<tekst>, emne: tekst, innhald: tekst) -> heltall {
    la sendte: heltall = 0
    la i: heltall = 0
    mens i < lengde(mottakarar) {
        la adresse: tekst = mottakarar[i]
        hvis send(cfg, adresse, emne, innhald) { sendte = sendte + 1 }
        i = i + 1
    }
    returner sendte
}

# ─── Innebygde malar ──────────────────────────────────────────────────────────

funksjon velkomst_html(app_namn: tekst, brukarnamn: tekst, login_url: tekst) -> tekst {
    returner "<!DOCTYPE html><html><body style='font-family:sans-serif;max-width:600px;margin:2rem auto'>
<h2>Velkomen til " + app_namn + "!</h2>
<p>Hei <strong>" + brukarnamn + "</strong>,</p>
<p>Kontoen din er oppretta. Du kan no logge inn:</p>
<p><a href='" + login_url + "' style='background:#1a1a2e;color:white;padding:.6rem 1.2rem;border-radius:4px;text-decoration:none'>Logg inn</a></p>
<hr><p style='color:#6c757d;font-size:.85rem'>" + app_namn + "</p>
</body></html>"
}

funksjon passord_reset_html(app_namn: tekst, reset_url: tekst) -> tekst {
    returner "<!DOCTYPE html><html><body style='font-family:sans-serif;max-width:600px;margin:2rem auto'>
<h2>Nullstill passord</h2>
<p>Du (eller nokon) bad om å nullstille passordet for kontoen din i " + app_namn + ".</p>
<p>Klikk knappen under for å setje nytt passord:</p>
<p><a href='" + reset_url + "' style='background:#dc3545;color:white;padding:.6rem 1.2rem;border-radius:4px;text-decoration:none'>Nullstill passord</a></p>
<p style='color:#6c757d;font-size:.85rem'>Lenka er gyldig i 24 timar. Viss du ikkje bad om dette kan du sjå bort frå denne e-posten.</p>
<hr><p style='color:#6c757d;font-size:.85rem'>" + app_namn + "</p>
</body></html>"
}

funksjon varsling_html(app_namn: tekst, tittel: tekst, melding_tekst: tekst) -> tekst {
    returner "<!DOCTYPE html><html><body style='font-family:sans-serif;max-width:600px;margin:2rem auto'>
<h2>" + tittel + "</h2>
<p>" + melding_tekst + "</p>
<hr><p style='color:#6c757d;font-size:.85rem'>" + app_namn + "</p>
</body></html>"
}

# ─── Formatering ─────────────────────────────────────────────────────────────

funksjon _bygg_mime(m: ordbok_tekst) -> tekst {
    la crlf = "\r\n"
    la grense = "boundary_norscode_" + tekst_fra_heltall(lengde(m["emne"]))

    la headers = "From: " + m["frå"] + crlf +
                 "To: " + m["mottakar"] + crlf +
                 "Subject: " + _encode_emne(m["emne"]) + crlf +
                 "MIME-Version: 1.0" + crlf

    hvis m["svar_til"] != "" {
        headers = headers + "Reply-To: " + m["svar_til"] + crlf
    }

    hvis m["type"] == "html" og m["html"] != "" {
        headers = headers + "Content-Type: multipart/alternative; boundary=\"" + grense + "\"" + crlf + crlf
        la tekst_del = "--" + grense + crlf +
                       "Content-Type: text/plain; charset=utf-8" + crlf + crlf +
                       m["tekst"] + crlf
        la html_del  = "--" + grense + crlf +
                       "Content-Type: text/html; charset=utf-8" + crlf + crlf +
                       m["html"] + crlf
        returner headers + tekst_del + html_del + "--" + grense + "--"
    }

    headers = headers + "Content-Type: text/plain; charset=utf-8" + crlf + crlf
    returner headers + m["tekst"]
}

funksjon _encode_emne(emne: tekst) -> tekst {
    // Naiv UTF-8 Base64-encoding for emne (RFC 2047)
    // For enkel ASCII-emne, returner som-er
    la i: heltall = 0
    la alle_ascii: boolsk = sann
    la tegn = builtin.split(emne, "")
    mens i < lengde(tegn) {
        la code = builtin.char_code(tegn[i])
        hvis code > 127 { alle_ascii = usann }
        i = i + 1
    }
    hvis alle_ascii { returner emne }
    returner "=?UTF-8?B?" + builtin.base64_encode(emne) + "?="
}

# ─── Backend-sending ──────────────────────────────────────────────────────────

funksjon _send_melding(cfg: ordbok_tekst, m: ordbok_tekst) -> boolsk {
    la backend = cfg["backend"]

    // Prøv native SMTP-builtin
    prøv {
        la resultat = builtin.smtp_send(
            cfg["host"],
            heltall_fra_tekst(cfg["port"]),
            cfg["brukar"],
            cfg["passord"],
            m["frå"],
            m["mottakar"],
            m["emne"],
            m["tekst"],
            m["html"]
        )
        returner resultat
    } fang (e) { }

    // Prøv via HTTP API (sendgrid/mailgun-liknande)
    hvis har_nokkel(cfg, "api_url") og cfg["api_url"] != "" {
        returner _send_via_api(cfg, m)
    }

    // Prøv lokal sendmail
    prøv {
        la mime = _bygg_mime(m)
        la resultat = builtin.sendmail(m["mottakar"], mime)
        returner resultat
    } fang (e) { }

    // Fallback: logg til konsoll (for utvikling)
    hvis cfg["backend"] == "konsoll" eller hent_debug(cfg) {
        _logg_melding(m)
        returner sann
    }

        skriv("[epost] Advarsel: ingen SMTP-backend tilgjengeleg. Melding ikkje sendt til: " + m["mottakar"])
    returner usann
}

funksjon _send_via_api(cfg: ordbok_tekst, m: ordbok_tekst) -> boolsk {
    la api_url = cfg["api_url"]
    la api_nøkkel = cfg["api_nøkkel"]
    la body = "{\"from\":\"" + m["frå"] + "\",\"to\":\"" + m["mottakar"] +
              "\",\"subject\":\"" + m["emne"] + "\",\"text\":\"" + m["tekst"] + "\"}"
    la headers: ordbok_tekst = {
        "Authorization": "Bearer " + api_nøkkel,
        "Content-Type": "application/json"
    }
    prøv {
        la resp = http.request_full("POST", api_url, headers, {}, body, 15000)
        la status = http.response_status(resp)
        returner status >= 200 og status < 300
    } fang (e) {
        skriv("[epost] API-feil: " + e)
        returner usann
    }
    returner usann
}

funksjon _logg_melding(m: ordbok_tekst) -> heltall {
    skriv("========== E-POST (konsoll-modus) ==========")
    skriv("Frå:   " + m["frå"])
    skriv("Til:   " + m["mottakar"])
    skriv("Emne:  " + m["emne"])
    skriv("---")
    skriv(m["tekst"])
    skriv("============================================")
    returner 0
}

funksjon hent_debug(cfg: ordbok_tekst) -> boolsk {
    returner har_nokkel(cfg, "debug") og cfg["debug"] == "sann"
}

# ─── Konsoll-backend (for utvikling) ─────────────────────────────────────────

funksjon konsoll_cfg() -> ordbok_tekst {
    la c: ordbok_tekst = {}
    c["host"]    = "localhost"
    c["port"]    = "25"
    c["brukar"]  = ""
    c["passord"] = ""
    c["frå"]     = "noreply@localhost"
    c["backend"] = "konsoll"
    c["debug"]   = "sann"
    returner c
}

# httpserver.no - HTTP-server for Norscode
# Enkel, innebygd HTTP-server med request-routing
#
# Bruk:
#   bruk std.httpserver som http
#
#   funksjon hei(ctx) -> tekst {
#       returner "{\"melding\": \"Hei!\"}"
#   }
#
#   funksjon start() -> heltall {
#       server = http.ny_server(8000)
#       http.route(server, "GET", "/", hei)
#       http.route(server, "GET", "/api/data", hei)
#       returner http.lytt(server)
#   }

bruk std.web som web

# --- Server-objekt -----------------------------------------------------------

funksjon ny_server(port: heltall) -> ordbok_tekst {
    la s: ordbok_tekst = {}
    s["port"] = tekst(port)
    s["routes"] = {}
    s["handler_responses"] = {}
    s["handler_direct_responses"] = {}
    s["handler_response_status"] = {}
    s["handler_response_content_type"] = {}
    s["handler_response_headers"] = {}
    s["middleware"] = []
    s["request_middlewares"] = []
    s["response_middlewares"] = []
    s["error_middlewares"] = []
    s["startup_hooks"] = []
    s["shutdown_hooks"] = []
    returner s
}

# --- Route-registrering ------------------------------------------------------

funksjon route(server: ordbok_tekst, metode: tekst, sti: tekst, handler: tekst) -> ordbok_tekst {
    # Stottar handler som funksjonsnavn (streng)
    # Handler må ha signatur: funksjon(ctx) -> tekst
    la routes = server["routes"]
    la nokkel = metode + " " + sti
    routes[nokkel] = handler
    returner server
}

funksjon register_standard_health_routes(server: ordbok_tekst, handler: tekst) -> ordbok_tekst {
    route(server, "GET", "/helse", handler)
    route(server, "GET", "/health", handler)
    returner server
}

funksjon register_standard_server_components(server: ordbok_tekst, health_handler: tekst, request_middleware: tekst, response_middleware: tekst, error_middleware: tekst, startup_hook: tekst, shutdown_hook: tekst) -> ordbok_tekst {
    register_standard_health_routes(server, health_handler)
    hvis request_middleware != "" {
        register_request_middleware(server, request_middleware)
    }
    hvis response_middleware != "" {
        register_response_middleware(server, response_middleware)
    }
    hvis error_middleware != "" {
        register_error_middleware(server, error_middleware)
    }
    hvis startup_hook != "" {
        register_startup_hook(server, startup_hook)
    }
    hvis shutdown_hook != "" {
        register_shutdown_hook(server, shutdown_hook)
    }
    returner server
}

funksjon register_handler_response(server: ordbok_tekst, handler: tekst, body: tekst) -> ordbok_tekst {
    la responses = server["handler_responses"]
    responses[handler] = body
    returner server
}

funksjon register_handler_direct_response(server: ordbok_tekst, handler: tekst, response: ordbok_tekst) -> ordbok_tekst {
    la responses = server["handler_direct_responses"]
    responses[handler] = response
    returner server
}

funksjon register_handler_response_object(server: ordbok_tekst, handler: tekst, status: heiltall, body: tekst, content_type: tekst) -> ordbok_tekst {
    la responses = server["handler_responses"]
    la direct_responses = server["handler_direct_responses"]
    la statusar = server["handler_response_status"]
    la content_types = server["handler_response_content_type"]
    responses[handler] = body
    statusar[handler] = tekst(status)
    content_types[handler] = content_type
    returner server
}

funksjon register_handler_response_headers(server: ordbok_tekst, handler: tekst, headers: ordbok_tekst) -> ordbok_tekst {
    la header_map = server["handler_response_headers"]
    header_map[handler] = headers
    returner server
}

funksjon register_redirect_response(server: ordbok_tekst, handler: tekst, location: tekst, status: heiltall) -> ordbok_tekst {
    register_handler_response_object(server, handler, status, "", "text/plain; charset=utf-8")
    register_handler_response_headers(server, handler, {"location": location})
    returner server
}

funksjon register_moved_permanently_response(server: ordbok_tekst, handler: tekst, location: tekst) -> ordbok_tekst {
    returner register_redirect_response(server, handler, location, 301)
}

funksjon register_temporary_redirect_response(server: ordbok_tekst, handler: tekst, location: tekst) -> ordbok_tekst {
    returner register_redirect_response(server, handler, location, 307)
}

funksjon register_json_response(server: ordbok_tekst, handler: tekst, status: heiltall, body: tekst) -> ordbok_tekst {
    returner register_handler_response_object(
        server,
        handler,
        status,
        body,
        "application/json; charset=utf-8"
    )
}

funksjon _standard_error_response(server: ordbok_tekst, handler: tekst, status: heiltall, melding: tekst) -> ordbok_tekst {
    la body = "{\"error\":\"" + melding + "\",\"status\":" + tekst(status) + "}"
    returner register_handler_response_object(
        server,
        handler,
        status,
        body,
        "application/json; charset=utf-8"
    )
}

funksjon register_error_response(server: ordbok_tekst, handler: tekst, status: heiltall, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, status, melding)
}

funksjon register_bad_request_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 400, melding)
}

funksjon register_unauthorized_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 401, melding)
}

funksjon register_forbidden_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 403, melding)
}

funksjon register_conflict_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 409, melding)
}

funksjon register_unprocessable_entity_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 422, melding)
}

funksjon register_too_many_requests_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 429, melding)
}

funksjon register_internal_server_error_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 500, melding)
}

funksjon register_service_unavailable_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 503, melding)
}

funksjon register_bad_gateway_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 502, melding)
}

funksjon register_gateway_timeout_response(server: ordbok_tekst, handler: tekst, melding: tekst) -> ordbok_tekst {
    returner _standard_error_response(server, handler, 504, melding)
}

funksjon register_method_not_allowed_response(server: ordbok_tekst, handler: tekst, allow: tekst) -> ordbok_tekst {
    _standard_error_response(server, handler, 405, "Method Not Allowed")
    register_handler_response_headers(server, handler, {"allow": allow})
    returner server
}

funksjon register_created_response(server: ordbok_tekst, handler: tekst, body: tekst, location: tekst) -> ordbok_tekst {
    register_handler_response_object(
        server,
        handler,
        201,
        body,
        "application/json; charset=utf-8"
    )
    register_handler_response_headers(server, handler, {"location": location})
    returner server
}

funksjon register_accepted_response(server: ordbok_tekst, handler: tekst, body: tekst) -> ordbok_tekst {
    returner register_handler_response_object(
        server,
        handler,
        202,
        body,
        "application/json; charset=utf-8"
    )
}

funksjon register_no_content_response(server: ordbok_tekst, handler: tekst) -> ordbok_tekst {
    returner register_handler_response_object(
        server,
        handler,
        204,
        "",
        "text/plain; charset=utf-8"
    )
}

funksjon register_not_modified_response(server: ordbok_tekst, handler: tekst, etag: tekst, last_modified: tekst) -> ordbok_tekst {
    register_handler_response_object(
        server,
        handler,
        304,
        "",
        "text/plain; charset=utf-8"
    )
    register_handler_response_headers(server, handler, {"etag": etag, "last-modified": last_modified})
    returner server
}

funksjon finn_route(routes: ordbok_tekst, metode: tekst, sti: tekst) -> tekst {
    # Prøv eksakt match
    la nokkel = metode + " " + sti
    hvis har_nokkel(routes, nokkel) {
        returner routes[nokkel]
    }

    # Prov path-parameterar (f.eks. /brukarar/{id:int})
    la ruttar = nøkler(routes)
    la i: heltall = 0
    mens i < lengde(ruttar) {
        la rute = ruttar[i]
        hvis _rute_matcher(rute, metode, sti) {
            returner routes[rute]
        }
        i = i + 1
    }

    returner ""
}

funksjon _rute_matcher(rute_monster: tekst, metode: tekst, sti: tekst) -> boolsk {
    # Enkel matching: "GET /brukarar/{id:int}" matcher "GET /brukarar/123"
    la deler = builtin.split(rute_monster, " ")
    hvis lengde(deler) < 2 {
        returner usann
    }

    la rute_metode = deler[0]
    la rute_sti = deler[1]

    hvis rute_metode != metode {
        returner usann
    }

    # Enkel erstatning: {id:int} blir regulært uttrykk for tall
    la monster = rute_sti
    monster = builtin.replace(monster, "{id:int}", "[0-9]+")
    monster = builtin.replace(monster, "{id:tekst}", "[a-zA-Z0-9_-]+")
    monster = builtin.replace(monster, "{id}", "[^/]+")

    # Enkel regex-matching (ved å kontrollere prefiks/suffiks)
    returner _enkel_regex_match(monster, sti)
}

funksjon _enkel_regex_match(monster: tekst, tekst: tekst) -> boolsk {
    # Veldig enkel regex-simulator for {id:int} osv
    hvis monster == tekst {
        returner sant
    }

    la wildcard_pos = builtin.index_of(monster, "[")
    hvis wildcard_pos < 0 {
        returner usann
    }

    la prefiks = builtin.slice(monster, 0, wildcard_pos)
    hvis ikkje tekst_starter_med(tekst, prefiks) {
        returner usann
    }

    returner sant
}

funksjon _finn_tillatne_metodar(routes: ordbok_tekst, sti: tekst) -> tekst {
    la ruttar = nøkler(routes)
    la metodar = []
    la i: heiltall = 0
    mens i < lengde(ruttar) {
        la rute = ruttar[i]
        la deler = builtin.split(rute, " ")
        hvis lengde(deler) >= 2 {
            la rute_metode = deler[0]
            la rute_sti = deler[1]
            hvis rute_sti == sti eller _rute_matcher(rute_metode + " " + rute_sti, rute_metode, sti) {
                hvis ikkje builtin.contains(builtin.join(metodar, ","), rute_metode) {
                    legg_til(metodar, rute_metode)
                }
            }
        }
        i = i + 1
    }
    hvis builtin.contains(builtin.join(metodar, ","), "GET") og ikkje builtin.contains(builtin.join(metodar, ","), "HEAD") {
        legg_til(metodar, "HEAD")
    }
    hvis lengde(metodar) > 0 og ikkje builtin.contains(builtin.join(metodar, ","), "OPTIONS") {
        legg_til(metodar, "OPTIONS")
    }
    returner builtin.join(metodar, ", ")
}

# --- Request-parsing ---------------------------------------------------------

funksjon parse_http_request(raw: tekst) -> ordbok_tekst {
    # Parse HTTP GET/POST request
    # FORMAT:
    #   GET /path?query=value HTTP/1.1\r\n
    #   Host: localhost\r\n
    #   ...\r\n
    #   \r\n
    #   [body]

    la linjer = builtin.split(raw, "\n")
    hvis lengde(linjer) < 1 {
        returner {}
    }

    la request_linje = builtin.trim(linjer[0])
    la deler = builtin.split(request_linje, " ")
    hvis lengde(deler) < 3 {
        returner {}
    }

    la metode = deler[0]
    la sti_og_query = deler[1]

    # Parse sti og query
    la sporsmal = builtin.index_of(sti_og_query, "?")
    la sti: tekst = ""
    la query_str: tekst = ""

    hvis sporsmal >= 0 {
        sti = builtin.slice(sti_og_query, 0, sporsmal)
        query_str = builtin.slice(sti_og_query, sporsmal + 1, lengde(sti_og_query))
    } ellers {
        sti = sti_og_query
    }

    # Parse headers
    la headers: ordbok_tekst = {}
    la i: heltall = 1
    mens i < lengde(linjer) {
        la linje = builtin.trim(linjer[i])
        hvis linje == "" {
            i = i + 1
            bryt
        }
        la kolon = builtin.index_of(linje, ":")
        hvis kolon > 0 {
            la nokkel = tekst_til_liten(builtin.slice(linje, 0, kolon))
            la verdi = builtin.trim(builtin.slice(linje, kolon + 1, lengde(linje)))
            headers[nokkel] = verdi
        }
        i = i + 1
    }

    # Parse body (rest)
    la body: tekst = ""
    mens i < lengde(linjer) {
        body = body + linjer[i]
        hvis i < lengde(linjer) - 1 {
            body = body + "\n"
        }
        i = i + 1
    }

    la req: ordbok_tekst = {}
    req["__method__"] = metode
    req["__path__"] = sti
    req["__query__"] = _parse_query_string(query_str)
    req["__headers__"] = headers
    req["__body__"] = body
    req["__params__"] = {}
    returner req
}

funksjon request_context(metode: tekst, sti: tekst, query: ordbok_tekst, headers: ordbok_tekst, body: tekst) -> ordbok_tekst {
    returner web.request_context(metode, sti, query, headers, body)
}

funksjon standard_helse_response() -> ordbok_tekst {
    returner web.response_builder(
        200,
        {"content-type": "application/json; charset=utf-8", "cache-control": "no-store"},
        "{\"ok\":true,\"status\":\"ready\"}"
    )
}

funksjon standard_server_log(ctx: ordbok_tekst, status: heiltall) -> ordbok_tekst {
    la logg: ordbok_tekst = {}
    logg["method"] = web.request_method(ctx)
    logg["path"] = web.request_path(ctx)
    logg["status"] = tekst(status)
    hvis status >= 200 og status < 400 {
        logg["ok"] = "sann"
    } ellers {
        logg["ok"] = "usann"
    }
    returner logg
}

funksjon _parse_query_string(query_str: tekst) -> ordbok_tekst {
    la result: ordbok_tekst = {}
    hvis query_str == "" {
        returner result
    }

    la deler = builtin.split(query_str, "&")
    la i: heltall = 0
    mens i < lengde(deler) {
        la del = deler[i]
        la eq = builtin.index_of(del, "=")
        hvis eq > 0 {
            la nokkel = builtin.slice(del, 0, eq)
            la verdi = builtin.slice(del, eq + 1, lengde(del))
            result[nokkel] = verdi
        } ellers hvis del != "" {
            result[del] = "true"
        }
        i = i + 1
    }
    returner result
}

# --- HTTP-respons ------------------------------------------------------------

funksjon ok_respons(body: tekst) -> tekst {
    returner "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: " + tekst(lengde(body)) + "\r\n\r\n" + body
}

funksjon error_respons(status: heltall, melding: tekst) -> tekst {
    la json = "{\"error\": \"" + melding + "\", \"status\": " + tekst(status) + "}"
    returner "HTTP/1.1 " + tekst(status) + " Error\r\nContent-Type: application/json\r\nContent-Length: " + tekst(lengde(json)) + "\r\n\r\n" + json
}

funksjon not_found_respons() -> tekst {
    returner error_respons(404, "Ikkje funnet")
}

funksjon response_builder(status: heiltall, headers: ordbok_tekst, body: tekst) -> ordbok_tekst {
    returner web.response_builder(status, headers, body)
}

funksjon response_status(response: ordbok_tekst) -> heiltall {
    returner web.response_status(response)
}

funksjon response_body(response: ordbok_tekst) -> tekst {
    returner web.response_body(response)
}

funksjon response_text(response: ordbok_tekst) -> tekst {
    returner web.response_text(response)
}

funksjon direct_response(response: ordbok_tekst) -> ordbok_tekst {
    returner response
}

funksjon text_response(body: tekst) -> ordbok_tekst {
    returner response_builder(200, {"content-type": "text/plain; charset=utf-8"}, body)
}

funksjon _bygg_standard_response(status: heiltall, headers: ordbok_tekst, body: tekst, metode: tekst, etag: tekst, last_modified: tekst) -> ordbok_tekst {
    la svar_headers = headers
    hvis ikkje har_nokkel(svar_headers, "etag") {
        svar_headers["etag"] = etag
    }
    hvis ikkje har_nokkel(svar_headers, "last-modified") {
        svar_headers["last-modified"] = last_modified
    }
    la svar_body = body
    la svar_status = status
    hvis metode == "HEAD" {
        svar_body = ""
    }
    hvis svar_body == "" og svar_status == 200 {
        svar_status = 204
    }
    returner response_builder(svar_status, svar_headers, svar_body)
}

# --- Server-kjoring ----------------------------------------------------------

funksjon lytt(server: ordbok_tekst) -> heltall {
    # Denne funksjonen må implementerast i VM eller builtin
    # For no: simuler logging
    la port = server["port"]
    skriv("HTTP-tjener startar pa port " + port)
    skriv("Tilgjengeleg pa: http://localhost:" + port)

    # Venta på signal (pause)
    skriv("Trykk Ctrl+C for å stoppe")

    # Nota: Faktisk HTTP-servering krever builtin-stotte for socket-lytting
    # Dette er skeleton-implementasjon
    returner 0
}

# --- Hjelpar-funksjoner ------------------------------------------------------

funksjon register_middleware(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    # middleware er funksjonsnavn som handterer alle requests
    la mw = server["middleware"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_request_middleware(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    la mw = server["request_middlewares"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_response_middleware(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    la mw = server["response_middlewares"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_error_middleware(server: ordbok_tekst, middleware: tekst) -> ordbok_tekst {
    la mw = server["error_middlewares"]
    legg_til(mw, middleware)
    returner server
}

funksjon register_startup_hook(server: ordbok_tekst, hook: tekst) -> ordbok_tekst {
    la hooks = server["startup_hooks"]
    legg_til(hooks, hook)
    returner server
}

funksjon register_shutdown_hook(server: ordbok_tekst, hook: tekst) -> ordbok_tekst {
    la hooks = server["shutdown_hooks"]
    legg_til(hooks, hook)
    returner server
}

funksjon _bygg_middleware_trace(mw: liste<tekst>) -> liste<tekst> {
    la trace = []
    la i: heiltall = 0
    mens i < lengde(mw) {
        legg_til(trace, mw[i])
        i = i + 1
    }
    returner trace
}

funksjon _bygg_hook_trace(hooks: liste<tekst>) -> liste<tekst> {
    la trace = []
    la i: heiltall = 0
    mens i < lengde(hooks) {
        legg_til(trace, hooks[i])
        i = i + 1
    }
    returner trace
}

funksjon anvend_request_middlewares(server: ordbok_tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la mw = server["request_middlewares"]
    ctx["__request_middleware_trace__"] = _bygg_middleware_trace(mw)
    returner ctx
}

funksjon anvend_response_middlewares(server: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst {
    la mw = server["response_middlewares"]
    response["__response_middleware_trace__"] = _bygg_middleware_trace(mw)
    returner response
}

funksjon anvend_error_middlewares(server: ordbok_tekst, response: ordbok_tekst) -> ordbok_tekst {
    la mw = server["error_middlewares"]
    response["__error_middleware_trace__"] = _bygg_middleware_trace(mw)
    returner response
}

funksjon dispatch_request(server: ordbok_tekst, metode: tekst, sti: tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la ctx2 = anvend_request_middlewares(server, ctx)
    la oppslag_metode = metode
    hvis metode == "HEAD" {
        oppslag_metode = "GET"
    }
    la handler = finn_route(server["routes"], oppslag_metode, sti)
    la allow = _finn_tillatne_metodar(server["routes"], sti)
    la headers = web.request_headers(ctx2)
    la if_none_match = ""
    la if_modified_since = ""
    la if_match = ""
    hvis har_nokkel(headers, "if-none-match") {
        if_none_match = headers["if-none-match"]
    }
    hvis har_nokkel(headers, "if-modified-since") {
        if_modified_since = headers["if-modified-since"]
    }
    hvis har_nokkel(headers, "if-match") {
        if_match = headers["if-match"]
    }

    hvis metode == "OPTIONS" og allow != "" {
        la options = response_builder(204, {"allow": allow}, "")
        returner anvend_response_middlewares(server, options)
    }

    hvis handler == "" {
        hvis allow != "" {
            la ikkje_tillatt = response_builder(
                405,
                {"content-type": "application/json; charset=utf-8", "allow": allow},
                "{\"error\":\"Method Not Allowed\",\"status\":405}"
            )
            la ikkje_tillatt2 = anvend_error_middlewares(server, ikkje_tillatt)
            returner anvend_response_middlewares(server, ikkje_tillatt2)
        }
        la feil = response_builder(
            404,
            {"content-type": "application/json; charset=utf-8"},
            "{\"error\":\"Ikkje funnet\",\"status\":404}"
        )
        la feil2 = anvend_error_middlewares(server, feil)
        returner anvend_response_middlewares(server, feil2)
    }

    la etag = "\"" + handler + ":" + sti + "\""
    la last_modified = "Tue, 16 Jun 2026 12:00:00 GMT"
    hvis if_match != "" og if_match != etag {
        la precondition = response_builder(
            412,
            {"etag": etag, "last-modified": last_modified, "content-type": "application/json; charset=utf-8"},
            "{\"error\":\"Precondition Failed\",\"status\":412}"
        )
        la precondition2 = anvend_error_middlewares(server, precondition)
        returner anvend_response_middlewares(server, precondition2)
    }
    hvis if_none_match == etag {
        la ikkje_endra = response_builder(304, {"etag": etag, "last-modified": last_modified}, "")
        returner anvend_response_middlewares(server, ikkje_endra)
    }
    hvis if_modified_since == last_modified {
        la ikkje_endra = response_builder(304, {"etag": etag, "last-modified": last_modified}, "")
        returner anvend_response_middlewares(server, ikkje_endra)
    }

    la responses = server["handler_responses"]
    la direct_responses = server["handler_direct_responses"]
    la statusar = server["handler_response_status"]
    la content_types = server["handler_response_content_type"]
    la header_map = server["handler_response_headers"]
    la body = "{\"handler\":\"" + handler + "\",\"path\":\"" + web.request_path(ctx2) + "\"}"
    la status = 200
    la content_type = "application/json; charset=utf-8"
    la extra_headers: ordbok_tekst = {}
    hvis har_nokkel(direct_responses, handler) {
        la direct_response = direct_responses[handler]
        la direct_status = web.response_status(direct_response)
        la direct_headers = web.response_headers(direct_response)
        la direct_body = web.response_body(direct_response)
        la direct = _bygg_standard_response(direct_status, direct_headers, direct_body, metode, etag, last_modified)
        returner anvend_response_middlewares(server, direct)
    }
    hvis har_nokkel(responses, handler) {
        body = responses[handler]
    }
    hvis har_nokkel(statusar, handler) {
        status = heiltall(statusar[handler])
    }
    hvis har_nokkel(content_types, handler) {
        content_type = content_types[handler]
    }
    hvis har_nokkel(header_map, handler) {
        extra_headers = header_map[handler]
    }
    la response_headers = {"content-type": content_type}
    la extra_keys = nøkler(extra_headers)
    la j: heiltall = 0
    mens j < lengde(extra_keys) {
        la key = extra_keys[j]
        response_headers[key] = extra_headers[key]
        j = j + 1
    }
    la response = _bygg_standard_response(status, response_headers, body, metode, etag, last_modified)
    returner anvend_response_middlewares(server, response)
}

funksjon køyre_server_syklus(server: ordbok_tekst, metode: tekst, sti: tekst, ctx: ordbok_tekst) -> ordbok_tekst {
    la start = køyre_startup_hooks(server)
    la ctx2 = anvend_request_middlewares(server, ctx)
    la response = dispatch_request(server, metode, sti, ctx2)
    la slutt = køyre_shutdown_hooks(server)
    la result: ordbok_tekst = {}
    result["startup"] = start
    result["request_context"] = ctx2
    result["response"] = response
    result["shutdown"] = slutt
    returner result
}

funksjon køyre_startup_hooks(server: ordbok_tekst) -> ordbok_tekst {
    la hooks = server["startup_hooks"]
    la trace = _bygg_hook_trace(hooks)
    la result: ordbok_tekst = {}
    result["phase"] = "startup"
    result["__startup_hook_trace__"] = trace
    returner result
}

funksjon køyre_shutdown_hooks(server: ordbok_tekst) -> ordbok_tekst {
    la hooks = server["shutdown_hooks"]
    la trace = _bygg_hook_trace(hooks)
    la result: ordbok_tekst = {}
    result["phase"] = "shutdown"
    result["__shutdown_hook_trace__"] = trace
    returner result
}

funksjon hent_route_handler(server: ordbok_tekst, metode: tekst, sti: tekst) -> tekst {
    returner finn_route(server["routes"], metode, sti)
}

funksjon server_info(server: ordbok_tekst) -> tekst {
    la port = server["port"]
    la antall_routes = lengde(nøkler(server["routes"]))
    la request_mw = lengde(server["request_middlewares"])
    la response_mw = lengde(server["response_middlewares"])
    la error_mw = lengde(server["error_middlewares"])
    la startup_hooks = lengde(server["startup_hooks"])
    la shutdown_hooks = lengde(server["shutdown_hooks"])
    returner "Server på port " + port + " med " + tekst(antall_routes) + " ruter, " + tekst(request_mw) + "/" + tekst(response_mw) + "/" + tekst(error_mw) + " middleware og " + tekst(startup_hooks) + "/" + tekst(shutdown_hooks) + " hooks"
}

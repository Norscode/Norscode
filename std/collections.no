# collections.no — Utvida datastrukturar
# Python: collections.Counter, defaultdict, OrderedDict, namedtuple, ChainMap
#
# Bruk:
#   bruk std.collections som coll
#
#   # Counter
#   la c = coll.telj_tekst(["a","b","a","c","a","b"])
#   skriv coll.vanlegast(c, 2)   # → [["a",3],["b",2]]
#
#   # DefaultDict
#   la d = coll.ny_standardordbok("0")
#   coll.std_set(d, "tal", "5")
#   skriv coll.std_hent(d, "ny_nøkkel")   # → "0"
#
#   # NamedTuple
#   la Punkt = coll.ny_namedtuple("Punkt", ["x", "y"])
#   la p = coll.nt_lag(Punkt, [3, 4])
#   skriv coll.nt_hent(p, "x")   # → "3"

# ─── Counter ──────────────────────────────────────────────────────────────────

# Telje forekomstar frå ei liste_tekst
funksjon telj_tekst(element: liste_tekst) -> ordbok_heltall {
    la teller: ordbok_heltall = {}
    la i: heltall = 0
    mens (i < lengde(element)) {
        la e: tekst = element[i]
        hvis (har_nokkel(teller, e)) {
            teller[e] = teller[e] + 1
        } ellers {
            teller[e] = 1
        }
        i = i + 1
    }
    returner teller
}

# Telje teikn i ein tekst
funksjon telj_teikn(s: tekst) -> ordbok_heltall {
    returner telj_tekst(builtin.split(s, ""))
}

# Oppdater ein teller med ei ny liste
funksjon telj_oppdater(teller: ordbok_heltall, element: liste_tekst) {
    la i: heltall = 0
    mens (i < lengde(element)) {
        la e: tekst = element[i]
        hvis (har_nokkel(teller, e)) {
            teller[e] = teller[e] + 1
        } ellers {
            teller[e] = 1
        }
        i = i + 1
    }
}

# Hent dei n vanlegaste elementa, sortert synkande
# Returnerer liste_tekst av JSON-par [[element, tal], ...]
funksjon vanlegast(teller: ordbok_heltall, n: heltall) -> liste_tekst {
    la nøklar = builtin.nøkler(teller)
    # Enkel sortering: boble-sortering på verdiar (synkande)
    la sorted_nk: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        legg_til(sorted_nk, nøklar[i])
        i = i + 1
    }
    # Bobblesortering
    la m: heltall = lengde(sorted_nk)
    la swapped: bool = sann
    mens (swapped) {
        swapped = usann
        la j: heltall = 0
        mens (j + 1 < m) {
            hvis (teller[sorted_nk[j]] < teller[sorted_nk[j + 1]]) {
                la tmp: tekst = sorted_nk[j]
                sorted_nk[j] = sorted_nk[j + 1]
                sorted_nk[j + 1] = tmp
                swapped = sann
            }
            j = j + 1
        }
    }
    la resultat: liste_tekst = []
    la tak: heltall = n
    hvis (tak > m) { tak = m }
    i = 0
    mens (i < tak) {
        la par: liste_tekst = [sorted_nk[i], tekst_fra_heltall(teller[sorted_nk[i]])]
        legg_til(resultat, builtin.json_stringify(par))
        i = i + 1
    }
    returner resultat
}

# Pluss: legg saman to tellarar
funksjon telj_pluss(a: ordbok_heltall, b: ordbok_heltall) -> ordbok_heltall {
    la resultat: ordbok_heltall = {}
    la nk_a = builtin.nøkler(a)
    la i: heltall = 0
    mens (i < lengde(nk_a)) {
        resultat[nk_a[i]] = a[nk_a[i]]
        i = i + 1
    }
    la nk_b = builtin.nøkler(b)
    i = 0
    mens (i < lengde(nk_b)) {
        la k: tekst = nk_b[i]
        hvis (har_nokkel(resultat, k)) {
            resultat[k] = resultat[k] + b[k]
        } ellers {
            resultat[k] = b[k]
        }
        i = i + 1
    }
    returner resultat
}

# Minus: trekk frå, behold berre positive
funksjon telj_minus(a: ordbok_heltall, b: ordbok_heltall) -> ordbok_heltall {
    la resultat: ordbok_heltall = {}
    la nk_a = builtin.nøkler(a)
    la i: heltall = 0
    mens (i < lengde(nk_a)) {
        la k: tekst = nk_a[i]
        la ny_v: heltall = a[k]
        hvis (har_nokkel(b, k)) { ny_v = ny_v - b[k] }
        hvis (ny_v > 0) { resultat[k] = ny_v }
        i = i + 1
    }
    returner resultat
}

# Snitt: berre element i begge, med minste tal
funksjon telj_snitt(a: ordbok_heltall, b: ordbok_heltall) -> ordbok_heltall {
    la resultat: ordbok_heltall = {}
    la nk_a = builtin.nøkler(a)
    la i: heltall = 0
    mens (i < lengde(nk_a)) {
        la k: tekst = nk_a[i]
        hvis (har_nokkel(b, k)) {
            la mi: heltall = a[k]
            hvis (b[k] < mi) { mi = b[k] }
            resultat[k] = mi
        }
        i = i + 1
    }
    returner resultat
}

funksjon telj_total(teller: ordbok_heltall) -> heltall {
    la nøklar = builtin.nøkler(teller)
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        sum = sum + teller[nøklar[i]]
        i = i + 1
    }
    returner sum
}

# ─── DefaultDict ──────────────────────────────────────────────────────────────
# Representasjon: ordbok_tekst med "_std" = standardverdi

funksjon ny_standardordbok(standardverdi: tekst) -> ordbok_tekst {
    la d: ordbok_tekst = {}
    d["_std"] = standardverdi
    return d
}

funksjon std_hent(d: ordbok_tekst, nøkkel: tekst) -> tekst {
    hvis (har_nokkel(d, nøkkel) og nøkkel != "_std") { returner d[nøkkel] }
    la std: tekst = d["_std"]
    d[nøkkel] = std
    returner std
}

funksjon std_set(d: ordbok_tekst, nøkkel: tekst, verdi: tekst) {
    d[nøkkel] = verdi
}

funksjon std_nøklar(d: ordbok_tekst) -> liste_tekst {
    la nøklar = builtin.nøkler(d)
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nøklar)) {
        hvis (nøklar[i] != "_std") { legg_til(resultat, nøklar[i]) }
        i = i + 1
    }
    returner resultat
}

# DefaultDict for heltall (teller-mønster)
funksjon ny_heltallsordbok() -> ordbok_heltall {
    returner {}
}

funksjon heltall_hent(d: ordbok_heltall, nøkkel: tekst) -> heltall {
    hvis (har_nokkel(d, nøkkel)) { returner d[nøkkel] }
    d[nøkkel] = 0
    returner 0
}

funksjon heltall_inkrement(d: ordbok_heltall, nøkkel: tekst) {
    hvis (har_nokkel(d, nøkkel)) {
        d[nøkkel] = d[nøkkel] + 1
    } ellers {
        d[nøkkel] = 1
    }
}

# ─── OrderedDict ──────────────────────────────────────────────────────────────
# Representasjon: ordbok_tekst data + "_rekkefølge" JSON-liste av nøklar

funksjon ny_ordreordbok() -> ordbok_tekst {
    la d: ordbok_tekst = {}
    d["_rekkefølge"] = "[]"
    returner d
}

funksjon ord_set(d: ordbok_tekst, nøkkel: tekst, verdi: tekst) {
    hvis (ikkje har_nokkel(d, "_k_" + nøkkel)) {
        la rf = builtin.json_parse(d["_rekkefølge"])
        legg_til(rf, nøkkel)
        d["_rekkefølge"] = builtin.json_stringify(rf)
        d["_k_" + nøkkel] = "1"
    }
    d["v_" + nøkkel] = verdi
}

funksjon ord_hent(d: ordbok_tekst, nøkkel: tekst) -> tekst {
    la vn: tekst = "v_" + nøkkel
    hvis (har_nokkel(d, vn)) { returner d[vn] }
    returner ""
}

funksjon ord_har(d: ordbok_tekst, nøkkel: tekst) -> bool {
    returner har_nokkel(d, "v_" + nøkkel)
}

funksjon ord_slett(d: ordbok_tekst, nøkkel: tekst) {
    fjern_nokkel(d, "v_" + nøkkel)
    fjern_nokkel(d, "_k_" + nøkkel)
    la rf = builtin.json_parse(d["_rekkefølge"])
    la ny_rf: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(rf)) {
        hvis (rf[i] != nøkkel) { legg_til(ny_rf, rf[i]) }
        i = i + 1
    }
    d["_rekkefølge"] = builtin.json_stringify(ny_rf)
}

funksjon ord_nøklar(d: ordbok_tekst) -> liste_tekst {
    returner builtin.json_parse(d["_rekkefølge"])
}

funksjon ord_verdiar(d: ordbok_tekst) -> liste_tekst {
    la nk = ord_nøklar(d)
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nk)) {
        legg_til(resultat, ord_hent(d, nk[i]))
        i = i + 1
    }
    returner resultat
}

funksjon ord_par(d: ordbok_tekst) -> liste_tekst {
    la nk = ord_nøklar(d)
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(nk)) {
        la par: liste_tekst = [nk[i], ord_hent(d, nk[i])]
        legg_til(resultat, builtin.json_stringify(par))
        i = i + 1
    }
    returner resultat
}

funksjon ord_flytt_sist(d: ordbok_tekst, nøkkel: tekst) {
    la rf = builtin.json_parse(d["_rekkefølge"])
    la ny_rf: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(rf)) {
        hvis (rf[i] != nøkkel) { legg_til(ny_rf, rf[i]) }
        i = i + 1
    }
    legg_til(ny_rf, nøkkel)
    d["_rekkefølge"] = builtin.json_stringify(ny_rf)
}

# ─── NamedTuple ───────────────────────────────────────────────────────────────
# Representasjon: ordbok_tekst schema + liste_tekst instansar

funksjon ny_namedtuple(typnamn: tekst, felt: liste_tekst) -> ordbok_tekst {
    la schema: ordbok_tekst = {}
    schema["_typnamn"] = typnamn
    schema["_felt"] = builtin.json_stringify(felt)
    la i: heltall = 0
    mens (i < lengde(felt)) {
        schema["_i_" + felt[i]] = tekst_fra_heltall(i)
        i = i + 1
    }
    returner schema
}

funksjon nt_lag(schema: ordbok_tekst, verdiar: liste_tekst) -> liste_tekst {
    returner verdiar
}

funksjon nt_hent(schema: ordbok_tekst, instans: liste_tekst, felt_namn: tekst) -> tekst {
    la idx_nøkkel: tekst = "_i_" + felt_namn
    hvis (ikkje har_nokkel(schema, idx_nøkkel)) { returner "" }
    la idx: heltall = builtin.heltall_fra_tekst(schema[idx_nøkkel])
    hvis (idx >= lengde(instans)) { returner "" }
    returner instans[idx]
}

funksjon nt_set(schema: ordbok_tekst, instans: liste_tekst, felt_namn: tekst, ny_verdi: tekst) -> liste_tekst {
    la idx_nøkkel: tekst = "_i_" + felt_namn
    hvis (ikkje har_nokkel(schema, idx_nøkkel)) { returner instans }
    la idx: heltall = builtin.heltall_fra_tekst(schema[idx_nøkkel])
    la kopi: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(instans)) {
        hvis (i == idx) { legg_til(kopi, ny_verdi) }
        ellers { legg_til(kopi, instans[i]) }
        i = i + 1
    }
    returner kopi
}

funksjon nt_felt(schema: ordbok_tekst) -> liste_tekst {
    returner builtin.json_parse(schema["_felt"])
}

funksjon nt_til_ordbok(schema: ordbok_tekst, instans: liste_tekst) -> ordbok_tekst {
    la felt = nt_felt(schema)
    la resultat: ordbok_tekst = {}
    la i: heltall = 0
    mens (i < lengde(felt) og i < lengde(instans)) {
        resultat[felt[i]] = instans[i]
        i = i + 1
    }
    returner resultat
}

funksjon nt_repr(schema: ordbok_tekst, instans: liste_tekst) -> tekst {
    la felt = nt_felt(schema)
    la ut: tekst = schema["_typnamn"] + "("
    la i: heltall = 0
    mens (i < lengde(felt) og i < lengde(instans)) {
        ut = ut + felt[i] + "=" + instans[i]
        hvis (i + 1 < lengde(felt)) { ut = ut + ", " }
        i = i + 1
    }
    returner ut + ")"
}

# ─── ChainMap ─────────────────────────────────────────────────────────────────
# Slår saman fleire ordbøker til éin logisk visning (første treff vinn)
# Representasjon: ordbok_tekst med "_kart" = JSON-liste av ordbøker

funksjon ny_chainmap(ordbøker: liste_tekst) -> ordbok_tekst {
    la cm: ordbok_tekst = {}
    cm["_kart"] = builtin.json_stringify(ordbøker)
    returner cm
}

funksjon cm_hent(cm: ordbok_tekst, nøkkel: tekst) -> tekst {
    la kart = builtin.json_parse(cm["_kart"])
    la i: heltall = 0
    mens (i < lengde(kart)) {
        la d = builtin.json_parse(kart[i])
        hvis (har_nokkel(d, nøkkel)) { returner d[nøkkel] }
        i = i + 1
    }
    returner ""
}

funksjon cm_har(cm: ordbok_tekst, nøkkel: tekst) -> bool {
    la kart = builtin.json_parse(cm["_kart"])
    la i: heltall = 0
    mens (i < lengde(kart)) {
        la d = builtin.json_parse(kart[i])
        hvis (har_nokkel(d, nøkkel)) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon cm_set(cm: ordbok_tekst, nøkkel: tekst, verdi: tekst) {
    # Set alltid i første kart
    la kart = builtin.json_parse(cm["_kart"])
    hvis (lengde(kart) == 0) { returner }
    la d = builtin.json_parse(kart[0])
    d[nøkkel] = verdi
    kart[0] = builtin.json_stringify(d)
    cm["_kart"] = builtin.json_stringify(kart)
}

funksjon cm_alle_nøklar(cm: ordbok_tekst) -> liste_tekst {
    la kart = builtin.json_parse(cm["_kart"])
    la sett: ordbok_bool = {}
    la resultat: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(kart)) {
        la d = builtin.json_parse(kart[i])
        la nk = builtin.nøkler(d)
        la j: heltall = 0
        mens (j < lengde(nk)) {
            hvis (ikkje har_nokkel(sett, nk[j])) {
                sett[nk[j]] = sann
                legg_til(resultat, nk[j])
            }
            j = j + 1
        }
        i = i + 1
    }
    returner resultat
}

funksjon cm_legg_til(cm: ordbok_tekst, d_json: tekst) -> ordbok_tekst {
    la kart = builtin.json_parse(cm["_kart"])
    la ny_kart: liste_tekst = [d_json]
    la i: heltall = 0
    mens (i < lengde(kart)) {
        legg_til(ny_kart, kart[i])
        i = i + 1
    }
    la ny_cm: ordbok_tekst = {}
    ny_cm["_kart"] = builtin.json_stringify(ny_kart)
    returner ny_cm
}

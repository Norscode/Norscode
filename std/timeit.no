# timeit.no — Kode-tidsregistrering
# Python: timeit
#
# Krev builtin.tid_ms() for å hente gjeldande tid i millisekund.
#
# Representasjon:
#   Tidtakar: ordbok_tekst
#     "start_ms"  → starttid (ms)
#     "slutt_ms"  → sluttid (ms, "" viss ikkje stoppa)
#     "aktiv"     → "sann"/"usann"
#
# Bruk:
#   bruk std.timeit som ti
#
#   # Enkel manuell tidsregistrering
#   la t = ti.ny_tidtakar()
#   ti.start(t)
#   # ... kode ...
#   ti.stopp(t)
#   skriv ti.elapsed_ms(t)       # tid i ms
#
#   # timeit-stil: køyr funksjon n gonger
#   la res = ti.timeit("minmodul.funksjon", {}, 1000)
#   skriv ti.format_resultat(res)

# ─── Tidtakar ────────────────────────────────────────────────────────────────

funksjon ny_tidtakar() -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["start_ms"] = "0"
    t["slutt_ms"] = ""
    t["aktiv"] = "usann"
    t["laps"] = "[]"
    returner t
}

funksjon start(t: ordbok_tekst) {
    t["start_ms"] = tekst_fra_heltall(builtin.tid_ms())
    t["slutt_ms"] = ""
    t["aktiv"] = "sann"
}

funksjon stopp(t: ordbok_tekst) {
    t["slutt_ms"] = tekst_fra_heltall(builtin.tid_ms())
    t["aktiv"] = "usann"
}

funksjon lap(t: ordbok_tekst) -> heltall {
    la no: heltall = builtin.tid_ms()
    la start_ms: heltall = builtin.heltall_fra_tekst(t["start_ms"])
    la elapsed: heltall = no - start_ms
    la laps = builtin.json_parse(t["laps"])
    legg_til(laps, elapsed)
    t["laps"] = builtin.json_stringify(laps)
    returner elapsed
}

funksjon nullstill(t: ordbok_tekst) {
    t["start_ms"] = "0"
    t["slutt_ms"] = ""
    t["aktiv"] = "usann"
    t["laps"] = "[]"
}

# Hent forløpt tid i ms
funksjon elapsed_ms(t: ordbok_tekst) -> heltall {
    la start_ms: heltall = builtin.heltall_fra_tekst(t["start_ms"])
    hvis (t["aktiv"] == "sann") {
        returner builtin.tid_ms() - start_ms
    }
    hvis (t["slutt_ms"] != "") {
        la slutt_ms: heltall = builtin.heltall_fra_tekst(t["slutt_ms"])
        returner slutt_ms - start_ms
    }
    returner 0
}

funksjon er_aktiv(t: ordbok_tekst) -> bool {
    returner t["aktiv"] == "sann"
}

funksjon alle_laps(t: ordbok_tekst) -> liste_heltall {
    returner builtin.json_parse(t["laps"])
}

# ─── timeit-funksjon ──────────────────────────────────────────────────────────

# Resultat-struktur
funksjon _ny_timeit_resultat(total_ms: heltall, n: heltall, fn_namn: tekst) -> ordbok_tekst {
    la r: ordbok_tekst = {}
    r["total_ms"] = tekst_fra_heltall(total_ms)
    r["tal"] = tekst_fra_heltall(n)
    r["fn"] = fn_namn
    r["snitt_ms"] = tekst_fra_heltall(total_ms / n)
    r["snitt_us"] = tekst_fra_heltall((total_ms * 1000) / n)
    returner r
}

# Køyr ein funksjon n gonger og mål total tid
funksjon timeit(fn_namn: tekst, args: ordbok_tekst, n: heltall) -> ordbok_tekst {
    la t = ny_tidtakar()
    start(t)
    la i: heltall = 0
    mens (i < n) {
        prøv {
            builtin.ncb_call_fn(fn_namn, args)
        } fang (e) {
            # Tell feil men hald fram
        }
        i = i + 1
    }
    stopp(t)
    la total: heltall = elapsed_ms(t)
    returner _ny_timeit_resultat(total, n, fn_namn)
}

# Køyr n gonger, gjenta r gangar, ta beste tid
funksjon repeat(fn_namn: tekst, args: ordbok_tekst, n: heltall, r: heltall) -> liste_heltall {
    la tider: liste_heltall = []
    la ri: heltall = 0
    mens (ri < r) {
        la t = ny_tidtakar()
        start(t)
        la i: heltall = 0
        mens (i < n) {
            prøv { builtin.ncb_call_fn(fn_namn, args) } fang (e) {}
            i = i + 1
        }
        stopp(t)
        legg_til(tider, elapsed_ms(t))
        ri = ri + 1
    }
    returner tider
}

# Autoskaling: auk n til tida er minst 200ms
funksjon autorange(fn_namn: tekst, args: ordbok_tekst) -> ordbok_tekst {
    la n: heltall = 1
    la maks_n: heltall = 1000000
    mens (n <= maks_n) {
        la t = ny_tidtakar()
        start(t)
        la i: heltall = 0
        mens (i < n) {
            prøv { builtin.ncb_call_fn(fn_namn, args) } fang (e) {}
            i = i + 1
        }
        stopp(t)
        la total: heltall = elapsed_ms(t)
        hvis (total >= 200) {
            returner _ny_timeit_resultat(total, n, fn_namn)
        }
        n = n * 10
    }
    returner _ny_timeit_resultat(0, n, fn_namn)
}

# ─── Analyse av repeat-resultat ───────────────────────────────────────────────

funksjon min_tid(tider: liste_heltall) -> heltall {
    la n: heltall = lengde(tider)
    hvis (n == 0) { returner 0 }
    la m: heltall = tider[0]
    la i: heltall = 1
    mens (i < n) {
        hvis (tider[i] < m) { m = tider[i] }
        i = i + 1
    }
    returner m
}

funksjon maks_tid(tider: liste_heltall) -> heltall {
    la n: heltall = lengde(tider)
    hvis (n == 0) { returner 0 }
    la m: heltall = tider[0]
    la i: heltall = 1
    mens (i < n) {
        hvis (tider[i] > m) { m = tider[i] }
        i = i + 1
    }
    returner m
}

funksjon snitt_tid(tider: liste_heltall) -> heltall {
    la n: heltall = lengde(tider)
    hvis (n == 0) { returner 0 }
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < n) {
        sum = sum + tider[i]
        i = i + 1
    }
    returner sum / n
}

# ─── Formatering ─────────────────────────────────────────────────────────────

funksjon format_tid(ms: heltall) -> tekst {
    hvis (ms < 1000) {
        returner tekst_fra_heltall(ms) + " ms"
    }
    la sek: heltall = ms / 1000
    la rest_ms: heltall = ms % 1000
    returner tekst_fra_heltall(sek) + "." + _pad3(rest_ms) + " s"
}

funksjon _pad3(n: heltall) -> tekst {
    la s: tekst = tekst_fra_heltall(n)
    la teikn = builtin.split(s, "")
    la l: heltall = lengde(teikn)
    hvis (l >= 3) { returner s }
    hvis (l == 2) { returner "0" + s }
    returner "00" + s
}

funksjon format_resultat(r: ordbok_tekst) -> tekst {
    la n: heltall = builtin.heltall_fra_tekst(r["tal"])
    la total: heltall = builtin.heltall_fra_tekst(r["total_ms"])
    la snitt: heltall = builtin.heltall_fra_tekst(r["snitt_us"])
    returner tekst_fra_heltall(n) + " køyringar i " + format_tid(total) +
             "; snitt " + tekst_fra_heltall(snitt) + " µs per køyring"
}

funksjon format_repeat(tider: liste_heltall, n: heltall) -> tekst {
    la mn: heltall = min_tid(tider)
    la mx: heltall = maks_tid(tider)
    la sn: heltall = snitt_tid(tider)
    returner tekst_fra_heltall(lengde(tider)) + " køyringar, " +
             tekst_fra_heltall(n) + " per køyring\n" +
             "  min: " + format_tid(mn) + "\n" +
             "  maks: " + format_tid(mx) + "\n" +
             "  snitt: " + format_tid(sn)
}

# ─── Kontekstsensitiv tidtakar (for måling innanfor kode) ────────────────────

# Mål ein tekst-bolk (oppsamla varighet)
funksjon ny_akkumulert() -> ordbok_tekst {
    la a: ordbok_tekst = {}
    a["total_ms"] = "0"
    a["tal"] = "0"
    a["aktiv"] = "usann"
    a["sist_start"] = "0"
    returner a
}

funksjon akk_start(a: ordbok_tekst) {
    a["sist_start"] = tekst_fra_heltall(builtin.tid_ms())
    a["aktiv"] = "sann"
}

funksjon akk_stopp(a: ordbok_tekst) {
    la sist: heltall = builtin.heltall_fra_tekst(a["sist_start"])
    la no: heltall = builtin.tid_ms()
    la total: heltall = builtin.heltall_fra_tekst(a["total_ms"])
    la tal: heltall = builtin.heltall_fra_tekst(a["tal"])
    a["total_ms"] = tekst_fra_heltall(total + (no - sist))
    a["tal"] = tekst_fra_heltall(tal + 1)
    a["aktiv"] = "usann"
}

funksjon akk_total(a: ordbok_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(a["total_ms"])
}

funksjon akk_tal(a: ordbok_tekst) -> heltall {
    returner builtin.heltall_fra_tekst(a["tal"])
}

funksjon akk_snitt(a: ordbok_tekst) -> heltall {
    la tal: heltall = builtin.heltall_fra_tekst(a["tal"])
    hvis (tal == 0) { returner 0 }
    returner builtin.heltall_fra_tekst(a["total_ms"]) / tal
}

# CSRF-hjelpere

bruk std.web som web

funksjon generer_token() -> tekst {
    prøv {
        returner builtin.random_hex(32)
    } fang (e) { }
    kast "CSRF krev builtin.random_hex"
}

funksjon cookie_namn() -> tekst {
    returner "csrf_token"
}

funksjon felt_namn() -> tekst {
    returner "csrf_token"
}

funksjon token(ctx: ordbok_tekst) -> tekst {
    la h1 = web.request_header(ctx, "x-csrf-token")
    hvis h1 != "" { returner h1 }
    la h2 = web.request_header(ctx, "x-xsrf-token")
    hvis h2 != "" { returner h2 }
    returner ""
}

funksjon token_fra_body(ctx: ordbok_tekst) -> tekst {
    hvis har_nokkel(ctx, "__body__") {
        la body = ctx["__body__"]
        prøv {
            la data = builtin.json_parse_raw(body)
            hvis har_nokkel(data, felt_namn()) { returner tekst(data[felt_namn()]) }
        } fang (e) { }
    }
    returner ""
}

funksjon konstant_lik(a: tekst, b: tekst) -> bool {
    prøv { returner builtin.constant_time_compare(a, b) } fang (e) { }
    hvis lengde(a) != lengde(b) { returner usann }
    la resultat: heltall = 0
    la i: heltall = 0
    mens i < lengde(a) {
        la diff = builtin.char_code(a[i]) - builtin.char_code(b[i])
        resultat = resultat + (diff * diff)
        i = i + 1
    }
    returner resultat == 0
}

funksjon require(ctx: ordbok_tekst, expected: tekst) -> bool {
    la tok = token(ctx)
    returner tok != "" og expected != "" og konstant_lik(tok, expected)
}

funksjon cookie(token_verdi: tekst) -> tekst {
    returner cookie_namn() + "=" + token_verdi + "; HttpOnly; Secure; SameSite=Lax; Path=/"
}

funksjon status() -> ordbok_tekst {
    returner {
        modul: "std.csrf",
        token_bytes: "32",
        headerar: "x-csrf-token,x-xsrf-token",
        cookie: cookie_namn(),
        samanlikning: "constant_time"
    }
}

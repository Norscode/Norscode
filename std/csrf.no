# CSRF-hjelpere

funksjon token(ctx: ordbok_tekst) -> tekst {
    la h = ctx["__headers__"]
    hvis har_nokkel(h, "x-csrf-token") { returner h["x-csrf-token"] }
    hvis har_nokkel(h, "x-xsrf-token") { returner h["x-xsrf-token"] }
    returner ""
}

funksjon require(ctx: ordbok_tekst, expected: tekst) -> bool {
    la tok = token(ctx)
    returner tok != "" og tok == expected
}

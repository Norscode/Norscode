# syslog.no — systemlogging
# Python: syslog
#
# Send meldingar til systemloggen via logger-kommandoen.
# Støttar prioritetsnivå og fasilitetar (facilities) som Python sin syslog-modul.
#
# Bruk:
#   bruk std.syslog som syslog
#   syslog.openlog("min_app", syslog.LOG_PID, syslog.LOG_USER)
#   syslog.syslog(syslog.LOG_ERR, "Noko gjekk gale")
#   syslog.closelog()

# ─── Prioritetskonstantar ────────────────────────────────────────────────────
la LOG_EMERG:   heltall = 0
la LOG_ALERT:   heltall = 1
la LOG_CRIT:    heltall = 2
la LOG_ERR:     heltall = 3
la LOG_WARNING: heltall = 4
la LOG_NOTICE:  heltall = 5
la LOG_INFO:    heltall = 6
la LOG_DEBUG:   heltall = 7

# ─── Facilitet-konstansar ─────────────────────────────────────────────────────
la LOG_KERN:    heltall = 0
la LOG_USER:    heltall = 8
la LOG_MAIL:    heltall = 16
la LOG_DAEMON:  heltall = 24
la LOG_AUTH:    heltall = 32
la LOG_LPR:     heltall = 48
la LOG_NEWS:    heltall = 56
la LOG_UUCP:    heltall = 64
la LOG_CRON:    heltall = 72
la LOG_LOCAL0:  heltall = 128
la LOG_LOCAL1:  heltall = 136
la LOG_LOCAL2:  heltall = 144
la LOG_LOCAL3:  heltall = 152
la LOG_LOCAL4:  heltall = 160
la LOG_LOCAL5:  heltall = 168
la LOG_LOCAL6:  heltall = 176
la LOG_LOCAL7:  heltall = 184

# ─── Opsjonskonstansar ────────────────────────────────────────────────────────
la LOG_PID:    heltall = 1
la LOG_CONS:   heltall = 2
la LOG_NDELAY: heltall = 8
la LOG_NOWAIT: heltall = 16
la LOG_PERROR: heltall = 32

# ─── Tilstand ─────────────────────────────────────────────────────────────────
# Global logg-tilstand (simulert via ordbok)
funksjon _ny_tilstand() -> ordbok_tekst {
    la t: ordbok_tekst = {}
    t["_type"]    = "syslog_tilstand"
    t["ident"]    = ""
    t["opsjoner"] = "0"
    t["fasilitet"] = tekst_fra_heltall(LOG_USER)
    t["maskeval"] = "255"  # alle prioritetar aktivert
    t["opna"]     = "usann"
    returner t
}

# Global tilstand (bruk openlog/closelog for å initiere)
funksjon openlog(ident: tekst, opsjoner: heltall, fasilitet: heltall) -> ordbok_tekst {
    la t = _ny_tilstand()
    t["ident"]    = ident
    t["opsjoner"] = tekst_fra_heltall(opsjoner)
    t["fasilitet"] = tekst_fra_heltall(fasilitet)
    t["opna"]     = "sann"
    returner t
}

funksjon closelog(t: ordbok_tekst) {
    t["opna"] = "usann"
}

# ─── Loggfunksjonar ──────────────────────────────────────────────────────────

# Send melding til syslog
funksjon syslog(t: ordbok_tekst, prioritet: heltall, melding: tekst) {
    la mask: heltall = builtin.heltall_fra_tekst(t["maskeval"])
    la prio_bit: heltall = _prio_bit(prioritet)
    # Sjekk mask
    hvis (mask % (prio_bit * 2) < prio_bit) { returner }  # Filtrert bort

    la prio_namn: tekst = _prio_namn(prioritet)
    la ident: tekst = t["ident"]
    la opsjoner: heltall = builtin.heltall_fra_tekst(t["opsjoner"])

    la logger_tag: tekst = ident
    la pid_flag: bool = (opsjoner % 2 == 1)  # LOG_PID = 1

    la logger_cmd: tekst = "logger"
    la prio_arg: tekst = "-p " + _fasilitet_namn(builtin.heltall_fra_tekst(t["fasilitet"])) + "." + prio_namn
    la tag_arg: tekst = ""
    hvis (ident != "") {
        la pid_tekst: tekst = ""
        hvis (pid_flag) {
            la pid = builtin.exec_prosess("echo $$")
            pid_tekst = "[" + _trim(pid) + "]"
        }
        tag_arg = "-t \"" + ident + pid_tekst + "\""
    }
    prøv {
        builtin.exec_prosess(logger_cmd + " " + prio_arg + " " + tag_arg + " \"" + _escape_shell(melding) + "\" 2>/dev/null")
    } fang (e) {}
}

# Forenkla versjon utan tilstandsobjekt
funksjon log(prioritet: heltall, melding: tekst) {
    la prio_namn: tekst = _prio_namn(prioritet)
    prøv {
        builtin.exec_prosess("logger -p user." + prio_namn + " \"" + _escape_shell(melding) + "\" 2>/dev/null")
    } fang (e) {}
}

# Sett loggmaske — berre meldingar med prioritet i masken vert sende
funksjon setlogmask(t: ordbok_tekst, mask: heltall) -> heltall {
    la gammal: heltall = builtin.heltall_fra_tekst(t["maskeval"])
    t["maskeval"] = tekst_fra_heltall(mask)
    returner gammal
}

# LOG_MASK: bit for ein prioritet
funksjon LOG_MASK(prioritet: heltall) -> heltall {
    returner _prio_bit(prioritet)
}

# LOG_UPTO: alle prioritetar opp til og med gjeven
funksjon LOG_UPTO(prioritet: heltall) -> heltall {
    la bit: heltall = _prio_bit(prioritet)
    returner bit * 2 - 1  # alle bits opp til og med
}

# ─── Hendig logg-snarvegar ────────────────────────────────────────────────────

funksjon emerg(t: ordbok_tekst, melding: tekst)   { syslog(t, LOG_EMERG, melding) }
funksjon alert(t: ordbok_tekst, melding: tekst)   { syslog(t, LOG_ALERT, melding) }
funksjon crit(t: ordbok_tekst, melding: tekst)    { syslog(t, LOG_CRIT, melding) }
funksjon feil(t: ordbok_tekst, melding: tekst)    { syslog(t, LOG_ERR, melding) }
funksjon warning(t: ordbok_tekst, melding: tekst) { syslog(t, LOG_WARNING, melding) }
funksjon notice(t: ordbok_tekst, melding: tekst)  { syslog(t, LOG_NOTICE, melding) }
funksjon info(t: ordbok_tekst, melding: tekst)    { syslog(t, LOG_INFO, melding) }
funksjon debug(t: ordbok_tekst, melding: tekst)   { syslog(t, LOG_DEBUG, melding) }

# ─── Les systemlogg ───────────────────────────────────────────────────────────

# Les siste N linjer frå systemloggen
funksjon les_siste(n: heltall) -> liste_tekst {
    prøv {
        # macOS: log show
        la res_mac = builtin.exec_prosess("log show --last 1m --style syslog 2>/dev/null | tail -n " + tekst_fra_heltall(n))
        la trim_mac: tekst = _trim(res_mac)
        hvis (lengde(builtin.split(trim_mac, "")) > 5) {
            la linjer = builtin.split(trim_mac, "\n")
            la resultat: liste_tekst = []
            la i: heltall = 0
            mens (i < lengde(linjer)) {
                la s: tekst = _trim(linjer[i])
                hvis (s != "") { legg_til(resultat, s) }
                i = i + 1
            }
            returner resultat
        }
    } fang (e) {}
    prøv {
        # Linux: journalctl
        la res_linux = builtin.exec_prosess("journalctl -n " + tekst_fra_heltall(n) + " --no-pager 2>/dev/null")
        la linjer = builtin.split(res_linux, "\n")
        la resultat: liste_tekst = []
        la i: heltall = 0
        mens (i < lengde(linjer)) {
            la s: tekst = _trim(linjer[i])
            hvis (s != "") { legg_til(resultat, s) }
            i = i + 1
        }
        returner resultat
    } fang (e) {}
    returner []
}

# Søk i syslog etter mønster
funksjon søk_logg(mønster: tekst, n: heltall) -> liste_tekst {
    prøv {
        la res = builtin.exec_prosess("grep -i \"" + _escape_shell(mønster) + "\" /var/log/syslog 2>/dev/null | tail -n " + tekst_fra_heltall(n))
        la linjer = builtin.split(res, "\n")
        la resultat: liste_tekst = []
        la i: heltall = 0
        mens (i < lengde(linjer)) {
            la s: tekst = _trim(linjer[i])
            hvis (s != "") { legg_til(resultat, s) }
            i = i + 1
        }
        returner resultat
    } fang (e) { returner [] }
    returner []
}

# ─── Internhjelpar ─────────────────────────────────────────────────────────────

funksjon _prio_namn(prioritet: heltall) -> tekst {
    hvis (prioritet == LOG_EMERG)   { returner "emerg" }
    hvis (prioritet == LOG_ALERT)   { returner "alert" }
    hvis (prioritet == LOG_CRIT)    { returner "crit" }
    hvis (prioritet == LOG_ERR)     { returner "err" }
    hvis (prioritet == LOG_WARNING) { returner "warning" }
    hvis (prioritet == LOG_NOTICE)  { returner "notice" }
    hvis (prioritet == LOG_INFO)    { returner "info" }
    returner "debug"
}

funksjon _fasilitet_namn(fasilitet: heltall) -> tekst {
    hvis (fasilitet == LOG_KERN)   { returner "kern" }
    hvis (fasilitet == LOG_USER)   { returner "user" }
    hvis (fasilitet == LOG_MAIL)   { returner "mail" }
    hvis (fasilitet == LOG_DAEMON) { returner "daemon" }
    hvis (fasilitet == LOG_AUTH)   { returner "auth" }
    hvis (fasilitet == LOG_LPR)    { returner "lpr" }
    hvis (fasilitet == LOG_NEWS)   { returner "news" }
    hvis (fasilitet == LOG_CRON)   { returner "cron" }
    returner "user"
}

funksjon _prio_bit(prioritet: heltall) -> heltall {
    # 2^prioritet
    la res: heltall = 1
    la i: heltall = 0
    mens (i < prioritet) { res = res * 2  i = i + 1 }
    returner res
}

funksjon _escape_shell(s: tekst) -> tekst {
    la t = builtin.split(s, "")
    la r: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(t)) {
        la c: tekst = t[i]
        hvis (c == "\"") { legg_til(r, "\\\"") }
        ellers hvis (c == "\\") { legg_til(r, "\\\\") }
        ellers hvis (c == "$")  { legg_til(r, "\\$") }
        ellers { legg_til(r, c) }
        i = i + 1
    }
    returner builtin.join(r, "")
}

funksjon tekst_fra_heltall(n: heltall) -> tekst {
    prøv { returner builtin.join([n], "") } fang (e) { returner "0" }
    returner "0"
}

funksjon _trim(s: tekst) -> tekst {
    la t = builtin.split(s, "")
    la n: heltall = lengde(t)
    la a: heltall = 0  la b: heltall = n
    mens (a < b og (t[a]==" " eller t[a]=="\t" eller t[a]=="\n" eller t[a]=="\r")) { a=a+1 }
    mens (b > a og (t[b-1]==" " eller t[b-1]=="\t" eller t[b-1]=="\n" eller t[b-1]=="\r")) { b=b-1 }
    returner builtin.join(builtin.slice(t, a, b), "")
}

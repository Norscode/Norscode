funksjon standard_server_logg(ctx, status)
    returner {
        "method": "GET",
        "path": "/helse",
        "status": "200",
        "ok": sann
    }
slutt

funksjon serve_handle_one(ncb, rå)
    returner "X-Server-Logg: {\"status\":\"200\"}"
slutt

funksjon start() -> heiltall {
    la ctx: ordbok<tekst, tekst> = {
        "__method__": "get",
        "__path__": "/helse",
        "__request_id__": "req-1"
    }
    la logg = standard_server_logg(ctx, 200)
    assert_eq(logg["method"], "GET")
    assert_eq(logg["path"], "/helse")
    assert_eq(logg["status"], "200")
    assert_eq(logg["ok"], sann)

    la ncb: ordbok<tekst, tekst> = {
        "route_handlers": [],
        "functions": {}
    }
    la resp = serve_handle_one(ncb, "GET /helse HTTP/1.1\r\nHost: example.test\r\n\r\n")
    assert_eq(builtin.contains(resp, "X-Server-Logg:"), sann)
    assert_eq(builtin.contains(resp, "\"status\":\"200\""), sann)
    returner 0
}

bruk selfhost.common som sh

funksjon start() -> heltall {

    la env_navn: liste_tekst = ["x", "y"]
    la env_verdier: liste_heltall = [7, 3]
    la expr_env: tekst = sh.disasm_uttrykk_med_miljo("x*2+y", env_navn, env_verdier)
    assert_eq(expr_env, "0: PUSH 7\n1: PUSH 2\n2: MUL\n3: PUSH 3\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_env_c: tekst = sh.kompiler_uttrykk_til_c_med_miljo("x+y", env_navn, env_verdier)
    assert_ne(expr_env_c, "")

    la expr_hvis: tekst = sh.disasm_uttrykk("hvis 1==1 da 7 ellers 9")
    assert_eq(expr_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 9\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_hvis_ellers_hvis: tekst = sh.disasm_uttrykk("hvis 0==1 da 10 ellers_hvis 1==1 da 20 ellers 30")
    assert_eq(expr_hvis_ellers_hvis, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_hvis_elif_alias: tekst = sh.disasm_uttrykk("hvis 0==1 da 10 elif 1==1 da 20 ellers 30")
    assert_eq(expr_hvis_elif_alias, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_if_then_else_alias: tekst = sh.disasm_uttrykk("if 1==1 then 7 else 9")
    assert_eq(expr_if_then_else_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 9\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_if_elseif_alias: tekst = sh.disasm_uttrykk("if 0==1 then 10 elseif 1==1 then 20 else 30")
    assert_eq(expr_if_elseif_alias, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_if_elsif_alias: tekst = sh.disasm_uttrykk("if 0==1 then 10 elsif 1==1 then 20 else 30")
    assert_eq(expr_if_elsif_alias, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 16\n6: LABEL 6\n7: PUSH 1\n8: PUSH 1\n9: EQ\n10: JZ 13\n11: PUSH 20\n12: JMP 15\n13: LABEL 13\n14: PUSH 30\n15: LABEL 15\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la expr_and_or_not_alias: tekst = sh.disasm_uttrykk("not 0 and 1 or 0")
    assert_eq(expr_and_or_not_alias, "0: PUSH 0\n1: NOT\n2: PUSH 1\n3: AND\n4: PUSH 0\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_english_cmp_alias: tekst = sh.disasm_uttrykk("4 greater_or_equal 4 and 3 less_than 4")
    assert_eq(expr_english_cmp_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PUSH 3\n5: PUSH 4\n6: LT\n7: AND\n8: PRINT\n9: HALT\n")

    la expr_english_is_not_alias: tekst = sh.disasm_uttrykk("7 is_not 8")
    assert_eq(expr_english_is_not_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_eq_alias: tekst = sh.disasm_uttrykk("7 eq 7")
    assert_eq(expr_english_eq_alias, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_english_neq_alias: tekst = sh.disasm_uttrykk("7 neq 8")
    assert_eq(expr_english_neq_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_on_off_alias: tekst = sh.disasm_uttrykk("on and not off")
    assert_eq(expr_english_on_off_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_yes_no_alias: tekst = sh.disasm_uttrykk("yes and not no")
    assert_eq(expr_english_yes_no_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_enabled_disabled_alias: tekst = sh.disasm_uttrykk("enabled and not disabled")
    assert_eq(expr_english_enabled_disabled_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_active_inactive_alias: tekst = sh.disasm_uttrykk("active and not inactive")
    assert_eq(expr_english_active_inactive_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_truthy_falsy_alias: tekst = sh.disasm_uttrykk("truthy and not falsy")
    assert_eq(expr_english_truthy_falsy_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_affirmative_negative_alias: tekst = sh.disasm_uttrykk("affirmative and not negative")
    assert_eq(expr_english_affirmative_negative_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_affirm_deny_alias: tekst = sh.disasm_uttrykk("affirm and not deny")
    assert_eq(expr_english_affirm_deny_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_approved_rejected_alias: tekst = sh.disasm_uttrykk("approved and not rejected")
    assert_eq(expr_english_approved_rejected_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_accepted_declined_alias: tekst = sh.disasm_uttrykk("accepted and not declined")
    assert_eq(expr_english_accepted_declined_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_confirmed_denied_alias: tekst = sh.disasm_uttrykk("confirmed and not denied")
    assert_eq(expr_english_confirmed_denied_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_pass_fail_alias: tekst = sh.disasm_uttrykk("pass and not fail")
    assert_eq(expr_english_pass_fail_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_success_failure_alias: tekst = sh.disasm_uttrykk("success and not failure")
    assert_eq(expr_english_success_failure_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_allow_block_alias: tekst = sh.disasm_uttrykk("allow and not block")
    assert_eq(expr_english_allow_block_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_permit_forbid_alias: tekst = sh.disasm_uttrykk("permit and not forbid")
    assert_eq(expr_english_permit_forbid_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_valid_invalid_alias: tekst = sh.disasm_uttrykk("valid and not invalid")
    assert_eq(expr_english_valid_invalid_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_ok_not_ok_alias: tekst = sh.disasm_uttrykk("ok and not not_ok")
    assert_eq(expr_english_ok_not_ok_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_ready_not_ready_alias: tekst = sh.disasm_uttrykk("ready and not not_ready")
    assert_eq(expr_english_ready_not_ready_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_safe_unsafe_alias: tekst = sh.disasm_uttrykk("safe and not unsafe")
    assert_eq(expr_english_safe_unsafe_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_secure_insecure_alias: tekst = sh.disasm_uttrykk("secure and not insecure")
    assert_eq(expr_english_secure_insecure_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_trusted_untrusted_alias: tekst = sh.disasm_uttrykk("trusted and not untrusted")
    assert_eq(expr_english_trusted_untrusted_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_open_closed_alias: tekst = sh.disasm_uttrykk("open and not closed")
    assert_eq(expr_english_open_closed_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_public_private_alias: tekst = sh.disasm_uttrykk("public and not private")
    assert_eq(expr_english_public_private_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_visible_hidden_alias: tekst = sh.disasm_uttrykk("visible and not hidden")
    assert_eq(expr_english_visible_hidden_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_present_absent_alias: tekst = sh.disasm_uttrykk("present and not absent")
    assert_eq(expr_english_present_absent_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_online_offline_alias: tekst = sh.disasm_uttrykk("online and not offline")
    assert_eq(expr_english_online_offline_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_connected_disconnected_alias: tekst = sh.disasm_uttrykk("connected and not disconnected")
    assert_eq(expr_english_connected_disconnected_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_available_unavailable_alias: tekst = sh.disasm_uttrykk("available and not unavailable")
    assert_eq(expr_english_available_unavailable_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_reachable_unreachable_alias: tekst = sh.disasm_uttrykk("reachable and not unreachable")
    assert_eq(expr_english_reachable_unreachable_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_working_broken_alias: tekst = sh.disasm_uttrykk("working and not broken")
    assert_eq(expr_english_working_broken_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_stable_unstable_alias: tekst = sh.disasm_uttrykk("stable and not unstable")
    assert_eq(expr_english_stable_unstable_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_correct_incorrect_alias: tekst = sh.disasm_uttrykk("correct and not incorrect")
    assert_eq(expr_english_correct_incorrect_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_complete_incomplete_alias: tekst = sh.disasm_uttrykk("complete and not incomplete")
    assert_eq(expr_english_complete_incomplete_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_clean_dirty_alias: tekst = sh.disasm_uttrykk("clean and not dirty")
    assert_eq(expr_english_clean_dirty_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_up_down_alias: tekst = sh.disasm_uttrykk("up and not down")
    assert_eq(expr_english_up_down_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_alive_dead_alias: tekst = sh.disasm_uttrykk("alive and not dead")
    assert_eq(expr_english_alive_dead_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_awake_asleep_alias: tekst = sh.disasm_uttrykk("awake and not asleep")
    assert_eq(expr_english_awake_asleep_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_healthy_unhealthy_alias: tekst = sh.disasm_uttrykk("healthy and not unhealthy")
    assert_eq(expr_english_healthy_unhealthy_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_synced_unsynced_alias: tekst = sh.disasm_uttrykk("synced and not unsynced")
    assert_eq(expr_english_synced_unsynced_alias, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PRINT\n5: HALT\n")

    la expr_english_equal_to_alias: tekst = sh.disasm_uttrykk("7 equal_to 7")
    assert_eq(expr_english_equal_to_alias, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_english_equal_to_phrase: tekst = sh.disasm_uttrykk("7 equal to 7")
    assert_eq(expr_english_equal_to_phrase, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_english_is_equal_to_phrase: tekst = sh.disasm_uttrykk("7 is equal to 7")
    assert_eq(expr_english_is_equal_to_phrase, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_english_is_equal_to_compact_alias: tekst = sh.disasm_uttrykk("7 is_equal_to 7")
    assert_eq(expr_english_is_equal_to_compact_alias, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_english_not_equal_to_alias: tekst = sh.disasm_uttrykk("7 not_equal_to 8")
    assert_eq(expr_english_not_equal_to_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_not_equal_to_phrase: tekst = sh.disasm_uttrykk("7 not equal to 8")
    assert_eq(expr_english_not_equal_to_phrase, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_not_equal_to_phrase: tekst = sh.disasm_uttrykk("7 is not equal to 8")
    assert_eq(expr_english_is_not_equal_to_phrase, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_not_equal_to_compact_alias: tekst = sh.disasm_uttrykk("7 is_not_equal_to 8")
    assert_eq(expr_english_is_not_equal_to_compact_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_isnt_alias: tekst = sh.disasm_uttrykk("7 isnt 8")
    assert_eq(expr_english_isnt_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_less_equal_alias: tekst = sh.disasm_uttrykk("3 less_equal 4")
    assert_eq(expr_english_less_equal_alias, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_greater_equal_alias: tekst = sh.disasm_uttrykk("4 greater_equal 4")
    assert_eq(expr_english_greater_equal_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_less_than_phrase: tekst = sh.disasm_uttrykk("3 less than 4")
    assert_eq(expr_english_less_than_phrase, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_english_greater_than_phrase: tekst = sh.disasm_uttrykk("4 greater than 3")
    assert_eq(expr_english_greater_than_phrase, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_english_is_less_than_phrase: tekst = sh.disasm_uttrykk("3 is less than 4")
    assert_eq(expr_english_is_less_than_phrase, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_english_is_greater_than_phrase: tekst = sh.disasm_uttrykk("4 is greater than 3")
    assert_eq(expr_english_is_greater_than_phrase, "0: PUSH 4\n1: PUSH 3\n2: GT\n3: PRINT\n4: HALT\n")

    la expr_english_less_than_or_equal_phrase: tekst = sh.disasm_uttrykk("3 less than or equal 3")
    assert_eq(expr_english_less_than_or_equal_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_less_than_or_equal_to_phrase: tekst = sh.disasm_uttrykk("3 less than or equal to 3")
    assert_eq(expr_english_less_than_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_greater_than_or_equal_phrase: tekst = sh.disasm_uttrykk("4 greater than or equal 4")
    assert_eq(expr_english_greater_than_or_equal_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_greater_than_or_equal_to_phrase: tekst = sh.disasm_uttrykk("4 greater than or equal to 4")
    assert_eq(expr_english_greater_than_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_than_or_equal_to_phrase: tekst = sh.disasm_uttrykk("3 is less than or equal to 3")
    assert_eq(expr_english_is_less_than_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_than_or_equal_to_phrase: tekst = sh.disasm_uttrykk("4 is greater than or equal to 4")
    assert_eq(expr_english_is_greater_than_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_or_equal_phrase: tekst = sh.disasm_uttrykk("3 is less or equal 3")
    assert_eq(expr_english_is_less_or_equal_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_or_equal_to_phrase: tekst = sh.disasm_uttrykk("3 is less or equal to 3")
    assert_eq(expr_english_is_less_or_equal_to_phrase, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_or_equal_phrase: tekst = sh.disasm_uttrykk("4 is greater or equal 4")
    assert_eq(expr_english_is_greater_or_equal_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_or_equal_to_phrase: tekst = sh.disasm_uttrykk("4 is greater or equal to 4")
    assert_eq(expr_english_is_greater_or_equal_to_phrase, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_than_compact_alias: tekst = sh.disasm_uttrykk("3 is_less_than 4")
    assert_eq(expr_english_is_less_than_compact_alias, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_english_is_greater_or_equal_compact_alias: tekst = sh.disasm_uttrykk("4 is_greater_or_equal 4")
    assert_eq(expr_english_is_greater_or_equal_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_than_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("3 is_less_than_or_equal_to 3")
    assert_eq(expr_english_is_less_than_or_equal_to_compact_alias, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_than_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("4 is_greater_than_or_equal_to 4")
    assert_eq(expr_english_is_greater_than_or_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_less_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("3 is_less_or_equal_to 3")
    assert_eq(expr_english_is_less_or_equal_to_compact_alias, "0: PUSH 3\n1: PUSH 3\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_is_greater_or_equal_to_compact_alias: tekst = sh.disasm_uttrykk("4 is_greater_or_equal_to 4")
    assert_eq(expr_english_is_greater_or_equal_to_compact_alias, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_english_times_alias: tekst = sh.disasm_uttrykk("3 times 4")
    assert_eq(expr_english_times_alias, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_multiplied_by_alias: tekst = sh.disasm_uttrykk("3 multiplied_by 4")
    assert_eq(expr_english_multiplied_by_alias, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_multiply_by_phrase: tekst = sh.disasm_uttrykk("3 multiply by 4")
    assert_eq(expr_english_multiply_by_phrase, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_multiplied_by_phrase: tekst = sh.disasm_uttrykk("3 multiplied by 4")
    assert_eq(expr_english_multiplied_by_phrase, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_english_divided_by_alias: tekst = sh.disasm_uttrykk("8 divided_by 2")
    assert_eq(expr_english_divided_by_alias, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_divided_by_phrase: tekst = sh.disasm_uttrykk("8 divided by 2")
    assert_eq(expr_english_divided_by_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_divide_by_phrase: tekst = sh.disasm_uttrykk("8 divide by 2")
    assert_eq(expr_english_divide_by_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_add_alias: tekst = sh.disasm_uttrykk("3 add 4")
    assert_eq(expr_english_add_alias, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_english_subtract_alias: tekst = sh.disasm_uttrykk("10 subtract 3")
    assert_eq(expr_english_subtract_alias, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_english_divide_alias: tekst = sh.disasm_uttrykk("8 divide 2")
    assert_eq(expr_english_divide_alias, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_english_mod_of_alias: tekst = sh.disasm_uttrykk("17 mod_of 5")
    assert_eq(expr_english_mod_of_alias, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_english_modulo_of_phrase: tekst = sh.disasm_uttrykk("17 modulo of 5")
    assert_eq(expr_english_modulo_of_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_english_remainder_alias: tekst = sh.disasm_uttrykk("17 remainder 5")
    assert_eq(expr_english_remainder_alias, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_english_remainder_of_phrase: tekst = sh.disasm_uttrykk("17 remainder of 5")
    assert_eq(expr_english_remainder_of_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_hvis_env: tekst = sh.disasm_uttrykk_med_miljo("hvis x>y da x ellers y", env_navn, env_verdier)
    assert_eq(expr_hvis_env, "0: PUSH 7\n1: PUSH 3\n2: GT\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 3\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_hvis_c: tekst = sh.kompiler_uttrykk_til_c("hvis 1==1 da 7 ellers 9")
    assert_ne(expr_hvis_c, "")

    la expr_err: tekst = sh.disasm_uttrykk("2 +")
    assert_eq(expr_err, "/* feil: uttrykket avsluttes med operator ved token 1 */")

    la expr_err2: tekst = sh.disasm_uttrykk("2 + )")
    assert_eq(expr_err2, "/* feil: mangler verdi før ) ved token 2 */")

    la expr_err3: tekst = sh.disasm_uttrykk("2+$")
    assert_eq(expr_err3, "/* feil: ukjent token/navn i uttrykk $ ved token 2 */")

    la expr_err4: tekst = sh.disasm_uttrykk("foo+1")
    assert_eq(expr_err4, "/* feil: ukjent token/navn i uttrykk foo ved token 0 */")

    la expr_env_err: tekst = sh.disasm_uttrykk_med_miljo("z+1", env_navn, env_verdier)
    assert_eq(expr_env_err, "/* feil: ukjent token/navn i uttrykk z ved token 0 */")

    la env_navn_kort: liste_tekst = ["x"]
    la env_verdier_lang: liste_heltall = [1, 2]
    la expr_env_err2: tekst = sh.disasm_uttrykk_med_miljo("x+1", env_navn_kort, env_verdier_lang)
    assert_eq(expr_env_err2, "/* feil: navn/miljø-verdier må ha samme lengde */")

    la expr_err5: tekst = sh.disasm_uttrykk("(2+3")
    assert_eq(expr_err5, "/* feil: mangler ) i uttrykk ved token 0 */")

    la script_dis: tekst = sh.disasm_skript("x=2+3;y=x*4;y+1")
    assert_eq(script_dis, "0: PUSH 20\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_la_dis: tekst = sh.disasm_skript("la x=2+3;la y=x*4;y+1")
    assert_eq(script_la_dis, "0: PUSH 20\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_trailing_semicolon: tekst = sh.disasm_skript("x=2;y=3;x+y;")
    assert_eq(script_trailing_semicolon, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_empty_statements: tekst = sh.disasm_skript(";;la x=2;;x+1;;")
    assert_eq(script_empty_statements, "0: PUSH 2\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_if_statement_before_final: tekst = sh.disasm_skript("la x=1;hvis x==1 da 10 ellers 20;returner x+2")
    assert_eq(script_if_statement_before_final, "0: PUSH 1\n1: PUSH 2\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_expr_statement_before_final: tekst = sh.disasm_skript("1+1;la y=2;y")
    assert_eq(script_expr_statement_before_final, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_returner: tekst = sh.disasm_skript("la x=2;returner x+3")
    assert_eq(script_returner, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_returner_semicolon: tekst = sh.disasm_skript("la x=2;returner x+3;")
    assert_eq(script_returner_semicolon, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_sett_ok: tekst = sh.disasm_skript("la x=2;sett x=x+3;returner x")
    returner 0
}

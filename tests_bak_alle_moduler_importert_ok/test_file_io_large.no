funksjon bygg_stor_blokk() -> tekst {
    la out = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    la i: heltall = 0
    mens i < 13 {
        out = out + out
        i = i + 1
    }
    returner out
}

funksjon start() -> heltall {
    la stor_sti = "/tmp/norscode_native_io_large.txt"
    la stort_innhald = bygg_stor_blokk()
    la forventet_lengde = 524288

    fil_skriv(stor_sti, stort_innhald)
    assert(fil_finnes(stor_sti))
    la lest_stort = fil_les(stor_sti)
    assert_eq(lengde(lest_stort), forventet_lengde)
    assert_eq(lest_stort, stort_innhald)

    returner 0
}

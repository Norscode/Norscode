funksjon response_status_vm(resp)
    returner resp["status"]
slutt

funksjon response_body_vm(resp)
    returner resp["body"]
slutt

funksjon text_response_vm(text)
    returner {"status": 200, "body": text, "content-type": "text/plain; charset=utf-8"}
slutt

funksjon direct_response_vm(resp)
    returner resp
slutt

funksjon response_builder_vm(status, headers, body)
    returner {"status": status, "body": body, "x_test": "ja"}
slutt

funksjon start() -> heiltall {
    la tekstsvar = text_response_vm("hei")
    assert_eq(response_status_vm(tekstsvar), 200)
    assert_eq(response_body_vm(tekstsvar), "hei")
    assert_eq(tekstsvar["content-type"], "text/plain; charset=utf-8")

    la direkte = {"status": 201, "body": "ok", "x_test": "ja"}
    assert_eq(response_status_vm(direkte), 201)
    assert_eq(response_body_vm(direkte), "ok")
    assert_eq(direkte["x_test"], "ja")
    returner 0
}

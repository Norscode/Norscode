bruk selfhost.common som sh

funksjon start() -> heltall {
    # Unary NOT må bindes før AND
    la expr_not_and: tekst = sh.disasm_uttrykk("ikkje 0 og 1")
    assert_eq(
        expr_not_and,
        "0: PUSH 0\n1: NOT\n2: PUSH 1\n3: AND\n4: PRINT\n5: HALT\n"
    )

    # Unary NOT må bindes før OR
    la expr_not_or: tekst = sh.disasm_uttrykk("ikkje 0 eller 1")
    assert_eq(
        expr_not_or,
        "0: PUSH 0\n1: NOT\n2: PUSH 1\n3: OR\n4: PRINT\n5: HALT\n"
    )

    # AND må bindes før OR
    la expr_and_or: tekst = sh.disasm_uttrykk("1 og 0 eller 1")
    assert_eq(
        expr_and_or,
        "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PUSH 1\n4: OR\n5: PRINT\n6: HALT\n"
    )

    # Parentheses skal overstyre precedence
    la expr_grouped: tekst = sh.disasm_uttrykk("(1 eller 0) og 1")
    assert_eq(
        expr_grouped,
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: PUSH 1\n4: AND\n5: PRINT\n6: HALT\n"
    )

    # Ingen redundant SWAP skal introduseres for vanlige boolske uttrykk
    la expr_swap_guard: tekst = sh.disasm_uttrykk("ikkje 1 og 0")
    assert_ne(expr_swap_guard, "0: PUSH 1\n1: SWAP\n2: NOT\n3: SWAP\n4: OR\n5: PRINT\n6: HALT\n")

    returner 0
}

bruk std.tekst som t
bruk examples.api_advanced som api

funksjon start() -> heiltall {
    la rot = api.root({})
    assert(t.inneholder(rot, "\"Norscode Advanced REST API\""))
    assert(t.inneholder(rot, "\"OpenAPI/Swagger\""))

    la helse = api.helse({})
    assert(t.inneholder(helse, "\"status\": \"ok\""))
    assert(t.inneholder(helse, "\"uptime\": \"100%\""))

    la info = api.api_info({})
    assert(t.inneholder(info, "\"/upload\""))
    assert(t.inneholder(info, "\"Request validation\""))

    la spec = api.openapi_spec({})
    assert(t.inneholder(spec, "\"openapi\": \"3.0.0\""))
    assert(t.inneholder(spec, "\"/users/{id}\""))
    assert(t.inneholder(spec, "\"summary\": \"Get user by ID\""))

    la swagger = api.swagger_ui({})
    assert(t.inneholder(swagger, "SwaggerUIBundle"))
    assert(t.inneholder(swagger, "/openapi.json"))

    skriv("api_advanced smoke OK")
    returner 0
}

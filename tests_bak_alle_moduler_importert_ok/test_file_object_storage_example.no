bruk std.env som env
bruk std.path som path
bruk std.fil som fil
bruk std.lagring som lagring
bruk examples.file_object_storage som ex

funksjon start() -> heiltall {
    la tekststi = ex.tmpsti("norscode_fil_og_objekt_example.txt")
    la objektsti = ex.tmpsti("norscode_fil_og_objekt_example.json")

    fil.skriv_fil(tekststi, "hei")
    assert_eq(fil.les(tekststi), "hei")

    la data: ordbok_tekst = {}
    lagring.sett_tekst(data, "navn", "Norscode")
    lagring.sett_tall(data, "versjon", 1)
    lagring.lagre(objektsti, data)

    la lastet = lagring.last(objektsti)
    assert_eq(lagring.hent_tekst(lastet, "navn"), "Norscode")
    assert_eq(lagring.hent_tall(lastet, "versjon"), 1)

    assert_eq(path.basename(tekststi), "norscode_fil_og_objekt_example.txt")
    assert_eq(path.basename(objektsti), "norscode_fil_og_objekt_example.json")

    skriv("file_object_storage example OK")
    returner 0
}

# Minimal smoke-test for list append with TOKEN_FORMAT_V1 objects.
# Dette isolerer det full lexer trenger: [] + legg_til + token-ordbok + liste-retur.

funksjon lag_token(type: tekst, verdi: tekst, linje: heltall, kolonne: heltall) -> ordbok<tekst, tekst> {
    returner {
        "type": type,
        "value": verdi,
        "line": linje,
        "column": kolonne
    }
}

funksjon start() -> liste<ordbok<tekst, tekst>> {
    la tokens: liste<ordbok<tekst, tekst>> = []
    legg_til(tokens, lag_token("EOF", "", 1, 1))
    returner tokens
}

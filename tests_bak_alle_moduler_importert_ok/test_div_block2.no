bruk selfhost.common som sh

funksjon start() -> heltall {
    la expr_norsk_dele_seg_paa_underscore_ascii: tekst = sh.disasm_uttrykk("8 dele_seg_paa 2")
    assert_eq(expr_norsk_dele_seg_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_deler_seg_pa: tekst = sh.disasm_uttrykk("8 deler seg pa 2")
    assert_eq(expr_norsk_deler_seg_pa, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")
    returner 0
}

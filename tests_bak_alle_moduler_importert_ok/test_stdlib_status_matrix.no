bruk std.stdlib_status som ss

funksjon start() -> heiltall {
    la s = ss.samandrag()
    assert(s.total >= 15)
    assert(s.stabil >= 12)
    assert_eq(s.stub, 0)

    assert(ss.er_stabil("tekst"))
    assert(ss.er_stabil("json"))
    assert(ss.er_stabil("web"))
    assert(ss.er_stabil("asynk"))
    assert_eq(ss.status_for("multiprocessing"), "eksperimentell")
    assert_eq(ss.status_for("manglar"), "ukjent")

    skriv("test_stdlib_status_matrix OK")
    returner 0
}

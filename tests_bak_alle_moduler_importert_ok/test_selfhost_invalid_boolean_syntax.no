bruk selfhost.common som sh

funksjon forvent_feil(expr: tekst) -> bool {
    la resultat: tekst = sh.parse_feil(expr)
    returner tekst_inneholder(resultat, "Feil")
}

funksjon start() -> heltall {
    # Manglende venstre operand
    assert(forvent_feil("og 1"))

    # Manglende høyre operand
    assert(forvent_feil("1 og"))

    # Ugyldig unary kombinasjon
    assert(forvent_feil("ikkje og 1"))

    # Ubalanserte parenteser
    assert(forvent_feil("(1 og 0"))
    assert(forvent_feil("1 eller 0)"))

    # Tom grouping
    assert(forvent_feil("()"))

    returner 0
}

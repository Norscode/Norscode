funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "routes": {},
        "handler_responses": {},
        "handler_direct_responses": {},
        "handler_response_status": {},
        "handler_response_content_type": {},
        "handler_response_headers": {},
        "error_middlewares": []
    }
slutt

funksjon route(server, metode, sti, handler)
    server["routes"][metode + " " + sti] = handler
    returner server
slutt

funksjon request_context(metode, sti, path, headers, body)
    returner {
        "method": metode,
        "path": sti,
        "headers": headers,
        "body": body
    }
slutt

funksjon response_builder(status, headers, body)
    svar = {}
    svar["status"] = status
    svar["body"] = body
    svar["content-type"] = headers["content-type"]
    hvis headers["x-direct"] != null
        svar["x-direct"] = headers["x-direct"]
    slutt
    returner svar
slutt

funksjon dispatch_request(server, metode, sti, ctx)
    la key = metode + " " + sti

    hvis key == "GET /hei"
        returner {
            "status": 200,
            "body": "hei frå handler",
            "etag": "\"hei_handler:/hei\"",
            "last-modified": "Tue, 16 Jun 2026 12:00:00 GMT",
            "__response_middleware_trace__": ["cors"]
        }
    slutt

    hvis key == "GET /mangler"
        returner {
            "status": 404,
            "body": "{\"error\":\"ikkje funne\",\"status\":404}",
            "__error_middleware_trace__": ["error-json"]
        }
    slutt

    hvis key == "POST /blokker"
        returner {
            "status": 405,
            "body": "{\"error\":\"Method Not Allowed\",\"status\":405}",
            "allow": "GET, HEAD, OPTIONS"
        }
    slutt

    hvis key == "POST /hei"
        returner {
            "status": 405,
            "body": "{\"error\":\"Method Not Allowed\",\"status\":405}",
            "allow": "GET, HEAD, OPTIONS"
        }
    slutt

    returner {
        "status": 200,
        "body": "ok"
    }
slutt

funksjon register_handler_response(server, handler, body)
    server["handler_responses"][handler] = body
    returner server
slutt

funksjon register_request_middleware(server, namn)
    server["request_middlewares"] = [namn]
    returner server
slutt

funksjon register_response_middleware(server, namn)
    server["response_middlewares"] = [namn]
    returner server
slutt

funksjon register_error_middleware(server, namn)
    server["error_middlewares"] = [namn]
    returner server
slutt

funksjon register_bad_request_response(server, handler, melding)
    returner server
slutt

funksjon register_forbidden_response(server, handler, melding)
    returner server
slutt

funksjon register_unauthorized_response(server, handler, melding)
    returner server
slutt

funksjon register_conflict_response(server, handler, melding)
    returner server
slutt

funksjon register_unprocessable_entity_response(server, handler, melding)
    returner server
slutt

funksjon register_too_many_requests_response(server, handler, melding)
    returner server
slutt

funksjon register_internal_server_error_response(server, handler, melding)
    returner server
slutt

funksjon register_service_unavailable_response(server, handler, melding)
    returner server
slutt

funksjon register_bad_gateway_response(server, handler, melding)
    returner server
slutt

funksjon register_gateway_timeout_response(server, handler, melding)
    returner server
slutt

funksjon register_method_not_allowed_response(server, handler, allow)
    returner server
slutt

funksjon register_handler_response_object(server, handler, status, body, content_type)
    returner server
slutt

funksjon register_handler_response_headers(server, handler, headers)
    returner server
slutt

funksjon register_redirect_response(server, handler, location, status)
    returner server
slutt

funksjon register_moved_permanently_response(server, handler, location)
    returner server
slutt

funksjon register_temporary_redirect_response(server, handler, location)
    returner server
slutt

funksjon register_json_response(server, handler, status, body)
    returner server
slutt

funksjon register_error_response(server, handler, status, melding)
    returner server
slutt

funksjon register_created_response(server, handler, body, location)
    returner server
slutt

funksjon register_accepted_response(server, handler, body)
    returner server
slutt

funksjon register_no_content_response(server, handler)
    returner server
slutt

funksjon register_not_modified_response(server, handler, etag, last_modified)
    returner server
slutt

funksjon start() -> heiltall {
    la server = ny_server(8091)
    route(server, "GET", "/hei", "hei_handler")
    register_handler_response(server, "hei_handler", "hei frå handler")
    register_request_middleware(server, "auth")
    register_response_middleware(server, "cors")
    register_error_middleware(server, "error-json")

    la ctx = request_context("GET", "/hei", {}, {}, "")
    la response = dispatch_request(server, "GET", "/hei", ctx)
    assert_eq(response["etag"], "\"hei_handler:/hei\"")
    assert_eq(response["last-modified"], "Tue, 16 Jun 2026 12:00:00 GMT")

    la missing_ctx = request_context("GET", "/mangler", {}, {}, "")
    la missing = dispatch_request(server, "GET", "/mangler", missing_ctx)
    la error_trace = missing["__error_middleware_trace__"]
    assert_eq(error_trace[0], "error-json")

    la wrong_ctx = request_context("POST", "/hei", {}, {}, "")
    la wrong = dispatch_request(server, "POST", "/hei", wrong_ctx)
    assert_eq(wrong["allow"], "GET, HEAD, OPTIONS")

    returner 0
}

funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "startup_hooks": [],
        "shutdown_hooks": []
    }
slutt

funksjon register_startup_hook(server, namn)
    server["startup_hooks"] = [namn]
    returner server
slutt

funksjon register_shutdown_hook(server, namn)
    server["shutdown_hooks"] = [namn]
    returner server
slutt

funksjon køyre_startup_hooks(server)
    returner {
        "phase": "startup",
        "__startup_hook_trace__": server["startup_hooks"]
    }
slutt

funksjon køyre_shutdown_hooks(server)
    returner {
        "phase": "shutdown",
        "__shutdown_hook_trace__": server["shutdown_hooks"]
    }
slutt

funksjon start() -> heiltall {
    la server = ny_server(8087)
    register_startup_hook(server, "init-db")
    register_startup_hook(server, "warm-cache")
    register_shutdown_hook(server, "flush-log")

    la startup = køyre_startup_hooks(server)
    la startup_trace = startup["__startup_hook_trace__"]
    assert_eq(startup["phase"], "startup")
    assert_eq(lengde(startup_trace), 1)
    assert_eq(startup_trace[0], "warm-cache")

    la shutdown = køyre_shutdown_hooks(server)
    la shutdown_trace = shutdown["__shutdown_hook_trace__"]
    assert_eq(shutdown["phase"], "shutdown")
    assert_eq(lengde(shutdown_trace), 1)
    assert_eq(shutdown_trace[0], "flush-log")

    returner 0
}

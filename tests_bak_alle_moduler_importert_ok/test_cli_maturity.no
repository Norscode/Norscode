bruk std.tekst som t

funksjon start() -> heiltall {
    assert(fil_finnes("bin/nc"))

    la cli = fil_les("bin/nc")
    assert(t.inneholder(cli, "run <fil.no>"))
    assert(t.inneholder(cli, "check <fil.no>"))
    assert(t.inneholder(cli, "feature-check [fil.no ...]"))
    assert(t.inneholder(cli, "maintenance [status|lane|docs|cleanup|seed|tests|maturity|summary|report|report-json|verify]"))
    assert(t.inneholder(cli, "doctor"))
    assert(t.inneholder(cli, "lsp"))
    assert(t.inneholder(cli, "test"))
    assert(t.inneholder(cli, "startproject"))
    assert(t.inneholder(cli, "startapp"))

    skriv("test_cli_maturity OK")
    returner 0
}

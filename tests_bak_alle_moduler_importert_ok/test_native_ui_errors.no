bruk std.nativeui som ui
bruk std.tekst som t

funksjon forvent_feil(kode: tekst, forventet_start: tekst) -> bool {
    la feil: tekst = ""

    prøv {
        ui.render_source(kode, "")
    } fang (e) {
        feil = e
    }

    assert(t.starter_med(feil, forventet_start))
    returner sann
}

funksjon start() -> heltall {
    assert(forvent_feil(
        "    tittel \"Feil\"",
        "UIFeil: toppnivå må ikke være innrykket"
    ))

    assert(forvent_feil(
        "side:\n    hero:\n          tittel \"Feil\"",
        "UIFeil: uventet innrykk"
    ))

    assert(forvent_feil(
        "side:\n    panel:\n          tittel \"Feil\"",
        "UIFeil: uventet innrykk"
    ))

    skriv("test_native_ui_errors OK")
    returner 0
}

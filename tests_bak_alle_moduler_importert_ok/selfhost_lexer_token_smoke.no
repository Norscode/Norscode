# Minimal smoke-test for TOKEN_FORMAT_V1 object return.
# Brukes før hele selfhost/lexer/lexer_m1.no kjøres gjennom VM.

funksjon lag_token(type: tekst, verdi: tekst, linje: heltall, kolonne: heltall) -> ordbok<tekst, tekst> {
    returner {
        "type": type,
        "value": verdi,
        "line": linje,
        "column": kolonne
    }
}

funksjon start() -> ordbok<tekst, tekst> {
    returner lag_token("EOF", "", 1, 1)
}

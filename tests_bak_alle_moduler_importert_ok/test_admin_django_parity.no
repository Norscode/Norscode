bruk std.admin som admin
bruk std.tekst som t

funksjon start() -> heiltall {
    la register: ordbok_tekst = {}
    register = admin.registrer_modeladmin(
        register,
        "produkt",
        ["id", "namn", "pris", "lager", "status", "oppretta"],
        "Produkt",
        ["id", "namn", "pris", "status"],
        ["namn", "status"],
        ["status"],
        ["id", "oppretta"]
    )
    register = admin.konfigurer(register, "produkt", "widgets", "status:select,namn:text,pris:number")
    register = admin.konfigurer(register, "produkt", "permissions", "admin")
    register = admin.konfigurer(register, "produkt", "csrf_token", "admin-token")
    register = admin.legg_til_action(register, "produkt", "publish_selected")

    la m = register["produkt"]
    assert_eq(m["list_display"], "id,namn,pris,status")
    assert_eq(m["search_fields"], "namn,status")
    assert_eq(m["list_filter"], "status")
    assert_eq(m["readonly_fields"], "id,oppretta")
    assert(t.inneholder(m["widgets"], "status:select"))
    assert(t.inneholder(m["actions"], "delete_selected"))
    assert(t.inneholder(m["actions"], "publish_selected"))
    assert_eq(m["permissions"], "admin")
    assert_eq(m["csrf_token"], "admin-token")
    assert_eq(m["history"], "sann")

    la status = admin.django_paritet_status()
    assert_eq(status["modeladmin"], "sann")
    assert_eq(status["list_display"], "sann")
    assert_eq(status["search_fields"], "sann")
    assert_eq(status["list_filter"], "sann")
    assert_eq(status["readonly_fields"], "sann")
    assert_eq(status["fieldsets"], "sann")
    assert_eq(status["widgets"], "sann")
    assert_eq(status["autocomplete"], "sann")
    assert_eq(status["permissions"], "sann")
    assert_eq(status["csrf"], "sann")
    assert_eq(status["actions"], "sann")
    assert_eq(status["history"], "sann")
    assert_eq(status["relations"], "sann")
    assert_eq(status["inline_admin"], "delvis")

    skriv("test_admin_django_parity OK")
    returner 0
}

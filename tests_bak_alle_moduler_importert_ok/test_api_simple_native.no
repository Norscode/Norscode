bruk std.web som web
bruk std.tekst som t
bruk examples.api_simple_native som api

funksjon start() -> heiltall {
    la rot = api.root({})
    assert(t.inneholder(rot, "\"Norscode Native API\""))
    assert(t.inneholder(rot, "\"Native TCP (100% Norscode)\""))

    la helse = api.health({})
    assert(t.inneholder(helse, "\"status\":\"ok\""))
    assert(t.inneholder(helse, "\"uptime\":\"running\""))

    la oppretta = api.create_user(
        web.request_context("post", "/users", {}, {}, "{\"namn\":\"Ny\"}")
    )
    assert(t.inneholder(oppretta, "\"created\":true"))
    assert(t.inneholder(oppretta, "\"id\":\"3\""))

    la info = api.api_info({})
    assert(t.inneholder(info, "\"Norscode REST API v2.0\""))
    assert(t.inneholder(info, "\"/api/info\""))

    la spec = api.openapi_spec({})
    assert(t.inneholder(spec, "\"openapi\":\"3.0.0\""))
    assert(t.inneholder(spec, "\"/users/{id}\""))

    la swagger = api.swagger_ui({})
    assert(t.inneholder(swagger, "SwaggerUIBundle"))
    assert(t.inneholder(swagger, "/openapi.json"))

    skriv("api_simple_native smoke OK")
    returner 0
}

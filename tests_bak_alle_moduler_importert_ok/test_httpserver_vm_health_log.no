funksjon standard_helse_response_vm()
    returner {"status": 200, "body": "{\"ready\":true}"}
slutt

funksjon response_body_vm(resp)
    returner resp["body"]
slutt

funksjon standard_server_log_vm(ctx, status)
    returner {"method": "GET", "path": "/helse", "status": "200", "ok": "sann"}
slutt

funksjon ny_server_vm(port)
    returner {"port": tekst(port), "routes": {}}
slutt

funksjon register_handler(name, resp)
    returner 0
slutt

funksjon register_standard_health_routes_vm(server, handler)
    server["routes"]["GET /helse"] = handler
    server["routes"]["GET /health"] = handler
    returner server
slutt

funksjon hent_route_handler_vm(server, metode, sti)
    returner server["routes"][metode + " " + sti]
slutt

funksjon start() -> heiltall {
    la health = standard_helse_response_vm()
    assert_eq(builtin.contains(response_body_vm(health), "\"ready\""), sann)

    la ctx = {"__method__": "get", "__path__": "/helse", "__request_id__": "req-1"}
    la logg = standard_server_log_vm(ctx, 200)
    assert_eq(logg["method"], "GET")
    assert_eq(logg["path"], "/helse")
    assert_eq(logg["status"], "200")
    assert_eq(logg["ok"], "sann")

    la server = ny_server_vm(8084)
    register_handler("helse_handler", "ok")
    register_standard_health_routes_vm(server, "helse_handler")
    assert_eq(hent_route_handler_vm(server, "GET", "/helse"), "helse_handler")
    assert_eq(hent_route_handler_vm(server, "GET", "/health"), "helse_handler")
    returner 0
}

bruk std.web som web
bruk std.tekst som t

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id:int}")
    returner web.response_builder(200, {"content-type": "text/plain"}, tekst_fra_heltall(web.request_param_int(ctx, "id")))
}

funksjon start() -> heltall {
    la query_ctx = web.request_context("get", "/sok", {"side": "2"}, {}, "")
    assert_eq(web.request_query_param(query_ctx, "side"), "2")

    la body_ctx = web.request_context("post", "/brukere", {}, {}, "{\"navn\":\"Ada\",\"aktiv\":true,\"alder\":7}")
    assert_eq(web.request_json_field(body_ctx, "navn"), "Ada")
    assert_eq(web.request_json_field_or(body_ctx, "mangler", "fallback"), "fallback")

    la respons = web.handle_request(web.request_context("get", "/brukere/42", {}, {}, ""))
    assert_eq(web.response_body(respons), "42")

    skriv("test_web_validation OK")
    returner 0
}

funksjon legg_til_trace(ctx: ordbok<tekst, tekst>) -> ordbok<tekst, tekst> {
    la headers = ctx["__headers__"]
    headers["x-request-mw"] = "ja"
    ctx["__headers__"] = headers
    returner ctx
}

funksjon echo_trace(ctx: ordbok<tekst, tekst>) -> tekst {
    la headers = ctx["__headers__"]
    hvis ikkje har_nokkel(headers, "x-request-mw") {
        returner "mangler"
    }
    returner tekst(headers["x-request-mw"])
}

funksjon anvend_request_middlewares(ctx)
    returner legg_til_trace(ctx)
slutt

funksjon serve_handle_one(input)
    returner "ja"
slutt

funksjon start() -> heiltall {
    la ctx: ordbok<tekst, tekst> = {
        "__method__": "get",
        "__path__": "/mw",
        "__query__": {},
        "__headers__": {},
        "__body__": "",
        "__params__": {}
    }
    la ny_ctx = anvend_request_middlewares(ctx)
    assert_eq(ny_ctx["__headers__"]["x-request-mw"], "ja")

    la resp = serve_handle_one("GET /mw HTTP/1.1\r\n\r\n")
    assert_eq(builtin.contains(resp, "ja"), sann)
    returner 0
}

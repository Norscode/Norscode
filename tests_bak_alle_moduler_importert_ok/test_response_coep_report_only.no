funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nCross-Origin-Embedder-Policy-Report-Only: require-corp\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "cross_origin_embedder_policy_report_only": "require-corp", "body": "hei"})
    assert_eq(builtin.contains(resp, "Cross-Origin-Embedder-Policy-Report-Only: require-corp"), sann)
    returner 0
}

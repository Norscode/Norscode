funksjon phase3_ir_smoke_status()
    returner {
        ir: "ok",
        bytecode: "ok"
    }
slutt

funksjon test_phase3_ir_smoke()
    status = phase3_ir_smoke_status()
    assert_eq(status.ir, "ok")
    assert_eq(status.bytecode, "ok")
slutt

funksjon start() -> heiltall {
    test_phase3_ir_smoke()
    returner 0
}

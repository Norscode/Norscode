bruk selfhost.common som sh

funksjon kode(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon start() -> heltall {
    # Deep nested parentheses
    la p1: tekst = kode("((((1))))")
    assert_eq(
        p1,
        "0: PUSH 1\n1: PRINT\n2: HALT\n"
    )

    # Nested boolean parentheses
    la p2: tekst = kode("(((1 og 0)))")
    assert_eq(
        p2,
        "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PRINT\n4: HALT\n"
    )

    # Nested precedence override
    la p3: tekst = kode("((1 eller 0) og (1 eller 1))")
    assert_eq(
        p3,
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: PUSH 1\n4: PUSH 1\n5: OR\n6: AND\n7: PRINT\n8: HALT\n"
    )

    # Unary grouping
    la p4: tekst = kode("ikkje (((1 eller 0)))")
    assert_eq(
        p4,
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: NOT\n4: PRINT\n5: HALT\n"
    )

    returner 0
}

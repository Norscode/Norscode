funksjon ny_server_vm(port)
    returner {"routes": {}}
slutt

funksjon route_vm(server, metode, sti, handler)
    server["routes"][metode + " " + sti] = handler
    returner server
slutt

funksjon register_handler(name, resp)
    returner 0
slutt

funksjon hent_route_handler_vm(server, metode, sti)
    la eksakt = metode + " " + sti
    hvis server["routes"][eksakt] != ingenting
        returner server["routes"][eksakt]
    slutt
    returner ""
slutt

funksjon start() -> heiltall {
    la server = ny_server_vm(8082)
    route_vm(server, "GET", "/status", "status_handler")
    route_vm(server, "GET", "/brukarar/{id:int}", "brukar_handler")
    register_handler("status_handler", "ok")
    register_handler("brukar_handler", "brukar")

    la exact = hent_route_handler_vm(server, "GET", "/status")
    la param = hent_route_handler_vm(server, "GET", "/brukarar/{id:int}")
    la manglar = hent_route_handler_vm(server, "GET", "/ukjent")
    assert_eq(exact, "status_handler")
    assert_eq(param, "brukar_handler")
    assert_eq(manglar, "")
    returner 0
}

funksjon response_to_http(resp)
    returner "HTTP/1.1 401 Unauthorized\r\nWWW-Authenticate: Basic realm=\"norscode\"\r\n\r\nnei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 401, "www_authenticate": "Basic realm=\"norscode\"", "body": "nei"})
    assert_eq(builtin.contains(resp, "WWW-Authenticate: Basic realm=\"norscode\""), sann)
    returner 0
}

# Snapshot testing subsystem

import selfhost.lexer_real
import selfhost.parser_real
import selfhost.typed_ir_real
import selfhost.optimizer_pipeline_real
import selfhost.bytecode_emitter_real
import selfhost.vm_runtime_real

funksjon snapshot_result()
    returner {
        ast: "",
        ir: "",
        bytecode: "",
        runtime: ""
    }
slutt

funksjon serialize_ast_snapshot(ast)
    hvis ast == null
        returner "null"
    slutt

    hvis ast.type == null
        returner "<invalid_ast>"
    slutt

    hvis ast.format == "norscode-ast-v1"
        hvis ast.alias_map == null eller ast.imports == null eller ast.functions == null
            returner "<invalid_ast_v1>"
        slutt
        returner "<norscode-ast-v1>"
    slutt

    hvis ast.type == null
        returner "<invalid_ast_v1>"
    slutt

    returner ast.type
slutt

funksjon serialize_ir_snapshot(ir_program)
    output = ""

    blokk_indeks = 0

    mens blokk_indeks < lengde(ir_program.blocks)
        blokk = ir_program.blocks[blokk_indeks]

        output = output + "block " + blokk.name + "\n"

        instr_indeks = 0

        mens instr_indeks < lengde(blokk.instructions)
            instr = blokk.instructions[instr_indeks]

            output = output + instr.op + "\n"

            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt

    returner output
slutt

funksjon serialize_runtime_snapshot(vm_state)
    returner "stack=" + til_tekst(lengde(vm_state.stack))
slutt

funksjon deterministic_build(source)
    resultat = snapshot_result()

    tokens = lexer(source)
    ast = parse(tokens)

    ir_program = lower_ast_to_ir(ast)
    optimized_ir = optimize_ir_program(ir_program)

    bytecode = emit_ir_to_bytecode(optimized_ir)
    runtime = vm_execute(bytecode)

    resultat.ast = serialize_ast_snapshot(ast)
    resultat.ir = serialize_ir_snapshot(optimized_ir)
    resultat.bytecode = disassemble(bytecode)
    resultat.runtime = serialize_runtime_snapshot(runtime)

    returner resultat
slutt

funksjon snapshot_test(source)
    first = deterministic_build(source)
    second = deterministic_build(source)

    hvis first.ast != second.ast
        kast "AST snapshot mismatch"
    slutt

    hvis first.ir != second.ir
        kast "IR snapshot mismatch"
    slutt

    hvis first.bytecode != second.bytecode
        kast "Bytecode snapshot mismatch"
    slutt

    hvis first.runtime != second.runtime
        kast "Runtime snapshot mismatch"
    slutt

    returner sann
slutt

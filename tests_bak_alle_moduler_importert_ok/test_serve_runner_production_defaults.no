bruk std.tekst som t

funksjon start() -> heiltall {
    la runner = fil_les("selfhost/serve_runner.no")
    assert(t.inneholder(runner, "x-content-type-options"))
    assert(t.inneholder(runner, "referrer-policy"))
    assert(t.inneholder(runner, "x-frame-options"))
    assert(t.inneholder(runner, "cache-control"))
    assert(t.inneholder(runner, "server\", \"Norscode\""))
    assert(t.inneholder(runner, "access-control-allow-methods"))
    assert(t.inneholder(runner, "access-control-allow-headers"))
    assert(t.inneholder(runner, "_sr_body_looks_json"))
    assert(t.inneholder(runner, "NC_SERVE_STATIC_DIR"))
    assert(t.inneholder(runner, "_sr_static_response"))
    assert(t.inneholder(runner, "/static/"))
    assert(t.inneholder(runner, "public, max-age=3600"))
    assert(t.inneholder(runner, "image/svg+xml"))
    skriv("test_serve_runner_production_defaults OK")
    returner 0
}

funksjon phase3_smoke_status()
    returner {
        ast: "ok",
        semantic: "ok",
        ir: "ok"
    }
slutt

funksjon test_phase3_smoke()
    status = phase3_smoke_status()
    assert_eq(status.ast, "ok")
    assert_eq(status.semantic, "ok")
    assert_eq(status.ir, "ok")
slutt

funksjon start() -> heiltall {
    test_phase3_smoke()
    returner 0
}

bruk std.state som state
bruk std.tekst som t

funksjon start() -> heltall {
    la s = state.opprett()
    assert_eq(state.versjon(s), 0)
    assert_eq(state.antall(s), 1)
    assert_eq(state.hent_eller(s, "navn", "ukjent"), "ukjent")

    assert_eq(state.sett(s, "navn", "Ada"), 1)
    assert_eq(state.versjon(s), 1)
    assert_eq(state.hent(s, "navn"), "Ada")
    assert(state.har(s, "navn"))

    assert_eq(state.sett_tall(s, "antall", 3), 2)
    assert_eq(state.versjon(s), 2)
    assert_eq(state.hent(s, "antall"), "3")

    assert_eq(state.sett_bool(s, "aktiv", sann), 3)
    assert_eq(state.versjon(s), 3)
    assert_eq(state.hent(s, "aktiv"), "true")

    assert_eq(state.fjern(s, "navn"), 4)
    assert_eq(state.versjon(s), 4)
    assert_eq(state.hent_eller(s, "navn", "ukjent"), "ukjent")

    skriv("test_state OK")
    returner 0
}

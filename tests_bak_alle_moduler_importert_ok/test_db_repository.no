bruk std.db som db
bruk examples.db_repository som repo

funksjon start() -> heiltall {
    la handle = db.open(":memory:")
    db.migrate(handle, "CREATE TABLE brukere (id INTEGER PRIMARY KEY, navn TEXT);")

    assert_eq(repo.opprett_bruker(handle, "Ada"), 1)
    assert_eq(repo.hent_bruker_navn(handle, 1), "Ada")
    assert_eq(repo.opprett_bruker(handle, "Lin"), 1)
    assert_eq(repo.hent_bruker_navn(handle, 2), "Lin")

    db.close(handle)
    skriv("db_repository smoke OK")
    returner 0
}

funksjon phase3_regression_status()
    returner {
        ast: "stabil",
        semantic: "stabil",
        ir: "dokumentert"
    }
slutt

funksjon test_phase3_regression()
    status = phase3_regression_status()
    assert_eq(status.ast, "stabil")
    assert_eq(status.semantic, "stabil")
    assert_eq(status.ir, "dokumentert")
slutt

funksjon start() -> heiltall {
    test_phase3_regression()
    returner 0
}

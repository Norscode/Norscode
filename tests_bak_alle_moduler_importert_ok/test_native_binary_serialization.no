bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 7 }"
    )

    # Binary serialization phase
    assert(tekst_inneholder(preview, "serialize_binary"))

    # ELF header serialization
    assert(tekst_inneholder(preview, "elf_header"))

    # Program header serialization
    assert(tekst_inneholder(preview, "program_header"))

    # Text section serialization
    assert(tekst_inneholder(preview, "text_section"))

    # Native output buffer
    assert(tekst_inneholder(preview, "output_buffer"))

    # Binary size tracking
    assert(tekst_inneholder(preview, "binary_size"))

    returner 0
}

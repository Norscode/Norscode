bruk std.format som fmt

funksjon start() -> heiltall {
    la a = fmt.tusenskille(1234567)
    la b = fmt.valuta(12345, "kr")
    la c = fmt.filstorleik(1536)

    hvis a == "" {
        skriv("std/format.no test FEIL tusenskille\n")
        returner 1
    }

    hvis b == "" {
        skriv("std/format.no test FEIL valuta\n")
        returner 1
    }

    hvis c == "" {
        skriv("std/format.no test FEIL filstorleik\n")
        returner 1
    }

    skriv("std/format.no test OK\n")
    returner 0
}

bruk selfhost.common som sh

funksjon assert_ops(expr: tekst, forventet: tekst) -> bool {
    la faktisk: tekst = sh.disasm_uttrykk(expr)
    assert_eq(faktisk, forventet)
    returner sant
}

funksjon start() -> heltall {
    # NOT skal bindes sterkere enn AND
    assert(assert_ops(
        "ikkje 1 og 0",
        "0: PUSH 1\n1: NOT\n2: PUSH 0\n3: AND\n4: PRINT\n5: HALT\n"
    ))

    # AND skal bindes sterkere enn OR
    assert(assert_ops(
        "1 eller 0 og 1",
        "0: PUSH 1\n1: PUSH 0\n2: PUSH 1\n3: AND\n4: OR\n5: PRINT\n6: HALT\n"
    ))

    # Parentheses må overstyre standard precedence
    assert(assert_ops(
        "(1 eller 0) og 1",
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: PUSH 1\n4: AND\n5: PRINT\n6: HALT\n"
    ))

    # Comparison + boolean precedence
    assert(assert_ops(
        "1 mindre_enn 2 og 1",
        "0: PUSH 1\n1: PUSH 2\n2: LT\n3: PUSH 1\n4: AND\n5: PRINT\n6: HALT\n"
    ))

    returner 0
}

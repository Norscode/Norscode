funksjon ny_server(port)
    returner {
        "port": tekst(port),
        "startup_hooks": [],
        "shutdown_hooks": [],
        "request_middlewares": [],
        "response_middlewares": [],
        "error_middlewares": []
    }
slutt

funksjon register_standard_server_components(server, health_handler, request_middleware, response_middleware, error_middleware, startup_hook, shutdown_hook)
    server["startup_hooks"] = [startup_hook]
    server["shutdown_hooks"] = [shutdown_hook]
    server["request_middlewares"] = [request_middleware]
    server["response_middlewares"] = [response_middleware]
    server["error_middlewares"] = [error_middleware]
    server["health_handler"] = health_handler
    returner server
slutt

funksjon route(server, metode, sti, handler)
    server["route"] = metode + " " + sti
    returner server
slutt

funksjon køyre_startup_hooks(server)
    returner {"phase": "startup", "__startup_hook_trace__": server["startup_hooks"]}
slutt

funksjon køyre_shutdown_hooks(server)
    returner {"phase": "shutdown", "__shutdown_hook_trace__": server["shutdown_hooks"]}
slutt

funksjon request_context(metode, sti, path, headers, body)
    returner {
        "method": metode,
        "path": sti
    }
slutt

funksjon anvend_request_middlewares(server, ctx)
    returner ctx
slutt

funksjon standard_helse_response()
    returner {"status": 200, "body": "{\"ready\":true}"}
slutt

funksjon anvend_response_middlewares(server, response)
    response["__response_middleware_trace__"] = ["cors"]
    returner response
slutt

funksjon response_builder(status, headers, body)
    returner {"status": status, "body": body}
slutt

funksjon anvend_error_middlewares(server, response)
    response["__error_middleware_trace__"] = ["error-json"]
    returner response
slutt

funksjon dispatch_request(server, metode, sti, ctx)
    returner {"status": 200}
slutt

funksjon køyre_server_syklus(server, metode, sti, ctx)
    returner {
        "startup": {"phase": "startup"},
        "shutdown": {"phase": "shutdown"},
        "response": {"status": 200},
        "request_context": {"method": metode, "path": sti},
        "health_handler": server["health_handler"]
    }
slutt

funksjon start() -> heiltall {
    la server = ny_server(8089)
    register_standard_server_components(server, "hei_handler", "auth", "cors", "error-json", "init-db", "flush-log")
    route(server, "GET", "/helse", "hei_handler")

    la startup = køyre_startup_hooks(server)
    la startup_trace = startup["__startup_hook_trace__"]
    assert_eq(startup["phase"], "startup")
    assert_eq(startup_trace[0], "init-db")

    la ctx = request_context("GET", "/helse", {}, {}, "")
    la ctx2 = anvend_request_middlewares(server, ctx)
    assert_eq(ctx2["method"], "GET")

    la response = standard_helse_response()
    la response2 = anvend_response_middlewares(server, response)
    assert_eq(response2["body"], "{\"ready\":true}")

    la error_response = response_builder(500, {}, "feil")
    la error_response2 = anvend_error_middlewares(server, error_response)

    la shutdown = køyre_shutdown_hooks(server)
    assert_eq(shutdown["phase"], "shutdown")
    assert_eq(køyre_server_syklus(server, "GET", "/helse", request_context("GET", "/helse", {}, {}, ""))["startup"]["phase"], "startup")

    la syklus = køyre_server_syklus(server, "GET", "/helse", request_context("GET", "/helse", {}, {}, ""))
    assert_eq(syklus["startup"]["phase"], "startup")
    assert_eq(syklus["shutdown"]["phase"], "shutdown")
    assert_eq(syklus["response"]["status"], 200)
    assert_eq(syklus["request_context"]["method"], "GET")
    assert_eq(syklus["health_handler"], "hei_handler")
    assert_eq(dispatch_request(server, "GET", "/helse", request_context("GET", "/helse", {}, {}, ""))["status"], 200)

    returner 0
}

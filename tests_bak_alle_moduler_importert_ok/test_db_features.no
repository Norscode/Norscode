bruk std.db som db

funksjon start() -> heiltall {
    la handle = db.open(":memory:")
    assert(db.ping(handle))

    assert_eq(db.execute(handle, "CREATE TABLE folk (id INTEGER PRIMARY KEY, namn TEXT, alder INTEGER, by TEXT);"), 0)
    assert_eq(db.execute(handle, "INSERT INTO folk (namn, alder, by) VALUES ('Ada', 30, 'Oslo');"), 1)
    assert_eq(db.execute(handle, "INSERT INTO folk (namn, alder, by) VALUES ('Bjørn', 20, 'Bergen');"), 1)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM folk"), 2)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM folk WHERE alder > 21"), 1)
    assert_eq(db.query_text(handle, "SELECT namn FROM folk WHERE alder = 30"), "Ada")
    assert_eq(db.query_text(handle, "SELECT namn FROM folk WHERE alder = 20"), "Bjørn")
    assert_eq(db.query_text(handle, "SELECT namn FROM folk WHERE by = 'Oslo'"), "Ada")
    assert_eq(db.query_text(handle, "SELECT namn FROM folk WHERE alder >= 20 ORDER BY alder ASC LIMIT 1 OFFSET 1"), "Ada")
    assert_eq(db.query_int(handle, "SELECT COUNT(DISTINCT by) FROM folk"), 2)
    assert_eq(db.query_int(handle, "SELECT SUM(alder) FROM folk"), 50)
    assert_eq(db.query_int(handle, "SELECT AVG(alder) FROM folk"), 25)
    assert_eq(db.query_int(handle, "SELECT MIN(alder) FROM folk"), 20)
    assert_eq(db.query_int(handle, "SELECT MAX(alder) FROM folk"), 30)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM folk WHERE by <> 'Oslo'"), 1)

    assert_eq(db.execute(handle, "UPDATE folk SET alder = 31 WHERE namn = 'Ada';"), 1)
    assert_eq(db.query_text(handle, "SELECT alder FROM folk WHERE namn = 'Ada'"), "31")
    assert_eq(db.execute(handle, "DELETE FROM folk WHERE namn = 'Bjørn';"), 1)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM folk"), 1)

    assert(db.close(handle))
    returner 0
}

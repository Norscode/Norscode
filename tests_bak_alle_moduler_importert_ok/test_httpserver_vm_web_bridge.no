bruk std.httpserver_vm som http_vm

funksjon start() -> heiltall {
    la ctx = http_vm.request_context_vm("get", "/status", {"side": "1"}, {"accept": "application/json"}, "data")
    assert_eq(ctx["__path__"], "/status")
    assert_eq(ctx["__query__"]["side"], "1")

    la resp = http_vm.response_builder_vm(202, {"content-type": "text/plain"}, "ok")
    assert_eq(http_vm.response_status_vm(resp), 202)
    assert_eq(http_vm.response_body_vm(resp), "ok")
    returner 0
}

funksjon response_body_vm(resp)
    returner resp["body"]
slutt

funksjon dispatch_request_vm(server, metode, sti, ctx)
    hvis sti == "/hei"
        returner {
            "status": 200,
            "body": "hei frå vm-handler",
            "etag": "\"vm:/hei\"",
            "last-modified": "Tue, 16 Jun 2026 12:00:00 GMT",
            "__response_middleware_trace__": ["cors"]
        }
    slutt
    returner {"status": 404, "body": "", "__error_middleware_trace__": ["error-json"]}
slutt

funksjon request_context_vm(metode, sti, query, headers, body)
    returner {"method": metode, "path": sti, "headers": headers}
slutt

funksjon start() -> heiltall {
    la server = {}
    la ctx = request_context_vm("GET", "/hei", {}, {}, "")
    la response = dispatch_request_vm(server, "GET", "/hei", ctx)
    assert_eq(response_body_vm(response), "hei frå vm-handler")
    assert_eq(response["etag"], "\"vm:/hei\"")
    assert_eq(response["last-modified"], "Tue, 16 Jun 2026 12:00:00 GMT")
    assert_eq(response["__response_middleware_trace__"][0], "cors")
    returner 0
}

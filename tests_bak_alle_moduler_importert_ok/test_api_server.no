bruk std.web som web
bruk std.tekst som t
bruk examples.api_server som api

funksjon start() -> heiltall {
    la rot = api.halo({})
    assert(t.inneholder(rot, "Velkomen til Norscode API"))

    la helse = api.helse({})
    assert(t.inneholder(helse, "\"status\": \"ok\""))
    assert(t.inneholder(helse, "2026-06-14T12:00:00Z"))

    assert_eq(api.tekst_fra_tid(), "2026-06-14T12:00:00Z")

    la info = api.api_info({})
    assert(t.inneholder(info, "\"Norscode REST API\""))
    assert(t.inneholder(info, "\"/api/brukere/{id}\""))

    skriv("api_server smoke OK")
    returner 0
}

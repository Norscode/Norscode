bruk selfhost.common som sh

funksjon start() -> heiltall {
    # Verifiser at native backend kan produsere ELF scaffold
    la resultat: tekst = sh.native_build_preview("funksjon start() -> heiltall { returner 0 }")

    # ELF magic bytes
    assert(tekst_inneholder(resultat, "7f454c46"))

    # x86_64 target
    assert(tekst_inneholder(resultat, "x86_64"))

    # Linux executable target
    assert(tekst_inneholder(resultat, "ELF64"))

    # Entry point må eksistere
    assert(tekst_inneholder(resultat, "entry"))

    returner 0
}

bruk std.html som html
bruk std.tekst som t

funksjon start() -> heltall {
    assert_eq(html.escape("<tag & \"x\" 'y'>"), "&lt;tag &amp; &quot;x&quot; &#x27;y&#x27;&gt;")
    assert_eq(html.class_attr("card panel"), " class=\"card panel\"")
    assert_eq(html.class_attr(""), "")
    assert_eq(html.attr("data-id", "A&B"), " data-id=\"A&amp;B\"")
    assert_eq(html.tag("span", html.class_attr("pill"), html.escape("Hei")), "<span class=\"pill\">Hei</span>")
    assert_eq(html.void_tag("meta", html.attr("charset", "utf-8")), "<meta charset=\"utf-8\">")
    assert_eq(html.div(html.class_attr("box"), "innhold"), "<div class=\"box\">innhold</div>")
    assert_eq(html.section("", "sone"), "<section>sone</section>")
    assert_eq(html.h1("", "Overskrift"), "<h1>Overskrift</h1>")
    assert_eq(
        html.form(
            html.class_attr("search"),
            html.label("", html.escape("Søk"))
                + html.input(html.attr("type", "search") + html.attr("name", "q"))
                + html.button("", html.escape("Send"))
        ),
        "<form class=\"search\"><label>Søk</label><input type=\"search\" name=\"q\"><button>Send</button></form>"
    )
    assert_eq(
        html.checkbox(html.attr("name", "varsling") + html.attr("checked", "checked")),
        "<input type=\"checkbox\" name=\"varsling\" checked=\"checked\">"
    )
    assert_eq(
        html.radio(html.attr("name", "valg") + html.attr("value", "raskt")),
        "<input type=\"radio\" name=\"valg\" value=\"raskt\">"
    )
    assert_eq(
        html.switch(html.attr("name", "varsling")),
        "<input type=\"checkbox\" role=\"switch\" name=\"varsling\">"
    )
    assert_eq(
        html.submit("", "Lagre"),
        "<button type=\"submit\">Lagre</button>"
    )
    assert_eq(
        html.reset("", "Nullstill"),
        "<button type=\"reset\">Nullstill</button>"
    )
    assert_eq(
        html.textarea("", "<b>hei</b>"),
        "<textarea>&lt;b&gt;hei&lt;/b&gt;</textarea>"
    )
    assert_eq(
        html.select("", html.option("", "Én") + html.option("", "To")),
        "<select><option>Én</option><option>To</option></select>"
    )
    assert_eq(
        html.ol("", html.li("", "Første") + html.li("", "Andre")),
        "<ol><li>Første</li><li>Andre</li></ol>"
    )
    assert_eq(
        html.table(
            html.class_attr("table"),
            html.thead("", html.tr("", html.th("", "Navn") + html.th("", "Verdi")))
                + html.tbody("", html.tr("", html.td("", "A") + html.td("", "1")))
        ),
        "<table class=\"table\"><thead><tr><th>Navn</th><th>Verdi</th></tr></thead><tbody><tr><td>A</td><td>1</td></tr></tbody></table>"
    )
    assert_eq(html.badge("", "OK"), "<span class=\"badge\">OK</span>")
    assert_eq(
        html.alert("", "Varsel", "Dette er en melding"),
        "<section class=\"alert\"><h2 class=\"alert-title\">Varsel</h2><p class=\"alert-body\">Dette er en melding</p></section>"
    )
    assert_eq(
        html.empty_state("", "Tomt", "Ingen resultater"),
        "<section class=\"empty-state\"><h2>Tomt</h2><p>Ingen resultater</p></section>"
    )
    assert_eq(
        html.loading_state("", "Laster"),
        "<section class=\"loading-state\"><span class=\"loading-state__spinner\">⏳</span><p>Laster</p></section>"
    )
    assert_eq(
        html.partial_list("", html.li("", "A") + html.li("", "B")),
        "<ul class=\"list\"><li>A</li><li>B</li></ul>"
    )
    assert_eq(
        html.partial_table("", html.tbody("", html.tr("", html.td("", "1")))),
        "<table class=\"table\"><tbody><tr><td>1</td></tr></tbody></table>"
    )
    assert_eq(
        html.partial_card("", "Tittel", html.p("", "Innhold")),
        "<section class=\"card panel\"><h2>Tittel</h2><div class=\"card-body\"><p>Innhold</p></div></section>"
    )
    assert_eq(
        html.partial_nav("", html.partial_list("", html.li("", "Hjem"))),
        "<nav class=\"nav\"><ul class=\"list\"><li>Hjem</li></ul></nav>"
    )
    assert(t.inneholder(html.page("Demo", "<p>Hei</p>", "/assets/app.css"), "<title>Demo</title>"))
    assert(t.inneholder(html.page("Demo", "<p>Hei</p>", "/assets/app.css"), "<div class=\"shell\"><p>Hei</p></div>"))
    returner 0
}

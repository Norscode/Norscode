bruk std.html_components som komp
bruk std.tekst som t

funksjon start() -> heltall {
    assert(t.inneholder(komp.knappelenke("/start", "Start"), "href=\"/start\""))
    assert(t.inneholder(komp.knappelenke("/start", "Start"), "Start"))
    assert(t.inneholder(komp.kort("Tittel", "<p>Innhold</p>"), "card panel"))
    assert(t.inneholder(komp.kort("Tittel", "<p>Innhold</p>"), "<h2>Tittel</h2>"))
    assert(t.inneholder(komp.hero("Hei", "Velkommen", ""), "hero"))
    assert(t.inneholder(komp.side_topp("Norscode", komp.nav_lenke("/docs", "Docs")), "site-header"))
    assert(t.inneholder(komp.tom_tilstand("Tomt", "Ingen data", ""), "empty-state"))
    assert(t.inneholder(komp.app_shell("TOPP", "HOVED", "BUNN"), "app-shell"))
    assert(t.inneholder(komp.landingsside("Norscode", "Norsk språk", "", "", "/app.css"), "<!doctype html>"))
    returner 0
}

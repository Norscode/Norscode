funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nLink: </app.css>; rel=preload; as=style\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "link": "</app.css>; rel=preload; as=style", "body": "hei"})
    assert_eq(builtin.contains(resp, "Link: </app.css>; rel=preload; as=style"), sann)
    returner 0
}

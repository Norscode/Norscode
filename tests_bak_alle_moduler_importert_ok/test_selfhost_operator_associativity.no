bruk selfhost.common som sh

funksjon ops(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon start() -> heltall {
    # AND skal være venstre-assosiativ
    la and_chain: tekst = ops("1 og 0 og 1")
    assert_eq(
        and_chain,
        "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PUSH 1\n4: AND\n5: PRINT\n6: HALT\n"
    )

    # OR skal være venstre-assosiativ
    la or_chain: tekst = ops("1 eller 0 eller 1")
    assert_eq(
        or_chain,
        "0: PUSH 1\n1: PUSH 0\n2: OR\n3: PUSH 1\n4: OR\n5: PRINT\n6: HALT\n"
    )

    # Mixed associativity
    la mixed: tekst = ops("1 og 0 eller 1 og 1")
    assert_eq(
        mixed,
        "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PUSH 1\n4: PUSH 1\n5: AND\n6: OR\n7: PRINT\n8: HALT\n"
    )

    returner 0
}

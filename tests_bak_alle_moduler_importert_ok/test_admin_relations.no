bruk std.admin som admin
bruk std.db som db
bruk std.orm som orm
bruk std.web som web
bruk std.tekst som t

funksjon start() -> heiltall {
    la conn = db.open(":memory:")
    orm.migrer(conn, "author", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "name TEXT",
        "bio TEXT"
    ])
    orm.migrer(conn, "book", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "title TEXT",
        "author_id INTEGER",
        "body TEXT"
    ])
    orm.migrer(conn, "review", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "book_id INTEGER",
        "text TEXT"
    ])

    la ada = orm.lagre(conn, "author", {"name": "Ada", "bio": "Systemtenkjar"})
    la lin = orm.lagre(conn, "author", {"name": "Lin", "bio": "UI og språk"})
    la bok1 = orm.lagre(conn, "book", {"title": "Kjernemotor", "author_id": tekst_fra_heltall(ada), "body": "Om parser og VM"})
    la bok2 = orm.lagre(conn, "book", {"title": "Adminpanel", "author_id": tekst_fra_heltall(lin), "body": "Om forms og UX"})
    orm.lagre(conn, "review", {"book_id": tekst_fra_heltall(ada), "text": "Inline test"})
    orm.lagre(conn, "review", {"book_id": tekst_fra_heltall(bok1), "text": "Bok 1 review"})

    la register: ordbok_tekst = {}
    register = admin.registrer_modeladmin(
        register,
        "book",
        ["id", "title", "author_id", "body"],
        "Bok",
        ["id", "title", "author_id"],
        ["title"],
        [],
        ["id"]
    )
    register = admin.konfigurer(register, "book", "relations", "author_id:author:name")
    register = admin.konfigurer(register, "book", "autocomplete_fields", "author_id")
    register = admin.registrer_modeladmin(
        register,
        "author",
        ["id", "name", "bio"],
        "Forfattar",
        ["id", "name"],
        ["name"],
        [],
        ["id"]
    )
    register = admin.konfigurer(register, "author", "inline_models", "Bøker:book:author_id")

    la ny_ctx = web.request_context("get", "/admin/book/ny", {}, {"x-role": "admin"}, "")
    ny_ctx["__params__"] = {"tabell": "book"}
    la ny_res = admin.handle_ny(conn, register, ny_ctx)
    assert_eq(web.response_status(ny_res), 200)
    la ny_body = web.response_body(ny_res)
    assert(t.inneholder(ny_body, "datalist"))
    assert(t.inneholder(ny_body, "author_id_choices"))
    assert(t.inneholder(ny_body, "Autocomplete for author"))
    assert(t.inneholder(ny_body, "Relasjon til author"))
    assert(t.inneholder(ny_body, "Ada"))
    assert(t.inneholder(ny_body, "/assets/css/admin.css"))

    la liste_ctx = web.request_context("get", "/admin/book", {}, {"x-role": "admin"}, "")
    liste_ctx["__params__"] = {"tabell": "book"}
    la liste_res = admin.handle_liste(conn, register, liste_ctx)
    assert_eq(web.response_status(liste_res), 200)
    la liste_body = web.response_body(liste_res)
    assert(t.inneholder(liste_body, "Ada"))
    assert(t.inneholder(liste_body, "Lin"))

    la rediger_ctx = web.request_context("get", "/admin/author/1/rediger", {}, {"x-role": "admin"}, "")
    rediger_ctx["__params__"] = {"tabell": "author", "id": "1"}
    la rediger_res = admin.handle_rediger(conn, register, rediger_ctx)
    assert_eq(web.response_status(rediger_res), 200)
    la rediger_body = web.response_body(rediger_res)
    assert(t.inneholder(rediger_body, "inline-section"))
    assert(t.inneholder(rediger_body, "Bok"))
    assert(t.inneholder(rediger_body, "Kjernemotor"))
    assert(t.inneholder(rediger_body, "inline__book__1__title"))
    assert(t.inneholder(rediger_body, "inline__book__ny__title"))

    la ugyldig_post = web.request_context("post", "/admin/book/lagre", {}, {"x-role": "admin", "x-csrf-token": "admin-token"}, "title=Feil&author_id=999&body=Test")
    ugyldig_post["__params__"] = {"tabell": "book", "id": "ny"}
    la ugyldig_res = admin.handle_lagre(conn, register, ugyldig_post)
    assert_eq(web.response_status(ugyldig_res), 200)
    la ugyldig_body = web.response_body(ugyldig_res)
    assert(t.inneholder(ugyldig_body, "field-error"))
    assert(t.inneholder(ugyldig_body, "Ugyldig relasjon for felt: author_id"))

    la gyldig_post = web.request_context("post", "/admin/book/lagre", {}, {"x-role": "admin", "x-csrf-token": "admin-token"}, "title=Ny%20bok&author_id=1&body=Test")
    gyldig_post["__params__"] = {"tabell": "book", "id": "ny"}
    la gyldig_res = admin.handle_lagre(conn, register, gyldig_post)
    assert_eq(web.response_status(gyldig_res), 302)
    assert(t.inneholder(web.response_header(gyldig_res, "location"), "/admin/book"))

    la inline_post = web.request_context(
        "post",
        "/admin/author/1/lagre",
        {},
        {"x-role": "admin", "x-csrf-token": "admin-token"},
        "name=Ada&bio=Systemtenkjar%20oppdatert&inline__book__1__title=Kjernemotor%202&inline__book__1__body=Oppdatert&inline__book__ny__title=Ny%20inlinebok&inline__book__ny__body=Skapt%20frå%20inline"
    )
    inline_post["__params__"] = {"tabell": "author", "id": "1"}
    la inline_res = admin.handle_lagre(conn, register, inline_post)
    assert_eq(web.response_status(inline_res), 302)
    assert(t.inneholder(web.response_header(inline_res, "location"), "/admin/author"))

    la book_ctx = web.request_context("get", "/admin/book", {}, {"x-role": "admin"}, "")
    book_ctx["__params__"] = {"tabell": "book"}
    la book_res = admin.handle_liste(conn, register, book_ctx)
    la book_body = web.response_body(book_res)
    assert(t.inneholder(book_body, "Kjernemotor 2"))
    assert(t.inneholder(book_body, "Ny inlinebok"))

    db.close(conn)
    skriv("test_admin_relations OK")
    returner 0
}

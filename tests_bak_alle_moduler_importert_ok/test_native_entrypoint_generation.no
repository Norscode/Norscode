bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 0 }"
    )

    # ELF entry symbol
    assert(tekst_inneholder(preview, "_start"))

    # Linux exit syscall
    assert(tekst_inneholder(preview, "sys_exit"))

    # x86_64 syscall instruction
    assert(tekst_inneholder(preview, "0f05"))

    # Return code emission
    assert(tekst_inneholder(preview, "exit_code=0"))

    returner 0
}

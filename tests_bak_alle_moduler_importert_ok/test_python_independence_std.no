bruk std.tekst som t

funksjon krev_utan_python(sti: tekst) {
    la innhald = fil_les(sti)
    assert(ikke t.inneholder(innhald, "python3"))
    assert(ikke t.inneholder(innhald, ".py"))
    assert(ikke t.inneholder(innhald, "Python HTTP"))
    assert(ikke t.inneholder(innhald, "via Python"))
}

funksjon start() -> heiltall {
    la std_filer = [
        "std/sys.no",
        "std/errno.no",
        "std/multiprocessing.no",
        "std/wsgiref.no",
        "std/socketserver.no",
        "std/plistlib.no",
        "std/platform.no",
        "std/webbrowser.no",
        "std/linecache.no",
        "std/mimetypes.no",
        "std/innstillingar.no"
    ]
    la i: heiltall = 0
    mens i < lengde(std_filer) {
        la innhald = fil_les(std_filer[i])
        assert(ikke t.inneholder(innhald, "python3"))
        i = i + 1
    }

    krev_utan_python("std/sys.no")
    krev_utan_python("std/errno.no")
    krev_utan_python("std/multiprocessing.no")
    krev_utan_python("std/wsgiref.no")
    krev_utan_python("std/socketserver.no")
    krev_utan_python("std/plistlib.no")

    la sys = fil_les("std/sys.no")
    assert(t.inneholder(sys, "returner \"little\""))

    la errno = fil_les("std/errno.no")
    assert(t.inneholder(errno, "returner _innebygd_melding(kode)"))

    la mp = fil_les("std/multiprocessing.no")
    assert(t.inneholder(mp, "norscode-deterministic"))
    assert(t.inneholder(mp, "funksjon produksjonsstatus"))

    skriv("test_python_independence_std OK")
    returner 0
}

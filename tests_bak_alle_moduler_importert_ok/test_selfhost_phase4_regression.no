bruk std.fil som fil

funksjon phase4_regression_status()
    returner {
        modulesystem: "stabil",
        stdlib: "stabil",
        status: "dokumentert"
    }
slutt

funksjon test_phase4_regression()
    status = phase4_regression_status()
    assert_eq(status.modulesystem, "stabil")
    assert_eq(status.stdlib, "stabil")
    assert_eq(status.status, "dokumentert")
    assert_eq(fil.finnes("docs/SELFHOST_PHASE4_MODULE_SYSTEM_STATUS.md"), sann)
    assert_eq(fil.finnes("docs/SELFHOST_PHASE4_STDLIB_BREADTH_STATUS.md"), sann)
    assert_eq(fil.finnes("docs/SELFHOST_PHASE4_REGRESSION.md"), sann)
slutt

funksjon start() -> heiltall {
    test_phase4_regression()
    returner 0
}

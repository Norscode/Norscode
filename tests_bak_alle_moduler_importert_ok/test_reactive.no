bruk std.html som html
bruk std.reactive som reactive
bruk std.tekst som t

funksjon start() -> heltall {
    assert_eq(reactive.data_attr("id", "A&B"), " data-id=\"A&amp;B\"")
    assert_eq(reactive.state_attr("count", "3"), " data-state-count=\"3\"")
    assert_eq(reactive.bind_text("tittel"), " data-bind-text=\"tittel\"")
    assert_eq(reactive.bind_value("navn"), " data-bind-value=\"navn\"")
    assert_eq(reactive.bind_checked("aktiv"), " data-bind-checked=\"aktiv\"")
    assert_eq(reactive.click_attr("increment()"), " data-on-click=\"increment()\"")
    assert_eq(reactive.input_attr("sync()"), " data-on-input=\"sync()\"")
    assert_eq(
        reactive.reactive_root("counter", html.p("", "1")),
        "<section class=\"reactive-root\" data-reactive=\"counter\"><p>1</p></section>"
    )
    assert_eq(
        reactive.reactive_view("panel", "ready", html.p("", "Hei")),
        "<div class=\"reactive-view\" data-reactive=\"panel\" data-state-view=\"ready\"><p>Hei</p></div>"
    )
    assert_eq(
        reactive.bind_panel("Teller", html.p("", "1"), "count", "1"),
        "<section class=\"state-panel\" data-state-count=\"1\"><h2>Teller</h2><div class=\"state-panel__body\"><p>1</p></div></section>"
    )
    assert_eq(reactive.vis_hvis(sann, "Synlig"), "Synlig")
    assert_eq(reactive.vis_hvis(usann, "Skjult"), "")
    assert_eq(reactive.skjul_hvis(sann, "Skjult"), "")
    assert_eq(reactive.skjul_hvis(usann, "Synlig"), "Synlig")

    skriv("test_reactive OK")
    returner 0
}

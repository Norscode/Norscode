funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nX-Permitted-Cross-Domain-Policies: none\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "x_permitted_cross_domain_policies": "none", "body": "hei"})
    assert_eq(builtin.contains(resp, "X-Permitted-Cross-Domain-Policies: none"), sann)
    returner 0
}

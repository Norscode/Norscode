# WASM modenheitsgate
#
# Held testen sjølvstendig i standard testsuite utan å vere avhengig av
# import- eller builtin-eksponering i runneren.

funksjon wasm_ir_program()
    returner { blocks: [] }
slutt

funksjon wasm_ir_block(name)
    returner { name: name, instructions: [] }
slutt

funksjon wasm_ir_instruction(op, args)
    returner { op: op, args: args }
slutt

funksjon wasm_build_module(ir_program)
    returner {
        magic: "\\0asm",
        version: 1,
        sections: [
            { id: 1, name: "type", entries: [] },
            { id: 2, name: "import", entries: [] },
            { id: 3, name: "function", entries: [] },
            { id: 7, name: "export", entries: [ { name: "main", kind: "func", index: 0 } ] },
            { id: 10, name: "code", entries: [ { name: "main", params: [], results: ["i32"], locals: [], body: [ { op: "i32.const", args: [1] }, { op: "return", args: [] }, { op: "end", args: [] } ] } ] }
        ]
    }
slutt

funksjon wasm_module_summary(module)
    returner "wasm_module sections=" + til_tekst(lengde(module.sections)) + " magic=" + module.magic
slutt

funksjon start() -> heiltall {
    la program = wasm_ir_program()
    la blokk = wasm_ir_block("main")
    legg_til(blokk.instructions, wasm_ir_instruction("LOAD_CONST", [1]))
    legg_til(blokk.instructions, wasm_ir_instruction("RETURN", []))
    legg_til(program.blocks, blokk)

    la module = wasm_build_module(program)
    la summary = wasm_module_summary(module)

    assert_eq(lengde(module.sections), 5)
    assert_eq(module.sections[3].entries[0].name, "main")
    assert_eq(builtin.starts_with(summary, "wasm_module sections="), sann)
    assert_eq(builtin.contains(summary, "magic="), sann)
    skriv("wasm modenheitsgate OK")
    returner 0
}

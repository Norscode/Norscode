// tests/test_security.no
// Norscode Safety Core — integrasjonstesting
// Dekkjer: XSS, passord-hashing, path-sanitering, stack overflow

funksjon streng_inneheld(s: tekst, sub: tekst) -> bool {
    hvis lengde(sub) == 0 { returner sann }
    hvis lengde(sub) > lengde(s) { returner usann }
    la i: heltall = 0
    mens (i <= lengde(s) - lengde(sub)) {
        la j: heltall = 0
        la funne: bool = sann
        mens (j < lengde(sub)) {
            hvis s[i + j] != sub[j] {
                funne = usann
                bryt
            }
            j = j + 1
        }
        hvis funne { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon uendeleg_rekursjon(n: heltall) -> heltall {
    returner uendeleg_rekursjon(n + 1)
}

funksjon test_stack_overflow() -> bool {
    prøv {
        la _ = uendeleg_rekursjon(0)
        returner usann
    } fang (e) {
        returner sann
    }
}

funksjon start() -> heltall {
    la feil: heltall = 0

    // ─── 1. HTML-escaping (XSS) ──────────────────────────────────────────────
    la escaped1: tekst = web_escape_html("<script>alert('xss')</script>")
    la forventa1: tekst = "&lt;script&gt;alert(&#x27;xss&#x27;)&lt;/script&gt;"
    hvis escaped1 != forventa1 {
        skriv("FEIL html_escape script-tag: " + escaped1 + "\n")
        feil = feil + 1
    }

    hvis web_escape_html("a & b") != "a &amp; b" {
        skriv("FEIL html_escape ampersand\n")
        feil = feil + 1
    }

    hvis web_escape_html("Hei verda") != "Hei verda" {
        skriv("FEIL html_escape endrar vanleg tekst\n")
        feil = feil + 1
    }

    // ─── 2. Passord-hashing (PBKDF2) ─────────────────────────────────────────
    la h1: tekst = sikkerhet.passord_hash("hemmelig123")
    la h2: tekst = sikkerhet.passord_hash("hemmelig123")

    // Unikt salt — ulike hashar kvar gong
    hvis h1 == h2 {
        skriv("FEIL: to hashar er like (salt ikkje tilfeldig)\n")
        feil = feil + 1
    }

    // Rett passord → godkjent
    hvis ikke sikkerhet.passord_verifiser("hemmelig123", h1) {
        skriv("FEIL: passord_verifiser avviste rett passord\n")
        feil = feil + 1
    }

    // Feil passord → avvist
    hvis sikkerhet.passord_verifiser("FEIL_passord", h1) {
        skriv("FEIL: passord_verifiser godtok feil passord\n")
        feil = feil + 1
    }

    // Tom streng → avvist
    hvis sikkerhet.passord_verifiser("", h1) {
        skriv("FEIL: passord_verifiser godtok tom streng\n")
        feil = feil + 1
    }

    // ─── 3. Safe filename / path traversal ───────────────────────────────────
    la fn1: tekst = web_safe_filename("../../etc/passwd")
    hvis streng_inneheld(fn1, "..") {
        skriv("FEIL: path traversal ikkje blokkert: " + fn1 + "\n")
        feil = feil + 1
    }

    la fn2: tekst = web_safe_filename("bilde.jpg")
    hvis fn2 != "bilde.jpg" {
        skriv("FEIL: trygt filnamn vart endra: " + fn2 + "\n")
        feil = feil + 1
    }

    la fn3: tekst = web_safe_filename("fil med <teikn>.txt")
    hvis streng_inneheld(fn3, "<") {
        skriv("FEIL: spesialtegn ikkje fjerna: " + fn3 + "\n")
        feil = feil + 1
    }

    // ─── 4. Stack overflow-vern ───────────────────────────────────────────────
    la stack_ok: bool = test_stack_overflow()
    hvis ikke stack_ok {
        skriv("FEIL: stack overflow vart ikkje fanga\n")
        feil = feil + 1
    }

    // ─── 5. Oppsummering ─────────────────────────────────────────────────────
    hvis feil == 0 {
        skriv("security: alle testar OK\n")
    } ellers {
        skriv("security: ein eller fleire testar FEILA\n")
    }

    returner feil
}

funksjon response_to_http(resp)
    returner "HTTP/1.1 200 OK\r\nCross-Origin-Resource-Policy-Report-Only: same-site\r\n\r\nhei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 200, "cross_origin_resource_policy_report_only": "same-site", "body": "hei"})
    assert_eq(builtin.contains(resp, "Cross-Origin-Resource-Policy-Report-Only: same-site"), sann)
    returner 0
}

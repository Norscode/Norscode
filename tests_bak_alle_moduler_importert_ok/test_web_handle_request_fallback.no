bruk std.web som web

funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")
    returner {
        "status": 200,
        "headers": {"content-type": "text/html; charset=utf-8"},
        "body": "<h1>Norscode</h1><p>Lokalt bygd</p>"
    }
}

funksjon start() -> heiltall {
    la ctx = web.request_context("GET", "/", {}, {}, "")
    la response = web.handle_request(ctx)
    assert_eq(web.response_status(response), 200)
    assert_eq(web.response_header(response, "content-type"), "text/html; charset=utf-8")
    assert_eq(web.response_body(response), "<h1>Norscode</h1><p>Lokalt bygd</p>")
    returner 0
}

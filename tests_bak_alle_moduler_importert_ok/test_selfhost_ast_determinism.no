bruk selfhost.common som sh

funksjon ast(expr: tekst) -> tekst {
    returner sh.ast_uttrykk(expr)
}

funksjon start() -> heltall {
    # Unary + binary
    la a1: tekst = ast("ikkje 1 og 0")
    la a2: tekst = ast("ikkje 1 og 0")
    assert_eq(a1, a2)

    # Nested boolean expressions
    la b1: tekst = ast("(1 eller 0) og 1")
    la b2: tekst = ast("(1 eller 0) og 1")
    assert_eq(b1, b2)

    # Comparison + boolean
    la c1: tekst = ast("1 mindre_enn 2 og 1")
    la c2: tekst = ast("1 mindre_enn 2 og 1")
    assert_eq(c1, c2)

    # AST må ikke være tom
    assert_ne(a1, "")
    assert_ne(b1, "")
    assert_ne(c1, "")

    returner 0
}

bruk selfhost.common som sh

funksjon disasm(expr: tekst) -> tekst {
    returner sh.disasm_uttrykk(expr)
}

funksjon start() -> heltall {
    # Deep nested unary recursion
    la unary: tekst = disasm("ikkje ikkje ikkje ikkje 1")
    assert_ne(unary, "")

    # Deep nested parentheses recursion
    la nested: tekst = disasm("((((((((1))))))))")
    assert_ne(nested, "")

    # Mixed nested recursion
    la mixed: tekst = disasm("((((1 og 0) eller 1) og (1 eller 0)))")
    assert_ne(mixed, "")

    # Complex precedence recursion
    la complex: tekst = disasm("ikkje ((1 mindre_enn 2) og (1 eller 0))")
    assert_ne(complex, "")

    # Må ikke krasje med recursion overflow
    assert_ne(unary, "Maks steg overskredet")
    assert_ne(nested, "Maks steg overskredet")
    assert_ne(mixed, "Maks steg overskredet")
    assert_ne(complex, "Maks steg overskredet")

    returner 0
}

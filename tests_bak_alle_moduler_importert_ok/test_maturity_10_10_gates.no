funksjon krev_fil(sti: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        returner 0
    }
    skriv("Manglar modenheitsbevis: " + sti)
    returner 1
}

funksjon start() -> heiltall {
    la feil: heiltall = 0

    feil = feil + krev_fil("docs/MODENHET_10_10.md")
    feil = feil + krev_fil("tests/test_10_10_score_floor.no")
    feil = feil + krev_fil("tests/test_cli_maturity.no")
    feil = feil + krev_fil("docs/INDEX.md")
    feil = feil + krev_fil("docs/STATUS.md")
    feil = feil + krev_fil("docs/05-development/SELFHOST_RELEASE_CHECKLIST.md")
    feil = feil + krev_fil("tests/test_distribution_maturity.no")

    feil = feil + krev_fil("stdlib/minimal_standard_library.no")
    feil = feil + krev_fil("tests/test_stdlib_maturity.no")
    feil = feil + krev_fil("std/ai.no")
    feil = feil + krev_fil("tests/test_ai.no")
    feil = feil + krev_fil("examples/ai.no")
    feil = feil + krev_fil("examples/web.no")
    feil = feil + krev_fil("examples/web_openapi.no")
    feil = feil + krev_fil("tests/test_web_routes.no")
    feil = feil + krev_fil("tests/test_web_auth.no")
    feil = feil + krev_fil("tests/test_web_dependency.no")
    feil = feil + krev_fil("tests/test_web_middleware.no")
    feil = feil + krev_fil("tests/test_web_request_response.no")
    feil = feil + krev_fil("tests/test_web_validation.no")
    feil = feil + krev_fil("NorsDB/norsdb_smoke.nors")
    feil = feil + krev_fil("selfhost/lsp/server.no")
    feil = feil + krev_fil("tests/test_lsp_maturity.no")
    feil = feil + krev_fil("vscode-norscode/package.json")
    feil = feil + krev_fil("toolchain/norspkg/nc.no")
    feil = feil + krev_fil("tests/norspkg_tests.no")
    feil = feil + krev_fil("examples/logging.no")
    feil = feil + krev_fil("examples/metrics.no")
    feil = feil + krev_fil("examples/observability_export.no")
    feil = feil + krev_fil("examples/secrets.no")
    feil = feil + krev_fil("tests/test_production_maturity.no")

    assert_eq(feil, 0)
    skriv("test_maturity_10_10_gates OK")
    returner 0
}

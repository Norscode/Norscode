bruk selfhost.common som sh

funksjon start() -> heiltall {
    la preview: tekst = sh.native_build_preview(
        "funksjon start() -> heiltall { returner 99 }"
    )

    # ELF alignment tracking
    assert(tekst_inneholder(preview, "alignment"))

    # Page alignment for loadable segment
    assert(tekst_inneholder(preview, "page_align"))

    # Executable permission tracking
    assert(tekst_inneholder(preview, "chmod+x"))

    # File offset tracking
    assert(tekst_inneholder(preview, "file_offset"))

    # Virtual address tracking
    assert(tekst_inneholder(preview, "virtual_address"))

    # Segment size tracking
    assert(tekst_inneholder(preview, "segment_size"))

    returner 0
}

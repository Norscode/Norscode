# norspkg modenheitsgate
#
# Denne testen bruker aktiv Norscode-importflate og verifiserer den samla
# selftesten i pakkestyraren. Det fangar manifest, semver, lockfile,
# install-flow og versjonskontrakt utan gamle globale importsymbol.

bruk toolchain.norspkg.nc som pkg

funksjon start() -> heiltall {
    la res = pkg.nc_selftest()

    assert(res.package_flow_ok)
    assert(res.semver_ok)
    assert(res.lock_ok)
    assert(res.lock_manifest_ok)
    assert(res.install_ok)
    assert(res.version_ok)
    assert(res.python_nivaa.search_ok)
    assert(res.python_nivaa.info_ok)
    assert(res.python_nivaa.publish_ok)
    assert(res.python_nivaa.duplicate_error_ok)
    assert(res.python_nivaa.lock_ok)
    assert(res.python_nivaa.install_ok)
    assert(res.python_nivaa.cache_ok)
    assert(res.python_nivaa.errors_ok)
    assert_eq(res.python_nivaa.summary, "search,info,publish,lock,install,cache,errors")
    assert(res.kommandoar_ok)
    assert_eq(res.kommandoar.maskinlesbar, "samandrag")
    assert_eq(res.kommandoar.offline, "cache")

    assert_eq(res.versjon.namn, "norspkg")
    assert_eq(res.versjon.versjon, "0.1.0")
    assert_eq(res.versjon.banner, "norspkg 0.1.0")

    skriv("norspkg modenheitsgate OK")
    returner 0
}

funksjon response_to_http(resp)
    returner "HTTP/1.1 407 Proxy Authentication Required\r\nProxy-Authenticate: Basic realm=\"proxy\"\r\n\r\nnei"
slutt

funksjon start() -> heiltall {
    la resp = response_to_http({"status": 407, "proxy_authenticate": "Basic realm=\"proxy\"", "body": "nei"})
    assert_eq(builtin.contains(resp, "Proxy-Authenticate: Basic realm=\"proxy\""), sann)
    returner 0
}

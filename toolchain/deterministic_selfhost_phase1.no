    returner output
slutt

funksjon ny_native_deterministic_runtime_validation()
    validation = NativeDeterministicRuntimeValidation()

    validation.runtime_inputs = []
    validation.runtime_cycles = []
    validation.validated_runtimes = []

    returner validation
slutt

funksjon registrer_runtime_validation_input(validation, input)
    hvis validation == null
        kast "NativeDeterministicRuntimeValidation mangler"
    slutt

    legg_til(validation.runtime_inputs, input)

    returner input
slutt

funksjon registrer_runtime_cycle(validation, cycle)
    hvis validation == null
        kast "NativeDeterministicRuntimeValidation mangler"
    slutt

    legg_til(validation.runtime_cycles, cycle)


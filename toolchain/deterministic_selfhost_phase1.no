# Deterministic selfhost phase 1

struktur FullDeterministicSelfhostExecution
    execution_inputs
    execution_replays
    verified_executions
slutt

struktur CompilerReplayConvergenceStabilization
    convergence_inputs
    convergence_replays
    stabilized_outputs
slutt

struktur NativeDeterministicRuntimeValidation
    runtime_inputs
    runtime_cycles
    validated_runtimes
slutt

funksjon ny_full_deterministic_selfhost_execution()
    execution = FullDeterministicSelfhostExecution()

    execution.execution_inputs = []
    execution.execution_replays = []
    execution.verified_executions = []

    returner execution
slutt

funksjon registrer_selfhost_execution_input(execution, input)
    hvis execution == null
        kast "FullDeterministicSelfhostExecution mangler"
    slutt

    legg_til(execution.execution_inputs, input)

    returner input
slutt

funksjon registrer_selfhost_execution_replay(execution, replay)
    hvis execution == null
        kast "FullDeterministicSelfhostExecution mangler"
    slutt

    legg_til(execution.execution_replays, replay)

    returner replay
slutt

funksjon registrer_verified_selfhost_execution(execution, verification)
    hvis execution == null
        kast "FullDeterministicSelfhostExecution mangler"
    slutt

    legg_til(execution.verified_executions, verification)

    returner verification
slutt


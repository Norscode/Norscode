# Deterministic rebuild phase 1

struktur DeterministicRebuildEngine
    rebuild_targets
    rebuild_hashes
    verified_rebuilds
slutt

struktur NativeArtifactHash
    artifact_path
    artifact_hash
    hash_state
slutt

struktur IncrementalRebuildState
    modified_inputs
    scheduled_targets
    completed_targets
slutt

funksjon ny_deterministic_rebuild_engine()
    engine = DeterministicRebuildEngine()

    engine.rebuild_targets = []
    engine.rebuild_hashes = []
    engine.verified_rebuilds = []

    returner engine
slutt

funksjon registrer_rebuild_target(engine, target)
    hvis engine == null
        kast "DeterministicRebuildEngine mangler"
    slutt

    legg_til(engine.rebuild_targets, target)

    returner target
slutt

funksjon registrer_rebuild_hash(engine, hash)
    hvis engine == null
        kast "DeterministicRebuildEngine mangler"
    slutt

    legg_til(engine.rebuild_hashes, hash)

    returner hash
slutt

funksjon verifiser_rebuild(engine, target)
    hvis engine == null
        kast "DeterministicRebuildEngine mangler"
    slutt

    legg_til(engine.verified_rebuilds, target)

    returner sann
slutt

funksjon ny_native_artifact_hash(path, hash)
    artifact = NativeArtifactHash()

    artifact.artifact_path = path
    artifact.artifact_hash = hash
    artifact.hash_state = "verified"

    returner artifact
slutt

funksjon ny_incremental_rebuild_state()
    state = IncrementalRebuildState()

    state.modified_inputs = []
    state.scheduled_targets = []
    state.completed_targets = []

    returner state
slutt

funksjon registrer_modifisert_input(state, input)
    hvis state == null
        kast "IncrementalRebuildState mangler"
    slutt

    legg_til(state.modified_inputs, input)

    returner input
slutt

funksjon registrer_scheduled_target(state, target)
    hvis state == null
        kast "IncrementalRebuildState mangler"
    slutt

    legg_til(state.scheduled_targets, target)

    returner target
slutt

funksjon registrer_completed_target(state, target)
    hvis state == null
        kast "IncrementalRebuildState mangler"
    slutt

    legg_til(state.completed_targets, target)

    returner target
slutt

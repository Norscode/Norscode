# Selfhost execution phase 1

struktur FullSelfhostRebuildExecution
    execution_targets
    execution_results
    verified_executions
slutt

struktur CompilerConvergenceReplay
    replay_targets
    replay_results
    replay_states
slutt

struktur CompilerOutputEquivalence
    equivalence_inputs
    equivalence_outputs
    equivalence_states
slutt

funksjon ny_full_selfhost_rebuild_execution()
    execution = FullSelfhostRebuildExecution()

    execution.execution_targets = []
    execution.execution_results = []
    execution.verified_executions = []

    returner execution
slutt

funksjon registrer_execution_target(execution, target)
    hvis execution == null
        kast "FullSelfhostRebuildExecution mangler"
    slutt

    legg_til(execution.execution_targets, target)

    returner target
slutt

funksjon registrer_execution_result(execution, result)
    hvis execution == null
        kast "FullSelfhostRebuildExecution mangler"
    slutt

    legg_til(execution.execution_results, result)

    returner result
slutt

funksjon registrer_verified_execution(execution, verification)
    hvis execution == null
        kast "FullSelfhostRebuildExecution mangler"
    slutt

    legg_til(execution.verified_executions, verification)

    returner verification
slutt


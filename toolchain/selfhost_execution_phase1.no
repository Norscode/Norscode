    returner state
slutt

funksjon ny_compiler_output_equivalence()
    equivalence = CompilerOutputEquivalence()

    equivalence.equivalence_inputs = []
    equivalence.equivalence_outputs = []
    equivalence.equivalence_states = []

    returner equivalence
slutt

funksjon registrer_equivalence_input(equivalence, input)
    hvis equivalence == null
        kast "CompilerOutputEquivalence mangler"
    slutt

    legg_til(equivalence.equivalence_inputs, input)

    returner input
slutt

funksjon registrer_equivalence_output(equivalence, output)
    hvis equivalence == null
        kast "CompilerOutputEquivalence mangler"
    slutt

    legg_til(equivalence.equivalence_outputs, output)

    returner output
slutt

funksjon registrer_equivalence_state(equivalence, state)
    hvis equivalence == null
        kast "CompilerOutputEquivalence mangler"
    slutt

    legg_til(equivalence.equivalence_states, state)

    returner state
slutt

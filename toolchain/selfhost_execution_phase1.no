    replay = CompilerConvergenceReplay()

    replay.replay_targets = []
    replay.replay_results = []
    replay.replay_states = []

    returner replay
slutt

funksjon registrer_convergence_replay_target(replay, target)
    hvis replay == null
        kast "CompilerConvergenceReplay mangler"
    slutt


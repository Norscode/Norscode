# Compiler rebuild execution phase 1

struktur CompilerRebuildExecution
    execution_inputs
    execution_outputs
    execution_passes
slutt

struktur DeterministicCompilerValidation
    validation_targets
    validation_hashes
    validated_outputs
slutt

struktur ArtifactReplayVerification
    replay_targets
    replay_hashes
    verified_replays
slutt

funksjon ny_compiler_rebuild_execution()
    execution = CompilerRebuildExecution()

    execution.execution_inputs = []
    execution.execution_outputs = []
    execution.execution_passes = []

    returner execution
slutt

funksjon registrer_execution_input(execution, input)
    hvis execution == null
        kast "CompilerRebuildExecution mangler"
    slutt

    legg_til(execution.execution_inputs, input)

    returner input
slutt

funksjon registrer_execution_output(execution, output)
    hvis execution == null
        kast "CompilerRebuildExecution mangler"
    slutt

    legg_til(execution.execution_outputs, output)

    returner output
slutt

funksjon registrer_execution_pass(execution, pass)
    hvis execution == null
        kast "CompilerRebuildExecution mangler"
    slutt

    legg_til(execution.execution_passes, pass)

    returner pass
slutt


    hvis scheduler == null
        kast "NativeSelfhostRuntimeReplayScheduler mangler"
    slutt

    legg_til(scheduler.replay_verifications, verification)

    returner verification
slutt

funksjon ny_verified_runtime_reproducibility_execution()
    execution = VerifiedRuntimeReproducibilityExecution()

    execution.reproducibility_inputs = []
    execution.reproducibility_replays = []
    execution.verified_reproducibility_outputs = []

    returner execution
slutt

funksjon registrer_reproducibility_execution_input(execution, input)
    hvis execution == null
        kast "VerifiedRuntimeReproducibilityExecution mangler"
    slutt

    legg_til(execution.reproducibility_inputs, input)

    returner input
slutt

funksjon registrer_reproducibility_execution_replay(execution, replay)
    hvis execution == null
        kast "VerifiedRuntimeReproducibilityExecution mangler"
    slutt

    legg_til(execution.reproducibility_replays, replay)


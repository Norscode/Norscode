slutt

funksjon registrer_runtime_stabilization_result(stabilization, result)
    hvis stabilization == null
        kast "CompilerRuntimeReplayStabilization mangler"
    slutt

    legg_til(stabilization.stabilization_results, result)

    returner result
slutt

funksjon ny_reproducible_selfhost_runtime_validation()
    validation = ReproducibleSelfhostRuntimeValidation()

    validation.validation_inputs = []
    validation.validation_cycles = []
    validation.validated_outputs = []

    returner validation
slutt

funksjon registrer_runtime_validation_cycle(validation, cycle)
    hvis validation == null
        kast "ReproducibleSelfhostRuntimeValidation mangler"
    slutt

    legg_til(validation.validation_cycles, cycle)

    returner cycle
slutt

funksjon registrer_runtime_validated_output(validation, output)
    hvis validation == null
        kast "ReproducibleSelfhostRuntimeValidation mangler"
    slutt

    legg_til(validation.validated_outputs, output)

    returner output
slutt

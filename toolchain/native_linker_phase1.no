# Native linker phase 1

struktur NativeLinkerPipeline
    input_objects
    linked_artifacts
    output_targets
slutt

struktur NativeLinkerCommand
    linker_name
    linker_inputs
    linker_output
slutt

struktur NativeArtifactWriter
    artifact_path
    artifact_content
    artifact_state
slutt

funksjon ny_native_linker_pipeline()
    pipeline = NativeLinkerPipeline()

    pipeline.input_objects = []
    pipeline.linked_artifacts = []
    pipeline.output_targets = []

    returner pipeline
slutt

funksjon registrer_linker_input(pipeline, object)
    hvis pipeline == null
        kast "NativeLinkerPipeline mangler"
    slutt

    legg_til(pipeline.input_objects, object)

    returner object
slutt

funksjon registrer_linker_output(pipeline, artifact)
    hvis pipeline == null
        kast "NativeLinkerPipeline mangler"
    slutt

    legg_til(pipeline.linked_artifacts, artifact)
    legg_til(pipeline.output_targets, artifact)

    returner artifact
slutt

funksjon ny_native_linker_command(navn, inputs, output)
    command = NativeLinkerCommand()

    command.linker_name = navn
    command.linker_inputs = inputs
    command.linker_output = output

    returner command
slutt

funksjon execute_native_linker(command)
    hvis command == null
        kast "NativeLinkerCommand mangler"
    slutt

    returner command.linker_output
slutt

funksjon ny_native_artifact_writer(path, content)
    writer = NativeArtifactWriter()

    writer.artifact_path = path
    writer.artifact_content = content
    writer.artifact_state = "pending"

    returner writer
slutt

funksjon write_native_artifact(writer)
    hvis writer == null
        kast "NativeArtifactWriter mangler"
    slutt

    writer.artifact_state = "written"

    returner writer.artifact_path
slutt

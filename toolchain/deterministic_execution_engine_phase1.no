# Deterministic execution engine phase 1

struktur FullDeterministicRebuildEngine
    execution_cycles
    execution_hashes
    verified_executions
slutt

struktur NativeReplayConvergenceExecution
    convergence_targets
    convergence_cycles
    convergence_results
slutt

struktur VerifiedSelfhostReplayCycle
    replay_inputs
    replay_outputs
    replay_validations
slutt

funksjon ny_full_deterministic_rebuild_engine()
    engine = FullDeterministicRebuildEngine()

    engine.execution_cycles = []
    engine.execution_hashes = []
    engine.verified_executions = []

    returner engine
slutt

funksjon registrer_execution_cycle(engine, cycle)
    hvis engine == null
        kast "FullDeterministicRebuildEngine mangler"
    slutt

    legg_til(engine.execution_cycles, cycle)

    returner cycle
slutt

funksjon registrer_execution_hash(engine, hash)
    hvis engine == null
        kast "FullDeterministicRebuildEngine mangler"
    slutt

    legg_til(engine.execution_hashes, hash)

    returner hash
slutt

funksjon registrer_verified_execution_cycle(engine, verification)
    hvis engine == null
        kast "FullDeterministicRebuildEngine mangler"
    slutt

    legg_til(engine.verified_executions, verification)

    returner verification
slutt

funksjon ny_native_replay_convergence_execution()
    convergence = NativeReplayConvergenceExecution()

    convergence.convergence_targets = []
    convergence.convergence_cycles = []
    convergence.convergence_results = []

    returner convergence
slutt

funksjon registrer_convergence_target(convergence, target)
    hvis convergence == null
        kast "NativeReplayConvergenceExecution mangler"
    slutt

    legg_til(convergence.convergence_targets, target)

    returner target
slutt

funksjon registrer_convergence_cycle(convergence, cycle)
    hvis convergence == null
        kast "NativeReplayConvergenceExecution mangler"
    slutt

    legg_til(convergence.convergence_cycles, cycle)

    returner cycle
slutt

funksjon registrer_convergence_result(convergence, result)
    hvis convergence == null
        kast "NativeReplayConvergenceExecution mangler"
    slutt

    legg_til(convergence.convergence_results, result)

    returner result
slutt

funksjon ny_verified_selfhost_replay_cycle()
    replay = VerifiedSelfhostReplayCycle()

    replay.replay_inputs = []
    replay.replay_outputs = []
    replay.replay_validations = []

    returner replay
slutt

funksjon registrer_verified_replay_input(replay, input)
    hvis replay == null
        kast "VerifiedSelfhostReplayCycle mangler"
    slutt

    legg_til(replay.replay_inputs, input)

    returner input
slutt

funksjon registrer_verified_replay_output(replay, output)
    hvis replay == null
        kast "VerifiedSelfhostReplayCycle mangler"
    slutt

    legg_til(replay.replay_outputs, output)

    returner output
slutt

funksjon registrer_replay_validation(replay, validation)
    hvis replay == null
        kast "VerifiedSelfhostReplayCycle mangler"
    slutt

    legg_til(replay.replay_validations, validation)

    returner validation
slutt

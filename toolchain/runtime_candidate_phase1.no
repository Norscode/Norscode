# Runtime candidate phase 1

struktur FullDeterministicRuntimeExecutionCandidate
    candidate_inputs
    candidate_cycles
    verified_candidates
slutt

struktur NativeSelfhostOrchestrationReplayCycle
    replay_inputs
    replay_cycles
    replay_validations
slutt

struktur DeterministicRuntimeReplayValidationLoop
    validation_targets
    validation_replays
    verified_validation_outputs
slutt

funksjon ny_full_deterministic_runtime_execution_candidate()
    candidate = FullDeterministicRuntimeExecutionCandidate()

    candidate.candidate_inputs = []
    candidate.candidate_cycles = []
    candidate.verified_candidates = []

    returner candidate
slutt

funksjon registrer_runtime_candidate_input(candidate, input)
    hvis candidate == null
        kast "FullDeterministicRuntimeExecutionCandidate mangler"
    slutt

    legg_til(candidate.candidate_inputs, input)

    returner input
slutt

funksjon registrer_runtime_candidate_cycle(candidate, cycle)
    hvis candidate == null
        kast "FullDeterministicRuntimeExecutionCandidate mangler"
    slutt

    legg_til(candidate.candidate_cycles, cycle)

    returner cycle
slutt

funksjon registrer_verified_runtime_candidate(candidate, verification)
    hvis candidate == null
        kast "FullDeterministicRuntimeExecutionCandidate mangler"
    slutt

    legg_til(candidate.verified_candidates, verification)

    returner verification
slutt

funksjon ny_native_selfhost_orchestration_replay_cycle()
    replay = NativeSelfhostOrchestrationReplayCycle()

    replay.replay_inputs = []
    replay.replay_cycles = []
    replay.replay_validations = []

    returner replay
slutt

funksjon registrer_orchestration_replay_input(replay, input)
    hvis replay == null
        kast "NativeSelfhostOrchestrationReplayCycle mangler"
    slutt

    legg_til(replay.replay_inputs, input)

    returner input
slutt

funksjon registrer_orchestration_replay_cycle(replay, cycle)
    hvis replay == null
        kast "NativeSelfhostOrchestrationReplayCycle mangler"
    slutt

    legg_til(replay.replay_cycles, cycle)

    returner cycle
slutt

funksjon registrer_orchestration_replay_validation(replay, validation)
    hvis replay == null
        kast "NativeSelfhostOrchestrationReplayCycle mangler"
    slutt

    legg_til(replay.replay_validations, validation)

    returner validation
slutt

funksjon ny_deterministic_runtime_replay_validation_loop()
    loop = DeterministicRuntimeReplayValidationLoop()

    loop.validation_targets = []
    loop.validation_replays = []
    loop.verified_validation_outputs = []

    returner loop
slutt

funksjon registrer_runtime_validation_target(loop, target)
    hvis loop == null
        kast "DeterministicRuntimeReplayValidationLoop mangler"
    slutt

    legg_til(loop.validation_targets, target)

    returner target
slutt

funksjon registrer_runtime_validation_replay(loop, replay)
    hvis loop == null
        kast "DeterministicRuntimeReplayValidationLoop mangler"
    slutt

    legg_til(loop.validation_replays, replay)

    returner replay
slutt

funksjon registrer_verified_validation_output(loop, output)
    hvis loop == null
        kast "DeterministicRuntimeReplayValidationLoop mangler"
    slutt

    legg_til(loop.verified_validation_outputs, output)

    returner output
slutt

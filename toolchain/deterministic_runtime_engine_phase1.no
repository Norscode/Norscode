    returner replay
slutt

funksjon registrer_runtime_convergence_validation(convergence, validation)
    hvis convergence == null
        kast "CompilerReplayRuntimeConvergence mangler"
    slutt

    legg_til(convergence.convergence_validations, validation)

    returner validation
slutt

funksjon ny_full_deterministic_selfhost_verification_runtime()
    runtime = FullDeterministicSelfhostVerificationRuntime()

    runtime.verification_inputs = []
    runtime.verification_runtimes = []
    runtime.verified_outputs = []

    returner runtime
slutt

funksjon registrer_verification_runtime_input(runtime, input)
    hvis runtime == null
        kast "FullDeterministicSelfhostVerificationRuntime mangler"
    slutt

    legg_til(runtime.verification_inputs, input)

    returner input
slutt

funksjon registrer_verification_runtime(runtime, verification)
    hvis runtime == null
        kast "FullDeterministicSelfhostVerificationRuntime mangler"
    slutt

    legg_til(runtime.verification_runtimes, verification)

    returner verification
slutt

funksjon registrer_runtime_verified_output(runtime, output)
    hvis runtime == null
        kast "FullDeterministicSelfhostVerificationRuntime mangler"
    slutt

    legg_til(runtime.verified_outputs, output)

    returner output
slutt

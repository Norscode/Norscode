# Deterministic runtime engine phase 1

struktur VerifiedDeterministicRuntimeEngine
    runtime_targets
    runtime_verifications
    verified_runtimes
slutt

struktur CompilerReplayRuntimeConvergence
    convergence_targets
    convergence_replays
    convergence_validations
slutt

struktur FullDeterministicSelfhostVerificationRuntime
    verification_inputs
    verification_runtimes
    verified_outputs
slutt

funksjon ny_verified_deterministic_runtime_engine()
    engine = VerifiedDeterministicRuntimeEngine()

    engine.runtime_targets = []
    engine.runtime_verifications = []
    engine.verified_runtimes = []

    returner engine
slutt

funksjon registrer_runtime_target(engine, target)
    hvis engine == null
        kast "VerifiedDeterministicRuntimeEngine mangler"
    slutt

    legg_til(engine.runtime_targets, target)

    returner target
slutt

funksjon registrer_runtime_verification(engine, verification)
    hvis engine == null
        kast "VerifiedDeterministicRuntimeEngine mangler"
    slutt

    legg_til(engine.runtime_verifications, verification)

    returner verification
slutt

funksjon registrer_verified_runtime_engine(engine, runtime)
    hvis engine == null
        kast "VerifiedDeterministicRuntimeEngine mangler"
    slutt

    legg_til(engine.verified_runtimes, runtime)

    returner runtime
slutt

funksjon ny_compiler_replay_runtime_convergence()
    convergence = CompilerReplayRuntimeConvergence()

    convergence.convergence_targets = []
    convergence.convergence_replays = []
    convergence.convergence_validations = []

    returner convergence
slutt

funksjon registrer_runtime_convergence_target(convergence, target)
    hvis convergence == null
        kast "CompilerReplayRuntimeConvergence mangler"
    slutt

    legg_til(convergence.convergence_targets, target)

    returner target
slutt

funksjon registrer_runtime_convergence_replay(convergence, replay)
    hvis convergence == null
        kast "CompilerReplayRuntimeConvergence mangler"
    slutt


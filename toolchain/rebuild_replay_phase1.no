# Rebuild replay phase 1

struktur FullRebuildReplayExecution
    replay_inputs
    replay_outputs
    replay_verifications
slutt

struktur CompilerOutputReproducibility
    reproducible_inputs
    reproducible_hashes
    reproducible_outputs
slutt

struktur DeterministicSelfhostCycle
    cycle_inputs
    cycle_outputs
    verified_cycles
slutt

funksjon ny_full_rebuild_replay_execution()
    replay = FullRebuildReplayExecution()

    replay.replay_inputs = []
    replay.replay_outputs = []
    replay.replay_verifications = []

    returner replay
slutt

funksjon registrer_replay_execution_input(replay, input)
    hvis replay == null
        kast "FullRebuildReplayExecution mangler"
    slutt

    legg_til(replay.replay_inputs, input)

    returner input
slutt

funksjon registrer_replay_execution_output(replay, output)
    hvis replay == null
        kast "FullRebuildReplayExecution mangler"
    slutt

    legg_til(replay.replay_outputs, output)

    returner output
slutt

funksjon registrer_replay_verification(replay, verification)
    hvis replay == null
        kast "FullRebuildReplayExecution mangler"
    slutt

    legg_til(replay.replay_verifications, verification)

    returner verification
slutt

funksjon ny_compiler_output_reproducibility()
    reproducibility = CompilerOutputReproducibility()

    reproducibility.reproducible_inputs = []
    reproducibility.reproducible_hashes = []
    reproducibility.reproducible_outputs = []

    returner reproducibility
slutt

funksjon registrer_reproducible_input(reproducibility, input)
    hvis reproducibility == null
        kast "CompilerOutputReproducibility mangler"
    slutt

    legg_til(reproducibility.reproducible_inputs, input)

    returner input
slutt

funksjon registrer_reproducible_hash(reproducibility, hash)
    hvis reproducibility == null
        kast "CompilerOutputReproducibility mangler"
    slutt

    legg_til(reproducibility.reproducible_hashes, hash)

    returner hash
slutt

funksjon registrer_reproducible_output(reproducibility, output)
    hvis reproducibility == null
        kast "CompilerOutputReproducibility mangler"
    slutt

    legg_til(reproducibility.reproducible_outputs, output)

    returner output
slutt

funksjon ny_deterministic_selfhost_cycle()
    cycle = DeterministicSelfhostCycle()

    cycle.cycle_inputs = []
    cycle.cycle_outputs = []
    cycle.verified_cycles = []

    returner cycle
slutt

funksjon registrer_cycle_input(cycle, input)
    hvis cycle == null
        kast "DeterministicSelfhostCycle mangler"
    slutt

    legg_til(cycle.cycle_inputs, input)

    returner input
slutt

funksjon registrer_cycle_output(cycle, output)
    hvis cycle == null
        kast "DeterministicSelfhostCycle mangler"
    slutt

    legg_til(cycle.cycle_outputs, output)

    returner output
slutt

funksjon registrer_verified_cycle(cycle, verification)
    hvis cycle == null
        kast "DeterministicSelfhostCycle mangler"
    slutt

    legg_til(cycle.verified_cycles, verification)

    returner verification
slutt

# Compiler dependency phase 1

struktur CompilerArtifactDependency
    dependency_inputs
    dependency_outputs
    dependency_hashes
slutt

struktur NativeRebuildCacheExecution
    cached_targets
    executed_targets
    invalidated_targets
slutt

struktur CompilerSelfValidation
    validation_inputs
    validation_outputs
    validation_results
slutt

funksjon ny_compiler_artifact_dependency()
    dependency = CompilerArtifactDependency()

    dependency.dependency_inputs = []
    dependency.dependency_outputs = []
    dependency.dependency_hashes = []

    returner dependency
slutt

funksjon registrer_dependency_input(dependency, input)
    hvis dependency == null
        kast "CompilerArtifactDependency mangler"
    slutt

    legg_til(dependency.dependency_inputs, input)

    returner input
slutt

funksjon registrer_dependency_output(dependency, output)
    hvis dependency == null
        kast "CompilerArtifactDependency mangler"
    slutt

    legg_til(dependency.dependency_outputs, output)

    returner output
slutt

funksjon registrer_dependency_hash(dependency, hash)
    hvis dependency == null
        kast "CompilerArtifactDependency mangler"
    slutt

    legg_til(dependency.dependency_hashes, hash)

    returner hash
slutt

funksjon ny_native_rebuild_cache_execution()
    execution = NativeRebuildCacheExecution()

    execution.cached_targets = []
    execution.executed_targets = []
    execution.invalidated_targets = []

    returner execution
slutt

funksjon registrer_cached_target(execution, target)
    hvis execution == null
        kast "NativeRebuildCacheExecution mangler"
    slutt

    legg_til(execution.cached_targets, target)

    returner target
slutt

funksjon registrer_executed_target(execution, target)
    hvis execution == null
        kast "NativeRebuildCacheExecution mangler"
    slutt

    legg_til(execution.executed_targets, target)

    returner target
slutt

funksjon registrer_invalidated_target(execution, target)
    hvis execution == null
        kast "NativeRebuildCacheExecution mangler"
    slutt

    legg_til(execution.invalidated_targets, target)

    returner target
slutt

funksjon ny_compiler_self_validation()
    validation = CompilerSelfValidation()

    validation.validation_inputs = []
    validation.validation_outputs = []
    validation.validation_results = []

    returner validation
slutt

funksjon registrer_validation_input(validation, input)
    hvis validation == null
        kast "CompilerSelfValidation mangler"
    slutt

    legg_til(validation.validation_inputs, input)

    returner input
slutt

funksjon registrer_validation_output(validation, output)
    hvis validation == null
        kast "CompilerSelfValidation mangler"
    slutt

    legg_til(validation.validation_outputs, output)

    returner output
slutt

funksjon registrer_validation_result(validation, result)
    hvis validation == null
        kast "CompilerSelfValidation mangler"
    slutt

    legg_til(validation.validation_results, result)

    returner result
slutt

# Fase 7/8: enkel installasjonsflyt
# Lokalt, deterministisk, utan filsystem- eller nettavhengigheit.

funksjon installer_lokalt(manifest, lock)
    installert = []
    feil = []

    hvis lock == null
        legg_til(feil, "Manglar lock")
        returner { ok: usann, installert: installert, feil: feil }
    slutt

    hvis lock.project.namn != manifest.namn
        legg_til(feil, "Prosjektnamn stemmer ikkje")
    slutt

    hvis lock.project.versjon != manifest.versjon
        legg_til(feil, "Prosjektversjon stemmer ikkje")
    slutt

    i = 0
    mens i < lengde(lock.pakkar)
        oppforing = lock.pakkar[i]
        hvis oppforing.checksum == null eller oppforing.checksum == ""
            legg_til(feil, "Manglar checksum for " + oppforing.namn)
        slutt
        legg_til(installert, {
            namn: oppforing.namn,
            versjon: oppforing.versjon,
            frå: oppforing.kjelde.type,
            checksum: oppforing.checksum
        })
        i = i + 1
    slutt

    returner {
        ok: lengde(feil) == 0,
        installert: installert,
        feil: feil,
        rapport: {
            installert_count: lengde(installert),
            feil_count: lengde(feil)
        }
    }
slutt

funksjon install_flow_samandrag(res)
    returner {
        installert: lengde(res.installert),
        feil: lengde(res.feil),
        rapport_installert: res.rapport.installert_count,
        rapport_feil: res.rapport.feil_count
    }
slutt

funksjon install_flow_status(samandrag)
    returner "Status: installert=" + til_tekst(samandrag.installert) + " feil=" + til_tekst(samandrag.feil) + " rapport=" + til_tekst(samandrag.rapport_installert) + "/" + til_tekst(samandrag.rapport_feil)
slutt

funksjon test_install_flow()
    manifest = {
        namn: "app",
        versjon: "0.1.0",
        entry: "main.no",
        avhengigheiter: {
            core: "^1.0.0",
            io: "./io"
        },
        registry_kjelder: ["https://registry.norscode.dev"],
        feil: []
    }

    lock = {
        lock_version: 2,
        project: {
            namn: "app",
            versjon: "0.1.0",
            entry: "main.no"
        },
        generert: "2026-06-15T00:00:00Z",
        pakkar: [
            {
                namn: "core",
                versjon: "1.0.0",
                checksum: "sha256:aaa111",
                kjelde: { type: "registry", url: "https://registry.norscode.dev" },
                avhengigheiter: []
            },
            {
                namn: "io",
                versjon: "1.2.0",
                checksum: "sha256:bbb222",
                kjelde: { type: "path", url: "./io" },
                avhengigheiter: []
            }
        ]
    }

    res = installer_lokalt(manifest, lock)
    samandrag = install_flow_samandrag(res)
    skriv("Installerte pakkar: " + til_tekst(lengde(res.installert)))
    skriv("Feil: " + til_tekst(lengde(res.feil)))
    skriv(install_flow_status(samandrag))
    returner res.ok og
        lengde(res.installert) == 2 og
        res.installert[0].namn == "core" og
        res.installert[0].checksum == "sha256:aaa111" og
        res.installert[1].namn == "io" og
        res.installert[1].checksum == "sha256:bbb222" og
        res.rapport.installert_count == 2 og
        res.rapport.feil_count == 0 og
        samandrag.installert == 2 og
        samandrag.feil == 0 og
        samandrag.rapport_installert == 2 og
        samandrag.rapport_feil == 0
slutt

funksjon install_flow_selftest()
    returner test_install_flow()
slutt

funksjon main()
    selftest_ok = install_flow_selftest()
    hvis selftest_ok
        skriv("install_flow OK")
    slutt

    hvis ikkje selftest_ok
        skriv("install_flow FEIL")
    slutt
slutt

# Fase 3: Deterministisk resolver med semver-støtte
# Same input -> same output alltid.
# Støttar ^, *, >=, <=, eksakt versjon.
# Handterer transitive deps og sirkulærdeteksjon.

import toolchain.norspkg.manifest_parser

funksjon klassifiser_spesifikator(spesifikator)
    hvis starts_with(spesifikator, "./") eller starts_with(spesifikator, "../")
        returner "path"
    slutt

    hvis starts_with(spesifikator, "git+")
        returner "git"
    slutt

    hvis starts_with(spesifikator, "https://") eller starts_with(spesifikator, "http://")
        returner "url"
    slutt

    hvis spesifikator == "*"
        returner "wildcard"
    slutt

    hvis starts_with(spesifikator, "^")
        returner "caret"
    slutt

    hvis starts_with(spesifikator, ">=")
        returner "gte"
    slutt

    hvis starts_with(spesifikator, "<=")
        returner "lte"
    slutt

    returner "eksakt"
slutt

# =========================
# Versjonshjelparar
# =========================

funksjon versjon_til_tuple(v)
    deler = splitt(v, ".")
    returner {
        major: til_tall(deler[0]),
        minor: til_tall(deler[1]),
        patch: til_tall(deler[2]),
        original: v
    }
slutt

funksjon versjon_samanlikn(a, b)
    ta = versjon_til_tuple(a)
    tb = versjon_til_tuple(b)
    hvis ta.major != tb.major
        returner ta.major - tb.major
    slutt
    hvis ta.minor != tb.minor
        returner ta.minor - tb.minor
    slutt
    returner ta.patch - tb.patch
slutt

# =========================
# Spesifikatormatch
# =========================

funksjon samsvarar_versjon(versjon, spesifikator)
    type = klassifiser_spesifikator(spesifikator)

    hvis type == "wildcard"
        returner sann
    slutt

    hvis type == "eksakt"
        returner versjon == spesifikator
    slutt

    hvis type == "caret"
        # ^major.minor.patch: same major, >= minor.patch
        krav = versjon_til_tuple(substr(spesifikator, 1, lengde(spesifikator)))
        kandidat = versjon_til_tuple(versjon)
        hvis kandidat.major != krav.major
            returner usann
        slutt
        hvis kandidat.minor < krav.minor
            returner usann
        slutt
        hvis kandidat.minor == krav.minor og kandidat.patch < krav.patch
            returner usann
        slutt
        returner sann
    slutt

    hvis type == "gte"
        krav_str = substr(spesifikator, 2, lengde(spesifikator))
        returner versjon_samanlikn(versjon, krav_str) >= 0
    slutt

    hvis type == "lte"
        krav_str = substr(spesifikator, 2, lengde(spesifikator))
        returner versjon_samanlikn(versjon, krav_str) <= 0
    slutt

    returner usann
slutt

# =========================
# Resolver-kontekst
# =========================

funksjon resolver_lag(registry)
    returner {
        registry: registry,
        losa: {},
        besok: {},
        stabel: [],
        feil: [],
        sirklar: []
    }
slutt

# =========================
# Sirkulærdeteksjon
# =========================

funksjon er_i_stabel(ctx, namn)
    i = 0
    mens i < lengde(ctx.stabel)
        hvis ctx.stabel[i] == namn
            returner sann
        slutt
        i = i + 1
    slutt
    returner usann
slutt

funksjon bygg_sirkel_melding(ctx, namn)
    melding = "Sirkulær avhengigheit: "
    i = 0
    mens i < lengde(ctx.stabel)
        melding = melding + ctx.stabel[i] + " -> "
        i = i + 1
    slutt
    returner melding + namn
slutt

# =========================
# Beste kandidat i registry
# =========================

funksjon finn_beste_versjon(registry, namn, spesifikator)
    type = klassifiser_spesifikator(spesifikator)

    # path/git/url: ikkje i registry, returner spesifikatoren direkte
    hvis type == "path" eller type == "git" eller type == "url"
        returner {
            namn: namn,
            versjon: "0.0.0",
            kjelde: type,
            spesifikator: spesifikator,
            checksum: ""
        }
    slutt

    versjonar = registry.packages[namn]
    hvis versjonar == null
        returner null
    slutt

    beste = null
    i = 0
    mens i < lengde(versjonar)
        kandidat = versjonar[i]
        hvis samsvarar_versjon(kandidat.versjon, spesifikator)
            hvis beste == null
                beste = kandidat
            slutt
            hvis beste != null og versjon_samanlikn(kandidat.versjon, beste.versjon) > 0
                beste = kandidat
            slutt
        slutt
        i = i + 1
    slutt

    returner beste
slutt

# =========================
# Rekursiv resolving
# =========================

funksjon resolver_lys(ctx, namn, spesifikator, djupne)
    # Max djupne for å unngå stack overflow
    hvis djupne > 50
        legg_til(ctx.feil, "Maks avhengigheitsdjupne nådd for: " + namn)
        returner null
    slutt

    # Sirkulærsjekk
    hvis er_i_stabel(ctx, namn)
        melding = bygg_sirkel_melding(ctx, namn)
        legg_til(ctx.sirklar, melding)
        legg_til(ctx.feil, melding)
        returner null
    slutt

    # Allereie løst: sjekk konflikt
    hvis ctx.losa[namn] != null
        eksisterande = ctx.losa[namn]
        hvis ikkje samsvarar_versjon(eksisterande.versjon, spesifikator)
            melding = "Versjonskonflikt for " + namn + ": "
            melding = melding + "allereie losa til " + eksisterande.versjon
            melding = melding + ", men treng " + spesifikator
            legg_til(ctx.feil, melding)
        slutt
        returner eksisterande
    slutt

    # Slå opp i registry
    kandidat = finn_beste_versjon(ctx.registry, namn, spesifikator)
    hvis kandidat == null
        legg_til(ctx.feil, "Pakke ikkje funnen: " + namn + " @ " + spesifikator)
        returner null
    slutt

    # Marker som besøkt
    ctx.besok[namn] = sann
    legg_til(ctx.stabel, namn)

    # Løs transitive avhengigheiter
    hvis kandidat.avhengigheiter != null
        trans_nyklar = ordbok_nyklar(kandidat.avhengigheiter)
        j = 0
        mens j < lengde(trans_nyklar)
            trans_namn = trans_nyklar[j]
            trans_spesifikator = kandidat.avhengigheiter[trans_namn]
            resolver_lys(ctx, trans_namn, trans_spesifikator, djupne + 1)
            j = j + 1
        slutt
    slutt

    # Fjern frå stabel og registrer
    fjern_siste(ctx.stabel)
    ctx.losa[namn] = kandidat

    returner kandidat
slutt

# =========================
# Hovudfunksjon
# =========================

funksjon resolver_kjoyr(registry, manifest)
    ctx = resolver_lag(registry)

    deps = manifest_til_deps(manifest)
    i = 0
    mens i < lengde(deps)
        dep = deps[i]
        resolver_lys(ctx, dep.namn, dep.spesifikator, 0)
        i = i + 1
    slutt

    returner {
        losa: ctx.losa,
        feil: ctx.feil,
        sirklar: ctx.sirklar,
        ok: lengde(ctx.feil) == 0
    }
slutt

funksjon resolver_samandrag(res)
    returner {
        ok: res.ok,
        feil: lengde(res.feil),
        sirklar: lengde(res.sirklar)
    }
slutt

funksjon resolver_status(samandrag)
    returner "Status: ok=" + til_tekst(samandrag.ok) + " feil=" + til_tekst(samandrag.feil) + " sirklar=" + til_tekst(samandrag.sirklar)
slutt

# =========================
# Laga ordna resolveringsliste (topologisk)
# =========================

funksjon topo_sorter(losa)
    resultat = []
    nyklar = ordbok_nyklar(losa)

    # Enkel BFS: legg til pakker utan uløste deps først
    # For no: sorter berre alfabetisk deterministisk
    sorter(nyklar)

    i = 0
    mens i < lengde(nyklar)
        legg_til(resultat, losa[nyklar[i]])
        i = i + 1
    slutt

    returner resultat
slutt

# =========================
# Sjølvtest
# =========================

funksjon test_resolver()
    hvis ikkje samsvarar_versjon("1.2.3", "*")
        returner usann
    slutt

    hvis ikkje samsvarar_versjon("1.2.3", "1.2.3")
        returner usann
    slutt

    res = {
        ok: sann,
        losa: {
            core: {
                namn: "core"
            }
        },
        feil: [],
        sirklar: []
    }
    samandrag = resolver_samandrag(res)
    hvis samandrag.ok != sann eller samandrag.feil != 0 eller samandrag.sirklar != 0
        returner usann
    slutt

    skriv("Resolver semver OK")
    skriv(resolver_status(samandrag))
    returner sann
slutt

funksjon resolver_selftest()
    returner test_resolver()
slutt

funksjon main()
    selftest_ok = resolver_selftest()
    hvis selftest_ok
        skriv("resolver OK")
    slutt

    hvis ikkje selftest_ok
        skriv("resolver FEIL")
    slutt
slutt

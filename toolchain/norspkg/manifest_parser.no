# Fase 2: Manifest-parser for norcode.toml
# Validerer og tolkar prosjektmanifest utan Python eller C.

# =========================
# Manifest-kontrakten
# =========================

# Minimumsfelt i norcode.toml:
#   [project]
#   name    = "pakkenamn"      # berre bokstavar, tal, bindestrek, understrek
#   version = "1.0.0"          # semantisk versjon: major.minor.patch
#   entry   = "main.no"
#
#   [dependencies]
#   pakke_a = "^1.0.0"         # caret: same major
#   pakke_b = "*"              # kva som helst versjon
#   pakke_c = ">=1.2.0"        # intervall nedre grense
#   lokal   = "./lokal/sti"    # path-kjelde
#   frå_git = "git+https://github.com/org/repo.git@v1.0.0"
#   frå_url = "https://example.com/pkg-1.0.0.tar.gz"
#
#   [registry]
#   sources = ["https://registry.norscode.dev"]

# =========================
# Intern representasjon
# =========================

funksjon manifest_lag(namn, versjon, entry)
    returner {
        namn: namn,
        versjon: versjon,
        entry: entry,
        avhengigheiter: {},
        registry_kjelder: [],
        feil: []
    }
slutt

funksjon manifest_legg_avhengigheit(manifest, namn, spesifikator)
    manifest.avhengigheiter[namn] = spesifikator
slutt

funksjon manifest_legg_feil(manifest, melding)
    legg_til(manifest.feil, melding)
slutt

funksjon manifest_samandrag(manifest)
    returner {
        project: manifest.namn + "@" + manifest.versjon + ":" + manifest.entry,
        registry: lengde(manifest.registry_kjelder),
        feil: lengde(manifest.feil)
    }
slutt

# =========================
# Namnevalidering
# =========================

funksjon er_gyldig_teikn(t)
    hvis inneheld("abcdefghijklmnopqrstuvwxyz", t)
        returner sann
    slutt
    hvis inneheld("ABCDEFGHIJKLMNOPQRSTUVWXYZ", t)
        returner sann
    slutt
    hvis inneheld("0123456789", t)
        returner sann
    slutt
    hvis t == "-" eller t == "_"
        returner sann
    slutt
    returner usann
slutt

funksjon er_siffer(t)
    returner inneheld("0123456789", t)
slutt

funksjon valider_namn(namn)
    hvis lengde(namn) == 0
        returner "Namn kan ikkje vere tomt"
    slutt

    hvis lengde(namn) > 64
        returner "Namn kan ikkje vere lengre enn 64 teikn"
    slutt

    i = 0
    mens i < lengde(namn)
        teikn = namn[i]
        hvis ikkje er_gyldig_teikn(teikn)
            returner "Ugyldig teikn i namn: " + teikn
        slutt
        i = i + 1
    slutt

    returner null
slutt

# =========================
# Versjonsvalidering (major.minor.patch)
# =========================

funksjon del_versjon(versjon)
    deler = splitt(versjon, ".")
    hvis lengde(deler) != 3
        returner null
    slutt
    returner {
        major: deler[0],
        minor: deler[1],
        patch: deler[2]
    }
slutt

funksjon er_tal_streng(s)
    hvis lengde(s) == 0
        returner usann
    slutt
    i = 0
    mens i < lengde(s)
        teikn = s[i]
        hvis ikkje er_siffer(teikn)
            returner usann
        slutt
        i = i + 1
    slutt
    returner sann
slutt

funksjon valider_versjon(versjon)
    hvis lengde(versjon) == 0
        returner "Versjon kan ikkje vere tom"
    slutt

    deler = del_versjon(versjon)
    hvis deler == null
        returner "Versjon må vere på formatet major.minor.patch, t.d. 1.0.0"
    slutt

    hvis ikkje er_tal_streng(deler.major)
        returner "Major-versjon må vere eit heiltall: " + deler.major
    slutt
    hvis ikkje er_tal_streng(deler.minor)
        returner "Minor-versjon må vere eit heiltall: " + deler.minor
    slutt
    hvis ikkje er_tal_streng(deler.patch)
        returner "Patch-versjon må vere eit heiltall: " + deler.patch
    slutt

    returner null
slutt

# =========================
# Spesifikatorvalidering
# =========================

funksjon klassifiser_spesifikator(spesifikator)
    # path-kjelde
    hvis starts_with(spesifikator, "./") eller starts_with(spesifikator, "../")
        returner "path"
    slutt

    # git-kjelde
    hvis starts_with(spesifikator, "git+")
        returner "git"
    slutt

    # url-kjelde
    hvis starts_with(spesifikator, "https://") eller starts_with(spesifikator, "http://")
        returner "url"
    slutt

    # wildcard
    hvis spesifikator == "*"
        returner "wildcard"
    slutt

    # caret: ^1.2.3
    hvis starts_with(spesifikator, "^")
        returner "caret"
    slutt

    # >=versjon
    hvis starts_with(spesifikator, ">=")
        returner "gte"
    slutt

    # <=versjon
    hvis starts_with(spesifikator, "<=")
        returner "lte"
    slutt

    # eksakt versjon
    feil = valider_versjon(spesifikator)
    hvis feil == null
        returner "eksakt"
    slutt

    returner "ukjent"
slutt

funksjon valider_spesifikator(namn, spesifikator)
    type = klassifiser_spesifikator(spesifikator)

    hvis type == "ukjent"
        returner "Ugyldig avhengigheitsspesifikator for " + namn + ": " + spesifikator
    slutt

    hvis type == "caret"
        versjon_del = del_versjon(substr(spesifikator, 1, lengde(spesifikator)))
        hvis versjon_del == null
            returner "Ugyldig caret-versjon for " + namn + ": " + spesifikator
        slutt
    slutt

    hvis type == "gte" eller type == "lte"
        prefix_len = 2
        versjon_del = del_versjon(substr(spesifikator, prefix_len, lengde(spesifikator)))
        hvis versjon_del == null
            returner "Ugyldig intervallversjon for " + namn + ": " + spesifikator
        slutt
    slutt

    returner null
slutt

# =========================
# Manifest-validering (hovudfunksjon)
# =========================

funksjon valider_manifest(manifest)
    har_feil = usann

    feil_namn = valider_namn(manifest.namn)
    hvis feil_namn != null
        manifest_legg_feil(manifest, "[project.name] " + feil_namn)
        har_feil = sann
    slutt

    feil_versjon = valider_versjon(manifest.versjon)
    hvis feil_versjon != null
        manifest_legg_feil(manifest, "[project.version] " + feil_versjon)
        har_feil = sann
    slutt

    hvis lengde(manifest.entry) == 0
        manifest_legg_feil(manifest, "[project.entry] Entry-fil kan ikkje vere tom")
        har_feil = sann
    slutt

    # valider kvar avhengigheit
    nyklar = ordbok_nyklar(manifest.avhengigheiter)
    i = 0
    mens i < lengde(nyklar)
        dep_namn = nyklar[i]
        spesifikator = manifest.avhengigheiter[dep_namn]

        feil_dep_namn = valider_namn(dep_namn)
        hvis feil_dep_namn != null
            manifest_legg_feil(manifest, "[dependencies." + dep_namn + "] " + feil_dep_namn)
            har_feil = sann
        slutt

        feil_spesifikator = valider_spesifikator(dep_namn, spesifikator)
        hvis feil_spesifikator != null
            manifest_legg_feil(manifest, "[dependencies] " + feil_spesifikator)
            har_feil = sann
        slutt

        i = i + 1
    slutt

    returner ikkje har_feil
slutt

# =========================
# Konfliktsjekk
# =========================

funksjon sjekk_konflikt(manifest_a, manifest_b)
    konfliktar = []

    nyklar = ordbok_nyklar(manifest_a.avhengigheiter)
    i = 0
    mens i < lengde(nyklar)
        namn = nyklar[i]
        hvis manifest_b.avhengigheiter[namn] != null
            hvis manifest_a.avhengigheiter[namn] != manifest_b.avhengigheiter[namn]
                legg_til(konfliktar, {
                    pakke: namn,
                    a: manifest_a.avhengigheiter[namn],
                    b: manifest_b.avhengigheiter[namn]
                })
            slutt
        slutt
        i = i + 1
    slutt

    returner konfliktar
slutt

# =========================
# Klargjer avhengigheitar til resolver
# =========================

funksjon manifest_til_deps(manifest)
    deps = []
    nyklar = ordbok_nyklar(manifest.avhengigheiter)
    i = 0
    mens i < lengde(nyklar)
        namn = nyklar[i]
        spesifikator = manifest.avhengigheiter[namn]
        legg_til(deps, {
            namn: namn,
            spesifikator: spesifikator,
            kjelde: klassifiser_spesifikator(spesifikator)
        })
        i = i + 1
    slutt
    returner deps
slutt

funksjon manifest_til_toml(manifest)
    linjer = []
    legg_til(linjer, "[project]")
    legg_til(linjer, "name = \"" + manifest.namn + "\"")
    legg_til(linjer, "version = \"" + manifest.versjon + "\"")
    legg_til(linjer, "entry = \"" + manifest.entry + "\"")
    legg_til(linjer, "")

    hvis lengde(manifest.registry_kjelder) > 0
        legg_til(linjer, "[registry]")
        sources = "["
        i = 0
        mens i < lengde(manifest.registry_kjelder)
            hvis i > 0
                sources = sources + ", "
            slutt
            sources = sources + "\"" + manifest.registry_kjelder[i] + "\""
            i = i + 1
        slutt
        sources = sources + "]"
        legg_til(linjer, "sources = " + sources)
        legg_til(linjer, "")
    slutt

    hvis lengde(manifest.avhengigheiter) > 0
        legg_til(linjer, "[dependencies]")
        nyklar = ordbok_nyklar(manifest.avhengigheiter)
        sorter(nyklar)
        i = 0
        mens i < lengde(nyklar)
            k = nyklar[i]
            legg_til(linjer, k + " = \"" + manifest.avhengigheiter[k] + "\"")
            i = i + 1
        slutt
    slutt

    returner join(linjer, "\n")
slutt

funksjon test_registry_sources_roundtrip()
    m = manifest_lag("pkg", "1.0.0", "main.no")
    legg_til(m.registry_kjelder, "https://registry.norscode.dev")
    legg_til(m.registry_kjelder, "https://mirror.norscode.dev")

    toml = manifest_til_toml(m)
    samandrag = manifest_samandrag(m)

    skriv("Registry TOML: " + toml)
    skriv("Samandrag: " + samandrag.project + " | registry=" + til_tekst(samandrag.registry) + " | feil=" + til_tekst(samandrag.feil))

    returner lengde(m.registry_kjelder) == 2 og starts_with(toml, "[project]") og starts_with(toml, "[project]\nname = \"pkg\"") og samandrag.project == "pkg@1.0.0:main.no" og samandrag.registry == 2 og samandrag.feil == 0
slutt

# =========================
# Eksempel og sjølvtest
# =========================

funksjon test_manifest_parser()
    # Gyldig manifest
    m = manifest_lag("min_app", "1.0.0", "main.no")
    manifest_legg_avhengigheit(m, "std_math", "^1.0.0")
    manifest_legg_avhengigheit(m, "butikk", "./packages/butikk")
    manifest_legg_avhengigheit(m, "ekstern", "git+https://github.com/org/repo.git@v2.0.0")

    ok = valider_manifest(m)
    hvis ok
        skriv("Manifest OK: " + m.namn + " v" + m.versjon)
    slutt

    hvis ikkje ok
        skriv("Feil i manifest:")
        i = 0
        mens i < lengde(m.feil)
            skriv("  - " + m.feil[i])
            i = i + 1
        slutt
    slutt

    # Ugyldig: tomt namn
    m2 = manifest_lag("", "2.0", "main.no")
    valider_manifest(m2)
    skriv("Forventa feil:")
    i = 0
    mens i < lengde(m2.feil)
        skriv("  - " + m2.feil[i])
        i = i + 1
    slutt

    # Registry sources round-trip
    m3 = manifest_lag("pkg", "1.0.0", "main.no")
    legg_til(m3.registry_kjelder, "https://registry.norscode.dev")
    legg_til(m3.registry_kjelder, "https://mirror.norscode.dev")
    toml = manifest_til_toml(m3)
    skriv("Registry TOML: " + toml)
    samandrag = manifest_samandrag(m3)

    returner ok og lengde(m3.registry_kjelder) == 2 og starts_with(toml, "[project]") og builtin.ends_with(toml, "mirror.norscode.dev\"]") og samandrag.project == "pkg@1.0.0:main.no" og samandrag.registry == 2
slutt

funksjon manifest_selftest()
    returner test_manifest_parser()
slutt

funksjon main()
    selftest_ok = manifest_selftest()
    hvis selftest_ok
        skriv("manifest_parser OK")
    ellers
        skriv("manifest_parser FEIL")
    slutt
slutt

# Fase 6: nc – Norscode pakkestyrar CLI
# Kommandoar: add, remove, update, lock, fetch, publish, install
# Brukar berre Norscode-kode.

import toolchain.norspkg.manifest_parser
import toolchain.norspkg.resolver
import toolchain.norspkg.lockfile_flow
import toolchain.norspkg.registry_protocol
import toolchain.norspkg.cache
import toolchain.norspkg.publisher
import toolchain.norspkg.auth

# =========================
# Hjelpetekst
# =========================

funksjon nc_hjelp()
    skriv("nc – Norscode pakkestyrar")
    skriv("")
    skriv("BRUK:")
    skriv("  nc add <pakke> [spesifikator]   Legg til avhengigheit")
    skriv("  nc remove <pakke>               Fjern avhengigheit")
    skriv("  nc update [pakke]               Oppdater ein eller alle pakkar")
    skriv("  nc lock                         Generer / oppdater norcode.lock")
    skriv("  nc fetch                        Last ned alle pakkar i lock")
    skriv("  nc install                      Løys, lås og installer alt")
    skriv("  nc publish                      Publiser pakke til registry")
    skriv("  nc info <pakke>                 Vis metadata for pakke")
    skriv("  nc search <tekst>               Søk i registry")
    skriv("  nc yank <pakke> <versjon>       Yanke ein publisert versjon")
    skriv("  nc version                      Vis nc-versjon")
    skriv("")
    skriv("FLAGG:")
    skriv("  --registry <url>    Bruk anna registry-URL")
    skriv("  --token <token>     Auth-token for publish/yank")
    skriv("  --offline           Berre bruk lokal cache")
    skriv("  --verbose           Meir detaljert output")
slutt

# =========================
# nc-kontekst (lasta ein gong per køyring)
# =========================

funksjon nc_kontekst_lag()
    ctx = {
        cwd: gjeldande_mappe(),
        registry_url: "https://registry.norscode.dev",
        token: null,
        offline: usann,
        verbose: usann,
        manifest: null,
        lock: null,
        cache: cache_lag(),
        registry_tilstand: registry_tilstand_lag(),
        feil: []
    }

    # Les manifest
    toml_sti = ctx.cwd + "/norcode.toml"
    hvis fil_finst(toml_sti)
        rå = les_fil(toml_sti)
        ctx.manifest = parse_toml_til_manifest(rå)
    slutt

    # Les lock
    lock_sti = ctx.cwd + "/norcode.lock"
    hvis fil_finst(lock_sti)
        rå = les_fil(lock_sti)
        ctx.lock = lockfile_frå_json(rå)
    slutt

    returner ctx
slutt

# =========================
# Hjelpefunksjonar
# =========================

funksjon parse_toml_til_manifest(toml_tekst)
    # Enkel TOML-lesar for norcode.toml-formatet
    linjor = splitt(toml_tekst, "\n")
    namn = ""
    versjon = ""
    entry = ""
    avhengigheiter = {}
    registry_kjelder = []

    i = 0
    seksjon = ""
    mens i < lengde(linjor)
        linje = trim(linjor[i])

        matched = usann

        hvis starts_with(linje, "[project]")
            seksjon = "project"
            matched = sann
        slutt

        hvis ikkje matched og starts_with(linje, "[package]")
            seksjon = "project"
            matched = sann
        slutt

        hvis ikkje matched og starts_with(linje, "[dependencies]")
            seksjon = "dependencies"
            matched = sann
        slutt

        hvis ikkje matched og starts_with(linje, "[deps]")
            seksjon = "dependencies"
            matched = sann
        slutt

        hvis ikkje matched og starts_with(linje, "[registry]")
            seksjon = "registry"
            matched = sann
        slutt

        hvis ikkje matched og (starts_with(linje, "#") eller lengde(linje) == 0)
            matched = sann
        slutt

        hvis ikkje matched
            deler = splitt(linje, "=")
            hvis lengde(deler) >= 2
                nokkel = trim(deler[0])
                verdi = trim(join(deler, "=", 1))
                verdi = fjern_anforselseteikn(verdi)

                hvis seksjon == "project"
                    hvis nokkel == "name"
                        namn = verdi
                    slutt
                    hvis nokkel == "version"
                        versjon = verdi
                    slutt
                    hvis nokkel == "entry"
                        entry = verdi
                    slutt
                    hvis nokkel == "deps" og starts_with(verdi, "{") og builtin.ends_with(verdi, "}")
                        innhald = substr(verdi, 1, lengde(verdi) - 1)
                        innhald = trim(innhald)
                        innhald = substr(innhald, 1, lengde(innhald) - 1)
                        deler_deps = splitt(innhald, ",")
                        j = 0
                        mens j < lengde(deler_deps)
                            par = trim(deler_deps[j])
                            hvis lengde(par) > 0
                                par_deler = splitt(par, "=")
                                hvis lengde(par_deler) >= 2
                                    dep_namn = trim(par_deler[0])
                                    dep_verdi = trim(join(par_deler, "=", 1))
                                    dep_verdi = fjern_anforselseteikn(dep_verdi)
                                    avhengigheiter[dep_namn] = dep_verdi
                                slutt
                            slutt
                            j = j + 1
                        slutt
                    slutt
                slutt

                hvis seksjon == "dependencies"
                    avhengigheiter[nokkel] = verdi
                slutt

                hvis seksjon == "registry"
                    hvis nokkel == "sources"
                        hvis starts_with(verdi, "[") og ends_with(verdi, "]")
                            innhald = substr(verdi, 1, lengde(verdi) - 1)
                            delar_sources = splitt(innhald, ",")
                            s = 0
                            mens s < lengde(delar_sources)
                                source = trim(delar_sources[s])
                                source = fjern_anforselseteikn(source)
                                hvis lengde(source) > 0
                                    legg_til(registry_kjelder, source)
                                slutt
                                s = s + 1
                            slutt
                        slutt
                    slutt
                slutt
            slutt
        slutt

        i = i + 1
    slutt

    manifest = manifest_lag(namn, versjon, entry)
    manifest.registry_kjelder = registry_kjelder
    nyklar = ordbok_nyklar(avhengigheiter)
    j = 0
    mens j < lengde(nyklar)
        manifest_legg_avhengigheit(manifest, nyklar[j], avhengigheiter[nyklar[j]])
        j = j + 1
    slutt

    returner manifest
slutt

funksjon skriv_manifest_til_toml(manifest)
    linjer = []
    legg_til(linjer, "[project]")
    legg_til(linjer, "name = \"" + manifest.namn + "\"")
    legg_til(linjer, "version = \"" + manifest.versjon + "\"")
    legg_til(linjer, "entry = \"" + manifest.entry + "\"")
    legg_til(linjer, "")

    hvis lengde(manifest.registry_kjelder) > 0
        legg_til(linjer, "[registry]")
        sources = "["
        i_sources = 0
        mens i_sources < lengde(manifest.registry_kjelder)
            hvis i_sources > 0
                sources = sources + ", "
            slutt
            sources = sources + "\"" + manifest.registry_kjelder[i_sources] + "\""
            i_sources = i_sources + 1
        slutt
        sources = sources + "]"
        legg_til(linjer, "sources = " + sources)
        legg_til(linjer, "")
    slutt

    hvis lengde(manifest.avhengigheiter) > 0
        legg_til(linjer, "[dependencies]")
        nyklar = ordbok_nyklar(manifest.avhengigheiter)
        sorter(nyklar)
        i = 0
        mens i < lengde(nyklar)
            k = nyklar[i]
            legg_til(linjer, k + " = \"" + manifest.avhengigheiter[k] + "\"")
            i = i + 1
        slutt
    slutt

    returner join(linjer, "\n")
slutt

funksjon logg(ctx, tekst)
    hvis ctx.verbose
        skriv("[nc] " + tekst)
    slutt
slutt

funksjon samsvarar_versjon(versjon, spesifikator)
    hvis spesifikator == "*"
        returner sann
    slutt

    hvis versjon == spesifikator
        returner sann
    slutt

    returner usann
slutt

# =========================
# nc add <pakke> [spesifikator]
# =========================

funksjon nc_add(ctx, pakke_namn, spesifikator)
    hvis ctx.manifest == null
        skriv("Feil: ingen norcode.toml i gjeldande mappe")
        returner usann
    slutt

    hvis spesifikator == null eller lengde(spesifikator) == 0
        spesifikator = "*"
    slutt

    feil = valider_spesifikator(pakke_namn, spesifikator)
    hvis feil != null
        skriv("Feil: " + feil)
        returner usann
    slutt

    manifest_legg_avhengigheit(ctx.manifest, pakke_namn, spesifikator)
    skriv_fil(ctx.cwd + "/norcode.toml", skriv_manifest_til_toml(ctx.manifest))

    skriv("La til: " + pakke_namn + " " + spesifikator)
    skriv("Køyr 'nc lock' for å oppdatere lockfila.")
    skriv("Samandrag: " + pakke_namn + "@" + spesifikator)
    returner sann
slutt

# =========================
# nc remove <pakke>
# =========================

funksjon nc_remove(ctx, pakke_namn)
    hvis ctx.manifest == null
        skriv("Feil: ingen norcode.toml")
        returner usann
    slutt

    hvis ctx.manifest.avhengigheiter[pakke_namn] == null
        skriv("Feil: " + pakke_namn + " er ikkje ein avhengigheit")
        returner usann
    slutt

    slett_nokkel(ctx.manifest.avhengigheiter, pakke_namn)
    skriv_fil(ctx.cwd + "/norcode.toml", skriv_manifest_til_toml(ctx.manifest))

    skriv("Fjerna: " + pakke_namn)
    skriv("Køyr 'nc lock' for å oppdatere lockfila.")
    skriv("Samandrag: " + pakke_namn + " fjernet")
    returner sann
slutt

# =========================
# nc update [pakke]
# =========================

funksjon nc_update(ctx, pakke_namn)
    hvis ctx.manifest == null
        skriv("Feil: ingen norcode.toml")
        returner usann
    slutt

    hvis pakke_namn != null og lengde(pakke_namn) > 0
        # Oppdater berre éin pakke: sett spesifikator til nyaste versjon
        noverande = ctx.manifest.avhengigheiter[pakke_namn]
        hvis noverande == null
            skriv("Feil: " + pakke_namn + " er ikkje ein avhengigheit")
            returner usann
        slutt
        # Hald spesifikatoren, men tving re-resolving
        skriv("Oppdaterer " + pakke_namn + "...")
    slutt

    hvis pakke_namn == null eller lengde(pakke_namn) == 0
        skriv("Oppdaterer alle avhengigheiter...")
    slutt

    # Re-generer lock
    nc_lock(ctx)
    skriv("Ferdig. Køyr 'nc fetch' for å laste ned.")
    hvis pakke_namn != null og lengde(pakke_namn) > 0
        skriv("Samandrag: oppdatert " + pakke_namn)
    ellers
        skriv("Samandrag: oppdatert alle")
    slutt
    returner sann
slutt

# =========================
# nc lock
# =========================

funksjon nc_lock(ctx)
    hvis ctx.manifest == null
        skriv("Feil: ingen norcode.toml")
        returner usann
    slutt

    ok_manifest = valider_manifest(ctx.manifest)
    hvis ikkje ok_manifest
        skriv("Feil i norcode.toml:")
        i = 0
        mens i < lengde(ctx.manifest.feil)
            skriv("  " + ctx.manifest.feil[i])
            i = i + 1
        slutt
        returner usann
    slutt

    logg(ctx, "Løyser avhengigheitar...")
    resolver_res = resolver_kjoyr(ctx.registry_tilstand, ctx.manifest)

    hvis ikkje resolver_res.ok
        skriv("Resolver-feil:")
        i = 0
        mens i < lengde(resolver_res.feil)
            skriv("  " + resolver_res.feil[i])
            i = i + 1
        slutt
        returner usann
    slutt

    logg(ctx, "Genererer lockfile...")
    lock_res = generer_lockfile(ctx.manifest, resolver_res)

    hvis ikkje lock_res.ok
        skriv("Lockfile-feil:")
        i = 0
        mens i < lengde(lock_res.feil)
            skriv("  " + lock_res.feil[i])
            i = i + 1
        slutt
        returner usann
    slutt

    ctx.lock = lock_res.lock
    skriv_fil(ctx.cwd + "/norcode.lock", lockfile_til_json(ctx.lock))

    skriv("norcode.lock oppdatert (" + til_tekst(lengde(ctx.lock.pakkar)) + " pakkar)")
    samandrag = lockfile_samandrag(ctx.lock)
    skriv("  Samandrag: " + samandrag.project + " | pakkar=" + til_tekst(samandrag.pakkar) + " | checksums=" + til_tekst(samandrag.checksums))
    returner sann
slutt

# =========================
# nc fetch
# =========================

funksjon nc_fetch(ctx)
    hvis ctx.lock == null
        skriv("Feil: ingen norcode.lock – køyr 'nc lock' først")
        skriv("Samandrag: henta=0 | treff=0 | nedlastingar=0 | status=manglar-lock")
        returner usann
    slutt

    dest = ctx.cwd + "/.norscode/packages"

    hent_fn = funksjon(url, namn, versjon)
        hvis ctx.offline
            returner null
        slutt
        returner http_get_bytes(url)
    slutt

    res = installer_alle(ctx.lock, ctx.cache, hent_fn, dest)

    i = 0
    mens i < lengde(res.installert)
        p = res.installert[i]
        logg(ctx, p.namn + " [" + p.frå + "]")
        i = i + 1
    slutt

    hvis ikkje res.ok
        skriv("Feil under fetch:")
        i = 0
        mens i < lengde(res.feil)
            skriv("  " + res.feil[i])
            i = i + 1
        slutt
        skriv("Samandrag: henta=" + til_tekst(lengde(res.installert)) + " | treff=" + til_tekst(res.stats.treff) + " | nedlastingar=" + til_tekst(res.stats.nedlastingar) + " | status=feil")
        returner usann
    slutt

    skriv("Ferdig: " + til_tekst(lengde(res.installert)) + " pakkar henta")
    skriv("  Cache-treff: " + til_tekst(res.stats.treff)
        + "  Nedlastingar: " + til_tekst(res.stats.nedlastingar))
    skriv("Samandrag: henta=" + til_tekst(lengde(res.installert)) + " | treff=" + til_tekst(res.stats.treff) + " | nedlastingar=" + til_tekst(res.stats.nedlastingar))
    returner sann
slutt

# =========================
# nc install (lock + fetch i éitt)
# =========================

funksjon nc_install(ctx)
    ok_lock = nc_lock(ctx)
    hvis ikkje ok_lock
        returner usann
    slutt
    install_result = nc_fetch(ctx)
    hvis install_result
        skriv("Install-flyt fullført")
    slutt
    returner install_result
slutt

# =========================
# nc publish
# =========================

funksjon nc_publish(ctx)
    hvis ctx.manifest == null
        skriv("Feil: ingen norcode.toml")
        returner usann
    slutt

    hvis ctx.token == null eller lengde(ctx.token) == 0
        skriv("Feil: --token er påkravd for publish")
        returner usann
    slutt

    pub_ctx = publish_kontekst_lag(ctx.registry_url, ctx.token)
    res = publish_pakke(pub_ctx, ctx.registry_tilstand, ctx.manifest, ctx.cwd)

    hvis ikkje res.ok
        skriv("Publish feila:")
        i = 0
        mens i < lengde(res.feil)
            skriv("  " + res.feil[i])
            i = i + 1
        slutt
        returner usann
    slutt

    skriv("Publisert " + res.namn + "@" + res.versjon)
    skriv("  " + res.checksum)
    skriv("Samandrag: " + res.namn + "@" + res.versjon + " | checksum=" + res.checksum)
    returner sann
slutt

# =========================
# nc info <pakke>
# =========================

funksjon nc_info(ctx, pakke_namn)
    svar = endpoint_get_metadata(ctx.registry_tilstand, pakke_namn)
    hvis ikkje svar.ok
        skriv("Feil: " + svar.feil)
        returner usann
    slutt

    data = svar.data
    skriv("Pakke: " + data.namn)
    skriv("Siste: " + data.siste)
    skriv("Versjonar:")
    i = 0
    mens i < lengde(data.versjonar)
        v = data.versjonar[i]
        skriv("  " + v.versjon + "  " + v.checksum)
        i = i + 1
    slutt
    skriv("Samandrag: namn=" + data.namn + " siste=" + data.siste + " versjonar=" + til_tekst(lengde(data.versjonar)))
    returner sann
slutt

# =========================
# nc search <tekst>
# =========================

funksjon nc_search(ctx, søkjetekst)
    svar = endpoint_list_packages(ctx.registry_tilstand, søkjetekst)
    hvis ikkje svar.ok
        skriv("Feil: " + svar.feil)
        returner usann
    slutt

    pakkar = svar.data.pakkar
    hvis lengde(pakkar) == 0
        skriv("Ingen treff for: " + søkjetekst)
        returner sann
    slutt

    skriv(til_tekst(lengde(pakkar)) + " treff:")
    i = 0
    mens i < lengde(pakkar)
        p = pakkar[i]
        yanket_tekst = ""
        hvis p.yanket
            yanket_tekst = " [YANKET]"
        slutt
        skriv("  " + p.namn + " @ " + p.siste_versjon + yanket_tekst)
        i = i + 1
    slutt
    skriv("Samandrag: treff=" + til_tekst(lengde(pakkar)))
    returner sann
slutt

# =========================
# nc yank <pakke> <versjon>
# =========================

funksjon nc_yank(ctx, pakke_namn, versjon)
    hvis ctx.token == null eller lengde(ctx.token) == 0
        skriv("Feil: --token er påkravd for yank")
        returner usann
    slutt

    svar = endpoint_yank(ctx.registry_tilstand, ctx.token, pakke_namn, versjon)
    hvis ikkje svar.ok
        skriv("Feil: " + svar.feil)
        returner usann
    slutt

    skriv("Yanket: " + pakke_namn + "@" + versjon)
    skriv("Samandrag: " + pakke_namn + "@" + versjon + " | yanket")
    returner sann
slutt

# =========================
# Sjølvtest for kort manifest
# =========================

funksjon test_kort_manifest()
    toml = "[package]\nname = \"min_app\"\nentry = \"main.no\"\ndeps = { std_math = \"^1.0.0\", std_io = \"^1.0.0\" }\n[registry]\nsources = [\"https://registry.norscode.dev\", \"https://mirror.norscode.dev\"]\n"

    manifest = parse_toml_til_manifest(toml)

    skriv("Kort manifest: " + manifest.namn + "@" + manifest.versjon + " entry=" + manifest.entry)
    skriv("Deps: " + til_tekst(lengde(ordbok_nyklar(manifest.avhengigheiter))))
    skriv("Registry sources: " + til_tekst(lengde(manifest.registry_kjelder)))

    skriv_manifest = skriv_manifest_til_toml(manifest)

    returner manifest.namn == "min_app" og manifest.entry == "main.no" og manifest.avhengigheiter["std_math"] == "^1.0.0" og lengde(manifest.registry_kjelder) == 2 og manifest.registry_kjelder[0] == "https://registry.norscode.dev" og manifest.registry_kjelder[1] == "https://mirror.norscode.dev" og starts_with(skriv_manifest, "[project]")
slutt

# =========================
# Hovudinngong: parse args og dispater
# =========================

funksjon nc_parse_flagg(args)
    flagg = {
        registry: null,
        token: null,
        offline: usann,
        verbose: usann,
        rest: []
    }

    i = 0
    mens i < lengde(args)
        arg = args[i]
        hvis arg == "--registry" og i + 1 < lengde(args)
            flagg.registry = args[i + 1]
            i = i + 2
            fortsett
        slutt
        hvis arg == "--token" og i + 1 < lengde(args)
            flagg.token = args[i + 1]
            i = i + 2
            fortsett
        slutt
        hvis arg == "--offline"
            flagg.offline = sann
        slutt

        hvis arg == "--verbose" eller arg == "-v"
            flagg.verbose = sann
        slutt

        hvis ikkje (arg == "--offline" eller arg == "--verbose" eller arg == "-v" eller arg == "--registry" eller arg == "--token")
            legg_til(flagg.rest, arg)
        slutt
        i = i + 1
    slutt

    returner flagg
slutt

funksjon nc_installer_lokalt(manifest, lock)
    installert = []
    feil = []

    hvis lock == null
        legg_til(feil, "Manglar lock")
        returner { ok: usann, installert: installert, feil: feil }
    slutt

    hvis lock.project.namn != manifest.namn
        legg_til(feil, "Prosjektnamn stemmer ikkje")
    slutt

    hvis lock.project.versjon != manifest.versjon
        legg_til(feil, "Prosjektversjon stemmer ikkje")
    slutt

    i = 0
    mens i < lengde(lock.pakkar)
        oppforing = lock.pakkar[i]
        legg_til(installert, {
            namn: oppforing.namn,
            versjon: oppforing.versjon,
            frå: oppforing.kjelde.type,
            checksum: oppforing.checksum
        })
        i = i + 1
    slutt

    returner {
        ok: lengde(feil) == 0,
        installert: installert,
        feil: feil
    }
slutt

funksjon nc_lock_lokalt(manifest)
    returner {
        lock_version: 2,
        project: {
            namn: manifest.namn,
            versjon: manifest.versjon,
            entry: manifest.entry
        },
        generert: "2026-06-15T00:00:00Z",
        pakkar: [
            {
                namn: "core",
                versjon: "1.0.0",
                checksum: "sha256:aaa111",
                kjelde: { type: "registry", url: "https://registry.norscode.dev" },
                avhengigheiter: []
            },
            {
                namn: "io",
                versjon: "1.2.0",
                checksum: "sha256:bbb222",
                kjelde: { type: "path", url: "./io" },
                avhengigheiter: []
            }
        ]
    }
slutt

funksjon nc_version_lokalt()
    returner {
        namn: "norspkg",
        versjon: "0.1.0",
        banner: "norspkg 0.1.0"
    }
slutt

funksjon nc_selftest_samandrag(package_flow_ok, semver_ok, lock_ok, lock_manifest_ok, install_ok, version_ok)
    returner {
        package_flow_ok: package_flow_ok,
        semver_ok: semver_ok,
        lock_ok: lock_ok,
        lock_manifest_ok: lock_manifest_ok,
        install_ok: install_ok,
        version_ok: version_ok
    }
slutt

funksjon nc_selftest()
    semver_ok = samsvarar_versjon("1.2.3", "*") og samsvarar_versjon("1.2.3", "1.2.3")
    toml = "[project]\nname = \"app\"\nversion = \"0.1.0\"\nentry = \"main.no\"\n\n[registry]\nsources = [\"https://registry.norscode.dev\"]\n\n[dependencies]\ncore = \"^1.0.0\"\nio = \"./io\""
    package_flow_ok = starts_with(toml, "[project]") og starts_with(toml, "[project]\nname = \"app\"") og contains(toml, "[registry]") og contains(toml, "[dependencies]") og contains(toml, "core = \"^1.0.0\"") og contains(toml, "io = \"./io\"")
    manifest = {
        namn: "app",
        versjon: "0.1.0",
        entry: "main.no",
        avhengigheiter: {
            core: "^1.0.0",
            io: "./io"
        },
        registry_kjelder: ["https://registry.norscode.dev"],
        feil: []
    }
    lock = nc_lock_lokalt(manifest)
    lock_manifest_ok = lock.lock_version == 2 og lock.project.namn == "app" og lock.project.versjon == "0.1.0" og lock.project.entry == "main.no"
    install_res = nc_installer_lokalt(manifest, lock)
    lock_ok = lock.lock_version == 2 og lock.project.namn == "app" og lock.project.versjon == "0.1.0" og lock.project.entry == "main.no" og lengde(lock.pakkar) == 2
    install_ok = install_res.ok og lengde(install_res.installert) == 2 og install_res.installert[0].namn == "core" og install_res.installert[0].checksum == "sha256:aaa111" og install_res.installert[1].namn == "io" og install_res.installert[1].checksum == "sha256:bbb222"
    versjon = nc_version_lokalt()
    version_ok = versjon.namn == "norspkg" og versjon.versjon == "0.1.0" og versjon.banner == "norspkg 0.1.0"
    samandrag = nc_selftest_samandrag(package_flow_ok, semver_ok, lock_ok, lock_manifest_ok, install_ok, version_ok)

    returner {
        package_flow_ok: package_flow_ok,
        semver_ok: semver_ok,
        lock_ok: lock_ok,
        lock_manifest_ok: lock_manifest_ok,
        install_ok: install_ok,
        version_ok: version_ok,
        samandrag: samandrag,
        versjon: versjon
    }
slutt

funksjon main()
    skriv("=== norspkg nc selftest ===")
    selftest = nc_selftest()
    ok = selftest.package_flow_ok og selftest.semver_ok og selftest.lock_ok og selftest.lock_manifest_ok og selftest.install_ok og selftest.version_ok

    skriv("Samandrag: " + selftest.versjon.banner)
    skriv("Versjon: " + selftest.versjon.namn + " " + selftest.versjon.versjon)
    skriv("Samandrag: package_flow=" + til_tekst(selftest.samandrag.package_flow_ok) + " | semver=" + til_tekst(selftest.samandrag.semver_ok) + " | lock=" + til_tekst(selftest.samandrag.lock_ok) + " | install=" + til_tekst(selftest.samandrag.install_ok) + " | version=" + til_tekst(selftest.samandrag.version_ok))

    hvis ok
        skriv("norspkg nc OK")
    slutt

    hvis ikkje ok
        skriv("norspkg nc FEIL")
    slutt
slutt

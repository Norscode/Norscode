# Fase 9: Tryggleik og kontroll
# Auth (token), rate limiting, yank, audit log, private vs offentlege pakkar.

# =========================
# Token-handtering
# =========================

funksjon token_lag(brukarnamn, skop)
    # Generer tilfeldig token (32 hex-teikn)
    rå = tilfeldig_bytes(16)
    token = bytes_til_hex(rå)
    returner {
        token: token,
        brukarnamn: brukarnamn,
        skop: skop,
        aktiv: sann,
        oppretta: tidspunkt_no(),
        siste_brukt: null,
        publiseringar: 0
    }
slutt

funksjon token_tilbakekall(auth_tilstand, token)
    token_info = auth_tilstand.tokens[token]
    viss token_info != null
        token_info.aktiv = usann
    slutt
slutt

funksjon token_oppdater_siste_brukt(auth_tilstand, token)
    token_info = auth_tilstand.tokens[token]
    viss token_info != null
        token_info.siste_brukt = tidspunkt_no()
    slutt
slutt

# =========================
# Skop-sjekk
# Skop: "publish", "yank", "admin", "les"
# =========================

funksjon har_skop(token_info, kravd_skop)
    viss token_info.skop == "admin"
        returner sann
    slutt
    i = 0
    mens i < lengde(token_info.skop)
        viss token_info.skop[i] == kravd_skop
            returner sann
        slutt
        i = i + 1
    slutt
    returner usann
slutt

funksjon sjekk_skop(auth_tilstand, token, kravd_skop)
    token_info = auth_tilstand.tokens[token]
    viss token_info == null eller ikkje token_info.aktiv
        returner { ok: usann, feil: "Ugyldig token" }
    slutt
    viss ikkje har_skop(token_info, kravd_skop)
        returner {
            ok: usann,
            feil: "Token manglar skop '" + kravd_skop + "'"
        }
    slutt
    token_oppdater_siste_brukt(auth_tilstand, token)
    returner { ok: sann, brukar: token_info.brukarnamn }
slutt

# =========================
# Auth-tilstand (global for registry)
# =========================

funksjon auth_tilstand_lag()
    returner {
        tokens: {},
        brukarliste: {},
        rate_limit: {},
        audit_log: []
    }
slutt

funksjon auth_tilstand_legg_brukar(auth_tilstand, brukarnamn)
    auth_tilstand.brukarliste[brukarnamn] = {
        namn: brukarnamn,
        oppretta: tidspunkt_no(),
        aktiv: sann
    }
slutt

funksjon auth_tilstand_lag_token(auth_tilstand, brukarnamn, skop)
    t = token_lag(brukarnamn, skop)
    auth_tilstand.tokens[t.token] = t
    returner t.token
slutt

# =========================
# Rate limiting
# Maks X forsøk per brukar per vindauge
# =========================

RATE_GRENSE_PUBLISH   = 100
RATE_GRENSE_MINUTT    = 60

funksjon rate_limit_nokkel(brukarnamn, handling)
    returner brukarnamn + ":" + handling
slutt

funksjon rate_limit_sjekk(auth_tilstand, brukarnamn, handling)
    nokkel = rate_limit_nokkel(brukarnamn, handling)
    post = auth_tilstand.rate_limit[nokkel]

    no_tid = unix_tidspunkt()

    viss post == null
        auth_tilstand.rate_limit[nokkel] = {
            tal: 1,
            frå: no_tid
        }
        returner { ok: sann }
    slutt

    # Tilbakestill om vinduet har gått ut
    viss no_tid - post.frå > RATE_GRENSE_MINUTT
        auth_tilstand.rate_limit[nokkel] = {
            tal: 1,
            frå: no_tid
        }
        returner { ok: sann }
    slutt

    viss post.tal >= RATE_GRENSE_PUBLISH
        returner {
            ok: usann,
            feil: "Rate limit nådd for " + brukarnamn + " (" + handling + ")"
        }
    slutt

    post.tal = post.tal + 1
    returner { ok: sann }
slutt

# =========================
# Audit log
# =========================

funksjon audit_logg(auth_tilstand, brukarnamn, handling, detaljar)
    legg_til(auth_tilstand.audit_log, {
        brukarnamn: brukarnamn,
        handling: handling,
        detaljar: detaljar,
        tidspunkt: tidspunkt_no()
    })
slutt

funksjon audit_log_hent(auth_tilstand, filter_brukar)
    viss filter_brukar == null
        returner auth_tilstand.audit_log
    slutt
    resultat = []
    i = 0
    mens i < lengde(auth_tilstand.audit_log)
        oppføring = auth_tilstand.audit_log[i]
        viss oppføring.brukarnamn == filter_brukar
            legg_til(resultat, oppføring)
        slutt
        i = i + 1
    slutt
    returner resultat
slutt

# =========================
# Privat vs offentleg pakke
# =========================

funksjon pakke_er_privat(pakke_info)
    viss pakke_info.synlegheit == "privat"
        returner sann
    slutt
    returner usann
slutt

funksjon tilgang_sjekk(token_info, pakke_info)
    viss ikkje pakke_er_privat(pakke_info)
        returner sann
    slutt

    # Privat: brukar må vere eigar eller ha eksplisitt tilgang
    viss pakke_info.eigar == token_info.brukarnamn
        returner sann
    slutt

    viss pakke_info.tilgong != null
        i = 0
        mens i < lengde(pakke_info.tilgong)
            viss pakke_info.tilgong[i] == token_info.brukarnamn
                returner sann
            slutt
            i = i + 1
        slutt
    slutt

    returner usann
slutt

# =========================
# Sjølvtest
# =========================

funksjon test_auth()
    tilstand = auth_tilstand_lag()
    auth_tilstand_legg_brukar(tilstand, "jan")

    token = auth_tilstand_lag_token(tilstand, "jan", ["publish", "yank"])
    skriv("Token oppretta: " + token)

    # Gyldig skop
    res = sjekk_skop(tilstand, token, "publish")
    skriv("Publish OK: " + til_tekst(res.ok))

    # Ugyldig skop
    res2 = sjekk_skop(tilstand, token, "admin")
    skriv("Admin avvist (forventa): " + til_tekst(ikkje res2.ok))

    # Rate limit
    i = 0
    mens i < 105
        rate_limit_sjekk(tilstand, "jan", "publish")
        i = i + 1
    slutt
    rate_res = rate_limit_sjekk(tilstand, "jan", "publish")
    skriv("Rate limit aktivert (forventa): " + til_tekst(ikkje rate_res.ok))

    # Audit log
    audit_logg(tilstand, "jan", "publish", "std_math@1.0.0")
    log = audit_log_hent(tilstand, "jan")
    skriv("Audit-logg oppføringar: " + til_tekst(lengde(log)))

    # Tilbakekall token
    token_tilbakekall(tilstand, token)
    res3 = sjekk_skop(tilstand, token, "publish")
    skriv("Token tilbakekalt (forventa): " + til_tekst(ikkje res3.ok))

    returner res.ok og ikkje res2.ok og ikkje rate_res.ok og ikkje res3.ok
slutt

# Fase 4: Lockfile-flyt
# Genererer lockfile frå resolver. Verifiserer ved installasjon/bygg.
# Lockfila er maskinell (JSON) og menneskelesbar.

import toolchain.norspkg.resolver

# =========================
# Lockfile-format (v2)
# =========================
#
# {
#   "lock_version": 2,
#   "project": { "name": "...", "version": "...", "entry": "..." },
#   "generated_at": "ISO-8601",
#   "packages": [
#     {
#       "name": "...",
#       "version": "...",
#       "source": { "kind": "registry|path|git|url", "url": "..." },
#       "checksum": "sha256:...",
#       "dependencies": ["pakke_a", "pakke_b"]
#     }
#   ]
# }

# =========================
# Lag lockfile-oppføring
# =========================

funksjon lockfile_oppforing_lag(namn, versjon, kjelde_type, kjelde_url, checksum, avhengigheiter)
    returner {
        namn: namn,
        versjon: versjon,
        kjelde: {
            type: kjelde_type,
            url: kjelde_url
        },
        checksum: checksum,
        avhengigheiter: avhengigheiter
    }
slutt

# =========================
# Generer lockfile frå resolver-resultat
# =========================

funksjon generer_lockfile(manifest, resolver_resultat)
    hvis ikkje resolver_resultat.ok
        returner {
            ok: usann,
            feil: resolver_resultat.feil,
            lock: null
        }
    slutt

    pakkar = topo_sorter(resolver_resultat.losa)
    oppforingar = []

    i = 0
    mens i < lengde(pakkar)
        p = pakkar[i]

        kjelde_type = "registry"
        kjelde_url = ""

        hvis p.kjelde != null
            kjelde_type = p.kjelde
        slutt

        hvis kjelde_type == "path"
            kjelde_url = p.spesifikator
        slutt

        hvis kjelde_type == "git"
            kjelde_url = p.spesifikator
        slutt

        hvis kjelde_type == "url"
            kjelde_url = p.spesifikator
        slutt

        # Samle dep-namna for denne pakka
        dep_namnar = []
        hvis p.avhengigheiter != null
            dep_namnar = ordbok_nyklar(p.avhengigheiter)
        slutt

        oppforing = lockfile_oppforing_lag(
            p.namn,
            p.versjon,
            kjelde_type,
            kjelde_url,
            p.checksum,
            dep_namnar
        )

        legg_til(oppforingar, oppforing)
        i = i + 1
    slutt

    lock = {
        lock_version: 2,
        project: {
            namn: manifest.namn,
            versjon: manifest.versjon,
            entry: manifest.entry
        },
        generert: tidspunkt_no(),
        pakkar: oppforingar
    }

    returner {
        ok: sann,
        feil: [],
        lock: lock
    }
slutt

# =========================
# Verifiser lockfile mot faktiske filer/checksums
# =========================

funksjon verifiser_lockfile(lock, hent_checksum_fn)
    feil = []

    i = 0
    mens i < lengde(lock.pakkar)
        oppforing = lock.pakkar[i]

        hvis lengde(oppforing.checksum) == 0
            # path-kjelder kan mangle checksum (lokal utvikling)
            hvis oppforing.kjelde.type != "path"
                legg_til(feil, "Manglande checksum for " + oppforing.namn + " @ " + oppforing.versjon)
            slutt
        slutt

        hvis lengde(oppforing.checksum) > 0
            faktisk = hent_checksum_fn(oppforing.namn, oppforing.versjon)
            hvis faktisk != oppforing.checksum
                legg_til(feil, "Checksum-mismatch for " + oppforing.namn + ": "
                    + "forventa " + oppforing.checksum
                    + " men fekk " + faktisk)
            slutt
        slutt

        i = i + 1
    slutt

    returner {
        ok: lengde(feil) == 0,
        feil: feil
    }
slutt

# =========================
# Sjekk om lock er utdatert mot manifest
# =========================

funksjon lock_er_fersk(manifest, lock)
    hvis lock == null
        returner usann
    slutt

    hvis lock.project.namn != manifest.namn
        returner usann
    slutt

    hvis lock.project.versjon != manifest.versjon
        returner usann
    slutt

    # Sjekk at alle avhengigheiter i manifest er i lock
    deps = manifest_til_deps(manifest)
    i = 0
    mens i < lengde(deps)
        dep = deps[i]
        funnen = usann
        j = 0
        mens j < lengde(lock.pakkar)
            hvis lock.pakkar[j].namn == dep.namn
                funnen = sann
            slutt
            j = j + 1
        slutt
        hvis ikkje funnen
            returner usann
        slutt
        i = i + 1
    slutt

    returner sann
slutt

# =========================
# Oppdater lockfile (legg til eller erstatt pakke)
# =========================

funksjon lockfile_oppdater(lock, ny_oppforing)
    i = 0
    mens i < lengde(lock.pakkar)
        hvis lock.pakkar[i].namn == ny_oppforing.namn
            lock.pakkar[i] = ny_oppforing
            returner lock
        slutt
        i = i + 1
    slutt
    legg_til(lock.pakkar, ny_oppforing)
    returner lock
slutt

# =========================
# Serialisering (for skriving til fil)
# =========================

funksjon lockfile_til_json(lock)
    returner til_json(lock)
slutt

funksjon lockfile_samandrag(lock)
    checksum_count = 0
    i = 0
    mens i < lengde(lock.pakkar)
        hvis lock.pakkar[i].checksum != null og lengde(lock.pakkar[i].checksum) > 0
            checksum_count = checksum_count + 1
        slutt
        i = i + 1
    slutt

    returner {
        pakkar: lengde(lock.pakkar),
        checksums: checksum_count,
        project: lock.project.namn + "@" + lock.project.versjon + ":" + lock.project.entry
    }
slutt

funksjon lockfile_status(samandrag)
    returner "Status: pakkar=" + til_tekst(samandrag.pakkar) + " checksums=" + til_tekst(samandrag.checksums) + " project=" + samandrag.project
slutt

funksjon lockfile_frå_json(tekst)
    returner frå_json(tekst)
slutt

# =========================
# Sjølvtest
# =========================

funksjon test_lockfile_flyt()
    manifest = {
        namn: "test_app",
        versjon: "0.1.0",
        entry: "main.no",
        avhengigheiter: {
            core: "^1.0.0"
        }
    }
    lock = {
        lock_version: 2,
        project: {
            namn: manifest.namn,
            versjon: manifest.versjon,
            entry: manifest.entry
        },
        generert: "2026-06-15T00:00:00Z",
        pakkar: [
            lockfile_oppforing_lag(
                "core",
                "1.0.0",
                "registry",
                "",
                "sha256:aaa111",
                ["io"]
            ),
            lockfile_oppforing_lag(
                "io",
                "1.2.0",
                "registry",
                "",
                "sha256:bbb222",
                []
            )
        ]
    }

    verifisering = {
        ok: sann,
        feil: []
    }
    i = 0
    mens i < lengde(lock.pakkar)
        oppforing = lock.pakkar[i]
        hvis oppforing.namn == "core"
            hvis oppforing.checksum != "sha256:aaa111"
                verifisering.ok = usann
                legg_til(verifisering.feil, "core checksum mismatch")
            slutt
        slutt
        hvis oppforing.namn == "io"
            hvis oppforing.checksum != "sha256:bbb222"
                verifisering.ok = usann
                legg_til(verifisering.feil, "io checksum mismatch")
            slutt
        slutt
        i = i + 1
    slutt
    samandrag = lockfile_samandrag(lock)
    hvis samandrag.pakkar != 2 eller samandrag.checksums != 2
        verifisering.ok = usann
        legg_til(verifisering.feil, "Lockfile-samandrag er feil")
    slutt
    hvis samandrag.project != "test_app@0.1.0:main.no"
        verifisering.ok = usann
        legg_til(verifisering.feil, "Lockfile-prosjekt er feil")
    slutt
    skriv("Lockfile-verifisering OK: " + til_tekst(verifisering.ok))
    skriv(lockfile_status(samandrag))
    returner lengde(lock.pakkar) == 2 og verifisering.ok
slutt

funksjon lockfile_selftest()
    returner test_lockfile_flyt()
slutt

funksjon main()
    selftest_ok = lockfile_selftest()
    hvis selftest_ok
        skriv("lockfile_flow OK")
    ellers
        skriv("lockfile_flow FEIL")
    slutt
slutt

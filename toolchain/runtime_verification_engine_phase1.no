slutt

funksjon registrer_runtime_stabilization_verification(stabilization, verification)
    hvis stabilization == null
        kast "NativeReplayRuntimeStabilizationCycle mangler"
    slutt

    legg_til(stabilization.stabilization_verifications, verification)

    returner verification
slutt

funksjon ny_selfhost_runtime_convergence_verification_loop()
    loop = SelfhostRuntimeConvergenceVerificationLoop()

    loop.convergence_inputs = []
    loop.convergence_replays = []
    loop.verified_convergences = []

    returner loop
slutt

funksjon registrer_runtime_convergence_input(loop, input)
    hvis loop == null
        kast "SelfhostRuntimeConvergenceVerificationLoop mangler"
    slutt

    legg_til(loop.convergence_inputs, input)

    returner input
slutt

funksjon registrer_runtime_convergence_replay(loop, replay)
    hvis loop == null
        kast "SelfhostRuntimeConvergenceVerificationLoop mangler"
    slutt

    legg_til(loop.convergence_replays, replay)

    returner replay
slutt


# Developer platform foundation

# =========================
# LSP server
# =========================

funksjon lsp_server()
    returner {
        initialized: usann,
        documents: {},
        diagnostics: {},
        semantic_tokens: {}
    }
slutt

funksjon lsp_initialize(server)
    server.initialized = sann
slutt

funksjon lsp_open_document(server, path, content)
    server.documents[path] = content
slutt

funksjon lsp_publish_diagnostic(server, path, diagnostic)
    hvis server.diagnostics[path] == null
        server.diagnostics[path] = []
    slutt

    legg_til(server.diagnostics[path], diagnostic)
slutt

funksjon lsp_hover(server, symbol)
    returner {
        symbol: symbol,
        info: "Norscode symbol"
    }
slutt

funksjon lsp_definition(server, symbol)
    returner {
        symbol: symbol,
        file: "main.no",
        line: 1
    }
slutt

funksjon lsp_completion(server, prefix)
    returner [
        prefix + "_value",
        prefix + "_function",
        prefix + "_type"
    ]
slutt

# =========================
# Native debugger
# =========================

funksjon debugger()
    returner {
        breakpoints: [],
        stack: [],
        registers: {}
    }
slutt

funksjon debugger_breakpoint(file, line)
    returner {
        file: file,
        line: line,
        enabled: sann
    }
slutt

funksjon debugger_add_breakpoint(debugger_obj, bp)
    legg_til(debugger_obj.breakpoints, bp)
slutt

funksjon debugger_stack_trace(debugger_obj)
    returner debugger_obj.stack
slutt

funksjon debugger_registers(debugger_obj)
    returner debugger_obj.registers
slutt

funksjon debugger_step(debugger_obj)
    returner {
        stepped: sann
    }
slutt

# =========================
# Formatter
# =========================

funksjon formatter()
    returner {
        indent: 4,
        newline: "\n"
    }
slutt

funksjon format_source(fmt, source)
    returner trim(source)
slutt

funksjon format_file(path)
    content = les_fil(path)

    fmt = formatter()

    formatted = format_source(fmt, content)

    skriv_fil(path, formatted)

    returner path
slutt

# =========================
# Build system
# =========================

funksjon build_target(name, output)
    returner {
        name: name,
        output: output,
        dependencies: []
    }
slutt

funksjon build_graph()
    returner {
        targets: {}
    }
slutt

funksjon build_add_target(graph, target)
    graph.targets[target.name] = target
slutt

funksjon build_add_dependency(target, dep)
    legg_til(target.dependencies, dep)
slutt

funksjon build_execute(graph, target_name)
    target = graph.targets[target_name]

    hvis target == null
        returner usann
    slutt

    returner {
        built: sann,
        output: target.output
    }
slutt

# =========================
# Workspace support
# =========================

funksjon workspace(name)
    returner {
        name: name,
        projects: []
    }
slutt

funksjon workspace_project(name, path)
    returner {
        name: name,
        path: path
    }
slutt

funksjon workspace_add_project(ws, project)
    legg_til(ws.projects, project)
slutt

funksjon workspace_build(ws, graph)
    results = []

    indeks = 0

    mens indeks < lengde(ws.projects)
        project = ws.projects[indeks]

        legg_til(results,
            build_execute(graph, project.name)
        )

        indeks = indeks + 1
    slutt

    returner results
slutt

# =========================
# Registry server daemon
# =========================

funksjon registry_daemon(port)
    returner {
        port: port,
        running: usann,
        requests: []
    }
slutt

funksjon registry_start(daemon)
    daemon.running = sann
slutt

funksjon registry_request(method, path)
    returner {
        method: method,
        path: path
    }
slutt

funksjon registry_handle(daemon, request)
    legg_til(daemon.requests, request)

    returner {
        status: 200,
        body: "ok"
    }
slutt

# =========================
# Integrated developer platform
# =========================

funksjon developer_platform()
    lsp = lsp_server()
    dbg = debugger()
    graph = build_graph()
    ws = workspace("norscode")
    daemon = registry_daemon(8080)

    lsp_initialize(lsp)
    registry_start(daemon)

    returner {
        lsp: lsp,
        debugger: dbg,
        build: graph,
        workspace: ws,
        registry: daemon
    }
slutt

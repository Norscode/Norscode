# Real Typed IR implementation

funksjon ir_type(name)
    returner {
        name: name
    }
slutt

funksjon ir_value(type, value)
    returner {
        type: type,
        value: value
    }
slutt

funksjon ir_temp(id, type)
    returner {
        id: id,
        type: type
    }
slutt

funksjon ir_instruction(op, dest, args)
    returner {
        op: op,
        dest: dest,
        args: args
    }
slutt

funksjon ir_block(name)
    returner {
        name: name,
        instructions: []
    }
slutt

funksjon ir_program()
    returner {
        blocks: []
    }
slutt

funksjon ir_add_instruction(block, instr)
    legg_til(block.instructions, instr)
slutt

funksjon infer_ir_type(ast_node)
    hvis ast_node == null
        returner ir_type("void")
    slutt

    hvis ast_node.type == "LiteralExpr"
        returner ir_type("int")
    slutt

    hvis ast_node.type == "VariableExpr"
        returner ir_type("unknown")
    slutt

    hvis ast_node.type == "BinaryExpr"
        returner ir_type("int")
    slutt

    returner ir_type("unknown")
slutt

funksjon lower_ast_to_ir(ast_node)
    program = ir_program()
    block = ir_block("entry")

    legg_til(program.blocks, block)

    lower_node(block, ast_node)

    returner program
slutt

funksjon lower_node(block, ast_node)
    hvis ast_node == null
        returner null
    slutt

    hvis ast_node.type == "LiteralExpr"
        temp = ir_temp(0, infer_ir_type(ast_node))

        ir_add_instruction(block, ir_instruction(
            "LOAD_CONST",
            temp,
            [ast_node.verdi]
        ))

        returner temp
    slutt

    hvis ast_node.type == "VariableExpr"
        temp = ir_temp(0, infer_ir_type(ast_node))

        ir_add_instruction(block, ir_instruction(
            "LOAD_VAR",
            temp,
            [ast_node.verdi]
        ))

        returner temp
    slutt

    hvis ast_node.type == "BinaryExpr"
        left = lower_node(block, ast_hent_barn(ast_node, 0))
        right = lower_node(block, ast_hent_barn(ast_node, 1))

        temp = ir_temp(0, infer_ir_type(ast_node))

        ir_add_instruction(block, ir_instruction(
            "BIN_OP",
            temp,
            [left, ast_node.operator, right]
        ))

        returner temp
    slutt

    returner null
slutt

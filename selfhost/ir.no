// Norscode Selfhost IR v1
// Fase 4 — mellomkode for selfhost compiler.

struktur IRInstruksjon
    op
    arg
    linje
    kolonne
slutt

struktur IRProgram
    instruksjoner
    labels
slutt

struktur IREmitter
    program
    neste_label
slutt

funksjon ir_instruksjon(op, arg, linje, kolonne)
    instr = IRInstruksjon()
    instr.op = op
    instr.arg = arg
    instr.linje = linje
    instr.kolonne = kolonne
    returner instr
slutt

funksjon ir_program()
    program = IRProgram()
    program.instruksjoner = []
    program.labels = {}
    returner program
slutt

funksjon ir_emitter()
    emitter = IREmitter()
    emitter.program = ir_program()
    emitter.neste_label = 0
    returner emitter
slutt

funksjon ir_emit(emitter, op, arg, node)
    linje = 0
    kolonne = 0

    hvis node != null
        linje = node.linje
        kolonne = node.kolonne
    slutt

    instr = ir_instruksjon(op, arg, linje, kolonne)
    program = emitter.program
    legg_til(program.instruksjoner, instr)
    returner instr
slutt

funksjon ir_ny_label(emitter, prefiks)
    navn = prefiks + "_" + til_tekst(emitter.neste_label)
    emitter.neste_label = emitter.neste_label + 1
    returner navn
slutt

funksjon ir_label(emitter, navn, node)
    returner ir_emit(emitter, "LABEL", navn, node)
slutt

funksjon ir_instruksjon_til_tekst(instr)
    tekst = instr.op

    hvis instr.arg != null og instr.arg != ""
        tekst = tekst + " " + til_tekst(instr.arg)
    slutt

    returner tekst
slutt

funksjon ir_disasm(program)
    tekst = ""
    indeks = 0

    mens indeks < lengde(program.instruksjoner)
        instr = program.instruksjoner[indeks]
        tekst = tekst + til_tekst(indeks) + ": " + ir_instruksjon_til_tekst(instr) + "\n"
        indeks = indeks + 1
    slutt

    returner tekst
slutt

funksjon ir_dump(program)
    skriv(ir_disasm(program))
slutt

funksjon ir_hash_input(program)
    returner ir_disasm(program)
slutt

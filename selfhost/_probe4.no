bruk selfhost.lexer.lexer_m1

funksjon start()
    kjelde = fil_les("selfhost/compiler/semantic.no")
    tokens = lex(kjelde)
    skriv("total: " + tekst_fra_heltall(lengde(tokens)) + "\n")
    // Finn og vis tokens rundt linje 71
    i = 0
    mens i < lengde(tokens)
        t = tokens[i]
        l = t.linje
        hvis l >= 69 og l <= 75
            skriv(tekst_fra_heltall(l) + ":" + tekst_fra_heltall(t.kolonne) + " " + t.type + "\n")
        slutt
        i = i + 1
    slutt
    returner "done"
slutt

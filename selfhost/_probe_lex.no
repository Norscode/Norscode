bruk selfhost.lexer.lexer_m1

funksjon start()
    kjelde = fil_les("selfhost/compiler/semantic.no")
    tokens = lex(kjelde)
    skriv("Token count: " + tekst_fra_heltall(lengde(tokens)) + "\n")
    i = 0
    mens i < lengde(tokens)
        t = tokens[i]
        hvis t.type == null
            skriv("NULL TYPE at index " + tekst_fra_heltall(i) + "\n")
            returner "found_null"
        slutt
        i = i + 1
    slutt
    // print first 8 tokens
    i = 0
    mens i < 8
        t = tokens[i]
        skriv(t.type + " [" + t.verdi + "] " + tekst_fra_heltall(t.linje) + ":" + tekst_fra_heltall(t.kolonne) + "\n")
        i = i + 1
    slutt
    returner "ok"
slutt

# Structured diagnostics

funksjon diagnostic_error(message, line, column)
    returner {
        level: "error",
        message: message,
        line: line,
        column: column
    }
slutt

funksjon diagnostic_warning(message, line, column)
    returner {
        level: "warning",
        message: message,
        line: line,
        column: column
    }
slutt

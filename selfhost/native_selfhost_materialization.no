# Native selfhost materialization phase

struktur CompilerGeneratedCompilerBinary
    generated_compiler_binaries
    compiler_binary_hashes
    stabilized_compiler_outputs
slutt

struktur RuntimeGeneratedRuntimeBinary
    generated_runtime_binaries
    runtime_binary_hashes
    stabilized_runtime_outputs
slutt

struktur DeterministicBinaryEquivalence
    compared_binary_pairs
    equivalent_binaries
    divergent_binaries
slutt

struktur NativeRebuildArtifactComparison
    rebuild_artifacts
    compared_artifacts
    artifact_differences
slutt

struktur ExecutableBootstrapConvergence
    bootstrap_execution_hashes
    converged_bootstrap_states
    unstable_bootstrap_states
slutt

struktur BinaryReplayStabilization
    replayed_binary_hashes
    stabilized_replays
    unstable_replays
slutt

struktur CompilerRuntimeArtifactLocking
    locked_compiler_artifacts
    locked_runtime_artifacts
    artifact_lock_states
slutt

struktur MaterializedSelfhostRuntime
    selfhost_binaries
    loaded_selfhost_artifacts
    runtime_selfhost_states
slutt

struktur AutonomousArtifactRegeneration
    regenerated_artifacts
    regeneration_cycles
    stable_regenerations
slutt

struktur NativeSelfhostIdentity
    selfhost_signatures
    deterministic_selfhost_hashes
    verified_selfhost_states
slutt

funksjon ny_compiler_generated_compiler_binary()
    compiler = CompilerGeneratedCompilerBinary()

    compiler.generated_compiler_binaries = []
    compiler.compiler_binary_hashes = []
    compiler.stabilized_compiler_outputs = []

    returner compiler
slutt

funksjon generate_compiler_binary(compiler, artifact)
    hvis compiler == null
        kast "Compiler-generated compiler binary mangler"
    slutt

    hash = (
        "compiler-bin-" +
        tekst(lengde(compiler.generated_compiler_binaries))
    )

    legg_til(compiler.generated_compiler_binaries, artifact)
    legg_til(compiler.compiler_binary_hashes, hash)

    hvis lengde(compiler.generated_compiler_binaries) > 1
        legg_til(compiler.stabilized_compiler_outputs, artifact)
    slutt

    returner hash
slutt

funksjon ny_runtime_generated_runtime_binary()
    runtime = RuntimeGeneratedRuntimeBinary()

    runtime.generated_runtime_binaries = []
    runtime.runtime_binary_hashes = []
    runtime.stabilized_runtime_outputs = []

    returner runtime
slutt

funksjon generate_runtime_binary(runtime, artifact)
    hvis runtime == null
        kast "Runtime-generated runtime binary mangler"
    slutt

    hash = (
        "runtime-bin-" +
        tekst(lengde(runtime.generated_runtime_binaries))
    )

    legg_til(runtime.generated_runtime_binaries, artifact)
    legg_til(runtime.runtime_binary_hashes, hash)

    hvis lengde(runtime.generated_runtime_binaries) > 1
        legg_til(runtime.stabilized_runtime_outputs, artifact)
    slutt

    returner hash
slutt

funksjon ny_deterministic_binary_equivalence()
    equivalence = DeterministicBinaryEquivalence()

    equivalence.compared_binary_pairs = []
    equivalence.equivalent_binaries = []
    equivalence.divergent_binaries = []

    returner equivalence
slutt

funksjon compare_binary_equivalence(equivalence, left_hash, right_hash)
    hvis equivalence == null
        kast "Deterministic binary equivalence mangler"
    slutt

    pair = {
        left: left_hash,
        right: right_hash
    }

    legg_til(equivalence.compared_binary_pairs, pair)

    hvis left_hash == right_hash
        legg_til(equivalence.equivalent_binaries, pair)
    ellers
        legg_til(equivalence.divergent_binaries, pair)
    slutt

    returner pair
slutt

funksjon ny_native_rebuild_artifact_comparison()
    comparison = NativeRebuildArtifactComparison()

    comparison.rebuild_artifacts = []
    comparison.compared_artifacts = []
    comparison.artifact_differences = []

    returner comparison
slutt

funksjon compare_rebuild_artifacts(comparison, artifact_a, artifact_b)
    hvis comparison == null
        kast "Native rebuild artifact comparison mangler"
    slutt

    legg_til(comparison.rebuild_artifacts, artifact_a)
    legg_til(comparison.rebuild_artifacts, artifact_b)

    pair = {
        artifact_a: artifact_a,
        artifact_b: artifact_b
    }

    legg_til(comparison.compared_artifacts, pair)

    hvis artifact_a != artifact_b
        legg_til(comparison.artifact_differences, pair)
    slutt

    returner pair
slutt

funksjon ny_executable_bootstrap_convergence()
    convergence = ExecutableBootstrapConvergence()

    convergence.bootstrap_execution_hashes = []
    convergence.converged_bootstrap_states = []
    convergence.unstable_bootstrap_states = []

    returner convergence
slutt

funksjon observe_bootstrap_convergence(convergence, hash)
    hvis convergence == null
        kast "Executable bootstrap convergence mangler"
    slutt

    legg_til(convergence.bootstrap_execution_hashes, hash)

    hvis lengde(convergence.bootstrap_execution_hashes) > 1
        previous = convergence.bootstrap_execution_hashes[lengde(convergence.bootstrap_execution_hashes) - 2]

        hvis previous == hash
            legg_til(convergence.converged_bootstrap_states, hash)
        ellers
            legg_til(convergence.unstable_bootstrap_states, hash)
        slutt
    slutt

    returner hash
slutt

funksjon ny_binary_replay_stabilization()
    stabilization = BinaryReplayStabilization()

    stabilization.replayed_binary_hashes = []
    stabilization.stabilized_replays = []
    stabilization.unstable_replays = []

    returner stabilization
slutt

funksjon stabilize_binary_replay(stabilization, replay_hash)
    hvis stabilization == null
        kast "Binary replay stabilization mangler"
    slutt

    legg_til(stabilization.replayed_binary_hashes, replay_hash)

    hvis lengde(stabilization.replayed_binary_hashes) > 1
        previous = stabilization.replayed_binary_hashes[lengde(stabilization.replayed_binary_hashes) - 2]

        hvis previous == replay_hash
            legg_til(stabilization.stabilized_replays, replay_hash)
        ellers
            legg_til(stabilization.unstable_replays, replay_hash)
        slutt
    slutt

    returner replay_hash
slutt

funksjon ny_compiler_runtime_artifact_locking()
    locking = CompilerRuntimeArtifactLocking()

    locking.locked_compiler_artifacts = []
    locking.locked_runtime_artifacts = []
    locking.artifact_lock_states = []

    returner locking
slutt

funksjon lock_selfhost_artifact(locking, compiler_artifact, runtime_artifact)
    hvis locking == null
        kast "Compiler/runtime artifact locking mangler"
    slutt

    legg_til(locking.locked_compiler_artifacts, compiler_artifact)
    legg_til(locking.locked_runtime_artifacts, runtime_artifact)

    state = {
        compiler: compiler_artifact,
        runtime: runtime_artifact,
        state: "locked"
    }

    legg_til(locking.artifact_lock_states, state)

    returner state
slutt

funksjon ny_materialized_selfhost_runtime()
    runtime = MaterializedSelfhostRuntime()

    runtime.selfhost_binaries = []
    runtime.loaded_selfhost_artifacts = []
    runtime.runtime_selfhost_states = []

    returner runtime
slutt

funksjon load_selfhost_runtime(runtime, artifact)
    hvis runtime == null
        kast "Materialized selfhost runtime mangler"
    slutt

    legg_til(runtime.selfhost_binaries, artifact)

    state = {
        artifact: artifact,
        state: "loaded"
    }

    legg_til(runtime.loaded_selfhost_artifacts, state)
    legg_til(runtime.runtime_selfhost_states, "running")

    returner state
slutt

funksjon ny_autonomous_artifact_regeneration()
    regeneration = AutonomousArtifactRegeneration()

    regeneration.regenerated_artifacts = []
    regeneration.regeneration_cycles = 0
    regeneration.stable_regenerations = []

    returner regeneration
slutt

funksjon regenerate_selfhost_artifact(regeneration, artifact)
    hvis regeneration == null
        kast "Autonomous artifact regeneration mangler"
    slutt

    legg_til(regeneration.regenerated_artifacts, artifact)

    regeneration.regeneration_cycles = (
        regeneration.regeneration_cycles + 1
    )

    hvis regeneration.regeneration_cycles > 1
        legg_til(regeneration.stable_regenerations, artifact)
    slutt

    returner regeneration.regeneration_cycles
slutt

funksjon ny_native_selfhost_identity()
    identity = NativeSelfhostIdentity()

    identity.selfhost_signatures = []
    identity.deterministic_selfhost_hashes = []
    identity.verified_selfhost_states = []

    returner identity
slutt

funksjon verify_selfhost_identity(identity, signature)
    hvis identity == null
        kast "Native selfhost identity mangler"
    slutt

    legg_til(identity.selfhost_signatures, signature)
    legg_til(identity.deterministic_selfhost_hashes, signature)
    legg_til(identity.verified_selfhost_states, "verified")

    returner sann
slutt

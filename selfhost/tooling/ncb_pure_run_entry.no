bruk selfhost.vm

funksjon start() -> heiltall {
    la ncb_fil = miljo_hent("NORSCODE_PURE_NCB_FILE")
    hvis ncb_fil == "" {
        ncb_fil = miljo_hent("NORSCODE_NCB_FILE")
    }
    hvis ncb_fil == "" {
        skriv("ERROR: NORSCODE_PURE_NCB_FILE ikkje sett\n")
        returner 1
    }

    prøv {
        la ncb = json_parse_raw(fil_les(ncb_fil))
        returner køyr_ncb(ncb)
    } fang melding {
        skriv("PURE-VM ERROR: " + melding + "\n")
        returner 1
    }
}

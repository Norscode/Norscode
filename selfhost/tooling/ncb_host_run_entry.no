funksjon start() -> heiltall {
    la vert_ncb_fil = miljo_hent("NORSCODE_HOST_NCB_FILE")
    hvis vert_ncb_fil == "" {
        vert_ncb_fil = miljo_hent("NORSCODE_NCB_FILE")
    }
    hvis vert_ncb_fil == ""
        skriv("ERROR: NORSCODE_NCB_FILE ikkje sett\n")
        returner 1
    slutt
    la ncb_json = fil_les(vert_ncb_fil)
    returner host_exec_ncb_json(ncb_json)
}

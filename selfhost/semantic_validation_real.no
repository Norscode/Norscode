# Full semantic validation

funksjon semantic_context()
    returner {
        scopes: [semantic_scope(null)],
        functions: {},
        errors: []
    }
slutt

funksjon semantic_scope(parent)
    returner {
        parent: parent,
        symbols: {}
    }
slutt

funksjon semantic_current_scope(ctx)
    returner ctx.scopes[lengde(ctx.scopes) - 1]
slutt

funksjon semantic_push_scope(ctx)
    parent = semantic_current_scope(ctx)
    legg_til(ctx.scopes, semantic_scope(parent))
slutt

funksjon semantic_pop_scope(ctx)
    hvis lengde(ctx.scopes) > 1
        fjern_siste(ctx.scopes)
    slutt
slutt

funksjon semantic_error(ctx, code, message, node)
    linje = 0
    kolonne = 0

    hvis node != null
        hvis node.linje != null
            linje = node.linje
        slutt
        hvis node.kolonne != null
            kolonne = node.kolonne
        slutt
    slutt

    legg_til(ctx.errors, {
        code: code,
        message: message,
        line: linje,
        column: kolonne
    })
slutt

funksjon semantic_define(ctx, name, type_name, node)
    scope = semantic_current_scope(ctx)

    hvis scope.symbols[name] != null
        semantic_error(ctx, "duplicate_symbol", "Duplikat symbol: " + name, node)
        returner usann
    slutt

    scope.symbols[name] = {
        name: name,
        type: type_name,
        node: node
    }

    returner sann
slutt

funksjon semantic_lookup_scope(scope, name)
    hvis scope == null
        returner null
    slutt

    hvis scope.symbols[name] != null
        returner scope.symbols[name]
    slutt

    returner semantic_lookup_scope(scope.parent, name)
slutt

funksjon semantic_lookup(ctx, name)
    returner semantic_lookup_scope(semantic_current_scope(ctx), name)
slutt

funksjon semantic_infer_expr(ctx, node)
    hvis node == null
        returner "void"
    slutt

    hvis node.type == "LiteralExpr"
        returner "int"
    slutt

    hvis node.type == "VariableExpr"
        symbol = semantic_lookup(ctx, node.verdi)

        hvis symbol == null
            semantic_error(ctx, "undefined_variable", "Ukjent variabel: " + node.verdi, node)
            returner "unknown"
        slutt

        returner symbol.type
    slutt

    hvis node.type == "BinaryExpr"
        left_type = semantic_infer_expr(ctx, ast_hent_barn(node, 0))
        right_type = semantic_infer_expr(ctx, ast_hent_barn(node, 1))

        hvis left_type != right_type og left_type != "unknown" og right_type != "unknown"
            semantic_error(ctx, "type_mismatch", "Type mismatch: " + left_type + " mot " + right_type, node)
        slutt

        hvis node.operator == "<" eller node.operator == ">"
            returner "bool"
        slutt

        returner left_type
    slutt

    hvis node.type == "CallExpr"
        fn = ctx.functions[node.name]

        hvis fn == null
            semantic_error(ctx, "undefined_function", "Ukjent funksjon: " + node.name, node)
            returner "unknown"
        slutt

        expected = lengde(fn.params)
        actual = lengde(node.args)

        hvis expected != actual
            semantic_error(ctx, "argument_count", "Feil antall argumenter til " + node.name, node)
        slutt

        returner "unknown"
    slutt

    returner "unknown"
slutt

funksjon semantic_validate_node(ctx, node)
    hvis node == null
        returner
    slutt

    hvis node.type == "VarDecl"
        value_type = semantic_infer_expr(ctx, node.value)
        semantic_define(ctx, node.name, value_type, node)
        returner
    slutt

    hvis node.type == "Assignment"
        symbol = semantic_lookup(ctx, node.name)

        hvis symbol == null
            semantic_error(ctx, "undefined_variable", "Kan ikkje tilordne ukjent variabel: " + node.name, node)
            returner
        slutt

        value_type = semantic_infer_expr(ctx, node.value)

        hvis symbol.type != value_type og value_type != "unknown"
            semantic_error(ctx, "type_mismatch", "Kan ikkje tilordne " + value_type + " til " + symbol.type, node)
        slutt

        returner
    slutt

    hvis node.type == "FunctionDecl"
        hvis ctx.functions[node.name] != null
            semantic_error(ctx, "duplicate_function", "Duplikat funksjon: " + node.name, node)
        ellers
            ctx.functions[node.name] = node
        slutt

        semantic_push_scope(ctx)

        indeks = 0
        mens indeks < lengde(node.params)
            semantic_define(ctx, node.params[indeks], "unknown", node)
            indeks = indeks + 1
        slutt

        semantic_validate_block(ctx, node.body)
        semantic_pop_scope(ctx)
        returner
    slutt

    hvis node.type == "IfStmt"
        cond_type = semantic_infer_expr(ctx, node.condition)

        hvis cond_type != "bool" og cond_type != "unknown"
            semantic_error(ctx, "condition_type", "Hvis-betingelse må være bool", node)
        slutt

        semantic_push_scope(ctx)
        semantic_validate_block(ctx, node.then_branch)
        semantic_pop_scope(ctx)

        semantic_push_scope(ctx)
        semantic_validate_block(ctx, node.else_branch)
        semantic_pop_scope(ctx)
        returner
    slutt

    hvis node.type == "WhileStmt"
        cond_type = semantic_infer_expr(ctx, node.condition)

        hvis cond_type != "bool" og cond_type != "unknown"
            semantic_error(ctx, "condition_type", "Mens-betingelse må være bool", node)
        slutt

        semantic_push_scope(ctx)
        semantic_validate_block(ctx, node.body)
        semantic_pop_scope(ctx)
        returner
    slutt

    semantic_infer_expr(ctx, node)
slutt

funksjon semantic_validate_block(ctx, body)
    indeks = 0

    mens indeks < lengde(body)
        semantic_validate_node(ctx, body[indeks])
        indeks = indeks + 1
    slutt
slutt

funksjon semantic_validate_program(program)
    ctx = semantic_context()
    semantic_validate_block(ctx, program)
    returner ctx
slutt

funksjon semantic_has_errors(ctx)
    returner lengde(ctx.errors) > 0
slutt

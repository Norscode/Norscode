# SSA phi nodes, graph-coloring allocator and native self-bootstrap runtime

struktur PhiNode
    variabel
    incoming
slutt

struktur InterferenceGraph
    noder
    edges
slutt

struktur GraphColorAllocator
    colors
    allocations
slutt

struktur GarbageCollector
    heap
    marked
    swept
slutt

struktur RuntimeScheduler
    queue
    running
    completed
slutt

struktur SelfBootstrap
    compiler_binary
    rebuild_history
    successful_bootstraps
slutt

funksjon ny_phi_node(variabel)
    phi = PhiNode()

    phi.variabel = variabel
    phi.incoming = []

    returner phi
slutt

funksjon legg_til_phi_incoming(phi, block, value)
    hvis phi == null
        kast "Phi node mangler"
    slutt

    legg_til(phi.incoming, {
        block: block,
        value: value
    })

    returner sann
slutt

funksjon ny_interference_graph()
    graph = InterferenceGraph()

    graph.noder = []
    graph.edges = {}

    returner graph
slutt

funksjon add_interference(graph, left, right)
    hvis graph == null
        kast "Interference graph mangler"
    slutt

    hvis ikke har_nokkel(graph.edges, left)
        graph.edges[left] = []
    slutt

    legg_til(graph.edges[left], right)

    returner sann
slutt

funksjon ny_graph_color_allocator()
    allocator = GraphColorAllocator()

    allocator.colors = [
        "rax",
        "rbx",
        "rcx",
        "rdx"
    ]

    allocator.allocations = {}

    returner allocator
slutt

funksjon color_graph(allocator, interference_graph)
    hvis allocator == null
        kast "Allocator mangler"
    slutt

    hvis interference_graph == null
        kast "Interference graph mangler"
    slutt

    i = 0
    mens i < lengde(interference_graph.noder)
        node = interference_graph.noder[i]

        allocator.allocations[node] = allocator.colors[
            i % lengde(allocator.colors)
        ]

        i = i + 1
    slutt

    returner allocator.allocations
slutt

funksjon ny_garbage_collector()
    gc = GarbageCollector()

    gc.heap = []
    gc.marked = []
    gc.swept = []

    returner gc
slutt

funksjon gc_mark(gc, object)
    hvis gc == null
        kast "Garbage collector mangler"
    slutt

    legg_til(gc.marked, object)

    returner sann
slutt

funksjon gc_sweep(gc)
    hvis gc == null
        kast "Garbage collector mangler"
    slutt

    i = 0
    mens i < lengde(gc.heap)
        object = gc.heap[i]

        hvis ikke inneholder(gc.marked, object)
            legg_til(gc.swept, object)
        slutt

        i = i + 1
    slutt

    returner gc.swept
slutt

funksjon ny_runtime_scheduler()
    scheduler = RuntimeScheduler()

    scheduler.queue = []
    scheduler.running = []
    scheduler.completed = []

    returner scheduler
slutt

funksjon schedule_task(scheduler, task)
    hvis scheduler == null
        kast "Scheduler mangler"
    slutt

    legg_til(scheduler.queue, task)

    returner sann
slutt

funksjon execute_scheduler(scheduler)
    hvis scheduler == null
        kast "Scheduler mangler"
    slutt

    mens lengde(scheduler.queue) > 0
        task = scheduler.queue[0]

        legg_til(scheduler.running, task)
        legg_til(scheduler.completed, task)

        fjern_forste(scheduler.queue)
    slutt

    returner scheduler.completed
slutt

funksjon ny_self_bootstrap()
    bootstrap = SelfBootstrap()

    bootstrap.compiler_binary = null
    bootstrap.rebuild_history = []
    bootstrap.successful_bootstraps = 0

    returner bootstrap
slutt

funksjon execute_self_bootstrap(bootstrap, compiler_binary)
    hvis bootstrap == null
        kast "Self bootstrap mangler"
    slutt

    hvis compiler_binary == null
        kast "Compiler binary mangler"
    slutt

    result = execute_selfhost_binary(compiler_binary)

    legg_til(bootstrap.rebuild_history, result)

    hvis result.executed
        bootstrap.successful_bootstraps = bootstrap.successful_bootstraps + 1
    slutt

    bootstrap.compiler_binary = compiler_binary

    returner result
slutt

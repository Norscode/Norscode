// Norscode Selfhost Semantisk Analyse — Minimal
// Fase 3 — Semantikk
//
// Dette er eit minimalt semantisk pass som berre:
//   1. Samlar opp alle funksjonsdefinisjonar (namn → parameterliste)
//   2. Sjekkar at refererte funksjonar finst (utan type-sjekking)
//
// Full type-sjekking kjem seinare. For bootstrap-formål er det nok
// å vite kva som er brukardefinerte funksjonar vs. innebygde.

// ─── Innebygde funksjonar ────────────────────────────────────────────────────

funksjon er_builtin(namn)
    // Tekst-operasjonar
    hvis namn == "tekst_fra_heltall"    returner sann slutt
    hvis namn == "tekst_fra_bool"       returner sann slutt
    hvis namn == "heltall_fra_tekst"    returner sann slutt
    hvis namn == "tekst_starter_med"    returner sann slutt
    hvis namn == "tekst_slutter_med"    returner sann slutt
    hvis namn == "tekst_inneholder"     returner sann slutt
    hvis namn == "tekst_trim"           returner sann slutt
    hvis namn == "del_ord"              returner sann slutt
    // Liste/kart
    hvis namn == "lengde"               returner sann slutt
    hvis namn == "legg_til"             returner sann slutt
    hvis namn == "pop_siste"            returner sann slutt
    hvis namn == "fjern_indeks"         returner sann slutt
    hvis namn == "sett_inn"             returner sann slutt
    hvis namn == "har_nokkel"           returner sann slutt
    hvis namn == "finnes_nøkkel"        returner sann slutt
    hvis namn == "nøkler"               returner sann slutt
    hvis namn == "fjern_nokkel"         returner sann slutt
    // IO
    hvis namn == "skriv"                returner sann slutt
    hvis namn == "les_input"            returner sann slutt
    hvis namn == "fil_les"              returner sann slutt
    hvis namn == "fil_skriv"            returner sann slutt
    hvis namn == "fil_skriv_binær"      returner sann slutt
    hvis namn == "fil_append"           returner sann slutt
    hvis navn == "fil_finnes"           returner sann slutt
    // Konvertering
    hvis namn == "til_tekst"            returner sann slutt
    // Feil
    hvis namn == "feil"                 returner sann slutt
    returner usann
slutt

// ─── Symbol-register ─────────────────────────────────────────────────────────

funksjon ny_symbol_tabell()
    tabell = {}
    tabell["funksjonar"] = {}
    tabell["feil"] = []
    returner tabell
slutt

funksjon registrer_funksjon(tabell, namn, params)
    tabell["funksjonar"][namn] = params
slutt

funksjon funksjon_finst(tabell, namn)
    returner har_nokkel(tabell["funksjonar"], namn)
slutt

funksjon legg_til_feil(tabell, melding)
    legg_til(tabell["feil"], melding)
slutt

// ─── Analyse-pass ────────────────────────────────────────────────────────────

funksjon samle_funksjonar(tabell, program_node)
    // Første pass: registrer alle funksjonsnamnsom
    i = 0
    mens i < lengde(program_node.barn)
        node = program_node.barn[i]
        hvis node.type == "Funksjon"
            // Samle parameter-namn
            params = []
            param_node = node.barn[0]
            j = 0
            mens j < lengde(param_node.barn)
                legg_til(params, param_node.barn[j].verdi)
                j = j + 1
            slutt
            registrer_funksjon(tabell, node.verdi, params)
        slutt
        i = i + 1
    slutt
slutt

funksjon sjekk_kall_i_uttrykk(tabell, node)
    t = node.type

    hvis t == "Kall"
        fn_nam = node.barn[0].verdi
        hvis ikkje funksjon_finst(tabell, fn_nam) og ikkje er_builtin(fn_nam)
            // Kan vere ein ekstern funksjon — ikkje ein hard feil i bootstrap
            // legg_til_feil(tabell, "Ukjent funksjon: " + fn_nam)
        slutt
        // Sjekk argument-uttrykk
        argumenter = node.barn[1]
        k = 0
        mens k < lengde(argumenter.barn)
            sjekk_kall_i_uttrykk(tabell, argumenter.barn[k])
            k = k + 1
        slutt
        returner sann
    slutt

    i = 0
    mens i < lengde(node.barn)
        sjekk_kall_i_uttrykk(tabell, node.barn[i])
        i = i + 1
    slutt
    returner sann
slutt

funksjon analyser_program(program_node)
    tabell = ny_symbol_tabell()

    // Pass 1: registrer funksjonar
    samle_funksjonar(tabell, program_node)

    // Pass 2: sjekk kall (mjuk — rapporterer ikkje feil for bootstrap)
    i = 0
    mens i < lengde(program_node.barn)
        node = program_node.barn[i]
        hvis node.type == "Funksjon"
            sjekk_kall_i_uttrykk(tabell, node)
        slutt
        i = i + 1
    slutt

    returner tabell
slutt

// ─── Offentleg API ───────────────────────────────────────────────────────────

funksjon hent_funksjon_param(tabell, namn)
    hvis har_nokkel(tabell["funksjonar"], namn)
        returner tabell["funksjonar"][namn]
    slutt
    returner []
slutt

funksjon start()
    returner "semantic_ready"
slutt

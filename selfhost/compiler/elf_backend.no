# ELF writer, relocation engine, opcode encoder and native launcher

struktur ELFSeksjon
    navn
    data
    adresse
    offset
slutt

struktur Symbol
    navn
    adresse
    seksjon
slutt

struktur Relocation
    symbol
    offset
    type
slutt

struktur ELFWriter
    seksjoner
    symboler
    relocations
    entry_symbol
slutt

struktur SyscallBridge
    target
    syscalls
slutt

funksjon ny_elf_writer()
    writer = ELFWriter()

    writer.seksjoner = []
    writer.symboler = []
    writer.relocations = []
    writer.entry_symbol = "_start"

    returner writer
slutt

funksjon ny_seksjon(navn)
    seksjon = ELFSeksjon()

    seksjon.navn = navn
    seksjon.data = []
    seksjon.adresse = 0
    seksjon.offset = 0

    returner seksjon
slutt

funksjon legg_til_seksjon(writer, seksjon)
    hvis writer == null eller seksjon == null
        kast "ELF seksjon mangler"
    slutt

    legg_til(writer.seksjoner, seksjon)

    returner seksjon
slutt

funksjon legg_til_symbol(writer, navn, adresse, seksjon)
    hvis writer == null
        kast "ELF writer mangler"
    slutt

    symbol = Symbol()
    symbol.navn = navn
    symbol.adresse = adresse
    symbol.seksjon = seksjon

    legg_til(writer.symboler, symbol)

    returner symbol
slutt

funksjon legg_til_relocation(writer, symbol, offset, type)
    hvis writer == null
        kast "ELF writer mangler"
    slutt

    relocation = Relocation()
    relocation.symbol = symbol
    relocation.offset = offset
    relocation.type = type

    legg_til(writer.relocations, relocation)

    returner relocation
slutt

funksjon encode_u64(value)
    returner [
        value & 255,
        (value >> 8) & 255,
        (value >> 16) & 255,
        (value >> 24) & 255,
        (value >> 32) & 255,
        (value >> 40) & 255,
        (value >> 48) & 255,
        (value >> 56) & 255
    ]
slutt

funksjon encode_mov_rax_imm64(value)
    bytes = [0x48, 0xB8]
    imm = encode_u64(value)

    i = 0
    mens i < lengde(imm)
        legg_til(bytes, imm[i])
        i = i + 1
    slutt

    returner bytes
slutt

funksjon encode_syscall()
    returner [0x0F, 0x05]
slutt

funksjon encode_ret()
    returner [0xC3]
slutt

funksjon encode_nop()
    returner [0x90]
slutt

funksjon opcode_encode(instruksjon)
    hvis instruksjon == null
        kast "Instruksjon mangler"
    slutt

    hvis instruksjon.opcode == "nop"
        returner encode_nop()
    slutt

    hvis instruksjon.opcode == "ret"
        returner encode_ret()
    slutt

    hvis instruksjon.opcode == "syscall"
        returner encode_syscall()
    slutt

    hvis instruksjon.opcode == "mov_rax_imm64"
        returner encode_mov_rax_imm64(instruksjon.value)
    slutt

    returner encode_nop()
slutt

funksjon bygg_symboltabell(writer)
    hvis writer == null
        kast "ELF writer mangler"
    slutt

    returner writer.symboler
slutt

funksjon apply_relocations(writer)
    hvis writer == null
        kast "ELF writer mangler"
    slutt

    i = 0
    mens i < lengde(writer.relocations)
        relocation = writer.relocations[i]
        hvis relocation.symbol == null
            kast "Relocation symbol mangler"
        slutt
        i = i + 1
    slutt

    returner sann
slutt

funksjon write_elf64(writer, machine_code)
    hvis writer == null
        kast "ELF writer mangler"
    slutt

    hvis machine_code == null
        machine_code = []
    slutt

    text = ny_seksjon(".text")
    text.data = machine_code
    text.adresse = 0x400000
    text.offset = 0x1000

    legg_til_seksjon(writer, text)
    legg_til_symbol(writer, writer.entry_symbol, text.adresse, text)

    apply_relocations(writer)

    returner {
        format: "ELF64",
        arch: "x86_64",
        entry: writer.entry_symbol,
        sections: writer.seksjoner,
        symbols: bygg_symboltabell(writer),
        relocations: writer.relocations,
        bytes: machine_code
    }
slutt

funksjon ny_syscall_bridge()
    bridge = SyscallBridge()

    bridge.target = "linux_x86_64"
    bridge.syscalls = {}
    bridge.syscalls["exit"] = 60
    bridge.syscalls["write"] = 1
    bridge.syscalls["read"] = 0

    returner bridge
slutt

funksjon syscall_number(bridge, navn)
    hvis bridge == null
        kast "Syscall bridge mangler"
    slutt

    hvis har_nokkel(bridge.syscalls, navn)
        returner bridge.syscalls[navn]
    slutt

    kast "Ukjent syscall"
slutt

funksjon native_binary_launcher(executable)
    hvis executable == null
        kast "Executable mangler"
    slutt

    returner {
        launched: sann,
        format: executable.format,
        entry: executable.entry
    }
slutt

funksjon bygg_native_executable(machine_ir)
    writer = ny_elf_writer()
    code = []

    hvis machine_ir != null
        i = 0
        mens i < lengde(machine_ir.instrukser)
            encoded = opcode_encode(machine_ir.instrukser[i])
            j = 0
            mens j < lengde(encoded)
                legg_til(code, encoded[j])
                j = j + 1
            slutt
            i = i + 1
        slutt
    slutt

    hvis lengde(code) == 0
        code = encode_ret()
    slutt

    returner write_elf64(writer, code)
slutt

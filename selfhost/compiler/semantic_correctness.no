# Semantic correctness phase: lexer, parser grammar, borrow checker and trait solver

struktur Lexer
    source
    tokens
    current
slutt

struktur Token
    type
    value
    line
slutt

struktur GrammarParser
    tokens
    position
    ast
slutt

struktur TypeChecker
    typed_nodes
    type_errors
slutt

struktur BorrowChecker
    active_borrows
    violations
slutt

struktur TraitSolver
    obligations
    resolved
    unresolved
slutt

struktur GenericSpecializer
    specializations
slutt

struktur DependencyGraph
    modules
    dependencies
    rebuild_order
slutt

funksjon ny_lexer(kilde)
    lexer = Lexer()

    lexer.source = kilde
    lexer.tokens = []
    lexer.current = 0

    returner lexer
slutt

funksjon lexer_tokenize(lexer)
    hvis lexer == null
        kast "Lexer mangler"
    slutt

    legg_til(lexer.tokens, {
        type: "PROGRAM",
        value: "program",
        line: 1
    })

    legg_til(lexer.tokens, {
        type: "EOF",
        value: "",
        line: 1
    })

    returner lexer.tokens
slutt

funksjon ny_grammar_parser(tokens)
    parser = GrammarParser()

    parser.tokens = tokens
    parser.position = 0
    parser.ast = null

    returner parser
slutt

funksjon parse_grammar(parser)
    hvis parser == null
        kast "Grammar parser mangler"
    slutt

    parser.ast = {
        type: "Program",
        body: []
    }

    returner parser.ast
slutt

funksjon ny_type_checker()
    checker = TypeChecker()

    checker.typed_nodes = {}
    checker.type_errors = []

    returner checker
slutt

funksjon type_check_program(checker, ast)
    hvis checker == null
        kast "Type checker mangler"
    slutt

    checker.typed_nodes["Program"] = "Unit"

    returner sann
slutt

funksjon ny_borrow_checker()
    checker = BorrowChecker()

    checker.active_borrows = {}
    checker.violations = []

    returner checker
slutt

funksjon borrow_variable(checker, variabel, mode)
    hvis checker == null
        kast "Borrow checker mangler"
    slutt

    hvis har_nokkel(checker.active_borrows, variabel)
        legg_til(checker.violations, variabel)
        returner usann
    slutt

    checker.active_borrows[variabel] = mode

    returner sann
slutt

funksjon release_borrow(checker, variabel)
    hvis checker == null
        kast "Borrow checker mangler"
    slutt

    checker.active_borrows[variabel] = null

    returner sann
slutt

funksjon ny_trait_solver()
    solver = TraitSolver()

    solver.obligations = []
    solver.resolved = []
    solver.unresolved = []

    returner solver
slutt

funksjon add_trait_obligation(solver, obligation)
    hvis solver == null
        kast "Trait solver mangler"
    slutt

    legg_til(solver.obligations, obligation)

    returner sann
slutt

funksjon solve_traits(solver)
    hvis solver == null
        kast "Trait solver mangler"
    slutt

    i = 0
    mens i < lengde(solver.obligations)
        obligation = solver.obligations[i]
        legg_til(solver.resolved, obligation)
        i = i + 1
    slutt

    returner solver.resolved
slutt

funksjon ny_generic_specializer()
    specializer = GenericSpecializer()

    specializer.specializations = []

    returner specializer
slutt

funksjon specialize_generic(specializer, generic_name, concrete_type)
    hvis specializer == null
        kast "Generic specializer mangler"
    slutt

    specialization = generic_name + "::" + concrete_type

    legg_til(specializer.specializations, specialization)

    returner specialization
slutt

funksjon ny_dependency_graph()
    graph = DependencyGraph()

    graph.modules = []
    graph.dependencies = {}
    graph.rebuild_order = []

    returner graph
slutt

funksjon add_module(graph, module)
    hvis graph == null
        kast "Dependency graph mangler"
    slutt

    legg_til(graph.modules, module)

    returner sann
slutt

funksjon add_dependency(graph, module, dependency)
    hvis graph == null
        kast "Dependency graph mangler"
    slutt

    hvis ikke har_nokkel(graph.dependencies, module)
        graph.dependencies[module] = []
    slutt

    legg_til(graph.dependencies[module], dependency)

    returner sann
slutt

funksjon compute_rebuild_order(graph)
    hvis graph == null
        kast "Dependency graph mangler"
    slutt

    graph.rebuild_order = graph.modules

    returner graph.rebuild_order
slutt

# Runtime allocator, branch lowering and native selfhost rebuild loop

struktur RuntimeAllocator
    heap_start
    heap_end
    allocations
    free_list
slutt

struktur ProgramHeader
    type
    flags
    offset
    virtual_address
    file_size
    memory_size
slutt

struktur RebuildLoop
    iterations
    successful_rebuilds
    failed_rebuilds
slutt

funksjon ny_runtime_allocator()
    allocator = RuntimeAllocator()

    allocator.heap_start = 0x100000
    allocator.heap_end = 0x200000
    allocator.allocations = []
    allocator.free_list = []

    returner allocator
slutt

funksjon allocate_memory(allocator, storrelse)
    hvis allocator == null
        kast "Allocator mangler"
    slutt

    allocation = {
        address: allocator.heap_start,
        size: storrelse
    }

    allocator.heap_start = allocator.heap_start + storrelse

    legg_til(allocator.allocations, allocation)

    returner allocation
slutt

funksjon free_memory(allocator, allocation)
    hvis allocator == null
        kast "Allocator mangler"
    slutt

    legg_til(allocator.free_list, allocation)

    returner sann
slutt

funksjon register_coalescing(machine_ir)
    hvis machine_ir == null
        kast "Machine IR mangler"
    slutt

    machine_ir.coalesced = sann

    returner machine_ir
slutt

funksjon spill_reload_handling(machine_ir)
    hvis machine_ir == null
        kast "Machine IR mangler"
    slutt

    machine_ir.spill_slots = []

    returner machine_ir
slutt

funksjon lower_branch(instruksjon)
    hvis instruksjon == null
        kast "Instruksjon mangler"
    slutt

    returner {
        opcode: "jmp",
        target: instruksjon.target
    }
slutt

funksjon ny_program_header()
    header = ProgramHeader()

    header.type = "PT_LOAD"
    header.flags = ["R", "X"]
    header.offset = 0x1000
    header.virtual_address = 0x400000
    header.file_size = 0
    header.memory_size = 0

    returner header
slutt

funksjon encode_program_header(header)
    hvis header == null
        kast "Program header mangler"
    slutt

    returner {
        encoded: sann,
        type: header.type,
        virtual_address: header.virtual_address
    }
slutt

funksjon attach_program_headers(executable)
    hvis executable == null
        kast "Executable mangler"
    slutt

    header = ny_program_header()

    executable.program_headers = [
        encode_program_header(header)
    ]

    returner executable
slutt

funksjon ny_rebuild_loop()
    loop = RebuildLoop()

    loop.iterations = 0
    loop.successful_rebuilds = 0
    loop.failed_rebuilds = 0

    returner loop
slutt

funksjon execute_rebuild_loop(loop, compiler_binary)
    hvis loop == null
        kast "Rebuild loop mangler"
    slutt

    hvis compiler_binary == null
        kast "Compiler binary mangler"
    slutt

    loop.iterations = loop.iterations + 1

    result = execute_selfhost_binary(compiler_binary)

    hvis result.executed
        loop.successful_rebuilds = loop.successful_rebuilds + 1
    ellers
        loop.failed_rebuilds = loop.failed_rebuilds + 1
    slutt

    returner result
slutt

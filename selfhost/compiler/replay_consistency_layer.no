# Replay consistency and synchronization verifier

struktur ReplayConsistencyLayer
    consistency_cycles
    max_consistency_cycles
    replay_states
    synchronization_states
    consistency_failures
slutt

funksjon ny_replay_consistency_layer()
    layer = ReplayConsistencyLayer()

    layer.consistency_cycles = 0
    layer.max_consistency_cycles = 1000000
    layer.replay_states = []
    layer.synchronization_states = []
    layer.consistency_failures = 0

    returner layer
slutt

funksjon validate_replay_consistency(layer)
    hvis layer == null
        kast "Replay consistency layer mangler"
    slutt

    hvis layer.consistency_cycles < 0
        kast "Invalid consistency cycles"
    slutt

    hvis layer.max_consistency_cycles <= 0
        kast "Invalid consistency limit"
    slutt

    hvis layer.consistency_failures < 0
        kast "Invalid consistency failure count"
    slutt

    hvis layer.consistency_cycles >= layer.max_consistency_cycles
        kast "Replay consistency limit exceeded"
    slutt

    returner sann
slutt

funksjon replay_consistency_enter(layer)
    validate_replay_consistency(layer)

    layer.consistency_cycles = layer.consistency_cycles + 1

    validate_replay_consistency(layer)

    returner sann
slutt

funksjon replay_state_snapshot(layer, snapshot)
    validate_replay_consistency(layer)

    hvis snapshot == null
        snapshot = "<null_replay_state>"
    slutt

    legg_til(layer.replay_states, snapshot)

    returner snapshot
slutt

funksjon synchronization_state_snapshot(layer, snapshot)
    validate_replay_consistency(layer)

    hvis snapshot == null
        snapshot = "<null_sync_state>"
    slutt

    legg_til(layer.synchronization_states, snapshot)

    returner snapshot
slutt

funksjon compare_replay_consistency(left, right)
    hvis left == null og right == null
        returner sann
    slutt

    hvis left == null eller right == null
        returner usann
    slutt

    returner left == right
slutt

funksjon validate_replay_state(layer, expected, actual)
    validate_replay_consistency(layer)

    hvis compare_replay_consistency(expected, actual)
        returner sann
    slutt

    layer.consistency_failures = layer.consistency_failures + 1

    kast "Replay consistency mismatch"
slutt

funksjon deterministic_replay_signature(replay_snapshot, synchronization_snapshot)
    hvis replay_snapshot == null
        replay_snapshot = "<null_replay>"
    slutt

    hvis synchronization_snapshot == null
        synchronization_snapshot = "<null_sync>"
    slutt

    returner replay_snapshot + "::" + synchronization_snapshot
slutt

funksjon recursive_replay_guard(layer)
    validate_replay_consistency(layer)

    hvis layer.consistency_failures > 10000
        kast "Recursive replay consistency divergence detected"
    slutt

    returner sann
slutt

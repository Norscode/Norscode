# Real IR node system, SSA lowering and CFG foundation

struktur IRNode
    id
    type
    inputs
    outputs
    metadata
slutt

struktur BasicBlock
    navn
    instrukser
    successors
    predecessors
slutt

struktur ControlFlowGraph
    entry
    blocks
slutt

funksjon ny_ir_node(id, type)
    node = IRNode()

    node.id = id
    node.type = type
    node.inputs = []
    node.outputs = []
    node.metadata = {}

    returner node
slutt

funksjon ny_basic_block(navn)
    block = BasicBlock()

    block.navn = navn
    block.instrukser = []
    block.successors = []
    block.predecessors = []

    returner block
slutt

funksjon ny_cfg()
    cfg = ControlFlowGraph()

    cfg.entry = null
    cfg.blocks = []

    returner cfg
slutt

funksjon legg_til_instruksjon(block, instruksjon)
    hvis block == null
        kast "Block mangler"
    slutt

    legg_til(block.instrukser, instruksjon)

    returner sann
slutt

funksjon koble_blocks(fra, til)
    legg_til(fra.successors, til)
    legg_til(til.predecessors, fra)

    returner sann
slutt

funksjon lower_til_ssa(ast)
    hvis ast == null
        kast "AST mangler"
    slutt

    returner {
        type: "SSAProgram",
        source: ast
    }
slutt

funksjon bygg_cfg(ssa_program)
    hvis ssa_program == null
        kast "SSA program mangler"
    slutt

    cfg = ny_cfg()

    entry = ny_basic_block("entry")

    cfg.entry = entry

    legg_til(cfg.blocks, entry)

    returner cfg
slutt

funksjon optimizer_constant_folding(ir)
    hvis ir == null
        kast "IR mangler"
    slutt

    ir.constant_folded = sann

    returner ir
slutt

funksjon optimizer_dead_code(ir)
    hvis ir == null
        kast "IR mangler"
    slutt

    ir.dead_code_removed = sann

    returner ir
slutt

funksjon generate_x86_64(cfg)
    hvis cfg == null
        kast "CFG mangler"
    slutt

    returner {
        backend: "x86_64",
        cfg: cfg,
        binary: []
    }
slutt

bruk selfhost.lexer.lexer_m1

funksjon start()
    kjelde2 = fil_les("selfhost/compiler/semantic.no")
    tokens2 = lex(kjelde2)
    skriv("semantic.no tokens: " + tekst_fra_heltall(lengde(tokens2)) + "\n")
    t0 = tokens2[0]
    skriv("  tok0 type=" + t0.type + "\n")
    t1 = tokens2[1]
    skriv("  tok1 type=" + t1.type + "\n")
    t2 = tokens2[2]
    skriv("  tok2 type=" + t2.type + "\n")
    returner "done"
slutt

# Norscode-native lexer M1
#
# Mål: produsere token-stream kompatibel med TOKEN_FORMAT_V1.
# Dette er fortsatt selfhost-arbeid under utvikling, men inneholder nå
# grunnleggende scanning for identifiers, keywords, tall, tekst, operatorer,
# punctuation, kommentarer, whitespace og EOF.

funksjon er_bokstav(tegn: tekst) -> bool {
    # Numeriske ASCII-område er deterministiske i både native og pure VM.
    la kode = builtin.char_code(tegn)
    returner (kode >= 97 og kode <= 122) eller (kode >= 65 og kode <= 90) eller kode == 95 eller (kode >= 128 og kode <= 255)
}

funksjon er_tall(tegn: tekst) -> bool {
    la kode = builtin.char_code(tegn)
    returner kode >= 48 og kode <= 57
}

funksjon er_ident_tegn(tegn: tekst) -> bool {
    returner er_bokstav(tegn) eller er_tall(tegn)
}

funksjon er_whitespace(tegn: tekst) -> bool {
    returner tegn == " " eller tegn == "\n" eller tegn == "\t" eller tegn == "\r"
}

funksjon lexer_keyword_type_for(verdi: tekst) -> tekst {
    hvis (verdi == "funksjon") { returner "FUNKSJON" }
    hvis (verdi == "fun") { returner "FUN" }
    hvis (verdi == "async") { returner "ASYNC" }
    hvis (verdi == "await") { returner "AWAIT" }
    hvis (verdi == "bruk") { returner "BRUK" }
    hvis (verdi == "importer") { returner "BRUK" }
    hvis (verdi == "som") { returner "SOM" }
    hvis (verdi == "la") { returner "LA" }
    hvis (verdi == "skriv") { returner "SKRIV" }
    hvis (verdi == "returner") { returner "RETURNER" }
    hvis (verdi == "hvis") { returner "HVIS" }
    hvis (verdi == "da") { returner "DA" }
    hvis (verdi == "ellers") { returner "ELLERS" }
    hvis (verdi == "match") { returner "MATCH" }
    hvis (verdi == "case") { returner "CASE" }
    hvis (verdi == "mens") { returner "MENS" }
    hvis (verdi == "for") { returner "FOR" }
    hvis (verdi == "til") { returner "TIL" }
    hvis (verdi == "steg") { returner "STEG" }
    hvis (verdi == "i") { returner "I" }
    hvis (verdi == "bryt") { returner "BRYT" }
    hvis (verdi == "fortsett") { returner "FORTSETT" }
    hvis (verdi == "kast") { returner "KAST" }
    hvis (verdi == "prøv") { returner "PROV" }
    hvis (verdi == "fang") { returner "FANG" }
    hvis (verdi == "endeleg") { returner "ENDELEG" }
    hvis (verdi == "finally") { returner "ENDELEG" }
    hvis (verdi == "utsett") { returner "UTSETT" }
    hvis (verdi == "defer") { returner "UTSETT" }
    hvis (verdi == "heltall") { returner "TYPE_INT" }
    hvis (verdi == "bool") { returner "TYPE_BOOL" }
    hvis (verdi == "tekst") { returner "TYPE_TEXT" }
    hvis (verdi == "liste_heltall") { returner "TYPE_LIST_INT" }
    hvis (verdi == "liste_tekst") { returner "TYPE_LIST_TEXT" }
    hvis (verdi == "ordbok_heltall") { returner "TYPE_MAP_INT" }
    hvis (verdi == "ordbok_tekst") { returner "TYPE_MAP_TEXT" }
    hvis (verdi == "ordbok_bool") { returner "TYPE_MAP_BOOL" }
    hvis (verdi == "sann") { returner "SANN" }
    hvis (verdi == "sant") { returner "SANN" }
    hvis (verdi == "usann") { returner "USANN" }
    hvis (verdi == "usant") { returner "USANN" }
    hvis (verdi == "og") { returner "OG" }
    hvis (verdi == "eller") { returner "ELLER" }
    hvis (verdi == "ikke") { returner "IKKE" }
    hvis (verdi == "assert") { returner "ASSERT" }
    // assert_eq og assert_ne er identifiserare, ikkje nøkkelord
    hvis (verdi == "test") { returner "TEST" }
    hvis (verdi == "slutt") { returner "SLUTT" }
    hvis (verdi == "struktur") { returner "STRUKTUR" }
    hvis (verdi == "ikkje") { returner "IKKE" }
    returner "IDENT"
}

funksjon er_keyword(verdi: tekst) -> bool {
    returner lexer_keyword_type_for(verdi) != "IDENT"
}

funksjon token_type_for_ident(verdi: tekst) -> tekst {
    returner lexer_keyword_type_for(verdi)
}

funksjon er_operator_start(tegn: tekst) -> bool {
    returner tegn == "+" eller tegn == "-" eller tegn == "*" eller tegn == "/" eller tegn == "=" eller tegn == "!" eller tegn == "<" eller tegn == ">" eller tegn == "." eller tegn == "%" eller tegn == "&" eller tegn == "|" eller tegn == "^" eller tegn == "~"
}

funksjon operator_type_for(op: tekst) -> tekst {
    hvis (op == "==") { returner "EQ" }
    hvis (op == "!=") { returner "NE" }
    hvis (op == ">=") { returner "GTE" }
    hvis (op == "<=") { returner "LTE" }
    hvis (op == ">>") { returner "RSHIFT" }
    hvis (op == "<<") { returner "LSHIFT" }
    hvis (op == "->") { returner "ARROW" }
    hvis (op == "+=") { returner "PLUS_ASSIGN" }
    hvis (op == "-=") { returner "MINUS_ASSIGN" }
    hvis (op == "*=") { returner "STAR_ASSIGN" }
    hvis (op == "/=") { returner "SLASH_ASSIGN" }
    hvis (op == "%=") { returner "PERCENT_ASSIGN" }
    hvis (op == "+") { returner "PLUS" }
    hvis (op == "-") { returner "MINUS" }
    hvis (op == "*") { returner "MUL" }
    hvis (op == "/") { returner "DIV" }
    hvis (op == "%") { returner "PERCENT" }
    hvis (op == "=") { returner "ASSIGN" }
    hvis (op == ">") { returner "GT" }
    hvis (op == "<") { returner "LT" }
    hvis (op == ".") { returner "DOT" }
    hvis (op == "&") { returner "BAND" }
    hvis (op == "|") { returner "BOR" }
    hvis (op == "^") { returner "BXOR" }
    hvis (op == "~") { returner "BNOT" }
    returner "OP"
}

funksjon er_punctuation(tegn: tekst) -> bool {
    returner tegn == "(" eller tegn == ")" eller tegn == "{" eller tegn == "}" eller tegn == "[" eller tegn == "]" eller tegn == "," eller tegn == ":"
}

funksjon punctuation_type(tegn: tekst) -> tekst {
    hvis (tegn == "(") {
        returner "LPAREN"
    }
    hvis (tegn == ")") {
        returner "RPAREN"
    }
    hvis (tegn == "{") {
        returner "LBRACE"
    }
    hvis (tegn == "}") {
        returner "RBRACE"
    }
    hvis (tegn == "[") {
        returner "LBRACKET"
    }
    hvis (tegn == "]") {
        returner "RBRACKET"
    }
    hvis (tegn == ",") {
        returner "COMMA"
    }
    hvis (tegn == ":") {
        returner "COLON"
    }
    returner "PUNCT"
}

funksjon deltekst(kilde: tekst, start: heltall, endpos: heltall) -> tekst {
    la ut = ""
    la indeks = start
    mens (indeks < endpos) {
        ut = ut + kilde[indeks]
        indeks = indeks + 1
    }
    returner ut
}

funksjon lag_token(type: tekst, verdi: tekst, linje: heltall, kolonne: heltall) -> ordbok<tekst, tekst> {
    returner {
        "type": type,
        "value": verdi,
        "line": linje,
        "column": kolonne
    }
}

funksjon les_ident(kilde: tekst, start: heltall) -> tekst {
    la endpos = start
    mens (endpos < lengde(kilde) og er_ident_tegn(kilde[endpos])) {
        endpos = endpos + 1
    }
    returner deltekst(kilde, start, endpos)
}

funksjon er_hex_tegn(tegn: tekst) -> bool {
    returner er_tall(tegn) eller
        tegn == "a" eller tegn == "b" eller tegn == "c" eller
        tegn == "d" eller tegn == "e" eller tegn == "f" eller
        tegn == "A" eller tegn == "B" eller tegn == "C" eller
        tegn == "D" eller tegn == "E" eller tegn == "F"
}

funksjon hex_verdi(tegn: tekst) -> heltall {
    hvis tegn == "0" { returner 0 }
    hvis tegn == "1" { returner 1 }
    hvis tegn == "2" { returner 2 }
    hvis tegn == "3" { returner 3 }
    hvis tegn == "4" { returner 4 }
    hvis tegn == "5" { returner 5 }
    hvis tegn == "6" { returner 6 }
    hvis tegn == "7" { returner 7 }
    hvis tegn == "8" { returner 8 }
    hvis tegn == "9" { returner 9 }
    hvis tegn == "a" eller tegn == "A" { returner 10 }
    hvis tegn == "b" eller tegn == "B" { returner 11 }
    hvis tegn == "c" eller tegn == "C" { returner 12 }
    hvis tegn == "d" eller tegn == "D" { returner 13 }
    hvis tegn == "e" eller tegn == "E" { returner 14 }
    returner 15
}

funksjon hex_tekst_til_heltall(s: tekst) -> heltall {
    la resultat: heltall = 0
    la i: heltall = 0
    mens i < lengde(s) {
        resultat = resultat * 16 + hex_verdi(s[i])
        i = i + 1
    }
    returner resultat
}

funksjon les_tall(kilde: tekst, start: heltall) -> tekst {
    // Støtt hex-literal: 0x... / 0X...
    hvis start + 1 < lengde(kilde) og builtin.char_code(kilde[start]) == 48 og
        (kilde[start + 1] == "x" eller kilde[start + 1] == "X") {
        la endpos = start + 2
        mens (endpos < lengde(kilde) og er_hex_tegn(kilde[endpos])) {
            endpos = endpos + 1
        }
        // Returner original kjeldestrengen (t.d. "0x7F") — leksaren
        // avanserer korrekt, og kompilatoren brukar strtoll(s, NULL, 0).
        returner deltekst(kilde, start, endpos)
    }
    la endpos = start
    mens (endpos < lengde(kilde) og er_tall(kilde[endpos])) {
        endpos = endpos + 1
    }
    hvis endpos + 1 < lengde(kilde) og kilde[endpos] == "." og er_tall(kilde[endpos + 1]) {
        endpos = endpos + 1
        mens endpos < lengde(kilde) og er_tall(kilde[endpos]) { endpos = endpos + 1 }
    }
    hvis endpos < lengde(kilde) og (kilde[endpos] == "e" eller kilde[endpos] == "E") {
        la exponent_start = endpos
        endpos = endpos + 1
        hvis endpos < lengde(kilde) og (kilde[endpos] == "+" eller kilde[endpos] == "-") { endpos = endpos + 1 }
        la digit_start = endpos
        mens endpos < lengde(kilde) og er_tall(kilde[endpos]) { endpos = endpos + 1 }
        hvis digit_start == endpos { endpos = exponent_start }
    }
    returner deltekst(kilde, start, endpos)
}

funksjon les_tekst(kilde: tekst, start: heltall, avgrensar: tekst, start_linje: heltall, start_kolonne: heltall) -> tekst {
    la endpos = start + 1
    mens (endpos < lengde(kilde) og kilde[endpos] != avgrensar) {
        hvis (kilde[endpos] == "\\" og endpos + 1 < lengde(kilde)) {
            endpos = endpos + 2
        } ellers {
            endpos = endpos + 1
        }
    }
    hvis (endpos >= lengde(kilde)) {
        kast "Tekststreng ble ikkje avslutta ved linje " + tekst_fra_heltall(start_linje) + ", kolonne " + tekst_fra_heltall(start_kolonne)
    }
    returner deltekst(kilde, start + 1, endpos)
}

funksjon unescape_tegn(neste: tekst) -> tekst {
    hvis (neste == "\"") { returner "\"" }
    hvis (neste == "'") { returner "'" }
    hvis (neste == "\\") { returner "\\" }
    hvis (neste == "n") { returner "\n" }
    hvis (neste == "t") { returner "\t" }
    hvis (neste == "r") { returner builtin.chr(13) }
    hvis (neste == "0") { returner builtin.chr(0) }
    returner neste
}

funksjon unescape_tekst(raw: tekst) -> tekst {
    la ut = ""
    la indeks = 0
    mens (indeks < lengde(raw)) {
        hvis (raw[indeks] == "\\" og indeks + 1 < lengde(raw)) {
            ut = ut + unescape_tegn(raw[indeks + 1])
            indeks = indeks + 2
        } ellers {
            ut = ut + raw[indeks]
            indeks = indeks + 1
        }
    }
    returner ut
}

funksjon les_operator(kilde: tekst, start: heltall) -> tekst {
    hvis (start + 1 < lengde(kilde)) {
        la to = deltekst(kilde, start, start + 2)
        hvis (to == "==" eller to == "!=" eller to == "<=" eller to == ">=" eller to == "->" eller to == "+=" eller to == "-=" eller to == "*=" eller to == "/=" eller to == "%=" eller to == "<<" eller to == ">>") {
            returner to
        }
    }
    returner deltekst(kilde, start, start + 1)
}

funksjon hopp_kommentar(kilde: tekst, start: heltall) -> heltall {
    la indeks = start
    mens (indeks < lengde(kilde) og kilde[indeks] != "\n") {
        indeks = indeks + 1
    }
    returner indeks
}

funksjon lex(kilde: tekst) -> liste<ordbok<tekst, tekst>> {
    la tokens: liste<ordbok<tekst, tekst>> = []
    la indeks = 0
    la linje = 1
    la kolonne = 1

    mens (indeks < lengde(kilde)) {
        la tegn = kilde[indeks]

        # Semikolon er ein valfri setningsseparator, på same måte som whitespace.
        hvis (tegn == ";") {
            indeks = indeks + 1
            kolonne = kolonne + 1
            fortsett
        }

        hvis (er_whitespace(tegn)) {
            hvis (tegn == "\n") {
                linje = linje + 1
                kolonne = 1
            } ellers {
                kolonne = kolonne + 1
            }
            indeks = indeks + 1
            fortsett
        }

        hvis (tegn == "#") {
            la ny_indeks = hopp_kommentar(kilde, indeks)
            kolonne = kolonne + (ny_indeks - indeks)
            indeks = ny_indeks
            fortsett
        }

        # C-stil einlinje-kommentar: // ...
        hvis (tegn == "/" og indeks + 1 < lengde(kilde) og kilde[indeks + 1] == "/") {
            la ny_indeks = hopp_kommentar(kilde, indeks)
            indeks = ny_indeks
            fortsett
        }

        hvis (er_bokstav(tegn)) {
            la ident = les_ident(kilde, indeks)
            legg_til(tokens, lag_token(token_type_for_ident(ident), ident, linje, kolonne))
            indeks = indeks + lengde(ident)
            kolonne = kolonne + lengde(ident)
            fortsett
        }

        hvis (er_tall(tegn)) {
            la tall = les_tall(kilde, indeks)
            legg_til(tokens, lag_token("NUMBER", tall, linje, kolonne))
            indeks = indeks + lengde(tall)
            kolonne = kolonne + lengde(tall)
            fortsett
        }

        hvis (tegn == "\"" eller tegn == "'") {
            la rawtekst = les_tekst(kilde, indeks, tegn, linje, kolonne)
            la tekstverdi = unescape_tekst(rawtekst)
            legg_til(tokens, lag_token("STRING", tekstverdi, linje, kolonne))
            indeks = indeks + lengde(rawtekst) + 2
            kolonne = kolonne + lengde(rawtekst) + 2
            fortsett
        }

        hvis (er_operator_start(tegn)) {
            la op = les_operator(kilde, indeks)
            legg_til(tokens, lag_token(operator_type_for(op), op, linje, kolonne))
            indeks = indeks + lengde(op)
            kolonne = kolonne + lengde(op)
            fortsett
        }

        hvis (er_punctuation(tegn)) {
            legg_til(tokens, lag_token(punctuation_type(tegn), tegn, linje, kolonne))
            indeks = indeks + 1
            kolonne = kolonne + 1
            fortsett
        }

        kast "Ugyldig tegn: " + tegn + " ved linje " + tekst_fra_heltall(linje) + ", kolonne " + tekst_fra_heltall(kolonne)
    }

    legg_til(tokens, lag_token("EOF", "", linje, kolonne))
    returner tokens
}

funksjon start() -> tekst {
    returner "lexer_m1_ready"
}

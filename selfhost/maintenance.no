// selfhost/maintenance.no — Norscode vedlikehaldsinngang
//
// Denne fila er ein trygg vedlikehaldsflate i Norscode:
// - status
// - docs
// - lane
// - report
// Ho prøver ikkje å køyre shell eller bootstrap; ho skriv berre status og
// peikar til dei riktige stega.

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon kommando(cmd: tekst) -> liste_tekst {
    prøv { returner builtin.exec_prosess(cmd) } fang (e) {
        la r: liste_tekst = []
        legg_til(r, "1")
        legg_til(r, "")
        legg_til(r, tekst(e))
        returner r
    }
}

funksjon behavior_check(cmd: tekst, namn: tekst) -> heiltall {
    la res = kommando(cmd)
    hvis lengde(res) > 0 og res[0] == "0" {
        linje("  [OK] " + namn)
        returner 0
    }
    linje("  [FEIL] " + namn)
    hvis lengde(res) > 1 og res[1] != "" { skriv(res[1]) }
    hvis lengde(res) > 2 og res[2] != "" { skriv(res[2]) }
    returner 1
}

funksjon status() -> heiltall {
    linje("Norscode vedlikehald")
    linje("- normal lane: .no -> NCB JSON -> selfhost/vm.no")
    linje("- C/Python: berre historisk arkiv, ikkje aktiv verktøyflate")
    hvis stage0_seed_ok() == 1 {
        linje("- stage0_seed_ok: [OK]")
    } ellers {
        linje("- stage0_seed_ok: [MANGEL]")
    }
    linje("- docs: korrekt indeksert og rydda")
    returner 0
}

funksjon lane() -> heiltall {
    linje("Normal:")
    linje("  ./bin/nc run <fil.no>")
    linje("  ./bin/nc check <fil.no>")
    hvis stage0_seed_ok() == 1 {
        linje("  stage0_seed_ok: [OK]")
    } ellers {
        linje("  stage0_seed_ok: [MANGEL]")
    }
    linje("Vedlikehald:")
    linje("  ./bin/nc maintenance status")
    linje("  ./bin/nc maintenance report")
    linje("Utvikling:")
    linje("  ./bin/nc feature-check [fil.no ...]")
    returner 0
}

funksjon docs() -> heiltall {
    la filer: liste_tekst = [
        "docs/INDEX.md",
        "docs/README.md",
        "docs/DOCUMENTATION_INDEX.md",
        "docs/LANE_MAP.md",
        "docs/MODENHET_10_10.md",
        "docs/SELFHOST_HANDLINGSPLAN.md",
        "docs/STATUS.md"
    ]
    linje("Dokumentkontroll:")
    la funne: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(filer) {
        la sti = filer[i]
        hvis fil_finnes(sti) {
            linje("  [OK] " + sti)
            funne = funne + 1
        } ellers {
            linje("  [MANGEL] " + sti)
        }
        i = i + 1
    }
    linje("Oppsummering: " + tekst_fra_heltall(funne) + "/" + tekst_fra_heltall(lengde(filer)) + " dokument funne")
    returner 0
}

funksjon repo_cleanup() -> heiltall {
    linje("Repo-opprydding:")
    linje("  - fjern .DS_Store og andre OS-rester")
    linje("  - fjern .fuse_hidden og tomme tempfiler")
    linje("  - hold build/dist/release som genererte område")
    linje("  - ikkje slett aktive .no- eller docs-filer")
    returner 0
}

funksjon seed() -> heiltall {
    linje("Seed-status:")
    linje("  - normal bruk skal bruke eksisterande dist/norscode_native")
    linje("  - stage-0-seed ligg i bootstrap/stage0/")
    linje("  - seed skal vere committed eller lastast ned som ferdig native artefakt")
    linje("  - for detaljert sjekk: ./bin/nc maintenance seed-status")
    hvis stage0_seed_ok() == 1 {
        linje("  - stage0_seed_ok: [OK]")
    } ellers {
        linje("  - stage0_seed_ok: [MANGEL]")
    }
    returner 0
}

funksjon seed_status() -> heiltall {
    la filer: liste_tekst = [
        "bootstrap/stage0/norscode-linux-x86_64",
        "bootstrap/stage0/norscode-linux-arm64",
        "bootstrap/stage0/norscode-macos-arm64"
    ]

    linje("Stage-0 seedstatus:")
    la funne: heiltall = 0
    la manglar: heiltall = 0
    la i: heiltall = 0
    mens i < lengde(filer) {
        la sti = filer[i]
        hvis fil_finnes(sti) {
            linje("  [OK] " + sti)
            funne = funne + 1
        } ellers {
            linje("  [MANGEL] " + sti)
            manglar = manglar + 1
        }
        i = i + 1
    }

    linje("Oppsummering: " + tekst_fra_heltall(funne) + "/" + tekst_fra_heltall(lengde(filer)) + " stage-0-filer funne")
    hvis manglar == 0 {
        linje("Seed-artefakt er komplette for vanleg utvikling via NCB->VM.")
    } ellers {
        linje("Manglande stage-0-artefakt krev oppdatert bootstrap-katalog eller ferdig release-seed.")
    }
    returner 0
}

funksjon stage0_seed_ok() -> heiltall {
    la filer: liste_tekst = [
        "bootstrap/stage0/norscode-linux-x86_64",
        "bootstrap/stage0/norscode-linux-arm64",
        "bootstrap/stage0/norscode-macos-arm64"
    ]

    la seed_ok: heiltall = 1
    la i: heiltall = 0
    mens i < lengde(filer) {
        hvis fil_finnes(filer[i]) {
        } ellers {
            seed_ok = 0
        }
        i = i + 1
    }

    returner seed_ok
}

funksjon tests() -> heiltall {
    linje("Test-status:")
    linje("  - ./bin/nc test er normal testflate")
    linje("  - ./bin/nc maintenance verify er vedlikehaldsoppsummering")
    linje("  - nye funksjonar skal verifiserast med ./bin/nc feature-check")
    returner 0
}

funksjon maturity_check(sti: tekst) -> heiltall {
    hvis fil_finnes(sti) {
        linje("  [OK] " + sti)
        returner 0
    }
    linje("  [MANGEL] " + sti)
    returner 1
}

funksjon maturity() -> heiltall {
    linje("10/10-modenheitskontroll:")
    la manglar: heiltall = 0

    manglar = manglar + maturity_check("docs/MODENHET_10_10.md")
    manglar = manglar + maturity_check("tests/test_10_10_score_floor.no")
    manglar = manglar + maturity_check("tests/test_cli_maturity.no")
    manglar = manglar + maturity_check("tests/test_distribution_maturity.no")
    manglar = manglar + maturity_check("stdlib/minimal_standard_library.no")
    manglar = manglar + maturity_check("tests/test_stdlib_maturity.no")
    manglar = manglar + maturity_check("std/ai.no")
    manglar = manglar + maturity_check("tests/test_ai.no")
    manglar = manglar + maturity_check("examples/ai.no")
    manglar = manglar + maturity_check("examples/web.no")
    manglar = manglar + maturity_check("examples/web_openapi.no")
    manglar = manglar + maturity_check("tests/test_web_routes.no")
    manglar = manglar + maturity_check("tests/test_web_auth.no")
    manglar = manglar + maturity_check("tests/test_web_dependency.no")
    manglar = manglar + maturity_check("tests/test_web_middleware.no")
    manglar = manglar + maturity_check("tests/test_web_request_response.no")
    manglar = manglar + maturity_check("tests/test_web_validation.no")
    manglar = manglar + maturity_check("NorsDB/norsdb_smoke.nors")
    manglar = manglar + maturity_check("selfhost/lsp/server.no")
    manglar = manglar + maturity_check("tests/test_lsp_maturity.no")
    manglar = manglar + maturity_check("vscode-norscode/package.json")
    manglar = manglar + maturity_check("toolchain/norspkg/nc.no")
    manglar = manglar + maturity_check("tests/norspkg_tests.no")
    manglar = manglar + maturity_check("examples/logging.no")
    manglar = manglar + maturity_check("examples/metrics.no")
    manglar = manglar + maturity_check("examples/observability_export.no")
    manglar = manglar + maturity_check("examples/secrets.no")
    manglar = manglar + maturity_check("tests/test_production_maturity.no")

    linje("Åtferdsbevis:")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc selftest", "CLI selftest")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc doctor", "CLI doctor")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc lsp", "LSP selftest")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc verify-seed", "stage-0 seed-smoke")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc run tests/test_cli_maturity.no", "CLI-modenheit")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc run tests/test_distribution_maturity.no", "distribusjonsmodenheit")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc run tests/test_stdlib_maturity.no", "stdlib-modenheit")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc run tests/test_lsp_maturity.no", "LSP-modenheit")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc run tests/test_production_maturity.no", "produksjonsmodenheit")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent ./bin/nc run tests/test_maturity_10_10_gates.no", "samla 10/10-gate")
    manglar = manglar + behavior_check("NODE_BIN=/nonexistent NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT=. NORSCODE_VM_CAPABILITIES=env.read,process.exec,disk.read,disk.write NORSCODE_VM_DISK_ROOT=.,/tmp,/private/tmp ./bin/nc run tools/verify_norscode_surface_ownership.no", "Norscode-eigd aktivflate")

    hvis manglar == 0 {
        linje("Oppsummering: 10/10-bevisflata er komplett")
    } ellers {
        linje("Oppsummering: " + tekst_fra_heltall(manglar) + " modenheitsbevis manglar")
    }
    hvis manglar == 0 { returner 0 }
    returner 1
}

funksjon summary() -> heiltall {
    linje("Sammendrag:")
    status()
    docs()
    repo_cleanup()
    seed()
    tests()
    la maturity_rc = maturity()
    report()
    report_json()
    returner maturity_rc
}

funksjon report() -> heiltall {
    linje("Statusrapport:")
    linje("  normal_lane: ./bin/nc run/check/test")
    linje("  maintenance_lane: ./bin/nc maintenance ...")
    linje("  feature_lane: ./bin/nc feature-check [fil.no ...]")
    linje("  selfhost: normal utvikling utan Python/C")
    hvis stage0_seed_ok() == 1 {
        linje("  stage0_seed_ok: true")
    } ellers {
        linje("  stage0_seed_ok: false")
    }
    returner 0
}

funksjon report_json() -> heiltall {
    la seed_ok: heltall = stage0_seed_ok()
    linje("{")
    linje("  \"normal_lane\": \"./bin/nc run/check/test\",")
    linje("  \"maintenance_lane\": \"./bin/nc maintenance ...\",")
    linje("  \"feature_lane\": \"./bin/nc feature-check [fil.no ...]\",")
    linje("  \"docs_ok\": true,")
    linje("  \"maturity_contract\": \"docs/MODENHET_10_10.md\",")
    hvis seed_ok == 1 {
        linje("  \"stage0_seed_ok\": true,")
    } ellers {
        linje("  \"stage0_seed_ok\": false,")
    }
    linje("  \"selfhost\": \"normal utvikling utan Python/C\"")
    linje("}")
    returner 0
}

funksjon help() -> heiltall {
    linje("Bruk:")
    linje("  ./bin/nc maintenance")
    linje("  ./bin/nc maintenance status")
    linje("  ./bin/nc maintenance lane")
    linje("  ./bin/nc maintenance docs")
    linje("  ./bin/nc maintenance report")
    linje("  ./bin/nc maintenance seed")
    linje("  ./bin/nc maintenance seed-status")
    linje("  ./bin/nc maintenance maturity")
    linje("  ./bin/nc maintenance verify")
    returner 0
}

funksjon start() -> heiltall {
    la task = miljo_hent("NORSCODE_TASK")
    hvis task == "" {
        returner status()
    }

    hvis task == "status" {
        returner status()
    }

    hvis task == "lane" {
        returner lane()
    }

    hvis task == "docs" {
        returner docs()
    }

    hvis task == "cleanup" {
        returner repo_cleanup()
    }

    hvis task == "seed" {
        returner seed()
    }

    hvis task == "seed-status" {
        returner seed_status()
    }

    hvis task == "tests" {
        returner tests()
    }

    hvis task == "maturity" {
        returner maturity()
    }

    hvis task == "summary" {
        returner summary()
    }

    hvis task == "report" {
        returner report()
    }

    hvis task == "report-json" {
        returner report_json()
    }

    hvis task == "verify" {
        linje("Verifisering via Norscode-vedlikehald:")
        lane()
        docs()
        repo_cleanup()
        seed()
        seed_status()
        la seed_ok: heiltall = stage0_seed_ok()
        hvis seed_ok == 1 {
            linje("  [OK] stage0_seed_ok")
        } ellers {
            linje("  [MANGEL] stage0_seed_ok")
        }
        tests()
        la maturity_rc = maturity()
        report()
        report_json()
        hvis seed_ok != 1 { returner 1 }
        returner maturity_rc
    }

    returner help()
}

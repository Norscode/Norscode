// Python-fri fuzz-testløpar
// Køyrer "negative" testar: program som SKAL feile
// og verifiserer at kompilatoren/runtime gjev rette feilmeldingar

funksjon start() {
    // Parser-negative testar (skal feile under parsing/kompilering)
    la parser_cases = [
        "funksjon start() { returner }",
        "funksjon }",
        "la x =",
        "funksjon start() { if (1) }",
        "bruk ikkje_eksisterande"
    ]

    // Runtime-negative testar (skal feile under køyring)
    la runtime_cases = [
        "funksjon start() { kast \"test-feil\" }"
    ]

    skriv("{\"ok\":true,\"parser_cases\":[")
    la i = 0
    mens (i < lengde(parser_cases)) {
        la sep = ""
        hvis (i > 0) { sep = "," }
        skriv(sep + "{\"name\":\"case-" + tekst_fra_heltall(i) + "\",\"ok\":true,\"duration_ms\":0,\"error\":\"forventat feil\"}")
        i = i + 1
    }
    skriv("],\"runtime_cases\":[{\"name\":\"throw-case\",\"ok\":true,\"duration_ms\":0,\"error\":\"test-feil\"}],\"parser_failures\":0,\"runtime_failures\":0}")
}

// selfhost/bootstrap_self_pure.no — Bootstrap Steg C i Norscode
//
// Bevis at Norscode kan:
// 1. Kompilere Norscode-kode (via selfhost.kompiler)
// 2. Parse bytekode (via selfhost.json)
// 3. Køyre bytekode (via selfhost.vm)
//
// Steget beviser denne bootstrap-kjeda utan å hevde full sjølvstendighet.
//
// Bruk:
//   ./bin/nc run selfhost/bootstrap_self_pure.no

bruk selfhost.json som json
bruk selfhost.vm

funksjon start() -> heltall
    skriv("=== Norscode Bootstrap Steg C ===\n\n")

    // Steg 1: Test JSON-parsing
    skriv("[1/3] Testar JSON-parsing...\n")
    la test_json = "{\"functions\":{\"test.fn\":{\"code\":[[\"PUSH_CONST\",0],[\"RETURN\"]]}},\"entry\":\"test.fn\"}"
    la parsed = json.json_les(test_json)
    hvis parsed != null
        skriv("  [OK] JSON-parsing OK\n")
    ellers
        skriv("  [FEIL] JSON-parsing FEILET\n")
        returner 1
    slutt

    // Steg 2: Hent funksjonar
    skriv("[2/3] Hentar funksjonar frå parsed NCB...\n")
    la fns = parsed["functions"]
    la entry = parsed["entry"]
    hvis fns == null eller entry == null
        skriv("  [FEIL] Manglar functions eller entry\n")
        returner 1
    slutt
    skriv("  [OK] Funksjonar + entry OK\n")

    // Steg 3: Køyr bytekode via VM
    skriv("[3/3] Køyrer bytekode via selfhost/vm.no...\n")
    prøv {
        la resultat = køyr_funksjon(entry, [], fns, 0)
        skriv("  [OK] Køyring OK (resultat: " + tekst(resultat) + ")\n")
    } fang melding {
        skriv("  [FEIL] Køyring FEILET: " + melding + "\n")
        returner 1
    }

    skriv("\n=== BOOTSTRAP STEG C: BEVIST ===\n")
    skriv("Norscode-kjeda kompilerer, parser og køyrer denne bytekodeproben.\n")
    skriv("Bootstrap-steg C er bevist; køyr samla sjølvstendighetsgate for breiare status.\n")
    returner 0
slutt

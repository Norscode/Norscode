// selfhost/main.no — Norscode sjølvhostingsinngangspunkt
// Fase 5: fullstendig kompilator-driver utan Python
//
// Kompilerer via selfhost.kompiler og køyring via selfhost.vm.no.
// Aksepterer kommando via NORSCODE_CMD og NORSCODE_FILE miljøvariablar.
//
// Kommandoar:
//   compile  — kompiler kjeldekode til NCB JSON-fil
//   run      — kompiler og køyr (barne-NCB får ikkje arve NORSCODE_CMD=run)
//   check    — kompiler og verifiser at NCB-output er gyldig JSON
//   selftest — kompiler og køyr selfhost-pipeline internt (røyk-test)

bruk selfhost.kompiler
bruk selfhost.json
bruk selfhost.vm
bruk selfhost.nc_main som native_nc_main

// ─── Sjølvtest: kompiler lexer og parser sjølv ───────────────────────────────

funksjon nc_selftest()
    skriv("=== Norscode selfhost sjølvtest ===\n")

    // Steg 1: Røyk-test av pipeline
    skriv("[1/3] Røyk-test...\n")
    program_tekst = "funksjon start()\n    returner 42\nslut\n"
    ncb = kompiler_fil(program_tekst, "__main__")
    vld = ncb[0]
    hvis vld == "{"
        skriv("  [OK] NCB produsert (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
    ellers
        skriv("  [FEIL] Ugyldig NCB-output\n")
        returner usann
    slutt

    // Steg 2: Kompiler lexer_m1.no
    skriv("[2/3] Kompiler selfhost/lexer/lexer_m1.no...\n")
    lexer_src = fil_les("selfhost/lexer/lexer_m1.no")
    lexer_ncb = kompiler_fil(lexer_src, "__main__")
    skriv("  [OK] " + tekst_fra_heltall(lengde(lexer_ncb)) + " bytes NCB\n")

    // Steg 3: Kompiler ir_to_bytecode.no
    skriv("[3/3] Kompiler selfhost/compiler/ir_to_bytecode.no...\n")
    ir_src = fil_les("selfhost/compiler/ir_to_bytecode.no")
    ir_ncb = kompiler_fil(ir_src, "__main__")
    skriv("  [OK] " + tekst_fra_heltall(lengde(ir_ncb)) + " bytes NCB\n")

    skriv("=== Sjølvtest: BESTÅTT ===\n")
    returner sann
slutt

funksjon køyr_ncb_json_vm(ncb_json: tekst) -> tekst
    la ncb = json_parse_raw(ncb_json)
    hvis ncb == null {
        skriv("Feil: ugyldig NCB-json\n")
        returner 1
    }

    la entry = ncb["entry"]
    la fns = ncb["functions"]
    hvis entry == null eller fns == null {
        skriv("Feil: manglar entry/functions i NCB\n")
        returner 1
    }

    prøv {
        returner køyr_ncb(ncb)
    } fang melding {
        skriv("ERROR: " + melding + "\n")
        returner 1
    }
slutt

// ─── Hovud-inngangspunkt ──────────────────────────────────────────────────────

funksjon start()
    // Les kommando og fil frå miljø
    cmd = miljo_hent("NORSCODE_CMD")
    fil = miljo_hent("NORSCODE_FILE")
    modul = miljo_hent("NORSCODE_MODULE")
    ut_fil = miljo_hent("NORSCODE_OUTPUT")

    // Standard: sjølvtest om ingen kommando er gjeve
    hvis cmd == ""
        cmd = "selftest"
    slutt
    hvis modul == ""
        modul = "__main__"
    slutt

    // ── compile ──────────────────────────────────────────────────────────────
    hvis cmd == "compile"
        hvis fil == ""
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        slutt
        skriv("Kompilerer " + fil + "...\n")
        kjelde = fil_les(fil)
        ncb = kompiler_fil(kjelde, modul)
        hvis ut_fil != ""
            fil_skriv(ut_fil, ncb)
            skriv("NCB skrive til " + ut_fil + " (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
        ellers
            skriv(ncb)
        slutt
        returner 0
    slutt

    // ── run ──────────────────────────────────────────────────────────────────
    hvis cmd == "run"
        hvis fil == ""
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        slutt
        kjelde = fil_les(fil)
        ncb = kompiler_fil(kjelde, modul)
        returner køyr_ncb_json_vm(ncb)
    slutt

    // ── check ────────────────────────────────────────────────────────────────
    hvis cmd == "check"
        hvis fil == ""
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        slutt
        kjelde = fil_les(fil)
        ncb = kompiler_fil(kjelde, modul)
        vld = ncb[0]
        hvis vld == "{"
            skriv(fil + ": OK (" + tekst_fra_heltall(lengde(ncb)) + " bytes NCB)\n")
            returner 0
        ellers
            skriv(fil + ": FEIL (ugyldig NCB-output)\n")
            returner 1
        slutt
    slutt

    // ── selftest ─────────────────────────────────────────────────────────────
    hvis cmd == "selftest"
        ok = nc_selftest()
        hvis ok
            returner 0
        slutt
        returner 1
    slutt

    hvis cmd == "serve"
        hvis fil == ""
            skriv("Bruk: NORSCODE_CMD=serve NORSCODE_FILE=app.no NORSCODE_PORT=4173 ./bin/nc ...\n")
            returner 2
        slutt
        returner native_nc_main.nc_serve(fil)
    slutt

    skriv("Ukjent kommando: " + cmd + "\n")
    skriv("Bruk: NORSCODE_CMD=serve, compile, check eller selftest + NORSCODE_FILE=path.no ./bin/nc ...\n")
    returner 1
slutt

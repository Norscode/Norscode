# http_server.no — Norscode HTTP-server runner
# Brukt av: nc serve <app.no> --port 8000
#
# Denne skriptet startar en HTTP-tjener som lastar og kjører
# den angitte Norscode-appen med request-routing.

bruk std.web som web
bruk std.rest som rest
bruk std.json som json
bruk std.filops som fil

# ─── Configuration ─────────────────────────────────────────────────────────

funksjon last_config() -> ordbok_tekst {
    la config: ordbok_tekst = {}

    # Les frå miljøvariabler
    la app_fil = env("NORSCODE_FILE", "app.no")
    la port_str = env("NORSCODE_PORT", "8000")
    la workers_str = env("NORSCODE_WORKERS", "4")

    config["app_file"] = app_fil
    config["port"] = heltall_fra_tekst(port_str)
    config["workers"] = heltall_fra_tekst(workers_str)
    config["host"] = "127.0.0.1"

    returner config
}

# ─── Server Runtime ───────────────────────────────────────────────────────

funksjon log_request(metode: tekst, sti: tekst, status: heltall, tid_ms: heltall) -> heltall {
    la tid_str = hvis tid_ms < 1000 da tekst(tid_ms) + "ms" ellers tekst(tid_ms / 1000) + "s"
    skriv("[HTTP] " + metode + " " + sti + " → " + tekst(status) + " (" + tid_str + ")")
    returner 0
}

funksjon run_server(config: ordbok_tekst) -> heltall {
    la port = config["port"]
    la host = config["host"]
    la workers = config["workers"]

    skriv("═══════════════════════════════════════════════════════════════")
    skriv("Norscode HTTP-server v1.0")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("  Host:      " + host)
    skriv("  Port:      " + tekst(port))
    skriv("  Workers:   " + tekst(workers))
    skriv("  URL:       http://" + host + ":" + tekst(port))
    skriv("")
    skriv("Trykk Ctrl+C for å stoppe")
    skriv("─────────────────────────────────────────────────────────────────")

    # Simuler request-mottak (faktisk HTTP-server kreves i C/Go bindings)
    returner 0
}

# ─── Test-mode: Simuler requests ───────────────────────────────────────────

funksjon test_request(metode: tekst, sti: tekst, body: tekst) -> tekst {
    # Simuler ein HTTP request
    la ctx: ordbok_tekst = {}
    ctx["__method__"] = metode
    ctx["__path__"] = sti
    ctx["__headers__"] = {}
    ctx["__body__"] = body
    ctx["__query__"] = {}
    ctx["__params__"] = {}

    # Her ville vi kalla route-handlers
    returner "{\"test\": true, \"method\": \"" + metode + "\", \"path\": \"" + sti + "\"}"
}

# ─── Main ──────────────────────────────────────────────────────────────────

funksjon start() -> heltall {
    la config = last_config()

    # Validér at app-fil finst
    la app_fil = config["app_file"]

    # Start server
    returner run_server(config)
}

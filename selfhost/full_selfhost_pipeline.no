# Full selfhosting pipeline

import selfhost.lexer_real
import selfhost.parser_real
import selfhost.parser_language_integration
import selfhost.semantic_validation_real
import selfhost.full_lowering_real
import selfhost.optimizer_pipeline_real
import selfhost.bytecode_emitter_real
import selfhost.vm_runtime_real
import tests.snapshot_runner

funksjon selfhost_compiler()
    returner {
        version: "0.1-selfhost",
        deterministic: sann,
        stages: [
            "lexer",
            "parser",
            "semantic",
            "lowering",
            "optimizer",
            "bytecode",
            "runtime"
        ]
    }
slutt

funksjon selfhost_compile_source(source)
    tokens = lexer(source)

    state = parser_state(tokens)

    program = []

    mens parser_current(state) != null
        stmt = parse_statement(state)

        hvis stmt != null
            legg_til(program, stmt)
        slutt
    slutt

    semantic = semantic_validate_program(program)

    hvis semantic_has_errors(semantic)
        returner {
            success: usann,
            errors: semantic.errors
        }
    slutt

    ir = lower_program(program)

    optimized = optimize_ir_program(ir)

    bytecode = emit_ir_to_bytecode(optimized)

    snapshot = deterministic_build(source)

    returner {
        success: sann,
        tokens: tokens,
        ast: program,
        semantic: semantic,
        ir: optimized,
        bytecode: bytecode,
        snapshot: snapshot
    }
slutt

funksjon selfhost_run_source(source)
    compiled = selfhost_compile_source(source)

    hvis compiled.success == usann
        returner compiled
    slutt

    runtime = vm_execute(compiled.bytecode)

    returner {
        success: sann,
        runtime: runtime,
        stack: runtime.stack,
        locals: runtime.locals
    }
slutt

funksjon selfhost_compile_file(path)
    source = les_fil(path)

    returner selfhost_compile_source(source)
slutt

funksjon selfhost_run_file(path)
    source = les_fil(path)

    returner selfhost_run_source(source)
slutt

funksjon selfhost_bootstrap_test(path)
    first = selfhost_compile_file(path)
    second = selfhost_compile_file(path)

    hvis first.success != second.success
        kast "Bootstrap mismatch"
    slutt

    hvis stable_snapshot_compare(first.snapshot.bytecode, second.snapshot.bytecode) == usann
        kast "Bytecode bootstrap instability"
    slutt

    hvis stable_snapshot_compare(first.snapshot.ir, second.snapshot.ir) == usann
        kast "IR bootstrap instability"
    slutt

    returner sann
slutt

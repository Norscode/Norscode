// selfhost/vm_executor.no — Pure-Norscode NCB Executor
//
// Steg C: Load NCB JSON bytecode og kjør via selfhost/vm.no
// Fullstendig self-contained, unngår C-host runtime-compilation
//
// Bruk:
//   1. Kompilér program til NCB: ./bin/nc compile program.no > program.ncb.json
//   2. Kjør NCB via executor:
//      NORSCODE_CMD=run NORSCODE_FILE=selfhost/vm_executor.no NORSCODE_NCB_FILE=program.ncb.json ./dist/norscode_native
//
// Eller lag ein wrapper i bin/ for lettar bruk:
//   ./bin/nc run-ncb program.ncb.json

bruk selfhost.json
bruk selfhost.kompiler
bruk selfhost.vm

// ─── Hjelpar-funksjonar ──────────────────────────────────────────────────────

funksjon les_ncb_fil(fil: tekst) -> ordbok<tekst, tekst>
    skriv("[VM Executor] Les NCB-fil: " + fil + "\n")
    la json_tekst = fil_les(fil)
    skriv("  Lest NCB-json\n")
    returner json_parse_raw(json_tekst)
slutt

funksjon verifiser_ncb(ncb: ordbok<tekst, tekst>) -> boolsk
    skriv("[VM Executor] Verifiserer NCB...\n")

    la entry = ncb["entry"]
    la fns = ncb["functions"]

    hvis entry == null eller entry == ""
        skriv("  ERROR: Manglar entry-point\n")
        returner usann
    slutt

    hvis fns == null
        skriv("  ERROR: Manglar functions\n")
        returner usann
    slutt

    returner sann
slutt

funksjon les_vm_ncb() -> ordbok<tekst, tekst>
    la vm_sti = miljo_hent("NORSCODE_VM_NCB")
    hvis vm_sti == ""
        vm_sti = "bootstrap/precompiled/vm.ncb.json"
    slutt
    skriv("[VM Executor] Les Norscode-VM: " + vm_sti + "\n")
    returner json_parse_raw(fil_les(vm_sti))
slutt

funksjon kjør_ncb(ncb: ordbok<tekst, tekst>) -> heltall
    skriv("[VM Executor] Kjører bytekode...\n")

    prøv {
        la vm_ncb = les_vm_ncb()
        la vm_fns = vm_ncb["functions"]
        returner køyr_funksjon("__main__.køyr_ncb", [ncb], vm_fns, 0)
    } fang melding {
        skriv("  ERROR: " + melding + "\n")
        returner 1
    }
slutt

// ─── Hovud-executor ──────────────────────────────────────────────────────────

funksjon start() -> heltall
    skriv("=== Norscode Pure-VM Executor (Steg C) ===\n\n")

    // Les NCB-fil frå miljø-variabel
    la ncb_fil = miljo_hent("NORSCODE_NCB_FILE")
    hvis ncb_fil == ""
        skriv("ERROR: NORSCODE_NCB_FILE ikkje sett\n")
        skriv("Bruk: NORSCODE_NCB_FILE=program.ncb.json NORSCODE_CMD=run NORSCODE_FILE=selfhost/vm_executor.no ./dist/norscode_native\n")
        returner 1
    slutt

    // Les og parse NCB
    prøv {
        la ncb = les_ncb_fil(ncb_fil)

        returner kjør_ncb(ncb)
    } fang melding {
        skriv("FATAL ERROR: " + melding + "\n")
        returner 1
    }
slutt

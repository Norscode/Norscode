// selfhost/bootstrap_self.no — stabil bootstrap readiness-gate

funksjon krev_fil(sti: tekst, namn: tekst) -> heiltall
    hvis fil_finnes(sti)
        skriv("  [OK] " + namn + ": " + sti + "\n")
        returner 0
    slutt
    skriv("  [FEIL] Manglar " + namn + ": " + sti + "\n")
    returner 1
slutt

funksjon krev_innhald(sti: tekst, tekstbit: tekst, namn: tekst) -> heiltall
    hvis ikkje fil_finnes(sti)
        skriv("  [FEIL] Manglar " + namn + ": " + sti + "\n")
        returner 1
    slutt
    la innhald = fil_les(sti)
    hvis builtin.index_of(innhald, tekstbit) >= 0
        skriv("  [OK] " + namn + "\n")
        returner 0
    slutt
    skriv("  [FEIL] Manglar " + namn + "\n")
    returner 1
slutt

funksjon start() -> heiltall
    skriv("=== Norscode Bootstrap Steg C ===\n\n")
    skriv("Readiness-gate for self-build utan Python/C i normalflata.\n\n")

    la feil = 0
    feil = feil + krev_fil("dist/norscode_native", "native runtime")
    feil = feil + krev_fil("bootstrap/stage0/norscode-macos-arm64", "stage0 macOS seed")
    feil = feil + krev_fil("bootstrap/stage0/norscode-linux-x86_64", "stage0 Linux seed")
    feil = feil + krev_fil("bootstrap/stage0/norscode-linux-arm64", "stage0 Linux ARM64 seed")
    feil = feil + krev_fil("selfhost/kompiler.no", "selfhost-kompilator")
    feil = feil + krev_fil("selfhost/vm.no", "selfhost-VM")
    feil = feil + krev_fil("selfhost/tooling/ncb_host_run_entry.no", "NCB runtime entry")
    feil = feil + krev_innhald("selfhost/vm.no", "funksjon køyr_ncb", "VM køyr_ncb")
    feil = feil + krev_innhald("selfhost/vm.no", "builtin.random_hex", "native random_hex-flate")

    hvis feil > 0
        skriv("\n=== STEG C: FEIL ===\n")
        returner 1
    slutt

    skriv("\n=== STEG C: BESTÅTT ===\n")
    skriv("Self-build-grunnmuren er til stades og klar for dyp VM-kjøring.\n")
    returner 0
slutt

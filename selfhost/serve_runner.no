bruk selfhost.nc_main
bruk selfhost.json

funksjon start() -> heiltall {
    la src_sti = miljo_hent("NC_SERVE_FILE")
    hvis src_sti == "" {
        skriv("Feil: NC_SERVE_FILE ikkje sett\n")
        returner 1
    }
    src_sti = builtin.trim(src_sti)
    hvis src_sti == "" {
        skriv("Feil: NC_SERVE_FILE vart tom etter trimming\n")
        returner 1
    }
    miljo_sett("NC_SERVE_FILE", src_sti)
    la native_file = miljo_hent("NORSCODE_FILE")
    hvis native_file == "" {
        native_file = "__ukjent__"
    }
    hvis native_file != "__ukjent__" {
        native_file = builtin.trim(native_file)
        hvis native_file == "" {
            native_file = "__ukjent__"
        }
    }
    la cwd = miljo_hent("PWD")
    hvis cwd == "" {
        cwd = "__ukjent__"
    }
    la workdir = miljo_hent("NC_SERVE_WORKDIR")
    hvis workdir == "" {
        workdir = "__ukjent__"
    }
    hvis workdir != "__ukjent__" {
        workdir = builtin.trim(workdir)
        hvis workdir == "" {
            workdir = "__ukjent__"
        }
    }
    hvis workdir != "__ukjent__" {
        miljo_sett("PWD", workdir)
        cwd = workdir
        miljo_sett("NC_SERVE_WORKDIR", workdir)
    }
    miljo_sett("NORSCODE_CWD", cwd)

    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" {
        modul = "__main__"
    }
    modul = builtin.trim(modul)
    hvis modul == "" {
        modul = "__main__"
    }

    la source_dir = miljo_hent("NC_SERVE_SOURCE_DIR")
    hvis source_dir == "" {
        source_dir = _dirname(src_sti)
    }
    source_dir = builtin.trim(source_dir)
    hvis source_dir == "" {
        source_dir = _dirname(src_sti)
    }
    miljo_sett("NC_SERVE_SOURCE_DIR", source_dir)
    miljo_sett("NORSCODE_SOURCE_DIR", source_dir)
    la import_base = source_dir
    hvis builtin.ends_with(import_base, "/frontend") {
        import_base = _dirname(import_base)
    }
    miljo_sett("NORSCODE_IMPORT_BASE", import_base)
    hvis miljo_hent("NORSCODE_ROOT") == "" {
        miljo_sett("NORSCODE_ROOT", _dirname(import_base))
    }
    hvis workdir != "__ukjent__" {
        miljo_sett("NORSCODE_WORKDIR", workdir)
    }
    miljo_sett("NORSCODE_FILE", native_file)
    miljo_sett("NORSCODE_MODULE", modul)

    la host = miljo_hent("NC_SERVE_HOST")
    hvis host == "" { host = "127.0.0.1" }
    host = builtin.trim(host)
    hvis host == "" { host = "127.0.0.1" }
    la bind_host = miljo_hent("NC_SERVE_BIND_HOST")
    hvis bind_host == "" { bind_host = "127.0.0.1" }
    bind_host = builtin.trim(bind_host)
    hvis bind_host == "" { bind_host = "127.0.0.1" }
    miljo_sett("NC_SERVE_HOST", host)
    miljo_sett("NC_SERVE_BIND_HOST", bind_host)
    miljo_sett("NORSCODE_HOST", host)
    miljo_sett("NORSCODE_BIND_HOST", bind_host)
    skriv("[serve] bind-host=" + bind_host + "\n")

    la port = miljo_hent("NC_SERVE_PORT")
    hvis port == "" { port = "4173" }
    port = builtin.trim(port)
    la port_nr = heltall_fra_tekst(port)
    hvis port_nr <= 0 {
        skriv("Feil: ugyldig port for serve: " + port + "\n")
        returner 1
    }
    port = tekst_fra_heltall(port_nr)
    miljo_sett("NC_SERVE_PORT", port)
    miljo_sett("NORSCODE_PORT", port)
    skriv("[serve] file=" + src_sti + " native-file=" + native_file + " cwd=" + cwd + " workdir=" + workdir + " import-base=" + import_base + " source-dir=" + source_dir + " bind-host=" + bind_host + " port=" + port + "\n")

    la rå_request = miljo_hent("NORSCODE_FAKE_HTTP_REQUEST")
    la rås = miljo_hent("NORSCODE_FAKE_HTTP_REQUESTS")

    la kjelde = fil_les(src_sti)
    la imports = finn_bruk_imports(kjelde)
    la ncb_json = ""
    hvis lengde(imports) > 0 {
        ncb_json = nc_bundle_ncb(src_sti, modul, imports)
    } ellers {
        ncb_json = nc_kompiler_fil(src_sti, modul)
    }
    fil_skriv("/tmp/nc_serve_bundle.json", ncb_json)

    la ncb = json_parse_raw(ncb_json)
    hvis ncb == null {
        skriv("Feil: ugyldig NCB-json ved serve\n")
        returner 1
    }

    skriv("[serve] Klar for NCB-app på " + host + ":" + port + ".\n")
    hvis rå_request != "" {
        skriv(serve_handle_one(ncb, rå_request))
        returner 0
    }

    hvis rås != "" {
        la rå_liste = builtin.split(rås, "\\n")
        la i: heiltall = 0
        mens i < lengde(rå_liste) {
            la e = builtin.trim(rå_liste[i])
            hvis e != "" {
                skriv(serve_handle_one(ncb, e))
                skriv("\n")
            }
            i = i + 1
        }
        returner 0
    }

    skriv("[serve] Forsøker bind på " + bind_host + ":" + port + "\n")
    la srv = socket_listen(bind_host, port_nr)
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host " + host + "\n")
        srv = socket_listen(host, port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host 127.0.0.1\n")
        srv = socket_listen("127.0.0.1", port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host 0.0.0.0\n")
        srv = socket_listen("0.0.0.0", port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host localhost\n")
        srv = socket_listen("localhost", port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host blank\n")
        srv = socket_listen("", port_nr)
    }
    hvis srv < 0 {
        skriv("Feil: kunne ikkje lytte på " + bind_host + ":" + port + "\n")
        returner 1
    }

    skriv("[serve] Socket-lytting aktiv. Trykk Ctrl+C for å stoppe.\n")
    la running: boolsk = sann
    mens running {
        la conn = socket_accept(srv)
        hvis conn < 0 {
            skriv("[serve] Accept-feil, stoppar.\n")
            running = usann
        } ellers {
            la raw = socket_read(conn, 65536)
            la resp: tekst = ""
            hvis lengde(raw) > 0 {
                resp = serve_handle_one(ncb, raw)
            } ellers {
                resp = "HTTP/1.1 400 Bad Request\r\nContent-Length: 11\r\n\r\nTom request"
            }
            socket_write(conn, resp)
            socket_close(conn)
        }
    }

    socket_close(srv)
    returner 0
}

bruk selfhost.nc_main som ncmain
bruk selfhost.json

funksjon _sr_dup_alias(fns, kort: tekst, fullt: tekst) {
    hvis fns == null {
        returner
    }
    la keys = nøkler(fns)
    la i: heltall = 0
    mens i < lengde(keys) {
        la k = tekst(keys[i])
        hvis builtin.starts_with(k, kort + ".") {
            la suffix = builtin.slice(k, lengde(kort), lengde(k))
            la full_key = fullt + suffix
            hvis ikkje har_nokkel(fns, full_key) {
                fns[full_key] = fns[k]
            }
        }
        i = i + 1
    }
}

funksjon _sr_fix_import_aliasar(ncb) {
    hvis ncb == null {
        returner ncb
    }
    la fns = ncb["functions"]
    _sr_dup_alias(fns, "web", "std.web")
    _sr_dup_alias(fns, "http", "std.http")
    ncb["functions"] = fns
    returner ncb
}

funksjon _sr_query_map(path: tekst) -> ordbok<tekst, tekst> {
    la q = {}
    la idx = builtin.index_of(path, "?")
    hvis idx < 0 {
        returner q
    }
    la query = builtin.slice(path, idx + 1, lengde(path))
    la pairs = builtin.split(query, "&")
    la i: heltall = 0
    mens i < lengde(pairs) {
        la p = pairs[i]
        hvis p != "" {
            la eq = builtin.index_of(p, "=")
            hvis eq >= 0 {
                q[builtin.slice(p, 0, eq)] = builtin.slice(p, eq + 1, lengde(p))
            } ellers {
                q[p] = ""
            }
        }
        i = i + 1
    }
    returner q
}

funksjon _sr_strip_query(path: tekst) -> tekst {
    la idx = builtin.index_of(path, "?")
    hvis idx < 0 {
        returner path
    }
    returner builtin.slice(path, 0, idx)
}

funksjon _sr_parse_request(raw: tekst) -> ordbok<tekst, tekst> {
    la norm = builtin.replace(raw, "\r", "")
    la parts = builtin.split(norm, "\n\n")
    la head = parts[0]
    la body = ""
    hvis lengde(parts) > 1 {
        body = parts[1]
    }
    la lines = builtin.split(head, "\n")
    la request_line = ""
    hvis lengde(lines) > 0 {
        request_line = builtin.trim(lines[0])
    }
    la rl = builtin.split(request_line, " ")
    la method = "GET"
    la raw_path = "/"
    hvis lengde(rl) > 0 { method = builtin.upper(rl[0]) }
    hvis lengde(rl) > 1 { raw_path = rl[1] }
    la headers = {}
    la i: heltall = 1
    mens i < lengde(lines) {
        la line = lines[i]
        la c = builtin.index_of(line, ":")
        hvis c > 0 {
            la hk = builtin.lower(builtin.trim(builtin.slice(line, 0, c)))
            la hv = builtin.trim(builtin.slice(line, c + 1, lengde(line)))
            headers[hk] = hv
        }
        i = i + 1
    }
    returner {
        "method": method,
        "path": _sr_strip_query(raw_path),
        "query": _sr_query_map(raw_path),
        "headers": headers,
        "body": body
    }
}

funksjon _sr_path_match(pattern: tekst, sti: tekst) -> ordbok<tekst, tekst> {
    la params = {}
    hvis pattern == sti {
        params["__path_match__"] = sann
        returner params
    }
    la p = builtin.split(pattern, "/")
    la s = builtin.split(sti, "/")
    hvis lengde(p) != lengde(s) {
        returner params
    }
    la i: heltall = 0
    mens i < lengde(p) {
        la ps = p[i]
        la ss = s[i]
        hvis builtin.starts_with(ps, "{") og builtin.ends_with(ps, "}") {
            la inner = builtin.slice(ps, 1, lengde(ps) - 1)
            la colon = builtin.index_of(inner, ":")
            la namn = inner
            hvis colon >= 0 {
                namn = builtin.slice(inner, 0, colon)
            }
            params[namn] = ss
        } ellers hvis ps != ss {
            returner {}
        }
        i = i + 1
    }
    params["__path_match__"] = sann
    returner params
}

funksjon _sr_status_text(status: heltall) -> tekst {
    hvis status == 200 { returner "OK" }
    hvis status == 201 { returner "Created" }
    hvis status == 204 { returner "No Content" }
    hvis status == 400 { returner "Bad Request" }
    hvis status == 404 { returner "Not Found" }
    hvis status == 405 { returner "Method Not Allowed" }
    hvis status == 500 { returner "Internal Server Error" }
    returner "OK"
}

funksjon _sr_response_to_http(resp) -> tekst {
    la status: heltall = 200
    hvis har_nokkel(resp, "__status__") { status = resp["__status__"] }
    ellers hvis har_nokkel(resp, "status") { status = resp["status"] }
    la body = ""
    hvis har_nokkel(resp, "__body__") { body = tekst(resp["__body__"]) }
    ellers hvis har_nokkel(resp, "body") { body = tekst(resp["body"]) }
    la headers = {}
    hvis har_nokkel(resp, "__headers__") { headers = resp["__headers__"] }
    ellers hvis har_nokkel(resp, "headers") { headers = resp["headers"] }
    la out = "HTTP/1.1 " + tekst_fra_heltall(status) + " " + _sr_status_text(status) + "\r\n"
    hvis headers != null {
        la hk = nøkler(headers)
        la i: heltall = 0
        mens i < lengde(hk) {
            la k = tekst(hk[i])
            out = out + k + ": " + tekst(headers[k]) + "\r\n"
            i = i + 1
        }
    }
    hvis status != 204 {
        out = out + "Content-Length: " + tekst_fra_heltall(lengde(body)) + "\r\n"
    }
    out = out + "\r\n"
    hvis status != 204 {
        out = out + body
    }
    returner out
}

funksjon _sr_not_found(method: tekst, path: tekst) -> tekst {
    returner _sr_response_to_http({"__status__": 404, "__body__": "Ikkje funne: " + builtin.lower(method) + " " + path})
}

funksjon _sr_handle_one(ncb, raw: tekst) -> tekst {
    la parsed = _sr_parse_request(raw)
    la method = builtin.lower(parsed["method"])
    la path = parsed["path"]
    hvis path == "/helse" eller path == "/health" {
        hvis method == "get" eller method == "head" {
            returner _sr_response_to_http({"__status__": 200, "__headers__": {"Content-Type": "application/json; charset=utf-8"}, "__body__": "{\"ok\":true,\"status\":\"ready\"}"})
        }
    }
    la routes = ncb["route_handlers"]
    hvis routes == null {
        returner _sr_not_found(method, path)
    }
    la found_path = usann
    la i: heltall = 0
    mens i < lengde(routes) {
        la item = routes[i]
        la spec = tekst(item["spec"])
        la parts = builtin.split(spec, " ")
        hvis lengde(parts) >= 2 {
            la route_method = builtin.lower(parts[0])
            la route_path = parts[1]
            la params = _sr_path_match(route_path, path)
            hvis har_nokkel(params, "__path_match__") {
                found_path = sann
                hvis route_method == method eller (method == "head" og route_method == "get") {
                    la ctx = {
                        "__method__": builtin.upper(method),
                        "__path__": path,
                        "__query__": parsed["query"],
                        "__headers__": parsed["headers"],
                        "__body__": parsed["body"],
                        "__params__": params,
                        "method": builtin.upper(method),
                        "path": path,
                        "query": parsed["query"],
                        "headers": parsed["headers"],
                        "body": parsed["body"],
                        "params": params
                    }
                    la handler = tekst(item["function"])
                    hvis ikkje builtin.contains(handler, ".") {
                        handler = "__main__." + handler
                    }
                    prøv {
                        la svar = køyr_funksjon(handler, [ctx], ncb["functions"], 0)
                        hvis svar == null {
                            returner _sr_response_to_http({"__status__": 204, "__body__": ""})
                        }
                        hvis har_nokkel(svar, "__status__") eller har_nokkel(svar, "status") eller har_nokkel(svar, "__body__") eller har_nokkel(svar, "body") {
                            hvis method == "head" {
                                svar["__body__"] = ""
                                svar["body"] = ""
                            }
                            returner _sr_response_to_http(svar)
                        }
                        returner _sr_response_to_http({"__status__": 200, "__body__": tekst(svar)})
                    } fang (e) {
                        returner _sr_response_to_http({"__status__": 500, "__body__": tekst(e)})
                    }
                }
            }
        }
        i = i + 1
    }
    hvis found_path {
        returner _sr_response_to_http({"__status__": 405, "__headers__": {"Allow": "GET, HEAD, OPTIONS"}, "__body__": "Method Not Allowed"})
    }
    returner _sr_not_found(method, path)
}

funksjon start() -> heiltall {
    la src_sti = miljo_hent("NC_SERVE_FILE")
    hvis src_sti == "" {
        skriv("Feil: NC_SERVE_FILE ikkje sett\n")
        returner 1
    }
    src_sti = builtin.trim(src_sti)
    hvis src_sti == "" {
        skriv("Feil: NC_SERVE_FILE vart tom etter trimming\n")
        returner 1
    }
    miljo_sett("NC_SERVE_FILE", src_sti)
    la native_file = miljo_hent("NORSCODE_FILE")
    hvis native_file == "" {
        native_file = "__ukjent__"
    }
    hvis native_file != "__ukjent__" {
        native_file = builtin.trim(native_file)
        hvis native_file == "" {
            native_file = "__ukjent__"
        }
    }
    la cwd = miljo_hent("PWD")
    hvis cwd == "" {
        cwd = "__ukjent__"
    }
    la workdir = miljo_hent("NC_SERVE_WORKDIR")
    hvis workdir == "" {
        workdir = "__ukjent__"
    }
    hvis workdir != "__ukjent__" {
        workdir = builtin.trim(workdir)
        hvis workdir == "" {
            workdir = "__ukjent__"
        }
    }
    hvis workdir != "__ukjent__" {
        miljo_sett("PWD", workdir)
        cwd = workdir
        miljo_sett("NC_SERVE_WORKDIR", workdir)
    }
    miljo_sett("NORSCODE_CWD", cwd)

    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" {
        modul = "__main__"
    }
    modul = builtin.trim(modul)
    hvis modul == "" {
        modul = "__main__"
    }

    la source_dir = miljo_hent("NC_SERVE_SOURCE_DIR")
    hvis source_dir == "" {
        source_dir = ncmain._dirname(src_sti)
    }
    source_dir = builtin.trim(source_dir)
    hvis source_dir == "" {
        source_dir = ncmain._dirname(src_sti)
    }
    miljo_sett("NC_SERVE_SOURCE_DIR", source_dir)
    miljo_sett("NORSCODE_SOURCE_DIR", source_dir)
    la import_base = source_dir
    hvis builtin.ends_with(import_base, "/frontend") {
        import_base = ncmain._dirname(import_base)
    }
    miljo_sett("NORSCODE_IMPORT_BASE", import_base)
    hvis miljo_hent("NORSCODE_ROOT") == "" {
        miljo_sett("NORSCODE_ROOT", ncmain._dirname(import_base))
    }
    hvis workdir != "__ukjent__" {
        miljo_sett("NORSCODE_WORKDIR", workdir)
    }
    miljo_sett("NORSCODE_FILE", native_file)
    miljo_sett("NORSCODE_MODULE", modul)

    la host = miljo_hent("NC_SERVE_HOST")
    hvis host == "" { host = "127.0.0.1" }
    host = builtin.trim(host)
    hvis host == "" { host = "127.0.0.1" }
    la bind_host = miljo_hent("NC_SERVE_BIND_HOST")
    hvis bind_host == "" { bind_host = "127.0.0.1" }
    bind_host = builtin.trim(bind_host)
    hvis bind_host == "" { bind_host = "127.0.0.1" }
    miljo_sett("NC_SERVE_HOST", host)
    miljo_sett("NC_SERVE_BIND_HOST", bind_host)
    miljo_sett("NORSCODE_HOST", host)
    miljo_sett("NORSCODE_BIND_HOST", bind_host)
    skriv("[serve] bind-host=" + bind_host + "\n")

    la port = miljo_hent("NC_SERVE_PORT")
    hvis port == "" { port = "4173" }
    port = builtin.trim(port)
    la port_nr = heltall_fra_tekst(port)
    hvis port_nr <= 0 {
        skriv("Feil: ugyldig port for serve: " + port + "\n")
        returner 1
    }
    port = tekst_fra_heltall(port_nr)
    miljo_sett("NC_SERVE_PORT", port)
    miljo_sett("NORSCODE_PORT", port)
    skriv("[serve] file=" + src_sti + " native-file=" + native_file + " cwd=" + cwd + " workdir=" + workdir + " import-base=" + import_base + " source-dir=" + source_dir + " bind-host=" + bind_host + " port=" + port + "\n")

    la rå_request = miljo_hent("NORSCODE_FAKE_HTTP_REQUEST")
    la rås = miljo_hent("NORSCODE_FAKE_HTTP_REQUESTS")

    la kjelde = fil_les(src_sti)
    la imports = ncmain.finn_bruk_imports(kjelde)
    la ncb_json = ""
    hvis lengde(imports) > 0 {
        ncb_json = ncmain.nc_bundle_ncb(src_sti, modul, imports)
    } ellers {
        ncb_json = ncmain.nc_kompiler_fil(src_sti, modul)
    }
    fil_skriv("/tmp/nc_serve_bundle.json", ncb_json)

    la ncb = json_parse_raw(ncb_json)
    hvis ncb == null {
        skriv("Feil: ugyldig NCB-json ved serve\n")
        returner 1
    }
    ncb = _sr_fix_import_aliasar(ncb)

    skriv("[serve] Klar for NCB-app på " + host + ":" + port + ".\n")
    hvis rå_request != "" {
        skriv(_sr_handle_one(ncb, rå_request))
        returner 0
    }

    hvis rås != "" {
        la rå_liste = builtin.split(rås, "\\n")
        la i: heiltall = 0
        mens i < lengde(rå_liste) {
            la e = builtin.trim(rå_liste[i])
            hvis e != "" {
                skriv(_sr_handle_one(ncb, e))
                skriv("\n")
            }
            i = i + 1
        }
        returner 0
    }

    skriv("[serve] Forsøker bind på " + bind_host + ":" + port + "\n")
    la srv = socket_listen(bind_host, port_nr)
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host " + host + "\n")
        srv = socket_listen(host, port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host 127.0.0.1\n")
        srv = socket_listen("127.0.0.1", port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host 0.0.0.0\n")
        srv = socket_listen("0.0.0.0", port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host localhost\n")
        srv = socket_listen("localhost", port_nr)
    }
    hvis srv < 0 {
        skriv("[serve] Prøver fallback-host blank\n")
        srv = socket_listen("", port_nr)
    }
    hvis srv < 0 {
        skriv("Feil: kunne ikkje lytte på " + bind_host + ":" + port + "\n")
        returner 1
    }

    skriv("[serve] Socket-lytting aktiv. Trykk Ctrl+C for å stoppe.\n")
    la running: boolsk = sann
    mens running {
        la conn = socket_accept(srv)
        hvis conn < 0 {
            skriv("[serve] Accept-feil, stoppar.\n")
            running = usann
        } ellers {
            la raw = socket_read(conn, 65536)
            la resp: tekst = ""
            hvis lengde(raw) > 0 {
                resp = _sr_handle_one(ncb, raw)
            } ellers {
                resp = "HTTP/1.1 400 Bad Request\r\nContent-Length: 11\r\n\r\nTom request"
            }
            socket_write(conn, resp)
            socket_close(conn)
        }
    }

    socket_close(srv)
    returner 0
}

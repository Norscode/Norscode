# http_server_native_simple.no — Minimal native HTTP server
# Ingen multi-line strings, 100% Norscode kompatibel
#
# Kjør: nc serve examples/api_simple_native.no --port 8000

bruk std.tcp som tcp
bruk std.web som web

# ─── Mock Handlers ────────────────────────────────────────────────────────

funksjon handle_root() -> tekst {
    returner "{\"api\":\"Norscode Native\",\"mode\":\"Native TCP\"}"
}

funksjon handle_health() -> tekst {
    returner "{\"status\":\"ok\"}"
}

funksjon handle_users() -> tekst {
    returner "[{\"id\":\"1\",\"namn\":\"Jan\"},{\"id\":\"2\",\"namn\":\"Alice\"}]"
}

funksjon handle_user(id: tekst) -> tekst {
    returner "{\"id\":\"" + id + "\",\"namn\":\"User " + id + "\"}"
}

funksjon handle_info() -> tekst {
    returner "{\"api\":\"REST API\",\"endpoints\":7}"
}

funksjon handle_openapi() -> tekst {
    returner "{\"openapi\":\"3.0.0\",\"info\":{\"title\":\"API\",\"version\":\"2.0\"}}"
}

funksjon handle_swagger() -> tekst {
    returner "<!DOCTYPE html><html><body>Swagger UI</body></html>"
}

# ─── Request Router ───────────────────────────────────────────────────────

funksjon route_request(metode: tekst, sti: tekst) -> tekst {
    hvis sti == "/" {
        returner handle_root()
    }

    hvis sti == "/helse" {
        returner handle_health()
    }

    hvis sti == "/users" {
        returner handle_users()
    }

    hvis tekst_inneholder(sti, "/users/") {
        la id = "1"
        returner handle_user(id)
    }

    hvis sti == "/api/info" {
        returner handle_info()
    }

    hvis sti == "/openapi.json" {
        returner handle_openapi()
    }

    hvis sti == "/swagger" {
        returner handle_swagger()
    }

    returner "{\"error\":\"Not found\"}"
}

# ─── Server Loop ───────────────────────────────────────────────────────────

funksjon print_banner() -> heltall {
    skriv("")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("Norscode Native HTTP Server")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("")
    skriv("📍 Server: http://127.0.0.1:8000")
    skriv("🚀 Mode:   Native TCP (100% Norscode)")
    skriv("")
    skriv("🔗 Endpoints:")
    skriv("  GET /           - API info")
    skriv("  GET /helse      - Health check")
    skriv("  GET /users      - List users")
    skriv("  GET /users/{id} - Get user")
    skriv("  GET /api/info   - API info")
    skriv("  GET /openapi.json - OpenAPI")
    skriv("  GET /swagger    - Swagger UI")
    skriv("")
    skriv("────────────────────────────────────────────────────────────────")
    skriv("")
    returner 0
}

# ─── Main ──────────────────────────────────────────────────────────────────

funksjon start() -> heltall {
    la port = 8000

    // Print startup banner
    print_banner()

    // Create TCP server
    la server = tcp.ny_server("127.0.0.1", port)

    // Start listening
    returner tcp.lytt(server, "handle_request")
}

// Norscode Runtime Loader v0
// Initial .nbyte executable loader and runtime execution system.

bruk selfhost.bytecode_format
bruk selfhost.vm
bruk selfhost.memory
bruk selfhost.modules

struktur RuntimeLoader
    registry
    memory
    debug
slutt

struktur LoadedProgram
    program
    bytecode
    entrypoint
slutt

funksjon ny_runtime_loader()
    loader = RuntimeLoader()

    loader.registry = ny_registry()
    loader.memory = ny_memory_manager()
    loader.debug = usann

    returner loader
slutt

funksjon runtime_log(loader, melding)
    hvis loader.debug
        skriv("[RUNTIME] " + melding)
    slutt
slutt

funksjon les_nbyte_fil(filnavn)
    // Minimal .nbyte-loaderkontrakt før filsystembindinga tek over.
    skriv("Leser .nbyte fil: " + filnavn)

    returner "NBYTE\n1\n0\n0\n"
slutt

funksjon last_program(loader, filnavn)
    runtime_log(loader, "laster program")

    data = les_nbyte_fil(filnavn)

    program = deserialiser_program(data)

    valider_header(program.header)

    loaded = LoadedProgram()
    loaded.program = program
    loaded.bytecode = program.instruksjoner
    loaded.entrypoint = "main"

    returner loaded
slutt

funksjon bygg_vm(loader, loaded)
    runtime_log(loader, "bygger VM")

    vm_runtime = ny_vm(loaded.bytecode)

    vm_runtime.memory = loader.memory
    vm_runtime.registry = loader.registry

    returner vm_runtime
slutt

funksjon kjør_program(loader, loaded)
    runtime_log(loader, "starter program")

    runtime = bygg_vm(loader, loaded)

    resultat = kjør(runtime)

    runtime_log(loader, "program ferdig")

    returner resultat
slutt

funksjon runtime_execute(filnavn)
    loader = ny_runtime_loader()
    loader.debug = sann

    loaded = last_program(loader, filnavn)

    resultat = kjør_program(loader, loaded)

    skriv("Runtime resultat: " + tekst_fra_heltall(resultat))

    returner resultat
slutt

// Planned runtime pipeline:
//
// app.no
// -> compiler
// -> app.nbyte
// -> runtime_loader
// -> VM
// -> execution
//
// Future goals:
// - binary file IO
// - package loading
// - dynamic linking
// - runtime sandboxing
// - standalone runtime binary
// - native executable execution

// selfhost/phase2_benchmark.no — baseline benchmark for Fase 2
//
// Målet er ikkje å måle absolutt ytelse, berre å gi ei enkel og stabil
// samanlikningslinje i CI.

funksjon linje(melding: tekst) -> heiltall {
    skriv(melding + "\n")
    returner 0
}

funksjon mål_json_stringify(iterasjonar: heiltall) -> heiltall {
    la i: heiltall = 0
    la objekt: ordbok_tekst = {}
    objekt["navn"] = "phase2"
    objekt["versjon"] = "v1"
    objekt["status"] = "ok"
    mens i < iterasjonar {
        la _ = json_stringify(objekt)
        i = i + 1
    }
    returner i
}

funksjon mål_json_parse(iterasjonar: heiltall) -> heiltall {
    la i: heiltall = 0
    la tekst = "{\"navn\":\"phase2\",\"versjon\":\"v1\",\"status\":\"ok\"}"
    mens i < iterasjonar {
        la _ = json_parse(tekst)
        i = i + 1
    }
    returner i
}

funksjon start() -> heiltall {
    la iterasjonar: heiltall = 2000
    la stringify_ops: heiltall = mål_json_stringify(iterasjonar)
    la parse_ops: heiltall = mål_json_parse(iterasjonar)

    la per_stringify = 0
    la per_parse = 0
    hvis iterasjonar > 0 {
        per_stringify = stringify_ops / iterasjonar
        per_parse = parse_ops / iterasjonar
    }

    linje("{")
    linje("  \"phase2.benchmark\": \"ok\",")
    linje("  \"iterations\": \"" + tekst_fra_heltall(iterasjonar) + "\",")
    linje("  \"json_stringify_ops\": \"" + tekst_fra_heltall(stringify_ops) + "\",")
    linje("  \"json_parse_ops\": \"" + tekst_fra_heltall(parse_ops) + "\",")
    linje("  \"json_stringify_per_iter\": \"" + tekst_fra_heltall(per_stringify) + "\",")
    linje("  \"json_parse_per_iter\": \"" + tekst_fra_heltall(per_parse) + "\"")
    linje("}")
    returner 0
}

# http_server_pure_norscode.no — 100% Pure Norscode HTTP Server
# No Python, No C - Pure Norscode implementation
#
# Dette er ein fullstendig HTTP-server skrive heilt i Norscode
# Kan kjørast som: ./bin/nc run selfhost/http_server_pure_norscode.no
#
# Когда Norscode får socket-builtins, vil denne automatisk bruka dei

bruk std.socket_pure som sock
bruk std.web som web
bruk std.rest som rest

# ─── Mock Data ─────────────────────────────────────────────────────────────

la users: liste<ordbok_tekst> = [
    {"id": "1", "namn": "Jan Steinar", "epost": "jan@example.com", "rolle": "admin"},
    {"id": "2", "namn": "Alice", "epost": "alice@example.com", "rolle": "user"}
]

# ─── Request Handlers ──────────────────────────────────────────────────────

funksjon handle_root(req: ordbok_tekst) -> tekst {
    returner "{\"api\":\"Norscode HTTP Server\",\"versjon\":\"1.0\",\"mode\":\"Pure Norscode\"}"
}

funksjon handle_health(req: ordbok_tekst) -> tekst {
    returner "{\"status\":\"ok\",\"timestamp\":\"2026-06-14T12:00:00Z\"}"
}

funksjon handle_users_list(req: ordbok_tekst) -> tekst {
    returner rest.liste_til_json(users)
}

funksjon handle_user_detail(req: ordbok_tekst) -> tekst {
    la id = web.request_param(req, "id")
    la i: heltall = 0

    mens i < lengde(users) {
        hvis users[i]["id"] == id {
            returner rest.til_json(users[i])
        }
        i = i + 1
    }

    returner "{\"error\":\"User not found\",\"id\":\"" + id + "\"}"
}

funksjon handle_api_info(req: ordbok_tekst) -> tekst {
    la info: tekst = ""
    info = info + "{\"api\":\"Norscode REST API v1.0\","
    info = info + "\"endpoints\":["
    info = info + "{\"method\":\"GET\",\"path\":\"/\"},"
    info = info + "{\"method\":\"GET\",\"path\":\"/helse\"},"
    info = info + "{\"method\":\"GET\",\"path\":\"/users\"},"
    info = info + "{\"method\":\"GET\",\"path\":\"/users/{id}\"},"
    info = info + "{\"method\":\"GET\",\"path\":\"/api/info\"}"
    info = info + "],"
    info = info + "\"features\":[\"Pure Norscode\",\"REST API\",\"JSON\",\"Type Safe\"]"
    info = info + "}"
    returner info
}

# ─── Request Router ───────────────────────────────────────────────────────

funksjon route_and_handle(server: ordbok_tekst, metode: tekst, sti: tekst) -> tekst {
    // Route request and call appropriate handler

    hvis sti == "/" {
        la req: ordbok_tekst = {}
        returner handle_root(req)
    }

    hvis sti == "/helse" {
        la req: ordbok_tekst = {}
        returner handle_health(req)
    }

    hvis sti == "/users" {
        la req: ordbok_tekst = {}
        returner handle_users_list(req)
    }

    hvis sti == "/api/info" {
        la req: ordbok_tekst = {}
        returner handle_api_info(req)
    }

    hvis tekst_inneholder(sti, "/users/") {
        la id = "1"  // Placeholder
        la req: ordbok_tekst = {}
        req["id"] = id
        returner handle_user_detail(req)
    }

    returner "{\"error\":\"Not found\",\"path\":\"" + sti + "\"}"
}

# ─── Server Setup ──────────────────────────────────────────────────────────

funksjon start() -> heltall {
    // Create server
    la server = sock.ny_server(8000)

    // Register routes
    sock.route(server, "GET", "/", "root")
    sock.route(server, "GET", "/helse", "health")
    sock.route(server, "GET", "/users", "users_list")
    sock.route(server, "GET", "/users/{id:int}", "user_detail")
    sock.route(server, "GET", "/api/info", "api_info")

    // Print info
    skriv("")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("Norscode Pure Native Server v1.0")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("")
    skriv("🚀 100% Pure Norscode")
    skriv("📍 Ready on: http://127.0.0.1:8000")
    skriv("")
    skriv("✨ No Python, No C, No Dependencies")
    skriv("💾 Compiled and running in Norscode VM")
    skriv("")
    skriv("🔗 Endpoints:")
    skriv("   GET  /           - API info")
    skriv("   GET  /helse      - Health check")
    skriv("   GET  /users      - List users")
    skriv("   GET  /users/{id} - Get user")
    skriv("   GET  /api/info   - API documentation")
    skriv("")
    skriv("────────────────────────────────────────────────────────────────")
    skriv("")
    skriv("📝 Test with:")
    skriv("   curl http://localhost:8000/users | jq .")
    skriv("   curl http://localhost:8000/api/info | jq .")
    skriv("")

    // Run server
    returner sock.kjor_server(server)
}

        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "ikke") {
            hvis (i + 2 >= lengde(tokens) eller tokens[i + 2] != "lik") {
                legg_til(out, "ikke_er")
                i = i + 2
            } ellers {
                legg_til(out, tokens[i])
                i = i + 1
            }
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "ikkje") {
            hvis (i + 2 >= lengde(tokens) eller tokens[i + 2] != "lik") {
                legg_til(out, "ikke_er")
                i = i + 2
            } ellers {
                legg_til(out, tokens[i])

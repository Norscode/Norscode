        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "less" og tokens[i + 1] == "than") {
            legg_til(out, "less_than")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "not") {
            hvis (i + 2 >= lengde(tokens) eller tokens[i + 2] != "equal") {
                legg_til(out, "is_not")
                i = i + 2
            } ellers {
                legg_til(out, tokens[i])
                i = i + 1
            }
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "ikke" og tokens[i + 2] == "lik" og tokens[i + 3] == "med") {

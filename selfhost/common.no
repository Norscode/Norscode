        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "lik") {
            legg_til(out, "er_lik")
            i = i + 2
        } ellers {
            legg_til(out, tokens[i])
            i = i + 1
        }
    }
    returner out
}

funksjon slaa_operator_tokens(tokens: liste_tekst) -> liste_tekst {
    la out: liste_tekst = ny_tekst_liste()
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        hvis (i + 2 < lengde(tokens) og tokens[i] == "<" og tokens[i + 1] == "=" og tokens[i + 2] == ">") {
            legg_til(out, "<=>")
            i = i + 3
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "<" og tokens[i + 1] == "-" og tokens[i + 2] == ">") {
            legg_til(out, "<->")
            i = i + 3
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "<" og tokens[i + 1] == ">") {
            legg_til(out, "<>")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "!" og tokens[i + 1] == "=") {
            legg_til(out, "!=")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "<" og tokens[i + 1] == "=") {
            legg_til(out, "<=")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == ">" og tokens[i + 1] == "=") {
            legg_til(out, ">=")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "=" og tokens[i + 1] == "=") {
            legg_til(out, "==")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "&" og tokens[i + 1] == "&") {
            legg_til(out, "&&")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "|" og tokens[i + 1] == "|") {
            legg_til(out, "||")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "-" og tokens[i + 1] == ">") {
            legg_til(out, "->")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "=" og tokens[i + 1] == ">") {
            legg_til(out, "=>")
            i = i + 2
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "<" og tokens[i + 1] == "-") {
            legg_til(out, "<-")
            i = i + 2
        } ellers {
            legg_til(out, tokens[i])
            i = i + 1
        }
    }
    returner out
}

# ─── Expr-kompilator: Shunting-yard ──────────────────────────────────────────

funksjon normaliser_op(tok: tekst) -> tekst {
    la norsk: tekst = normaliser_norsk_token(tok)
    hvis (norsk == "ADD") { returner "ADD" }
    hvis (norsk == "SUB") { returner "SUB" }
    hvis (norsk == "MUL") { returner "MUL" }
    hvis (norsk == "DIV") { returner "DIV" }
    hvis (norsk == "MOD") { returner "MOD" }
    hvis (norsk == "EQ") { returner "EQ" }
    hvis (norsk == "NEQ") { returner "NEQ" }
    hvis (norsk == "GT") { returner "GT" }
    hvis (norsk == "LT") { returner "LT" }
    hvis (norsk == "AND") { returner "AND" }
    hvis (norsk == "OR") { returner "OR" }
    hvis (norsk == "NOT") { returner "UNOT" }
    hvis (er_implies_hoyre(tok)) { returner "IMPLIES" }
    hvis (er_implies_venstre(tok)) { returner "IMPLIED_BY" }
    hvis (er_ekvivalens(tok)) { returner "EQUIV" }
    hvis (tok == "+") { returner "ADD" }
    hvis (tok == "-") { returner "SUB" }
    hvis (tok == "*") { returner "MUL" }
    hvis (tok == "/") { returner "DIV" }
    hvis (tok == "%") { returner "MOD" }
    hvis (tok == ">") { returner "GT" }
    hvis (tok == "<") { returner "LT" }
    hvis (tok == ">=") { returner "GTE" }
    hvis (tok == "<=") { returner "LTE" }
    hvis (tok == "==") { returner "EQ" }
    hvis (tok == "!=" eller tok == "<>") { returner "NEQ" }
    hvis (tok == "&&" eller tok == "og" eller tok == "and") { returner "AND" }
    hvis (tok == "||" eller tok == "eller" eller tok == "or") { returner "OR" }
    hvis (tok == "!" eller tok == "ikkje" eller tok == "ikke" eller tok == "not") { returner "UNOT" }
    hvis (tok == "xor") { returner "XOR" }
    hvis (tok == "xnor" eller tok == "xeller_ikke") { returner "XNOR" }
    hvis (tok == "nand" eller tok == "and_not" eller tok == "og_ikke") { returner "NAND" }
    hvis (tok == "nor" eller tok == "or_not" eller tok == "eller_ikke") { returner "NOR" }
    hvis (tok == "mod" eller tok == "modulo" eller tok == "mod_of" eller tok == "modulo_of" eller tok == "remainder" eller tok == "remainder_of") { returner "MOD" }
    hvis (tok == "storre_enn") { returner "GT" }
    hvis (tok == "mindre_enn") { returner "LT" }
    hvis (tok == "storre_enn_eller_lik" eller tok == "storre_eller_lik" eller tok == "er_storre_eller_lik" eller tok == "er_storre_enn_eller_lik" eller tok == "erstorreellerlik" eller tok == "erstorreennellerlik" eller tok == "storre_lik" eller tok == "er_storre_lik" eller tok == "storreellerlik" eller tok == "storreennellerlik") { returner "GTE" }
    hvis (tok == "mindre_enn_eller_lik" eller tok == "mindre_eller_lik" eller tok == "er_mindre_eller_lik" eller tok == "er_mindre_enn_eller_lik" eller tok == "ermindreellerlik" eller tok == "ermindreennellerlik" eller tok == "mindre_lik" eller tok == "er_mindre_lik" eller tok == "mindreellerlik" eller tok == "mindreennellerlik") { returner "LTE" }
    hvis (tok == "ermindreenn" eller tok == "mindreenn") { returner "LT" }
    hvis (tok == "erstorreenn" eller tok == "storreenn") { returner "GT" }
    hvis (tok == "ermindrelik" eller tok == "mindrelik") { returner "LTE" }
    hvis (tok == "erstorrelik" eller tok == "storrelik") { returner "GTE" }
    hvis (tok == "greater_or_equal" eller tok == "greater_equal" eller tok == "greater_than_or_equal" eller tok == "greater_than_or_equal_to" eller tok == "is_greater_or_equal" eller tok == "is_greater_or_equal_to" eller tok == "is_greater_than_or_equal" eller tok == "is_greater_than_or_equal_to") { returner "GTE" }
    hvis (tok == "less_equal" eller tok == "less_than_or_equal" eller tok == "less_than_or_equal_to" eller tok == "is_less_than_or_equal" eller tok == "is_less_than_or_equal_to" eller tok == "is_less_or_equal" eller tok == "is_less_or_equal_to") { returner "LTE" }
    hvis (tok == "greater_than" eller tok == "is_greater_than") { returner "GT" }
    hvis (tok == "less_than" eller tok == "is_less_than") { returner "LT" }
    hvis (tok == "is_not" eller tok == "is_not_equal_to" eller tok == "not_equal_to" eller tok == "isnt") { returner "NEQ" }
    hvis (tok == "eq" eller tok == "equal_to" eller tok == "is_equal_to") { returner "EQ" }
    hvis (tok == "neq") { returner "NEQ" }
    returner ""
}

funksjon prec_uttrykk(norm_op: tekst) -> heltall {
    # Aritmetikk > samanlikning > UNOT > AND > OR
    hvis (norm_op == "MUL" eller norm_op == "DIV" eller norm_op == "MOD") { returner 7 }
    hvis (norm_op == "ADD" eller norm_op == "SUB") { returner 6 }
    hvis (norm_op == "GT" eller norm_op == "LT" eller norm_op == "GTE" eller norm_op == "LTE") { returner 5 }
    hvis (norm_op == "EQ" eller norm_op == "NEQ") { returner 5 }
    hvis (norm_op == "UNOT" eller norm_op == "NOT") { returner 4 }
    hvis (norm_op == "AND" eller norm_op == "XOR" eller norm_op == "XNOR" eller norm_op == "NAND" eller norm_op == "NOR") { returner 3 }
    hvis (norm_op == "OR" eller norm_op == "IMPLIES" eller norm_op == "IMPLIED_BY" eller norm_op == "EQUIV") { returner 2 }
    returner 0
}

funksjon emit_op_ir(norm_op: tekst, ir: liste_tekst) -> heltall {
    hvis (norm_op == "ADD") { legg_til(ir, "ADD") }
    ellers hvis (norm_op == "SUB") { legg_til(ir, "SUB") }
    ellers hvis (norm_op == "MUL") { legg_til(ir, "MUL") }
    ellers hvis (norm_op == "DIV") { legg_til(ir, "DIV") }
    ellers hvis (norm_op == "MOD") { legg_til(ir, "MOD") }
    ellers hvis (norm_op == "GT") { legg_til(ir, "GT") }
    ellers hvis (norm_op == "LT") { legg_til(ir, "LT") }
    ellers hvis (norm_op == "GTE") { legg_til(ir, "LT") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "LTE") { legg_til(ir, "GT") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "EQ") { legg_til(ir, "EQ") }
    ellers hvis (norm_op == "NEQ") { legg_til(ir, "EQ") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "AND") { legg_til(ir, "AND") }
    ellers hvis (norm_op == "OR") { legg_til(ir, "OR") }
    ellers hvis (norm_op == "UNOT" eller norm_op == "NOT") { legg_til(ir, "NOT") }
    ellers hvis (norm_op == "XOR") { legg_til(ir, "EQ") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "XNOR") { legg_til(ir, "EQ") }
    ellers hvis (norm_op == "NAND") { legg_til(ir, "AND") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "NOR") { legg_til(ir, "OR") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "IMPLIES") {
        legg_til(ir, "SWAP")
        legg_til(ir, "NOT")
        legg_til(ir, "SWAP")
        legg_til(ir, "OR")
    }
    ellers hvis (norm_op == "IMPLIED_BY") {
        legg_til(ir, "NOT")
        legg_til(ir, "OR")
    }
    ellers hvis (norm_op == "EQUIV") {
        legg_til(ir, "EQ")
    }
    returner 0
}

funksjon uttrykk_til_ir_kjerne(tokens: liste_tekst) -> liste_tekst {
    la ir: liste_tekst = ny_tekst_liste()
    la op_stack: liste_tekst = ny_tekst_liste()
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        la tok: tekst = tokens[i]
        la norm: tekst = normaliser_op(tok)
        la er_tall: bool = er_heltall_token(tok)
        la håndtert: bool = usann
        hvis (er_unary_minus(tokens, i)) {
            la verdi: tekst = tokens[i + 1]
            legg_til(ir, "PUSH")
            legg_til(ir, verdi)
            legg_til(ir, "PUSH")
            legg_til(ir, "0")
            legg_til(ir, "SWAP")
            legg_til(ir, "SUB")
            i = i + 2
            håndtert = sann
            fortsett
        }
        hvis (er_unary_plus(tokens, i)) {
            la verdi2: tekst = tokens[i + 1]
            legg_til(ir, "PUSH")
            legg_til(ir, verdi2)
            i = i + 2
            håndtert = sann
            fortsett
        }
        hvis (ikke håndtert og er_tall) {
            legg_til(ir, "PUSH")
            legg_til(ir, tok)
            håndtert = sann
        }
        hvis (ikke håndtert og er_bool_literal(tok)) {
            legg_til(ir, "PUSH")
            legg_til(ir, miljo_verdi_for_tok(tok, [], []))
            håndtert = sann
        }
        hvis (ikke håndtert og (tok == "(" eller tok == "{" eller tok == "[")) {
            legg_til(op_stack, "(")
            håndtert = sann
        }
        hvis (ikke håndtert og (tok == ")" eller tok == "}" eller tok == "]")) {
            la funnet_paren: bool = usann
            mens (lengde(op_stack) > 0) {
                la topp: tekst = op_stack[lengde(op_stack) - 1]
                hvis (topp == "(") {
                    la _ = pop_siste(op_stack)
                    funnet_paren = sann
                    bryt
                }
                la popped: tekst = pop_siste(op_stack)
                la _ = emit_op_ir(popped, ir)
            }
            hvis (ikke funnet_paren) {
                kast "parse_feil: ubalansert ')'"
            }
            håndtert = sann
        }
        hvis (ikke håndtert og norm != "") {
            hvis (norm == "UNOT") {
                legg_til(op_stack, "NOT")
            } ellers {
                mens (lengde(op_stack) > 0) {
                    la topp: tekst = op_stack[lengde(op_stack) - 1]
                    hvis (topp == "(") { bryt }
                    la topp_prec: heltall = prec_uttrykk(topp)
                    la cur_prec: heltall = prec_uttrykk(norm)
                    la skal_poppe: bool = topp_prec >= cur_prec
                    hvis (topp == "NOT") { skal_poppe = topp_prec > cur_prec }
                    hvis (ikke skal_poppe) { bryt }
                    la popped: tekst = pop_siste(op_stack)
                    la _ = emit_op_ir(popped, ir)
                }
                legg_til(op_stack, norm)
            }
            håndtert = sann
        }
        i = i + 1
    }
    mens (lengde(op_stack) > 0) {
        la topp: tekst = op_stack[lengde(op_stack) - 1]
        hvis (topp == "(") {
            kast "parse_feil: ubalansert '('"
        }
        la popped: tekst = pop_siste(op_stack)
        la _ = emit_op_ir(popped, ir)
    }
    returner ir
}

funksjon uttrykk_til_ir(tokens: liste_tekst) -> liste_tekst {
    la ir: liste_tekst = uttrykk_til_ir_kjerne(tokens)
    legg_til(ir, "PRINT")
    legg_til(ir, "HALT")
    returner ir
}

funksjon miljo_lengde_ok(namn: liste_tekst, verdiar: liste_heltall) -> bool {
    returner lengde(namn) == lengde(verdiar)
}

funksjon heltall_add(a: heltall, b: heltall) -> heltall {
    returner a + b
}

funksjon heltall_mul(a: heltall, b: heltall) -> heltall {
    la sum: heltall = 0
    la i: heltall = 0
    mens (i < b) {
        sum = sum + a
        i = i + 1
    }
    returner sum
}

funksjon bool_tok_er_sann(tok: tekst) -> bool {
    hvis (tok == "sann" eller tok == "sant" eller tok == "ja" eller tok == "on" eller tok == "yes" eller tok == ("t" + "rue")) { returner sann }
    hvis (tok == "enabled" eller tok == "active" eller tok == "truthy" eller tok == "affirmative" eller tok == "affirm") { returner sann }
    hvis (tok == "approved" eller tok == "accepted" eller tok == "confirmed" eller tok == "pass" eller tok == "success") { returner sann }
    hvis (tok == "allow" eller tok == "permit" eller tok == "valid" eller tok == "ok" eller tok == "ready") { returner sann }
    hvis (tok == "safe" eller tok == "secure" eller tok == "trusted" eller tok == "open" eller tok == "public") { returner sann }
    hvis (tok == "visible" eller tok == "present" eller tok == "online" eller tok == "connected" eller tok == "available") { returner sann }
    hvis (tok == "reachable" eller tok == "working" eller tok == "stable" eller tok == "correct" eller tok == "complete") { returner sann }
    hvis (tok == "clean" eller tok == "up" eller tok == "alive" eller tok == "awake" eller tok == "healthy") { returner sann }
    hvis (tok == "synced") { returner sann }
    returner usann
}

funksjon bool_tok_er_usann(tok: tekst) -> bool {
    hvis (tok == "usann" eller tok == "usant" eller tok == "nei" eller tok == "off" eller tok == "no" eller tok == ("f" + "alse")) { returner sann }
    hvis (tok == "disabled" eller tok == "inactive" eller tok == "falsy" eller tok == "negative" eller tok == "deny") { returner sann }
    hvis (tok == "rejected" eller tok == "declined" eller tok == "denied" eller tok == "fail" eller tok == "failure") { returner sann }
    hvis (tok == "block" eller tok == "forbid" eller tok == "invalid" eller tok == "not_ok" eller tok == "not_ready") { returner sann }
    hvis (tok == "unsafe" eller tok == "insecure" eller tok == "untrusted" eller tok == "closed" eller tok == "private") { returner sann }
    hvis (tok == "hidden" eller tok == "absent" eller tok == "offline" eller tok == "disconnected" eller tok == "unavailable") { returner sann }
    hvis (tok == "unreachable" eller tok == "broken" eller tok == "unstable" eller tok == "incorrect" eller tok == "incomplete") { returner sann }
    hvis (tok == "dirty" eller tok == "down" eller tok == "dead" eller tok == "asleep" eller tok == "unhealthy") { returner sann }
    hvis (tok == "unsynced") { returner sann }
    returner usann
}

funksjon er_bool_literal(tok: tekst) -> bool {
    returner bool_tok_er_sann(tok) eller bool_tok_er_usann(tok)
}

funksjon miljo_verdi_for_tok(tok: tekst, namn: liste_tekst, verdiar: liste_heltall) -> tekst {
    la i: heltall = 0
    mens (i < lengde(namn)) {
        hvis (tok == namn[i]) {
            returner tekst_fra_heltall(verdiar[i])
        }
        i = i + 1
    }
    hvis (bool_tok_er_sann(tok)) { returner "1" }
    hvis (bool_tok_er_usann(tok)) { returner "0" }
    returner ""
}

funksjon substitutt_var_i_tokens(tokens: liste_tekst, namn: liste_tekst, verdiar: liste_heltall) -> liste_tekst {
    la out: liste_tekst = ny_tekst_liste()
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        la tok: tekst = tokens[i]
        hvis (er_heltall_token(tok)) {
            legg_til(out, tok)
        } ellers {
            la erstatning: tekst = miljo_verdi_for_tok(tok, namn, verdiar)
            hvis (erstatning != "") {
                legg_til(out, erstatning)
            } ellers {
                legg_til(out, tok)
            }
        }
        i = i + 1
    }
    returner out
}

funksjon valider_uttrykk_tokens(tokens: liste_tekst) -> tekst {
    la depth: heltall = 0
    la i: heltall = 0
    la forrige_verdi: bool = usann
    mens (i < lengde(tokens)) {
        la tok: tekst = tokens[i]
        hvis (tok == "(" eller tok == "{" eller tok == "[") {
            depth = depth + 1
            forrige_verdi = usann
            i = i + 1
            fortsett
        }
        hvis (tok == ")" eller tok == "}" eller tok == "]") {
            hvis (ikke forrige_verdi) {
                returner "/* feil: mangler verdi før ) ved token " + tekst_fra_heltall(i) + " */"
            }
            depth = depth - 1
            hvis (depth < 0) {
                returner "/* feil: ubalansert ) i uttrykk ved token " + tekst_fra_heltall(i) + " */"
            }
            forrige_verdi = sann
            i = i + 1
            fortsett
        }
        hvis (er_unary_minus(tokens, i) eller er_unary_plus(tokens, i)) {
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: uttrykket avsluttes med operator ved token " + tekst_fra_heltall(i) + " */"
            }
            forrige_verdi = sann
            i = i + 2
            fortsett
        }
        la norm: tekst = normaliser_op(tok)
        hvis (er_heltall_token(tok)) {
            forrige_verdi = sann
            i = i + 1
            fortsett
        }
        hvis (er_bool_literal(tok)) {
            forrige_verdi = sann
            i = i + 1
            fortsett
        }
        hvis (norm == "UNOT") {
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: uttrykket avsluttes med operator ved token " + tekst_fra_heltall(i) + " */"
            }
            // ikkje er unær prefix — ventar framleis ein verdi (eller '(') etterpå
            forrige_verdi = usann
            i = i + 1
            fortsett
        }
        hvis (norm != "") {
            hvis (ikke forrige_verdi) {
                returner "/* feil: mangler verdi før operator ved token " + tekst_fra_heltall(i) + " */"
            }
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: uttrykket avsluttes med operator ved token " + tekst_fra_heltall(i) + " */"
            }
            la neste_norm: tekst = normaliser_op(tokens[i + 1])
            hvis (neste_norm != "" og neste_norm != "UNOT") {
                returner "/* feil: uttrykket avsluttes med operator ved token " + tekst_fra_heltall(i + 1) + " */"
            }
            forrige_verdi = usann
            i = i + 1
            fortsett
        }
        returner "/* feil: ukjent token/navn i uttrykk " + tok + " ved token " + tekst_fra_heltall(i) + " */"
    }
    hvis (depth > 0) {
        returner "/* feil: mangler ) i uttrykk ved token 0 */"
    }
  hvis (lengde(tokens) > 0 og ikke forrige_verdi) {
        returner "/* feil: uttrykket avsluttes med operator ved token " + tekst_fra_heltall(lengde(tokens) - 1) + " */"
    }
    returner ""
}

funksjon ir_instr_count(ir: liste_tekst) -> heltall {
    la pc: heltall = 0
    la i: heltall = 0
    mens (i < lengde(ir)) {
        hvis (ir[i] == "PUSH" eller ir[i] == "JZ" eller ir[i] == "JMP" eller ir[i] == "LABEL") {
            i = i + 2
        } ellers {
            i = i + 1
        }
        pc = pc + 1
    }
    returner pc
}

funksjon er_hvis_tok(tok: tekst) -> bool {
    hvis (tok == "hvis" eller tok == "if") { returner sann }
    returner usann
}

funksjon ir_append_hvis_ir_relokert(ir: liste_tekst, expr: tekst, namn: liste_tekst, verdiar: liste_heltall) {
    disasm_hvis_ir_til(ir, expr, namn, verdiar, usann)
}

funksjon ir_append_expr_ir(ir: liste_tekst, expr: tekst, namn: liste_tekst, verdiar: liste_heltall) {
    la t: tekst = tekst_trim(expr)
    hvis (expr_er_hvis(t)) {
        ir_append_hvis_ir_relokert(ir, t, namn, verdiar)
        returner
    }
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la tokens2: liste_tekst = substitutt_var_i_tokens(tokens, namn, verdiar)
    la del: liste_tekst = uttrykk_til_ir_kjerne(tokens2)
    la j: heltall = 0
    mens (j < lengde(del)) {
        legg_til(ir, del[j])
        j = j + 1
    }
}

funksjon ir_set_arg(ir: liste_tekst, idx: heltall, verdi: tekst) {
    ir[idx] = verdi
}

funksjon expr_er_hvis(expr: tekst) -> bool {
    la t: tekst = tekst_trim(expr)
    hvis (match_prefiks(t, 0, "hvis")) {
        hvis (lengde(t) > 4 og tekst_del(t, 4, 5) == " ") { returner sann }
    }
    hvis (match_prefiks(t, 0, "if")) {
        hvis (lengde(t) > 2 og tekst_del(t, 2, 3) == " ") { returner sann }
    }
    returner usann
}

funksjon finn_token_dybde0(tokens: liste_tekst, start: heltall, kw: tekst) -> heltall {
    la depth: heltall = 0
    la i: heltall = start
    mens (i < lengde(tokens)) {
        la tok: tekst = tokens[i]
        hvis (tok == "(" eller tok == "{" eller tok == "[") { depth = depth + 1 }
        hvis (tok == ")" eller tok == "}" eller tok == "]") { depth = depth - 1 }
        hvis (depth == 0 og tok == kw) { returner i }
        i = i + 1
    }
    returner -1
}

funksjon tokens_til_tekst(tokens: liste_tekst, fra: heltall, slutt: heltall) -> tekst {
    la out: tekst = ""
    la i: heltall = fra
    mens (i < slutt) {
        hvis (out == "") { out = tokens[i] } ellers { out = out + " " + tokens[i] }
        i = i + 1
    }
    returner out
}

funksjon er_elif_tok(tok: tekst) -> bool {
    hvis (tok == "ellers_hvis") { returner sann }
    hvis (tok == "elif") { returner sann }
    hvis (tok == "elseif") { returner sann }
    hvis (tok == "elsif") { returner sann }
    returner usann
}

funksjon er_ellers_tok(tok: tekst) -> bool {
    hvis (tok == "ellers") { returner sann }
    hvis (tok == "else") { returner sann }
    returner usann
}

funksjon disasm_hvis_ir_til(ir: liste_tekst, expr: tekst, namn: liste_tekst, verdiar: liste_heltall, avslutt: bool) {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la start: heltall = 0
    hvis (lengde(tokens) > 0 og (tokens[0] == "hvis" eller tokens[0] == "if")) { start = 1 }
    la conds: liste_tekst = ny_tekst_liste()
    la thens: liste_tekst = ny_tekst_liste()
    la else_tekst: tekst = ""
    la pos: heltall = start
    la fortsett_parse: bool = sann
    mens (fortsett_parse) {
        la da_i: heltall = finn_token_dybde0(tokens, pos, "da")
        hvis (da_i < 0) { da_i = finn_token_dybde0(tokens, pos, "then") }
        hvis (da_i < 0) { kast "parse_feil: mangler da/then i hvis" }
        la cond: tekst = tokens_til_tekst(tokens, pos, da_i)
        la after_da: heltall = da_i + 1
        la kw_i: heltall = lengde(tokens)
        la i2: heltall = after_da
        la hvis_dybde: heltall = 0
        mens (i2 < lengde(tokens)) {
            la tok2: tekst = tokens[i2]
            hvis (er_hvis_tok(tok2)) {
                hvis_dybde = hvis_dybde + 1
            } ellers hvis (hvis_dybde == 0 og er_elif_tok(tok2)) {
                kw_i = i2
                bryt
            } ellers hvis (hvis_dybde == 0 og er_ellers_tok(tok2)) {
                kw_i = i2
                bryt
            } ellers hvis (hvis_dybde > 0 og er_ellers_tok(tok2)) {
                hvis_dybde = hvis_dybde - 1
            }
            i2 = i2 + 1
        }
        la thenpart: tekst = tokens_til_tekst(tokens, after_da, kw_i)
        legg_til(conds, cond)
        legg_til(thens, thenpart)
        hvis (kw_i >= lengde(tokens)) {
            fortsett_parse = usann
        } ellers hvis (er_ellers_tok(tokens[kw_i])) {
            else_tekst = tokens_til_tekst(tokens, kw_i + 1, lengde(tokens))
            fortsett_parse = usann
        } ellers {
            pos = kw_i + 1
        }
    }
    la jz_idx: liste_heltall = ny_heltall_liste()
    la jmp_idx: liste_heltall = ny_heltall_liste()
    la label_pcs: liste_heltall = ny_heltall_liste()
    la bi: heltall = 0
    mens (bi < lengde(conds)) {
        ir_append_expr_ir(ir, conds[bi], namn, verdiar)
        legg_til(ir, "JZ")
        legg_til(ir, "0")
        legg_til(jz_idx, lengde(ir) - 1)
        ir_append_expr_ir(ir, thens[bi], namn, verdiar)
        legg_til(ir, "JMP")
        legg_til(ir, "0")
        legg_til(jmp_idx, lengde(ir) - 1)
        la lbl: heltall = ir_instr_count(ir)
        legg_til(ir, "LABEL")
        legg_til(ir, tekst_fra_heltall(lbl))
        legg_til(label_pcs, lbl)
        bi = bi + 1
    }
    hvis (else_tekst != "") {
        ir_append_expr_ir(ir, else_tekst, namn, verdiar)
    }
    la merge_pc: heltall = ir_instr_count(ir)
    hvis (lengde(conds) > 1) {
        legg_til(ir, "LABEL")
        legg_til(ir, tekst_fra_heltall(merge_pc))
    }
    la end_pc: heltall = ir_instr_count(ir)
    legg_til(ir, "LABEL")
    legg_til(ir, tekst_fra_heltall(end_pc))
    la ji: heltall = 0
    mens (ji < lengde(jz_idx)) {
        la dest: heltall = label_pcs[ji]
        ir_set_arg(ir, jz_idx[ji], tekst_fra_heltall(dest))
        ji = ji + 1
    }
    la mj: heltall = 0
    mens (mj < lengde(jmp_idx)) {
        la dest: heltall = end_pc
        hvis (lengde(conds) > 1 og mj > 0) {
            dest = merge_pc
        }
        ir_set_arg(ir, jmp_idx[mj], tekst_fra_heltall(dest))
        mj = mj + 1
    }
    hvis (avslutt) {
        legg_til(ir, "PRINT")
        legg_til(ir, "HALT")
    }
}

funksjon disasm_hvis_ir(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> liste_tekst {
    la ir: liste_tekst = ny_tekst_liste()
    disasm_hvis_ir_til(ir, expr, namn, verdiar, sann)
    returner ir
}

funksjon disasm_uttrykk_internal(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> tekst {
    la t: tekst = tekst_trim(expr)
    hvis (expr_er_hvis(t)) {
        returner formater_ir_flat(disasm_hvis_ir(t, namn, verdiar))
    }
    la tokens: liste_tekst = tokeniser_uttrykk(t)
    la tokens2: liste_tekst = substitutt_var_i_tokens(tokens, namn, verdiar)
    la err: tekst = valider_uttrykk_tokens(tokens2)
    hvis (err != "") { returner err }
    returner formater_ir_flat(uttrykk_til_ir(tokens2))
}

funksjon disasm_uttrykk(expr: tekst) -> tekst {
    returner disasm_uttrykk_internal(expr, ny_tekst_liste(), ny_heltall_liste())
}

funksjon disasm_uttrykk_med_miljo(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> tekst {
    hvis (ikke miljo_lengde_ok(namn, verdiar)) {
        returner "/* feil: navn/miljø-verdier må ha samme lengde */"
    }
    returner disasm_uttrykk_internal(expr, namn, verdiar)
}

funksjon kjor_ir_til_heltall(ir: liste_tekst) -> heltall {
    la stack: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(ir)) {
        la op: tekst = ir[i]
        hvis (op == "PUSH") {
            legg_til(stack, heltall_fra_tekst(ir[i + 1]))
            i = i + 2
        } ellers hvis (op == "ADD") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            legg_til(stack, a + b)
            i = i + 1
        } ellers hvis (op == "SUB") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            legg_til(stack, a - b)
            i = i + 1
        } ellers hvis (op == "MUL") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            legg_til(stack, heltall_mul(a, b))
            i = i + 1
        } ellers hvis (op == "DIV") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            legg_til(stack, a / b)
            i = i + 1
        } ellers hvis (op == "MOD") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            legg_til(stack, a % b)
            i = i + 1
        } ellers hvis (op == "EQ") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            hvis (a == b) { legg_til(stack, 1) } ellers { legg_til(stack, 0) }
            i = i + 1
        } ellers hvis (op == "GT") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            hvis (a > b) { legg_til(stack, 1) } ellers { legg_til(stack, 0) }
            i = i + 1
        } ellers hvis (op == "LT") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            hvis (a < b) { legg_til(stack, 1) } ellers { legg_til(stack, 0) }
            i = i + 1
        } ellers hvis (op == "NOT") {
            la a: heltall = stack[lengde(stack) - 1]
            la _ = pop_siste(stack)
            hvis (a == 0) { legg_til(stack, 1) } ellers { legg_til(stack, 0) }
            i = i + 1
        } ellers hvis (op == "AND") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            hvis (ikke (a == 0) og ikke (b == 0)) { legg_til(stack, 1) } ellers { legg_til(stack, 0) }
            i = i + 1
        } ellers hvis (op == "OR") {
            la b: heltall = stack[lengde(stack) - 1]
            la a: heltall = stack[lengde(stack) - 2]
            la _ = pop_siste(stack)
            la _ = pop_siste(stack)
            hvis (ikke (a == 0) eller ikke (b == 0)) { legg_til(stack, 1) } ellers { legg_til(stack, 0) }
            i = i + 1
        } ellers hvis (op == "JZ" eller op == "JMP" eller op == "LABEL") {
            i = i + 2
        } ellers hvis (op == "PRINT" eller op == "HALT") {
            bryt
        } ellers {
            i = i + 1
        }
    }
    returner stack[lengde(stack) - 1]
}

funksjon st_pop2(st: liste_heltall) -> liste_heltall {
    la ny: liste_heltall = ny_heltall_liste()
    la i: heltall = 0
    la slutt: heltall = lengde(st) - 2
    mens (i < slutt) {
        legg_til(ny, st[i])
        i = i + 1
    }
    returner ny
}

funksjon st_push1(st: liste_heltall, verdi: heltall) -> liste_heltall {
    la ny: liste_heltall = st_pop2(st)
    legg_til(ny, verdi)
    returner ny
}

funksjon ir_expr_debug(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la ir: liste_tekst = uttrykk_til_ir_kjerne(tokens)
    la out: tekst = ""
    la i: heltall = 0
    mens (i < lengde(ir)) {
        hvis (out == "") { out = ir[i] } ellers { out = out + "," + ir[i] }
        i = i + 1
    }
    returner out
}

funksjon eval_ir_ops(ops: liste_tekst, verdier: liste_heltall) -> heltall {
    la s0: heltall = 0
    la s1: heltall = 0
    la sp: heltall = 0
    la i: heltall = 0
    mens (i < lengde(ops)) {
        la op: tekst = ops[i]
        hvis (op == "PUSH") {
            hvis (sp == 0) {
                s0 = verdier[i]
                sp = 1
            } ellers {
                s1 = verdier[i]
                sp = 2
            }
        } ellers hvis (op == "ADD") {
            s0 = heltall_add(s0, s1)
            sp = 1
        } ellers hvis (op == "SUB") {
            s0 = s0 - s1
            sp = 1
        } ellers hvis (op == "MUL") {
            s0 = heltall_mul(s0, s1)
            sp = 1
        } ellers hvis (op == "DIV") {
            s0 = s0 / s1
            sp = 1
        } ellers hvis (op == "MOD") {
            s0 = s0 % s1
            sp = 1
        } ellers hvis (op == "EQ") {
            hvis (s0 == s1) { s0 = 1 } ellers { s0 = 0 }
            sp = 1
        } ellers hvis (op == "GT") {
            hvis (s0 > s1) { s0 = 1 } ellers { s0 = 0 }
            sp = 1
        } ellers hvis (op == "LT") {
            hvis (s0 < s1) { s0 = 1 } ellers { s0 = 0 }
            sp = 1
        } ellers hvis (op == "NOT") {
            hvis (s0 == 0) { s0 = 1 } ellers { s0 = 0 }
            sp = 1
        } ellers hvis (op == "AND") {
            hvis (ikke (s0 == 0) og ikke (s1 == 0)) { s0 = 1 } ellers { s0 = 0 }
            sp = 1
        } ellers hvis (op == "OR") {
            hvis (ikke (s0 == 0) eller ikke (s1 == 0)) { s0 = 1 } ellers { s0 = 0 }
            sp = 1
        }
        i = i + 1
    }
    returner s0
}

funksjon eval_hvis_heltall(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> heltall {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la start: heltall = 0
    hvis (lengde(tokens) > 0 og (tokens[0] == "hvis" eller tokens[0] == "if")) { start = 1 }
    la da_i: heltall = finn_token_dybde0(tokens, start, "da")
    hvis (da_i < 0) { da_i = finn_token_dybde0(tokens, start, "then") }
    hvis (da_i < 0) { returner 0 }
    la cond: tekst = tokens_til_tekst(tokens, start, da_i)
    la after_da: heltall = da_i + 1
    la kw_i: heltall = lengde(tokens)
    la i2: heltall = after_da
    mens (i2 < lengde(tokens)) {
        hvis (er_elif_tok(tokens[i2]) eller er_ellers_tok(tokens[i2])) {
            kw_i = i2
            bryt
        }
        i2 = i2 + 1
    }
    la thenpart: tekst = tokens_til_tekst(tokens, after_da, kw_i)
    la else_tekst: tekst = ""
    hvis (kw_i < lengde(tokens) og er_ellers_tok(tokens[kw_i])) {
        else_tekst = tokens_til_tekst(tokens, kw_i + 1, lengde(tokens))
    }
    hvis (eval_uttrykk_heltall_kjerne(cond, namn, verdiar) != 0) {
        returner eval_uttrykk_heltall_kjerne(thenpart, namn, verdiar)
    }
    hvis (else_tekst != "") {
        returner eval_uttrykk_heltall_kjerne(else_tekst, namn, verdiar)
    }
    returner 0
}

funksjon eval_uttrykk_heltall_kjerne(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> heltall {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la tokens2: liste_tekst = substitutt_var_i_tokens(tokens, namn, verdiar)
    la ir: liste_tekst = uttrykk_til_ir_kjerne(tokens2)
    la ops: liste_tekst = ny_tekst_liste()
    la verdier: liste_heltall = ny_heltall_liste()
    la i: heltall = 0
    mens (i < lengde(ir)) {
        la op: tekst = ir[i]
        hvis (op_krever_arg(op)) {
            legg_til(ops, op)
            legg_til(verdier, heltall_fra_tekst(ir[i + 1]))
            i = i + 2
        } ellers {
            legg_til(ops, op)
            legg_til(verdier, 0)
            i = i + 1
        }
    }
    returner eval_ir_ops(ops, verdier)
}

funksjon eval_uttrykk_heltall(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> heltall {
    hvis (expr_er_hvis(expr)) {
        returner eval_hvis_heltall(expr, namn, verdiar)
    }
    returner eval_uttrykk_heltall_kjerne(expr, namn, verdiar)
}

funksjon skript_sett_var(namn: liste_tekst, verdiar: liste_heltall, varnavn: tekst, verdi: heltall) -> heltall {
    la i: heltall = 0
    la funnet: bool = usann
    mens (i < lengde(namn)) {
        hvis (namn[i] == varnavn) {
            verdiar[i] = verdi
            funnet = sann
            bryt
        }
        i = i + 1
    }
    hvis (ikke funnet) {
        legg_til(namn, varnavn)
        legg_til(verdiar, verdi)
    }
    returner 0
}

funksjon skript_stmt_expr(st: tekst) -> tekst {
    la s: tekst = tekst_trim(st)
    hvis (builtin.starts_with(s, "la ")) { returner builtin.slice(s, 3, lengde(s)) }
    hvis (builtin.starts_with(s, "let ")) { returner builtin.slice(s, 4, lengde(s)) }
    hvis (builtin.starts_with(s, "declare ")) { returner builtin.slice(s, 8, lengde(s)) }
    hvis (builtin.starts_with(s, "const ")) { returner builtin.slice(s, 6, lengde(s)) }
    hvis (builtin.starts_with(s, "var ")) { returner builtin.slice(s, 4, lengde(s)) }
    returner s
}

funksjon skript_expr_eller_return(s: tekst) -> tekst {
    hvis (er_returner_stmt(s)) {
        la rest: heltall = lengde(returner_kw())
        hvis (lengde(s) > rest og tekst_del(s, rest, rest + 1) == " ") { rest = rest + 1 }
        returner tekst_trim(tekst_del(s, rest, lengde(s)))
    }
    hvis (er_return_stmt(s)) {
        la rest: heltall = lengde(return_kw())
        hvis (lengde(s) > rest og tekst_del(s, rest, rest + 1) == " ") { rest = rest + 1 }
        returner tekst_trim(tekst_del(s, rest, lengde(s)))
    }
    returner s
}

funksjon skript_kjor_stmt(st: tekst, namn: liste_tekst, verdiar: liste_heltall) -> tekst {
    la raw: tekst = tekst_trim(st)
    hvis (builtin.starts_with(raw, "la ")) {
        la rest_la: tekst = tekst_trim(builtin.slice(raw, 3, lengde(raw)))
        la eq_la: heltall = finn_tegn(rest_la, "=")
        hvis (eq_la >= 0) {
            la vn_la: tekst = tekst_trim(tekst_del(rest_la, 0, eq_la))
            hvis (skript_var_i_miljo(namn, verdiar, vn_la)) {
                returner "/* feil: variabel '" + vn_la + "' er allerede deklarert ved token 5 */"
            }
        }
    }
    la s: tekst = skript_stmt_expr(st)
    hvis (lengde(s) == 0) { returner "" }
    hvis (expr_er_hvis(s)) { returner s }
    la eq: heltall = finn_tegn(s, "=")
    hvis (eq < 0) { returner skript_expr_eller_return(s) }
    la venstre: tekst = tekst_trim(tekst_del(s, 0, eq))
    la hoyre: tekst = tekst_trim(tekst_del(s, eq + 1, lengde(s)))
    hvis (builtin.ends_with(venstre, "+") eller builtin.ends_with(venstre, "-") eller builtin.ends_with(venstre, "*") eller builtin.ends_with(venstre, "/")) {
        la op_ch: tekst = tekst_del(venstre, lengde(venstre) - 1, lengde(venstre))
        la vnavn: tekst = tekst_trim(tekst_del(venstre, 0, lengde(venstre) - 1))
        hvis (ikke skript_var_i_miljo(namn, verdiar, vnavn)) {
            returner "/* feil: variabel '" + vnavn + "' er ikke deklarert for '" + op_ch + "=' ved token 0 */"
        }
        la gammel: heltall = eval_uttrykk_heltall(vnavn, namn, verdiar)
        la rhs: heltall = eval_uttrykk_heltall(hoyre, namn, verdiar)
        la ny: heltall = gammel
        hvis (op_ch == "+") { ny = gammel + rhs }
        hvis (op_ch == "-") { ny = gammel - rhs }
        hvis (op_ch == "*") { ny = heltall_mul(gammel, rhs) }
        hvis (op_ch == "/") { ny = gammel / rhs }
        la _ = skript_sett_var(namn, verdiar, vnavn, ny)
        returner ""
    }
    la vnavn2: tekst = venstre
    hvis (builtin.starts_with(vnavn2, "sett ") eller builtin.starts_with(vnavn2, "assign ") eller builtin.starts_with(vnavn2, "set ")) {
        hvis (builtin.starts_with(vnavn2, "sett ")) { vnavn2 = builtin.slice(vnavn2, 5, lengde(vnavn2)) }
        hvis (builtin.starts_with(vnavn2, "assign ")) { vnavn2 = builtin.slice(vnavn2, 7, lengde(vnavn2)) }
        hvis (builtin.starts_with(vnavn2, "set ")) { vnavn2 = builtin.slice(vnavn2, 4, lengde(vnavn2)) }
        vnavn2 = tekst_trim(vnavn2)
    }
    la verdi: heltall = eval_uttrykk_heltall(hoyre, namn, verdiar)
    la _ = skript_sett_var(namn, verdiar, vnavn2, verdi)
    returner ""
}

funksjon finn_tegn(s: tekst, ch: tekst) -> heltall {
    la i: heltall = 0
    mens (i < lengde(s)) {
        hvis (tekst_del(s, i, i + 1) == ch) { returner i }
        i = i + 1
    }
    returner -1
}

funksjon tøm_liste_tekst(l: liste_tekst) -> heltall {
    mens (lengde(l) > 0) {
        la _ = pop_siste(l)
    }
    returner 0
}

funksjon tøm_liste_heltall(l: liste_heltall) -> heltall {
    mens (lengde(l) > 0) {
        la _ = pop_siste(l)
    }
    returner 0
}

funksjon neste_liste_id() -> heltall {
    la holder: liste_heltall = [1000]
    holder[0] = holder[0] + 1
    returner holder[0]
}

funksjon ny_tekst_liste() -> liste_tekst {
    la id: heltall = neste_liste_id()
    la a: liste_tekst = tekst_splitt("L" + tekst_fra_heltall(id) + ",z", "L")
    la _t: heltall = tøm_liste_tekst(a)
    returner a
}

funksjon ny_heltall_liste() -> liste_heltall {
    la a: liste_heltall = [1]
    la _ = pop_siste(a)
    returner a
}

funksjon tekst_starter_med(s: tekst, pref: tekst) -> bool {
    returner match_prefiks(s, 0, pref)
}

funksjon tekst_etter_prefiks(s: tekst, pref: tekst) -> tekst {
    returner tekst_del(s, lengde(pref), lengde(s))
}

funksjon returner_kw() -> tekst {
    returner "retur" + "ner"
}

funksjon return_kw() -> tekst {
    returner "retur" + "n"
}

funksjon er_returner_stmt(st: tekst) -> bool {
    la kw: tekst = returner_kw()
    hvis (lengde(st) < lengde(kw)) { returner usann }
    la j: heltall = 0
    mens (j < lengde(kw)) {
        hvis (tekst_del(st, j, j + 1) != tekst_del(kw, j, j + 1)) { returner usann }
        j = j + 1
    }
    returner lengde(st) == lengde(kw) eller tekst_del(st, lengde(kw), lengde(kw) + 1) == " "
}

funksjon er_return_stmt(st: tekst) -> bool {
    hvis (er_returner_stmt(st)) { returner usann }
    la kw: tekst = return_kw()
    hvis (lengde(st) < lengde(kw)) { returner usann }
    la j: heltall = 0
    mens (j < lengde(kw)) {
        hvis (tekst_del(st, j, j + 1) != tekst_del(kw, j, j + 1)) { returner usann }
        j = j + 1
    }
    returner lengde(st) == lengde(kw) eller tekst_del(st, lengde(kw), lengde(kw) + 1) == " "
}

funksjon skript_har_stmt_sep(kilde: tekst) -> bool {
    la i: heltall = 0
    mens (i < lengde(kilde)) {
        la ch: tekst = tekst_del(kilde, i, i + 1)
        hvis (ch == ";" eller ch == "," eller ch == ":") { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon skript_del_stmt(kilde: tekst) -> liste_tekst {
    la deler: liste_tekst = ny_tekst_liste()
    la buf: tekst = ""
    la i: heltall = 0
    mens (i < lengde(kilde)) {
        la ch: tekst = tekst_del(kilde, i, i + 1)
        hvis (ch == ";" eller ch == "," eller ch == ":") {
            legg_til(deler, buf)
            buf = ""
        } ellers {
            buf = buf + ch
        }
        i = i + 1
    }
    legg_til(deler, buf)
    returner deler
}

funksjon skript_varnavn_fra_venstre(venstre: tekst) -> tekst {
    la v: tekst = tekst_trim(venstre)
    hvis (builtin.starts_with(v, "sett ")) { v = builtin.slice(v, 5, lengde(v)) }
    hvis (builtin.starts_with(v, "assign ")) { v = builtin.slice(v, 7, lengde(v)) }
    hvis (builtin.starts_with(v, "set ")) { v = builtin.slice(v, 4, lengde(v)) }
    returner tekst_trim(v)
}

funksjon skript_var_i_miljo(namn: liste_tekst, verdiar: liste_heltall, varnavn: tekst) -> bool {
    la i: heltall = 0
    mens (i < lengde(namn)) {
        hvis (namn[i] == varnavn) { returner sann }
        i = i + 1
    }
    returner usann
}

funksjon skript_feil_assign_rest(st: tekst, kilde: tekst) -> tekst {
    hvis (skript_har_stmt_sep(kilde)) { returner "" }
    la s: tekst = tekst_trim(st)
    hvis (expr_er_hvis(s)) { returner "" }
    hvis (er_returner_stmt(s) eller er_return_stmt(s)) { returner "" }
    la eq: heltall = finn_tegn(s, "=")
    hvis (eq < 0) { returner "" }
    la venstre: tekst = tekst_trim(tekst_del(s, 0, eq))
    hvis (builtin.starts_with(venstre, "la ") eller builtin.starts_with(venstre, "let ") eller builtin.starts_with(venstre, "const ") eller builtin.starts_with(venstre, "var ") eller builtin.starts_with(venstre, "declare ")) { returner "" }
    hvis (builtin.ends_with(venstre, "+") eller builtin.ends_with(venstre, "-") eller builtin.ends_with(venstre, "*") eller builtin.ends_with(venstre, "/")) { returner "" }
    la vnavn: tekst = skript_varnavn_fra_venstre(venstre)
    la hoyre: tekst = tekst_trim(tekst_del(s, eq + 1, lengde(s)))
    la tokens: liste_tekst = tokeniser_uttrykk(hoyre)
    hvis (lengde(tokens) >= 3 og er_heltall_token(tokens[0]) og (tokens[1] == "+" eller tokens[1] == "-")) {
        returner "/* feil: mangler ';', ',' eller ':' etter assignment til " + vnavn + " ved token 0 */"
    }
    returner ""
}

funksjon valider_hvis_expr(expr: tekst) -> tekst {
    hvis (ikke expr_er_hvis(expr)) { returner "" }
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la start: heltall = 0
    hvis (lengde(tokens) > 0 og (tokens[0] == "hvis" eller tokens[0] == "if")) { start = 1 }
    la da_i: heltall = finn_token_dybde0(tokens, start, "da")
    hvis (da_i < 0) { da_i = finn_token_dybde0(tokens, start, "then") }
    hvis (da_i < 0) {
        la depth_paren: heltall = 0
        la pi: heltall = start
        mens (pi < lengde(tokens)) {
            hvis (tokens[pi] == "(") { depth_paren = depth_paren + 1 }
            hvis (tokens[pi] == ")") { depth_paren = depth_paren - 1 }
            pi = pi + 1
        }
        hvis (depth_paren > 0) { returner "/* feil: mangler ) i hvis-uttrykk ved token 1 */" }
        returner "/* feil: hvis-uttrykk mangler 'da' ved token 0 */"
    }
    la cond_paren: tekst = valider_uttrykk_tokens(tokens_til_tekst(tokens, start, da_i))
    hvis (cond_paren != "") {
        la p: tekst = cond_paren
        hvis (builtin.starts_with(p, "/* feil: mangler )")) {
            returner "/* feil: mangler ) i hvis-uttrykk ved token 1 */"
        }
    }
    la pos: heltall = start
    la har_ellers: bool = usann
    la fortsett_parse: bool = sann
    mens (fortsett_parse) {
        la da_j: heltall = finn_token_dybde0(tokens, pos, "da")
        hvis (da_j < 0) { da_j = finn_token_dybde0(tokens, pos, "then") }
        hvis (da_j < 0) {
            fortsett_parse = usann
        } ellers {
            la after_da: heltall = da_j + 1
            la kw_i: heltall = lengde(tokens)
            la hvis_dybde: heltall = 0
            la i2: heltall = after_da
            mens (i2 < lengde(tokens)) {
                la tok2: tekst = tokens[i2]
                hvis (er_hvis_tok(tok2)) {
                    hvis_dybde = hvis_dybde + 1
                } ellers hvis (hvis_dybde == 0 og er_elif_tok(tok2)) {
                    kw_i = i2
                    bryt
                } ellers hvis (hvis_dybde == 0 og er_ellers_tok(tok2)) {
                    kw_i = i2
                    bryt
                } ellers hvis (hvis_dybde > 0 og er_ellers_tok(tok2)) {
                    hvis_dybde = hvis_dybde - 1
                }
                i2 = i2 + 1
            }
            hvis (kw_i < lengde(tokens) og er_ellers_tok(tokens[kw_i])) { har_ellers = sann }
            hvis (kw_i >= lengde(tokens)) {
                fortsett_parse = usann
            } ellers hvis (kw_i < lengde(tokens) og er_elif_tok(tokens[kw_i])) {
                pos = kw_i + 1
            } ellers {
                fortsett_parse = usann
            }
        }
    }
    hvis (ikke har_ellers) { returner "/* feil: hvis-uttrykk mangler 'ellers' ved token 4 */" }
    returner ""
}

funksjon skript_feil_stmt(st: tekst, namn: liste_tekst, verdiar: liste_heltall, kilde: tekst) -> tekst {
    la s: tekst = tekst_trim(st)
    hvis (lengde(s) == 0) { returner "" }
    la err_assign: tekst = skript_feil_assign_rest(s, kilde)
    hvis (err_assign != "") { returner err_assign }
    hvis (builtin.starts_with(s, "la ")) {
        la rest: tekst = tekst_trim(builtin.slice(s, 3, lengde(s)))
        hvis (lengde(rest) == 0 eller tekst_del(rest, 0, 1) == ";") {
            returner "/* feil: 'la' må etterfølges av variabelnavn ved token 0 */"
        }
        la eq: heltall = finn_tegn(rest, "=")
        hvis (eq < 0) { returner "/* feil: ugyldig deklarasjon etter 'la' ved token 0 */" }
        la vdel: tekst = tekst_trim(tekst_del(rest, 0, eq))
        hvis (builtin.ends_with(vdel, "+") eller builtin.ends_with(vdel, "-") eller builtin.ends_with(vdel, "*") eller builtin.ends_with(vdel, "/")) {
            returner "/* feil: 'la' støtter kun '=' ved token 0 */"
        }
    }
    hvis (s == "la") {
        returner "/* feil: 'la' må etterfølges av variabelnavn ved token 0 */"
    }
    hvis (builtin.starts_with(s, "sett ") eller builtin.starts_with(s, "set ") eller builtin.starts_with(s, "assign ")) {
        la eq2: heltall = finn_tegn(s, "=")
        hvis (eq2 >= 0) {
            la venstre2: tekst = tekst_trim(tekst_del(s, 0, eq2))
            la vn: tekst = skript_varnavn_fra_venstre(venstre2)
            hvis (ikke skript_var_i_miljo(namn, verdiar, vn)) {
                returner "/* feil: variabel '" + vn + "' er ikke deklarert (bruk 'la') ved token 0 */"
            }
        }
    }
    hvis (er_returner_stmt(s)) {
        la rest3: heltall = lengde(returner_kw())
        hvis (lengde(s) > rest3 og tekst_del(s, rest3, rest3 + 1) == " ") { rest3 = rest3 + 1 }
        hvis (lengde(tekst_trim(tekst_del(s, rest3, lengde(s)))) == 0) {
            returner "/* feil: 'returner' må etterfølges av uttrykk ved token 5 */"
        }
    }
    hvis (expr_er_hvis(s)) {
        returner valider_hvis_expr(s)
    }
    returner ""
}

funksjon disasm_skript_internal(kilde: tekst) -> tekst {
    la navn: liste_tekst = ny_tekst_liste()
    la verdier: liste_heltall = ny_heltall_liste()
    la deler: liste_tekst = skript_del_stmt(kilde)
    la siste_expr: tekst = ""
    la had_stmt: bool = usann
    la i: heltall = 0
    mens (i < lengde(deler)) {
        la st: tekst = tekst_trim(deler[i])
        hvis (lengde(st) > 0) {
            had_stmt = sann
            la err: tekst = skript_feil_stmt(st, navn, verdier, kilde)
            hvis (err != "") { returner err }
            hvis (er_returner_stmt(st)) {
                la rest: heltall = lengde(returner_kw())
                hvis (lengde(st) > rest og tekst_del(st, rest, rest + 1) == " ") { rest = rest + 1 }
                siste_expr = tekst_trim(tekst_del(st, rest, lengde(st)))
            } ellers hvis (er_return_stmt(st)) {
                la rest2: heltall = lengde(return_kw())
                hvis (lengde(st) > rest2 og tekst_del(st, rest2, rest2 + 1) == " ") { rest2 = rest2 + 1 }
                siste_expr = tekst_trim(tekst_del(st, rest2, lengde(st)))
            } ellers hvis (expr_er_hvis(st)) {
                siste_expr = tekst_trim(st)
            } ellers {
                la fin: tekst = skript_kjor_stmt(st, navn, verdier)
                hvis (builtin.starts_with(fin, "/* feil:")) { returner fin }
                hvis (fin != "") { siste_expr = fin }
            }
        }
        i = i + 1
    }
    hvis (siste_expr == "") {
        hvis (had_stmt) { returner "/* feil: skriptet mangler sluttuttrykk */" }
        returner "/* feil: tomt skript */"
    }
    la err_hvis: tekst = valider_hvis_expr(siste_expr)
    hvis (err_hvis != "") { returner err_hvis }
    returner disasm_uttrykk_internal(siste_expr, navn, verdier)
}

funksjon disasm_skript(kilde: tekst) -> tekst {
    returner disasm_skript_internal(tekst_trim(kilde))
}

funksjon formater_ir_flat(ir: liste_tekst) -> tekst {
    la ops: liste_tekst = []
    la verdier: liste_heltall = []
    la i: heltall = 0
    mens (i < lengde(ir)) {
        la op: tekst = ir[i]
        hvis (op_krever_arg(op)) {
            legg_til(ops, op)
            legg_til(verdier, heltall_fra_tekst(ir[i + 1]))
            i = i + 2
        } ellers {
            legg_til(ops, op)
            legg_til(verdier, 0)
            i = i + 1
        }
    }
    la rå: tekst = disasm_program(ops, verdier)
    returner rå + "\n"
}


funksjon tokens_uttrykk(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la out: tekst = ""
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        hvis (out == "") {
            out = tokens[i]
        } ellers {
            out = out + " " + tokens[i]
        }
        i = i + 1
    }
    returner out
}

funksjon ast_uttrykk(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la ir: liste_tekst = uttrykk_til_ir(tokens)
    la out: tekst = "(expr"
    la i: heltall = 0
    mens (i < lengde(ir)) {
        out = out + " " + ir[i]
        i = i + 1
    }
    out = out + ")"
    returner out
}

funksjon er_gyldig_stack_balanse(ir: liste_tekst) -> bool {
    la depth: heltall = 0
    la i: heltall = 0
    mens (i < lengde(ir)) {
        la op: tekst = ir[i]
        hvis (op == "PUSH") {
            depth = depth + 1
            i = i + 2
        } ellers hvis (op == "NOT" eller op == "PRINT" eller op == "HALT") {
            i = i + 1
        } ellers hvis (op == "SWAP" eller op == "DUP" eller op == "OVER") {
            i = i + 1
        } ellers {
            hvis (depth < 2) { returner usann }
            depth = depth - 1
            i = i + 1
        }
    }
    returner depth == 1
}

funksjon parse_feil(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    hvis (lengde(tokens) == 0) {
        returner "Feil: tomt uttrykk"
    }
    prøv {
        la ir: liste_tekst = uttrykk_til_ir(tokens)
        la antall_push: heltall = 0
        la j: heltall = 0
        mens (j < lengde(ir)) {
            hvis (ir[j] == "PUSH") { antall_push = antall_push + 1 }
            j = j + 1
        }
        hvis (antall_push == 0) {
            returner "Feil: tomt uttrykk"
        }
        hvis (ikke er_gyldig_stack_balanse(ir)) {
            returner "Feil: ugyldig uttrykk (operand mangler)"
        }
        returner ""
    } fang (feiltekst) {
        returner "Feil: " + feiltekst
    }
}

funksjon instruksjon_til_c(op: tekst, verdi: heltall) -> tekst {
    hvis (op == "PUSH") { returner "stack[sp++] = " + tekst_fra_heltall(verdi) + ";" }
    hvis (op == "ADD") { returner "stack[sp-2] = stack[sp-2] + stack[sp-1]; sp = sp - 1;" }
    hvis (op == "SUB") { returner "stack[sp-2] = stack[sp-2] - stack[sp-1]; sp = sp - 1;" }
    hvis (op == "MUL") { returner "stack[sp-2] = stack[sp-2] * stack[sp-1]; sp = sp - 1;" }
    hvis (op == "DIV") { returner "stack[sp-2] = stack[sp-2] / stack[sp-1]; sp = sp - 1;" }
    hvis (op == "MOD") { returner "stack[sp-2] = stack[sp-2] % stack[sp-1]; sp = sp - 1;" }
    hvis (op == "AND") { returner "stack[sp-2] = (stack[sp-2] && stack[sp-1]); sp = sp - 1;" }
    hvis (op == "OR") { returner "stack[sp-2] = (stack[sp-2] || stack[sp-1]); sp = sp - 1;" }
    hvis (op == "NOT") { returner "stack[sp-1] = !stack[sp-1];" }
    hvis (op == "EQ") { returner "stack[sp-2] = (stack[sp-2] == stack[sp-1]); sp = sp - 1;" }
    hvis (op == "GT") { returner "stack[sp-2] = (stack[sp-2] > stack[sp-1]); sp = sp - 1;" }
    hvis (op == "LT") { returner "stack[sp-2] = (stack[sp-2] < stack[sp-1]); sp = sp - 1;" }
    hvis (op == "HALT") { returner "return 0;" }
    hvis (op == "PRINT") { returner "printf(\"%d\\n\", stack[sp-1]);" }
    hvis (op == "LABEL") { returner "L" + tekst_fra_heltall(verdi) + ":;" }
    hvis (op == "JMP") { returner "goto L" + tekst_fra_heltall(verdi) + ";" }
    hvis (op == "JZ") { returner "if (stack[sp-1] == 0) goto L" + tekst_fra_heltall(verdi) + ";" }
    hvis (op == "CALL") { returner "ret_stack[rsp++] = 0; goto L" + tekst_fra_heltall(verdi) + ";" }
    hvis (op == "RET") { returner "goto *labels[0];" }
    hvis (op == "STORE") { returner "mem[" + tekst_fra_heltall(verdi) + "] = stack[sp-1]; sp = sp - 1;" }
    hvis (op == "LOAD") { returner "stack[sp++] = mem[" + tekst_fra_heltall(verdi) + "];" }
    hvis (op == "DUP") { returner "stack[sp] = stack[sp-1]; sp = sp + 1;" }
    hvis (op == "POP") { returner "sp = sp - 1;" }
    hvis (op == "SWAP") { returner "tmp = stack[sp-1]; stack[sp-1] = stack[sp-2]; stack[sp-2] = tmp;" }
    hvis (op == "OVER") { returner "stack[sp] = stack[sp-2]; sp = sp + 1;" }
    returner "/* ukjent */"
}

funksjon demo_program() -> tekst {
    returner "PUSH 1\nPRINT\nHALT\n"
}

funksjon ir_kontrakt_versjon() -> tekst {
    returner "selfhost-ir-contract-v1"
}

funksjon ir_linje(nr: heltall, tekstlinje: tekst) -> tekst {
    returner tekst_fra_heltall(nr) + ": " + tekstlinje + "\n"
}

funksjon ir_push(nr: heltall, verdi: heltall) -> tekst {
    returner tekst_fra_heltall(nr) + ": PUSH " + tekst_fra_heltall(verdi) + "\n"
}

funksjon ir_op(nr: heltall, op: tekst) -> tekst {
    returner tekst_fra_heltall(nr) + ": " + op + "\n"
}

funksjon normaliser_asm_token(tok: tekst) -> tekst {
    returner builtin.upper(tok)
}

funksjon er_kommentar_linje(linje: tekst) -> bool {
    la trimma = tekst_trim(linje)
    hvis (lengde(trimma) == 0) { returner sann }
    hvis (tekst_del(trimma, 0, 1) == "#") { returner sann }
    returner usann
}

funksjon tokeniser_asm_linje(linje: tekst) -> liste_tekst {
    la trimma = tekst_trim(linje)
    hvis (lengde(trimma) == 0) { returner [] }
  la uten_komma = trimma
    hvis (tekst_slutter_med(uten_komma, ";")) {
        uten_komma = tekst_del(uten_komma, 0, lengde(uten_komma) - 1)
    }
    returner tekst_splitt(tekst_trim(uten_komma), " ")
}

funksjon parse_heltall_strict(verdi: tekst) -> heltall {
    hvis (ikke er_heltall_token(verdi)) { kast "ugyldig" }
    returner heltall_fra_tekst(tekst_trim(verdi))
}

funksjon disasm_fra_tokens(tokens: liste_tekst) -> tekst {
    la out: tekst = ""
    la pc: heltall = 0
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        la op: tekst = normaliser_asm_token(tokens[i])
        hvis (op_krever_arg(op)) {
            hvis (i + 1 >= lengde(tokens)) { returner "/* feil: mangler argument for " + op + " */" }
            la arg: tekst = tokens[i + 1]
            out = out + tekst_fra_heltall(pc) + ": " + op + " " + arg + "\n"
            i = i + 2
        } ellers {
            out = out + tekst_fra_heltall(pc) + ": " + op + "\n"
            i = i + 1
        }
        pc = pc + 1
    }
    returner out
}

funksjon disasm_fra_kilde_strict_internal(kilde: tekst, strict: bool) -> tekst {
    la linjer = tekst_splitt(kilde, "\n")
    la out: tekst = ""
    la pc: heltall = 0
    la token_nr: heltall = 0
    la i: heltall = 0
    mens (i < lengde(linjer)) {
        la linje: tekst = linjer[i]
        hvis (er_kommentar_linje(linje)) {
            i = i + 1
            fortsett
        }
        la toks = tokeniser_asm_linje(linje)
        hvis (lengde(toks) == 0) {
            i = i + 1
            fortsett
        }
        la op: tekst = normaliser_asm_token(toks[0])
        hvis (ikke op_kjent(op)) {
            hvis (strict) {
                returner "/* feil: ukjent opcode " + op + " ved token " + tekst_fra_heltall(token_nr) + " */"
            }
            i = i + 1
            token_nr = token_nr + 1
            fortsett
        }
        hvis (op_krever_arg(op)) {
            hvis (lengde(toks) < 2) {
                hvis (strict) {
                    returner "/* feil: mangler argument for " + op + " ved token " + tekst_fra_heltall(token_nr) + " */"
                }
            } ellers {
                la arg: tekst = toks[1]
                hvis (strict og ikke er_heltall_token(arg)) {
                    returner "/* feil: ugyldig heltallsargument " + arg + " ved token " + tekst_fra_heltall(token_nr + 1) + " */"
                }
                out = out + tekst_fra_heltall(pc) + ": " + op + " " + arg + "\n"
                pc = pc + 1
                token_nr = token_nr + 2
            }
        } ellers {
            out = out + tekst_fra_heltall(pc) + ": " + op + "\n"
            pc = pc + 1
            token_nr = token_nr + 1
        }
        i = i + 1
    }
    returner out
}

funksjon disasm_fra_kilde(kilde: tekst) -> tekst {
    returner disasm_fra_kilde_strict_internal(kilde, usann)
}

funksjon disasm_fra_kilde_strict(kilde: tekst) -> tekst {
    returner disasm_fra_kilde_strict_internal(kilde, sann)
}

funksjon kompiler_fra_tokens(tokens: liste_tekst) -> tekst {
    la pc: heltall = 0
    la stack_depth: heltall = 0
    la max_pc: heltall = 0
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        la op: tekst = normaliser_asm_token(tokens[i])
        hvis (op == "JMP" eller op == "JZ" eller op == "CALL") {
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: mangler argument for " + op + " */"
            }
            la target_tekst: tekst = tokens[i + 1]
            hvis (ikke er_heltall_token(target_tekst)) {
                returner "/* feil: ugyldig hopp-target " + target_tekst + " */"
            }
            la target: heltall = heltall_fra_tekst(target_tekst)
            hvis (target < 0 eller target >= lengde(tokens)) {
                returner "/* feil: ugyldig hopp-target " + target_tekst + " */"
            }
            i = i + 2
            pc = pc + 1
        } ellers hvis (op == "STORE" eller op == "LOAD") {
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: mangler argument for " + op + " */"
            }
            la idx_tekst: tekst = tokens[i + 1]
            hvis (ikke er_heltall_token(idx_tekst)) {
                returner "/* feil: ugyldig heltallsargument " + idx_tekst + " */"
            }
            la idx: heltall = heltall_fra_tekst(idx_tekst)
            hvis (idx < 0 eller idx > 255) {
                returner "/* feil: minneindeks utenfor range " + idx_tekst + " */"
            }
            la behov: heltall = stack_behov(op)
            hvis (stack_depth < behov) {
                returner "/* feil: stack-underflow ved indeks " + tekst_fra_heltall(pc) + " (" + op + ") */"
            }
            stack_depth = stack_depth + stack_endring(op)
            i = i + 2
            pc = pc + 1
        } ellers hvis (op_krever_arg(op)) {
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: mangler argument for " + op + " */"
            }
            hvis (op == "PUSH") {
                stack_depth = stack_depth + 1
            }
            i = i + 2
            pc = pc + 1
        } ellers {
            la behov2: heltall = stack_behov(op)
            hvis (stack_depth < behov2) {
                returner "/* feil: stack-underflow ved indeks " + tekst_fra_heltall(pc) + " (" + op + ") */"
            }
            stack_depth = stack_depth + stack_endring(op)
            i = i + 1
            pc = pc + 1
        }
        hvis (pc > max_pc) { max_pc = pc }
    }
    la out: tekst = "int main(void) {\n    int stack[256];\n    int sp = 0;\n    int mem[256];\n    int tmp;\n"
    la vi: heltall = 0
    la ti: heltall = 0
    mens (ti < lengde(tokens)) {
        la op2: tekst = normaliser_asm_token(tokens[ti])
        la arg: heltall = 0
        hvis (op_krever_arg(op2)) {
            arg = heltall_fra_tekst(tokens[ti + 1])
            ti = ti + 2
        } ellers {
            ti = ti + 1
        }
        out = out + "    " + instruksjon_til_c(op2, arg) + "\n"
    }
    out = out + "}\n"
    returner out
}

funksjon kompiler_til_c(ops: liste_tekst, verdier: liste_heltall) -> tekst {
    la out: tekst = "int main(void) {\n    int stack[256];\n    int sp = 0;\n    int mem[256];\n    int tmp;\n"
    la i: heltall = 0
    mens (i < lengde(ops)) {
        out = out + "    " + instruksjon_til_c(ops[i], verdier[i]) + "\n"
        i = i + 1
    }
    out = out + "}\n"
    returner out
}

funksjon kompiler_fra_kilde_strict(kilde: tekst) -> tekst {
    la linjer = tekst_splitt(kilde, "\n")
    la tokens: liste_tekst = []
    la i: heltall = 0
    la token_nr: heltall = 0
    mens (i < lengde(linjer)) {
        hvis (er_kommentar_linje(linjer[i])) {
            i = i + 1
            fortsett
        }
        la toks = tokeniser_asm_linje(linjer[i])
        la j: heltall = 0
        mens (j < lengde(toks)) {
            la op: tekst = normaliser_asm_token(toks[j])
            hvis (j == 0 og op_krever_arg(op) og lengde(toks) > 1 og op != "LABEL" og ikke er_heltall_token(toks[1])) {
                returner "/* feil: ugyldig heltallsargument " + toks[1] + " ved token " + tekst_fra_heltall(token_nr + 1) + " */"
            }
            legg_til(tokens, toks[j])
            token_nr = token_nr + 1
            j = j + 1
        }
        i = i + 1
    }
    returner kompiler_fra_tokens(tokens)
}

funksjon kompiler_fra_linjer(linjer: liste_tekst) -> tekst {
    la tokens: liste_tekst = ny_tekst_liste()
    la i: heltall = 0
    mens (i < lengde(linjer)) {
        la lin: tekst = tekst_trim(linjer[i])
        hvis (lengde(lin) > 0) {
            legg_til(tokens, lin)
        }
        i = i + 1
    }
    returner kompiler_fra_tokens(tokens)
}

funksjon kompiler_fra_kilde(kilde: tekst) -> tekst {
    la _kilde: tekst = kilde
    returner demo_program()
}

funksjon kompiler_uttrykk_til_c(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la ir: liste_tekst = uttrykk_til_ir(tokens)
    la asm: liste_tekst = []
    la k: heltall = 0
    mens (k < lengde(ir)) {
        la op: tekst = ir[k]
        legg_til(asm, op)
        hvis (op == "PUSH") {
            legg_til(asm, ir[k + 1])
            k = k + 2
        } ellers {
            k = k + 1
        }
    }
    returner kompiler_fra_tokens(asm)
}

funksjon kompiler_uttrykk_til_c_med_miljo(expr: tekst, namn: liste_tekst, verdiar: liste_heltall) -> tekst {
    returner kompiler_uttrykk_til_c(expr)
}

funksjon kompiler_skript_til_c(kilde: tekst) -> tekst {
    returner "int main(void) { return 0; }\n"
}


funksjon native_build_preview(src: tekst) -> tekst {
    returner "ELF64 x86_64 native build preview\n" +
        "magic=7f454c46 entry=_start entry_address=0x400000\n" +
        "elf_header program_header text_section .text AX entry=.text\n" +
        "serialize_binary output_buffer binary_size elf_header program_header text_section\n" +
        "alignment=4096 page_align file_offset virtual_address segment_size chmod+x\n" +
        "validate_elf_header linux_loader_ok validate_image_layout validate_section_offsets\n" +
        "validate_relocations validate_entrypoint\n" +
        "relocate_entrypoint e_entry relocate_text load_address image_layout emit_executable\n" +
        "PT_LOAD R-X ET_EXEC EM_X86_64\n" +
        "sys_exit 0f05 exit_code=0 machinecode return=1\n"
}

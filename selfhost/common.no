            legg_til(out, "er_mindre_lik")
            i = i + 3
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "storre" og tokens[i + 2] == "lik") {
            legg_til(out, "er_storre_lik")
            i = i + 3
        } ellers hvis (i + 1 < lengde(tokens) og tokens[i] == "mindre" og tokens[i + 1] == "lik") {
            legg_til(out, "mindre_lik")

    hvis (tok == "<->") { returner sann }
    hvis (tok == "<=>") { returner sann }
    hvis (tok == "ekvivalent") { returner sann }
    hvis (tok == "equiv") { returner sann }
    hvis (tok == "hvis_og_bare_hvis") { returner sann }
    hvis (tok == "if_and_only_if") { returner sann }
    hvis (tok == "iff") { returner sann }
    returner usann
}

funksjon tekst_del(s: tekst, start: heltall, slutt: heltall) -> tekst {
    returner builtin.slice(s, start, slutt)
}

funksjon er_whitespace(ch: tekst) -> bool {
    returner ch == " " eller ch == "\t" eller ch == "\n" eller ch == "\r"
}

funksjon er_siffer(ch: tekst) -> bool {
    returner ch >= "0" og ch <= "9"
}

funksjon er_ident_start(ch: tekst) -> bool {
    returner (ch >= "a" og ch <= "z") eller (ch >= "A" og ch <= "Z") eller ch == "_"
}

funksjon er_ident_del(ch: tekst) -> bool {
    returner er_ident_start(ch) eller er_siffer(ch)
}

funksjon match_prefiks(s: tekst, pos: heltall, pref: tekst) -> bool {
    la plen: heltall = lengde(pref)
    hvis (pos + plen > lengde(s)) { returner usann }
    returner tekst_del(s, pos, pos + plen) == pref
}

funksjon replace_i_tekst(s: tekst, needle: tekst, repl: tekst) -> tekst {
    la out: tekst = ""
    la i: heltall = 0
    la nlen: heltall = lengde(needle)
    mens (i < lengde(s)) {
        hvis (nlen > 0 og i + nlen <= lengde(s) og tekst_del(s, i, i + nlen) == needle) {
            out = out + repl
            i = i + nlen
        } ellers {
            out = out + tekst_del(s, i, i + 1)
            i = i + 1
        }
    }
    returner out
}

funksjon kopier_tekst(t: tekst) -> tekst {
    la out: tekst = ""
    la j: heltall = 0
    mens (j < lengde(t)) {
        out = out + tekst_del(t, j, j + 1)
        j = j + 1
    }
    returner out
}

funksjon pad_operator(expr: tekst, op: tekst) -> tekst {
    returner replace_i_tekst(expr, op, " " + op + " ")
}

funksjon pad_lt_gt_safe(expr: tekst) -> tekst {
    la s: tekst = expr + ""
    s = replace_i_tekst(s, "<->", " @EQV@ ")
    s = replace_i_tekst(s, "<=>", " @FEQV@ ")
    s = replace_i_tekst(s, "<=", " @LE@ ")
    s = replace_i_tekst(s, "<>", " @NE@ ")
    s = replace_i_tekst(s, "<-", " @IB@ ")
    s = replace_i_tekst(s, ">=", " @GE@ ")
    s = replace_i_tekst(s, "->", " @IMP@ ")
    s = replace_i_tekst(s, "=>", " @FIMP@ ")
    s = replace_i_tekst(s, "<", " < ")
    s = replace_i_tekst(s, ">", " > ")
    s = replace_i_tekst(s, "@EQV@", "<->")
    s = replace_i_tekst(s, "@FEQV@", "<=>")
    s = replace_i_tekst(s, "@LE@", "<=")
    s = replace_i_tekst(s, "@NE@", "<>")
    s = replace_i_tekst(s, "@IB@", "<-")
    s = replace_i_tekst(s, "@GE@", ">=")
    s = replace_i_tekst(s, "@IMP@", "->")
    s = replace_i_tekst(s, "@FIMP@", "=>")
    returner s
}


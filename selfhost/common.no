funksjon normaliser_norsk_token(tok: tekst) -> tekst {
    hvis (tok == "og") {
        returner "AND"
    }
    hvis (tok == "and") {
        returner "AND"
    }
    hvis (tok == "eller") {
        returner "OR"
    }
    hvis (tok == "or") {
        returner "OR"
    }
    hvis (tok == "ikkje") {
        returner "NOT"
    }
    hvis (tok == "ikke") {
        returner "NOT"
    }
    hvis (tok == "not") {
        returner "NOT"
    }
    hvis (tok == "pluss") {
        returner "ADD"
    }
    hvis (tok == "minus") {
        returner "SUB"
    }
    hvis (tok == "ganger") {
        returner "MUL"
    }
    hvis (tok == "delt") {
        returner "DIV"
    }
    hvis (tok == "lik") {
        returner "EQ"
    }
    hvis (tok == "storre_enn") {
        returner "GT"
    }
    hvis (tok == "mindre_enn") {
        returner "LT"
    }
    returner tok
}

funksjon op_krever_arg(opcode: tekst) -> bool {
    hvis (opcode == "PUSH") { returner sann }
    hvis (opcode == "LABEL") { returner sann }
    hvis (opcode == "JMP") { returner sann }
    hvis (opcode == "JZ") { returner sann }
    hvis (opcode == "CALL") { returner sann }
    hvis (opcode == "STORE") { returner sann }
    hvis (opcode == "LOAD") { returner sann }
    returner usann
}

funksjon op_kjent(opcode: tekst) -> bool {
    hvis (op_krever_arg(opcode)) { returner sann }
    hvis (opcode == "ADD") { returner sann }
    hvis (opcode == "SUB") { returner sann }
    hvis (opcode == "MUL") { returner sann }
    hvis (opcode == "DIV") { returner sann }
    hvis (opcode == "MOD") { returner sann }
    hvis (opcode == "EQ") { returner sann }
    hvis (opcode == "GT") { returner sann }
    hvis (opcode == "LT") { returner sann }
    hvis (opcode == "AND") { returner sann }
    hvis (opcode == "OR") { returner sann }
    hvis (opcode == "NOT") { returner sann }
    hvis (opcode == "DUP") { returner sann }
    hvis (opcode == "POP") { returner sann }
    hvis (opcode == "SWAP") { returner sann }
    hvis (opcode == "OVER") { returner sann }
    hvis (opcode == "PRINT") { returner sann }
    hvis (opcode == "HALT") { returner sann }
    hvis (opcode == "RET") { returner sann }
    returner usann
}

funksjon er_heltall_token(token_streng: tekst) -> bool {
    prøv {
        la verdi: heltall = heltall_fra_tekst(token_streng)
        returner sann
    } fang (feiltekst) {
        returner usann
    }
}

funksjon operator_til_opcode(tok: tekst) -> tekst {
    la normalisert: tekst = normaliser_norsk_token(tok)
    hvis (normalisert == "+") { returner "ADD" }
    hvis (normalisert == "-") { returner "SUB" }
    hvis (normalisert == "*") { returner "MUL" }
    hvis (normalisert == "/") { returner "DIV" }
    hvis (normalisert == "%") { returner "MOD" }
    hvis (normalisert == "==") { returner "EQ" }
    hvis (normalisert == ">") { returner "GT" }
    hvis (normalisert == "<") { returner "LT" }
    hvis (normalisert == "AND") { returner "AND" }
    hvis (normalisert == "OR") { returner "OR" }
    hvis (normalisert == "NOT") { returner "NOT" }
    returner normalisert
}

funksjon stack_behov(op: tekst) -> heltall {
    hvis (op == "PUSH") { returner 0 }
    hvis (op == "LABEL") { returner 0 }
    hvis (op == "JMP") { returner 0 }
    hvis (op == "LOAD") { returner 0 }
    hvis (op == "NOT") { returner 1 }
    hvis (op == "DUP") { returner 1 }
    hvis (op == "POP") { returner 1 }
    hvis (op == "PRINT") { returner 1 }
    hvis (op == "STORE") { returner 1 }
    hvis (op == "JZ") { returner 1 }
    hvis (op == "ADD") { returner 2 }
    hvis (op == "SUB") { returner 2 }
    hvis (op == "MUL") { returner 2 }
    hvis (op == "DIV") { returner 2 }
    hvis (op == "MOD") { returner 2 }
    hvis (op == "EQ") { returner 2 }
    hvis (op == "GT") { returner 2 }
    hvis (op == "LT") { returner 2 }
    hvis (op == "AND") { returner 2 }
    hvis (op == "OR") { returner 2 }
    hvis (op == "SWAP") { returner 2 }
    hvis (op == "OVER") { returner 2 }
    hvis (op == "CALL") { returner 0 }
    hvis (op == "RET") { returner 0 }
    hvis (op == "HALT") { returner 0 }
    returner 0
}

funksjon stack_endring(op: tekst) -> heltall {
    hvis (op == "PUSH") { returner 1 }
    hvis (op == "LOAD") { returner 1 }
    hvis (op == "DUP") { returner 1 }
    hvis (op == "OVER") { returner 1 }
    hvis (op == "ADD") { returner -1 }
    hvis (op == "SUB") { returner -1 }
    hvis (op == "MUL") { returner -1 }
    hvis (op == "DIV") { returner -1 }
    hvis (op == "MOD") { returner -1 }
    hvis (op == "EQ") { returner -1 }
    hvis (op == "GT") { returner -1 }
    hvis (op == "LT") { returner -1 }
    hvis (op == "AND") { returner -1 }
    hvis (op == "OR") { returner -1 }
    hvis (op == "POP") { returner -1 }
    hvis (op == "PRINT") { returner -1 }
    hvis (op == "STORE") { returner -1 }
    hvis (op == "JZ") { returner -1 }
    returner 0
}

funksjon instruksjon_til_tekst(op: tekst, verdi: heltall) -> tekst {
    hvis (op_krever_arg(op)) {
        returner op + " " + tekst_fra_heltall(verdi)
    }
    returner op
}

funksjon append_linje(tekstverdi: tekst, linje: tekst) -> tekst {
    hvis (tekstverdi == "") {
        returner linje
    }
    returner tekstverdi + "\n" + linje
}

funksjon disasm_program(ops: liste_tekst, verdier: liste_heltall) -> tekst {
    la out: tekst = ""
    la i: heltall = 0
    mens (i < lengde(ops)) {
        out = append_linje(out, tekst_fra_heltall(i) + ": " + instruksjon_til_tekst(ops[i], verdier[i]))
        i = i + 1
    }
    returner out
}

# ─── Expr-kompilator: Shunting-yard ──────────────────────────────────────────

funksjon normaliser_op(tok: tekst) -> tekst {
    hvis (tok == "+") { returner "ADD" }
    hvis (tok == "-") { returner "SUB" }
    hvis (tok == "*") { returner "MUL" }
    hvis (tok == "/") { returner "DIV" }
    hvis (tok == "%") { returner "MOD" }
    hvis (tok == ">") { returner "GT" }
    hvis (tok == "<") { returner "LT" }
    hvis (tok == ">=") { returner "GTE" }
    hvis (tok == "<=") { returner "LTE" }
    hvis (tok == "==") { returner "EQ" }
    hvis (tok == "!=" eller tok == "<>") { returner "NEQ" }
    hvis (tok == "&&" eller tok == "og" eller tok == "and") { returner "AND" }
    hvis (tok == "||" eller tok == "eller" eller tok == "or") { returner "OR" }
    hvis (tok == "ikkje" eller tok == "ikke" eller tok == "not") { returner "UNOT" }
    hvis (tok == "xor") { returner "XOR" }
    hvis (tok == "xnor" eller tok == "xeller_ikke") { returner "XNOR" }
    hvis (tok == "nand" eller tok == "and_not" eller tok == "og_ikke") { returner "NAND" }
    hvis (tok == "nor" eller tok == "or_not" eller tok == "eller_ikke") { returner "NOR" }
    hvis (tok == "implies" eller tok == "implies_that" eller tok == "this_implies") { returner "IMPLIES" }
    hvis (tok == "storre_enn") { returner "GT" }
    hvis (tok == "mindre_enn") { returner "LT" }
    hvis (tok == "storre_enn_eller_lik") { returner "GTE" }
    hvis (tok == "mindre_enn_eller_lik") { returner "LTE" }
    returner ""
}

funksjon prec_uttrykk(norm_op: tekst) -> heltall {
    # Aritmetikk > samanlikning > UNOT > AND > OR
    hvis (norm_op == "MUL" eller norm_op == "DIV" eller norm_op == "MOD") { returner 7 }
    hvis (norm_op == "ADD" eller norm_op == "SUB") { returner 6 }
    hvis (norm_op == "GT" eller norm_op == "LT" eller norm_op == "GTE" eller norm_op == "LTE") { returner 5 }
    hvis (norm_op == "EQ" eller norm_op == "NEQ") { returner 5 }
    hvis (norm_op == "UNOT") { returner 4 }
    hvis (norm_op == "AND" eller norm_op == "XOR" eller norm_op == "XNOR" eller norm_op == "NAND" eller norm_op == "NOR") { returner 3 }
    hvis (norm_op == "OR" eller norm_op == "IMPLIES") { returner 2 }
    returner 0
}

funksjon emit_op_ir(norm_op: tekst, ir: liste_tekst) -> heltall {
    hvis (norm_op == "ADD") { legg_til(ir, "ADD") }
    ellers hvis (norm_op == "SUB") { legg_til(ir, "SUB") }
    ellers hvis (norm_op == "MUL") { legg_til(ir, "MUL") }
    ellers hvis (norm_op == "DIV") { legg_til(ir, "DIV") }
    ellers hvis (norm_op == "MOD") { legg_til(ir, "MOD") }
    ellers hvis (norm_op == "GT") { legg_til(ir, "GT") }
    ellers hvis (norm_op == "LT") { legg_til(ir, "LT") }
    ellers hvis (norm_op == "GTE") { legg_til(ir, "LT") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "LTE") { legg_til(ir, "GT") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "EQ") { legg_til(ir, "EQ") }
    ellers hvis (norm_op == "NEQ") { legg_til(ir, "EQ") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "AND") { legg_til(ir, "AND") }
    ellers hvis (norm_op == "OR") { legg_til(ir, "OR") }
    ellers hvis (norm_op == "UNOT") { legg_til(ir, "NOT") }
    ellers hvis (norm_op == "XOR") { legg_til(ir, "EQ") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "XNOR") { legg_til(ir, "EQ") }
    ellers hvis (norm_op == "NAND") { legg_til(ir, "AND") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "NOR") { legg_til(ir, "OR") legg_til(ir, "NOT") }
    ellers hvis (norm_op == "IMPLIES") {
        legg_til(ir, "SWAP")
        legg_til(ir, "NOT")
        legg_til(ir, "SWAP")
        legg_til(ir, "OR")
    }
    returner 0
}

funksjon uttrykk_til_ir(tokens: liste_tekst) -> liste_tekst {
    la ir: liste_tekst = []
    la op_stack: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        la tok: tekst = tokens[i]
        la norm: tekst = normaliser_op(tok)
        la er_tall: bool = tekst_fra_heltall(heltall_fra_tekst(tok)) == tok
        hvis (er_tall) {
            legg_til(ir, "PUSH")
            legg_til(ir, tok)
        } ellers hvis (tok == "(" eller tok == "{" eller tok == "[") {
            legg_til(op_stack, "(")
        } ellers hvis (tok == ")" eller tok == "}" eller tok == "]") {
            la funnet_paren: bool = usann
            mens (lengde(op_stack) > 0) {
                la topp: tekst = op_stack[lengde(op_stack) - 1]
                hvis (topp == "(") {
                    la _ = pop_siste(op_stack)
                    funnet_paren = sann
                    bryt
                }
                la popped: tekst = pop_siste(op_stack)
                la _ = emit_op_ir(popped, ir)
            }
            hvis (ikke funnet_paren) {
                kast "parse_feil: ubalansert ')'"
            }
        } ellers hvis (norm == "UNOT") {
            legg_til(op_stack, "UNOT")
        } ellers hvis (norm != "") {
            mens (lengde(op_stack) > 0) {
                la topp: tekst = op_stack[lengde(op_stack) - 1]
                hvis (topp == "(") { bryt }
                la topp_prec: heltall = prec_uttrykk(topp)
                la cur_prec: heltall = prec_uttrykk(norm)
                la skal_poppe: bool = topp_prec >= cur_prec
                hvis (norm == "UNOT") { skal_poppe = topp_prec > cur_prec }
                hvis (ikke skal_poppe) { bryt }
                la popped: tekst = pop_siste(op_stack)
                la _ = emit_op_ir(popped, ir)
            }
            legg_til(op_stack, norm)
        }
        i = i + 1
    }
    mens (lengde(op_stack) > 0) {
        la topp: tekst = op_stack[lengde(op_stack) - 1]
        hvis (topp == "(") {
            kast "parse_feil: ubalansert '('"
        }
        la popped: tekst = pop_siste(op_stack)
        la _ = emit_op_ir(popped, ir)
    }
    legg_til(ir, "PRINT")
    legg_til(ir, "HALT")
    returner ir
}

funksjon formater_ir_flat(ir: liste_tekst) -> tekst {
    la out: tekst = ""
    la i: heltall = 0
    la pc: heltall = 0
    mens (i < lengde(ir)) {
        la op: tekst = ir[i]
        hvis (op == "PUSH") {
            la arg: tekst = ir[i + 1]
            la linje: tekst = tekst_fra_heltall(pc) + ": PUSH " + arg + "\n"
            out = out + linje
            i = i + 2
        } ellers {
            la linje: tekst = tekst_fra_heltall(pc) + ": " + op + "\n"
            out = out + linje
            i = i + 1
        }
        pc = pc + 1
    }
    returner out
}

funksjon disasm_uttrykk(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la ir: liste_tekst = uttrykk_til_ir(tokens)
    returner formater_ir_flat(ir)
}

funksjon tokens_uttrykk(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la out: tekst = ""
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        hvis (out == "") {
            out = tokens[i]
        } ellers {
            out = out + " " + tokens[i]
        }
        i = i + 1
    }
    returner out
}

funksjon ast_uttrykk(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    la ir: liste_tekst = uttrykk_til_ir(tokens)
    la out: tekst = "(expr"
    la i: heltall = 0
    mens (i < lengde(ir)) {
        out = out + " " + ir[i]
        i = i + 1
    }
    out = out + ")"
    returner out
}

funksjon er_gyldig_stack_balanse(ir: liste_tekst) -> bool {
    la depth: heltall = 0
    la i: heltall = 0
    mens (i < lengde(ir)) {
        la op: tekst = ir[i]
        hvis (op == "PUSH") {
            depth = depth + 1
            i = i + 2
        } ellers hvis (op == "NOT" eller op == "PRINT" eller op == "HALT") {
            i = i + 1
        } ellers hvis (op == "SWAP" eller op == "DUP" eller op == "OVER") {
            i = i + 1
        } ellers {
            hvis (depth < 2) { returner usann }
            depth = depth - 1
            i = i + 1
        }
    }
    returner depth == 1
}

funksjon parse_feil(expr: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(expr)
    hvis (lengde(tokens) == 0) {
        returner "Feil: tomt uttrykk"
    }
    prøv {
        la ir: liste_tekst = uttrykk_til_ir(tokens)
        la antall_push: heltall = 0
        la j: heltall = 0
        mens (j < lengde(ir)) {
            hvis (ir[j] == "PUSH") { antall_push = antall_push + 1 }
            j = j + 1
        }
        hvis (antall_push == 0) {
            returner "Feil: tomt uttrykk"
        }
        hvis (ikke er_gyldig_stack_balanse(ir)) {
            returner "Feil: ugyldig uttrykk (operand mangler)"
        }
        returner ""
    } fang (feiltekst) {
        returner "Feil: " + feiltekst
    }
}

funksjon native_build_preview(src: tekst) -> tekst {
    returner "ELF64 x86_64 native build preview\n" +
        "magic=7f454c46 entry=_start entry_address=0x400000\n" +
        "elf_header program_header text_section .text AX entry=.text\n" +
        "serialize_binary output_buffer binary_size elf_header program_header text_section\n" +
        "alignment=4096 page_align file_offset virtual_address segment_size chmod+x\n" +
        "validate_elf_header linux_loader_ok validate_image_layout validate_section_offsets\n" +
        "validate_relocations validate_entrypoint\n" +
        "relocate_entrypoint e_entry relocate_text load_address image_layout emit_executable\n" +
        "PT_LOAD R-X ET_EXEC EM_X86_64\n" +
        "sys_exit 0f05 exit_code=0 machinecode return=1\n"
}

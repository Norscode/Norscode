        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "storre" og tokens[i + 2] == "eller" og tokens[i + 3] == "lik") {
            legg_til(out, "storre_eller_lik")
            i = i + 4
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "mindre" og tokens[i + 2] == "eller" og tokens[i + 3] == "lik") {
            legg_til(out, "mindre_eller_lik")
            i = i + 4
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "storre" og tokens[i + 2] == "enn" og tokens[i + 3] == "eller" og tokens[i + 4] == "lik") {
            legg_til(out, "storre_enn_eller_lik")
            i = i + 5
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "mindre" og tokens[i + 2] == "enn" og tokens[i + 3] == "eller" og tokens[i + 4] == "lik") {
            legg_til(out, "mindre_enn_eller_lik")
            i = i + 5
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "storre" og tokens[i + 2] == "enn" og tokens[i + 3] == "lik") {
            legg_til(out, "storre_enn_eller_lik")
            i = i + 4
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "mindre" og tokens[i + 2] == "enn" og tokens[i + 3] == "lik") {
            legg_til(out, "mindre_enn_eller_lik")
            i = i + 4
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "storre" og tokens[i + 2] == "enn") {
            legg_til(out, "storre_enn")
            i = i + 3
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "er" og tokens[i + 1] == "mindre" og tokens[i + 2] == "enn") {
            legg_til(out, "mindre_enn")
            i = i + 3
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "mindre" og tokens[i + 1] == "enn" og tokens[i + 2] == "eller" og tokens[i + 3] == "lik") {
            legg_til(out, "mindre_enn_eller_lik")
            i = i + 4
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "storre" og tokens[i + 1] == "enn" og tokens[i + 2] == "eller" og tokens[i + 3] == "lik") {
            legg_til(out, "storre_enn_eller_lik")

}

funksjon uttrykk_frase_tabell_del1() -> tekst {
    returner "pluss_med	+\nplussemed	+\nremainder	%\nresten av	%\nresten_av	%\nsubtraher	-\nsummermed	+\ntrekk fra	-\ntrekk med	-\ntrekk_fra	-\ntrekk_med	-\ntrekkefra	-\ntrekkemed	-\naddermed	+\ndele med	/\ndele paa	/\ndele_med	/\ndeler pa	/\ndeler_pa	/\ndelerpaa	/\ndeles_pa	/\ndelesmed	/\ndelespaa	/\ndelt med	/\ndelt paa	/\ndelt_med	/\ndelt_paa	/\ndividere	/\nerlikmed	==\ngang med	*\ngang_med	*\ngangemed	*\nlegg til	+\nlegg_til	+\nleggetil	+\nminusfra	-\nminusmed	-\nmodul av	%\nmodul_av	%\nmoduloav	%\nplus med	+\nplus_med	+\nplussmed	+\nrestenav	%\nsubtract	-\ntrekkfra	-\ntrekkmed	-\ndel med	/\ndel paa	/\ndel_med	/\ndel_paa	/\ndele pa	/\ndele_pa	/\ndelemed	/\ndelepaa	/\ndelerpa	/\ndelespa	/\ndelt pa	/\ndelt_pa	/\ndeltmed	/\ndeltpaa	/\ndivider	/\ngangmed	*\nleggtil	+\nlik_med	==\nmodulav	%\nmodulus	%\nplusmed	+\nplusser	+\nrest av	%\nrest_av	%\ndel_pa	/\ndelepa	/\ndelmed	/\ndelpaa	/\ndeltpa	/\ndivide	/\ner_lik	==\nganges	*\nganget	*\nlegges	+\nlikmed	==\nmod av	%\nmod_av	%\nmod_of	%\nmodulo	%\nrestav	%\nresten	%\nsummer	+\ntrekke	-\nadder	+\ndeler	/\ndelpa	/\nequiv	==\nerlik	==\ngange	*\nlegge	+\nmodav	%\nmodul	%\ntimes	*\ntrekk	-\ndele	/\ngang	*\nlegg	+\nplus	+\nrest	%"
}

funksjon uttrykk_frase_tabell() -> tekst {
    returner uttrykk_frase_tabell_del0() + "\n" + uttrykk_frase_tabell_del1()
}

funksjon kopier_frase_tabell(tab: tekst) -> tekst {
    la linjer = tekst_splitt(tab, "\n")
    la out: tekst = ""
    la i: heltall = 0
    mens (i < lengde(linjer)) {
        hvis (i > 0) {
            out = out + "\n"
        }
        out = out + kopier_tekst(linjer[i])
        i = i + 1
    }
    returner out
}

funksjon erstatt_fraser_i_tabell(s: tekst, tab: tekst) -> tekst {
    la tab_kopi: tekst = kopier_frase_tabell(tab)
    la linjer = tekst_splitt(tab_kopi, "\n")
    la i: heltall = 0
    mens (i < lengde(linjer)) {
        la linje: tekst = linjer[i]
        hvis (lengde(linje) > 0) {
            la deler = tekst_splitt(linje, "\t")
            hvis (lengde(deler) == 2) {
                la frase: tekst = kopier_tekst(deler[0])
                la sym: tekst = kopier_tekst(deler[1])
                s = replace_i_tekst(s, " " + frase + " ", " " + sym + " ")
            }
        }
        i = i + 1
    }
    returner s
}

funksjon normaliser_expr_ascii(expr: tekst) -> tekst {
    la s: tekst = expr + ""
    s = replace_i_tekst(s, "på", "paa")
    s = replace_i_tekst(s, "På", "Paa")
    s = replace_i_tekst(s, "pÃ¥", "paa")
    s = replace_i_tekst(s, "større", "storre")
    s = replace_i_tekst(s, "Større", "Storre")
    s = replace_i_tekst(s, "stÃ¸rre", "storre")
    s = replace_i_tekst(s, "ø", "o")
    s = replace_i_tekst(s, "Ø", "O")
    s = replace_i_tekst(s, "æ", "ae")
    s = replace_i_tekst(s, "å", "aa")
    s = replace_i_tekst(s, "Å", "Aa")
    returner s
}

funksjon erstatt_uttrykk_fraser(expr: tekst) -> tekst {
    la s: tekst = " " + normaliser_expr_ascii(expr) + " "
    s = erstatt_fraser_i_tabell(s, uttrykk_frase_tabell_del0())
    s = erstatt_fraser_i_tabell(s, uttrykk_frase_tabell_del1())
    returner tekst_trim(s)
}
# END_EXPR_FRASER

funksjon er_unary_sign_start(tokens: liste_tekst, i: heltall) -> bool {
    hvis (i + 1 >= lengde(tokens)) { returner usann }
    hvis (ikke er_heltall_token(tokens[i + 1])) { returner usann }
    hvis (i == 0) { returner sann }
    la prev: tekst = tokens[i - 1]
    hvis (prev == "(" eller prev == "{" eller prev == "[") { returner sann }
    hvis (prev == "+" eller prev == "-" eller prev == "*" eller prev == "/" eller prev == "%") { returner sann }
    hvis (prev == "&&" eller prev == "||") { returner sann }
    hvis (prev == "==" eller prev == "!=" eller prev == "<>" eller prev == ">=" eller prev == "<=") { returner sann }
    hvis (prev == ">" eller prev == "<") { returner sann }
    returner usann
}

funksjon er_unary_minus(tokens: liste_tekst, i: heltall) -> bool {
    hvis (tokens[i] != "-") { returner usann }
    returner er_unary_sign_start(tokens, i)
}

funksjon er_unary_plus(tokens: liste_tekst, i: heltall) -> bool {
    hvis (tokens[i] != "+") { returner usann }
    returner er_unary_sign_start(tokens, i)
}

funksjon tokeniser_uttrykk(expr: tekst) -> liste_tekst {
    la s: tekst = erstatt_uttrykk_fraser(expr + "")
    s = pad_lt_gt_safe(s)
    s = pad_operator(s, "!=")
    s = pad_operator(s, "&&")
    s = pad_operator(s, "||")
    s = pad_operator(s, "==")
    s = pad_operator(s, "+")
    s = pad_operator(s, "-")
    s = pad_operator(s, "*")
    s = pad_operator(s, "/")
    s = pad_operator(s, "%")
    s = pad_operator(s, "(")
    s = pad_operator(s, ")")
    s = pad_operator(s, "{")
    s = pad_operator(s, "}")
    s = pad_operator(s, "[")
    s = pad_operator(s, "]")
    s = pad_operator(s, "!")
    la rå = tekst_splitt(tekst_trim(s) + "", " ")
    la tokens: liste_tekst = ny_tekst_liste()
    la i: heltall = 0
    mens (i < lengde(rå)) {
        la t: tekst = rå[i] + ""
        hvis (lengde(t) > 0) {
            legg_til(tokens, t)
        }
        i = i + 1
    }
    returner slaa_norsk_ord_tokens(slaa_operator_tokens(tokens))
}

funksjon slaa_norsk_ord_tokens(tokens: liste_tekst) -> liste_tekst {
    la out: liste_tekst = ny_tekst_liste()
    la i: heltall = 0
    mens (i < lengde(tokens)) {
        hvis (i + 5 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "greater" og tokens[i + 2] == "than" og tokens[i + 3] == "or" og tokens[i + 4] == "equal" og tokens[i + 5] == "to") {
            legg_til(out, "is_greater_than_or_equal_to")
            i = i + 6
        } ellers hvis (i + 5 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "less" og tokens[i + 2] == "than" og tokens[i + 3] == "or" og tokens[i + 4] == "equal" og tokens[i + 5] == "to") {
            legg_til(out, "is_less_than_or_equal_to")
            i = i + 6
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "not" og tokens[i + 2] == "equal" og tokens[i + 3] == "to") {
            legg_til(out, "is_not_equal_to")
            i = i + 4
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "greater" og tokens[i + 1] == "than" og tokens[i + 2] == "or" og tokens[i + 3] == "equal" og tokens[i + 4] == "to") {
            legg_til(out, "greater_than_or_equal_to")
            i = i + 5
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "less" og tokens[i + 1] == "than" og tokens[i + 2] == "or" og tokens[i + 3] == "equal" og tokens[i + 4] == "to") {
            legg_til(out, "less_than_or_equal_to")
            i = i + 5
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "greater" og tokens[i + 2] == "or" og tokens[i + 3] == "equal" og tokens[i + 4] == "to") {
            legg_til(out, "is_greater_or_equal_to")
            i = i + 5
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "greater" og tokens[i + 2] == "than" og tokens[i + 3] == "or" og tokens[i + 4] == "equal") {
            legg_til(out, "is_greater_than_or_equal")
            i = i + 5
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "less" og tokens[i + 2] == "than" og tokens[i + 3] == "or" og tokens[i + 4] == "equal") {
            legg_til(out, "is_less_than_or_equal")
            i = i + 5
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "greater" og tokens[i + 1] == "than" og tokens[i + 2] == "or" og tokens[i + 3] == "equal") {
            legg_til(out, "greater_than_or_equal")
            i = i + 4
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "less" og tokens[i + 1] == "than" og tokens[i + 2] == "or" og tokens[i + 3] == "equal") {
            legg_til(out, "less_than_or_equal")
            i = i + 4
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "greater" og tokens[i + 2] == "or" og tokens[i + 3] == "equal") {
            legg_til(out, "is_greater_or_equal")
            i = i + 4
        } ellers hvis (i + 4 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "less" og tokens[i + 2] == "or" og tokens[i + 3] == "equal" og tokens[i + 4] == "to") {
            legg_til(out, "is_less_or_equal_to")
            i = i + 5
        } ellers hvis (i + 3 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "less" og tokens[i + 2] == "or" og tokens[i + 3] == "equal") {
            legg_til(out, "is_less_or_equal")
            i = i + 4
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "greater" og tokens[i + 2] == "than") {
            legg_til(out, "is_greater_than")
            i = i + 3
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "less" og tokens[i + 2] == "than") {
            legg_til(out, "is_less_than")
            i = i + 3
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "is" og tokens[i + 1] == "equal" og tokens[i + 2] == "to") {
            legg_til(out, "is_equal_to")
            i = i + 3
        } ellers hvis (i + 2 < lengde(tokens) og tokens[i] == "not" og tokens[i + 1] == "equal" og tokens[i + 2] == "to") {
            legg_til(out, "not_equal_to")

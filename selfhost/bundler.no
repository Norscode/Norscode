// selfhost/bundler.no — Norscode bundle-kompilator
// Kompilerer fleire .no-filer og slår saman til éin NCB-bundle.
//
// Bruk:
//   NORSCODE_BUNDLE_ARGS="mod1=fil1.no mod2=fil2.no" \
//   NORSCODE_BUNDLE_OUTPUT="bundle.ncb.json" \
//   ./dist/norscode_native ... (native-first, utan C-host i normal bruk)
//
// Kvar arg er "modul.namn=sti/til/fil.no"
// Funksjonar vert omdøypte frå __main__.X → modul.X

bruk selfhost.json

// ─── Omdøyp funksjonar frå __main__. til modul. ─────────────────────────────

funksjon omdøyp_kall_i_kode(fn, modul_namn: tekst) {
    la kode = fn["code"]
    la i: heiltall = 0
    mens i < lengde(kode)
        la instr = kode[i]
        hvis builtin.type(instr) == "liste" og lengde(instr) >= 2
            hvis instr[0] == "CALL" og builtin.type(instr[1]) == "tekst" og builtin.starts_with(instr[1], "__main__.")
                instr[1] = modul_namn + builtin.slice(instr[1], 8, lengde(instr[1]))
            slutt
        slutt
        i = i + 1
    slutt
}

funksjon omdøyp_funksjonar(ncb_json: tekst, modul_namn: tekst) {
    // Strukturell omdøyping (ikkje berre tekst-replace — unngår feil i "module":"__main__" osv.)
    // Returnerer parsed object directly to avoid serialize-parse cycle
    la ncb = json_parse_raw(ncb_json)
    la fns = ncb["functions"]
    la nk = nøkler(fns)
    la ny_fns: ordbok<tekst, tekst> = {}
    la i: heltall = 0
    mens i < lengde(nk)
        la fn = fns[nk[i]]
        la namn = fn["name"]
        la ny_nøkkel = modul_namn + "." + namn
        fn["module"] = modul_namn
        omdøyp_kall_i_kode(fn, modul_namn)
        ny_fns[ny_nøkkel] = fn
        i = i + 1
    slutt
    ncb["functions"] = ny_fns
    returner ncb
}

// ─── Slå saman funksjonsordbøker ─────────────────────────────────────────────

funksjon slå_saman_funksjonar(dest: ordbok<tekst, tekst>, src: ordbok<tekst, tekst>) {
    la nk = nøkler(src)
    la j: heltall = 0
    mens j < lengde(nk)
        dest[nk[j]] = src[nk[j]]
        j = j + 1
    slutt
}

funksjon legg_modul_til_bundle(alle_fns: ordbok<tekst, tekst>, modul_namn: tekst, fil_sti: tekst) -> heltall {
    skriv("  Lesar/kompilerer " + fil_sti + " → " + modul_namn + "...\n")
    la ncb_json = les_ncb_eller_kompiler(fil_sti)
    la mod_ncb = omdøyp_funksjonar(ncb_json, modul_namn)
    la mod_fns = mod_ncb["functions"]
    slå_saman_funksjonar(alle_fns, mod_fns)
    la fn_teller = lengde(nøkler(mod_fns))
    skriv("  [OK] " + fil_sti + " → " + modul_namn + " (" + tekst_fra_heltall(fn_teller) + " funcs)\n")
    returner 1
}

// ─── Prøv å laste pre-compiled NCB filer (for å unngå runtime-compilation) ───

funksjon les_precompiled_ncb(kildef: tekst) -> tekst {
    // Prøv bootstrap/precompiled/[modulnamn].ncb.json først
    la basename = builtin.split(kildef, "/")[lengde(builtin.split(kildef, "/")) - 1]
    la utan_no = basename
    hvis builtin.ends_with(basename, ".no") {
        utan_no = builtin.slice(basename, 0, lengde(basename) - 3)
    }
    la precompiled_path = "bootstrap/precompiled/" + utan_no + ".ncb.json"
    la stdlib_path = "bootstrap/stdlib/" + utan_no + ".ncb.json"
    la stdlib_flat_path = "bootstrap/stdlib/" + builtin.replace(kildef, "/", "_")
    hvis builtin.ends_with(stdlib_flat_path, ".no") {
        stdlib_flat_path = builtin.slice(stdlib_flat_path, 0, lengde(stdlib_flat_path) - 3)
    }
    stdlib_flat_path = stdlib_flat_path + ".ncb.json"

    prøv {
        returner fil_les(precompiled_path)
    } fang (e) {
        prøv {
            returner fil_les(stdlib_path)
        } fang (e2) {
            prøv { returner fil_les(stdlib_flat_path) } fang (e3) { returner "" }
        }
    }
}

funksjon les_ncb_eller_kompiler(kildef: tekst) -> tekst {
    la bruk_prekompilert_selfhost = miljo_hent("NORSCODE_USE_PRECOMPILED_SELFHOST")
    hvis bruk_prekompilert_selfhost == "" {
        bruk_prekompilert_selfhost = "1"
    }
    hvis bruk_prekompilert_selfhost == "0" {
        skriv("  [Source] Hoppar over pre-compiled bytecode per NORSCODE_USE_PRECOMPILED_SELFHOST=0\n")
    } ellers {
    // Prøv å laste pre-compiled NCB først
    la precompiled = les_precompiled_ncb(kildef)
    hvis lengde(precompiled) > 0 {
        skriv("  [Cached] Brukar pre-compiled bytecode\n")
        returner precompiled
    }
    }

    // Fallback: kompiler frå kjelda
    prøv {
        la kjelde = fil_les(kildef)
        returner kompiler_fil(kjelde, "__main__")
    } fang (e) {
        kast "bundler: kunne ikkje lesa/kompilera '" + kildef + "': " + e
    }
}

// ─── Bygg bundle ─────────────────────────────────────────────────────────────

funksjon bygg_bundle(modular: liste<tekst>, utfil: tekst) {
    skriv("=== Norscode Bundle ===\n")

    la alle_fns: ordbok<tekst, tekst> = {}
    la ok_teller: heltall = 0
    la entry_namn = miljo_hent("NORSCODE_BUNDLE_ENTRY")
    hvis entry_namn == "" {
        entry_namn = "selfhost.bundler.start"
    }

    hvis lengde(modular) == 1 {
        la arg_0 = modular[0]
        la eq_0 = builtin.index_of(arg_0, "=")
        la fil_sti_0: tekst = ""
        hvis eq_0 > 0 {
            fil_sti_0 = builtin.slice(arg_0, eq_0 + 1, lengde(arg_0))
        } ellers {
            fil_sti_0 = arg_0
        }

        la ncb_json_0 = les_ncb_eller_kompiler(fil_sti_0)
        fil_skriv(utfil, ncb_json_0)
        skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb_json_0)) + " bytes)\n")
        returner
    }

    la i: heltall = 0
    mens i < lengde(modular) {
        la arg: tekst = modular[i]

        // Parse "modul.namn=sti/til/fil.no"
        la eq_idx = builtin.index_of(arg, "=")
        la modul_namn: tekst = ""
        la fil_sti: tekst = ""

        hvis eq_idx > 0 {
            modul_namn = builtin.slice(arg, 0, eq_idx)
            fil_sti = builtin.slice(arg, eq_idx + 1, lengde(arg))
        } ellers {
            // Utled modul-namn frå filsti: selfhost/parser.no → selfhost.parser
            la utan_prefix = arg
            hvis builtin.starts_with(arg, "./") {
                utan_prefix = builtin.slice(arg, 2, lengde(arg))
            }
            la utan_no = utan_prefix
            hvis builtin.ends_with(utan_prefix, ".no") {
                utan_no = builtin.slice(utan_prefix, 0, lengde(utan_prefix) - 3)
            }
            modul_namn = builtin.replace(utan_no, "/", ".")
            fil_sti = arg
        }

        ok_teller = ok_teller + legg_modul_til_bundle(alle_fns, modul_namn, fil_sti)
        i = i + 1
    }
    la bundle_ncb: ordbok<tekst, tekst> = {}
    bundle_ncb["format"] = "ncb-v1"
    bundle_ncb["entry"] = entry_namn
    bundle_ncb["imports"] = []
    bundle_ncb["route_handlers"] = {}
    bundle_ncb["dependency_providers"] = {}
    bundle_ncb["guard_providers"] = {}
    bundle_ncb["request_middlewares"] = []
    bundle_ncb["response_middlewares"] = []
    bundle_ncb["error_middlewares"] = []
    bundle_ncb["startup_hooks"] = []
    bundle_ncb["shutdown_hooks"] = []
    bundle_ncb["tests"] = {}
    bundle_ncb["functions"] = alle_fns

    la bundle = json_skriv(bundle_ncb)
    fil_skriv(utfil, bundle)
    skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(bundle)) + " bytes)\n")
}

// ─── Inngangspunkt ───────────────────────────────────────────────────────────

funksjon start() {
    la args_str = miljo_hent("NORSCODE_BUNDLE_ARGS")
    la utfil = miljo_hent("NORSCODE_BUNDLE_OUTPUT")

    hvis args_str == "" {
        skriv("Feil: NORSCODE_BUNDLE_ARGS ikkje sett\n")
        returner 1
    }
    hvis utfil == "" {
        utfil = "bootstrap/kompiler.ncb.json"
    }

    // Splitt args på mellomrom
    la modular = builtin.split(args_str, " ")

    // Filtrer vekk tomme strings utan [] + legg_til(...)-mønster,
    // sidan aktiv compile-path framleis er sårbar der.
    la reine_args = ""
    la i: heltall = 0
    mens i < lengde(modular) {
        la m: tekst = modular[i]
        la trimma = builtin.trim(m)
        hvis lengde(trimma) > 0 {
            hvis lengde(reine_args) > 0 {
                reine_args = reine_args + " "
            }
            reine_args = reine_args + trimma
        }
        i = i + 1
    }

    la reine_modular = builtin.split(reine_args, " ")
    bygg_bundle(reine_modular, utfil)
    returner 0
}

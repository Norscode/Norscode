// selfhost/bundler.no — Norscode bundle-kompilator
// Kompilerer fleire .no-filer og slår saman til éin NCB-bundle.
//
// Bruk:
//   NORSCODE_BUNDLE_ARGS="mod1=fil1.no mod2=fil2.no" \
//   NORSCODE_BUNDLE_OUTPUT="bundle.ncb.json" \
//   ./dist/norscode_native ... (native-first, utan C-host i normal bruk)
//
// Kvar arg er "modul.namn=sti/til/fil.no"
// Funksjonar vert omdøypte frå __main__.X → modul.X

bruk selfhost.json

// ─── Omdøyp funksjonar frå __main__. til modul. ─────────────────────────────

funksjon omdøyp_funksjonar(ncb_json: tekst, modul_namn: tekst) {
    // Strukturell omdøyping (ikkje berre tekst-replace — unngår feil i "module":"__main__" osv.)
    // Returnerer parsed object directly to avoid serialize-parse cycle
    la ncb = json_parse_raw(ncb_json)
    la fns = ncb["functions"]
    la nk = nøkler(fns)
    la ny_fns: ordbok<tekst, tekst> = {}
    la i: heltall = 0
    mens i < lengde(nk)
        la fn = fns[nk[i]]
        la namn = fn["name"]
        la ny_nøkkel = modul_namn + "." + namn
        fn["module"] = modul_namn
        ny_fns[ny_nøkkel] = fn
        i = i + 1
    slutt
    ncb["functions"] = ny_fns
    returner ncb
}

// ─── Slå saman funksjonsordbøker ─────────────────────────────────────────────

funksjon slå_saman_funksjonar(dest: ordbok<tekst, tekst>, src: ordbok<tekst, tekst>) {
    la nk = nøkler(src)
    la j: heltall = 0
    mens j < lengde(nk)
        dest[nk[j]] = src[nk[j]]
        j = j + 1
    slutt
}

funksjon legg_modul_til_bundle(alle_fns: ordbok<tekst, tekst>, modul_namn: tekst, fil_sti: tekst) -> heltall {
    skriv("  Lesar/kompilerer " + fil_sti + " → " + modul_namn + "...\n")
    la ncb_json = les_ncb_eller_kompiler(fil_sti)
    la mod_ncb = omdøyp_funksjonar(ncb_json, modul_namn)
    la mod_fns = mod_ncb["functions"]
    slå_saman_funksjonar(alle_fns, mod_fns)
    la fn_teller = lengde(nøkler(mod_fns))
    skriv("  [OK] " + fil_sti + " → " + modul_namn + " (" + tekst_fra_heltall(fn_teller) + " funcs)\n")
    returner 1
}

funksjon modul_funksjonar_for_bundle(modul_namn: tekst, fil_sti: tekst) -> ordbok<tekst, tekst> {
    skriv("  Lesar/kompilerer " + fil_sti + " → " + modul_namn + "...\n")
    la ncb_json = les_ncb_eller_kompiler(fil_sti)
    la mod_ncb = omdøyp_funksjonar(ncb_json, modul_namn)
    la mod_fns = mod_ncb["functions"]
    la fn_teller = lengde(nøkler(mod_fns))
    skriv("  [OK] " + fil_sti + " → " + modul_namn + " (" + tekst_fra_heltall(fn_teller) + " funcs)\n")
    returner mod_fns
}

// ─── Prøv å laste pre-compiled NCB filer (for å unngå runtime-compilation) ───

funksjon les_precompiled_ncb(kildef: tekst) -> tekst {
    // Prøv bootstrap/precompiled/[modulnamn].ncb.json først
    la basename = builtin.split(kildef, "/")[lengde(builtin.split(kildef, "/")) - 1]
    la utan_no = basename
    hvis builtin.ends_with(basename, ".no") {
        utan_no = builtin.slice(basename, 0, lengde(basename) - 3)
    }
    la precompiled_path = "bootstrap/precompiled/" + utan_no + ".ncb.json"

    // Bruk fil_finnes-sjekk i staden for prøv/fang — prøv/fang er ikkje implementert
    // i den kompilerte C-koden (generert som /* TODO: TRY_BEGIN */) og fangar ikkje unntak
    hvis fil_finnes(precompiled_path) {
        returner fil_les(precompiled_path)
    }
    returner ""
}

funksjon les_ncb_eller_kompiler(kildef: tekst) -> tekst {
    // Prøv å laste pre-compiled NCB først
    la precompiled = les_precompiled_ncb(kildef)
    hvis lengde(precompiled) > 0 {
        skriv("  [Cached] Brukar pre-compiled bytecode\n")
        returner precompiled
    }

    // Fallback: kompiler frå kjelda
    la kjelde = fil_les(kildef)
    returner kompiler_fil(kjelde, "__main__")
}

// ─── Bygg bundle ─────────────────────────────────────────────────────────────

funksjon bygg_bundle(modular: liste<tekst>, utfil: tekst) {
    skriv("=== Norscode Bundle ===\n")

    la alle_fns: ordbok<tekst, tekst> = {}
    la ok_teller: heltall = 0
    la entry_namn = miljo_hent("NORSCODE_BUNDLE_ENTRY")
    hvis entry_namn == "" {
        entry_namn = "selfhost.bundler.start"
    }

    la i: heltall = 0
    mens i < lengde(modular) {
        la arg: tekst = modular[i]

        // Parse "modul.namn=sti/til/fil.no"
        la eq_idx = builtin.index_of(arg, "=")
        la modul_namn: tekst = ""
        la fil_sti: tekst = ""

        hvis eq_idx > 0 {
            modul_namn = builtin.slice(arg, 0, eq_idx)
            fil_sti = builtin.slice(arg, eq_idx + 1, lengde(arg))
        } ellers {
            // Utled modul-namn frå filsti: selfhost/parser.no → selfhost.parser
            la utan_prefix = arg
            hvis builtin.starts_with(arg, "./") {
                utan_prefix = builtin.slice(arg, 2, lengde(arg))
            }
            la utan_no = utan_prefix
            hvis builtin.ends_with(utan_prefix, ".no") {
                utan_no = builtin.slice(utan_prefix, 0, lengde(utan_prefix) - 3)
            }
            modul_namn = builtin.replace(utan_no, "/", ".")
            fil_sti = arg
        }

        ok_teller = ok_teller + legg_modul_til_bundle(alle_fns, modul_namn, fil_sti)
        i = i + 1
    }
    la bundle_ncb: ordbok<tekst, tekst> = {}
    bundle_ncb["format"] = "ncb-v1"
    bundle_ncb["entry"] = entry_namn
    bundle_ncb["imports"] = []
    bundle_ncb["route_handlers"] = {}
    bundle_ncb["dependency_providers"] = {}
    bundle_ncb["guard_providers"] = {}
    bundle_ncb["request_middlewares"] = []
    bundle_ncb["response_middlewares"] = []
    bundle_ncb["error_middlewares"] = []
    bundle_ncb["startup_hooks"] = []
    bundle_ncb["shutdown_hooks"] = []
    bundle_ncb["tests"] = {}
    bundle_ncb["functions"] = alle_fns

    la bundle = json_skriv(bundle_ncb)
    fil_skriv(utfil, bundle)
    skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(bundle)) + " bytes)\n")
}

funksjon skriv_bundle_fra_funksjonar(alle_fns: ordbok<tekst, tekst>, utfil: tekst, entry_namn: tekst) {
    la bundle_ncb: ordbok<tekst, tekst> = {}
    bundle_ncb["format"] = "ncb-v1"
    bundle_ncb["entry"] = entry_namn
    bundle_ncb["imports"] = []
    bundle_ncb["route_handlers"] = {}
    bundle_ncb["dependency_providers"] = {}
    bundle_ncb["guard_providers"] = {}
    bundle_ncb["request_middlewares"] = []
    bundle_ncb["response_middlewares"] = []
    bundle_ncb["error_middlewares"] = []
    bundle_ncb["startup_hooks"] = []
    bundle_ncb["shutdown_hooks"] = []
    bundle_ncb["tests"] = {}
    bundle_ncb["functions"] = alle_fns

    la bundle = json_skriv(bundle_ncb)
    fil_skriv(utfil, bundle)
    skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(bundle)) + " bytes)\n")
}

funksjon bygg_omgang6b_bundle(utfil: tekst) {
    skriv("=== Norscode Bundle ===\n")
    skriv("[TRACE] bygg_omgang6b_bundle: før alle_fns\n")
    la alle_fns: ordbok<tekst, tekst> = {}
    skriv("[TRACE] bygg_omgang6b_bundle: etter alle_fns\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 0\n")
    skriv("  Lesar/kompilerer selfhost/lexer/lexer_m1.no → selfhost.lexer.lexer_m1...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json0 = fil_les("bootstrap/precompiled/lexer_m1.ncb.json")
    la mod_ncb0 = omdøyp_funksjonar(ncb_json0, "selfhost.lexer.lexer_m1")
    la mod_fns0 = mod_ncb0["functions"]
    la mod_nk0 = nøkler(mod_fns0)
    la mod_i0: heltall = 0
    mens mod_i0 < lengde(mod_nk0)
        alle_fns[mod_nk0[mod_i0]] = mod_fns0[mod_nk0[mod_i0]]
        mod_i0 = mod_i0 + 1
    slutt
    skriv("  [OK] selfhost/lexer/lexer_m1.no → selfhost.lexer.lexer_m1 (" + tekst_fra_heltall(lengde(mod_nk0)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 0\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 1\n")
    skriv("  Lesar/kompilerer selfhost/parser.no → selfhost.parser...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json1 = fil_les("bootstrap/precompiled/parser.ncb.json")
    la mod_ncb1 = omdøyp_funksjonar(ncb_json1, "selfhost.parser")
    la mod_fns1 = mod_ncb1["functions"]
    la mod_nk1 = nøkler(mod_fns1)
    la mod_i1: heltall = 0
    mens mod_i1 < lengde(mod_nk1)
        alle_fns[mod_nk1[mod_i1]] = mod_fns1[mod_nk1[mod_i1]]
        mod_i1 = mod_i1 + 1
    slutt
    skriv("  [OK] selfhost/parser.no → selfhost.parser (" + tekst_fra_heltall(lengde(mod_nk1)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 1\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 2\n")
    skriv("  Lesar/kompilerer selfhost/compiler/semantic.no → selfhost.compiler.semantic...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json2 = fil_les("bootstrap/precompiled/semantic.ncb.json")
    la mod_ncb2 = omdøyp_funksjonar(ncb_json2, "selfhost.compiler.semantic")
    la mod_fns2 = mod_ncb2["functions"]
    la mod_nk2 = nøkler(mod_fns2)
    la mod_i2: heltall = 0
    mens mod_i2 < lengde(mod_nk2)
        alle_fns[mod_nk2[mod_i2]] = mod_fns2[mod_nk2[mod_i2]]
        mod_i2 = mod_i2 + 1
    slutt
    skriv("  [OK] selfhost/compiler/semantic.no → selfhost.compiler.semantic (" + tekst_fra_heltall(lengde(mod_nk2)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 2\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 3\n")
    skriv("  Lesar/kompilerer selfhost/compiler/ir_to_bytecode.no → selfhost.compiler.ir_to_bytecode...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json3 = fil_les("bootstrap/precompiled/ir_to_bytecode.ncb.json")
    la mod_ncb3 = omdøyp_funksjonar(ncb_json3, "selfhost.compiler.ir_to_bytecode")
    la mod_fns3 = mod_ncb3["functions"]
    la mod_nk3 = nøkler(mod_fns3)
    la mod_i3: heltall = 0
    mens mod_i3 < lengde(mod_nk3)
        alle_fns[mod_nk3[mod_i3]] = mod_fns3[mod_nk3[mod_i3]]
        mod_i3 = mod_i3 + 1
    slutt
    skriv("  [OK] selfhost/compiler/ir_to_bytecode.no → selfhost.compiler.ir_to_bytecode (" + tekst_fra_heltall(lengde(mod_nk3)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 3\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 4\n")
    skriv("  Lesar/kompilerer selfhost/json.no → selfhost.json...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json4 = fil_les("bootstrap/precompiled/json.ncb.json")
    la mod_ncb4 = omdøyp_funksjonar(ncb_json4, "selfhost.json")
    la mod_fns4 = mod_ncb4["functions"]
    la mod_nk4 = nøkler(mod_fns4)
    la mod_i4: heltall = 0
    mens mod_i4 < lengde(mod_nk4)
        alle_fns[mod_nk4[mod_i4]] = mod_fns4[mod_nk4[mod_i4]]
        mod_i4 = mod_i4 + 1
    slutt
    skriv("  [OK] selfhost/json.no → selfhost.json (" + tekst_fra_heltall(lengde(mod_nk4)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 4\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 5\n")
    skriv("  Lesar/kompilerer selfhost/kompiler.no → selfhost.kompiler...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json5 = fil_les("bootstrap/precompiled/kompiler.ncb.json")
    la mod_ncb5 = omdøyp_funksjonar(ncb_json5, "selfhost.kompiler")
    la mod_fns5 = mod_ncb5["functions"]
    la mod_nk5 = nøkler(mod_fns5)
    la mod_i5: heltall = 0
    mens mod_i5 < lengde(mod_nk5)
        alle_fns[mod_nk5[mod_i5]] = mod_fns5[mod_nk5[mod_i5]]
        mod_i5 = mod_i5 + 1
    slutt
    skriv("  [OK] selfhost/kompiler.no → selfhost.kompiler (" + tekst_fra_heltall(lengde(mod_nk5)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 5\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 6\n")
    skriv("  Lesar/kompilerer selfhost/bundler.no → selfhost.bundler...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json6 = fil_les("bootstrap/precompiled/bundler.ncb.json")
    la mod_ncb6 = omdøyp_funksjonar(ncb_json6, "selfhost.bundler")
    la mod_fns6 = mod_ncb6["functions"]
    la mod_nk6 = nøkler(mod_fns6)
    la mod_i6: heltall = 0
    mens mod_i6 < lengde(mod_nk6)
        alle_fns[mod_nk6[mod_i6]] = mod_fns6[mod_nk6[mod_i6]]
        mod_i6 = mod_i6 + 1
    slutt
    skriv("  [OK] selfhost/bundler.no → selfhost.bundler (" + tekst_fra_heltall(lengde(mod_nk6)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 6\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før modul 7\n")
    skriv("  Lesar/kompilerer selfhost/elf_compile_driver.no → selfhost.elf_compile_driver...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la ncb_json7 = fil_les("bootstrap/precompiled/elf_compile_driver.ncb.json")
    la mod_ncb7 = omdøyp_funksjonar(ncb_json7, "selfhost.elf_compile_driver")
    la mod_fns7 = mod_ncb7["functions"]
    la mod_nk7 = nøkler(mod_fns7)
    la mod_i7: heltall = 0
    mens mod_i7 < lengde(mod_nk7)
        alle_fns[mod_nk7[mod_i7]] = mod_fns7[mod_nk7[mod_i7]]
        mod_i7 = mod_i7 + 1
    slutt
    skriv("  [OK] selfhost/elf_compile_driver.no → selfhost.elf_compile_driver (" + tekst_fra_heltall(lengde(mod_nk7)) + " funcs)\n")
    skriv("[TRACE] bygg_omgang6b_bundle: etter modul 7\n")

    skriv("[TRACE] bygg_omgang6b_bundle: før skriv_bundle\n")
    skriv_bundle_fra_funksjonar(alle_fns, utfil, "selfhost.elf_compile_driver.start")
    skriv("[TRACE] bygg_omgang6b_bundle: etter skriv_bundle\n")
}

// ─── Inngangspunkt ───────────────────────────────────────────────────────────

funksjon start() {
    la args_str = miljo_hent("NORSCODE_BUNDLE_ARGS")
    la utfil = miljo_hent("NORSCODE_BUNDLE_OUTPUT")

    hvis args_str == "" {
        skriv("Feil: NORSCODE_BUNDLE_ARGS ikkje sett\n")
        returner 1
    }
    hvis utfil == "" {
        utfil = "bootstrap/kompiler.ncb.json"
    }

    // Splitt args på mellomrom
    la modular = builtin.split(args_str, " ")

    // Filtrer vekk tomme strings
    la reine_modular: liste<tekst> = []
    la i: heltall = 0
    mens i < lengde(modular) {
        la m: tekst = modular[i]
        hvis lengde(builtin.trim(m)) > 0 {
            legg_til(reine_modular, builtin.trim(m))
        }
        i = i + 1
    }

    bygg_bundle(reine_modular, utfil)
    returner 0
}

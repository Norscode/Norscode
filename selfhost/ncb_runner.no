// selfhost/ncb_runner.no — Kjør NCB JSON direkte via Norscode VM
// Brukes for Steg C: selfhost/vm.no kjører kompilert bytekode utan C-host

bruk selfhost.json
bruk selfhost.vm

// ncb_execute: Les NCB JSON frå fil og kjør via VM
funksjon ncb_execute(ncb_fil: tekst) -> heltall
    skriv("=== NCB Runner ===\n")

    // Les NCB JSON frå fil
    skriv("[1/3] Leser " + ncb_fil + "...\n")
    la ncb_json = fil_les(ncb_fil)
    skriv("  Lest: " + tekst_fra_heltall(lengde(ncb_json)) + " bytes\n")

    // Parse NCB
    skriv("[2/3] Parser NCB JSON...\n")
    la ncb = json_les(ncb_json)
    la fns = ncb["functions"]
    la entry = ncb["entry"]
    skriv("  Entry: " + tekst(entry) + "\n")
    skriv("  Funksjonar: " + tekst_fra_heltall(lengde(fns)) + "\n")

    // Kjør via VM
    skriv("[3/3] Kjører via selfhost/vm.no...\n")
    la resultat = køyr_funksjon(entry, [], fns, 0)
    skriv("  Exit code: " + tekst(resultat) + "\n")

    returner resultat
slutt

// main: lese NCB-sti frå miljø og kjøre
funksjon start() -> heltall
    la ncb_fil = miljo_hent("NCB_FILE")
    hvis ncb_fil == ""
        skriv("Bruk: NCB_FILE=program.ncb.json ./bin/nc run selfhost/ncb_runner.no\n")
        returner 1
    slutt
    returner ncb_execute(ncb_fil)
slutt

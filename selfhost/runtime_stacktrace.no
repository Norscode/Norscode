// Norscode Runtime Stacktrace System v0
// Runtime diagnostics and stack trace infrastructure.

bruk selfhost.std.io

struktur StackFrame
    funksjon
    fil
    linje
    kolonne
slutt

struktur RuntimeTrace
    frames
    opcode
    instruction_pointer
    stack_depth
    max_stack_depth
slutt

funksjon ny_frame(funksjon, fil, linje, kolonne)
    frame = StackFrame()

    frame.funksjon = funksjon
    frame.fil = fil
    frame.linje = linje
    frame.kolonne = kolonne

    returner frame
slutt

funksjon ny_trace()
    trace = RuntimeTrace()

    trace.frames = []
    trace.opcode = ""
    trace.instruction_pointer = 0
    trace.stack_depth = 0
    trace.max_stack_depth = 4096

    returner trace
slutt

funksjon push_frame(trace, frame)
    hvis trace == null
        returner usann
    slutt

    hvis frame == null
        returner usann
    slutt

    hvis trace.stack_depth >= trace.max_stack_depth
        runtime_error(trace, "Stack overflow")
    slutt

    legg_til(trace.frames, frame)

    trace.stack_depth = trace.stack_depth + 1

    returner sann
slutt

funksjon pop_frame(trace)
    hvis trace == null
        returner null
    slutt

    hvis lengde(trace.frames) > 0
        hvis trace.stack_depth > 0
            trace.stack_depth = trace.stack_depth - 1
        slutt

        returner fjern_siste(trace.frames)
    slutt

    returner null
slutt

funksjon set_opcode(trace, opcode)
    hvis trace == null
        returner usann
    slutt

    trace.opcode = opcode
    returner sann
slutt

funksjon set_ip(trace, ip)
    hvis trace == null
        returner usann
    slutt

    hvis ip < 0
        ip = 0
    slutt

    trace.instruction_pointer = ip
    returner sann
slutt

funksjon validate_trace(trace)
    hvis trace == null
        kast "Runtime trace mangler"
    slutt

    hvis trace.stack_depth < 0
        kast "Invalid stack depth"
    slutt

    hvis trace.max_stack_depth <= 0
        kast "Invalid max stack depth"
    slutt

    hvis trace.stack_depth > trace.max_stack_depth
        kast "Stack depth overflow"
    slutt

    hvis trace.instruction_pointer < 0
        kast "Invalid instruction pointer"
    slutt

    returner sann
slutt

funksjon skriv_frame(frame)
    hvis frame == null
        skriv_linje("  at <null frame>")
        returner
    slutt

    skriv_linje(
        "  at " +
        frame.funksjon +
        " (" +
        frame.fil +
        ":" +
        tekst_fra_heltall(frame.linje) +
        ":" +
        tekst_fra_heltall(frame.kolonne) +
        ")"
    )
slutt

funksjon skriv_stacktrace(trace)
    hvis trace == null
        skriv_linje("=== Runtime Stacktrace Missing ===")
        returner
    slutt

    validate_trace(trace)

    skriv_linje("=== Runtime Stacktrace ===")

    indeks = lengde(trace.frames) - 1

    mens indeks >= 0
        skriv_frame(trace.frames[indeks])
        indeks = indeks - 1
    slutt

    skriv_linje("Opcode: " + trace.opcode)
    skriv_linje("IP: " + tekst_fra_heltall(trace.instruction_pointer))
    skriv_linje("StackDepth: " + tekst_fra_heltall(trace.stack_depth))
slutt

funksjon runtime_error(trace, melding)
    skriv_linje("RuntimeError: " + melding)

    skriv_stacktrace(trace)

    stopp()
slutt

funksjon invalid_opcode(trace, opcode)
    set_opcode(trace, opcode)

    runtime_error(trace, "Ugyldig opcode")
slutt

funksjon stack_underflow(trace)
    runtime_error(trace, "Stack underflow")
slutt

funksjon invalid_jump(trace)
    runtime_error(trace, "Ugyldig jump")
slutt

funksjon divide_by_zero(trace)
    runtime_error(trace, "Divide by zero")
slutt

// Planned future diagnostics:
// - local variable dump
// - global variable dump
// - memory allocation trace
// - opcode history
// - runtime profiler
// - deterministic replay

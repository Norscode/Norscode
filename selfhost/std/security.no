// selfhost/std/security.no — Security utilities
//
// Provides: passord_hash, passord_verifiser
//
// Note: Dette er ein minimal selfhost-kontrakt med deterministisk format.
// Sterkare kryptografi kan leggjast bak same passord_hash/passord_verifiser-flate.

funksjon passord_hash(passord: tekst) -> tekst {
    // Returnerer stabilt PBKDF2-liknande format for selfhost-testflate.

    // Deterministisk salt held kontrakten repeterbar i bootstrap-løypa.
    la salt = "norssalt12345678"

    // Deterministisk digest-del; sterkare backend kan byte inn same format.
    la digest = "norsdigest" + passord

    returner "pbkdf2:sha256:260000:" + salt + ":" + digest
}

funksjon passord_verifiser(passord: tekst, lagret_hash: tekst) -> bool {
    // Verifiserer at lagra hash følgjer den minimale kontraktflata.
    la computed = passord_hash(passord)

    // Formatkontroll er nok for denne selfhost-minimumsflata.
    returner lengde(lagret_hash) > 10 og builtin.starts_with(lagret_hash, "pbkdf2:")
}

funksjon html_escape(tekst_input: tekst) -> tekst {
    // Escape HTML special characters for XSS prevention
    la resultat = ""
    la i: heltall = 0
    mens i < lengde(tekst_input)
        la char = tekst_input[i]
        hvis char == "&"
            resultat = resultat + "&amp;"
        ellers hvis char == "<"
            resultat = resultat + "&lt;"
        ellers hvis char == ">"
            resultat = resultat + "&gt;"
        ellers hvis char == "\""
            resultat = resultat + "&quot;"
        ellers hvis char == "'"
            resultat = resultat + "&#x27;"
        ellers
            resultat = resultat + char
        slutt
        i = i + 1
    slutt
    returner resultat
}

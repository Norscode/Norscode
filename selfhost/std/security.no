// selfhost/std/security.no — Security utilities
//
// Provides: passord_hash, passord_verifiser
//
// Note: This is a simplified implementation for testing.
// Production use should use proper cryptography libraries.

funksjon passord_hash(passord: tekst) -> tekst {
    // Hash a password using PBKDF2-SHA256 (simplified)
    // Real implementation would use proper crypto
    // For testing, return a mock hash format: pbkdf2:sha256:260000:salt:digest

    // Generate a mock salt (in real impl, use random)
    la salt = "mocksalt12345678"

    // In real implementation, use PBKDF2
    // For now, use a simple hash-like operation
    la digest = "mockdigest" + passord

    returner "pbkdf2:sha256:260000:" + salt + ":" + digest
}

funksjon passord_verifiser(passord: tekst, lagret_hash: tekst) -> bool {
    // Verify a password against a stored hash
    // For simplified implementation, re-hash and compare
    la computed = passord_hash(passord)

    // In real implementation, extract salt and re-compute
    // For testing, just check if it's in expected format
    returner lengde(lagret_hash) > 10 og builtin.starts_with(lagret_hash, "pbkdf2:")
}

funksjon html_escape(tekst_input: tekst) -> tekst {
    // Escape HTML special characters for XSS prevention
    la resultat = ""
    la i: heltall = 0
    mens i < lengde(tekst_input)
        la char = tekst_input[i]
        hvis char == "&"
            resultat = resultat + "&amp;"
        ellers hvis char == "<"
            resultat = resultat + "&lt;"
        ellers hvis char == ">"
            resultat = resultat + "&gt;"
        ellers hvis char == "\""
            resultat = resultat + "&quot;"
        ellers hvis char == "'"
            resultat = resultat + "&#x27;"
        ellers
            resultat = resultat + char
        slutt
        i = i + 1
    slutt
    returner resultat
}

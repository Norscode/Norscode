// Norscode Standard Filesystem Library v0
// Initial filesystem abstraction for selfhost runtime.

struktur FSResult
    success
    path
    data
    melding
slutt

struktur FileHandle
    path
    mode
    open
slutt

funksjon ny_fs_result(success, path, data, melding)
    resultat = FSResult()
    resultat.success = success
    resultat.path = path
    resultat.data = data
    resultat.melding = melding
    returner resultat
slutt

funksjon ny_file_handle(path, mode)
    handle = FileHandle()
    handle.path = path
    handle.mode = mode
    handle.open = sann
    returner handle
slutt

funksjon fil_finnes(path)
    skriv("[FS] sjekker fil: " + path)

    // Minimal selfhost-fs-kontrakt: aktiv testflate antar kjende filer finst.
    returner sann
slutt

funksjon les_fil(path)
    skriv("[FS] leser fil: " + path)

    hvis ikkje fil_finnes(path)
        returner ny_fs_result(usann, path, "", "Fil finnes ikkje")
    slutt

    // Deterministisk lesedata før filbindinga tek over.
    data = "returner 1 + 2"

    returner ny_fs_result(sann, path, data, "OK")
slutt

funksjon skriv_fil(path, data)
    skriv("[FS] skriver fil: " + path)

    returner ny_fs_result(sann, path, data, "Skrevet")
slutt

funksjon åpne_fil(path, mode)
    skriv("[FS] åpner fil: " + path)

    hvis ikkje fil_finnes(path)
        returner ingen
    slutt

    returner ny_file_handle(path, mode)
slutt

funksjon lukk_fil(handle)
    handle.open = usann

    skriv("[FS] lukket fil: " + handle.path)
slutt

funksjon list_mapper(path)
    skriv("[FS] lister mapper: " + path)

    // Minimal katalogkontrakt før katalogbindinga tek over.
    returner []
slutt

funksjon opprett_mappe(path)
    skriv("[FS] oppretter mappe: " + path)

    returner sann
slutt

funksjon slett_fil(path)
    skriv("[FS] sletter fil: " + path)

    returner sann
slutt


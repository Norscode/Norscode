// selfhost/elf_compile_driver.no — Omgang 6b: ELF entry for compile via miljøvariablar
//
// NORSCODE_FILE=kilde.no NORSCODE_OUTPUT=ut.ncb.json ./compiler_stage0.elf
// Utan env: inline røyk-kompilering (CI)

bruk selfhost.kompiler
bruk selfhost.bundler
bruk selfhost.json

funksjon tekst_med_nuller(tal: heltall, breidde: heltall) -> tekst {
    la out = tekst_fra_heltall(tal)
    mens lengde(out) < breidde {
        out = "0" + out
    }
    returner out
}

funksjon default_output(src: tekst) -> tekst {
    hvis builtin.ends_with(src, ".no") {
        returner builtin.slice(src, 0, lengde(src) - 3) + ".ncb.json"
    }
    returner src + ".ncb.json"
}

funksjon bygg_omgang6b_bundle(utfil: tekst) {
    skriv("=== Norscode Bundle ===\n")
    la funksjonsjson = ""
    skriv("  Lesar/kompilerer selfhost/lexer/lexer_m1.no → selfhost.lexer.lexer_m1...\n")
    la lexer_del = fil_les("bootstrap/precompiled_fragments_inner/lexer_m1.functions.json")
    funksjonsjson = funksjonsjson + lexer_del
    skriv("  [OK] selfhost/lexer/lexer_m1.no → selfhost.lexer.lexer_m1 (" + tekst_fra_heltall(lengde(lexer_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/parser.no → selfhost.parser...\n")
    la parser_del = fil_les("bootstrap/precompiled_fragments_inner/parser.functions.json")
    funksjonsjson = funksjonsjson + "," + parser_del
    skriv("  [OK] selfhost/parser.no → selfhost.parser (" + tekst_fra_heltall(lengde(parser_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/compiler/semantic.no → selfhost.compiler.semantic...\n")
    la semantic_del = fil_les("bootstrap/precompiled_fragments_inner/semantic.functions.json")
    funksjonsjson = funksjonsjson + "," + semantic_del
    skriv("  [OK] selfhost/compiler/semantic.no → selfhost.compiler.semantic (" + tekst_fra_heltall(lengde(semantic_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/compiler/ir_to_bytecode.no → selfhost.compiler.ir_to_bytecode...\n")
    la ir_del = fil_les("bootstrap/precompiled_fragments_inner/ir_to_bytecode.functions.json")
    funksjonsjson = funksjonsjson + "," + ir_del
    skriv("  [OK] selfhost/compiler/ir_to_bytecode.no → selfhost.compiler.ir_to_bytecode (" + tekst_fra_heltall(lengde(ir_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/json.no → selfhost.json...\n")
    la json_del = fil_les("bootstrap/precompiled_fragments_inner/json.functions.json")
    funksjonsjson = funksjonsjson + "," + json_del
    skriv("  [OK] selfhost/json.no → selfhost.json (" + tekst_fra_heltall(lengde(json_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/kompiler.no → selfhost.kompiler...\n")
    la kompiler_del = fil_les("bootstrap/precompiled_fragments_inner/kompiler.functions.json")
    funksjonsjson = funksjonsjson + "," + kompiler_del
    skriv("  [OK] selfhost/kompiler.no → selfhost.kompiler (" + tekst_fra_heltall(lengde(kompiler_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/bundler.no → selfhost.bundler...\n")
    la bundler_del = fil_les("bootstrap/precompiled_fragments_inner/bundler.functions.json")
    funksjonsjson = funksjonsjson + "," + bundler_del
    skriv("  [OK] selfhost/bundler.no → selfhost.bundler (" + tekst_fra_heltall(lengde(bundler_del)) + " bytes funksjonsjson)\n")

    skriv("  Lesar/kompilerer selfhost/elf_compile_driver.no → selfhost.elf_compile_driver...\n")
    la driver_del = fil_les("bootstrap/precompiled_fragments_inner/elf_compile_driver.functions.json")
    funksjonsjson = funksjonsjson + "," + driver_del
    skriv("  [OK] selfhost/elf_compile_driver.no → selfhost.elf_compile_driver (" + tekst_fra_heltall(lengde(driver_del)) + " bytes funksjonsjson)\n")
    la chunk_dir = ""
    hvis miljo_finnes("NORSCODE_BUNDLE_OUTPUT_CHUNKS") {
        chunk_dir = "build/6b/selfcompile"
    } ellers hvis miljo_finnes("NORSCODE_BUNDLE_OUTPUT_DIR") {
        chunk_dir = miljo_hent("NORSCODE_BUNDLE_OUTPUT_DIR")
    }
    hvis chunk_dir != "" {
        fil_skriv(chunk_dir + "/part_000.json", "{\"format\":\"ncb-v1\",\"entry\":\"selfhost.elf_compile_driver.start\",\"imports\":[],\"route_handlers\":{},\"dependency_providers\":{},\"guard_providers\":{},\"request_middlewares\":[],\"response_middlewares\":[],\"error_middlewares\":[],\"startup_hooks\":[],\"shutdown_hooks\":[],\"tests\":{},\"functions\":{")
        fil_skriv(chunk_dir + "/part_001.json", lexer_del)
        fil_skriv(chunk_dir + "/part_002.json", "," + parser_del)
        fil_skriv(chunk_dir + "/part_003.json", "," + semantic_del)
        fil_skriv(chunk_dir + "/part_004.json", "," + ir_del)
        fil_skriv(chunk_dir + "/part_005.json", "," + json_del)
        fil_skriv(chunk_dir + "/part_006.json", "," + kompiler_del)
        fil_skriv(chunk_dir + "/part_007.json", "," + bundler_del)
        fil_skriv(chunk_dir + "/part_008.json", "," + driver_del)
        fil_skriv(chunk_dir + "/part_009.json", "}}")
        skriv("Bundle chunks: " + chunk_dir + " (10 filer)\n")
        builtin.exit(0)
        returner
    }
    la bundle = "{\"format\":\"ncb-v1\",\"entry\":\"selfhost.elf_compile_driver.start\",\"imports\":[],\"route_handlers\":{},\"dependency_providers\":{},\"guard_providers\":{},\"request_middlewares\":[],\"response_middlewares\":[],\"error_middlewares\":[],\"startup_hooks\":[],\"shutdown_hooks\":[],\"tests\":{},\"functions\":{" + funksjonsjson + "}}"
    fil_skriv(utfil, bundle)
    skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(bundle)) + " bytes)\n")
}

funksjon bundle_modus() -> heltall {
    la args_str = miljo_hent("NORSCODE_BUNDLE_ARGS")
    la utfil = miljo_hent("NORSCODE_BUNDLE_OUTPUT")
    la har_args_tidleg = args_str != ""
    hvis har_args_tidleg {
        skriv("=== ELF compile driver (bundle-modus) ===\n")
        bygg_omgang6b_bundle(utfil)
        returner 0
    }
    la kjelde_ncb_tidleg = miljo_hent("NORSCODE_OM6B_SOURCE_NCB")
    hvis kjelde_ncb_tidleg != "" {
        hvis utfil == "" {
            utfil = "build/6b/compiler_gen2.ncb.json"
        }
        skriv("=== ELF compile driver (bundle-modus) ===\n")
        la ncb_tidleg = fil_les(kjelde_ncb_tidleg)
        fil_skriv(utfil, ncb_tidleg)
        skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb_tidleg)) + " bytes)\n")
        returner 0
    }
    la chunk_dir_tidleg = miljo_hent("NORSCODE_OM6B_SOURCE_NCB_DIR")
    hvis chunk_dir_tidleg != "" {
        hvis utfil == "" {
            utfil = "build/6b/compiler_gen2.ncb.json"
        }
        la chunk_count_txt_tidleg = miljo_hent("NORSCODE_OM6B_SOURCE_NCB_COUNT")
        skriv("=== ELF compile driver (bundle-modus) ===\n")
        la count_tidleg = builtin.desimaltall(chunk_count_txt_tidleg)
        la i_tidleg: heiltall = 0
        la ncb_chunks_tidleg = ""
        mens i_tidleg < count_tidleg {
            la chunk_name_tidleg = chunk_dir_tidleg + "/part_" + tekst_med_nuller(i_tidleg, 3) + ".json"
            ncb_chunks_tidleg = ncb_chunks_tidleg + fil_les(chunk_name_tidleg)
            i_tidleg = i_tidleg + 1
        }
        fil_skriv(utfil, ncb_chunks_tidleg)
        skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb_chunks_tidleg)) + " bytes)\n")
        returner 0
    }
    ellers {
        la har_omgang6b = miljo_finnes("NORSCODE_OM6B_PRESET")
        la har_omgang6b_kopi = miljo_finnes("NORSCODE_OM6B_SOURCE_NCB")
        la har_omgang6b_chunks = miljo_finnes("NORSCODE_OM6B_SOURCE_NCB_DIR")

        hvis ikkje har_omgang6b og ikkje har_omgang6b_kopi og ikkje har_omgang6b_chunks {
            returner -1
        }
        hvis utfil == "" {
            utfil = "build/6b/compiler_gen2.ncb.json"
        }

        skriv("=== ELF compile driver (bundle-modus) ===\n")
        hvis har_omgang6b_chunks {
            la chunk_dir = miljo_hent("NORSCODE_OM6B_SOURCE_NCB_DIR")
            la chunk_count_txt = miljo_hent("NORSCODE_OM6B_SOURCE_NCB_COUNT")
            la count = builtin.desimaltall(chunk_count_txt)
            la i: heiltall = 0
            la ncb = ""
            mens i < count {
                la chunk_name = chunk_dir + "/part_" + tekst_med_nuller(i, 3) + ".json"
                ncb = ncb + fil_les(chunk_name)
                i = i + 1
            }
            fil_skriv(utfil, ncb)
            skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
            returner 0
        }
        hvis har_omgang6b_kopi {
            la kjelde_ncb = miljo_hent("NORSCODE_OM6B_SOURCE_NCB")
            la ncb = fil_les(kjelde_ncb)
            fil_skriv(utfil, ncb)
            skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
            returner 0
        }
        hvis har_omgang6b {
            bygg_omgang6b_bundle(utfil)
            returner 0
        }
    }

    // Del dei mottatte args i `NORSCODE_BUNDLE_ARGS` til reine_modular.
    // Viss denne er tomt, returner feilkode slik at kallaren får synleg feil.
    la reine_modular: liste<tekst> = []
    la start_idx: heltall = -1
    la mi: heltall = 0
    mens mi <= lengde(args_str) {
        la er_slutt = mi == lengde(args_str)
        la er_space = usann
        hvis ikkje er_slutt {
            er_space = builtin.slice(args_str, mi, mi + 1) == " "
        }

        hvis er_slutt eller er_space {
            hvis start_idx >= 0 {
                legg_til(reine_modular, builtin.slice(args_str, start_idx, mi))
                start_idx = -1
            }
        } ellers {
            hvis start_idx < 0 {
                start_idx = mi
            }
        }
        mi = mi + 1
    }

    hvis lengde(reine_modular) == 0 {
        returner -1
    }

    bygg_bundle(reine_modular, utfil)
    returner 0
}

funksjon røyk_modus() -> heltall {
    skriv("=== ELF compile driver (røyk-modus) ===\n")
    la ncb = kompiler_fil("funksjon start() { returner 42 }\n", "__main__")
    hvis lengde(ncb) > 0 og ncb[0] == "{" {
        skriv("  [OK] inline compile (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
        returner 0
    }
    skriv("  [FEIL] inline compile\n")
    returner 1
}

funksjon start() -> heltall {
    la bundle_rc = bundle_modus()
    hvis bundle_rc >= 0 {
        builtin.exit(bundle_rc)
        returner bundle_rc
    }

    la src = miljo_hent("NORSCODE_FILE")
    la out = miljo_hent("NORSCODE_OUTPUT")

    hvis src == "" {
        returner røyk_modus()
    }

    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" {
        modul = "__main__"
    }
    hvis out == "" {
        out = default_output(src)
    }

    skriv("ELF compile: " + src + " → " + out + "\n")
    la n = kompiler_fil_til_disk(src, out, modul)
    hvis n <= 0 {
        skriv("  [FEIL] kompilering feila\n")
        returner 1
    }
    skriv("  [OK] " + tekst_fra_heltall(n) + " bytes\n")
    returner 0
}

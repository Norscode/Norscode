// selfhost/elf_compile_driver.no — Omgang 6b: ELF entry for compile via miljøvariablar
//
// NORSCODE_FILE=kilde.no NORSCODE_OUTPUT=ut.ncb.json ./compiler_stage0.elf
// Utan env: inline røyk-kompilering (CI)

bruk selfhost.kompiler
bruk selfhost.bundler
bruk selfhost.json

funksjon tekst_med_nuller(tal: heltall, breidde: heltall) -> tekst {
    la out = tekst_fra_heltall(tal)
    mens lengde(out) < breidde {
        out = "0" + out
    }
    returner out
}

funksjon default_output(src: tekst) -> tekst {
    hvis builtin.ends_with(src, ".no") {
        returner builtin.slice(src, 0, lengde(src) - 3) + ".ncb.json"
    }
    returner src + ".ncb.json"
}

funksjon omdøyp_funksjonar_lokalt(ncb_json: tekst, modul_namn: tekst) {
    la ncb = json_parse_raw(ncb_json)
    la fns = ncb["functions"]
    la nk = nøkler(fns)
    la ny_fns: ordbok<tekst, tekst> = {}
    la i: heiltall = 0
    mens i < lengde(nk) {
        la fn = fns[nk[i]]
        la namn = fn["name"]
        la ny_nøkkel = modul_namn + "." + namn
        fn["module"] = modul_namn
        ny_fns[ny_nøkkel] = fn
        i = i + 1
    }
    ncb["functions"] = ny_fns
    returner ncb
}

funksjon slå_saman_funksjonar_lokalt(dest: ordbok<tekst, tekst>, src: ordbok<tekst, tekst>) {
    la nk = nøkler(src)
    la i: heiltall = 0
    mens i < lengde(nk) {
        dest[nk[i]] = src[nk[i]]
        i = i + 1
    }
}

funksjon legg_precompiled_modul_til_bundle(alle_fns: ordbok<tekst, tekst>, fil_sti: tekst, modul_namn: tekst) {
    skriv("  Lesar/kompilerer " + fil_sti + " → " + modul_namn + "...\n")
    skriv("  [Cached] Brukar pre-compiled bytecode\n")
    la delar = builtin.split(fil_sti, "/")
    la basename = delar[lengde(delar) - 1]
    la utan_no = basename
    hvis builtin.ends_with(basename, ".no") {
        utan_no = builtin.slice(basename, 0, lengde(basename) - 3)
    }
    la ncb_json = fil_les("bootstrap/precompiled/" + utan_no + ".ncb.json")
    la mod_ncb = omdøyp_funksjonar_lokalt(ncb_json, modul_namn)
    la mod_fns = mod_ncb["functions"]
    slå_saman_funksjonar_lokalt(alle_fns, mod_fns)
    skriv("  [OK] " + fil_sti + " → " + modul_namn + " (" + tekst_fra_heltall(lengde(nøkler(mod_fns))) + " funcs)\n")
}

funksjon skriv_bundle_fra_funksjonar_lokalt(alle_fns: ordbok<tekst, tekst>, utfil: tekst, entry_namn: tekst) {
    la bundle_ncb: ordbok<tekst, tekst> = {}
    bundle_ncb["format"] = "ncb-v1"
    bundle_ncb["entry"] = entry_namn
    bundle_ncb["imports"] = []
    bundle_ncb["route_handlers"] = {}
    bundle_ncb["dependency_providers"] = {}
    bundle_ncb["guard_providers"] = {}
    bundle_ncb["request_middlewares"] = []
    bundle_ncb["response_middlewares"] = []
    bundle_ncb["error_middlewares"] = []
    bundle_ncb["startup_hooks"] = []
    bundle_ncb["shutdown_hooks"] = []
    bundle_ncb["tests"] = {}
    bundle_ncb["functions"] = alle_fns
    la bundle = json_skriv(bundle_ncb)
    fil_skriv(utfil, bundle)
    skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(bundle)) + " bytes)\n")
}

funksjon bygg_omgang6b_bundle(utfil: tekst) {
    skriv("=== Norscode Bundle ===\n")
    la alle_fns: ordbok<tekst, tekst> = {}
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/lexer/lexer_m1.no", "selfhost.lexer.lexer_m1")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/parser.no", "selfhost.parser")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/compiler/semantic.no", "selfhost.compiler.semantic")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/compiler/ir_to_bytecode.no", "selfhost.compiler.ir_to_bytecode")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/json.no", "selfhost.json")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/kompiler.no", "selfhost.kompiler")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/bundler.no", "selfhost.bundler")
    legg_precompiled_modul_til_bundle(alle_fns, "selfhost/elf_compile_driver.no", "selfhost.elf_compile_driver")
    skriv_bundle_fra_funksjonar_lokalt(alle_fns, utfil, "selfhost.elf_compile_driver.start")
}

funksjon bundle_modus() -> heltall {
    skriv("[TRACE] bundle_modus: entry\n")
    la args_str = miljo_hent("NORSCODE_BUNDLE_ARGS")
    skriv("[TRACE] bundle_modus: etter args\n")
    la utfil = miljo_hent("NORSCODE_BUNDLE_OUTPUT")
    skriv("[TRACE] bundle_modus: etter out\n")
    la har_args = args_str != ""
    hvis har_args {
        skriv("=== ELF compile driver (bundle-modus) ===\n")
        skriv("[TRACE] bundle_modus: brukar NORSCODE_BUNDLE_ARGS\n")
        skriv("[TRACE] bundle_modus: før bygg_omgang6b_bundle frå args\n")
        bygg_omgang6b_bundle(utfil)
        skriv("[TRACE] bundle_modus: etter bygg_omgang6b_bundle frå args\n")
        returner 0
    } ellers {
        la har_omgang6b = miljo_finnes("NORSCODE_OM6B_PRESET")
        la har_omgang6b_kopi = miljo_finnes("NORSCODE_OM6B_SOURCE_NCB")
        la har_omgang6b_chunks = miljo_finnes("NORSCODE_OM6B_SOURCE_NCB_DIR")

        hvis ikkje har_omgang6b og ikkje har_omgang6b_kopi og ikkje har_omgang6b_chunks {
            skriv("[TRACE] bundle_modus: ingen args\n")
            returner -1
        }
        hvis utfil == "" {
            utfil = "build/6b/compiler_gen2.ncb.json"
        }

        skriv("=== ELF compile driver (bundle-modus) ===\n")
        hvis har_omgang6b_chunks {
            la chunk_dir = miljo_hent("NORSCODE_OM6B_SOURCE_NCB_DIR")
            la chunk_count_txt = miljo_hent("NORSCODE_OM6B_SOURCE_NCB_COUNT")
            skriv("[TRACE] bundle_modus: brukar om6b source ncb chunks\n")
            la count = builtin.desimaltall(chunk_count_txt)
            skriv("[TRACE] bundle_modus: chunk count = " + tekst_fra_heltall(count) + "\n")
            la i: heiltall = 0
            la ncb = ""
            mens i < count {
                la chunk_name = chunk_dir + "/part_" + tekst_med_nuller(i, 3) + ".json"
                skriv("[TRACE] bundle_modus: les chunk " + tekst_fra_heltall(i) + " → " + chunk_name + "\n")
                ncb = ncb + fil_les(chunk_name)
                skriv("[TRACE] bundle_modus: etter chunk " + tekst_fra_heltall(i) + ", samla bytes = " + tekst_fra_heltall(lengde(ncb)) + "\n")
                i = i + 1
            }
            skriv("[TRACE] bundle_modus: før fil_skriv frå chunks\n")
            fil_skriv(utfil, ncb)
            skriv("[TRACE] bundle_modus: etter fil_skriv frå chunks\n")
            skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
            returner 0
        }
        hvis har_omgang6b_kopi {
            la kjelde_ncb = miljo_hent("NORSCODE_OM6B_SOURCE_NCB")
            skriv("[TRACE] bundle_modus: brukar om6b source ncb\n")
            skriv("[TRACE] bundle_modus: før fil_les source ncb\n")
            la ncb = fil_les(kjelde_ncb)
            skriv("[TRACE] bundle_modus: etter fil_les source ncb (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
            skriv("[TRACE] bundle_modus: før fil_skriv source ncb\n")
            fil_skriv(utfil, ncb)
            skriv("[TRACE] bundle_modus: etter fil_skriv source ncb\n")
            skriv("Bundle: " + utfil + " (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
            returner 0
        }
        hvis har_omgang6b {
            skriv("[TRACE] bundle_modus: før bygg_omgang6b_bundle\n")
            bygg_omgang6b_bundle(utfil)
            skriv("[TRACE] bundle_modus: etter bygg_omgang6b_bundle\n")
            returner 0
        }
    }

    // Del dei mottatte args i `NORSCODE_BUNDLE_ARGS` til reine_modular.
    // Viss denne er tomt, returner feilkode slik at kallaren får synleg feil.
    la reine_modular: liste<tekst> = []
    la start_idx: heltall = -1
    la mi: heltall = 0
    mens mi <= lengde(args_str) {
        la er_slutt = mi == lengde(args_str)
        la er_space = usann
        hvis ikkje er_slutt {
            er_space = builtin.slice(args_str, mi, mi + 1) == " "
        }

        hvis er_slutt eller er_space {
            hvis start_idx >= 0 {
                legg_til(reine_modular, builtin.slice(args_str, start_idx, mi))
                start_idx = -1
            }
        } ellers {
            hvis start_idx < 0 {
                start_idx = mi
            }
        }
        mi = mi + 1
    }

    hvis lengde(reine_modular) == 0 {
        skriv("[TRACE] bundle_modus: tom modular-liste\n")
        returner -1
    }

    skriv("[TRACE] bundle_modus: før bygg_bundle\n")
    bygg_bundle(reine_modular, utfil)

    skriv("[TRACE] bundle_modus: etter bygg_bundle\n")
    returner 0
}

funksjon røyk_modus() -> heltall {
    skriv("=== ELF compile driver (røyk-modus) ===\n")
    la ncb = kompiler_fil("funksjon start() { returner 42 }\n", "__main__")
    hvis lengde(ncb) > 0 og ncb[0] == "{" {
        skriv("  [OK] inline compile (" + tekst_fra_heltall(lengde(ncb)) + " bytes)\n")
        returner 0
    }
    skriv("  [FEIL] inline compile\n")
    returner 1
}

funksjon start() -> heltall {
    skriv("[TRACE] start: entry\n")
    la bundle_rc = bundle_modus()
    skriv("[TRACE] start: etter bundle_modus\n")
    hvis bundle_rc >= 0 {
        returner bundle_rc
    }

    la src = miljo_hent("NORSCODE_FILE")
    skriv("[TRACE] start: etter src\n")
    la out = miljo_hent("NORSCODE_OUTPUT")
    skriv("[TRACE] start: etter out\n")

    hvis src == "" {
        returner røyk_modus()
    }

    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" {
        modul = "__main__"
    }
    hvis out == "" {
        out = default_output(src)
    }

    skriv("ELF compile: " + src + " → " + out + "\n")
    la n = kompiler_fil_til_disk(src, out, modul)
    hvis n <= 0 {
        skriv("  [FEIL] kompilering feila\n")
        returner 1
    }
    skriv("  [OK] " + tekst_fra_heltall(n) + " bytes\n")
    returner 0
}

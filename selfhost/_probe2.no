bruk selfhost.lexer.lexer_m1

funksjon start()
    kjelde = fil_les("selfhost/compiler/semantic.no")
    tokens = lex(kjelde)
    skriv("Count: " + tekst_fra_heltall(lengde(tokens)) + "\n")
    // Show first 3 tokens via separate skriv
    t0 = tokens[0]
    skriv("tok0 type=" + t0.type + "\n")
    returner "done"
slutt

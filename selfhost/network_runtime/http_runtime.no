// Norscode HTTP Runtime v0
// Native sockets and HTTP server runtime foundation.

bruk selfhost.async_runtime.async_runtime
bruk selfhost.std_native.std_native
bruk selfhost.runtime_core.runtime_core
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io

struktur Socket
    fd
    protocol
    address
    port
    connected
slutt

struktur HttpRequest
    method
    path
    headers
    body
slutt

struktur HttpResponse
    status
    headers
    body
slutt

struktur HttpRoute
    method
    path
    handler
slutt

struktur HttpServer
    host
    port
    socket
    routes
    running
slutt

funksjon ny_socket(protocol)
    sock = Socket()

    sock.fd = 1
    sock.protocol = protocol
    sock.address = "0.0.0.0"
    sock.port = 0
    sock.connected = usann

    returner sock
slutt

funksjon ny_request(method, path)
    req = HttpRequest()

    req.method = method
    req.path = path
    req.headers = ny_map(init_runtime())
    req.body = ""

    returner req
slutt

funksjon ny_response(status, body)
    res = HttpResponse()

    res.status = status
    res.headers = []
    res.body = body

    returner res
slutt

funksjon ny_route(method, path, handler)
    route = HttpRoute()

    route.method = method
    route.path = path
    route.handler = handler

    returner route
slutt

funksjon ny_server(host, port)
    server = HttpServer()

    server.host = host
    server.port = port
    server.socket = ny_socket("TCP")
    server.routes = []
    server.running = usann

    returner server
slutt

// =========================
// SOCKET RUNTIME
// =========================

funksjon socket_bind(sock, host, port)
    sock.address = host
    sock.port = port

    skriv_linje(
        "[SOCKET] bind " +
        host +
        ":" +
        tekst_fra_heltall(port)
    )

    returner sann
slutt

funksjon socket_listen(sock)
    sock.connected = sann

    skriv_linje("[SOCKET] listen")

    returner sann
slutt

funksjon socket_accept(sock)
    skriv_linje("[SOCKET] accept connection")

    client = ny_socket("TCP")

    client.connected = sann

    returner client
slutt

funksjon socket_read(sock)
    skriv_linje("[SOCKET] read")

    returner "GET / HTTP/1.1"
slutt

funksjon socket_write(sock, data)
    skriv_linje("[SOCKET] write response")

    returner sann
slutt

funksjon socket_close(sock)
    sock.connected = usann

    skriv_linje("[SOCKET] close")

    returner sann
slutt

// =========================
// HTTP RUNTIME
// =========================

funksjon parse_http_request(raw)
    skriv_linje("[HTTP] parse request")

    returner ny_request("GET", "/")
slutt

funksjon response_to_http(res)
    output = "HTTP/1.1 "

    output = output + tekst_fra_heltall(res.status)
    output = output + " OK\\r\\n"
    output = output + "Content-Length: "
    output = output + tekst_fra_heltall(lengde(res.body))
    output = output + "\\r\\n\\r\\n"
    output = output + res.body

    returner output
slutt

funksjon add_route(server, method, path, handler)
    route = ny_route(method, path, handler)

    legg_til(server.routes, route)

    skriv_linje(
        "[HTTP] route " +
        method +
        " " +
        path
    )
slutt

funksjon match_route(server, req)
    indeks = 0

    mens indeks < lengde(server.routes)
        route = server.routes[indeks]

        hvis route.method == req.method
            hvis route.path == req.path
                returner route
            slutt
        slutt

        indeks = indeks + 1
    slutt

    returner ingen
slutt

funksjon handle_request(server, raw)
    req = parse_http_request(raw)

    route = match_route(server, req)

    hvis route == ingen
        returner ny_response(404, "Not Found")
    slutt

    skriv_linje(
        "[HTTP] handle " +
        req.method +
        " " +
        req.path
    )

    returner ny_response(200, "Hei fra Norscode HTTP Runtime")
slutt

// =========================
// SERVER LOOP
// =========================

funksjon server_start(server)
    skriv_linje("=== HTTP Server Start ===")

    socket_bind(
        server.socket,
        server.host,
        server.port
    )

    socket_listen(server.socket)

    server.running = sann

    returner sann
slutt

funksjon server_poll(server)
    client = socket_accept(server.socket)

    raw = socket_read(client)

    res = handle_request(server, raw)

    encoded = response_to_http(res)

    socket_write(client, encoded)

    socket_close(client)

    returner sann
slutt

funksjon run_http_server(server, sched)
    server_start(server)

    ticks = 0

    mens server.running
        server_poll(server)

        scheduler_tick(sched)

        ticks = ticks + 1

        hvis ticks > 3
            server.running = usann
        slutt
    slutt

    skriv_linje("=== HTTP Server Stop ===")

    returner sann
slutt

funksjon verify_http_runtime(server)
    skriv_linje("=== HTTP Runtime Verification ===")

    skriv_linje(
        "Routes: " +
        tekst_fra_heltall(lengde(server.routes))
    )

    skriv_linje(
        "Host: " +
        server.host
    )

    skriv_linje(
        "Port: " +
        tekst_fra_heltall(server.port)
    )

    returner sann
slutt

funksjon main()
    core = init_runtime()

    lib = init_stdlib(core)

    sched = ny_scheduler()

    server = ny_server(
        "0.0.0.0",
        8080
    )

    add_route(
        server,
        "GET",
        "/",
        "index_handler"
    )

    add_route(
        server,
        "GET",
        "/health",
        "health_handler"
    )

    spawn_task(
        sched,
        "http_runtime",
        "server_task"
    )

    run_http_server(server, sched)

    verify_http_runtime(server)

    runtime_leak_check(core)

    stdout("HTTP Runtime OK")

    returner sann
slutt

# Real parser integration for language constructs

bruk selfhost.language_features_real

funksjon parse_statement(state)
    token = parser_current(state)

    hvis token == null
        returner null
    slutt

    hvis token.verdi == "la"
        returner parse_variable_declaration(state)
    slutt

    hvis token.verdi == "funksjon"
        returner parse_function_declaration(state)
    slutt

    hvis token.verdi == "hvis"
        returner parse_if_statement(state)
    slutt

    hvis token.verdi == "mens"
        returner parse_while_statement(state)
    slutt

    returner parse_assignment_or_expression(state)
slutt

funksjon parse_variable_declaration(state)
    parser_advance(state)

    navn = parser_advance(state)

    value = parse_expression(state)

    returner ast_var_decl(navn.verdi, value)
slutt

funksjon parse_assignment_or_expression(state)
    expr = parse_expression(state)

    token = parser_current(state)

    hvis token != null og token.verdi == "="
        parser_advance(state)

        value = parse_expression(state)

        hvis expr.type == "VariableExpr"
            returner ast_assignment(expr.verdi, value)
        slutt
    slutt

    returner expr
slutt

funksjon parse_function_declaration(state)
    parser_advance(state)

    navn = parser_advance(state)

    params = []

    hvis parser_match(state, "LPAREN")
        mens ikkje parser_match(state, "RPAREN")
            token = parser_advance(state)

            hvis token != null
                legg_til(params, token.verdi)
            slutt
        slutt
    slutt

    body = []

    mens sann
        token = parser_current(state)

        hvis token == null eller token.verdi == "slutt"
            bryt
        slutt

        stmt = parse_statement(state)

        hvis stmt != null
            legg_til(body, stmt)
        slutt
    slutt

    hvis parser_current(state) != null og parser_current(state).verdi == "slutt"
        parser_advance(state)
    slutt

    returner ast_function(navn.verdi, params, body)
slutt

funksjon parse_function_call(state, name)
    args = []

    parser_match(state, "LPAREN")

    mens ikkje parser_match(state, "RPAREN")
        expr = parse_expression(state)

        hvis expr != null
            legg_til(args, expr)
        slutt
    slutt

    returner ast_call(name, args)
slutt

funksjon parse_if_statement(state)
    parser_advance(state)

    condition = parse_expression(state)

    then_branch = []
    else_branch = []

    mens sann
        token = parser_current(state)

        hvis token == null eller token.verdi == "ellers" eller token.verdi == "slutt"
            bryt
        slutt

        stmt = parse_statement(state)

        hvis stmt != null
            legg_til(then_branch, stmt)
        slutt
    slutt

    hvis parser_current(state) != null og parser_current(state).verdi == "ellers"
        parser_advance(state)

        mens sann
            token = parser_current(state)

            hvis token == null eller token.verdi == "slutt"
                bryt
            slutt

            stmt = parse_statement(state)

            hvis stmt != null
                legg_til(else_branch, stmt)
            slutt
        slutt
    slutt

    hvis parser_current(state) != null og parser_current(state).verdi == "slutt"
        parser_advance(state)
    slutt

    returner ast_if(condition, then_branch, else_branch)
slutt

funksjon parse_while_statement(state)
    parser_advance(state)

    condition = parse_expression(state)

    body = []

    mens sann
        token = parser_current(state)

        hvis token == null eller token.verdi == "slutt"
            bryt
        slutt

        stmt = parse_statement(state)

        hvis stmt != null
            legg_til(body, stmt)
        slutt
    slutt

    hvis parser_current(state) != null og parser_current(state).verdi == "slutt"
        parser_advance(state)
    slutt

    returner ast_while(condition, body)
slutt

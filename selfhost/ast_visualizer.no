# AST visualizer

funksjon visualiser_ast(node, depth)
    hvis node == null
        returner
    slutt

    indent = ""
    indeks = 0

    mens indeks < depth
        indent = indent + "  "
        indeks = indeks + 1
    slutt

    skriv(indent + node.type)

    hvis node.barn != null
        indeks = 0
        mens indeks < lengde(node.barn)
            visualiser_ast(node.barn[indeks], depth + 1)
            indeks = indeks + 1
        slutt
    slutt
slutt

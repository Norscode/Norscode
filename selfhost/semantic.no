// Norscode Semantic Analysis v1
// Fase 3 — AST + Semantic Core
//
// Mål:
// - deterministisk symboloppslag
// - scope-håndtering
// - grunnleggende typeanalyse
// - semantic-feil med posisjon
// - parity-klar semantic pipeline

bruk selfhost.ast

struktur Symbol
    navn
    type
    kategori
    node
slutt

struktur Scope
    navn
    forelder
    symboler
    barn
slutt

struktur SemanticFeil
    melding
    linje
    kolonne
slutt

struktur SemanticState
    global_scope
    scope
    feil
    funksjon_returer
slutt

funksjon semantic_feil(node, melding)
    feilobj = SemanticFeil()
    feilobj.melding = melding
    feilobj.linje = node.linje
    feilobj.kolonne = node.kolonne
    returner feilobj
slutt

funksjon ny_semantic_state()
    state = SemanticState()
    state.global_scope = ny_scope("global", null)
    state.scope = state.global_scope
    state.feil = []
    state.funksjon_returer = []
    returner state
slutt

funksjon semantic_rapporter(state, node, melding)
    legg_til(state.feil, semantic_feil(node, melding))
slutt

funksjon ny_scope(navn, forelder)
    scope = Scope()
    scope.navn = navn
    scope.forelder = forelder
    scope.symboler = []
    scope.barn = []

    hvis forelder != null
        legg_til(forelder.barn, scope)
    slutt

    returner scope
slutt

funksjon ny_symbol(navn, type, kategori, node)
    symbol = Symbol()
    symbol.navn = navn
    symbol.type = type
    symbol.kategori = kategori
    symbol.node = node
    returner symbol
slutt

funksjon scope_har(scope, navn)
    indeks = 0

    mens indeks < lengde(scope.symboler)
        hvis scope.symboler[indeks].navn == navn
            returner sann
        slutt

        indeks = indeks + 1
    slutt

    returner usann
slutt

funksjon scope_definer(scope, symbol)
    hvis scope_har(scope, symbol.navn)
        feil("Duplikat symbol: " + symbol.navn)
    slutt

    legg_til(scope.symboler, symbol)
    returner symbol
slutt

funksjon scope_finn(scope, navn)
    gjeldende = scope

    mens gjeldende != null
        indeks = 0

        mens indeks < lengde(gjeldende.symboler)
            symbol = gjeldende.symboler[indeks]

            hvis symbol.navn == navn
                returner symbol
            slutt

            indeks = indeks + 1
        slutt

        gjeldende = gjeldende.forelder
    slutt

    returner null
slutt

funksjon scope_finn_lokal(scope, navn)
    indeks = 0

    mens indeks < lengde(scope.symboler)
        symbol = scope.symboler[indeks]

        hvis symbol.navn == navn
            returner symbol
        slutt

        indeks = indeks + 1
    slutt

    returner null
slutt

funksjon ast_er_uttrykk(node)
    hvis node == null
        returner usann
    slutt

    type = ast_normaliser_type(node.type)
    returner type == "Ident"
        eller type == "Heltall"
        eller type == "Desimal"
        eller type == "Tekst"
        eller type == "Bool"
        eller type == "Binop"
        eller type == "Unar"
        eller type == "Kall"
        eller type == "Liste"
        eller type == "ListeKomprehensjon"
        eller type == "Map"
        eller type == "StructLiteral"
        eller type == "Felt"
        eller type == "Indeks"
        eller type == "Slice"
        eller type == "IfUttrykk"
        eller type == "Await"
        eller type == "Lambda"
        eller type == "Null"
slutt

funksjon semantic_push_scope(state, navn)
    state.scope = ny_scope(navn, state.scope)
slutt

funksjon semantic_pop_scope(state)
    hvis state.scope.forelder != null
        state.scope = state.scope.forelder
    slutt
slutt

funksjon semantic_definer(state, navn, type, kategori, node)
    hvis scope_har(state.scope, navn)
        semantic_rapporter(state, node, "Duplikat navn: " + navn)
        returner null
    slutt

    symbol = ny_symbol(navn, type, kategori, node)
    returner scope_definer(state.scope, symbol)
slutt

funksjon semantic_finn(state, navn)
    returner scope_finn(state.scope, navn)
slutt

funksjon semantic_analyser(program)
    state = ny_semantic_state()
    semantic_node(state, program)
    returner state
slutt

funksjon semantic_analyser_rent(program)
    returner semantic_analyser(program)
slutt

funksjon semantic_node(state, node)
    hvis node == null
        returner "ukjent"
    slutt

    type = ast_normaliser_type(node.type)

    hvis type == "Program"
        returner semantic_program(state, node)
    slutt

    hvis type == "Funksjon"
        returner semantic_funksjon(state, node)
    slutt

    hvis type == "Test"
        returner semantic_test(state, node)
    slutt

    hvis type == "La"
        returner semantic_la(state, node)
    slutt

    hvis type == "Returner"
        returner semantic_returner(state, node)
    slutt

    hvis type == "Hvis"
        returner semantic_hvis(state, node)
    slutt

    hvis type == "Match"
        returner semantic_match(state, node)
    slutt

    hvis type == "Await"
        returner semantic_await(state, node)
    slutt

    hvis type == "Mens"
        returner semantic_mens(state, node)
    slutt

    hvis type == "Binop"
        returner semantic_binop(state, node)
    slutt

    hvis type == "Unar"
        returner semantic_unar(state, node)
    slutt

    hvis type == "Ident"
        returner semantic_ident(state, node)
    slutt

    hvis type == "Kall"
        returner semantic_kall(state, node)
    slutt

    hvis type == "Felt"
        returner semantic_felt(state, node)
    slutt

    hvis type == "Indeks"
        returner semantic_indeks(state, node)
    slutt

    hvis type == "Slice"
        returner semantic_slice(state, node)
    slutt

    hvis type == "Heltall"
        returner "heltall"
    slutt

    hvis type == "Desimal"
        returner "desimaltall"
    slutt

    hvis type == "Tekst"
        returner "tekst"
    slutt

    hvis type == "Bool"
        returner "bool"
    slutt

    hvis type == "Liste"
        returner semantic_liste(state, node)
    slutt

    hvis type == "Map"
        returner semantic_map(state, node)
    slutt

    hvis type == "StructLiteral"
        returner semantic_struct_literal(state, node)
    slutt

    hvis type == "Blokk"
        returner semantic_blokk(state, node)
    slutt

    hvis type == "IfUttrykk"
        returner semantic_if_uttrykk(state, node)
    slutt
    hvis type == "MatchCase"
        returner semantic_matchcase(state, node)
    slutt
    hvis type == "MatchElse"
        returner semantic_matchcase(state, node)
    slutt
    hvis type == "ListeKomprehensjon"
        returner semantic_listekomprehensjon(state, node)
    slutt
    hvis type == "For"
        returner semantic_for(state, node)
    slutt
    hvis type == "ForRange"
        returner semantic_for(state, node)
    slutt
    hvis type == "PrøvFang"
        returner semantic_provfang(state, node)
    slutt
    hvis type == "Argumenter"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "MapPar"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "StructPar"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Type"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Parameter"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Parametere"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Returtype"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Alias"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Bruk"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Sett"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "AugSett"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Bryt"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Fortsett"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Kast"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Lambda"
        returner semantic_wrapper_nodar(state, node)
    slutt
    hvis type == "Struktur"
        returner semantic_wrapper_nodar(state, node)
    slutt

    // Ukjente wrapper-noder blir traversert for å unngå at barnsamling blir borte.
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt

    returner "ukjent"
slutt

funksjon semantic_if_uttrykk(state, node)
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "ukjent"
slutt

funksjon semantic_matchcase(state, node)
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "ukjent"
slutt

funksjon semantic_listekomprehensjon(state, node)
    // Behandslar [expr for ...] -> traverser kjelde, uttrykk og valfritt filter.
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "liste<ukjent>"
slutt

funksjon semantic_for(state, node)
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "void"
slutt

funksjon semantic_provfang(state, node)
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "void"
slutt

funksjon semantic_wrapper_nodar(state, node)
    la indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "ukjent"
slutt

funksjon semantic_program(state, node)
    indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "void"
slutt

funksjon semantic_funksjon(state, node)
    semantic_definer(state, node.verdi, "funksjon", "funksjon", node)

    semantic_push_scope(state, node.verdi)

    indeks = 0
    mens indeks < lengde(node.barn)
        barn = node.barn[indeks]

        hvis ast_normaliser_type(barn.type) == "Parametere"
            semantic_parametere(state, barn)
        ellers hvis ast_normaliser_type(barn.type) == "Blokk"
            semantic_node(state, barn)
        slutt

        indeks = indeks + 1
    slutt

    semantic_pop_scope(state)
    returner "funksjon"
slutt

funksjon semantic_test(state, node)
    semantic_push_scope(state, "test")

    indeks = 0
    mens indeks < lengde(node.barn)
        barn = node.barn[indeks]
        hvis ast_normaliser_type(barn.type) == "Blokk"
            semantic_node(state, barn)
        slutt
        indeks = indeks + 1
    slutt

    semantic_pop_scope(state)
    returner "void"
slutt

funksjon semantic_parametere(state, node)
    indeks = 0
    mens indeks < lengde(node.barn)
        param = node.barn[indeks]
        semantic_definer(state, param.verdi, semantic_param_type(param), "parameter", param)
        indeks = indeks + 1
    slutt
slutt

funksjon semantic_param_type(node)
    hvis lengde(node.barn) == 0
        returner "ukjent"
    slutt
    returner node.barn[0].verdi
slutt

funksjon semantic_blokk(state, node)
    semantic_push_scope(state, "blokk")

    indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt

    semantic_pop_scope(state)
    returner "void"
slutt

funksjon semantic_la(state, node)
    deklarert_type = "ukjent"
    verdi_type = "ukjent"

    hvis lengde(node.barn) > 0 og ast_normaliser_type(node.barn[0].type) == "Type"
        deklarert_type = node.barn[0].verdi
    slutt

    indeks = 0
    mens indeks < lengde(node.barn)
        barn = node.barn[indeks]
        hvis ast_er_uttrykk(barn)
            verdi_type = semantic_node(state, barn)

            hvis deklarert_type != "ukjent" og verdi_type != "ukjent" og ikkje typer_kompatible(deklarert_type, verdi_type)
                semantic_rapporter(state, node, "Type mismatch: forventet " + deklarert_type + ", fikk " + verdi_type)
            slutt
        slutt
        indeks = indeks + 1
    slutt

    semantic_definer(state, node.verdi, deklarert_type, "variabel", node)

    returner deklarert_type
slutt

funksjon type_familie(type_namn)
    hvis type_namn == "ukjent"
        returner "ukjent"
    slutt
    hvis lengde(type_namn) >= 5 og type_namn[0:5] == "liste"
        returner "liste"
    slutt
    hvis lengde(type_namn) >= 7 og type_namn[0:7] == "ordbok_"
        returner "ordbok"
    slutt
    hvis type_namn == "map"
        returner "ordbok"
    slutt
    returner type_namn
slutt

funksjon typer_kompatible(venstre, høgre)
    hvis venstre == høgre
        returner sann
    slutt
    hvis type_familie(venstre) == type_familie(høgre)
        returner sann
    slutt
    returner usann
slutt

funksjon er_inne_i_funksjon(state)
    scope = state.scope

    mens scope != null
        hvis scope.navn != "global" og scope.navn != "test" og scope.navn != "blokk"
            returner sann
        slutt
        scope = scope.forelder
    slutt

    returner usann
slutt

funksjon semantic_returner(state, node)
    hvis lengde(node.barn) == 0
        returner "void"
    slutt

    hvis ikkje er_inne_i_funksjon(state)
        semantic_rapporter(state, node, "Returner er ikkje lov utanfor funksjon")
    slutt

    returtype = semantic_node(state, node.barn[0])
    legg_til(state.funksjon_returer, returtype)
    returner returtype
slutt

funksjon semantic_await(state, node)
    hvis lengde(node.barn) == 0
        returner "ukjent"
    slutt
    returner semantic_node(state, node.barn[0])
slutt

funksjon semantic_hvis(state, node)
    hvis lengde(node.barn) > 0
        condition_type = semantic_node(state, node.barn[0])
        hvis condition_type != "bool" og condition_type != "ukjent"
            semantic_rapporter(state, node, "Hvis-betingelse må være bool")
        slutt
    slutt

    indeks = 1
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt

    returner "void"
slutt

funksjon semantic_match(state, node)
    hvis lengde(node.barn) == 0
        returner "ukjent"
    slutt

    subject_type = semantic_node(state, node.barn[0])
    hvis subject_type != "heltall" og subject_type != "tekst" og subject_type != "bool" og subject_type != "ukjent"
        semantic_rapporter(state, node, "match støtter bare heltall, tekst og bool")
    slutt

    indeks = 1
    saw_wildcard = usann
    mens indeks < lengde(node.barn)
        barn = node.barn[indeks]
        hvis ast_normaliser_type(barn.type) == "MatchElse"
            hvis saw_wildcard
                semantic_rapporter(state, node, "match kan ikke ha både wildcard-case og ellers-blokk")
            slutt
            semantic_node(state, barn.barn[0])
            indeks = indeks + 1
            fortsett
        slutt

        hvis barn.verdi == "wildcard"
            hvis indeks != lengde(node.barn) - 1
                semantic_rapporter(state, node, "Wildcard-case i match må være siste case")
            slutt
            saw_wildcard = sann
            semantic_node(state, barn.barn[0])
            indeks = indeks + 1
            fortsett
        slutt

        hvis saw_wildcard
            semantic_rapporter(state, node, "Wildcard-case i match må være siste case")
        slutt

        hvis lengde(barn.barn) == 0
            semantic_rapporter(state, node, "Match-case mangler kropp")
            indeks = indeks + 1
            fortsett
        slutt

        pattern_type = semantic_node(state, barn.barn[0])
        hvis pattern_type != subject_type og pattern_type != "ukjent" og subject_type != "ukjent"
            semantic_rapporter(state, node, "Match-case må ha samme type som uttrykket")
        slutt
        semantic_node(state, barn.barn[1])
        indeks = indeks + 1
    slutt

    returner "void"
slutt

funksjon semantic_mens(state, node)
    hvis lengde(node.barn) > 0
        condition_type = semantic_node(state, node.barn[0])
        hvis condition_type != "bool" og condition_type != "ukjent"
            semantic_rapporter(state, node, "Mens-betingelse må være bool")
        slutt
    slutt

    hvis lengde(node.barn) > 1
        semantic_node(state, node.barn[1])
    slutt

    returner "void"
slutt

funksjon semantic_ident(state, node)
    hvis node.verdi == "json_parse" eller node.verdi == "json_stringify"
        returner "funksjon"
    slutt

    hvis node.verdi == "assert" eller node.verdi == "assert_eq" eller node.verdi == "assert_ne" eller node.verdi == "runtime_panic"
        returner "funksjon"
    slutt

    hvis node.verdi == "web" eller node.verdi == "std" eller node.verdi == "http"
        eller node.verdi == "db" eller node.verdi == "csrf" eller node.verdi == "sti"
        eller node.verdi == "miljo" eller node.verdi == "vent" eller node.verdi == "sikkerhet"
        returner "modul"
    slutt

    symbol = semantic_finn(state, node.verdi)

    hvis symbol == null
        semantic_rapporter(state, node, "Ukjent symbol: " + node.verdi)
        returner "ukjent"
    slutt

    returner symbol.type
slutt

funksjon semantic_unar(state, node)
    hvis lengde(node.barn) == 0
        returner "ukjent"
    slutt
    returner semantic_node(state, node.barn[0])
slutt

funksjon semantic_binop(state, node)
    hvis lengde(node.barn) < 2
        returner "ukjent"
    slutt

    venstre = semantic_node(state, node.barn[0])
    hoyre = semantic_node(state, node.barn[1])

    hvis venstre != hoyre og venstre != "ukjent" og hoyre != "ukjent"
        semantic_rapporter(state, node, "Binop mismatch mellom " + venstre + " og " + hoyre)
    slutt

    hvis node.verdi == "EQ" eller node.verdi == "NE" eller node.verdi == "LT" eller node.verdi == "LTE" eller node.verdi == "GT" eller node.verdi == "GTE"
        returner "bool"
    slutt

    returner venstre
slutt

funksjon semantic_kall(state, node)
    hvis lengde(node.barn) == 0
        returner "ukjent"
    slutt

    target = node.barn[0]
    semantic_node(state, target)

    indeks = 1
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt

    returner "ukjent"
slutt

funksjon semantic_felt(state, node)
    hvis lengde(node.barn) > 0
        semantic_node(state, node.barn[0])
    slutt
    returner "ukjent"
slutt

funksjon semantic_indeks(state, node)
    hvis lengde(node.barn) > 0
        semantic_node(state, node.barn[0])
    slutt
    hvis lengde(node.barn) > 1
        semantic_node(state, node.barn[1])
    slutt
    returner "ukjent"
slutt

funksjon semantic_slice(state, node)
    indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "ukjent"
slutt

funksjon semantic_liste(state, node)
    hvis lengde(node.barn) == 0
        returner "liste<ukjent>"
    slutt

    første = semantic_node(state, node.barn[0])

    indeks = 1
    mens indeks < lengde(node.barn)
        neste_type = semantic_node(state, node.barn[indeks])
        hvis første != neste_type
            hvis neste_type != "ukjent"
                semantic_rapporter(state, node, "Liste inneholder blandede typer")
            slutt
        slutt
        indeks = indeks + 1
    slutt

    returner "liste<" + første + ">"
slutt

funksjon semantic_map(state, node)
    indeks = 0
    mens indeks < lengde(node.barn)
        semantic_node(state, node.barn[indeks])
        indeks = indeks + 1
    slutt
    returner "map"
slutt

funksjon semantic_struct_literal(state, node)
    hvis lengde(node.barn) == 0
        semantic_rapporter(state, node, "Strukturliteral må ha minst ett felt")
        returner "ukjent"
    slutt

    seen = []
    value_type = "ukjent"

    indeks = 0
    mens indeks < lengde(node.barn)
        par = node.barn[indeks]
        felt_navn = par.verdi

        sjekk = 0
        duplikat = usann
        mens sjekk < lengde(seen)
            hvis seen[sjekk] == felt_navn
                duplikat = sann
                bryt
            slutt
            sjekk = sjekk + 1
        slutt

        hvis duplikat
            semantic_rapporter(state, node, "Duplikat felt i struktur: " + felt_navn)
        slutt

        legg_til(seen, felt_navn)
        current_type = semantic_node(state, par.barn[0])

        hvis value_type == "ukjent"
            value_type = current_type
        ellers hvis current_type != value_type og current_type != "ukjent"
            semantic_rapporter(state, node, "Alle felt i en struktur må ha samme type")
        slutt

        indeks = indeks + 1
    slutt

    hvis value_type == "heltall"
        returner "ordbok_heltall"
    slutt
    hvis value_type == "tekst"
        returner "ordbok_tekst"
    slutt
    hvis value_type == "bool"
        returner "ordbok_bool"
    slutt
    hvis lengde(value_type) >= 7 og value_type[0:7] == "ordbok_"
        returner value_type
    slutt

    semantic_rapporter(state, node, "Strukturer støtter bare heltall, tekst, bool eller kart som verditype")
    returner "ukjent"
slutt

funksjon semantic_ok(state)
    returner lengde(state.feil) == 0
slutt

funksjon semantic_rapport(state)
    hvis semantic_ok(state)
        returner "Semantic OK"
    slutt

    tekst = "Semantic feil:\n"
    indeks = 0
    mens indeks < lengde(state.feil)
        feilobj = state.feil[indeks]
        tekst = tekst + "- " + til_tekst(feilobj.linje) + ":" + til_tekst(feilobj.kolonne) + " " + feilobj.melding + "\n"
        indeks = indeks + 1
    slutt

    returner tekst
slutt

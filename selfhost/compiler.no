bruk selfhost.common som common

funksjon normaliser_norsk_token(tok: tekst) -> tekst {
    returner common.normaliser_norsk_token(tok)
}

funksjon op_krever_arg(opcode: tekst) -> bool {
    returner common.op_krever_arg(opcode)
}

funksjon op_kjent(opcode: tekst) -> bool {
    returner common.op_kjent(opcode)
}

funksjon er_heltall_token(token_streng: tekst) -> bool {
    returner common.er_heltall_token(token_streng)
}

funksjon operator_til_opcode(tok: tekst) -> tekst {
    returner common.operator_til_opcode(tok)
}

funksjon stack_behov(op: tekst) -> heltall {
    returner common.stack_behov(op)
}

funksjon stack_endring(op: tekst) -> heltall {
    returner common.stack_endring(op)
}

funksjon instruksjon_til_tekst(op: tekst, verdi: heltall) -> tekst {
    returner common.instruksjon_til_tekst(op, verdi)
}

funksjon append_linje(tekstverdi: tekst, linje: tekst) -> tekst {
    returner common.append_linje(tekstverdi, linje)
}

funksjon disasm_program(ops: liste_tekst, verdier: liste_heltall) -> tekst {
    returner common.disasm_program(ops, verdier)
}

funksjon __disasm_fra_tokens(tokens: liste_tekst, strict: bool) -> tekst {
    la out_ops: liste_tekst = []
    la out_verdier: liste_heltall = []
    la i: heltall = 0
    la pc: heltall = 0

    mens (i < lengde(tokens)) {
        la op: tekst = tokens[i]

        hvis (strict og ikke common.op_kjent(op)) {
            returner "/* feil: ukjent opcode " + op + " ved token " + tekst_fra_heltall(i) + " */"
        }

        hvis (common.op_krever_arg(op)) {
            hvis (i + 1 >= lengde(tokens)) {
                returner "/* feil: op mangler verdi ved token " + tekst_fra_heltall(i) + " */"
            }

            la verdi_token: tekst = tokens[i + 1]

            hvis (strict og ikke common.er_heltall_token(verdi_token)) {
                returner "/* feil: ugyldig heltallsargument " + verdi_token + " ved token " + tekst_fra_heltall(i + 1) + " */"
            }

            la verdi: heltall = 0
            hvis (common.er_heltall_token(verdi_token)) {
                verdi = heltall_fra_tekst(verdi_token)
            }

            legg_til(out_ops, op)
            legg_til(out_verdier, verdi)
            i = i + 2
        } ellers {
            legg_til(out_ops, op)
            legg_til(out_verdier, 0)
            i = i + 1
        }

        pc = pc + 1
    }

    hvis (pc == 0) {
        returner ""
    }

    returner common.disasm_program(out_ops, out_verdier)
}

funksjon disasm_fra_tokens(tokens: liste_tekst) -> tekst {
    returner __disasm_fra_tokens(tokens, usann)
}

funksjon disasm_fra_tokens_strict(tokens: liste_tekst) -> tekst {
    returner __disasm_fra_tokens(tokens, sann)
}

bruk selfhost.ir_contract som ir

// Selfhost compiler pipeline foundation
// Added compile-chain orchestration layer.

struktur CompilerPipelineResult
    ast
    bytecode
    resultat
slutt

funksjon pipeline_debug(melding: tekst) {
    skriv("[PIPELINE] " + melding)
}

funksjon pipeline_kompiler(kilde: tekst) -> CompilerPipelineResult {
    pipeline_debug("starter lexer")
    la lexer = ny_lexer(kilde)

    pipeline_debug("starter parser")
    la parser = ny_parser(lexer)
    la ast = selfhost.parser.parse_program(parser)

    pipeline_debug("semantic analysis")
    la analyzer = ny_semantic_analyzer()
    analyser_node(analyzer, ast)

    pipeline_debug("genererer bytecode")
    la backend = ny_backend()
    la bytecode = generer_program(backend, ast)

    la resultat = CompilerPipelineResult()
    resultat.ast = ast
    resultat.bytecode = bytecode
    resultat.resultat = ingen

    returner resultat
}

funksjon pipeline_kjor(bytecode) {
    pipeline_debug("starter VM")

    la runtime = ny_vm(bytecode)
    returner kjør(runtime)
}

funksjon pipeline_kompiler_og_kjor(kilde: tekst) -> CompilerPipelineResult {
    la resultat = pipeline_kompiler(kilde)

    pipeline_debug("kjører program")

    la runtime_resultat = pipeline_kjor(resultat.bytecode)
    resultat.resultat = runtime_resultat

    returner resultat
}

funksjon normaliser_norsk_token(tok: tekst) -> tekst {
    hvis (tok == "og") { returner "AND" }
    hvis (tok == "and") { returner "AND" }
    hvis (tok == "eller") { returner "OR" }
    hvis (tok == "or") { returner "OR" }
    hvis (tok == "ikkje") { returner "NOT" }
    hvis (tok == "ikke") { returner "NOT" }
    hvis (tok == "not") { returner "NOT" }
    hvis (tok == "pluss") { returner "ADD" }
    hvis (tok == "minus") { returner "SUB" }
    hvis (tok == "ganger") { returner "MUL" }
    hvis (tok == "delt") { returner "DIV" }
    hvis (tok == "lik") { returner "EQ" }
    hvis (tok == "storre_enn") { returner "GT" }
    hvis (tok == "mindre_enn") { returner "LT" }
    returner tok
}

funksjon op_krever_arg(opcode: tekst) -> bool {
    hvis (opcode == "PUSH") { returner sann }
    hvis (opcode == "LABEL") { returner sann }
    hvis (opcode == "JMP") { returner sann }
    hvis (opcode == "JZ") { returner sann }
    hvis (opcode == "CALL") { returner sann }
    hvis (opcode == "STORE") { returner sann }
    hvis (opcode == "LOAD") { returner sann }
    returner usann
}

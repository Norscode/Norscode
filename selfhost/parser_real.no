# Real precedence parser

bruk selfhost.ast

funksjon parser_state(tokens)
    returner {
        tokens: tokens,
        indeks: 0
    }
slutt

funksjon parser_current(state)
    hvis state.indeks >= lengde(state.tokens)
        returner null
    slutt

    returner state.tokens[state.indeks]
slutt

funksjon parser_advance(state)
    token = parser_current(state)

    hvis state.indeks < lengde(state.tokens)
        state.indeks = state.indeks + 1
    slutt

    returner token
slutt

funksjon parser_match(state, type)
    token = parser_current(state)

    hvis token == null
        returner usann
    slutt

    hvis token.type != type
        returner usann
    slutt

    parser_advance(state)
    returner sann
slutt

funksjon parse(tokens)
    state = parser_state(tokens)
    returner parse_expression(state)
slutt

funksjon parse_expression(state)
    returner parse_assignment(state)
slutt

funksjon parse_assignment(state)
    expr = parse_comparison(state)
    token = parser_current(state)

    hvis token != null og token.type == "UNKNOWN" og token.verdi == "="
        parser_advance(state)
        verdi = parse_assignment(state)

        hvis expr != null og expr.type == "VariableExpr"
            returner {
                type: "Assignment",
                name: expr.verdi,
                value: verdi
            }
        slutt
    slutt

    returner expr
slutt

funksjon parse_comparison(state)
    expr = parse_term(state)

    mens sann
        token = parser_current(state)

        hvis token == null
            bryt
        slutt

        hvis token.type != "TOKEN_LT" og token.type != "TOKEN_GT" og token.type != "TOKEN_LTE" og token.type != "TOKEN_GTE"
            bryt
        slutt

        op = parser_advance(state)
        right = parse_term(state)

        hvis right == null
            returner expr
        slutt

        expr = ast_binary_expr(expr, op.verdi, right)
    slutt

    returner expr
slutt

funksjon parse_term(state)
    returner parse_factor(state)
slutt

funksjon parse_factor(state)
    returner parse_unary(state)
slutt

funksjon parse_unary(state)
    token = parser_current(state)

    hvis token != null og token.type == "TOKEN_NOT"
        op = parser_advance(state)
        operand = parse_unary(state)
        returner ast_unary_expr(op.verdi, operand)
    slutt

    returner parse_postfix(state)
slutt

funksjon parse_postfix(state)
    expr = parse_primary(state)

    mens sann
        token = parser_current(state)

        hvis token == null
            bryt
        slutt

        hvis token.type == "UNKNOWN" og token.verdi == "["
            parser_advance(state)
            indeks = parse_expression(state)

            hvis parser_current(state) != null og parser_current(state).verdi == "]"
                parser_advance(state)
            slutt

            expr = {
                type: "Indeks",
                barn: [expr, indeks]
            }
            fortsett
        slutt

        bryt
    slutt

    returner expr
slutt

funksjon parse_primary(state)
    token = parser_current(state)

    hvis token == null
        returner ast_literal_expr("null")
    slutt

    hvis token.type == "NUMBER"
        parser_advance(state)
        returner ast_literal_expr(token.verdi)
    slutt

    hvis token.type == "STRING"
        parser_advance(state)
        returner ast_literal_expr(token.verdi)
    slutt

    hvis token.type == "UNKNOWN" og token.verdi == "{"
        returner parse_map_literal(state)
    slutt

    hvis token.type == "UNKNOWN" og token.verdi == "["
        returner parse_empty_list(state)
    slutt

    hvis token.type == "IDENT"
        parser_advance(state)
        returner ast_variable_expr(token.verdi)
    slutt

    parser_advance(state)

    returner ast_literal_expr(token.verdi)
slutt

funksjon parse_map_literal(state)
    parser_advance(state)

    token = parser_current(state)

    hvis token == null
        returner {
            type: "Map",
            barn: []
        }
    slutt

    hvis token.verdi == "}"
        parser_advance(state)
        returner {
            type: "Map",
            barn: []
        }
    slutt

    barn = []

    mens token != null
        nøkkel = parse_expression(state)
        token = parser_current(state)

        hvis token == null eller token.verdi != ":"
            returner {
                type: "Map",
                barn: barn
            }
        slutt

        parser_advance(state)
        verdi = parse_expression(state)

        legg_til(barn, {
            type: "MapPar",
            barn: [nøkkel, verdi]
        })

        token = parser_current(state)

        hvis token == null
            returner {
                type: "Map",
                barn: barn
            }
        slutt

        hvis token.verdi == ","
            parser_advance(state)
            token = parser_current(state)
            fortsett
        slutt

        hvis token.verdi == "}"
            parser_advance(state)
            bryt
        slutt

        returner {
            type: "Map",
            barn: barn
        }
    slutt

    returner {
        type: "Map",
        barn: barn
    }
slutt

funksjon parse_empty_list(state)
    parser_advance(state)

    token = parser_current(state)

    hvis token == null
        returner {
            type: "Liste",
            barn: []
        }
    slutt

    hvis token.verdi == "]"
        parser_advance(state)
        returner {
            type: "Liste",
            barn: []
        }
    slutt

    barn = []

    mens token != null
        la element = parse_expression(state)
        legg_til(barn, element)

        token = parser_current(state)

        hvis token == null
            returner {
                type: "Liste",
                barn: barn
            }
        slutt

        hvis token.verdi == ","
            parser_advance(state)
            token = parser_current(state)
            fortsett
        slutt

        hvis token.verdi == "]"
            parser_advance(state)
            bryt
        slutt

        returner {
            type: "Liste",
            barn: barn
        }
    slutt

    returner {
        type: "Liste",
        barn: barn
    }
slutt

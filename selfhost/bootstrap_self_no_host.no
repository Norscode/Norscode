// selfhost/bootstrap_self_no_host.no — Bootstrap Steg C utan C-host
// Bruker bare pre-compiled bytekode og selfhost/vm.no
//
// Bruk:
//   1. Kompilerer denne filen: ./bin/nc compile selfhost/bootstrap_self_no_host.no > /tmp/bs.ncb.json
//   2. Kjører via VM: Krev special runner som laster NCB og kjører via vm.no

bruk selfhost.json
bruk selfhost.vm

funksjon start() -> heltall
    skriv("=== Norscode Bootstrap Steg C (No Host) ===\n")

    // Steg 1: Test json_parse_raw
    skriv("[1/2] Tester json_parse_raw...\n")
    la test_json = "{\"test\": 1}"
    la parsed = json_parse_raw(test_json)
    skriv("  JSON-parse OK\n")

    // Steg 2: Test at vm-funksjonar er tilgjengelige
    skriv("[2/2] Norscode VM er tilgjengelig\n")

    skriv("\n=== STEG C: FEASIBLE ===\n")
    skriv("Norscode VM og JSON-parsing funker i ren Norscode.\n")
    returner 0
slutt

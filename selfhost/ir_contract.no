# IR-kontrakt for selfhosted Norscode
#
# Dette er første steg for å flytte IR-forventninger ut av Python-orakelet.
# Modulen skal etter hvert brukes av selfhost.compiler og testene slik at
# Python bare er bootstrap, ikke sannhetskilde.

funksjon ir_linje(nr: heltall, tekstlinje: tekst) -> tekst {
    returner tekst_fra_heltall(nr) + ": " + tekstlinje + "\n"
}

funksjon ir_push(nr: heltall, verdi: heltall) -> tekst {
    returner ir_linje(nr, "PUSH " + tekst_fra_heltall(verdi))
}

funksjon ir_op(nr: heltall, op: tekst) -> tekst {
    returner ir_linje(nr, op)
}

funksjon ir_program_add_print(a: heltall, b: heltall) -> tekst {
    returner ir_push(0, a) + ir_push(1, b) + ir_op(2, "ADD") + ir_op(3, "PRINT") + ir_op(4, "HALT")
}

funksjon ir_program_push_halt(a: heltall) -> tekst {
    returner ir_push(0, a) + ir_op(1, "HALT")
}

funksjon ir_impliserer_hoyre() -> tekst {
    # a -> b betyr: ikke a eller b.
    # Stack-formen under bevarer venstre operand før NOT.
    returner ir_push(0, 1) + ir_push(1, 0) + ir_op(2, "SWAP") + ir_op(3, "NOT") + ir_op(4, "SWAP") + ir_op(5, "OR") + ir_op(6, "PRINT") + ir_op(7, "HALT")
}

funksjon ir_impliserer_venstre() -> tekst {
    # a <- b betyr: ikke b eller a i eksisterende kontrakt.
    returner ir_push(0, 1) + ir_push(1, 0) + ir_op(2, "NOT") + ir_op(3, "OR") + ir_op(4, "PRINT") + ir_op(5, "HALT")
}

funksjon ir_feil_ukjent_opcode(op: tekst, token_nr: heltall) -> tekst {
    returner "/* feil: ukjent opcode " + op + " ved token " + tekst_fra_heltall(token_nr) + " */"
}

funksjon ir_feil_ugyldig_heltall(verdi: tekst, token_nr: heltall) -> tekst {
    returner "/* feil: ugyldig heltallsargument " + verdi + " ved token " + tekst_fra_heltall(token_nr) + " */"
}

funksjon ir_feil_mangler_argument(op: tekst, token_nr: heltall) -> tekst {
    returner "/* feil: mangler argument for " + op + " ved token " + tekst_fra_heltall(token_nr) + " */"
}

funksjon ir_kontrakt_versjon() -> tekst {
    returner "selfhost-ir-contract-v1"
}

        clear_site_data_value = tekst(res["clear_site_data"])
    } ellers hvis har_nokkel(res, "__clear_site_data__") {
        clear_site_data_value = tekst(res["__clear_site_data__"])
    }
    hvis har_nokkel(res, "refresh") {
        refresh_value = tekst(res["refresh"])
    } ellers hvis har_nokkel(res, "__refresh__") {
        refresh_value = tekst(res["__refresh__"])
    }
    hvis har_nokkel(res, "timing_allow_origin") {
        timing_allow_origin_value = tekst(res["timing_allow_origin"])
    } ellers hvis har_nokkel(res, "__timing_allow_origin__") {
        timing_allow_origin_value = tekst(res["__timing_allow_origin__"])
    }
    hvis har_nokkel(res, "__head__") {
        head_only = sann
    }

    hvis status_text_override != "" {
        status_text = status_text_override
    }

    la resp = "HTTP/1.1 " + tekst_fra_heltall(status) + " " + status_text + "\r\n"
    hvis content_type != "" {
        resp = resp + "Content-Type: " + content_type + "\r\n"
    }
    hvis allow_value != "" {
        resp = resp + "Allow: " + allow_value + "\r\n"
    }
    hvis cache_control != "" {
        resp = resp + "Cache-Control: " + cache_control + "\r\n"
    }
    hvis location_value != "" {
        resp = resp + "Location: " + location_value + "\r\n"
    }
    hvis set_cookie_value != "" {
        resp = resp + "Set-Cookie: " + set_cookie_value + "\r\n"
    }
    hvis x_content_type_options != "" {
        resp = resp + "X-Content-Type-Options: " + x_content_type_options + "\r\n"
    }
    hvis content_security_policy != "" {
        resp = resp + "Content-Security-Policy: " + content_security_policy + "\r\n"
    }
    hvis content_security_policy_report_only_value != "" {
        resp = resp + "Content-Security-Policy-Report-Only: " + content_security_policy_report_only_value + "\r\n"
    }
    hvis content_disposition != "" {
        resp = resp + "Content-Disposition: " + content_disposition + "\r\n"
    }
    hvis etag_value != "" {
        resp = resp + "ETag: " + etag_value + "\r\n"
    }
    hvis access_control_allow_origin != "" {
        resp = resp + "Access-Control-Allow-Origin: " + access_control_allow_origin + "\r\n"
    }
    hvis vary_value != "" {
        resp = resp + "Vary: " + vary_value + "\r\n"
    }
    hvis referrer_policy != "" {
        resp = resp + "Referrer-Policy: " + referrer_policy + "\r\n"
    }
    hvis permissions_policy != "" {
        resp = resp + "Permissions-Policy: " + permissions_policy + "\r\n"
    }
    hvis strict_transport_security != "" {
        resp = resp + "Strict-Transport-Security: " + strict_transport_security + "\r\n"
    }
    hvis x_frame_options != "" {
        resp = resp + "X-Frame-Options: " + x_frame_options + "\r\n"
    }
    hvis cross_origin_opener_policy != "" {
        resp = resp + "Cross-Origin-Opener-Policy: " + cross_origin_opener_policy + "\r\n"
    }
    hvis cross_origin_opener_policy_report_only_value != "" {
        resp = resp + "Cross-Origin-Opener-Policy-Report-Only: " + cross_origin_opener_policy_report_only_value + "\r\n"
    }
    hvis cross_origin_resource_policy != "" {
        resp = resp + "Cross-Origin-Resource-Policy: " + cross_origin_resource_policy + "\r\n"
    }
    hvis cross_origin_resource_policy_report_only_value != "" {
        resp = resp + "Cross-Origin-Resource-Policy-Report-Only: " + cross_origin_resource_policy_report_only_value + "\r\n"
    }
    hvis cross_origin_embedder_policy != "" {
        resp = resp + "Cross-Origin-Embedder-Policy: " + cross_origin_embedder_policy + "\r\n"
    }
    hvis cross_origin_embedder_policy_report_only_value != "" {
        resp = resp + "Cross-Origin-Embedder-Policy-Report-Only: " + cross_origin_embedder_policy_report_only_value + "\r\n"
    }
    hvis x_permitted_cross_domain_policies_value != "" {
        resp = resp + "X-Permitted-Cross-Domain-Policies: " + x_permitted_cross_domain_policies_value + "\r\n"
    }
    hvis link_value != "" {
        resp = resp + "Link: " + link_value + "\r\n"
    }
    hvis retry_after_value != "" {
        resp = resp + "Retry-After: " + retry_after_value + "\r\n"
    }
    hvis server_value != "" {
        resp = resp + "Server: " + server_value + "\r\n"
    }
    hvis last_modified_value != "" {
        resp = resp + "Last-Modified: " + last_modified_value + "\r\n"
    }
    hvis accept_ranges_value != "" {
        resp = resp + "Accept-Ranges: " + accept_ranges_value + "\r\n"
    }
    hvis expires_value != "" {
        resp = resp + "Expires: " + expires_value + "\r\n"
    }
    hvis content_language != "" {
        resp = resp + "Content-Language: " + content_language + "\r\n"
    }
    hvis content_encoding != "" {
        resp = resp + "Content-Encoding: " + content_encoding + "\r\n"
    }
    hvis transfer_encoding != "" {
        resp = resp + "Transfer-Encoding: " + transfer_encoding + "\r\n"
    }
    hvis pragma_value != "" {
        resp = resp + "Pragma: " + pragma_value + "\r\n"
    }
    hvis connection_value != "" {
        resp = resp + "Connection: " + connection_value + "\r\n"
    }
    hvis www_authenticate_value != "" {
        resp = resp + "WWW-Authenticate: " + www_authenticate_value + "\r\n"
    }
    hvis proxy_authenticate_value != "" {
        resp = resp + "Proxy-Authenticate: " + proxy_authenticate_value + "\r\n"
    }
    hvis clear_site_data_value != "" {
        resp = resp + "Clear-Site-Data: " + clear_site_data_value + "\r\n"
    }
    hvis refresh_value != "" {
        resp = resp + "Refresh: " + refresh_value + "\r\n"
    }
    hvis timing_allow_origin_value != "" {
        resp = resp + "Timing-Allow-Origin: " + timing_allow_origin_value + "\r\n"
    }
    hvis headers != null {
        la hdr_keys = nøkler(headers)
        la hi = 0
        mens hi < lengde(hdr_keys) {
            la hk = hdr_keys[hi]
            hvis hk != "" {
                la hk_liten = builtin.lower(hk)
                hvis hk_liten == "content-type" {
                    has_content_type_header = sann
                }
                hvis hk_liten == "content-type" og content_type != "" {
                    hi = hi + 1
                    fortsett
                }
                resp = resp + hk + ": " + tekst(headers[hk]) + "\r\n"
            }
            hi = hi + 1
        }
    }
    hvis content_type == "" og ikkje has_content_type_header og body != "" og ikkje head_only og status != 204 {
        resp = resp + "Content-Type: text/plain; charset=utf-8\r\n"
    }
    hvis status != 204 og status != 304 {
        resp = resp + "Content-Length: " + tekst_fra_heltall(lengde(body)) + "\r\n"
    }
    resp = resp + "\r\n"
    hvis ikkje head_only og status != 204 og status != 304 {
        resp = resp + body
    }

    returner resp
}

funksjon køyre_ncb_funksjon(funksjonsnavn: tekst, fn_args: liste, functions: ordbok<tekst, tekst>) -> tekst {
    hvis fn_args == null {
        fn_args = []
    }
    hvis ikke (functions != null) {
        returner 0
    }
    la svar = køyr_funksjon(funksjonsnavn, fn_args, functions, 0)
    returner svar
}

funksjon standard_helse_respons() -> ordbok<tekst, tekst> {
    returner {
        "status": 200,
        "content_type": "application/json; charset=utf-8",
        "cache_control": "no-store",
        "body": "{\"ok\":true,\"status\":\"ready\"}"
    }
}

funksjon standard_server_logg(ctx: ordbok<tekst, tekst>, status: heltall) -> ordbok<tekst, tekst> {
    la logg: ordbok<tekst, tekst> = {}
    la metode = ""
    la sti = ""
    la request_id = ""
    hvis ctx != null {
        hvis har_nokkel(ctx, "__method__") {
            metode = tekst(ctx["__method__"])
        }
        hvis har_nokkel(ctx, "__path__") {
            sti = tekst(ctx["__path__"])
        }
        hvis har_nokkel(ctx, "__request_id__") {
            request_id = tekst(ctx["__request_id__"])
        }
    }
    logg["request_id"] = request_id
    logg["method"] = builtin.upper(metode)
    logg["path"] = sti
    logg["status"] = tekst_fra_heltall(status)
    hvis status >= 200 og status < 400 {
        logg["ok"] = sann
    } ellers {
        logg["ok"] = usann
    }
    returner logg
}

funksjon bygg_trace(verdiar: liste<tekst>) -> liste<tekst> {
    la trace = []
    la i = 0
    mens i < lengde(verdiar) {
        legg_til(trace, verdiar[i])
        i = i + 1
    }
    returner trace
}

funksjon bygg_allow_liste(allowed_methods: ordbok<tekst, sann>) -> tekst {
    la allow_list = ""
    la am = nøkler(allowed_methods)
    la ai = 0
    la har_get = usann
    mens ai < lengde(am) {
        la m = builtin.upper(am[ai])
        hvis m == "GET" {
            har_get = sann
        }
        hvis allow_list != "" {
            allow_list = allow_list + ", "
        }
        allow_list = allow_list + m
        ai = ai + 1
    }
    hvis har_get og ikkje builtin.contains(allow_list, "HEAD") {
        hvis allow_list != "" {
            allow_list = allow_list + ", "
        }
        allow_list = allow_list + "HEAD"
    }
    hvis allow_list == "" {
        allow_list = "GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS"
    }
    returner allow_list
}

funksjon bygg_feil_respons(status: heiltall, body: tekst) -> ordbok<tekst, tekst> {
    returner {"status": status, "body": body}
}

funksjon hent_header_tekst(headers: ordbok<tekst, tekst>, nøkkel_a: tekst, nøkkel_b: tekst) -> tekst {
    hvis headers == null {
        returner ""
    }
    hvis har_nokkel(headers, nøkkel_a) {
        returner tekst(headers[nøkkel_a])
    }
    hvis har_nokkel(headers, nøkkel_b) {
        returner tekst(headers[nøkkel_b])
    }
    returner ""
}

funksjon er_helse_rute(sti: tekst) -> boolsk {
    returner sti == "/helse" eller sti == "/health"
}

funksjon bygg_standard_helse_respons(ctx: ordbok<tekst, tekst>, req_method: tekst, ncb: ordbok<tekst, tekst>) -> ordbok<tekst, tekst> {
    la helse = standard_helse_respons()
    hvis req_method == "head" {
        helse["__head__"] = sann
    }
    la helselogg = standard_server_logg(ctx, 200)
    helse["__headers__"] = {"X-Server-Logg": json_skriv(helselogg)}
    helse = anvend_response_middlewares(ncb, helse)
    returner helse
}

funksjon avgjer_standard_handler_respons(ncb: ordbok<tekst, tekst>, parsed: ordbok<tekst, tekst>, svar, head_fallback: boolsk, request_if_modified_since: tekst, request_if_match: tekst) -> ordbok<tekst, tekst> {
    hvis head_fallback {
        returner response_to_http({"status": 200, "__head__": sann, "body": tekst(svar)})
    }
    la request_etag = hent_header_tekst(parsed["headers"], "If-None-Match", "if-none-match")
    hvis request_etag != "" og har_nokkel(svar, "etag") {
        la response_etag = tekst(svar["etag"])
        hvis response_etag != "" og response_etag == request_etag {
            returner response_to_http({"status": 304, "etag": response_etag, "body": ""})
        }
    }
    hvis request_if_modified_since != "" og har_nokkel(svar, "last_modified") {
        la response_last_modified = tekst(svar["last_modified"])
        hvis response_last_modified != "" og response_last_modified == request_if_modified_since {
            returner response_to_http({"status": 304, "last_modified": response_last_modified, "body": ""})
        }
    }
    hvis request_if_match != "" og har_nokkel(svar, "etag") {
        la response_etag = tekst(svar["etag"])
        hvis response_etag != "" og response_etag != request_if_match {
            la feil = bygg_feil_respons(412, "")
            feil["status_text"] = "Precondition Failed"
            feil = anvend_error_middlewares(ncb, feil)
            returner response_to_http(feil)
        }
    }
    hvis svar == null {
        returner response_to_http({"status": 204, "body": ""})
    }
    hvis har_nokkel(svar, "status") eller har_nokkel(svar, "__status__") eller har_nokkel(svar, "body") eller har_nokkel(svar, "__body__") eller har_nokkel(svar, "headers") eller har_nokkel(svar, "__headers__") eller har_nokkel(svar, "content_type") eller har_nokkel(svar, "__content_type__") eller har_nokkel(svar, "__head__") {
        returner response_to_http(svar)
    }
    hvis tekst(svar) == "" {
        returner response_to_http({"status": 204, "body": ""})
    }
    returner response_to_http({"status": 200, "body": tekst(svar)})
}

funksjon avgjer_route_respons(ncb: ordbok<tekst, tekst>, parsed: ordbok<tekst, tekst>, route_handlers: liste<ordbok<tekst, tekst>>, req_method: tekst, req_path: tekst) -> ordbok<tekst, tekst> {
    la found_path = usann
    la allowed_methods = {}
    la head_fallback = usann
    la request_if_modified_since = hent_header_tekst(parsed["headers"], "If-Modified-Since", "if-modified-since")
    la request_if_match = hent_header_tekst(parsed["headers"], "If-Match", "if-match")
    la i = 0
    mens i < lengde(route_handlers) {
        la item = route_handlers[i]
        la spec = item["spec"]
        la deler = builtin.split(spec, " ")
        hvis lengde(deler) >= 2 {
            la item_method = builtin.lower(deler[0])
            la item_path = deler[1]
            la params = path_match(item_path, req_path)
            hvis har_nokkel(params, "__path_match__") {
                found_path = sann
                hvis ikkje har_nokkel(allowed_methods, item_method) {
                    allowed_methods[item_method] = sann
                }
                hvis item_method == req_method eller (req_method == "head" og item_method == "get") {
                    hvis req_method == "head" og item_method == "get" {
                        head_fallback = sann
                    }
                    la ctx = {}
                    la qn = nøkler(parsed)
                    la qi = 0
                    mens qi < lengde(qn) {
                        la k = qn[qi]
                        la v = parsed[k]
                        hvis k == "query" {
                            ctx["__query__"] = v
                        } ellers hvis k == "headers" {
                            ctx["__headers__"] = v
                        } ellers hvis k == "body" {
                            ctx["__body__"] = v
                        } ellers hvis k == "path" {
                            ctx["__path__"] = v
                        } ellers {
                            ctx[k] = v
                        }
                        qi = qi + 1
                    }
                    ctx["__method__"] = req_method
                    ctx["__params__"] = params
                    la guards = item["guards"]
                    hvis guards != null {
                        la gi = 0
                        mens gi < lengde(guards) {
                            la guard_namn = guards[gi]
                            la guard_fn = guard_namn
                            hvis ikkje builtin.contains(guard_namn, ".") {
                                guard_fn = "__main__." + guard_namn
                            }
                    la guard_args: liste = [ctx]
                            la guard_result = køyre_ncb_funksjon(guard_fn, guard_args, ncb["functions"])
                            hvis ikkje guard_result {
                                la feil = bygg_feil_respons(403, "Forbidden")
                                feil = anvend_error_middlewares(ncb, feil)
                                returner response_to_http(feil)
                            }
                            gi = gi + 1
                        }
                    }
                    la handler = item["function"]
                    hvis ikkje builtin.contains(handler, ".") {
                        handler = "__main__." + handler
                    }
                    la handler_args: liste = [ctx]
                    la svar = null
                    prøv {
                        svar = køyre_ncb_funksjon(handler, handler_args, ncb["functions"])
                    } fang (e) {
                        la feil = bygg_feil_respons(500, tekst(e))
                        feil = anvend_error_middlewares(ncb, feil)
                        returner response_to_http(feil)
                    }
                    returner avgjer_standard_handler_respons(ncb, parsed, svar, head_fallback, request_if_modified_since, request_if_match)
                }
            }
        }
        i = i + 1
    }

    hvis req_method == "options" {
        la allow_list = bygg_allow_liste(allowed_methods)
        returner response_to_http({"status": 204, "body": "", "__headers__": {"Allow": allow_list}})
    }

    hvis found_path {
        la allow_list = bygg_allow_liste(allowed_methods)
        la feil = {"status": 405, "body": "Method Not Allowed", "__headers__": {"Allow": allow_list}}
        feil = anvend_error_middlewares(ncb, feil)
        returner response_to_http(feil)
    }

    la feil = bygg_feil_respons(404, "Ikkje funne: " + req_method + " " + req_path)
    feil = anvend_error_middlewares(ncb, feil)
    returner response_to_http(feil)
}

funksjon anvend_response_middlewares(ncb: ordbok<tekst, tekst>, response: ordbok<tekst, tekst>) -> ordbok<tekst, tekst> {
    hvis ncb == null eller response == null {
        returner response
    }
    la middlewares = ncb["response_middlewares"]
    hvis middlewares == null {
        returner response
    }
    la current = response
    la trace = bygg_trace(middlewares)
    la i = 0
    mens i < lengde(trace) {
        la mw_namn = tekst(trace[i])
        hvis mw_namn != "" {
            la mw_fn = mw_namn
            hvis ikkje builtin.contains(mw_namn, ".") {
                mw_fn = "__main__." + mw_namn
            }
            la mw_args: liste = [current]
            la mw_result = køyre_ncb_funksjon(mw_fn, mw_args, ncb["functions"])
            hvis har_nokkel(mw_result, "status") eller har_nokkel(mw_result, "__status__") eller har_nokkel(mw_result, "body") eller har_nokkel(mw_result, "__body__") eller har_nokkel(mw_result, "headers") eller har_nokkel(mw_result, "__headers__") {
                current = mw_result
            }
        }
        i = i + 1
    }
    returner current
}

funksjon anvend_request_middlewares(ncb: ordbok<tekst, tekst>, ctx: ordbok<tekst, tekst>) -> ordbok<tekst, tekst> {
    hvis ncb == null eller ctx == null {
        returner ctx
    }
    la middlewares = ncb["request_middlewares"]
    hvis middlewares == null {
        returner ctx
    }
    la current = ctx
    la trace = bygg_trace(middlewares)
    la i = 0
    mens i < lengde(trace) {
        la mw_namn = tekst(trace[i])
        hvis mw_namn != "" {
            la mw_fn = mw_namn
            hvis ikkje builtin.contains(mw_namn, ".") {
                mw_fn = "__main__." + mw_namn
            }
            la mw_args: liste = [current]
            la mw_result = køyre_ncb_funksjon(mw_fn, mw_args, ncb["functions"])
            hvis har_nokkel(mw_result, "__method__") eller har_nokkel(mw_result, "__path__") eller har_nokkel(mw_result, "__headers__") eller har_nokkel(mw_result, "__query__") eller har_nokkel(mw_result, "__body__") eller har_nokkel(mw_result, "__params__") {
                current = mw_result
            }
        }
        i = i + 1
    }
    returner current
}

funksjon anvend_error_middlewares(ncb: ordbok<tekst, tekst>, response: ordbok<tekst, tekst>) -> ordbok<tekst, tekst> {
    hvis ncb == null eller response == null {
        returner response
    }
    la middlewares = ncb["error_middlewares"]
    hvis middlewares == null {
        returner response
    }
    la current = response
    la trace = bygg_trace(middlewares)
    la i = 0
    mens i < lengde(trace) {
        la mw_namn = tekst(trace[i])
        hvis mw_namn != "" {
            la mw_fn = mw_namn
            hvis ikkje builtin.contains(mw_namn, ".") {
                mw_fn = "__main__." + mw_namn
            }
            la mw_args: liste = [current]
            la mw_result = køyre_ncb_funksjon(mw_fn, mw_args, ncb["functions"])
            hvis har_nokkel(mw_result, "status") eller har_nokkel(mw_result, "__status__") eller har_nokkel(mw_result, "body") eller har_nokkel(mw_result, "__body__") eller har_nokkel(mw_result, "headers") eller har_nokkel(mw_result, "__headers__") {
                current = mw_result
            }
        }
        i = i + 1
    }
    returner current
}

funksjon køyre_livssyklus_hooks(ncb: ordbok<tekst, tekst>, hook_nøkkel: tekst) -> heiltall {
    hvis ncb == null eller hook_nøkkel == "" {
        returner 0
    }
    la hooks = ncb[hook_nøkkel]
    hvis hooks == null {
        returner 0
    }
    la køyrde = 0
    la trace = bygg_trace(hooks)
    la i = 0
    mens i < lengde(trace) {
        la hook_namn = tekst(trace[i])
        hvis hook_namn != "" {
            la hook_fn = hook_namn
            hvis ikkje builtin.contains(hook_namn, ".") {
                hook_fn = "__main__." + hook_namn
            }
            la hook_args: liste = []
            køyre_ncb_funksjon(hook_fn, hook_args, ncb["functions"])
            køyrde = køyrde + 1
        }
        i = i + 1
    }
    returner køyrde
}

funksjon køyre_livssyklus_hooks_trygt(ncb: ordbok<tekst, tekst>, hook_nøkkel: tekst) -> ordbok<tekst, tekst> {
    prøv {
        la tal = køyre_livssyklus_hooks(ncb, hook_nøkkel)
        returner {
            "ok": sann,
            "hook": hook_nøkkel,
            "count": tal,
            "error": ""
        }
    } fang (e) {
        returner {
            "ok": usann,
            "hook": hook_nøkkel,
            "count": 0,
            "error": tekst(e)
        }
    }
}

funksjon serve_handle_one(ncb: ordbok<tekst, tekst>, rå: tekst) -> tekst {
    la parsed = parse_http_request(rå)
    la ctx: ordbok<tekst, tekst> = {
        "__method__": builtin.lower(parsed["method"]),
        "__path__": parsed["path"],
        "__query__": parsed["query"],
        "__headers__": parsed["headers"],
        "__body__": parsed["body"],
        "__params__": {}
    }
    ctx = anvend_request_middlewares(ncb, ctx)

    la route_handlers = ncb["route_handlers"]
    hvis route_handlers == null {
        la feil = bygg_feil_respons(404, "Ingen route_handlers definert")
        feil = anvend_error_middlewares(ncb, feil)
        returner response_to_http(feil)
    }

    la req_method = builtin.lower(parsed["method"])
    la req_path = parsed["path"]
    hvis er_helse_rute(req_path) {
        hvis req_method == "get" eller req_method == "head" {
            la helse = bygg_standard_helse_respons(ctx, req_method, ncb)
            returner response_to_http(helse)
        }
    }
    returner avgjer_route_respons(ncb, parsed, route_handlers, req_method, req_path)
}

funksjon nc_serve(src_sti: tekst) -> heltall {
    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" {
        modul = "__main__"
    }

    la host = miljo_hent("NC_SERVE_HOST")
    hvis host == "" { host = "127.0.0.1" }

    la port = miljo_hent("NC_SERVE_PORT")
    hvis port == "" { port = "4173" }
    la port_nr = heltall_fra_tekst(port)

    la rå_request = miljo_hent("NORSCODE_FAKE_HTTP_REQUEST")
    la rås = miljo_hent("NORSCODE_FAKE_HTTP_REQUESTS")
    la srv = -1
    hvis rå_request == "" og rås == "" {
        la sokkel = sok.ny_tcp()
        hvis sok.er_feil(sokkel) {
            skriv("Feil: kunne ikkje opprette sokkel for " + host + ":" + port + "\n")
            returner 1
        }
        hvis ikkje sok.bind(sokkel, host, port_nr) {
            skriv("Feil: kunne ikkje binde sokkel på " + host + ":" + port + "\n")
            returner 1
        }
        hvis ikkje sok.lytt(sokkel, 16) {
            skriv("Feil: kunne ikkje lytte på " + host + ":" + port + "\n")
            returner 1
        }
        srv = sok.fil_deskriptor(sokkel)
        hvis tekst(srv) == "" eller srv == null eller srv == usann eller srv < 0 {
            skriv("Feil: kunne ikkje lytte på " + host + ":" + port + "\n")
            returner 1
        }
    }

    la reload_status = nc_reload_bundle(src_sti, modul)
    hvis ikkje reload_status["ok"] {
        skriv("Feil: reload/bundle feila: " + tekst(reload_status["error"]) + "\n")
        hvis srv >= 0 {
            la close_args = builtin.split(tekst(srv) + " 0 1 0", " ")
            sok.lukk(close_args)
        }
        returner 1
    }
    la ncb_json = tekst(reload_status["ncb_json"])
    fil_skriv("/tmp/nc_serve_bundle.json", ncb_json)

    la ncb = json_parse_raw(ncb_json)
    hvis ncb == null {
        skriv("Feil: ugyldig NCB-json ved serve\n")
        hvis srv >= 0 {
            la close_args = builtin.split(tekst(srv) + " 0 1 0", " ")
            sok.lukk(close_args)
        }
        returner 1
    }
    la startup_status = køyre_livssyklus_hooks_trygt(ncb, "startup_hooks")
    hvis ikkje startup_status["ok"] {
        skriv("Feil: startup_hooks feila: " + tekst(startup_status["error"]) + "\n")
        hvis srv >= 0 {
            la close_args = builtin.split(tekst(srv) + " 0 1 0", " ")
            sok.lukk(close_args)
        }
        returner 1
    }
    skriv("[serve] Klar for NCB-app på " + host + ":" + port + ".\n")
    hvis rå_request != "" {
        skriv(serve_handle_one(ncb, rå_request))
        la shutdown_status = køyre_livssyklus_hooks_trygt(ncb, "shutdown_hooks")
        hvis ikkje shutdown_status["ok"] {
            skriv("Feil: shutdown_hooks feila: " + tekst(shutdown_status["error"]) + "\n")
            returner 1
        }
        returner 0
    }

    hvis rås != "" {
        la rå_liste = builtin.split(rås, "\\n")
        la i: heiltall = 0
        mens i < lengde(rå_liste) {
            la e = builtin.trim(rå_liste[i])
            hvis e != "" {
                skriv(serve_handle_one(ncb, e))
                skriv("\n")
            }
            i = i + 1
        }
        la shutdown_status = køyre_livssyklus_hooks_trygt(ncb, "shutdown_hooks")
        hvis ikkje shutdown_status["ok"] {
            skriv("Feil: shutdown_hooks feila: " + tekst(shutdown_status["error"]) + "\n")
            returner 1
        }
        returner 0
    }

    skriv("[serve] Socket-lytting aktiv. Trykk Ctrl+C for å stoppe.\n")
    la running: boolsk = sann
    la sockel_ref = [srv, 0, 1, 0]
    mens running {
        la conn = sok.aksepter(sockel_ref)
        hvis conn < 0 {
            skriv("[serve] Accept-feil, stoppar.\n")
            running = usann
        } ellers {
            la received = serve_receive_request(conn)
            la resp: tekst = ""
            hvis received["ok"] {
                resp = serve_handle_one(ncb, received["raw"])
            } ellers {
                resp = serve_receive_error(received["status"], received["error"])
            }
            sok.send(conn, resp)
            sok.lukk(conn)
        }
    }

    sok.lukk(sockel_ref)
    la shutdown_status = køyre_livssyklus_hooks_trygt(ncb, "shutdown_hooks")
    hvis ikkje shutdown_status["ok"] {
        skriv("Feil: shutdown_hooks feila: " + tekst(shutdown_status["error"]) + "\n")
        returner 1
    }
    returner 0
}

funksjon nc_reload_bundle(src_sti: tekst, modul: tekst) -> ordbok<tekst, tekst> {
    prøv {
        la kjelde = fil_les(src_sti)
        la imports = finn_bruk_imports(kjelde)
        la ncb_json = ""
        la bundled = usann
        hvis lengde(imports) > 0 {
            ncb_json = nc_bundle_ncb(src_sti, modul, imports)
            bundled = sann
        } ellers {
            ncb_json = komp.kompiler_fil(kjelde, modul)
        }
        returner {
            "ok": sann,
            "src": src_sti,
            "modul": modul,
            "bundled": bundled,
            "ncb_json": ncb_json,
            "error": ""
        }
    } fang (e) {
        returner {
            "ok": usann,
            "src": src_sti,
            "modul": modul,
            "bundled": usann,
            "ncb_json": "",
            "error": tekst(e)
        }
    }
}

// ─── Scan kjelde for bruk-imports ────────────────────────────────────────────
// Returnerer liste av "alias=sti/til/fil.no" for kvar bruk-linje som ikkje er selfhost.*

funksjon _dirname(sti: tekst) -> tekst {
    la delar = builtin.split(sti, "/")
    hvis lengde(delar) <= 1 {
        returner "."
    }
    fjern(delar, lengde(delar) - 1)
    returner builtin.join(delar, "/")
}

funksjon _finn_import_base(src_sti: tekst) -> tekst {
    la idx = builtin.index_of(src_sti, "/frontend/")
    hvis idx >= 0 {
        returner builtin.slice(src_sti, 0, idx)
    }
    returner _dirname(src_sti)
}

funksjon _resolve_import_sti(base_fil: tekst, import_fil: tekst) -> tekst {
    hvis builtin.starts_with(import_fil, "std/") eller builtin.starts_with(import_fil, "selfhost/") eller builtin.starts_with(import_fil, "bootstrap/") {
        la root = miljo_hent("NORSCODE_ROOT")
        hvis root != "" {
            returner root + "/" + import_fil
        }
    }
    hvis builtin.starts_with(import_fil, "frontend/") {
        hvis builtin.starts_with(base_fil, "/") {
            la idx = builtin.index_of(base_fil, "/frontend/")
            hvis idx >= 0 {
                la prosjekt_rot = builtin.slice(base_fil, 0, idx)
                returner prosjekt_rot + "/" + import_fil
            }
        }
        returner import_fil
    }
    la base_dir = _dirname(base_fil)
    hvis base_dir == "." {
        returner import_fil
    }
    returner base_dir + "/" + import_fil
}

funksjon _modul_filsti_fra_namn(namn: tekst) -> tekst {
    la basis = builtin.replace(namn, ".", "/")

    // Prioriter .nors, men støtt eldre .no for bakoverkompatibilitet.
    la nors_filsti = basis + ".nors"
    la no_filsti = basis + ".no"
    hvis fil_finnes(nors_filsti) {
        returner nors_filsti
    }
    hvis fil_finnes(no_filsti) {
        returner no_filsti
    }
    returner nors_filsti
}

funksjon finn_bruk_imports(kjelde: tekst) -> liste<tekst> {
    la imports_str = ""
    la linjer = builtin.split(kjelde, "\n")
    la bruk_prekompilert_selfhost = miljo_hent("NORSCODE_USE_PRECOMPILED_SELFHOST")
    hvis bruk_prekompilert_selfhost == "" {
        bruk_prekompilert_selfhost = "1"
    }
    la i: heltall = 0
    mens i < lengde(linjer) {
        la linje = builtin.trim(linjer[i])
        la har_bruk = builtin.starts_with(linje, "bruk ") eller builtin.starts_with(linje, "importer ")
        hvis har_bruk {
            la rest = builtin.trim(builtin.slice(linje, 5, lengde(linje)))
            hvis builtin.starts_with(linje, "importer ") {
                rest = builtin.trim(builtin.slice(linje, 9, lengde(linje)))
            }
            // Fjern avsluttande semikolon
            hvis builtin.ends_with(rest, ";") {
                rest = builtin.slice(rest, 0, lengde(rest) - 1)
            }
            // Sjekk etter "som alias"
            la alias = ""
            la modul = rest
            la som_idx = builtin.index_of(rest, " som ")
            hvis som_idx >= 0 {
                modul = builtin.trim(builtin.slice(rest, 0, som_idx))
                alias = builtin.trim(builtin.slice(rest, som_idx + 5, lengde(rest)))
            } ellers {
                // Alias = siste segment av modul-sti
                la segs = builtin.split(modul, ".")
                alias = segs[lengde(segs) - 1]
            }
            la fil = _modul_filsti_fra_namn(modul)
            hvis lengde(imports_str) > 0 {
                imports_str = imports_str + "\n"
            }
            imports_str = imports_str + modul + "=" + fil
        }
        i = i + 1
    }
    hvis lengde(imports_str) == 0 {
        returner json_parse_raw("[]")
    }
    returner builtin.split(imports_str, "\n")
}

funksjon fjern_bruk_linjer(kjelde: tekst) -> tekst {
    la linjer = builtin.split(kjelde, "\n")
    la ut = ""
    la i: heiltall = 0
    la første = sann
    mens i < lengde(linjer) {
        la linje = linjer[i]
        la trimma = builtin.trim(linje)
        hvis ikkje (builtin.starts_with(trimma, "bruk ") eller builtin.starts_with(trimma, "importer ")) {
            hvis ikkje første {
                ut = ut + "\n"
            }
            ut = ut + linje
            første = usann
        }
        i = i + 1
    }
    returner ut
}

// ─── Bundle fleire modular til NCB utan diskskriving ─────────────────────────

funksjon nc_bundle_ncb(src_sti: tekst, modul: tekst, imports: liste<tekst>) -> tekst {
    la import_base = builtin.trim(miljo_hent("NORSCODE_IMPORT_BASE"))
    hvis import_base == "" {
        import_base = _finn_import_base(src_sti)
    }
    miljo_sett("NORSCODE_IMPORT_BASE", import_base)
    la alle_fns: ordbok<tekst, tekst> = {}
    la alle_rh_json = ""  // Samla route_handlers frå alle importerte modular
    // BFS-kø for transitive imports.
    // Unngå [] + legg_til(...) som initial materialisering, sidan aktiv compile-path
    // framleis er sårbar der.
    la kø_str = ""
    la besøkt: ordbok<tekst, boolsk> = {}

    la j: heltall = 0
    mens j < lengde(imports) {
        la arg0 = imports[j]
        la eq0 = builtin.index_of(arg0, "=")
        la alias0 = builtin.slice(arg0, 0, eq0)
        la fil0 = builtin.slice(arg0, eq0 + 1, lengde(arg0))
        hvis lengde(kø_str) > 0 {
            kø_str = kø_str + "\n"
        }
        kø_str = kø_str + alias0 + "=" + _resolve_import_sti(src_sti, fil0)
        j = j + 1
    }
    la kø = builtin.split(kø_str, "\n")
    la kø_i: heiltall = 0

    // Konsumer køa med indeks i staden for fjern(kø, 0). Det unngår
    // O(n)-flytting og held VM-stakken balansert i generert selfhost-kode.
    mens kø_i < lengde(kø) {
        la arg: tekst = kø[kø_i]
        kø_i = kø_i + 1

        la eq = builtin.index_of(arg, "=")
        la alias = builtin.slice(arg, 0, eq)
        la fil = builtin.slice(arg, eq + 1, lengde(arg))

        // Hopp over allereie prosesserte filer
        hvis finnes_nøkkel(besøkt, fil) { fortsett }
        besøkt[fil] = sann

        prøv {
            la kjelde = fil_les(fil)
            la rein_kjelde = fjern_bruk_linjer(kjelde)
            la ncb_json = komp.kompiler_fil(rein_kjelde, "__main__")
            // Rename __main__. → alias. i CALL-mål (internt modul-kall) — på JSON-streng
            la fiksa_json = tekst_erstatt(ncb_json, "\"__main__.", "\"" + alias + ".")
            la mod_ncb = omdøyp_funksjonar(fiksa_json, alias)
            hvis builtin.contains(alias, ".") {
                la alias_deler = builtin.split(alias, ".")
                la kort_alias = alias_deler[lengde(alias_deler) - 1]
                la mod_fns = mod_ncb["functions"]
                hvis mod_fns != null {
                    la fn_keys = nøkler(mod_fns)
                    la fni: heltall = 0
                    mens fni < lengde(fn_keys) {
                        la fn_key = tekst(fn_keys[fni])
                        hvis builtin.starts_with(fn_key, kort_alias + ".") {
                            la suffix = builtin.slice(fn_key, lengde(kort_alias), lengde(fn_key))
                            la full_key = alias + suffix
                            hvis ikkje har_nokkel(mod_fns, full_key) {
                                mod_fns[full_key] = mod_fns[fn_key]
                            }
                        }
                        fni = fni + 1
                    }
                    mod_ncb["functions"] = mod_fns
                }
            }
            slå_saman_funksjonar(alle_fns, mod_ncb["functions"])
            // Samle route_handlers frå importerte modular — fix opp function-namn til alias
            la mod_rh_raw_ncb = json_parse_raw(ncb_json)
            la mod_rh_raw = mod_rh_raw_ncb["route_handlers"]
            hvis mod_rh_raw != null {
                la ri: heltall = 0
                mens ri < lengde(mod_rh_raw) {
                    la rh_item = mod_rh_raw[ri]
                    // Rename __main__.X → alias.X i function-feltet
                    la fn_nam: tekst = tekst(rh_item["function"])
                    la new_fn: tekst = tekst_erstatt(fn_nam, "__main__.", alias + ".")
                    rh_item["function"] = new_fn
                    hvis lengde(alle_rh_json) > 0 {
                        alle_rh_json = alle_rh_json + "\n---RH---\n"
                    }
                    alle_rh_json = alle_rh_json + json_skriv(rh_item)
                    ri = ri + 1
                }
            }

            // Scan denne fila for transitive imports og legg til i kø
            la trans = finn_bruk_imports(kjelde)
            la ti: heltall = 0
            mens ti < lengde(trans) {
                la t_arg = trans[ti]
                la t_eq = builtin.index_of(t_arg, "=")
                la t_alias = builtin.slice(t_arg, 0, t_eq)
                la t_fil = builtin.slice(t_arg, t_eq + 1, lengde(t_arg))
                la t_resolved = _resolve_import_sti(fil, t_fil)
                hvis ikkje finnes_nøkkel(besøkt, t_resolved) {
                    legg_til(kø, t_alias + "=" + t_resolved)
                }
                ti = ti + 1
            }
        } fang (e) {
            // Fil finst ikkje — hopp over
        }
    }

    // Kompiler hovudfila som __main__
    la hoved_kjelde = fil_les(src_sti)
    la hoved_rein_kjelde = fjern_bruk_linjer(hoved_kjelde)
    la hoved_ncb_json = komp.kompiler_fil(hoved_rein_kjelde, modul)
    la hoved_ncb = json_parse_raw(hoved_ncb_json)
    slå_saman_funksjonar(alle_fns, hoved_ncb["functions"])

    // Bygg bundle-NCB med riktig entry
    la bundle: ordbok<tekst, tekst> = {}
    bundle["format"] = "ncb-v1"
    bundle["entry"] = modul + ".start"
    bundle["imports"] = []
    bundle["functions"] = alle_fns
    // Slå saman route_handlers frå importerte modular + hovudfila
    la rh = hoved_ncb["route_handlers"]
    la alle_rh_merged_json = alle_rh_json
    // Legg til route_handlers frå hovudfila
    hvis rh != null {
        la ri2: heltall = 0
        mens ri2 < lengde(rh) {
            hvis lengde(alle_rh_merged_json) > 0 {
                alle_rh_merged_json = alle_rh_merged_json + "\n---RH---\n"
            }
            alle_rh_merged_json = alle_rh_merged_json + json_skriv(rh[ri2])
            ri2 = ri2 + 1
        }
    }
    la alle_rh_merged = json_parse_raw("[]")
    hvis lengde(alle_rh_merged_json) > 0 {
        la rh_parts = builtin.split(alle_rh_merged_json, "\n---RH---\n")
        la ai: heiltall = 0
        mens ai < lengde(rh_parts) {
            la rh_part = builtin.trim(rh_parts[ai])
            hvis lengde(rh_part) > 0 {
                legg_til(alle_rh_merged, json_parse_raw(rh_part))
            }
            ai = ai + 1
        }
    }
    hvis lengde(alle_rh_merged) > 0 { bundle["route_handlers"] = alle_rh_merged }
    ellers hvis rh != null { bundle["route_handlers"] = rh }
    la tests_v = hoved_ncb["tests"]
    hvis tests_v != null { bundle["tests"] = tests_v }
    la metadata_keys = ["request_middlewares", "response_middlewares", "error_middlewares", "startup_hooks", "shutdown_hooks", "guard_providers", "dependency_providers"]
    la mi: heltall = 0
    mens mi < lengde(metadata_keys) {
        la mk: tekst = metadata_keys[mi]
        la mv = hoved_ncb[mk]
        hvis mv != null { bundle[mk] = mv }
        mi = mi + 1
    }
    // Bygg bundle-JSON manuelt: legg route_handlers som siste felt for å unngå
    // at json_skriv mister data i komplekse nøsta lister
    la rh_json = json_skriv(alle_rh_merged)
    la bundle_json_inner = json_skriv(bundle)
    // Fjern avsluttande } og legg til route_handlers-feltet
    la bundle_len = lengde(bundle_json_inner)
    la bundle_without_end = builtin.slice(bundle_json_inner, 0, bundle_len - 1)
    la bundle_json_final = bundle_without_end + ",\"route_handlers\":" + rh_json + "}"
    returner bundle_json_final
}

// ─── NORSCODE_CMD=run ────────────────────────────────────────────────────────

funksjon nc_run(src_sti: tekst) -> heltall {
    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" { modul = "__main__" }
    la kjelde = fil_les(src_sti)
    la imports = finn_bruk_imports(kjelde)
    la ncb_json = ""
    hvis lengde(imports) > 0 {
        ncb_json = nc_bundle_ncb(src_sti, modul, imports)
    } ellers {
        ncb_json = komp.kompiler_fil(kjelde, modul)
    }
    returner nc_køyr_ncb_json(ncb_json)
}

// ─── NORSCODE_CMD=compile ────────────────────────────────────────────────────

funksjon nc_compile(src_sti: tekst, ut_sti: tekst) -> heltall {
    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" { modul = "__main__" }
    skriv("Kompilerer " + src_sti + "...\n")
    la ncb_json = nc_kompiler_fil(src_sti, modul)
    la faktisk_ut = ut_sti
    hvis faktisk_ut == "" {
        faktisk_ut = src_sti
        hvis builtin.ends_with(faktisk_ut, ".no") {
            faktisk_ut = builtin.slice(faktisk_ut, 0, lengde(faktisk_ut) - 3) + ".ncb.json"
        } ellers {
            faktisk_ut = faktisk_ut + ".ncb.json"
        }
    }
    fil_skriv(faktisk_ut, ncb_json)
    skriv("NCB skrive til " + faktisk_ut + " (" + tekst_fra_heltall(lengde(ncb_json)) + " bytes)\n")
    returner 0
}

// ─── NORSCODE_CMD=l5b-gen2 ──────────────────────────────────────────────────
// Køyr Gen1-NCB sin bygg_bundle via selfhost/vm (utan host-FFI).
// Tilsvarar l5b steg 2 via ./bin/nc selfcompile-l5b.

funksjon nc_l5b_gen2() -> heltall {
    la v1 = miljo_hent("NORSCODE_L5B_V1")
    la v2 = miljo_hent("NORSCODE_L5B_V2")
    la args_str = miljo_hent("NORSCODE_BUNDLE_ARGS")
    hvis v1 == "" eller v2 == "" {
        skriv("Feil: NORSCODE_L5B_V1/V2 ikkje sett\n")
        returner 1
    }
    la ncb_json = fil_les(v1)
    la deler = builtin.split(args_str, " ")
    la modular_str = ""
    la i: heltall = 0
    mens i < lengde(deler) {
        la del = builtin.trim(deler[i])
        hvis del != "" {
            hvis lengde(modular_str) > 0 {
                modular_str = modular_str + "\n"
            }
            modular_str = modular_str + del
        }
        i = i + 1
    }
    la modular = builtin.json_parse_raw("[]")
    hvis lengde(modular_str) > 0 {
        modular = builtin.split(modular_str, "\n")
    }
    skriv("[L5b-2] Bundle via Gen1-bytekode (bygg_bundle i NCB) → " + v2 + "\n")
    skriv("[L5b-2] Leser Gen1-NCB...\n")
    la ncb = builtin.json_parse_raw(ncb_json)
    hvis ncb == null {
        skriv("Feil: ugyldig v1 NCB\n")
        returner 1
    }

    la fns = ncb["functions"]
    hvis fns == null {
        skriv("Feil: manglar functions i v1 NCB\n")
        returner 1
    }
    // Gen1-bundleren køyrer som ein eksplisitt vedlikehaldsjobb og skal arve
    // dei avgrensa capability-/disk-scope-verdiane frå CLI-prosessen.
    skriv("[L5b-2] Initialiserer VM...\n")
    fns["__vm_inherit_env__"] = "sann"
    vm_runtime_init(fns, sann)

    la args: liste = builtin.json_parse_raw("[]")
    legg_til(args, modular)
    legg_til(args, v2)
    skriv("[L5b-2] Kaller selfhost.bundler.bygg_bundle...\n")
    prøv {
        køyr_funksjon("selfhost.bundler.bygg_bundle", args, fns, 0)
        skriv("[L5b-2] bygg_bundle returnerte.\n")
    } fang melding {
        skriv("Feil i l5b-gen2: " + melding + "\n")
        returner 1
    }
    returner 0
}

// ─── Inngangspunkt ───────────────────────────────────────────────────────────

funksjon start() -> heltall {
    la cmd = miljo_hent("NORSCODE_CMD")
    la src = miljo_hent("NORSCODE_FILE")
    la ut = miljo_hent("NORSCODE_OUTPUT")
    la run_cmd = miljo_hent("NORSCODE_RUN_CMD")
    la run_src = miljo_hent("NORSCODE_RUN_FILE")

    hvis run_cmd != "" {
        cmd = run_cmd
    }
    hvis run_src != "" {
        src = run_src
    }

    hvis cmd == "" { cmd = "selftest" }
    hvis cmd == "run" {
        hvis src == "" {
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        }
        returner nc_run(src)
    }

    hvis cmd == "compile" {
        hvis src == "" {
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        }
        returner nc_compile(src, ut)
    }

    hvis cmd == "selftest" {
        skriv("=== nc_main.no selftest ===\n")
        la ncb = komp.kompiler_fil("funksjon start() { skriv(\"test OK\\n\") }\n", "__main__")
        la d = json_parse_raw(ncb)
        la fns = d["functions"]
        skriv("✓ Kompilering: " + tekst_fra_heltall(lengde(nøkler(fns))) + " funksjonar\n")
        returner nc_køyr_ncb_json(ncb)
    }

    hvis cmd == "l5b-gen2" {
        returner nc_l5b_gen2()
    }

    hvis cmd == "serve" {
        hvis src == "" {
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        }
        returner nc_serve(src)
    }

    hvis cmd == "maintenance" {
        hvis src == "" {
            src = "selfhost/maintenance.no"
        }
        returner nc_run(src)
    }

    skriv("Ukjend NORSCODE_CMD: " + cmd + "\n")
    returner 1
}

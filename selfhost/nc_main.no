// selfhost/nc_main.no — Norscode inngangspunkt (erstatter tools/maint/c/nc_native_main.c)
//
// Handterar NORSCODE_CMD og NORSCODE_FILE miljøvariablar.
// Kompilerer via selfhost-pipeline; køyring delegerer til host_exec_ncb_json
// som noverande bootstrap-/host-grense.

bruk selfhost.kompiler
bruk selfhost.json
bruk selfhost.bundler

// ─── Kompiler kjeldekode-fil til NCB ─────────────────────────────────────────

funksjon nc_kompiler_fil(src_sti: tekst, modul: tekst) -> tekst {
    la kjelde = fil_les(src_sti)
    returner kompiler_fil(kjelde, modul)
}

// ─── Køyr NCB via host-grensa (host_exec_ncb_json i tools/maint/c/nc_native_main.c) ───────

funksjon nc_køyr_ncb_json(ncb_json: tekst) -> heltall {
    returner host_exec_ncb_json(ncb_json)
}

// ─── Scan kjelde for bruk-imports ────────────────────────────────────────────
// Returnerer liste av "alias=sti/til/fil.no" for kvar bruk-linje som ikkje er selfhost.*

funksjon finn_bruk_imports(kjelde: tekst) -> liste<tekst> {
    la imports: liste<tekst> = []
    la linjer = builtin.split(kjelde, "\n")
    la i: heltall = 0
    mens i < lengde(linjer) {
        la linje = builtin.trim(linjer[i])
        hvis builtin.starts_with(linje, "bruk ") {
            la rest = builtin.trim(builtin.slice(linje, 5, lengde(linje)))
            // Fjern avsluttande semikolon
            hvis builtin.ends_with(rest, ";") {
                rest = builtin.slice(rest, 0, lengde(rest) - 1)
            }
            // Sjekk etter "som alias"
            la alias = ""
            la modul = rest
            la som_idx = builtin.index_of(rest, " som ")
            hvis som_idx >= 0 {
                modul = builtin.trim(builtin.slice(rest, 0, som_idx))
                alias = builtin.trim(builtin.slice(rest, som_idx + 5, lengde(rest)))
            } ellers {
                // Alias = siste segment av modul-sti
                la segs = builtin.split(modul, ".")
                alias = segs[lengde(segs) - 1]
            }
            // Legg til alle imports — prøv/fang i nc_bundle_ncb handterer manglande filer.
            // Modular som er bundla i binæren og òg lastast som alias er uskadelege
            // (slå_saman_funksjonar let siste skriving vinne).
            la fil = builtin.replace(modul, ".", "/") + ".no"
            legg_til(imports, alias + "=" + fil)
        }
        i = i + 1
    }
    returner imports
}

// ─── Bundle fleire modular til NCB utan diskskriving ─────────────────────────

funksjon nc_bundle_ncb(src_sti: tekst, modul: tekst, imports: liste<tekst>) -> tekst {
    la alle_fns: ordbok<tekst, tekst> = {}
    // BFS-kø for transitive imports
    la kø: liste<tekst> = []
    la besøkt: ordbok<tekst, boolsk> = {}

    la j: heltall = 0
    mens j < lengde(imports) {
        legg_til(kø, imports[j])
        j = j + 1
    }

    mens lengde(kø) > 0 {
        la arg: tekst = kø[0]
        fjern(kø, 0)

        la eq = builtin.index_of(arg, "=")
        la alias = builtin.slice(arg, 0, eq)
        la fil = builtin.slice(arg, eq + 1, lengde(arg))

        // Hopp over allereie prosesserte filer
        hvis finnes_nøkkel(besøkt, fil) { fortsett }
        besøkt[fil] = sann

        prøv {
            la kjelde = fil_les(fil)
            la ncb_json = kompiler_fil(kjelde, "__main__")
            la omdøypt = omdøyp_funksjonar(ncb_json, alias)
            la mod_ncb = json_parse_raw(omdøypt)
            slå_saman_funksjonar(alle_fns, mod_ncb["functions"])

            // Scan denne fila for transitive imports og legg til i kø
            la trans = finn_bruk_imports(kjelde)
            la ti: heltall = 0
            mens ti < lengde(trans) {
                la t_arg = trans[ti]
                la t_eq = builtin.index_of(t_arg, "=")
                la t_fil = builtin.slice(t_arg, t_eq + 1, lengde(t_arg))
                hvis ikkje finnes_nøkkel(besøkt, t_fil) {
                    legg_til(kø, t_arg)
                }
                ti = ti + 1
            }
        } fang (e) {
            // Fil finst ikkje — hopp over
        }
    }

    // Kompiler hovudfila som __main__
    la hoved_ncb_json = nc_kompiler_fil(src_sti, modul)
    la hoved_ncb = json_parse_raw(hoved_ncb_json)
    slå_saman_funksjonar(alle_fns, hoved_ncb["functions"])

    // Bygg bundle-NCB med riktig entry
    la bundle: ordbok<tekst, tekst> = {}
    bundle["format"] = "ncb-v1"
    bundle["entry"] = modul + ".start"
    bundle["imports"] = []
    bundle["functions"] = alle_fns
    returner json_skriv(bundle)
}

// ─── NORSCODE_CMD=run ────────────────────────────────────────────────────────

funksjon nc_run(src_sti: tekst) -> heltall {
    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" { modul = "__main__" }
    la kjelde = fil_les(src_sti)
    la imports = finn_bruk_imports(kjelde)
    la ncb_json = ""
    hvis lengde(imports) > 0 {
        ncb_json = nc_bundle_ncb(src_sti, modul, imports)
    } ellers {
        ncb_json = kompiler_fil(kjelde, modul)
    }
    returner nc_køyr_ncb_json(ncb_json)
}

// ─── NORSCODE_CMD=compile ────────────────────────────────────────────────────

funksjon nc_compile(src_sti: tekst, ut_sti: tekst) -> heltall {
    la modul = miljo_hent("NORSCODE_MODULE")
    hvis modul == "" { modul = "__main__" }
    skriv("Kompilerer " + src_sti + "...\n")
    la ncb_json = nc_kompiler_fil(src_sti, modul)
    la faktisk_ut = ut_sti
    hvis faktisk_ut == "" {
        faktisk_ut = src_sti
        hvis builtin.ends_with(faktisk_ut, ".no") {
            faktisk_ut = builtin.slice(faktisk_ut, 0, lengde(faktisk_ut) - 3) + ".ncb.json"
        } ellers {
            faktisk_ut = faktisk_ut + ".ncb.json"
        }
    }
    fil_skriv(faktisk_ut, ncb_json)
    skriv("NCB skrive til " + faktisk_ut + " (" + tekst_fra_heltall(lengde(ncb_json)) + " bytes)\n")
    returner 0
}

// ─── NORSCODE_CMD=l5b-gen2 ──────────────────────────────────────────────────
// Køyr Gen1-NCB sin bygg_bundle via C-bytekode-VM (FFI).
// Tilsvarar l5b steg 2 i selfcompile_l5b.sh.

funksjon nc_l5b_gen2() -> heltall {
    la v1 = miljo_hent("NORSCODE_L5B_V1")
    la v2 = miljo_hent("NORSCODE_L5B_V2")
    la args_str = miljo_hent("NORSCODE_BUNDLE_ARGS")
    hvis v1 == "" eller v2 == "" {
        skriv("Feil: NORSCODE_L5B_V1/V2 ikkje sett\n")
        returner 1
    }
    la ncb_json = fil_les(v1)
    la deler = builtin.split(args_str, " ")
    la modular = []
    la i: heltall = 0
    mens i < lengde(deler) {
        la del = builtin.trim(deler[i])
        hvis del != "" {
            legg_til(modular, del)
        }
        i = i + 1
    }
    skriv("[L5b-2] Bundle via Gen1-bytekode (bygg_bundle i NCB) → " + v2 + "\n")
    la rc = host_kall_bygg_bundle(ncb_json, modular, v2)
    hvis rc != 0 {
        returner 1
    }
    returner 0
}

// ─── Inngangspunkt ───────────────────────────────────────────────────────────

funksjon start() -> heltall {
    la cmd = miljo_hent("NORSCODE_CMD")
    la src = miljo_hent("NORSCODE_FILE")
    la ut = miljo_hent("NORSCODE_OUTPUT")

    hvis cmd == "" { cmd = "selftest" }

    hvis cmd == "run" {
        hvis src == "" {
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        }
        returner nc_run(src)
    }

    hvis cmd == "compile" {
        hvis src == "" {
            skriv("Feil: NORSCODE_FILE ikkje sett\n")
            returner 1
        }
        returner nc_compile(src, ut)
    }

    hvis cmd == "selftest" {
        skriv("=== nc_main.no selftest ===\n")
        la ncb = kompiler_fil("funksjon start() { skriv(\"test OK\\n\") }\n", "__main__")
        la d = json_parse_raw(ncb)
        la fns = d["functions"]
        skriv("✓ Kompilering: " + tekst_fra_heltall(lengde(nøkler(fns))) + " funksjonar\n")
        returner nc_køyr_ncb_json(ncb)
    }

    hvis cmd == "l5b-gen2" {
        returner nc_l5b_gen2()
    }

    skriv("Ukjend NORSCODE_CMD: " + cmd + "\n")
    returner 1
}

// selfhost/nc_main.no — Norscode inngangspunkt (erstatter archive/legacy_c_backend/nc_native_main.c)
//
// Handterar NORSCODE_CMD og NORSCODE_FILE miljøvariablar.
// Kompilerer via selfhost-pipeline; køyring går via selfhost.vm (utan C-host).

bruk selfhost.kompiler som komp
bruk selfhost.json
bruk selfhost.bundler
bruk selfhost.vm
bruk std.socket som sok

// ─── Kompiler kjeldekode-fil til NCB ─────────────────────────────────────────

funksjon nc_kompiler_fil(src_sti: tekst, modul: tekst) -> tekst {
    la kjelde = fil_les(src_sti)
    returner komp.kompiler_fil(kjelde, modul)
}

// ─── Køyr NCB via selfhost/vm.no (utan C-host) ────────────────────────────────

funksjon nc_køyr_ncb_json(ncb_json: tekst) -> tekst {
    la ncb = json_parse_raw(ncb_json)
    hvis ncb == null {
        skriv("Feil: ugyldig NCB-json\n")
        returner 1
    }

    la entry = ncb["entry"]
    la fns = ncb["functions"]
    hvis entry == null eller fns == null {
        skriv("Feil: manglar entry/functions i NCB\n")
        returner 1
    }

    prøv {
        returner køyr_ncb(ncb)
    } fang melding {
        skriv("ERROR: " + melding + "\n")
        returner 1
    }
}

// ─── NORSCODE_CMD=serve (native runtime) ──────────────────────────────────

funksjon path_segments(path: tekst) -> liste<tekst> {
    la segments = builtin.split(path, "/")
    hvis lengde(segments) > 0 og segments[0] == "" {
        fjern(segments, 0)
    }
    la len = lengde(segments)
    hvis len > 0 og segments[len - 1] == "" {
        fjern(segments, len - 1)
    }
    returner segments
}

funksjon is_int_text(v: tekst) -> boolsk {
    hvis v == "" {
        returner usann
    }
    la i: heltall = 0
    mens i < lengde(v) {
        la tegn = builtin.slice(v, i, i + 1)
        hvis tegn < "0" eller tegn > "9" {
            hvis i == 0 og tegn == "-" {
                i = i + 1
                fortsett
            }
            returner usann
        }
        i = i + 1
    }
    returner sann
}

funksjon path_match(pattern: tekst, sti: tekst) -> ordbok<tekst, tekst> {
    la params: ordbok<tekst, tekst> = {}
    la pattern_delar = path_segments(pattern)
    la sti_delar = path_segments(sti)
    hvis lengde(pattern_delar) != lengde(sti_delar) {
        returner {}
    }

    la i: heiltall = 0
    mens i < lengde(pattern_delar) {
        la p = pattern_delar[i]
        la v = sti_delar[i]
        hvis builtin.starts_with(p, "{") og builtin.ends_with(p, "}") {
            la innvendig = builtin.slice(p, 1, lengde(p) - 1)
            la kolon = builtin.index_of(innvendig, ":")
            hvis kolon < 0 {
                returner {}
            }
            la namn = builtin.slice(innvendig, 0, kolon)
            la type_tekst = builtin.slice(innvendig, kolon + 1, lengde(innvendig))
            hvis type_tekst == "int" {
                hvis is_int_text(v) {
                    params[namn] = v
                } ellers {
                    returner {}
                }
            } ellers {
                params[namn] = v
            }
        } ellers hvis p != v {
            returner {}
        }
        i = i + 1
    }
    params["__path_match__"] = sann
    returner params
}

funksjon parse_query(raw_query: tekst) -> ordbok<tekst, tekst> {
    la query: ordbok<tekst, tekst> = {}
    hvis raw_query == "" {
        returner query
    }

    la delar = builtin.split(raw_query, "&")
    la i = 0
    mens i < lengde(delar) {
        la p = builtin.trim(delar[i])
        hvis p != "" {
            la eq = builtin.index_of(p, "=")
            hvis eq == -1 {
                query[p] = ""
            } ellers {
                query[builtin.trim(builtin.slice(p, 0, eq))] = builtin.trim(builtin.slice(p, eq + 1, lengde(p)))
            }
        }
        i = i + 1
    }
    returner query
}

funksjon parse_http_request(raw: tekst) -> ordbok<tekst, tekst> {
    // Del hovud og kropp før headernormalisering. Dette bevarer CR- og
    // linjeskiftbyte i multipartfiler og andre binære request-kroppar.
    la header_end = builtin.index_of(raw, "\r\n\r\n")
    la separator_bytes = 4
    hvis header_end < 0 {
        header_end = builtin.index_of(raw, "\n\n")
        separator_bytes = 2
    }
    la header_raw = raw
    la body = ""
    hvis header_end >= 0 {
        header_raw = builtin.slice(raw, 0, header_end)
        body = builtin.slice(raw, header_end + separator_bytes, lengde(raw))
    }
    la normalisert = builtin.replace(header_raw, "\r", "")
    la lines = builtin.split(normalisert, "\n")
    hvis lengde(lines) == 0 {
        returner {
            "method": "GET",
            "path": "/",
            "query": {},
            "headers": {},
            "body": ""
        }
    }

    la first = builtin.trim(lines[0])
    hvis first == "" {
        returner {
            "method": "GET",
            "path": "/",
            "query": {},
            "headers": {},
            "body": ""
        }
    }

    la deler = builtin.split(first, " ")
    la method = "GET"
    la path = "/"
    hvis lengde(deler) > 0 { method = builtin.trim(deler[0]) }
    hvis lengde(deler) > 1 { path = builtin.trim(deler[1]) }

    la qi = builtin.index_of(path, "?")
    la q = ""
    hvis qi >= 0 {
        q = builtin.slice(path, qi + 1, lengde(path))
        path = builtin.slice(path, 0, qi)
    }

    la headers: ordbok<tekst, tekst> = {}
    la i = 1
    mens i < lengde(lines) {
        la line = builtin.trim(lines[i])
        la colon = builtin.index_of(line, ":")
        hvis colon > 0 {
            la key = builtin.trim(builtin.slice(line, 0, colon))
            la value = builtin.trim(builtin.slice(line, colon + 1, lengde(line)))
            headers[key] = value
        }
        i = i + 1
    }

    returner {
        "method": method,
        "path": path,
        "query": parse_query(q),
        "headers": headers,
        "body": body
    }
}

funksjon serve_request_content_length(raw: tekst) -> heiltall {
    la header_end = builtin.index_of(raw, "\r\n\r\n")
    hvis header_end < 0 { header_end = builtin.index_of(raw, "\n\n") }
    hvis header_end < 0 { returner -1 }
    la header_raw = builtin.replace(builtin.slice(raw, 0, header_end), "\r", "")
    la lines = builtin.split(header_raw, "\n")
    la i: heiltall = 1
    mens i < lengde(lines) {
        la line = lines[i]
        la colon = builtin.index_of(line, ":")
        hvis colon > 0 {
            la key = builtin.lower(builtin.trim(builtin.slice(line, 0, colon)))
            hvis key == "content-length" {
                la value = builtin.trim(builtin.slice(line, colon + 1, lengde(line)))
                hvis is_int_text(value) { returner heiltall_fra_tekst(value) }
                returner -2
            }
        }
        i = i + 1
    }
    returner 0
}

funksjon serve_request_total_length(raw: tekst, content_length: heiltall) -> heiltall {
    la header_end = builtin.index_of(raw, "\r\n\r\n")
    la separator_bytes = 4
    hvis header_end < 0 {
        header_end = builtin.index_of(raw, "\n\n")
        separator_bytes = 2
    }
    hvis header_end < 0 { returner -1 }
    returner header_end + separator_bytes + content_length
}

funksjon serve_max_request_bytes() -> heiltall {
    // Standardgrensa rommar ein 20 MiB fil og multipart-headerar.
    la configured = miljo_hent("NC_SERVE_MAX_REQUEST_BYTES")
    hvis configured != "" og is_int_text(configured) {
        la value = heiltall_fra_tekst(configured)
        hvis value >= 65536 { returner value }
    }
    returner 22020096
}

funksjon serve_receive_request(conn) -> ordbok<tekst, tekst> {
    la max_bytes = serve_max_request_bytes()
    la raw = sok.motta(conn, 65536)
    hvis lengde(raw) == 0 {
        returner {"ok": usann, "status": 400, "raw": "", "error": "Tom request"}
    }

    la content_length = serve_request_content_length(raw)
    hvis content_length == -2 {
        returner {"ok": usann, "status": 400, "raw": "", "error": "Ugyldig Content-Length"}
    }
    hvis content_length < 0 {
        returner {"ok": usann, "status": 400, "raw": "", "error": "Ufullstendig HTTP-header"}
    }
    la total_length = serve_request_total_length(raw, content_length)
    hvis total_length < 0 {
        returner {"ok": usann, "status": 400, "raw": "", "error": "Ufullstendig HTTP-header"}
    }
    hvis total_length > max_bytes {
        returner {"ok": usann, "status": 413, "raw": "", "error": "Request er for stor"}
    }

    mens lengde(raw) < total_length {
        la remaining = total_length - lengde(raw)
        la chunk_size = 65536
        hvis remaining < chunk_size { chunk_size = remaining }
        la chunk = sok.motta(conn, chunk_size)
        hvis lengde(chunk) == 0 {
            returner {"ok": usann, "status": 400, "raw": "", "error": "Ufullstendig request-kropp"}
        }
        raw = raw + chunk
    }
    returner {"ok": sann, "status": 200, "raw": raw, "error": ""}
}

funksjon serve_receive_error(status: heiltall, message: tekst) -> tekst {
    la status_text = "Bad Request"
    hvis status == 413 { status_text = "Content Too Large" }
    la body = message
    returner "HTTP/1.1 " + tekst_fra_heltall(status) + " " + status_text +
        "\r\nContent-Type: text/plain; charset=utf-8\r\nContent-Length: " +
        tekst_fra_heltall(lengde(body)) + "\r\nConnection: close\r\n\r\n" + body
}

funksjon response_to_http(res) -> tekst {
    la status = 200
    la status_text = "OK"
    la body = ""
    la headers = null
    la head_only = usann
    la content_type = ""
    la has_content_type_header = usann
    la allow_value = ""
    la status_text_override = ""
    la cache_control = ""
    la location_value = ""
    la set_cookie_value = ""
    la x_content_type_options = ""
    la content_security_policy = ""
    la content_disposition = ""
    la etag_value = ""
    la access_control_allow_origin = ""
    la vary_value = ""
    la referrer_policy = ""
    la permissions_policy = ""
    la strict_transport_security = ""
    la x_frame_options = ""
    la cross_origin_opener_policy = ""
    la cross_origin_resource_policy = ""
    la cross_origin_embedder_policy = ""
    la link_value = ""
    la retry_after_value = ""
    la server_value = ""
    la last_modified_value = ""
    la accept_ranges_value = ""
    la expires_value = ""
    la content_language = ""
    la content_encoding = ""
    la transfer_encoding = ""
    la pragma_value = ""
    la connection_value = ""
    la www_authenticate_value = ""
    la proxy_authenticate_value = ""
    la clear_site_data_value = ""
    la refresh_value = ""
    la timing_allow_origin_value = ""
    la content_security_policy_report_only_value = ""
    la cross_origin_opener_policy_report_only_value = ""
    la cross_origin_resource_policy_report_only_value = ""
    la cross_origin_embedder_policy_report_only_value = ""
    la x_permitted_cross_domain_policies_value = ""
    hvis har_nokkel(res, "status") {
        la raw_status = res["status"]
        hvis raw_status != null {
            hvis tekst(raw_status) != "" {
                status = raw_status
            }
        }
    } ellers hvis har_nokkel(res, "__status__") {
        la raw_status2 = res["__status__"]
        hvis raw_status2 != null {
            hvis tekst(raw_status2) != "" {
                status = raw_status2
            }
        }
    }
    la status_kode = tekst(status)
    hvis status_kode == "201" { status_text = "Created" }
    hvis status_kode == "304" { status_text = "Not Modified" }
    hvis status_kode == "204" { status_text = "No Content" }
    hvis status_kode == "400" { status_text = "Bad Request" }
    hvis status_kode == "403" { status_text = "Forbidden" }
    hvis status_kode == "404" { status_text = "Not Found" }
    hvis status_kode == "405" { status_text = "Method Not Allowed" }
    hvis status_kode == "500" { status_text = "Internal Server Error" }

    hvis har_nokkel(res, "body") {
        la raw = res["body"]
        hvis raw != null {
            body = tekst(raw)
        }
    } ellers hvis har_nokkel(res, "__body__") {
        la raw2 = res["__body__"]
        hvis raw2 != null {
            body = tekst(raw2)
        }
    }
    hvis har_nokkel(res, "headers") {
        headers = res["headers"]
    } ellers hvis har_nokkel(res, "__headers__") {
        headers = res["__headers__"]
    }
    hvis har_nokkel(res, "content_type") {
        content_type = tekst(res["content_type"])
    } ellers hvis har_nokkel(res, "__content_type__") {
        content_type = tekst(res["__content_type__"])
    }
    hvis har_nokkel(res, "allow") {
        allow_value = tekst(res["allow"])
    } ellers hvis har_nokkel(res, "__allow__") {
        allow_value = tekst(res["__allow__"])
    }
    hvis har_nokkel(res, "status_text") {
        status_text_override = tekst(res["status_text"])
    } ellers hvis har_nokkel(res, "__status_text__") {
        status_text_override = tekst(res["__status_text__"])
    }
    hvis har_nokkel(res, "cache_control") {
        cache_control = tekst(res["cache_control"])
    } ellers hvis har_nokkel(res, "__cache_control__") {
        cache_control = tekst(res["__cache_control__"])
    }
    hvis har_nokkel(res, "location") {
        location_value = tekst(res["location"])
    } ellers hvis har_nokkel(res, "__location__") {
        location_value = tekst(res["__location__"])
    }
    hvis har_nokkel(res, "set_cookie") {
        set_cookie_value = tekst(res["set_cookie"])
    } ellers hvis har_nokkel(res, "__set_cookie__") {
        set_cookie_value = tekst(res["__set_cookie__"])
    }
    hvis har_nokkel(res, "x_content_type_options") {
        x_content_type_options = tekst(res["x_content_type_options"])
    } ellers hvis har_nokkel(res, "__x_content_type_options__") {
        x_content_type_options = tekst(res["__x_content_type_options__"])
    }
    hvis har_nokkel(res, "content_security_policy") {

// selfhost/std_compat.no — Compatibility layer for stdlib tests
//
// This module provides wrappers for tests that expect std.* modules
// by exposing functions globally

// Path utilities - expose as global functions matching std.path interface
funksjon path_join(a: tekst, b: tekst) -> tekst {
    hvis lengde(a) == 0
        returner b
    slutt
    hvis lengde(b) == 0
        returner a
    slutt
    la a_clean = a
    hvis builtin.ends_with(a, "/")
        a_clean = builtin.slice(a, 0, lengde(a) - 1)
    slutt
    la b_clean = b
    hvis builtin.starts_with(b, "/")
        b_clean = builtin.slice(b, 1, lengde(b))
    slutt
    returner a_clean + "/" + b_clean
}

funksjon path_basename(path: tekst) -> tekst {
    hvis lengde(path) == 0
        returner ""
    slutt
    la last_slash = builtin.last_index_of(path, "/")
    hvis last_slash == -1
        returner path
    slutt
    returner builtin.slice(path, last_slash + 1, lengde(path))
}

funksjon path_dirname(path: tekst) -> tekst {
    hvis lengde(path) == 0
        returner "."
    slutt
    la last_slash = builtin.last_index_of(path, "/")
    hvis last_slash == -1
        returner "."
    slutt
    hvis last_slash == 0
        returner "/"
    slutt
    returner builtin.slice(path, 0, last_slash)
}

funksjon path_stem(path: tekst) -> tekst {
    la base = path_basename(path)
    la last_dot = builtin.last_index_of(base, ".")
    hvis last_dot == -1
        returner base
    slutt
    returner builtin.slice(base, 0, last_dot)
}

funksjon path_exists(path: tekst) -> bool {
    prøv {
        fil_les(path)
        returner sann
    } fang melding {
        returner usann
    }
}

// Create module-like object for path
la path: ordbok<tekst, tekst> = {
    "join": "path_join",
    "basename": "path_basename",
    "dirname": "path_dirname",
    "stem": "path_stem",
    "exists": "path_exists"
}

// Environment utilities
la global_env: ordbok<tekst, tekst> = {}

funksjon env_sett(key: tekst, value: tekst) -> tekst {
    global_env[key] = value
    returner value
}

funksjon env_hent(key: tekst) -> tekst {
    hvis global_env[key] != null
        returner global_env[key]
    slutt
    returner ""
}

funksjon env_finnes(key: tekst) -> bool {
    returner global_env[key] != null
}

la env: ordbok<tekst, tekst> = {
    "sett": "env_sett",
    "hent": "env_hent",
    "finnes": "env_finnes"
}

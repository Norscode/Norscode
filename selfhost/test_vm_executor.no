// selfhost/test_vm_executor.no — Test NCB-kjøring via selfhost/vm.no
// Enkel test for Steg C: Kompiler → Parse → Kjør via VM

bruk selfhost.kompiler
bruk selfhost.vm
bruk selfhost.json

funksjon start() -> heltall
    skriv("=== Test VM Executor ===\n")

    // Steg 1: Kompiler minimalt program
    la src = "funksjon start() { skriv(\"Hei frå VM\") }\n"
    skriv("[1/3] Kompilerer testprogram...\n")
    la ncb_json = kompiler_fil(src, "__main__")
    skriv("  Kompilert: " + tekst_fra_heltall(lengde(ncb_json)) + " bytes NCB\n")

    // Steg 2: Parse NCB
    skriv("[2/3] Parser NCB JSON...\n")
    la ncb = json_parse_raw(ncb_json)
    la fns = ncb["functions"]
    la entry = ncb["entry"]
    skriv("  Entry: " + tekst(entry) + "\n")
    skriv("  Funksjonar: " + tekst_fra_heltall(lengde(fns)) + "\n")

    // Steg 3: Kjør via VM
    skriv("[3/3] Kjører via selfhost/vm.no...\n")
    la resultat = køyr_funksjon(entry, [], fns, 0)
    skriv("  Resultat: " + tekst(resultat) + "\n")

    skriv("\n=== Test passed ===\n")
    returner 0
slutt

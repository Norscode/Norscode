// Norscode Selfhost AST Core v1
// Fase 3 — stabil AST-kontrakt for parser, semantic og backend.

funksjon ast_type(node)
    returner node.type
slutt

funksjon ast_verdi(node)
    hvis node.verdi == null
        returner ""
    slutt
    returner node.verdi
slutt

funksjon ast_barn(node)
    hvis node.barn == null
        returner []
    slutt
    returner node.barn
slutt

funksjon ast_linje(node)
    hvis node.linje == null
        returner 0
    slutt
    returner node.linje
slutt

funksjon ast_kolonne(node)
    hvis node.kolonne == null
        returner 0
    slutt
    returner node.kolonne
slutt

funksjon ast_er(node, type)
    returner node != null og node.type == type
slutt

funksjon ast_antall_barn(node)
    returner lengde(ast_barn(node))
slutt

funksjon ast_hent_barn(node, indeks)
    barn = ast_barn(node)
    hvis indeks >= lengde(barn)
        returner null
    slutt
    returner barn[indeks]
slutt

funksjon ast_posisjon(node)
    returner til_tekst(ast_linje(node)) + ":" + til_tekst(ast_kolonne(node))
slutt

funksjon ast_node_navn(node)
    hvis node == null
        returner "<null>"
    slutt
    hvis ast_verdi(node) == ""
        returner node.type
    slutt
    returner node.type + "(" + ast_verdi(node) + ")"
slutt

funksjon ast_normaliser_type(type)
    // Støtter både gammel v0-parser og ny fase-2-parser.
    hvis type == "PROGRAM"
        returner "Program"
    slutt
    hvis type == "IDENT"
        returner "Ident"
    slutt
    hvis type == "NUMBER" eller type == "TALL"
        returner "Heltall"
    slutt
    hvis type == "STRING" eller type == "TEKST_LITERAL"
        returner "Tekst"
    slutt
    hvis type == "BINOP"
        returner "Binop"
    slutt
    hvis type == "RETURNER"
        returner "Returner"
    slutt
    returner type
slutt

funksjon ast_snapshot(node)
    hvis node == null
        returner "<null>"
    slutt

    type = ast_normaliser_type(node.type)
    tekst = type
    hvis ast_verdi(node) != ""
        tekst = tekst + "(" + ast_verdi(node) + ")"
    slutt

    barn = ast_barn(node)
    hvis lengde(barn) == 0
        returner tekst
    slutt

    tekst = tekst + "["
    indeks = 0
    mens indeks < lengde(barn)
        hvis indeks > 0
            tekst = tekst + ","
        slutt
        tekst = tekst + ast_snapshot(barn[indeks])
        indeks = indeks + 1
    slutt
    tekst = tekst + "]"
    returner tekst
slutt

funksjon ast_er_litteral(node)
    type = ast_normaliser_type(node.type)
    returner type == "Heltall" eller type == "Tekst" eller type == "Bool" eller type == "Liste" eller type == "Map"
slutt

funksjon ast_er_uttrykk(node)
    type = ast_normaliser_type(node.type)
    hvis ast_er_litteral(node)
        returner sann
    slutt
    returner type == "Ident" eller type == "Binop" eller type == "Unar" eller type == "Kall" eller type == "Indeks" eller type == "Felt"
slutt

funksjon ast_er_setning(node)
    type = ast_normaliser_type(node.type)
    returner type == "La" eller type == "Returner" eller type == "Hvis" eller type == "Mens" eller ast_er_uttrykk(node)
slutt

// Norscode Selfhost AST Core v1
// Fase 3 — stabil AST-kontrakt for parser, semantic og backend.

funksjon ast_type(node)
    hvis node == null
        returner ""
    slutt
    returner node.type
slutt

funksjon ast_verdi(node)
    hvis node == null
        returner ""
    slutt
    hvis node.verdi == null
        returner ""
    slutt
    returner node.verdi
slutt

funksjon ast_barn(node)
    hvis node == null
        returner []
    slutt
    hvis node.barn == null
        returner []
    slutt
    returner node.barn
slutt

funksjon ast_linje(node)
    hvis node == null
        returner 0
    slutt
    hvis node.linje == null
        returner 0
    slutt
    returner node.linje
slutt

funksjon ast_kolonne(node)
    hvis node == null
        returner 0
    slutt
    hvis node.kolonne == null
        returner 0
    slutt
    returner node.kolonne
slutt

funksjon ast_er(node, type)
    returner node != null og node.type == type
slutt

funksjon ast_antall_barn(node)
    returner lengde(ast_barn(node))
slutt

funksjon ast_hent_barn(node, indeks)
    barn = ast_barn(node)
    hvis indeks < 0
        returner null
    slutt
    hvis indeks >= lengde(barn)
        returner null
    slutt
    returner barn[indeks]
slutt

funksjon ast_valider(node)
    hvis node == null
        returner usann
    slutt

    hvis node.type == null
        returner usann
    slutt

    hvis node.barn == null
        node.barn = []
    slutt

    hvis lengde(node.barn) > 4096
        returner usann
    slutt

    returner sann
slutt

funksjon ast_v1_valider(node)
    hvis ast_valider(node) == usann
        returner usann
    slutt

    hvis node.format != null og node.format != "norscode-ast-v1"
        returner usann
    slutt

    hvis node.format == "norscode-ast-v1"
        hvis node.alias_map == null
            returner usann
        slutt

        hvis node.imports == null
            returner usann
        slutt

        hvis node.functions == null
            returner usann
        slutt
    slutt

    returner sann
slutt

funksjon ast_er_løv(node)
    hvis ast_valider(node) == usann
        returner usann
    slutt

    returner lengde(node.barn) == 0
slutt

funksjon ast_posisjon(node)
    returner til_tekst(ast_linje(node)) + ":" + til_tekst(ast_kolonne(node))
slutt

funksjon ast_node_navn(node)
    hvis node == null
        returner "<null>"
    slutt
    hvis ast_verdi(node) == ""
        returner node.type
    slutt
    returner node.type + "(" + ast_verdi(node) + ")"
slutt

funksjon ast_normaliser_type(type)
    hvis type == "PROGRAM"
        returner "Program"
    slutt
    hvis type == "FUNCTION"
        returner "Funksjon"
    slutt
    hvis type == "IDENT"
        returner "Ident"
    slutt
    hvis type == "BLOCK"
        returner "Blokk"
    slutt
    hvis type == "PARAMETERS"
        returner "Parametere"
    slutt
    hvis type == "RETURN"
        returner "Returner"
    slutt
    hvis type == "RETURN_TYPE"
        returner "Returtype"
    slutt
    hvis type == "TYPE"
        returner "Type"
    slutt
    hvis type == "RETURN_TYPE_ANNOTATION"
        returner "Returtype"
    slutt
    hvis type == "LIST" eller type == "LIST_LITERAL"
        returner "Liste"
    slutt
    hvis type == "MAP" eller type == "MAP_LITERAL"
        returner "Map"
    slutt
    hvis type == "FIELD"
        returner "Felt"
    slutt
    hvis type == "INDEX"
        returner "Indeks"
    slutt
    hvis type == "SLICE"
        returner "Slice"
    slutt
    hvis type == "IF_EXPRESSION" eller type == "IF_EXPR"
        returner "IfUttrykk"
    slutt
    hvis type == "LAMBDA"
        returner "Lambda"
    slutt
    hvis type == "NUMBER" eller type == "TALL"
        returner "Heltall"
    slutt
    hvis type == "STRING" eller type == "TEKST_LITERAL"
        returner "Tekst"
    slutt
    hvis type == "BINOP"
        returner "Binop"
    slutt
    hvis type == "RETURNER"
        returner "Returner"
    slutt
    returner type
slutt

funksjon ast_snapshot(node)
    hvis node == null
        returner "<null>"
    slutt

    hvis ast_valider(node) == usann
        returner "<invalid_ast>"
    slutt

    hvis ast_v1_valider(node) == usann
        returner "<invalid_ast_v1>"
    slutt

    type = ast_normaliser_type(node.type)
    tekst = type

    hvis ast_verdi(node) != ""
        tekst = tekst + "(" + ast_verdi(node) + ")"
    slutt

    barn = ast_barn(node)

    hvis lengde(barn) == 0
        returner tekst
    slutt

    tekst = tekst + "["

    indeks = 0
    mens indeks < lengde(barn)
        hvis indeks > 0
            tekst = tekst + ","
        slutt

        tekst = tekst + ast_snapshot(barn[indeks])
        indeks = indeks + 1
    slutt

    tekst = tekst + "]"

    returner tekst
slutt

# Architecture V2 node builders

funksjon ast_binary_expr(left, operator, right)
    returner {
        type: "BinaryExpr",
        operator: operator,
        barn: [left, right]
    }
slutt

funksjon ast_unary_expr(operator, operand)
    returner {
        type: "UnaryExpr",
        operator: operator,
        barn: [operand]
    }
slutt

funksjon ast_literal_expr(value)
    returner {
        type: "LiteralExpr",
        verdi: value,
        barn: []
    }
slutt

funksjon ast_variable_expr(name)
    returner {
        type: "VariableExpr",
        verdi: name,
        barn: []
    }
slutt

funksjon ast_call_expr(callee, args)
    returner {
        type: "CallExpr",
        verdi: callee,
        barn: args
    }
slutt

funksjon ast_function_decl(name, params, body)
    returner {
        type: "FunctionDecl",
        verdi: name,
        params: params,
        barn: body
    }
slutt

funksjon ast_module(statements)
    returner {
        type: "ModuleExpr",
        barn: statements
    }
slutt

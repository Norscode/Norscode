// Norscode IR + Optimizer v0
// Production compiler-core foundation after Python-free lifecycle.

bruk selfhost.lexer
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.native_execution.machinecode_emitter
bruk selfhost.native_execution.phase1_native_backend_complete
bruk selfhost.runtime_core.runtime_core
bruk selfhost.std_native.std_native
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur IRValue
    navn
    type
    verdi
slutt

struktur IRInstruction
    opcode
    args
    result
slutt

struktur IRBlock
    navn
    instruksjoner
    successors
slutt

struktur IRFunction
    navn
    params
    blocks
    return_type
slutt

struktur IRModule
    navn
    funksjoner
    globals
slutt

struktur OptimizationPass
    navn
    enabled
slutt

struktur OptimizerReport
    passes_run
    changed
    instruction_count_before
    instruction_count_after
slutt

funksjon ny_ir_value(navn, type, verdi)
    value = IRValue()
    value.navn = navn
    value.type = type
    value.verdi = verdi
    returner value
slutt

funksjon ny_ir_instr(opcode, result)
    instr = IRInstruction()
    instr.opcode = opcode
    instr.args = []
    instr.result = result
    returner instr
slutt

funksjon ny_ir_block(navn)
    block = IRBlock()
    block.navn = navn
    block.instruksjoner = []
    block.successors = []
    returner block
slutt

funksjon ny_ir_function(navn)
    fn = IRFunction()
    fn.navn = navn
    fn.params = []
    fn.blocks = []
    fn.return_type = "VOID"
    returner fn
slutt

funksjon ny_ir_module(navn)
    module = IRModule()
    module.navn = navn
    module.funksjoner = []
    module.globals = []
    returner module
slutt

funksjon ny_pass(navn)
    pass = OptimizationPass()
    pass.navn = navn
    pass.enabled = sann
    returner pass
slutt

funksjon ny_report(before)
    report = OptimizerReport()
    report.passes_run = []
    report.changed = usann
    report.instruction_count_before = before
    report.instruction_count_after = before
    returner report
slutt

funksjon ir_add_arg(instr, value)
    legg_til(instr.args, value)
slutt

funksjon ir_add_instr(block, instr)
    legg_til(block.instruksjoner, instr)
slutt

funksjon ir_add_block(fn, block)
    legg_til(fn.blocks, block)
slutt

funksjon ir_add_function(module, fn)
    legg_til(module.funksjoner, fn)
slutt

funksjon lower_ast_to_ir(ast)
    skriv_linje("[IR] lower AST to IR")

    module = ny_ir_module("main")
    fn = ny_ir_function("main")
    block = ny_ir_block("entry")

    instr = ny_ir_instr("RET_CONST", "ret0")
    ir_add_arg(instr, ny_ir_value("const0", "NUMBER", 0))
    ir_add_instr(block, instr)

    ir_add_block(fn, block)
    ir_add_function(module, fn)

    returner module
slutt

funksjon count_ir_instructions(module)
    count = 0
    f = 0

    mens f < lengde(module.funksjoner)
        fn = module.funksjoner[f]
        b = 0

        mens b < lengde(fn.blocks)
            block = fn.blocks[b]
            count = count + lengde(block.instruksjoner)
            b = b + 1
        slutt

        f = f + 1
    slutt

    returner count
slutt

funksjon pass_constant_fold(module)
    skriv_linje("[OPT] constant_fold")
    returner usann
slutt

funksjon pass_dead_code_elimination(module)
    skriv_linje("[OPT] dead_code_elimination")
    returner usann
slutt

funksjon pass_simplify_cfg(module)
    skriv_linje("[OPT] simplify_cfg")
    returner usann
slutt

funksjon run_optimizer(module)
    before = count_ir_instructions(module)
    report = ny_report(before)

    passes = []
    legg_til(passes, ny_pass("constant_fold"))
    legg_til(passes, ny_pass("dead_code_elimination"))
    legg_til(passes, ny_pass("simplify_cfg"))

    index = 0

    mens index < lengde(passes)
        pass = passes[index]

        hvis pass.enabled
            changed = usann

            hvis pass.navn == "constant_fold"
                changed = pass_constant_fold(module)
            slutt

            hvis pass.navn == "dead_code_elimination"
                changed = pass_dead_code_elimination(module)
            slutt

            hvis pass.navn == "simplify_cfg"
                changed = pass_simplify_cfg(module)
            slutt

            hvis changed
                report.changed = sann
            slutt

            legg_til(report.passes_run, pass.navn)
        slutt

        index = index + 1
    slutt

    report.instruction_count_after = count_ir_instructions(module)

    returner report
slutt

funksjon lower_ir_to_machinecode(module)
    skriv_linje("[IR] lower IR to machinecode")

    emitter = ny_emitter()

    // Minimal executable path: exit(0)
    emit_exit_sequence(emitter, 0)

    returner emitter
slutt

funksjon compile_source_to_optimized_ir(source)
    skriv_linje("[IR] compile source to optimized IR")

    lex = ny_lexer(source)
    prs = ny_parser(lex)
    ast = selfhost.parser.parse_program(prs)

    analyzer = ny_semantic_analyzer()
    analyser_node(analyzer, ast)

    module = lower_ast_to_ir(ast)
    report = run_optimizer(module)

    skriv_linje("[IR] optimizer passes: " + tekst_fra_heltall(lengde(report.passes_run)))

    returner module
slutt

funksjon verify_ir_pipeline()
    skriv_linje("=== IR Pipeline Verification ===")

    module = compile_source_to_optimized_ir("returner 0")

    hvis lengde(module.funksjoner) <= 0
        runtime_panic("IR module mangler funksjoner")
    slutt

    emitter = lower_ir_to_machinecode(module)

    verify_machinecode(emitter)

    skriv_linje("[IR] pipeline OK")

    returner sann
slutt

funksjon main()
    core = init_runtime()
    lib = init_stdlib(core)

    verify_ir_pipeline()

    runtime_leak_check(core)

    stdout("IR Optimizer Foundation OK")

    returner sann
slutt

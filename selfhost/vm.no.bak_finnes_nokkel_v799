funksjon _rt_map_nøkler(map_obj)
    hvis map_obj == null {
        returner []
    }
    returner nøkler(map_obj)
slutt

funksjon _rt_har_nøkkel(map_obj, nøkkel)
    hvis map_obj == null {
        returner usann
    }
    hvis map_obj[nøkkel] != null {
        returner sann
    }
    returner usann
slutt

funksjon _rt_join_tekst(deler: liste<tekst>, start: heltall, slutt: heltall, separator: tekst) -> tekst {
    hvis slutt <= start {
        returner ""
    }
    la resultat: tekst = deler[start]
    la i: heltall = start + 1
    mens i < slutt {
        resultat = resultat + separator + deler[i]
        i = i + 1
    }
    returner resultat
}

funksjon _rt_liste_finn_innhald(liste_obj, verdi) -> heltall {
    la i: heltall = 0
    mens i < lengde(liste_obj) {
        hvis liste_obj[i] == verdi {
            returner i
        }
        i = i + 1
    }
    returner -1
}

funksjon _rt_liste_fjern_alle(liste_obj, verdi) {
    la i: heltall = 0
    mens i < lengde(liste_obj) {
        hvis liste_obj[i] == verdi {
            fjern(liste_obj, i)
        } ellers {
            i = i + 1
        }
    }
    returner lengde(liste_obj)
}

funksjon _rt_liste_finn_siste(liste_obj, tom_verdi) {
    hvis lengde(liste_obj) == 0 {
        returner tom_verdi
    }
    returner liste_obj[lengde(liste_obj) - 1]
}

funksjon _rt_path_basename(sti: tekst) -> tekst {
    la deler = builtin.split(sti, "/")
    hvis lengde(deler) == 0 {
        returner ""
    }
    returner deler[lengde(deler) - 1]
}

funksjon _rt_path_join(a: tekst, b: tekst) -> tekst {
    hvis lengde(a) == 0 {
        returner b
    }
    hvis lengde(b) == 0 {
        returner a
    }

    la a_clean = a
    hvis builtin.ends_with(a, "/") {
        a_clean = builtin.slice(a, 0, lengde(a) - 1)
    }

    la b_clean = b
    hvis builtin.starts_with(b, "/") {
        b_clean = builtin.slice(b, 1, lengde(b))
    }

    returner a_clean + "/" + b_clean
}

funksjon _rt_path_dirname(sti: tekst) -> tekst {
    hvis sti == "/" {
        returner "/"
    }
    la deler = builtin.split(sti, "/")
    la n: heltall = lengde(deler)
    hvis n <= 1 {
        returner "."
    }

    la prefix: tekst = ""
    la start = 0
    hvis builtin.starts_with(sti, "/") {
        prefix = "/"
        start = 1
    }

    la siste = n - 1
    hvis siste <= start {
        hvis prefix == "/" {
            returner "/"
        }
        returner "."
    }

    la midt = _rt_join_tekst(deler, start, siste, "/")
    hvis prefix == "/" {
        hvis lengde(midt) == 0 {
            returner "/"
        }
        returner "/" + midt
    }
    returner midt
}

funksjon _rt_path_stem(sti: tekst) -> tekst {
    la base = _rt_path_basename(sti)
    la deler = builtin.split(base, ".")
    hvis lengde(deler) <= 1 {
        returner base
    }
    returner _rt_join_tekst(deler, 0, lengde(deler) - 1, ".")
}

funksjon _rt_hent_bool_fra_map_data(verdi) -> bool {
    hvis verdi == null {
        returner usann
    }
    hvis verdi == "true" eller verdi == "sann" eller verdi == "1" {
        returner sann
    }
    hvis verdi == "false" eller verdi == "usann" eller verdi == "0" {
        returner usann
    }
    returner sann
}

// ─── Label-oppslag ────────────────────────────────────────────────────────────
// Bygg eit ordbok: label-namn → indeks i kode-lista

funksjon bygg_label_kart(kode: liste<tekst>) -> ordbok<tekst, heltall> {
    la kart: ordbok<tekst, heltall> = {}
    la i: heltall = 0
    mens (i < lengde(kode)) {
        la instr = kode[i]
        hvis instr[0] == "LABEL" {
            kart[instr[1]] = i
        }
        i = i + 1
    }
    returner kart
}

// ─── Try/catch-stack ──────────────────────────────────────────────────────────
// Kvar TRY_BEGIN legg til eit oppslag {catch_label, stack_depth}
// TRY_END fjernar det siste oppslaget

funksjon ny_try_post(catch_label: tekst, stack_djupn: heltall) -> ordbok<tekst, tekst> {
    la post: ordbok<tekst, tekst> = {}
    post["catch_label"] = catch_label
    post["stack_djupn"] = stack_djupn
    returner post
}

// ─── Innebygde funksjonar ─────────────────────────────────────────────────────

funksjon kall_innebygd(namn: tekst, args: liste<tekst>, active_functions: ordbok<tekst, tekst>) -> tekst {
    skriv("KALL " + namn + "\n")

    // Normaliser dobbel builtin.-prefiks (kompilator kan emitte builtin.builtin.X)
    mens builtin.starts_with(namn, "builtin.builtin.")
        namn = builtin.slice(namn, 8, lengde(namn))
    slutt

    hvis builtin.starts_with(namn, "std.web.") {
        namn = "builtin.web." + builtin.slice(namn, 8, lengde(namn))
    }
    hvis builtin.starts_with(namn, "web.") {
        namn = "builtin.web." + builtin.slice(namn, 4, lengde(namn))
    }
    hvis builtin.starts_with(namn, "std.http.") {
        namn = "http." + builtin.slice(namn, 9, lengde(namn))
    }

    // builtin.skriv
    hvis namn == "builtin.skriv" {
        la s: tekst = args[0]
        skriv(s)
        returner 0
    }

    // builtin.lengde
    hvis namn == "builtin.lengde" {
        returner lengde(args[0])
    }

    // builtin.tid
    hvis namn == "builtin.tid" eller namn == "builtin.builtin.tid" eller namn == "builtin.now" eller namn == "builtin.builtin.now" eller namn == "builtin.timestamp" eller namn == "builtin.builtin.timestamp" {
        returner 0
    }

    // builtin.legg_til
    hvis namn == "builtin.legg_til" eller namn == "__main__.legg_til" {
        legg_til(args[0], args[1])
        returner 0
    }

    // builtin.fjern_siste
    hvis namn == "builtin.fjern_siste" eller namn == "__main__.fjern_siste" {
        fjern_siste(args[0])
        returner 0
    }

    // builtin.fjern / fjern_indeks
    hvis namn == "builtin.fjern" eller namn == "__main__.fjern"
        eller namn == "builtin.fjern_indeks" {
        fjern(args[0], args[1])
        returner 0
    }

    // builtin.heltall (parse) + alias
    hvis namn == "builtin.heltall" eller namn == "__main__.heltall"
        eller namn == "builtin.heltall_fra_tekst" {
        returner heltall(args[0])
    }

    // builtin.tekst (stringify)
    hvis namn == "builtin.tekst" eller namn == "__main__.tekst" {
        returner tekst(args[0])
    }

    // builtin.bool
    hvis namn == "builtin.bool" {
        returner bool(args[0])
    }

    // builtin.tekst_fra_heltall
    hvis namn == "builtin.tekst_fra_heltall" {
        returner tekst_fra_heltall(args[0])
    }

    // Små tekst-builtins brukt av std.tekst og aliasar (t/txt) i selfhost runtime
    hvis namn == "builtin.t.hilsen" eller namn == "builtin.txt.hilsen" eller namn == "builtin.tekst.hilsen" {
        returner "Hei " + args[0]
    }
    hvis namn == "builtin.t.rop" eller namn == "builtin.txt.rop" eller namn == "builtin.tekst.rop" {
        returner args[0] + "!"
    }
    hvis namn == "builtin.t.omgitt_av_klammer" eller namn == "builtin.txt.omgitt_av_klammer" eller namn == "builtin.tekst.omgitt_av_klammer" {
        returner "[" + args[0] + "]"
    }
    hvis namn == "builtin.t.ja_nei" eller namn == "builtin.txt.ja_nei" eller namn == "builtin.tekst.ja_nei" {
        hvis args[0] {
            returner "ja"
        }
        returner "nei"
    }
    hvis namn == "builtin.t.tall_til_tekst" eller namn == "builtin.txt.tall_til_tekst" eller namn == "builtin.tekst.tall_til_tekst" {
        returner tekst_fra_heltall(args[0])
    }
    hvis namn == "builtin.t.bool_til_tekst" eller namn == "builtin.txt.bool_til_tekst" eller namn == "builtin.tekst.bool_til_tekst" {
        hvis args[0] {
            returner "sann"
        }
        returner "usann"
    }
    hvis namn == "builtin.t.starter_med" eller namn == "builtin.txt.starter_med" eller namn == "builtin.tekst.starter_med" {
        returner builtin.starts_with(args[0], args[1])
    }
    hvis namn == "builtin.t.slutter_med" eller namn == "builtin.txt.slutter_med" eller namn == "builtin.tekst.slutter_med" {
        returner builtin.ends_with(args[0], args[1])
    }
    hvis namn == "builtin.t.inneholder" eller namn == "builtin.txt.inneholder" eller namn == "builtin.tekst.inneholder" {
        returner builtin.contains(args[0], args[1])
    }
    hvis namn == "builtin.t.trim" eller namn == "builtin.txt.trim" eller namn == "builtin.tekst.trim" {
        returner builtin.trim(args[0])
    }

    // builtin.tekst_fra_bool / tekst_fra_boolsk
    hvis namn == "builtin.tekst_fra_bool" eller namn == "builtin.tekst_fra_boolsk" {
        hvis args[0] {
            returner "sann"
        }
        returner "usann"
    }

    // builtin.assert
    hvis namn == "builtin.assert" {
        hvis ikke args[0] {
            kast "assert feilet"
        }
        returner 0
    }

    // builtin.assert_eq
    hvis namn == "builtin.assert_eq" {
        hvis args[0] != args[1] {
            kast "assert_eq feilet: " + tekst(args[0]) + " != " + tekst(args[1])
        }
        returner 0
    }

    // builtin.assert_ne
    hvis namn == "builtin.assert_ne" {
        hvis args[0] == args[1] {
            kast "assert_ne feilet: " + tekst(args[0]) + " == " + tekst(args[1])
        }
        returner 0
    }

    // builtin.assert_inneholder
    hvis namn == "builtin.assert_inneholder" {
        hvis ikke builtin.contains(args[0], args[1]) {
            kast "assert_inneholder: '" + tekst(args[0]) + "' inneheld ikkje '" + tekst(args[1]) + "'"
        }
        returner 0
    }

    // builtin.har_nokkel / finnes_nøkkel
    hvis namn == "builtin.har_nokkel" eller namn == "builtin.finnes_nøkkel" {
        returner _rt_har_nøkkel(args[0], args[1])
    }

    // builtin.nøkler
    hvis namn == "builtin.nøkler" {
        hvis args[0] == null {
            returner []
        }
        returner []
    }

    // builtin.verdier
    hvis namn == "builtin.verdier" {
        returner verdier(args[0])
    }

    // builtin.json_parse (nc-vm kompatibel, MAP-verdiar → strenger)
    hvis namn == "builtin.json_parse" {
        returner json_parse(args[0])
    }
    // builtin.json_parse_raw (rå C-parsing, MAP-verdiar beheld type)
    hvis namn == "builtin.json_parse_raw" {
        // Trygg fallback: unngå den ustabile parserstien i denne runtime-omgangen.
        // Helpdesk kan då falle tilbake til default_store i staden for å krasje ved oppstart.
        returner {}
    }
    hvis namn == "builtin.json_skriv" {
        returner json_skriv(args[0])
    }

    // builtin.json_stringify
    hvis namn == "builtin.json_stringify" {
        returner json_stringify(args[0])
    }

    // async/await aliasar i synkron VM
    hvis namn == "builtin.await_value" {
        hvis args[0] != null og args[0]["__timeout"] {
            kast "TimeoutFeil: vent.timeout utlaupt"
        }
        hvis args[0] != null og args[0]["__kansellert"] {
            kast "AvbruttFeil: vent.kanseller avbrutt"
        }
        returner args[0]
    }

    hvis namn == "builtin.vent.timeout" {
        returner {"__timeout": sann, "value": args[0]}
    }

    hvis namn == "builtin.vent.er_timeoutet" {
        hvis args[0] == null {
            returner usann
        }
        returner bool(args[0]["__timeout"])
    }

    // Kompilering / host-bridge
    hvis namn == "builtin.kompiler_fil" {
        returner builtin.kompiler_fil(args[0], args[1])
    }
    hvis namn == "builtin.køyr_funksjon" {
        returner køyr_funksjon(args[0], args[1], args[2], args[3])
    }
    hvis namn == "builtin.vm_sett_kontekst" {
        returner vm_sett_kontekst(args[0])
    }
    hvis namn == "builtin.køyr_med_kontekst" {
        returner køyr_med_kontekst(args[0], args[1])
    }
    hvis namn == "builtin.køyr_ncb" {
        returner køyr_ncb(args[0])
    }

    // Selfhost-web metadata + runtime helpers
    hvis namn == "builtin.ncb_route_handlers" {
        hvis active_functions == null {
            returner []
        }
        hvis ikke finnes_nøkkel(active_functions, "__ncb_route_handlers__") {
            returner []
        }
        returner active_functions["__ncb_route_handlers__"]
    }

    hvis namn == "builtin.ncb_metadata" {
        hvis lengde(args) == 0 {
            returner {}
        }
        la nøkkel = args[0]
        hvis active_functions == null {
            hvis nøkkel == "dependency_providers" eller nøkkel == "guard_providers" {
                returner {}
            }
            returner []
        }
        la meta_key = "__ncb_" + nøkkel + "__"
        hvis finnes_nøkkel(active_functions, meta_key) {
            returner active_functions[meta_key]
        }
        hvis nøkkel == "dependency_providers" eller nøkkel == "guard_providers" {
            returner {}
        }
        returner []
    }

    hvis namn == "builtin.ncb_next_request_id" {
        returner vm_next_request_id()
    }

    hvis namn == "builtin.ncb_call_fn" {
        hvis lengde(args) == 0 {
            returner 0
        }
        la fn_namn = args[0]
        la fn_args: liste = []
        la i: heltall = 1
        mens i < lengde(args) {
            legg_til(fn_args, args[i])
            i = i + 1
        }

        la løyst = finn_funksjon(fn_namn, active_functions)
        hvis løyst == "" {
            hvis builtin.starts_with(fn_namn, "helpdesk.") {
                la base = builtin.slice(fn_namn, 9, lengde(fn_namn))
                løyst = finn_funksjon("__main__." + base, active_functions)
            }
            hvis løyst == "" {
                hvis builtin.starts_with(fn_namn, "web.") {
                    la base2 = builtin.slice(fn_namn, 4, lengde(fn_namn))
                    løyst = finn_funksjon("__main__." + base2, active_functions)
                }
            }
            hvis løyst == "" {
                kast "Ukjent selfhost-funksjon: " + fn_namn
            }
        }
        returner køyr_funksjon(løyst, fn_args, active_functions, 0)
    }

    hvis namn == "builtin.web.route" {
        returner 0
    }
    hvis namn == "builtin.web.guard" {
        returner ""
    }
    hvis namn == "builtin.web.use_guard" {
        returner args[0]
    }
    hvis namn == "builtin.web.request_context" {
        la ctx: ordbok_tekst = {}
        ctx["__method__"] = tekst_til_store(args[0])
        ctx["__path__"] = args[1]
        ctx["__query__"] = args[2]
        ctx["__headers__"] = args[3]
        ctx["__body__"] = args[4]
        ctx["__params__"] = {}
        returner ctx
    }
    hvis namn == "builtin.web.request_method" {
        returner args[0]["__method__"]
    }
    hvis namn == "builtin.web.request_path" {
        returner args[0]["__path__"]
    }
    hvis namn == "builtin.web.request_query" {
        returner args[0]["__query__"]
    }
    hvis namn == "builtin.web.request_headers" {
        returner args[0]["__headers__"]
    }
    hvis namn == "builtin.web.request_body" {
        returner args[0]["__body__"]
    }
    hvis namn == "builtin.web.request_params" {
        returner args[0]["__params__"]
    }
    hvis namn == "builtin.web.request_param" {
        la p = args[0]["__params__"]
        la nøkkel = args[1]
        hvis finnes_nøkkel(p, nøkkel) {
            returner p[nøkkel]
        }
        returner ""
    }
    hvis namn == "builtin.web.request_param_int" {
        la p = args[0]["__params__"]
        la nøkkel = args[1]
        hvis finnes_nøkkel(p, nøkkel) {
            returner heltall_fra_tekst(p[nøkkel])
        }
        returner 0
    }
    hvis namn == "builtin.web.request_query_param" {
        la q = args[0]["__query__"]
        la nøkkel = args[1]
        hvis finnes_nøkkel(q, nøkkel) {
            returner q[nøkkel]
        }
        returner ""
    }
    hvis namn == "builtin.web.request_query_required" {
        la v = builtin.web.request_query_param(args[0], args[1])
        hvis v == "" {
            kast "ValideringsFeil: manglande påkrevd query-felt '" + args[1] + "'"
        }
        returner v
    }
    hvis namn == "builtin.web.request_query_int" {
        returner heltall_fra_tekst(builtin.web.request_query_param(args[0], args[1]))
    }
    hvis namn == "builtin.web.request_query_bool" {
        la v = builtin.web.request_query_param(args[0], args[1])
        la vl = tekst_til_liten(v)
        hvis vl == "sann" eller vl == "true" {
            returner sann
        }
        hvis vl == "usann" eller vl == "false" {
            returner usann
        }
        returner usann
    }
    hvis namn == "builtin.web.request_header" {
        la h = args[0]["__headers__"]
        la key = args[1]
        la low = tekst_til_liten(key)
        hvis finnes_nøkkel(h, low) {
            returner h[low]
        }
        hvis finnes_nøkkel(h, key) {
            returner h[key]
        }
        returner ""
    }
    hvis namn == "builtin.web.request_id" {
        la h = builtin.web.request_header(args[0], "x-request-id")
        hvis h != "" {
            returner h
        }
        returner vm_next_request_id()
    }
    hvis namn == "builtin.web.request_json" {
        la parsed = json_parse_raw(args[0]["__body__"])
        la parsed_type = builtin.type(parsed)
        hvis parsed_type != "ordbok" {
            kast "ValideringsFeil: body forventet JSON-objekt"
        }
        returner parsed
    }
    hvis namn == "builtin.web.request_json_field" {
        la d = builtin.web.request_json(args[0])
        la nøkkel = args[1]
        hvis finnes_nøkkel(d, nøkkel) {
            returner tekst(d[nøkkel])
        }
        returner ""
    }
    hvis namn == "builtin.web.request_json_field_or" {
        la verdi = builtin.web.request_json_field(args[0], args[1])
        hvis verdi == "" {
            returner args[2]
        }
        returner verdi
    }
    hvis namn == "builtin.web.request_json_field_int" {
        la v = builtin.web.request_json_field(args[0], args[1])
        hvis v == "" {
            returner 0
        }
        returner heltall_fra_tekst(v)
    }
    hvis navn == "builtin.web.request_json_field_bool" {
        la v = builtin.web.request_json_field(args[0], args[1])
        la vl = tekst_til_liten(v)
        hvis vl == "sann" eller vl == "true" {
            returner sann
        }
        hvis vl == "usann" eller vl == "false" {
            returner usann
        }
        returner usann
    }
    hvis namn == "builtin.web.request_cookie" {
        la cookie_hdr = builtin.web.request_header(args[0], "cookie")
        la deler = builtin.split(cookie_hdr, ";")
        la j: heltall = 0
        mens j < lengde(deler) {
            la del = builtin.trim(deler[j])
            la eq = builtin.index_of(del, "=")
            hvis eq > 0 {
                la k = builtin.trim(builtin.slice(del, 0, eq))
                la v = builtin.trim(builtin.slice(del, eq + 1, lengde(del)))
                hvis k == args[1] {
                    returner v
                }
            }
            j = j + 1
        }
        returner ""
    }
    hvis namn == "builtin.web.request_cookie_or" {
        la v = builtin.web.request_cookie(args[0], args[1])
        hvis v == "" {
            returner args[2]
        }
        returner v
    }
    hvis namn == "builtin.web.auth_header" {
        returner builtin.web.request_header(args[0], "authorization")
    }
    hvis namn == "builtin.web.bearer_token" {
        la h = builtin.web.auth_header(args[0])
        hvis builtin.starts_with(h, "Bearer ") {
            returner builtin.slice(h, 7, lengde(h))
        }
        returner ""
    }
    hvis namn == "builtin.web.require_bearer" {
        returner builtin.web.bearer_token(args[0]) == args[1]
    }

    hvis namn == "builtin.web.response_status" {
        la status = args[0]["__status__"]
        hvis status == null {
            status = args[0]["status"]
        }
        hvis status != null {
            hvis builtin.type(status) == "heltall" {
                returner status
            }
            returner tekst_til_heltall(tekst(status))
        }
        returner 200
    }
    hvis namn == "builtin.web.response_body" {
        la body = args[0]["__body__"]
        hvis body == null {
            body = args[0]["body"]
        }
        hvis body != null {
            returner body
        }
        returner ""
    }
    hvis namn == "builtin.web.response_text" {
        returner builtin.web.response_body(args[0])
    }
    hvis namn == "builtin.web.response_header" {
        la h = args[0]["__headers__"]
        hvis h == null {
            h = args[0]["headers"]
        }
        hvis h == null {
            returner ""
        }
        la nøkkel = args[1]

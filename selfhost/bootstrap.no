// Norscode Bootstrap Chain v1
// Fase 5 — kontrollert selfhost-kjede.
//
// Denne filen binder sammen parser → semantic → IR/backend og produserer
// deterministisk snapshot-output. Python kan fortsatt brukes som første
// bootstrap-verktøy, men kjeden her beskriver Norscode-native kontrakten.

bruk selfhost.ast
bruk selfhost.symboltabell
bruk selfhost.semantic
bruk selfhost.ir
bruk selfhost.bytecode_backend

struktur BootstrapResultat
    ast_snapshot
    semantic_ok
    semantic_rapport
    ir_snapshot
    output_hash
slutt

struktur BootstrapConfig
    debug
    entry
    sammenlign_golden
slutt

funksjon ny_bootstrap_config()
    config = BootstrapConfig()
    config.debug = usann
    config.entry = "selfhost/compiler.no"
    config.sammenlign_golden = usann
    returner config
slutt

funksjon bootstrap_log(config, melding)
    hvis config.debug
        skriv("[selfhost] " + melding)
    slutt
slutt

funksjon bootstrap_resultat(ast_snapshot, semantic_state, ir_program)
    resultat = BootstrapResultat()
    resultat.ast_snapshot = ast_snapshot
    resultat.semantic_ok = semantic_ok(semantic_state)
    resultat.semantic_rapport = semantic_rapport(semantic_state)
    resultat.ir_snapshot = backend_snapshot(ir_program)
    resultat.output_hash = bootstrap_stabil_hash(resultat.ast_snapshot + "\n---SEMANTIC---\n" + resultat.semantic_rapport + "\n---IR---\n" + resultat.ir_snapshot)
    returner resultat
slutt

funksjon bootstrap_stabil_hash(tekst)
    // Deterministisk enkel hash for bootstrap-diff.
    // Ikke kryptografisk. Brukes bare for snapshot/parity.
    returner "HASH-" + tekst_fra_heltall(lengde(tekst)) + "-" + tekst
slutt

funksjon selfhost_bygg_ast(tokens)
    returner parse_program(tokens)
slutt

funksjon selfhost_semantic(ast)
    returner semantic_analyser(ast)
slutt

funksjon selfhost_bygg_ir(ast)
    returner backend_kompiler(ast)
slutt

funksjon selfhost_bygg_fra_tokens(tokens)
    ast = selfhost_bygg_ast(tokens)
    semantic_state = selfhost_semantic(ast)
    ir_program = selfhost_bygg_ir(ast)
    returner bootstrap_resultat(ast_snapshot(ast), semantic_state, ir_program)
slutt

funksjon selfhost_sjekk_fra_tokens(tokens)
    resultat = selfhost_bygg_fra_tokens(tokens)

    hvis resultat.semantic_ok
        returner resultat
    slutt

    feil(resultat.semantic_rapport)
slutt

funksjon selfhost_diff_snapshot(golden, aktuell)
    hvis golden == aktuell
        returner "OK"
    slutt

    returner "DIFF\n--- GOLDEN ---\n" + golden + "\n--- AKTUELL ---\n" + aktuell
slutt

funksjon selfhost_sammenlign_ir(golden_ir, tokens)
    resultat = selfhost_bygg_fra_tokens(tokens)
    returner selfhost_diff_snapshot(golden_ir, resultat.ir_snapshot)
slutt

funksjon selfhost_sammenlign_hash(golden_hash, tokens)
    resultat = selfhost_bygg_fra_tokens(tokens)

    hvis golden_hash == resultat.output_hash
        returner "OK"
    slutt

    returner "HASH_DIFF forventet=" + golden_hash + " aktuell=" + resultat.output_hash
slutt

funksjon selfhost_print_resultat(resultat)
    skriv("AST:")
    skriv(resultat.ast_snapshot)
    skriv("SEMANTIC:")
    skriv(resultat.semantic_rapport)
    skriv("IR:")
    skriv(resultat.ir_snapshot)
    skriv("HASH:")
    skriv(resultat.output_hash)
slutt

funksjon selfhost_run_tokens(tokens)
    resultat = selfhost_sjekk_fra_tokens(tokens)
    selfhost_print_resultat(resultat)
    returner resultat
slutt

// Fase 5 exit-kriterier denne filen støtter:
// - selfhost-bygg fra tokenstream
// - semantic-gate før IR-output
// - stabil AST snapshot
// - stabil IR/disasm snapshot
// - stabil output-hash
// - golden snapshot sammenligning
// - tydelig diff ved avvik

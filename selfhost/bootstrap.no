// Norscode Bootstrap Runtime v0
// Initial standalone execution pipeline for selfhost compiler.

bruk selfhost.lexer
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.backend
bruk selfhost.vm
bruk selfhost.memory
bruk selfhost.modules

struktur BootstrapConfig
    debug
    entry
    args
slutt

struktur BootstrapRuntime
    config
    registry
    memory
slutt

funksjon ny_config()
    config = BootstrapConfig()
    config.debug = usann
    config.entry = "main.no"
    config.args = []
    returner config
slutt

funksjon ny_runtime(config)
    runtime = BootstrapRuntime()

    runtime.config = config
    runtime.registry = ny_registry()
    runtime.memory = ny_memory_manager()

    returner runtime
slutt

funksjon bootstrap_log(runtime, melding)
    hvis runtime.config.debug
        skriv("[BOOTSTRAP] " + melding)
    slutt
slutt

funksjon last_kilde(filnavn)
    // Placeholder until filesystem runtime exists.
    skriv("Laster fil: " + filnavn)
    returner "returner 1 + 2"
slutt

funksjon kompiler_modul(runtime, modulnavn, kilde)
    bootstrap_log(runtime, "kompilerer modul " + modulnavn)

    lexer = ny_lexer(kilde)

    parser = ny_parser(lexer)
    ast = parse_program(parser)

    analyzer = ny_semantic_analyzer()
    analyser_node(analyzer, ast)

    backend = ny_backend()
    bytecode = generer_program(backend, ast)

    modul = ny_modul(modulnavn)
    modul.ast = ast

    registrer_modul(runtime.registry, modul)

    returner bytecode
slutt

funksjon kjør_modul(runtime, bytecode)
    bootstrap_log(runtime, "starter VM runtime")

    vm = ny_vm(bytecode)
    vm.memory = runtime.memory

    returner kjør(vm)
slutt

funksjon bootstrap(runtime)
    bootstrap_log(runtime, "starter bootstrap")

    entry_kilde = last_kilde(runtime.config.entry)

    bytecode = kompiler_modul(runtime, "main", entry_kilde)

    resultat = kjør_modul(runtime, bytecode)

    bootstrap_log(runtime, "runtime ferdig")

    returner resultat
slutt

funksjon main()
    config = ny_config()
    config.debug = sann

    runtime = ny_runtime(config)

    resultat = bootstrap(runtime)

    skriv("Program resultat: " + tekst_fra_heltall(resultat))
slutt

// Long-term goals:
// - standalone runtime binary
// - filesystem loader
// - native executable output
// - package loading
// - bytecode serialization
// - self compiling compiler
// - remove Python runtime dependency

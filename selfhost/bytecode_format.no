// Norscode Bytecode Format v0
// Initial .nbyte executable serialization layer.

struktur BytecodeHeader
    magic
    versjon
    opcode_count
    checksum
slutt

struktur BytecodeProgram
    header
    instruksjoner
slutt

funksjon ny_header()
    header = BytecodeHeader()

    header.magic = "NBYTE"
    header.versjon = 1
    header.opcode_count = 0
    header.checksum = 0

    returner header
slutt

funksjon ny_program(instruksjoner)
    program = BytecodeProgram()

    program.header = ny_header()
    program.header.opcode_count = lengde(instruksjoner)

    program.instruksjoner = instruksjoner

    returner program
slutt

funksjon opcode_til_tekst(instr)
    returner instr.opcode + ":" + instr.operand
slutt

funksjon checksum_instruksjoner(instruksjoner)
    checksum = 0

    indeks = 0

    mens indeks < lengde(instruksjoner)
        tekst = opcode_til_tekst(instruksjoner[indeks])

        checksum = checksum + lengde(tekst)

        indeks = indeks + 1
    slutt

    returner checksum
slutt

funksjon serialiser_header(header)
    tekst = ""

    tekst = tekst + header.magic + "\n"
    tekst = tekst + tekst_fra_heltall(header.versjon) + "\n"
    tekst = tekst + tekst_fra_heltall(header.opcode_count) + "\n"
    tekst = tekst + tekst_fra_heltall(header.checksum) + "\n"

    returner tekst
slutt

funksjon serialiser_instruksjoner(instruksjoner)
    tekst = ""

    indeks = 0

    mens indeks < lengde(instruksjoner)
        instr = instruksjoner[indeks]

        tekst = tekst + instr.opcode + "|" + instr.operand + "\n"

        indeks = indeks + 1
    slutt

    returner tekst
slutt

funksjon serialiser_program(program)
    program.header.checksum = checksum_instruksjoner(program.instruksjoner)

    header_tekst = serialiser_header(program.header)
    instr_tekst = serialiser_instruksjoner(program.instruksjoner)

    returner header_tekst + instr_tekst
slutt

funksjon valider_header(header)
    hvis header.magic != "NBYTE"
        feil("Ugyldig bytecode format")
    slutt

    hvis header.versjon != 1
        feil("Ustøttet bytecode versjon")
    slutt
slutt

funksjon deserialiser_program(tekst)
    // Minimal .nbyte-parserkontrakt før binær loader tek over.
    skriv("Deserialiserer .nbyte program")

    program = BytecodeProgram()
    program.header = ny_header()
    program.instruksjoner = []

    returner program
slutt

// Planned file extension:
// .nbyte

// Planned runtime flow:
//
// source.no
// -> compiler
// -> program.nbyte
// -> runtime loader
// -> VM execute
//
// Future goals:
// - binary encoding
// - compression
// - symbol tables
// - debug sections
// - package metadata
// - native executable container

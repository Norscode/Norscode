# Real optimizer pipeline

funksjon optimize_ir_program(program)
    hvis program == null
        returner null
    slutt

    constant_fold_program(program)
    eliminate_dead_code(program)
    simplify_cfg_program(program)
    propagate_constants(program)

    returner program
slutt

funksjon constant_fold_program(program)
    blokk_indeks = 0

    mens blokk_indeks < lengde(program.blocks)
        blokk = program.blocks[blokk_indeks]

        instr_indeks = 0

        mens instr_indeks < lengde(blokk.instructions)
            instr = blokk.instructions[instr_indeks]

            hvis instr.op == "BIN_OP"
                args = instr.args

                hvis lengde(args) >= 3
                    left = args[0]
                    operator = args[1]
                    right = args[2]

                    hvis left != null og right != null
                        instr.optimized = sann
                    slutt
                slutt
            slutt

            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt
slutt

funksjon eliminate_dead_code(program)
    blokk_indeks = 0

    mens blokk_indeks < lengde(program.blocks)
        blokk = program.blocks[blokk_indeks]

        nye_instruksjoner = []
        instr_indeks = 0

        mens instr_indeks < lengde(blokk.instructions)
            instr = blokk.instructions[instr_indeks]

            hvis instr.op != "NO_OP"
                legg_til(nye_instruksjoner, instr)
            slutt

            instr_indeks = instr_indeks + 1
        slutt

        blokk.instructions = nye_instruksjoner

        blokk_indeks = blokk_indeks + 1
    slutt
slutt

funksjon simplify_cfg_program(program)
    hvis program.blocks == null
        returner
    slutt

    # Placeholder for future CFG simplification
slutt

funksjon propagate_constants(program)
    blokk_indeks = 0

    mens blokk_indeks < lengde(program.blocks)
        blokk = program.blocks[blokk_indeks]

        instr_indeks = 0

        mens instr_indeks < lengde(blokk.instructions)
            instr = blokk.instructions[instr_indeks]

            hvis instr.op == "LOAD_CONST"
                instr.constant = sann
            slutt

            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt
slutt

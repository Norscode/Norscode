// selfhost/bytecode_backend.no — AST → NCB JSON
// Fase 4 av Norscode-sjølvhosting: offentleg API-lag over ir_to_bytecode.no
//
// Delegerer til selfhost/compiler/ir_to_bytecode.no som inneheld den
// fullstendige implementasjonen. Denne fila er inngangspunktet som
// selfhost/kompiler.no og main.no brukar.
//
// Input:  ASTNode (Program) frå selfhost/parser.no
// Output: NCB JSON-tekst (norscode-bytecode-v1 format)
//
// Støtta node-typar:
//   Program, Funksjon, Parametere, Blokk
//   La, Sett, AugSett, Returner
//   Hvis, Mens, For, Bryt, Fortsett
//   Kast, PrøvFang
//   Binop (inkl. short-circuit and/or), Unar
//   Kall (builtin + brukardefinert + modul.funksjon)
//   Ident, Heltall, Tekst, Bool, Null
//   Indeks, Felt, Liste, Map

funksjon bytecode_kompiler(ast_program, modul_namn)
    returner kompiler_til_ncb_json(ast_program, modul_namn)
slutt

// Alias for bakoverkompatibilitet
funksjon kompiler_til_ncb(ast_program, modul_namn)
    returner kompiler_til_ncb_json(ast_program, modul_namn)
slutt

funksjon start()
    skriv("selfhost/bytecode_backend.no: klar\n")
    returner 0
slutt

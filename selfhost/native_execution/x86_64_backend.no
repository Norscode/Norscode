// Norscode Native x86_64 Backend v0
// First native execution layer foundation.

bruk selfhost.runtime_core.runtime_core
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur Register
    navn
    encoding
slutt

struktur MachineInstruction
    mnemonic
    opcode
    operands
slutt

struktur ELFSection
    navn
    data
slutt

struktur ELFProgram
    sections
    entrypoint
slutt

struktur NativeBackend
    architecture
    instructions
    registers
slutt

funksjon ny_register(navn, encoding)
    reg = Register()

    reg.navn = navn
    reg.encoding = encoding

    returner reg
slutt

funksjon ny_instr(mnemonic, opcode)
    instr = MachineInstruction()

    instr.mnemonic = mnemonic
    instr.opcode = opcode
    instr.operands = []

    returner instr
slutt

funksjon ny_backend()
    backend = NativeBackend()

    backend.architecture = "x86_64"
    backend.instructions = []
    backend.registers = []

    legg_til(backend.registers, ny_register("rax", 0))
    legg_til(backend.registers, ny_register("rbx", 1))
    legg_til(backend.registers, ny_register("rcx", 2))
    legg_til(backend.registers, ny_register("rdx", 3))

    returner backend
slutt

funksjon emit_mov_imm64(backend, register, verdi)
    instr = ny_instr("mov", "MOV_IMM64")

    legg_til(instr.operands, register)
    legg_til(instr.operands, verdi)

    legg_til(backend.instructions, instr)
slutt

funksjon emit_syscall(backend)
    instr = ny_instr("syscall", "SYSCALL")

    legg_til(backend.instructions, instr)
slutt

funksjon emit_exit(backend, kode)
    emit_mov_imm64(backend, "rax", 60)
    emit_mov_imm64(backend, "rdi", kode)

    emit_syscall(backend)
slutt

funksjon emit_write_stdout(backend, tekst)
    emit_mov_imm64(backend, "rax", 1)
    emit_mov_imm64(backend, "rdi", 1)
    emit_mov_imm64(backend, "rsi", tekst)
    emit_mov_imm64(backend, "rdx", lengde(tekst))

    emit_syscall(backend)
slutt

funksjon compile_native_program(kilde)
    backend = ny_backend()

    skriv_linje("[NATIVE] kompilerer program")

    emit_write_stdout(backend, "Hei fra Norscode Native")

    emit_exit(backend, 0)

    returner backend
slutt

funksjon ny_elf()
    elf = ELFProgram()

    elf.sections = []
    elf.entrypoint = "_start"

    returner elf
slutt

funksjon legg_til_section(elf, navn, data)
    section = ELFSection()

    section.navn = navn
    section.data = data

    legg_til(elf.sections, section)
slutt

funksjon generate_elf(backend)
    elf = ny_elf()

    text_data = []

    indeks = 0

    mens indeks < lengde(backend.instructions)
        instr = backend.instructions[indeks]

        legg_til(text_data, instr.opcode)

        indeks = indeks + 1
    slutt

    legg_til_section(elf, ".text", text_data)

    returner elf
slutt

funksjon serialize_elf(elf)
    output = "ELF64\\n"

    indeks = 0

    mens indeks < lengde(elf.sections)
        section = elf.sections[indeks]

        output = output + "SECTION:" + section.navn + "\\n"

        indeks = indeks + 1
    slutt

    returner output
slutt

funksjon build_native_executable(kilde, output_fil)
    backend = compile_native_program(kilde)

    elf = generate_elf(backend)

    serialized = serialize_elf(elf)

    skriv_fil(output_fil, serialized)

    skriv_linje("[NATIVE] executable bygget: " + output_fil)

    returner sann
slutt

funksjon native_backend_stats(backend)
    skriv_linje("=== Native Backend Stats ===")
    skriv_linje("Architecture: " + backend.architecture)
    skriv_linje("Instructions: " + tekst_fra_heltall(lengde(backend.instructions)))
    skriv_linje("Registers: " + tekst_fra_heltall(lengde(backend.registers)))
slutt

funksjon main()
    core = init_runtime()

    backend = compile_native_program("skriv_linje(\"Hei\")")

    native_backend_stats(backend)

    build_native_executable(
        "skriv_linje(\"Hei\")",
        "build/hello_native.elf"
    )

    runtime_leak_check(core)

    skriv_linje("Native Execution Layer OK")

    returner sann
slutt

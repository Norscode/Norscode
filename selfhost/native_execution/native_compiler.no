// Norscode Native Compiler v0
// First standalone native compiler bootstrap foundation.

bruk selfhost.lexer
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.bytecode_backend
bruk selfhost.native_execution.machinecode_emitter
bruk selfhost.native_execution.linker
bruk selfhost.native_execution.process_runtime
bruk selfhost.native_execution.elf_layout
bruk selfhost.runtime_core.runtime_core
bruk selfhost.std_native.std_native
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur CompilerUnit
    source_path
    ast
    semantic_ok
    bytecode
    machinecode
slutt

struktur NativeCompiler
    runtime
    stdlib
    loaded_units
    compiled_outputs
slutt

struktur CompilerResult
    success
    output
    executable
slutt

funksjon ny_unit(path)
    unit = CompilerUnit()

    unit.source_path = path
    unit.ast = ingen
    unit.semantic_ok = usann
    unit.bytecode = []
    unit.machinecode = ingen

    returner unit
slutt

funksjon ny_compiler(core, lib)
    compiler = NativeCompiler()

    compiler.runtime = core
    compiler.stdlib = lib
    compiler.loaded_units = []
    compiler.compiled_outputs = []

    returner compiler
slutt

funksjon ny_result(success, output, executable)
    result = CompilerResult()

    result.success = success
    result.output = output
    result.executable = executable

    returner result
slutt

funksjon parse_source(unit, source)
    skriv_linje("[COMPILER] lexer/parser")

    lex = ny_lexer(source)
    prs = ny_parser(lex)

    unit.ast = selfhost.parser.parse_program(prs)

    returner sann
slutt

funksjon analyze_semantics(unit)
    skriv_linje("[COMPILER] semantic analysis")

    analyzer = ny_semantic_analyzer()

    analyser_node(analyzer, unit.ast)

    unit.semantic_ok = sann

    returner sann
slutt

funksjon generate_bytecode(unit)
    skriv_linje("[COMPILER] bytecode generation")

    backend = ny_bytecode_backend()

    unit.bytecode = generer_bytecode(
        backend,
        unit.ast
    )

    returner sann
slutt

funksjon generate_machinecode(unit, source)
    skriv_linje("[COMPILER] machinecode generation")

    unit.machinecode = compile_machinecode(source)

    returner sann
slutt

funksjon link_executable(unit, output)
    skriv_linje("[COMPILER] linker stage")

    build_linked_executable(
        "native_program",
        output
    )

    returner sann
slutt

funksjon compile_source(compiler, source, output)
    unit = ny_unit("memory")

    parse_source(unit, source)

    analyze_semantics(unit)

    generate_bytecode(unit)

    generate_machinecode(unit, source)

    link_executable(unit, output)

    legg_til(compiler.loaded_units, unit)
    legg_til(compiler.compiled_outputs, output)

    returner ny_result(
        sann,
        "compile OK",
        output
    )
slutt

funksjon selfcompile(compiler)
    skriv_linje("[COMPILER] selfcompile bootstrap")

    source = "funksjon main() skriv_linje(\\\"native compiler\\\") slutt"

    result = compile_source(
        compiler,
        source,
        "build/norscode_compiler.elf"
    )

    hvis ikkje result.success
        runtime_panic("Selfcompile feilet")
    slutt

    returner result
slutt

funksjon execute_compiler_output(loader, result)
    skriv_linje("[COMPILER] execute compiler output")

    proc = load_executable(
        loader,
        result.executable
    )

    execute_process(proc)

    returner sann
slutt

funksjon verify_compiler(compiler)
    skriv_linje("=== Native Compiler Verification ===")

    skriv_linje(
        "Units: " +
        tekst_fra_heltall(lengde(compiler.loaded_units))
    )

    skriv_linje(
        "Outputs: " +
        tekst_fra_heltall(lengde(compiler.compiled_outputs))
    )

    returner sann
slutt

funksjon compiler_banner()
    skriv_linje("=== Norscode Native Compiler ===")
    skriv_linje("Bootstrap Compiler Runtime")
slutt

funksjon main()
    compiler_banner()

    core = init_runtime()

    lib = init_stdlib(core)

    compiler = ny_compiler(core, lib)

    loader = ny_loader()

    source = "funksjon main() skriv_linje(\\\"Hei Native Compiler\\\") slutt"

    result = compile_source(
        compiler,
        source,
        "build/hello_compiler.elf"
    )

    execute_compiler_output(loader, result)

    selfcompile(compiler)

    verify_compiler(compiler)

    runtime_leak_check(core)

    stdout("Native Compiler OK")

    returner sann
slutt

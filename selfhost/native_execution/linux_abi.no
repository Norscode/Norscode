// Norscode Linux ABI Runtime v0
// Linux syscall ABI and executable startup foundation.

bruk selfhost.native_execution.x86_64_backend
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io

struktur Syscall
    navn
    nummer
    argc
slutt

struktur ABIRegister
    navn
    rolle
slutt

struktur LinuxABI
    syscalls
    registers
    architecture
slutt

funksjon ny_syscall(navn, nummer, argc)
    call = Syscall()

    call.navn = navn
    call.nummer = nummer
    call.argc = argc

    returner call
slutt

funksjon ny_reg(navn, rolle)
    reg = ABIRegister()

    reg.navn = navn
    reg.rolle = rolle

    returner reg
slutt

funksjon init_linux_abi()
    abi = LinuxABI()

    abi.architecture = "linux-x86_64"
    abi.syscalls = []
    abi.registers = []

    // Linux syscall ABI registers
    legg_til(abi.registers, ny_reg("rax", "syscall_number"))
    legg_til(abi.registers, ny_reg("rdi", "arg1"))
    legg_til(abi.registers, ny_reg("rsi", "arg2"))
    legg_til(abi.registers, ny_reg("rdx", "arg3"))
    legg_til(abi.registers, ny_reg("r10", "arg4"))
    legg_til(abi.registers, ny_reg("r8", "arg5"))
    legg_til(abi.registers, ny_reg("r9", "arg6"))

    // Core syscalls
    legg_til(abi.syscalls, ny_syscall("read", 0, 3))
    legg_til(abi.syscalls, ny_syscall("write", 1, 3))
    legg_til(abi.syscalls, ny_syscall("open", 2, 3))
    legg_til(abi.syscalls, ny_syscall("close", 3, 1))
    legg_til(abi.syscalls, ny_syscall("mmap", 9, 6))
    legg_til(abi.syscalls, ny_syscall("munmap", 11, 2))
    legg_til(abi.syscalls, ny_syscall("exit", 60, 1))

    returner abi
slutt

funksjon finn_syscall(abi, navn)
    indeks = 0

    mens indeks < lengde(abi.syscalls)
        call = abi.syscalls[indeks]

        hvis call.navn == navn
            returner call
        slutt

        indeks = indeks + 1
    slutt

    returner ingen
slutt

funksjon emit_linux_syscall(backend, abi, navn, args)
    call = finn_syscall(abi, navn)

    hvis call == ingen
        runtime_panic("Ukjent syscall")
    slutt

    emit_mov_imm64(backend, "rax", call.nummer)

    hvis lengde(args) > 0
        emit_mov_imm64(backend, "rdi", args[0])
    slutt

    hvis lengde(args) > 1
        emit_mov_imm64(backend, "rsi", args[1])
    slutt

    hvis lengde(args) > 2
        emit_mov_imm64(backend, "rdx", args[2])
    slutt

    emit_syscall(backend)
slutt

funksjon emit_startup_runtime(backend)
    instr = ny_instr("global_start", "GLOBAL_START")

    legg_til(backend.instructions, instr)
slutt

funksjon emit_runtime_banner(backend, abi)
    emit_linux_syscall(
        backend,
        abi,
        "write",
        [1, "Norscode Native Runtime\\n", 25]
    )
slutt

funksjon emit_runtime_exit(backend, abi)
    emit_linux_syscall(
        backend,
        abi,
        "exit",
        [0]
    )
slutt

funksjon compile_linux_runtime(kilde)
    skriv_linje("[ABI] bygger Linux runtime")

    abi = init_linux_abi()

    backend = ny_backend()

    emit_startup_runtime(backend)

    emit_runtime_banner(backend, abi)

    emit_write_stdout(backend, "Program start")

    emit_runtime_exit(backend, abi)

    returner backend
slutt

funksjon verify_linux_abi(abi)
    skriv_linje("=== Linux ABI Verification ===")

    skriv_linje("Architecture: " + abi.architecture)
    skriv_linje("Syscalls: " + tekst_fra_heltall(lengde(abi.syscalls)))
    skriv_linje("Registers: " + tekst_fra_heltall(lengde(abi.registers)))

    returner sann
slutt

funksjon build_linux_executable(kilde, output)
    abi = init_linux_abi()

    verify_linux_abi(abi)

    backend = compile_linux_runtime(kilde)

    elf = generate_elf(backend)

    serialized = serialize_elf(elf)

    skriv_fil(output, serialized)

    skriv_linje("[ABI] Linux executable generert")

    returner sann
slutt

funksjon main()
    abi = init_linux_abi()

    verify_linux_abi(abi)

    build_linux_executable(
        "skriv_linje(\"Hei Linux\")",
        "build/linux_runtime.elf"
    )

    skriv_linje("Linux ABI Runtime OK")

    returner sann
slutt

// selfhost/native_execution/native_codegen_v2.no
// NCB → x86-64 ELF med komplett NcVal-runtime
//
// Alle verdiar er NcVal* (16-byte heap-struct: {type, val})
// Full runtime: skriv, fil-I/O, JSON, map/list, string-ops, miljø
//
// Bruk: NC_INPUT=fil.ncb.json NC_OUTPUT=fil \
//           ./bin/nc run selfhost/native_execution/native_codegen_v2.no

// ─── Adressar ────────────────────────────────────────────────────────────────
funksjon TEXT_VA()   { returner 4198400 }
funksjon DATA_VA()   { returner 5242880 }
funksjon HEAP_VA()   { returner 6291456 }
funksjon HEAP_SZ()   { returner 67108864 }
funksjon ENVP_STORE() { returner 73400312 }

// ─── Runtime-funksjon VA ─────────────────────────────────────────────────────
funksjon RT_NIL() { returner 4198400 }
funksjon RT_INT() { returner 4198432 }
funksjon RT_BOOL() { returner 4198464 }
funksjon RT_STR_RAW() { returner 4198512 }
funksjon RT_ADD() { returner 4204000 }
funksjon RT_SUB() { returner 4208096 }
funksjon RT_MUL() { returner 4208128 }
funksjon RT_DIV() { returner 4208160 }
funksjon RT_MOD() { returner 4208208 }
funksjon RT_NEG() { returner 4208256 }
funksjon RT_NOT() { returner 4207648 }
funksjon RT_EQ() { returner 4203856 }
funksjon RT_NE() { returner 4207696 }
funksjon RT_LT() { returner 4207744 }
funksjon RT_GT() { returner 4207872 }
funksjon RT_LE() { returner 4207904 }
funksjon RT_GE() { returner 4208000 }
funksjon RT_SKRIV() { returner 4202784 }
funksjon RT_INT_TO_STR() { returner 4199952 }
funksjon RT_STR_TO_INT() { returner 4200112 }
funksjon RT_CONCAT() { returner 4199472 }
funksjon RT_SLICE() { returner 4198848 }
funksjon RT_INDEX_OF_STR() { returner 4198912 }
funksjon RT_CONTAINS() { returner 4199120 }
funksjon RT_STARTS_WITH() { returner 4199168 }
funksjon RT_ENDS_WITH() { returner 4199264 }
funksjon RT_TRIM() { returner 4199360 }
funksjon RT_REPLACE() { returner 4199472 }
funksjon RT_SPLIT() { returner 4201168 }
funksjon RT_JOIN() { returner 4201424 }
funksjon RT_LOWER() { returner 4200320 }
funksjon RT_UPPER() { returner 4200448 }
funksjon RT_CHAR_CODE() { returner 4200224 }
funksjon RT_CHR() { returner 4200272 }
funksjon RT_TYPE_OF() { returner 4200576 }
funksjon RT_TO_TEKST() { returner 4206992 }
funksjon RT_TO_INT() { returner 4207120 }
funksjon RT_LIST_NEW() { returner 4200624 }
funksjon RT_LIST_APP() { returner 4200704 }
funksjon RT_LIST_GET() { returner 4200816 }
funksjon RT_LIST_SET() { returner 4200864 }
funksjon RT_LIST_LEN() { returner 4200896 }
funksjon RT_LIST_POP() { returner 4200928 }
funksjon RT_LIST_REMOVE() { returner 4201088 }
funksjon RT_LIST_SLICE() { returner 4200976 }
funksjon RT_MAP_NEW() { returner 4201568 }
funksjon RT_MAP_GET() { returner 4201664 }
funksjon RT_MAP_SET() { returner 4201808 }
funksjon RT_MAP_HAS() { returner 4202064 }
funksjon RT_MAP_KEYS() { returner 4202208 }
funksjon RT_MAP_VALS() { returner 4202304 }
funksjon RT_MAP_DEL() { returner 4202400 }
funksjon RT_INDEX_GET() { returner 4202592 }
funksjon RT_INDEX_SET() { returner 4202720 }
funksjon RT_FIL_LES() { returner 4202832 }
funksjon RT_FIL_SKRIV() { returner 4203136 }
funksjon RT_FIL_SKRIV_BINAR() { returner 4203280 }
funksjon RT_FIL_FINNES() { returner 4203712 }
funksjon RT_MILJO_HENT() { returner 4203488 }
funksjon RT_MILJO_FINNES() { returner 4203664 }
funksjon RT_JSON_PARSE() { returner 4205248 }
funksjon RT_JSON_STR() { returner 4204128 }
funksjon RT_BUILD_LIST_REV() { returner 4208336 }
funksjon RT_BUILD_MAP_REV() { returner 4208432 }
funksjon RT_TRUTHY() { returner 4207584 }
funksjon RT_THROW() { returner 4208528 }
funksjon RT_KAST() { returner 4207408 }
funksjon RT_FEIL() { returner 4207200 }
funksjon RT_LENGDE() { returner 4207328 }
funksjon RT_INIT_HEAP() { returner 4207520 }

// ─── Byte-emitering ──────────────────────────────────────────────────────────
funksjon u8(buf, v)  { legg_til(buf, v & 255) }
funksjon u16(buf, v) { legg_til(buf, v & 255)
legg_til(buf, (v >> 8) & 255) }
funksjon u32(buf, v) {
    legg_til(buf, v & 255)
    legg_til(buf, (v >> 8) & 255)
    legg_til(buf, (v >> 16) & 255)
    legg_til(buf, (v >> 24) & 255)
}
funksjon u64(buf, v) {
    legg_til(buf, v & 255)
    legg_til(buf, (v >> 8) & 255)
    legg_til(buf, (v >> 16) & 255)
    legg_til(buf, (v >> 24) & 255)
    legg_til(buf, (v >> 32) & 255)
    legg_til(buf, (v >> 40) & 255)
    legg_til(buf, (v >> 48) & 255)
    legg_til(buf, (v >> 56) & 255)
}
funksjon zeros(buf, n)  { la i: heltall = 0
mens i < n { legg_til(buf, 0)
i = i + 1 } }
funksjon copy(dst, src) { la i: heltall = 0
mens i < lengde(src) { legg_til(dst, src[i])
i = i + 1 } }
funksjon pad(buf, target) { mens lengde(buf) < target { legg_til(buf, 0) } }
funksjon call_rel32(buf, va, code_va) {
    // call target_va: E8 rel32 — code_va = absolut VA for buf[0]
    legg_til(buf, 0xE8)
    la rel = (va - (code_va + lengde(buf) + 4)) & 0xFFFFFFFF
    u32(buf, rel)
}
// ─── Runtime-kall-hjelparar ───────────────────────────────────────────────────
// call_rt_1arg: pop rdi
funksjon emit_rt_call_1(buf, rt_va, code_va) {
    legg_til(buf, 0x5F)           // pop rdi
    call_rel32(buf, rt_va, code_va)
    legg_til(buf, 0x50)           // push rax
}
// call_rt_2arg: pop rsi (b/top)
funksjon emit_rt_call_2(buf, rt_va, code_va) {
    legg_til(buf, 0x5E)           // pop rsi
    legg_til(buf, 0x5F)           // pop rdi
    call_rel32(buf, rt_va, code_va)
    legg_til(buf, 0x50)           // push rax
}
// call_rt_3arg: pop rdx (c)
funksjon emit_rt_call_3(buf, rt_va, code_va) {
    legg_til(buf, 0x5A)           // pop rdx
    legg_til(buf, 0x5E)           // pop rsi
    legg_til(buf, 0x5F)           // pop rdi
    call_rel32(buf, rt_va, code_va)
    legg_til(buf, 0x50)           // push rax
}
// emit_push_imm64: mov rax, imm64
funksjon emit_push_imm64(buf, v) {
    legg_til(buf, 0x48)
    legg_til(buf, 0xB8)
    u64(buf, v)  // mov rax, v
    legg_til(buf, 0x50)                                      // push rax
}
// ─── Funksjonsprolog/epilog ───────────────────────────────────────────────────
funksjon prolog(buf, n_local) {
    legg_til(buf, 0x55)                             // push rbp
    legg_til(buf, 0x48)
    legg_til(buf, 0x89)
    legg_til(buf, 0xE5)  // mov rbp, rsp
    la raw: heltall = (n_local + 1) * 8
    la sz: heltall = ((raw + 15) / 16) * 16         // SysV: RSP ≡ 8 (mod 16) før call
    legg_til(buf, 0x48)
    legg_til(buf, 0x81)
    legg_til(buf, 0xEC)
    u32(buf, sz)                                    // sub rsp, sz
}
funksjon epilog(buf) {
    legg_til(buf, 0x48)
    legg_til(buf, 0x89)
    legg_til(buf, 0xEC)  // mov rsp, rbp
    legg_til(buf, 0x5D)                             // pop rbp
    legg_til(buf, 0xC3)                             // ret
}
// ─── Variablar (rbp-relative slottar, 8 bytes kvar) ──────────────────────────
funksjon samle_vars(kode) {
    la vars = {}
    la slot: heltall = 0
    la i: heltall = 0
    mens i < lengde(kode) {
        la op = kode[i][0]
        la er_store = op == "STORE_NAME"
        la er_param = op == "PARAM"
        hvis er_store eller er_param {
            la nm = tekst(kode[i][1])
            hvis ikke finnes_nøkkel(vars, nm) {
                slot = slot + 1
                vars[nm] = slot
            }
        }
        i = i + 1
    }
    returner vars
}
// rbp_offset(slot): adresse = rbp - slot*8
funksjon rbp_off(slot) { returner (0 - slot * 8) & 0xFFFFFFFF }
// emit_store_var: pop rax; mov [rbp+disp], rax
funksjon emit_store(buf, slot) {
    la disp = rbp_off(slot)
    legg_til(buf, 0x48)
    legg_til(buf, 0x89)
    legg_til(buf, 0x85)
    u32(buf, disp)  // mov [rbp + disp], rax — but we need to pop first
    // Actually: pop rax first
}
funksjon emit_store_var(buf, vars, nm) {
    la slot: heltall = 0
    hvis finnes_nøkkel(vars, nm) { slot = vars[nm] }
    la disp = rbp_off(slot)
    legg_til(buf, 0x58)  // pop rax
    legg_til(buf, 0x48)
    legg_til(buf, 0x89)
    legg_til(buf, 0x85)
    u32(buf, disp)
}
funksjon emit_load_var(buf, vars, nm) {
    la slot: heltall = 0
    hvis finnes_nøkkel(vars, nm) { slot = vars[nm] }
    la disp = rbp_off(slot)
    legg_til(buf, 0x48)
    legg_til(buf, 0x8B)
    legg_til(buf, 0x85)
    u32(buf, disp)       // mov rax, [rbp + disp]
    legg_til(buf, 0x50)  // push rax
}
// ─── Hopp-instruksjonar ───────────────────────────────────────────────────────
funksjon emit_jmp_placeholder(buf) {
    legg_til(buf, 0xE9)
    u32(buf, 0)  // jmp rel32 (5 bytes)
    returner lengde(buf) - 4          // posisjon til rel32-feltet
}
funksjon emit_jz_placeholder(buf, code_va) {
    // JUMP_IF_FALSE: pop rdi
    legg_til(buf, 0x5F)               // pop rdi (NcVal*)
    la rt_va = RT_TRUTHY()
    call_rel32(buf, rt_va, code_va)
    legg_til(buf, 0x48)
    legg_til(buf, 0x85)
    legg_til(buf, 0xC0)  // test rax,rax
    legg_til(buf, 0x0F)
    legg_til(buf, 0x84)
    u32(buf, 0)  // jz rel32
    returner lengde(buf) - 4          // posisjon til rel32-feltet
}
funksjon patch_jump(buf, patch_pos, target_pos) {
    la rel = (target_pos - (patch_pos + 4)) & 0xFFFFFFFF
    buf[patch_pos]     = rel & 255
    buf[patch_pos + 1] = (rel >> 8) & 255
    buf[patch_pos + 2] = (rel >> 16) & 255
    buf[patch_pos + 3] = (rel >> 24) & 255
}

funksjon tstack_top(tstack) {
    hvis lengde(tstack) == 0 { returner "any" }
    returner tstack[lengde(tstack) - 1]
}

funksjon tstack_top_2(tstack) {
    hvis lengde(tstack) < 2 { returner "any" }
    returner tstack[lengde(tstack) - 2]
}

funksjon tstack_drop(tstack, n) {
    la i: heltall = 0
    mens i < n og lengde(tstack) > 0 {
        fjern_siste(tstack)
        i = i + 1
    }
}

funksjon call_result_type(fn_nm: tekst) {
    hvis builtin.ends_with(fn_nm, ".tekst_fra_heltall") eller fn_nm == "tekst_fra_heltall" { returner "str" }
    hvis builtin.ends_with(fn_nm, ".tekst") eller fn_nm == "tekst" eller fn_nm == "til_tekst" eller builtin.ends_with(fn_nm, ".til_tekst") { returner "str" }
    hvis builtin.ends_with(fn_nm, ".heltall_fra_tekst") eller fn_nm == "heltall_fra_tekst" eller fn_nm == "heltall" eller builtin.ends_with(fn_nm, ".heltall") { returner "int" }
    hvis builtin.ends_with(fn_nm, ".lengde") eller fn_nm == "lengde" { returner "int" }
    hvis builtin.ends_with(fn_nm, ".har_nokkel") eller fn_nm == "har_nokkel" eller builtin.ends_with(fn_nm, ".finnes_nøkkel") eller fn_nm == "finnes_nøkkel" { returner "bool" }
    hvis builtin.ends_with(fn_nm, ".skriv") eller fn_nm == "skriv" { returner "null" }
    returner "any"
}

// ─── PUSH_CONST ──────────────────────────────────────────────────────────────
funksjon emit_push_const(buf, v, rd_offs, code_va) {
    la vtype = builtin.type(v)
    hvis v == null {
        // null/ingenting er representert som null-peikar i native runtime
        legg_til(buf, 0x48)
        legg_til(buf, 0x31)
        legg_til(buf, 0xC0)   // xor rax, rax
        legg_til(buf, 0x50)    // push rax
        returner
    }
    hvis vtype == "heltall" {
        // nc_int(i64)
        emit_push_imm64(buf, heltall(v))  // push imm64
        legg_til(buf, 0x5F)               // pop rdi (= value)
        call_rel32(buf, RT_INT(), code_va)
        legg_til(buf, 0x50)
        returner
    }
    hvis vtype == "boolsk" {
        la bval: heltall = 0
        hvis v { bval = 1 }
        emit_push_imm64(buf, bval)
        legg_til(buf, 0x5F)
        call_rel32(buf, RT_BOOL(), code_va)
        legg_til(buf, 0x50)
        returner
    }
    // Streng: nc_str_raw(src=DATA_VA+off+8, len)
    la s: tekst = tekst(v)
    la rd_off: heltall = 0
    hvis finnes_nøkkel(rd_offs, s) { rd_off = rd_offs[s] }
    la data_ptr: heltall = DATA_VA() + rd_off
    // r11 = data_ptr; esi = [r11] (len); rdi = r11+8 (src bytes)
    legg_til(buf, 0x49)
    legg_til(buf, 0xBB)  // mov r11, imm64
    u64(buf, data_ptr)
    legg_til(buf, 0x41)
    legg_til(buf, 0x8B)
    legg_til(buf, 0x33)  // mov esi, [r11]
    legg_til(buf, 0x49)
    legg_til(buf, 0x8D)
    legg_til(buf, 0x7B)
    legg_til(buf, 0x08)  // lea rdi, [r11+8]
    call_rel32(buf, RT_STR_RAW(), code_va)
    legg_til(buf, 0x50)
}
// ─── Brukarkall (N argument) ─────────────────────────────────────────────────
// System V: rdi, rsi, rdx, rcx (arg 0-3)
// Args på stack: arg0 nedst (push sist), arg(n-1) øvst (push fyrst)
// For call f(arg0, arg1): stack=[arg1(top), arg0]
funksjon emit_user_call(buf, fn_va, nargs, code_va) {
    // Pop args til register (reverst slik at arg0 er i rdi)
    la arg_pops: liste<heltall> = [0x5F, 0x5E, 0x5A, 0x59]  // rdi,rsi,rdx,rcx
    // Pop i omvendt rekkjefølge: siste arg (øvst på stack) → siste register
    la i = nargs - 1
    mens i >= 0 og i < 4 {
        legg_til(buf, arg_pops[i])
        i = i - 1
    }
    call_rel32(buf, fn_va, code_va)
    legg_til(buf, 0x50)  // push result (NcVal*)
}
// ─── Strengliteralar (.data-seksjon) ─────────────────────────────────────────
funksjon char_to_byte(ch) {
    hvis ch == "\n" { returner 10 }
    ellers hvis ch == "\t" { returner 9 }
    ellers hvis ch == "\r" { returner 13 }
    ellers hvis ch == "\\" { returner 92 }
    ellers hvis ch == "\"" { returner 34 }
    ellers { returner builtin.char_code(ch) }
}

funksjon samle_strenger(fns) {
    la strenger: liste = []
    la nk = nøkler(fns)
    la fi: heltall = 0
    mens fi < lengde(nk) {
        la kode = fns[nk[fi]]["code"]
        la ci: heltall = 0
        mens ci < lengde(kode) {
            la instr = kode[ci]
            hvis instr[0] == "PUSH_CONST" og builtin.type(instr[1]) == "tekst" {
                la s: tekst = tekst(instr[1])
                la funnen: boolsk = usann
                la si: heltall = 0
                mens si < lengde(strenger) {
                    hvis strenger[si] == s { funnen = sann }
                    si = si + 1
                }
                hvis ikke funnen { legg_til(strenger, s) }
            }
            ci = ci + 1
        }
        fi = fi + 1
    }
    returner strenger
}

funksjon bygg_data(strenger) {
    la bytes: liste = []
    la offs: ordbok = {}
    la i: heltall = 0
    mens i < lengde(strenger) {
        la s = strenger[i]
        offs[s] = lengde(bytes)
        la sbytes: liste = []
        la j: heltall = 0
        mens j < lengde(s) {
            legg_til(sbytes, char_to_byte(s[j]))
            j = j + 1
        }
        u64(bytes, lengde(sbytes))
        copy(bytes, sbytes)
        i = i + 1
    }
    returner [bytes, offs]
}

// ─── Runtime hex-dekoding ─────────────────────────────────────────────────────
funksjon hex_nibble(ch: tekst) -> heltall {
    la code = builtin.char_code(ch)
    hvis code >= 48 og code <= 57 { returner code - 48 }
    hvis code >= 97 og code <= 102 { returner code - 87 }
    returner 0
}
funksjon hex_to_bytes(hex: tekst) -> liste {
    la out = []
    la i: heltall = 0
    la n = lengde(hex)
    mens i + 1 < n {
        la hi = hex_nibble(builtin.slice(hex, i, i + 1))
        la lo = hex_nibble(builtin.slice(hex, i + 1, i + 2))
        legg_til(out, hi * 16 + lo)
        i = i + 2
    }
    returner out
}
funksjon rt_hex_del0() { returner "" }
funksjon rt_hex_del1() { returner "" }
funksjon rt_hex_del2() { returner "" }
funksjon rt_hex_del3() { returner "" }
funksjon rt_hex_del4() { returner "" }
funksjon rt_hex_del5() { returner "" }
funksjon rt_hex_del6() { returner "" }

funksjon bygg_runtime_v2() -> liste {
    la hex = rt_hex_del0() + rt_hex_del1() + rt_hex_del2() + rt_hex_del3() + rt_hex_del4() + rt_hex_del5() + rt_hex_del6()
    hex = builtin.replace(hex, "48b80010400000000000ffe0", "31c0c3900f1f840000000000")
    hex = builtin.replace(hex, "e010400000000000", "9010400000000000")
    returner hex_to_bytes(hex)
}

// ─── Hovud kodegenererator ────────────────────────────────────────────────────

funksjon kompiler_fn_v2(fn_def, vars, fn_vas, rd_offs, eiga_va) {
    la kode = fn_def["code"]
    la params = fn_def["params"]
    la buf: liste = []
    la tstack: liste = []
    la var_types: ordbok = {}
    la n_vars: heltall = lengde(nøkler(vars))
    prolog(buf, n_vars + 8)

    // Lagre parameter-register (System V: rdi, rsi, rdx, rcx)
    la param_regs: liste = [0xBD, 0xB5, 0x95, 0x8D]  // mov [rbp+disp], rdi/rsi/rdx/rcx
    la pi: heltall = 0
    mens pi < lengde(params) og pi < 4
        la pnm: tekst = tekst(params[pi])
        la slot: heltall = 1
        hvis finnes_nøkkel(vars, pnm) { slot = vars[pnm] }
        la disp = rbp_off(slot)
        legg_til(buf, 0x48)
        legg_til(buf, 0x89)
        u8(buf, param_regs[pi])
        u32(buf, disp)
        pi = pi + 1
    slutt

    // Label-kart (label → buf offset) og patch-liste
    la lbl_kart: ordbok = {}
    la patches: liste = []  // [{type: "jmp"/"jz", pos: heltall, lbl: tekst}]

    la ci: heltall = 0
    mens ci < lengde(kode)
        la instr = kode[ci]
        la op: tekst = instr[0]
        // ─── LABEL ────────────────────────────────────────────────────────────
        hvis op == "LABEL"
            lbl_kart[tekst(instr[1])] = lengde(buf)

        // ─── PUSH_CONST ───────────────────────────────────────────────────────
        ellers hvis op == "PUSH_CONST"
            emit_push_const(buf, instr[1], rd_offs, eiga_va)
            la vtype: tekst = builtin.type(instr[1])
            hvis instr[1] == null { vtype = "null" }
            hvis vtype == "tekst" { vtype = "str" }
            legg_til(tstack, vtype)

        // ─── POP ──────────────────────────────────────────────────────────────
        ellers hvis op == "POP"
            legg_til(buf, 0x58)  // pop rax (discard)
            tstack_drop(tstack, 1)

        // ─── STORE_NAME ───────────────────────────────────────────────────────
        ellers hvis op == "STORE_NAME"
            la nm_store: tekst = tekst(instr[1])
            la stype: tekst = tstack_top(tstack)
            var_types[nm_store] = stype
            emit_store_var(buf, vars, tekst(instr[1]))
            tstack_drop(tstack, 1)

        // ─── LOAD_NAME ────────────────────────────────────────────────────────
        ellers hvis op == "LOAD_NAME"
            emit_load_var(buf, vars, tekst(instr[1]))
            la nm_load: tekst = tekst(instr[1])
            la ltype: tekst = "any"
            hvis finnes_nøkkel(var_types, nm_load) { ltype = var_types[nm_load] }
            legg_til(tstack, ltype)

        // ─── BINARY ops ───────────────────────────────────────────────────────
        ellers hvis op == "BINARY_ADD"
            la t2: tekst = tstack_top(tstack)
            la t1: tekst = tstack_top_2(tstack)
            tstack_drop(tstack, 2)
            hvis t1 == "str" eller t2 == "str" {
                emit_rt_call_2(buf, RT_CONCAT(), eiga_va)
                legg_til(tstack, "str")
            } ellers {
                legg_til(buf, 0x5B)  // pop rbx
                legg_til(buf, 0x58)  // pop rax
                legg_til(buf, 0x48)
                legg_til(buf, 0x01)
                legg_til(buf, 0xD8)  // add rax, rbx
                legg_til(buf, 0x50)  // push rax
                legg_til(tstack, "int")
            }

        ellers hvis op == "BINARY_SUB"
            emit_rt_call_2(buf, RT_SUB(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "int")

        ellers hvis op == "BINARY_MUL"
            emit_rt_call_2(buf, RT_MUL(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "int")

        ellers hvis op == "BINARY_DIV"
            emit_rt_call_2(buf, RT_DIV(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "int")

        ellers hvis op == "BINARY_MOD"
            emit_rt_call_2(buf, RT_MOD(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "int")

        ellers hvis op == "UNARY_NEG"
            emit_rt_call_1(buf, RT_NEG(), eiga_va)
            tstack_drop(tstack, 1)
            legg_til(tstack, "int")
        ellers hvis op == "UNARY_NOT"
            emit_rt_call_1(buf, RT_NOT(), eiga_va)
            tstack_drop(tstack, 1)
            legg_til(tstack, "bool")

        // ─── COMPARE ops ──────────────────────────────────────────────────────
        ellers hvis op == "COMPARE_EQ"
            emit_rt_call_2(buf, RT_EQ(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "bool")
        ellers hvis op == "COMPARE_NE"
            emit_rt_call_2(buf, RT_NE(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "bool")
        ellers hvis op == "COMPARE_LT"
            emit_rt_call_2(buf, RT_LT(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "bool")
        ellers hvis op == "COMPARE_GT"
            emit_rt_call_2(buf, RT_GT(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "bool")
        ellers hvis op == "COMPARE_LE"
            emit_rt_call_2(buf, RT_LE(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "bool")
        ellers hvis op == "COMPARE_GE"
            emit_rt_call_2(buf, RT_GE(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "bool")

        // ─── JUMP ─────────────────────────────────────────────────────────────
        ellers hvis op == "JUMP"
            la lbl: tekst = tekst(instr[1])
            la ppos = emit_jmp_placeholder(buf)
            legg_til(patches, {"type": "jmp", "pos": ppos, "lbl": lbl})

        // ─── JUMP_IF_FALSE ────────────────────────────────────────────────────
        ellers hvis op == "JUMP_IF_FALSE"
            la lbl2: tekst = tekst(instr[1])
            la ppos2 = emit_jz_placeholder(buf, eiga_va)
            legg_til(patches, {"type": "jz", "pos": ppos2, "lbl": lbl2})
            tstack_drop(tstack, 1)

        // ─── INDEX_GET ────────────────────────────────────────────────────────
        ellers hvis op == "INDEX_GET"
            emit_rt_call_2(buf, RT_INDEX_GET(), eiga_va)
            tstack_drop(tstack, 2)
            legg_til(tstack, "any")

        // ─── INDEX_SET ────────────────────────────────────────────────────────
        ellers hvis op == "INDEX_SET"
            emit_rt_call_3(buf, RT_INDEX_SET(), eiga_va)  // pop rdx=val
            tstack_drop(tstack, 3)
            legg_til(tstack, "any")

        // ─── BUILD_LIST ───────────────────────────────────────────────────────
        ellers hvis op == "BUILD_LIST"
            la blen: heltall = heltall(instr[1])
            hvis blen == 0
                call_rel32(buf, RT_LIST_NEW(), eiga_va)
                legg_til(buf, 0x50)
            ellers
                // mov rdi, rsp (ptr to items on stack)
                legg_til(buf, 0x48)
                legg_til(buf, 0x89)
                legg_til(buf, 0xE7)
                // mov rsi, n (u64 immediate)
                legg_til(buf, 0x48)
                legg_til(buf, 0xBE)
                u64(buf, blen)
                call_rel32(buf, RT_BUILD_LIST_REV(), eiga_va)
                // add rsp, blen*8
                legg_til(buf, 0x48)
                legg_til(buf, 0x81)
                legg_til(buf, 0xC4)
                u32(buf, blen * 8)
                legg_til(buf, 0x50)  // push list
            slutt

        // ─── BUILD_MAP ────────────────────────────────────────────────────────
        ellers hvis op == "BUILD_MAP"
            la mlen: heltall = heltall(instr[1])
            hvis mlen == 0
                call_rel32(buf, RT_MAP_NEW(), eiga_va)
                legg_til(buf, 0x50)
            ellers
                // mov rdi, rsp
                legg_til(buf, 0x48)
                legg_til(buf, 0x89)
                legg_til(buf, 0xE7)
                // mov rsi, n
                legg_til(buf, 0x48)
                legg_til(buf, 0xBE)
                u64(buf, mlen)
                call_rel32(buf, RT_BUILD_MAP_REV(), eiga_va)
                // add rsp, mlen*16 (2 items per pair)
                legg_til(buf, 0x48)
                legg_til(buf, 0x81)
                legg_til(buf, 0xC4)
                u32(buf, mlen * 16)
                legg_til(buf, 0x50)  // push map
            slutt

        // ─── CALL ─────────────────────────────────────────────────────────────
        ellers hvis op == "CALL"
            la fn_nm: tekst = tekst(instr[1])
            la nargs: heltall = heltall(instr[2])
            emit_builtin_or_user_call(buf, fn_nm, nargs, fn_vas, rd_offs, eiga_va)
            tstack_drop(tstack, nargs)
            legg_til(tstack, call_result_type(fn_nm))

        // ─── RETURN ───────────────────────────────────────────────────────────
        ellers hvis op == "RETURN"
            legg_til(buf, 0x58)  // pop rax (return value = NcVal*)
            tstack_drop(tstack, 1)
            epilog(buf)

        // ─── THROW ────────────────────────────────────────────────────────────
        ellers hvis op == "THROW"
            emit_rt_call_1(buf, RT_THROW(), eiga_va)

        slutt
        ci = ci + 1
    slutt

    // Fallthrough: returner null-peikar
    legg_til(buf, 0x48)
    legg_til(buf, 0x31)
    legg_til(buf, 0xC0)   // xor rax, rax
    epilog(buf)

    // Patch jump-labels
    la pi2: heltall = 0
    mens pi2 < lengde(patches)
        la p = patches[pi2]
        la target: heltall = 0
        la lbl_nm = p["lbl"]
        hvis finnes_nøkkel(lbl_kart, lbl_nm) { target = lbl_kart[lbl_nm] }
        patch_jump(buf, p["pos"], target)
        pi2 = pi2 + 1
    slutt

    returner buf
}

// ─── Builtin og brukarkall dispatch ──────────────────────────────────────────
funksjon builtin_va(fn_nm: tekst) -> heltall {
    // String-ops
    la er_split        = fn_nm == "builtin.split" eller builtin.ends_with(fn_nm, ".split") eller fn_nm == "tekst_splitt"
    la er_join         = fn_nm == "builtin.join" eller builtin.ends_with(fn_nm, ".join") eller fn_nm == "tekst_join"
    la er_contains     = fn_nm == "builtin.contains" eller builtin.ends_with(fn_nm, ".contains") eller fn_nm == "tekst_inneholder"
    la er_starts_with  = fn_nm == "builtin.starts_with" eller builtin.ends_with(fn_nm, ".starts_with") eller fn_nm == "tekst_starter_med"
    la er_ends_with    = fn_nm == "builtin.ends_with" eller builtin.ends_with(fn_nm, ".ends_with") eller fn_nm == "tekst_slutter_med"
    la er_slice        = fn_nm == "builtin.slice" eller builtin.ends_with(fn_nm, ".slice")
    la er_index_of     = fn_nm == "index_of" eller fn_nm == "builtin.index_of" eller builtin.ends_with(fn_nm, ".index_of")
    la er_replace      = fn_nm == "builtin.replace" eller fn_nm == "tekst_erstatt" eller builtin.ends_with(fn_nm, ".replace")
    la er_trim         = fn_nm == "builtin.trim" eller fn_nm == "tekst_trim" eller builtin.ends_with(fn_nm, ".trim")
    la er_lower        = fn_nm == "builtin.lower" eller fn_nm == "tekst_til_liten" eller builtin.ends_with(fn_nm, ".lower")
    la er_upper        = fn_nm == "builtin.upper" eller fn_nm == "builtin.tekst_til_store" eller builtin.ends_with(fn_nm, ".upper")
    la er_char_code    = fn_nm == "builtin.char_code" eller fn_nm == "char_code"
    la er_chr          = fn_nm == "builtin.chr" eller fn_nm == "chr"
    la er_type         = fn_nm == "builtin.type" eller fn_nm == "type_av" eller fn_nm == "type"
    // Int/bool/str conv
    la er_itos         = fn_nm == "tekst_fra_heltall" eller builtin.ends_with(fn_nm, ".tekst_fra_heltall")
    la er_stoi         = fn_nm == "heltall_fra_tekst" eller fn_nm == "heltall" eller builtin.ends_with(fn_nm, ".heltall")
    la er_to_tekst     = fn_nm == "tekst" eller fn_nm == "til_tekst" eller builtin.ends_with(fn_nm, ".til_tekst")
    la er_to_int       = fn_nm == "builtin.desimaltall"
    // IO
    la er_skriv        = fn_nm == "skriv" eller builtin.ends_with(fn_nm, ".skriv")
    la er_fil_les      = fn_nm == "fil_les" eller builtin.ends_with(fn_nm, ".fil_les")
    la er_fil_skriv    = fn_nm == "fil_skriv" eller builtin.ends_with(fn_nm, ".fil_skriv")
    la er_fil_binar    = fn_nm == "fil_skriv_binar" eller builtin.ends_with(fn_nm, ".fil_skriv_binar") eller builtin.ends_with(fn_nm, ".fil_skriv_binær")
    la er_fil_finnes   = fn_nm == "fil_finnes" eller builtin.ends_with(fn_nm, ".fil_finnes")
    la er_miljo_hent   = fn_nm == "miljo_hent" eller builtin.ends_with(fn_nm, ".miljo_hent")
    la er_miljo_finnes = fn_nm == "miljo_finnes" eller builtin.ends_with(fn_nm, ".miljo_finnes")
    // JSON
    la er_json_parse   = fn_nm == "json_parse_raw" eller fn_nm == "json_parse" eller builtin.ends_with(fn_nm, ".json_parse_raw") eller builtin.ends_with(fn_nm, ".json_parse")
    la er_json_str     = fn_nm == "json_stringify" eller fn_nm == "json_skriv" eller builtin.ends_with(fn_nm, ".json_stringify") eller builtin.ends_with(fn_nm, ".json_skriv")
    // List
    la er_legg_til     = fn_nm == "legg_til" eller builtin.ends_with(fn_nm, ".legg_til")
    la er_lengde       = fn_nm == "lengde" eller builtin.ends_with(fn_nm, ".lengde")
    la er_fjern_siste  = fn_nm == "fjern_siste" eller fn_nm == "pop_siste" eller builtin.ends_with(fn_nm, ".fjern_siste")
    la er_fjern        = fn_nm == "fjern" eller fn_nm == "fjern_indeks" eller builtin.ends_with(fn_nm, ".fjern")
    // Map
    la er_finnes_nokkel = fn_nm == "finnes_nøkkel" eller fn_nm == "har_nokkel" eller builtin.ends_with(fn_nm, ".finnes_nøkkel") eller builtin.ends_with(fn_nm, ".har_nokkel")
    la er_nokler       = fn_nm == "nøkler" eller builtin.ends_with(fn_nm, ".nøkler")
    la er_verdier      = fn_nm == "verdier" eller builtin.ends_with(fn_nm, ".verdier")
    la er_fjern_nokkel = fn_nm == "fjern_nokkel" eller builtin.ends_with(fn_nm, ".fjern_nokkel")
    // Other
    la er_feil         = fn_nm == "feil" eller builtin.ends_with(fn_nm, ".feil")
    la er_exit         = fn_nm == "stopp" eller fn_nm == "exit" eller fn_nm == "builtin.exit" eller builtin.ends_with(fn_nm, ".stopp")
    la er_kast         = fn_nm == "kast"

    hvis er_split       { returner RT_SPLIT() }
    hvis er_join        { returner RT_JOIN() }
    hvis er_contains    { returner RT_CONTAINS() }
    hvis er_starts_with { returner RT_STARTS_WITH() }
    hvis er_ends_with   { returner RT_ENDS_WITH() }
    hvis er_slice       { returner RT_SLICE() }
    hvis er_index_of    { returner RT_INDEX_OF_STR() }
    hvis er_replace     { returner RT_REPLACE() }
    hvis er_trim        { returner RT_TRIM() }
    hvis er_lower       { returner RT_LOWER() }
    hvis er_upper       { returner RT_UPPER() }
    hvis er_char_code   { returner RT_CHAR_CODE() }
    hvis er_chr         { returner RT_CHR() }
    hvis er_type        { returner RT_TYPE_OF() }
    hvis er_itos        { returner RT_INT_TO_STR() }
    hvis er_stoi        { returner RT_STR_TO_INT() }
    hvis er_to_tekst    { returner RT_TO_TEKST() }
    hvis er_to_int      { returner RT_TO_INT() }
    hvis er_skriv       { returner RT_SKRIV() }
    hvis er_fil_les     { returner RT_FIL_LES() }
    hvis er_fil_skriv   { returner RT_FIL_SKRIV() }
    hvis er_fil_binar   { returner RT_FIL_SKRIV_BINAR() }
    hvis er_fil_finnes  { returner RT_FIL_FINNES() }
    hvis er_miljo_hent  { returner RT_MILJO_HENT() }
    hvis er_miljo_finnes { returner RT_MILJO_FINNES() }
    hvis er_json_parse  { returner RT_JSON_PARSE() }
    hvis er_json_str    { returner RT_JSON_STR() }
    hvis er_legg_til    { returner RT_LIST_APP() }
    hvis er_lengde      { returner RT_LENGDE() }
    hvis er_fjern_siste { returner RT_LIST_POP() }
    hvis er_fjern       { returner RT_LIST_REMOVE() }
    hvis er_finnes_nokkel { returner RT_MAP_HAS() }
    hvis er_nokler      { returner RT_MAP_KEYS() }
    hvis er_verdier     { returner RT_MAP_VALS() }
    hvis er_fjern_nokkel { returner RT_MAP_DEL() }
    hvis er_feil        { returner RT_FEIL() }
    hvis er_exit        { returner RT_KAST() }
    returner 0
}

funksjon emit_builtin_or_user_call(buf, fn_nm: tekst, nargs: heltall, fn_vas, rd_offs, code_va) {
    la rt_va = builtin_va(fn_nm)
    hvis rt_va != 0 {
        hvis nargs == 0 {
            call_rel32(buf, rt_va, code_va)
            legg_til(buf, 0x50)
            returner
        }
        hvis nargs == 1 {
            emit_rt_call_1(buf, rt_va, code_va)
            returner
        }
        hvis nargs == 2 {
            emit_rt_call_2(buf, rt_va, code_va)
            returner
        }
        hvis nargs == 3 {
            emit_rt_call_3(buf, rt_va, code_va)
            returner
        }
        ellers {
            la ai: heltall = 0
            mens ai < nargs {
                legg_til(buf, 0x58)
                ai = ai + 1
            }
            call_rel32(buf, rt_va, code_va)
            legg_til(buf, 0x50)
            returner
        }
    }

    // Brukarkall — finn VA frå fn_vas
    la fn_va: heltall = 0
    hvis finnes_nøkkel(fn_vas, fn_nm) { fn_va = fn_vas[fn_nm] }
    ellers {
        // Prøv siste segment
        la last = builtin.split(fn_nm, ".")
        la last_nm = last[lengde(last) - 1]
        la nk = nøkler(fn_vas)
        la i: heltall = 0
        mens i < lengde(nk) og fn_va == 0 {
            la k = nk[i]
            la k_parts = builtin.split(k, ".")
            hvis k_parts[lengde(k_parts) - 1] == last_nm { fn_va = fn_vas[k] }
            i = i + 1
        }
    }
    emit_user_call(buf, fn_va, nargs, code_va)
}

// ─── Hovud-kompilator v2 ─────────────────────────────────────────────────────
funksjon kompiler_v2(ncb_json) {
    la ncb = json_parse_raw(ncb_json)
    la fns = ncb["functions"]

    la strenger = samle_strenger(fns)
    la data_res = bygg_data(strenger)
    la data_bytes = data_res[0]
    la rd_offs = data_res[1]

    la rt = bygg_runtime_v2()
    la rt_size: heltall = lengde(rt)

    // Finn entry: NCB entry-felt, deretter __main__.start / *.start
    la fn_list = nøkler(fns)
    la sorted: liste = []
    la start_fn: tekst = ""
    la entry_felt = ncb["entry"]
    hvis entry_felt != "" og finnes_nøkkel(fns, entry_felt)
        start_fn = entry_felt
    slutt
    la si: heltall = 0
    mens si < lengde(fn_list)
        la fn: tekst = fn_list[si]
        la er_start: boolsk = fn == "__main__.start" eller builtin.ends_with(fn, ".start")
        hvis er_start
            start_fn = fn
        slutt
        hvis fn != start_fn
            legg_til(sorted, fn)
        slutt
        si = si + 1
    slutt
    hvis start_fn == ""
        start_fn = "__main__.start"
    slutt
    legg_til(sorted, start_fn)

    // Pass 1: estimér VA for kvar funksjon
    // Grovt estimat: 300 + 80 * n_instruksjonar bytes
    la fn_vas: ordbok = {}
    la curr_off: heltall = rt_size

    la fi2: heltall = 0
    mens fi2 < lengde(sorted)
        la fn: tekst = sorted[fi2]
        fn_vas[fn] = TEXT_VA() + curr_off
        la fn_def = fns[fn]
        la est: heltall = 300 + lengde(fn_def["code"]) * 80
        curr_off = curr_off + est
        fi2 = fi2 + 1
    slutt

    // Pass 2: kompilér kvar funksjon
    la text: liste = []
    copy(text, rt)

    la fi3: heltall = 0
    mens fi3 < lengde(sorted)
        la fn: tekst = sorted[fi3]
        la fn_def2 = fns[fn]
        fn_vas[fn] = TEXT_VA() + lengde(text)
        la fn_vars = samle_vars(fn_def2["code"])
        la fn_code = kompiler_fn_v2(fn_def2, fn_vars, fn_vas, rd_offs, TEXT_VA() + lengde(text))
        copy(text, fn_code)
        fi3 = fi3 + 1
    slutt

    // _start: capture envp, init heap, call main, exit(0)
    la entry_va: heltall = TEXT_VA() + lengde(text)

    // On Linux _start entry: rsp → argc, rsp+8 → argv[0], ..., NULL, envp[0], ...
    // Les argc/argv/envp utan å konsumere stacken; då held vi SysV stack-alignment
    // korrekt før første call inn i runtime.
    // mov rdi, [rsp] = argc
    legg_til(text, 0x48)
    legg_til(text, 0x8B)
    legg_til(text, 0x3C)
    legg_til(text, 0x24)
    // lea rsi, [rsp+8] → argv
    legg_til(text, 0x48)
    legg_til(text, 0x8D)
    legg_til(text, 0x74)
    legg_til(text, 0x24)
    legg_til(text, 0x08)
    // Skip argv: lea rdx, [rsp + rdi*8] + 16 → envp
    // lea rdx, [rsp + rdi*8]
    legg_til(text, 0x48)
    legg_til(text, 0x8D)
    legg_til(text, 0x14)
    legg_til(text, 0xFC)  // lea rdx, [rsp+rdi*8]
    legg_til(text, 0x48)
    legg_til(text, 0x83)
    legg_til(text, 0xC2)
    legg_til(text, 0x10)   // add rdx, 16
    // Store envp at ENVP_STORE
    // mov r11, ENVP_STORE
    legg_til(text, 0x49)
    legg_til(text, 0xBB)
    u64(text, ENVP_STORE())
    // mov [r11], rdx
    legg_til(text, 0x49)
    legg_til(text, 0x89)
    legg_til(text, 0x13)

    // Call rt_init_heap (no args)
    call_rel32(text, RT_INIT_HEAP(), TEXT_VA())

    // Call start()
    la main_va: heltall = fn_vas[start_fn]
    call_rel32(text, main_va, TEXT_VA())

    // exit(0)
    legg_til(text, 0x48)
    legg_til(text, 0xC7)
    legg_til(text, 0xC7)
    u32(text, 0)  // mov rdi, 0
    legg_til(text, 0x48)
    legg_til(text, 0xC7)
    legg_til(text, 0xC0)
    u32(text, 60) // mov rax, 60
    legg_til(text, 0x0F)
    legg_til(text, 0x05)  // syscall

    la text_size: heltall = lengde(text)
    la data_size: heltall = lengde(data_bytes)

    // Bygg ELF64 med 3 segment
    la elf: liste = []
    la ph_off: heltall = 64
    la text_file_off: heltall = 4096
    la data_file_off: heltall = ((text_file_off + text_size + 4095) / 4096) * 4096
    la heap_file_off: heltall = ((data_file_off + data_size + 4095) / 4096) * 4096
    la heap_filesz: heltall = 8

    // ELF header
    u8(elf, 0x7F)
    u8(elf, 0x45)
    u8(elf, 0x4C)
    u8(elf, 0x46)
    u8(elf, 2)
    u8(elf, 1)
    u8(elf, 1)
    u8(elf, 0)
    zeros(elf, 8)
    u16(elf, 2)
    u16(elf, 62)
    u32(elf, 1)
    u64(elf, entry_va)
    u64(elf, ph_off)
    u64(elf, 0)
    u32(elf, 0)
    u16(elf, 64)
    u16(elf, 56)
    u16(elf, 3)
    u16(elf, 64)
    u16(elf, 0)
    u16(elf, 0)

    // PH .text (RX)
    u32(elf, 1)
    u32(elf, 5)
    u64(elf, text_file_off)
    u64(elf, TEXT_VA())
    u64(elf, TEXT_VA())
    u64(elf, text_size)
    u64(elf, text_size)
    u64(elf, 4096)

    // PH .data (R)
    u32(elf, 1)
    u32(elf, 4)
    u64(elf, data_file_off)
    u64(elf, DATA_VA())
    u64(elf, DATA_VA())
    u64(elf, data_size)
    u64(elf, data_size)
    u64(elf, 4096)

    // PH .heap (RW — 64MB)
    u32(elf, 1)
    u32(elf, 6)
    u64(elf, heap_file_off)
    u64(elf, HEAP_VA())
    u64(elf, HEAP_VA())
    u64(elf, heap_filesz)
    u64(elf, HEAP_SZ())
    u64(elf, 4096)

    pad(elf, text_file_off)
    copy(elf, text)
    pad(elf, data_file_off)
    copy(elf, data_bytes)
    pad(elf, heap_file_off)
    zeros(elf, heap_filesz)

    returner elf
}

// ─── Inngangspunkt ───────────────────────────────────────────────────────────
funksjon start() {
    la inp = miljo_hent("NC_INPUT")
    la out = miljo_hent("NC_OUTPUT")
    hvis inp == ""
        skriv("native_codegen_v2: NC_INPUT=fil.ncb.json NC_OUTPUT=fil\n")
        returner 1
    slutt
    hvis out == "" { out = "a.out" }
    skriv("native_codegen_v2: " + inp + " → " + out + "\n")
    la ncb_json = fil_les(inp)
    la bytes = kompiler_v2(ncb_json)
    fil_skriv_binær(out, bytes)
    skriv("native_codegen_v2: " + tekst_fra_heltall(lengde(bytes)) + " bytes\n")
    returner 0
slutt
}

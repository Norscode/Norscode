// NCB -> statisk Linux arm64 ELF via den felles arm64-instruksjonsflata.

bruk selfhost.native_execution.macho_arm64_codegen som arm64
bruk selfhost.native_execution.elf_arm64_emitter som elf

funksjon kompiler_ncb(ncb, output: tekst) -> ordbok_tekst {
    la entry = ncb["entry"]
    la funksjonar = ncb["functions"]
    hvis entry == null eller funksjonar == null eller funksjonar[entry] == null {
        returner {"ok": "usann", "error": "NCB manglar gyldig entry", "format": "ELF64 AArch64", "image": []}
    }
    la utvida = arm64.inline_kall(funksjonar[entry]["code"], funksjonar, "entry_", sann, 0)
    hvis utvida["ok"] != "sann" {
        returner {"ok": "usann", "error": utvida["error"], "format": "ELF64 AArch64", "image": []}
    }
    la native = arm64.kompiler_arm64(utvida["code"])
    hvis native["ok"] != "sann" {
        returner {"ok": "usann", "error": native["error"], "format": "ELF64 AArch64", "image": []}
    }
    la image = elf.bygg_program(native["image"])
    builtin.fil_skriv_binær(output, image)
    returner {"ok": "sann", "error": "", "format": "ELF64 AArch64", "image": image, "output": output}
}

funksjon shell(sti: tekst) -> tekst {
    returner "'" + builtin.replace(sti, "'", "'\"'\"'") + "'"
}

funksjon start() -> heiltall {
    la input = miljo_hent("NC_INPUT")
    la output = miljo_hent("NC_OUTPUT")
    hvis input == "" eller output == "" {
        skriv("elf_arm64_codegen: NC_INPUT og NC_OUTPUT er påkravde\n")
        returner 2
    }
    la resultat = kompiler_ncb(builtin.json_parse_raw(builtin.fil_les(input)), output)
    hvis resultat["ok"] != "sann" { kast resultat["error"] }
    hvis exec_prosess("chmod +x " + shell(output))[0] != "0" { returner 1 }
    skriv("elf_arm64_codegen: ELF64 AArch64 skrive til " + output + "\n")
    returner 0
}

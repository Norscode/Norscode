// Norscode-eigd runtimeinngang for NCB-payloadar i den køyrbare binæren.
// Payloaden blir parsea og køyrd direkte frå minnet; ingen ekstern NCB-fil
// blir oppretta eller lesen. Fram til stage0-seeden får denne inngangen som
// native startfunksjon, kan brua kallast med NORSCODE_EXECUTABLE og
// NORSCODE_EMBED_PAYLOAD.

bruk selfhost.native_execution.embedded_ncb_image som image
bruk selfhost.vm som vm
bruk std.bytes som bytes

funksjon env(namn: tekst) -> tekst {
    prøv { returner miljo_hent(namn) } fang (e) { returner "" }
    returner ""
}

funksjon køyr_payload_bytes(binær: liste_heiltall, payload_namn: tekst) -> heiltall {
    hvis payload_namn == "" { kast "Innebygd runtime krev payloadnamn" }
    la ncb_json = ""
    hvis image.har_image(binær) {
        ncb_json = image.hent(binær, payload_namn)
    } ellers hvis image.stream_har_image(binær) {
        ncb_json = image.hent_stream_bytes(binær, payload_namn)
    } ellers {
        ncb_json = image.hent_stream_tekst(binær, payload_namn)
    }
    la ncb = builtin.json_parse_raw(ncb_json)
    hvis ncb == null eller ncb["entry"] == null eller ncb["functions"] == null {
        kast "Innebygd payload er ikkje gyldig NCB: " + payload_namn
    }
    returner vm.køyr_ncb(ncb)
}

funksjon køyr_payload_tekst(binær: tekst, payload_namn: tekst) -> heiltall {
    hvis payload_namn == "" { kast "Innebygd runtime krev payloadnamn" }
    la ncb_json = image.hent_tekst_auto(binær, payload_namn)
    la ncb = builtin.json_parse_raw(ncb_json)
    hvis ncb == null eller ncb["entry"] == null eller ncb["functions"] == null {
        kast "Innebygd payload er ikkje gyldig NCB: " + payload_namn
    }
    returner vm.køyr_ncb(ncb)
}

funksjon køyr_payload_fil(binær_sti: tekst, payload_namn: tekst) -> heiltall {
    hvis binær_sti == "" { kast "Innebygd runtime krev binærsti" }
    // Stream-image er lagt til som tekstsluttmarkør. Les den direkte som
    // tekst først slik at ein stor compiler-NCB ikkje blir konvertert til ei
    // millionstor liste med VM-verdiar. Eldre binær-image fell tilbake til
    // bytes-vegen under.
    prøv {
        la tekstbinær = builtin.fil_les(binær_sti)
        hvis image.stream_har_image(tekstbinær) {
            returner køyr_payload_tekst(tekstbinær, payload_namn)
        }
    } fang (e) { }
    returner køyr_payload_bytes(builtin.fil_les_binær(binær_sti), payload_namn)
}

funksjon køyr_payload_fil_tekst(binær_sti: tekst, payload_namn: tekst) -> heiltall {
    hvis binær_sti == "" { kast "Innebygd runtime krev binærsti" }
    returner køyr_payload_tekst(builtin.fil_les(binær_sti), payload_namn)
}

funksjon start() -> heiltall {
    la binær_sti = env("NORSCODE_EXECUTABLE")
    la payload_namn = env("NORSCODE_EMBED_PAYLOAD")
    hvis binær_sti == "" eller payload_namn == "" {
        skriv("embedded_runtime_entry: NORSCODE_EXECUTABLE og NORSCODE_EMBED_PAYLOAD er påkravde\n")
        returner 2
    }
    hvis env("NORSCODE_NATIVE_BINARY_TEXT") == "1" {
        returner køyr_payload_fil_tekst(binær_sti, payload_namn)
    }
    returner køyr_payload_fil(binær_sti, payload_namn)
}

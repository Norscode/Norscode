# Deterministic native selfhost phase

struktur DeterministicExecutionReplay
    replay_sequences
    verified_replays
    divergence_points
slutt

struktur NativeBinaryConvergence
    observed_binaries
    convergence_cycles
    stable_binaries
slutt

struktur ExecutableIdentityLock
    locked_hashes
    identity_signatures
    stable_identities
slutt

struktur RecursiveCompilerStabilizer
    stabilization_rounds
    stabilized_compilers
    unstable_rounds
slutt

struktur StableNativeRebuildLoop
    rebuild_iterations
    stable_iterations
    rebuild_history
slutt

struktur CompilerBinaryEquivalence
    equivalent_binaries
    non_equivalent_binaries
    equivalence_hashes
slutt

struktur RuntimeReplayVerifier
    verified_runtime_replays
    failed_runtime_replays
    replay_hashes
slutt

struktur AutonomousEvolutionTracker
    observed_generations
    evolution_events
    stabilized_evolution
slutt

struktur NativeSelfhostState
    current_generation
    stable_generation
    active_rebuilds
slutt

struktur DeterministicExecutionIdentity
    execution_hash
    replay_hash
    stable_execution
slutt

funksjon ny_deterministic_execution_replay()
    replay = DeterministicExecutionReplay()

    replay.replay_sequences = []
    replay.verified_replays = []
    replay.divergence_points = []

    returner replay
slutt

funksjon replay_native_execution(replay, binary)
    hvis replay == null
        kast "Deterministic execution replay mangler"
    slutt

    hash = (
        "replay-" +
        tekst(lengde(replay.replay_sequences))
    )

    legg_til(
        replay.replay_sequences,
        binary
    )

    legg_til(
        replay.verified_replays,
        hash
    )

    returner hash
slutt

funksjon ny_native_binary_convergence()
    convergence = NativeBinaryConvergence()

    convergence.observed_binaries = []
    convergence.convergence_cycles = 0
    convergence.stable_binaries = []

    returner convergence
slutt

funksjon observe_native_binary(convergence, hash)
    hvis convergence == null
        kast "Native binary convergence mangler"
    slutt

    legg_til(
        convergence.observed_binaries,
        hash
    )

    hvis lengde(convergence.observed_binaries) > 1
        forrige = convergence.observed_binaries[
            lengde(convergence.observed_binaries) - 2
        ]

        hvis forrige == hash
            convergence.convergence_cycles = (
                convergence.convergence_cycles + 1
            )

            legg_til(
                convergence.stable_binaries,
                hash
            )
        slutt
    slutt

    returner convergence.convergence_cycles
slutt

funksjon ny_executable_identity_lock()
    lock = ExecutableIdentityLock()

    lock.locked_hashes = []
    lock.identity_signatures = []
    lock.stable_identities = []

    returner lock
slutt

funksjon lock_executable_identity(lock, hash)
    hvis lock == null
        kast "Executable identity lock mangler"
    slutt

    signature = (
        "identity-" + hash
    )

    legg_til(
        lock.locked_hashes,
        hash
    )

    legg_til(
        lock.identity_signatures,
        signature
    )

    legg_til(
        lock.stable_identities,
        hash
    )

    returner signature
slutt

funksjon ny_recursive_compiler_stabilizer()
    stabilizer = RecursiveCompilerStabilizer()

    stabilizer.stabilization_rounds = []
    stabilizer.stabilized_compilers = []
    stabilizer.unstable_rounds = []

    returner stabilizer
slutt

funksjon stabilize_recursive_compiler(stabilizer, compiler_hash)
    hvis stabilizer == null
        kast "Recursive compiler stabilizer mangler"
    slutt

    legg_til(
        stabilizer.stabilization_rounds,
        compiler_hash
    )

    hvis lengde(stabilizer.stabilization_rounds) > 1
        forrige = stabilizer.stabilization_rounds[
            lengde(stabilizer.stabilization_rounds) - 2
        ]

        hvis forrige == compiler_hash
            legg_til(
                stabilizer.stabilized_compilers,
                compiler_hash
            )
        ellers
            legg_til(
                stabilizer.unstable_rounds,
                compiler_hash
            )
        slutt
    slutt

    returner compiler_hash
slutt

funksjon ny_stable_native_rebuild_loop()
    loop = StableNativeRebuildLoop()

    loop.rebuild_iterations = 0
    loop.stable_iterations = 0
    loop.rebuild_history = []

    returner loop
slutt

funksjon stable_native_rebuild(loop, compiler, source)
    hvis loop == null
        kast "Stable native rebuild loop mangler"
    slutt

    binary = execute_self_rebuild_session(
        ny_self_rebuild_session(),
        compiler,
        source
    )

    legg_til(
        loop.rebuild_history,
        binary
    )

    loop.rebuild_iterations = (
        loop.rebuild_iterations + 1
    )

    hvis loop.rebuild_iterations > 1
        loop.stable_iterations = (
            loop.stable_iterations + 1
        )
    slutt

    returner binary
slutt

funksjon ny_compiler_binary_equivalence()
    equivalence = CompilerBinaryEquivalence()

    equivalence.equivalent_binaries = []
    equivalence.non_equivalent_binaries = []
    equivalence.equivalence_hashes = []

    returner equivalence
slutt

funksjon verify_binary_equivalence(equivalence, hash_a, hash_b)
    hvis equivalence == null
        kast "Compiler binary equivalence mangler"
    slutt

    sammen = (hash_a == hash_b)

    hvis sammen
        legg_til(
            equivalence.equivalent_binaries,
            hash_a
        )
    ellers
        legg_til(
            equivalence.non_equivalent_binaries,
            hash_a
        )
    slutt

    legg_til(
        equivalence.equivalence_hashes,
        {
            left: hash_a,
            right: hash_b
        }
    )

    returner sammen
slutt

funksjon ny_runtime_replay_verifier()
    verifier = RuntimeReplayVerifier()

    verifier.verified_runtime_replays = []
    verifier.failed_runtime_replays = []
    verifier.replay_hashes = []

    returner verifier
slutt

funksjon verify_runtime_replay(verifier, replay_hash, expected_hash)
    hvis verifier == null
        kast "Runtime replay verifier mangler"
    slutt

    hvis replay_hash == expected_hash
        legg_til(
            verifier.verified_runtime_replays,
            replay_hash
        )
    ellers
        legg_til(
            verifier.failed_runtime_replays,
            replay_hash
        )
    slutt

    legg_til(
        verifier.replay_hashes,
        replay_hash
    )

    returner replay_hash == expected_hash
slutt

funksjon ny_autonomous_evolution_tracker()
    tracker = AutonomousEvolutionTracker()

    tracker.observed_generations = []
    tracker.evolution_events = []
    tracker.stabilized_evolution = 0

    returner tracker
slutt

funksjon track_compiler_evolution(tracker, generation)
    hvis tracker == null
        kast "Autonomous evolution tracker mangler"
    slutt

    legg_til(
        tracker.observed_generations,
        generation
    )

    legg_til(
        tracker.evolution_events,
        {
            generation: generation,
            state: "evolved"
        }
    )

    tracker.stabilized_evolution = (
        tracker.stabilized_evolution + 1
    )

    returner tracker.stabilized_evolution
slutt

funksjon ny_native_selfhost_state()
    state = NativeSelfhostState()

    state.current_generation = 0
    state.stable_generation = 0
    state.active_rebuilds = []

    returner state
slutt

funksjon advance_selfhost_generation(state, rebuild)
    hvis state == null
        kast "Native selfhost state mangler"
    slutt

    state.current_generation = (
        state.current_generation + 1
    )

    legg_til(
        state.active_rebuilds,
        rebuild
    )

    hvis state.current_generation > 1
        state.stable_generation = (
            state.stable_generation + 1
        )
    slutt

    returner state.current_generation
slutt

funksjon ny_deterministic_execution_identity()
    identity = DeterministicExecutionIdentity()

    identity.execution_hash = ""
    identity.replay_hash = ""
    identity.stable_execution = usann

    returner identity
slutt

funksjon establish_execution_identity(identity, execution_hash, replay_hash)
    hvis identity == null
        kast "Deterministic execution identity mangler"
    slutt

    identity.execution_hash = execution_hash
    identity.replay_hash = replay_hash

    hvis execution_hash == replay_hash
        identity.stable_execution = sann
    slutt

    returner identity.stable_execution
slutt

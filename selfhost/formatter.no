// Norscode Python-fri formaterer
// Token-basert formatering utan AST-parsing

bruk selfhost.lexer.lexer_m1

funksjon er_operator_type(type: tekst) -> bool {
    returner type == "PLUS" eller type == "MINUS" eller type == "MUL" eller
             type == "DIV" eller type == "PERCENT" eller type == "ASSIGN" eller
             type == "EQ" eller type == "NE" eller type == "LT" eller
             type == "LTE" eller type == "GT" eller type == "GTE" eller
             type == "ARROW" eller type == "PLUS_ASSIGN" eller type == "MINUS_ASSIGN" eller
             type == "BAND" eller type == "BOR" eller type == "BXOR"
}

funksjon er_nøkkelord(type: tekst) -> bool {
    returner type == "FUNKSJON" eller type == "FUN" eller type == "LA" eller
             type == "RETURNER" eller type == "HVIS" eller type == "ELLERS" eller
             type == "MENS" eller type == "FOR" eller type == "BRYT" eller
             type == "FORTSETT" eller type == "KAST" eller type == "PROV" eller
             type == "FANG" eller type == "BRUK" eller type == "SOM" eller
             type == "ASYNC" eller type == "AWAIT" eller type == "MATCH" eller
             type == "CASE" eller type == "TIL" eller type == "STEG" eller
             type == "I" eller type == "STRUKTUR" eller type == "TEST" eller
             type == "SLUTT" eller type == "OG" eller type == "ELLER" eller type == "IKKE"
}

funksjon indenter(djupn: heltall) -> tekst {
    la ut = ""
    la i = 0
    mens (i < djupn) {
        ut = ut + "    "
        i = i + 1
    }
    returner ut
}

funksjon escape_tekst_for_kjelde(verdi: tekst) -> tekst {
    la ut = ""
    la i = 0
    mens (i < lengde(verdi)) {
        la tegn = verdi[i]
        hvis (tegn == "\\") {
            ut = ut + "\\\\"
        } ellers hvis (tegn == "\"") {
            ut = ut + "\\\""
        } ellers hvis (tegn == "\n") {
            ut = ut + "\\n"
        } ellers hvis (tegn == "\t") {
            ut = ut + "\\t"
        } ellers hvis (tegn == builtin.chr(13)) {
            ut = ut + "\\r"
        } ellers hvis (tegn == builtin.chr(0)) {
            ut = ut + "\\0"
        } ellers {
            ut = ut + tegn
        }
        i = i + 1
    }
    returner ut
}

funksjon finn_kommentarar(kjelde: tekst) -> liste<ordbok<tekst, tekst>> {
    la kommentarar: liste<ordbok<tekst, tekst>> = []
    la i = 0
    la linje = 1
    la kolonne = 1
    la sitat = ""

    mens (i < lengde(kjelde)) {
        la tegn = kjelde[i]
        hvis (lengde(sitat) > 0) {
            hvis (tegn == "\\" og i + 1 < lengde(kjelde)) {
                i = i + 2
                kolonne = kolonne + 2
                fortsett
            }
            hvis (tegn == sitat) { sitat = "" }
        } ellers hvis (tegn == "\"" eller tegn == "'") {
            sitat = tegn
        } ellers hvis (tegn == "#" eller (tegn == "/" og i + 1 < lengde(kjelde) og kjelde[i + 1] == "/")) {
            la start = i
            la start_kolonne = kolonne
            mens (i < lengde(kjelde) og kjelde[i] != "\n") {
                i = i + 1
                kolonne = kolonne + 1
            }
            legg_til(kommentarar, {
                "type": "COMMENT",
                "value": deltekst(kjelde, start, i),
                "line": tekst_fra_heltall(linje),
                "column": tekst_fra_heltall(start_kolonne)
            })
            fortsett
        }

        hvis (tegn == "\n") {
            linje = linje + 1
            kolonne = 1
        } ellers {
            kolonne = kolonne + 1
        }
        i = i + 1
    }
    returner kommentarar
}

funksjon token_før(a: ordbok<tekst, tekst>, b: ordbok<tekst, tekst>) -> bool {
    la a_linje = heltall_fra_tekst(a["line"])
    la b_linje = heltall_fra_tekst(b["line"])
    hvis (a_linje != b_linje) { returner a_linje < b_linje }
    returner heltall_fra_tekst(a["column"]) < heltall_fra_tekst(b["column"])
}

funksjon flett_kommentarar(tokens: liste<ordbok<tekst, tekst>>, kommentarar: liste<ordbok<tekst, tekst>>) -> liste<ordbok<tekst, tekst>> {
    la ut: liste<ordbok<tekst, tekst>> = []
    la ti = 0
    la ki = 0
    mens (ti < lengde(tokens) eller ki < lengde(kommentarar)) {
        hvis (ki >= lengde(kommentarar)) {
            legg_til(ut, tokens[ti])
            ti = ti + 1
        } ellers hvis (ti >= lengde(tokens) eller token_før(kommentarar[ki], tokens[ti])) {
            legg_til(ut, kommentarar[ki])
            ki = ki + 1
        } ellers {
            legg_til(ut, tokens[ti])
            ti = ti + 1
        }
    }
    returner ut
}

funksjon format_kjelde(kilde: tekst) -> tekst {
    la tokens = flett_kommentarar(lex(kilde), finn_kommentarar(kilde))
    la ut = ""
    la djupn = 0
    la forrige_type = ""
    la forrige_linje = 1
    la i = 0
    la n = lengde(tokens)

    mens (i < n) {
        la tok = tokens[i]
        la type = tok["type"]
        la verdi = tok["value"]
        la tok_linje = heltall_fra_tekst(tok["line"])

        hvis (type == "EOF") {
            i = i + 1
            fortsett
        }

        la er_ny_linje = tok_linje > forrige_linje og lengde(ut) > 0

        hvis (er_ny_linje) {
            la nl = tok_linje - forrige_linje
            hvis (nl > 2) { nl = 2 }
            la j = 0
            mens (j < nl) {
                ut = ut + "\n"
                j = j + 1
            }
            la linje_djupn = djupn
            hvis (type == "RBRACE") {
                linje_djupn = djupn - 1
                hvis (linje_djupn < 0) { linje_djupn = 0 }
            }
            ut = ut + indenter(linje_djupn)
        } ellers hvis (lengde(ut) > 0 og tok_linje == forrige_linje) {
            la treng_sp = usann

            hvis (er_operator_type(forrige_type) eller forrige_type == "COMMA" eller
                  forrige_type == "COLON" eller er_nøkkelord(forrige_type)) {
                treng_sp = sann
            }
            hvis (er_operator_type(type) eller (er_nøkkelord(type) og
                  type != "OG" og type != "ELLER" og type != "IKKE")) {
                treng_sp = sann
            }
            hvis (type == "LBRACE" og forrige_type != "") {
                treng_sp = sann
            }
            hvis (forrige_type == "LBRACE" eller forrige_type == "LPAREN" eller
                  forrige_type == "LBRACKET") {
                treng_sp = usann
            }
            hvis (type == "RPAREN" eller type == "RBRACKET" eller type == "RBRACE" eller
                  type == "COMMA" eller type == "DOT" eller type == "COLON") {
                treng_sp = usann
            }
            hvis (forrige_type == "DOT") {
                treng_sp = usann
            }

            hvis (type == "COMMENT") {
                ut = ut + "  "
                treng_sp = usann
            }

            hvis (treng_sp) { ut = ut + " " }
        }

        hvis (type == "LBRACE") {
            djupn = djupn + 1
        }
        hvis (type == "RBRACE") {
            djupn = djupn - 1
            hvis (djupn < 0) { djupn = 0 }
        }

        hvis (type == "STRING") {
            ut = ut + "\"" + escape_tekst_for_kjelde(verdi) + "\""
        } ellers {
            ut = ut + verdi
        }

        forrige_type = type
        forrige_linje = tok_linje
        i = i + 1
    }

    hvis (lengde(ut) > 0) {
        la siste = ut[lengde(ut) - 1]
        hvis (siste != "\n") {
            ut = ut + "\n"
        }
    }

    returner ut
}

funksjon format_fil(sti: tekst) -> tekst {
    la kilde = fil_les(sti)
    hvis (lengde(kilde) == 0) {
        kast "Kan ikkje lese fil: " + sti
    }
    returner format_kjelde(kilde)
}

funksjon start() {
    la sti = miljo_hent("NC_FORMAT_FILE")
    hvis (lengde(sti) == 0) {
        skriv("Bruk: NC_FORMAT_FILE=fil.no nc-vm --nc-run selfhost/formatter.no")
        returner
    }
    la formatert = format_fil(sti)
    la sjekk = miljo_hent("NC_FORMAT_CHECK")
    la skriv_tilbake = miljo_hent("NC_FORMAT_WRITE")
    hvis (sjekk == "1") {
        la original = fil_les(sti)
        hvis (formatert == original) {
            skriv("OK: " + sti)
        } ellers {
            skriv("IKKJE FORMATERT: " + sti)
            stopp(1)
        }
    } ellers hvis (skriv_tilbake == "1") {
        fil_skriv(sti, formatert)
        skriv("Formatert: " + sti)
    } ellers {
        skriv(formatert)
    }
}

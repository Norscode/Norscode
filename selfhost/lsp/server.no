    hvis inneheld(route_summary, "routes=") == usann
        returner usann
    slutt

    hvis inneheld(route_summary, "textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis lsp_main() != sann
        returner usann
    slutt

    hvis inneheld("LSP demo-runner starta", "LSP demo-runner") == usann
        returner usann
    slutt

    returner sann
slutt

funksjon hoved()
    hvis lsp_stdio_main()
        returner sann
    ellers
        returner usann
    slutt
slutt

funksjon main()
    returner hoved()
slutt

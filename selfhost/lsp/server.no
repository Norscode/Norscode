# Fase 5 - LSP grunnmur
# Minimal JSON-RPC-flate for seinare utviding.

bruk std.sys som sys

funksjon lsp_server()
    returner {
        initialized: usann,
        documents: {},
        document_versions: {},
        diagnostics: {},
        methods: []
    }
slutt

funksjon lsp_initialize(server)
    server.initialized = sann
    returner '{"jsonrpc":"2.0","result":{"capabilities":{"textDocumentSync":1,"hoverProvider":true,"definitionProvider":true,"completionProvider":true}}}'
slutt

funksjon lsp_capabilities_summary()
    returner "textDocumentSync=1, hoverProvider=true, definitionProvider=true, completionProvider=true"
slutt

funksjon lsp_notifications_summary()
    returner "notifications=textDocument/publishDiagnostics"
slutt

funksjon lsp_notifications_count_summary(session)
    returner "notifications_count=" + til_tekst(lengde(session.notifications))
slutt

funksjon lsp_notifications_health_summary(session)
    hvis lengde(session.notifications) == 0
        returner "notifications_health=idle"
    slutt
    returner "notifications_health=active"
slutt

funksjon lsp_notifications_overview_summary(session)
    returner lsp_notifications_count_summary(session) + " | " + lsp_notifications_health_summary(session)
slutt

funksjon lsp_notification_type_summary(notification)
    hvis inneheld(notification, "textDocument/publishDiagnostics")
        returner "notification=textDocument/publishDiagnostics"
    slutt
    returner "notification=unknown"
slutt

funksjon lsp_output_summary(server, session)
    returner "output=responses:" + til_tekst(lengde(session.responses)) + ", notifications:" + til_tekst(lengde(session.notifications)) + ", documents:" + til_tekst(lengde(server.documents))
slutt

funksjon lsp_document_health_summary(server)
    la keys = ordbok_nyklar(server.documents)
    hvis lengde(keys) == 0
        returner "document_health=empty"
    slutt

    la healthy = 0
    la i = 0
    mens i < lengde(keys)
        la path = keys[i]
        la probe = lsp_semantic_probe_from_document(server, path)
        hvis probe.ok
            healthy = healthy + 1
        slutt
        i = i + 1
    slutt

    returner "document_health=" + til_tekst(healthy) + "/" + til_tekst(lengde(keys))
slutt

funksjon lsp_document_health_state_summary(server)
    la health = lsp_document_health_summary(server)
    hvis inneheld(health, "document_health=empty")
        returner "document_health_state=empty"
    slutt
    hvis inneheld(health, "0/")
        returner "document_health_state=unhealthy"
    slutt
    hvis inneheld(health, "/")
        returner "document_health_state=partial"
    slutt
    returner "document_health_state=unknown"
slutt

funksjon lsp_document_versions_summary(server)
    la keys = ordbok_nyklar(server.document_versions)
    hvis lengde(keys) == 0
        returner "document_versions=empty"
    slutt

    la total = 0
    la i = 0
    mens i < lengde(keys)
        total = total + lsp_document_version(server, keys[i])
        i = i + 1
    slutt

    returner "document_versions=" + til_tekst(lengde(keys)) + ", total=" + til_tekst(total)
slutt

funksjon lsp_latest_document_version_summary(server)
    la keys = ordbok_nyklar(server.document_versions)
    hvis lengde(keys) == 0
        returner "latest_document_version=empty"
    slutt

    la latest_path = keys[0]
    la latest_version = lsp_document_version(server, latest_path)
    la i = 1
    mens i < lengde(keys)
        la path = keys[i]
        la v = lsp_document_version(server, path)
        hvis v > latest_version
            latest_version = v
            latest_path = path
        slutt
        i = i + 1
    slutt

    returner "latest_document_version=" + latest_path + "@" + til_tekst(latest_version)
slutt

funksjon lsp_version_health_summary(server)
    la versions = lsp_document_versions_summary(server)
    hvis inneheld(versions, "document_versions=empty")
        returner "version_health=empty"
    slutt
    hvis inneheld(versions, "total=0")
        returner "version_health=stalled"
    slutt
    hvis inneheld(versions, "total=")
        returner "version_health=active"
    slutt
    returner "version_health=unknown"
slutt

funksjon lsp_transport_summary()
    returner "transport=batch/session,json-batch-stdio,content-length"
slutt

funksjon lsp_io_summary()
    returner "io=json-batch-stdio,content-length"
slutt

funksjon lsp_framing_summary()
    returner "framing=json-batch+content-length"
slutt

funksjon lsp_entrypoint_summary()
    returner "entrypoint=lsp_stdio_main"
slutt

funksjon lsp_transport_overview_summary()
    returner lsp_transport_summary() + " | " + lsp_io_summary() + " | " + lsp_framing_summary()
slutt

funksjon lsp_message_count_summary(session)
    returner "messages=" + til_tekst(lengde(session.responses) + lengde(session.notifications))
slutt

funksjon lsp_session_methods_summary(session)
    hvis lengde(session.methods) == 0
        returner "session_methods=empty"
    slutt
    returner "session_methods=" + til_tekst(lengde(session.methods))
slutt

funksjon lsp_activity_summary(session)
    returner lsp_message_count_summary(session) + " | " + lsp_session_methods_summary(session)
slutt

funksjon lsp_activity_health_summary(session)
    hvis lengde(session.methods) == 0
        returner "activity_health=idle"
    slutt
    hvis lengde(session.notifications) == 0
        returner "activity_health=quiet"
    slutt
    returner "activity_health=active"
slutt

funksjon lsp_overall_health_summary(server, session)
    returner lsp_document_health_state_summary(server) + " | " + lsp_activity_health_summary(session) + " | " + lsp_notifications_health_summary(session) + " | " + lsp_version_health_summary(server)
slutt

funksjon lsp_top_status_summary(server, session)
    returner "top_status=" + lsp_overall_health_summary(server, session)
slutt

funksjon lsp_banner_summary(server, session)
    la status = lsp_top_status_summary(server, session)
    hvis inneheld(status, "document_health_state=empty") eller inneheld(status, "activity_health=idle")
        returner "banner=uklar"
    slutt
    hvis inneheld(status, "version_health=stalled")
        returner "banner=delvis"
    slutt
    hvis inneheld(status, "activity_health=quiet") eller inneheld(status, "notifications_health=idle")
        returner "banner=delvis"
    slutt
    returner "banner=klar"
slutt

funksjon lsp_document_exists_summary(server, path)
    hvis lsp_has_document(server, path)
        returner "document_exists=true"
    slutt
    returner "document_exists=false"
slutt

funksjon lsp_document_version_summary(server, path)
    returner "document_version=" + til_tekst(lsp_document_version(server, path))
slutt

funksjon lsp_full_summary(server, session, probe)
    returner lsp_protocol_summary(server, session, probe) + " | full=ok"
slutt

funksjon lsp_route_summary()
    returner "routes=initialize/didOpen/didChange/hover/definition/completion/textDocument/publishDiagnostics/shutdown/exit"
slutt

funksjon lsp_supported_methods_summary()
    returner "initialize,didOpen,didChange,hover,definition,completion,textDocument/publishDiagnostics,shutdown,exit"
slutt

funksjon lsp_open_document(server, path, content)
    server.documents[path] = content
    hvis server.document_versions[path] == null
        server.document_versions[path] = 0
    slutt
    server.document_versions[path] = server.document_versions[path] + 1
    hvis server.diagnostics[path] == null
        server.diagnostics[path] = []
    slutt
    returner sann
slutt

funksjon lsp_publish_diagnostic(server, path, diagnostic)
    hvis server.diagnostics[path] == null
        server.diagnostics[path] = []
    slutt
    legg_til(server.diagnostics[path], diagnostic)
    returner sann
slutt

funksjon lsp_clear_diagnostics(server, path)
    server.diagnostics[path] = []
    returner sann
slutt

funksjon lsp_document_version(server, path)
    hvis server.document_versions[path] == null
        returner 0
    slutt
    returner server.document_versions[path]
slutt

funksjon lsp_has_document(server, path)
    hvis server.documents[path] == null
        returner usann
    slutt
    returner sann
slutt

funksjon lsp_validate_document(server, path, content)
    lsp_clear_diagnostics(server, path)

    la probe = lsp_semantic_probe_from_document(server, path)
    hvis probe.ok
        returner sann
    slutt

    lsp_publish_diagnostic(server, path, {
        message: probe.message,
        severity: probe.severity,
        source: "norscode-lsp"
    })
    returner usann
slutt

funksjon lsp_semantic_probe_from_document(server, path)
    hvis lsp_has_document(server, path) == usann
        returner {
            ok: usann,
            severity: 1,
            message: "Dokumentet finst ikkje i servertilstand"
        }
    slutt
    returner lsp_semantic_probe(server.documents[path])
slutt

funksjon lsp_semantic_probe(content)
    hvis inneheld(content, "returner") og inneheld(content, "funksjon") == usann
        returner {
            ok: usann,
            severity: 1,
            message: "returner utanfor funksjon"
        }
    slutt

    hvis inneheld(content, "funksjon") == usann
        returner {
            ok: usann,
            severity: 1,
            message: "Dokumentet manglar nøkkelordet funksjon"
        }
    slutt

    hvis inneheld(content, "feil")
        returner {
            ok: usann,
            severity: 2,
            message: "Funne ordet feil i dokumentet"
        }
    slutt

    returner {
        ok: sann,
        severity: 0,
        message: "OK"
    }
slutt

funksjon lsp_semantic_probe_summary(probe)
    returner "ok=" + til_tekst(probe.ok) + ", severity=" + til_tekst(probe.severity) + ", message=" + probe.message
slutt

funksjon lsp_document_summary(server)
    la doc_count = lengde(server.documents)
    la version_count = lengde(server.document_versions)
    la diag_count = 0
    la keys = ordbok_nyklar(server.diagnostics)
    la i = 0
    mens i < lengde(keys)
        diag_count = diag_count + lengde(server.diagnostics[keys[i]])
        i = i + 1
    slutt
    returner "documents=" + til_tekst(doc_count) + ", diagnostics=" + til_tekst(diag_count) + ", versions=" + til_tekst(version_count)
slutt

funksjon lsp_state_summary(server, session, probe)
    la docs = lsp_document_summary(server)
    la versions = lsp_document_versions_summary(server)
    la latest_version = lsp_latest_document_version_summary(server)
    la sess = lsp_session_summary(session)
    la probe_text = lsp_semantic_probe_summary(probe)
    la notifications_health = lsp_notifications_health_summary(session)
    la notifications_overview = lsp_notifications_overview_summary(session)
    returner docs + " | " + versions + " | " + latest_version + " | " + sess + " | methods_seen=" + til_tekst(lengde(server.methods)) + " | session_methods=" + til_tekst(lengde(session.methods)) + " | " + notifications_health + " | " + notifications_overview + " | " + probe_text + " | caps=" + lsp_capabilities_summary()
slutt

funksjon lsp_protocol_summary(server, session, probe)
    la state = lsp_state_summary(server, session, probe)
    la notifications = lsp_notifications_summary()
    la notifications_count = lsp_notifications_count_summary(session)
    la notifications_health = lsp_notifications_health_summary(session)
    la notifications_overview = lsp_notifications_overview_summary(session)
    la transport = lsp_transport_summary()
    la methods = lsp_supported_methods_summary()
    la io = lsp_io_summary()
    la framing = lsp_framing_summary()
    la entry = lsp_entrypoint_summary()
    la messages = lsp_message_count_summary(session)
    la versions = lsp_document_versions_summary(server)
    la session_methods = "session_methods=" + til_tekst(lengde(session.methods))
    la activity_health = lsp_activity_health_summary(session)
    la doc_health_state = lsp_document_health_state_summary(server)
    la version_health = lsp_version_health_summary(server)
    returner state + " | protocol=JSON-RPC | notifications=" + notifications + " | " + notifications_count + " | " + notifications_health + " | " + notifications_overview + " | transport=" + transport + " | methods=" + methods + " | io=" + io + " | " + framing + " | entrypoint=" + entry + " | " + messages + " | " + versions + " | " + session_methods + " | " + activity_health + " | " + doc_health_state + " | " + version_health
slutt

funksjon lsp_status_bundle_summary(server, session, probe)
    la summary = lsp_session_summary(session)
    la protocol_summary = lsp_protocol_summary(server, session, probe)
    la activity_summary = lsp_activity_summary(session)
    la notifications_count_summary = lsp_notifications_count_summary(session)
    la notifications_health_summary = lsp_notifications_health_summary(session)
    la notifications_overview_summary = lsp_notifications_overview_summary(session)
    la activity_health_summary = lsp_activity_health_summary(session)
    la overall_health_summary = lsp_overall_health_summary(server, session)
    la transport_overview_summary = lsp_transport_overview_summary()
    la top_status_summary = lsp_top_status_summary(server, session)
    la banner_summary = lsp_banner_summary(server, session)
    la document_summary = lsp_document_summary(server)
    la state_summary = lsp_state_summary(server, session, probe)
    la probe_summary = lsp_semantic_probe_summary(probe)
    la output_summary = lsp_output_summary(server, session)
    la document_health_summary = lsp_document_health_summary(server)
    la document_health_state_summary = lsp_document_health_state_summary(server)
    la document_versions_summary = lsp_document_versions_summary(server)
    la latest_document_version_summary = lsp_latest_document_version_summary(server)
    la version_health_summary = lsp_version_health_summary(server)
    la stream_source_summary = lsp_stream_source_summary("", json_skriv(lsp_demo_requests()))
    la stream_mode_summary = lsp_stream_mode_summary(["a", "b"])
    la stream_overview_summary = lsp_stream_overview_summary(["a", "b"], { requests_total: 2, responses: ["{}", "{}"], notifications: [], methods: ["initialize", "shutdown"], trace: [] })
    returner summary + "\n" + protocol_summary + "\n" + activity_summary + "\n" + notifications_count_summary + "\n" + notifications_health_summary + "\n" + notifications_overview_summary + "\n" + activity_health_summary + "\n" + overall_health_summary + "\n" + transport_overview_summary + "\n" + top_status_summary + "\n" + banner_summary + "\n" + probe_summary + "\n" + document_summary + "\n" + state_summary + "\n" + output_summary + "\n" + document_health_summary + "\n" + document_health_state_summary + "\n" + document_versions_summary + "\n" + latest_document_version_summary + "\n" + version_health_summary + "\n" + stream_source_summary + "\n" + stream_mode_summary + "\n" + stream_overview_summary
slutt

funksjon lsp_format_diagnostics_notification(path, diagnostics)
    la items = "["
    la i = 0
    mens i < lengde(diagnostics)
        hvis i > 0
            items = items + ","
        slutt
        la d = diagnostics[i]
        items = items + '{"message":"' + d.message + '","severity":' + til_tekst(d.severity) + ',"source":"' + d.source + '"}'
        i = i + 1
    slutt
    items = items + "]"
    returner '{"jsonrpc":"2.0","method":"textDocument/publishDiagnostics","params":{"uri":"' + path + '","diagnostics":' + items + '}}'
slutt

funksjon lsp_hover(server, symbol)
    hvis server.initialized == usann
        returner '"LSP ikkje initialisert"'
    slutt
    returner '{"contents":{"kind":"markdown","value":"' + symbol + '"}}'
slutt

funksjon lsp_definition(server, symbol)
    hvis server.initialized == usann
        returner 'null'
    slutt
    returner '{"uri":"file:///norscode/' + symbol + '.no","range":{"start":{"line":0,"character":0},"end":{"line":0,"character":0}}}'
slutt

funksjon lsp_completion(server, prefix)
    hvis server.initialized == usann
        returner '[]'
    slutt
    returner '[{"label":"funksjon"},{"label":"hvis"},{"label":"sann"}]'
slutt

funksjon lsp_supports_method(method)
    hvis method == "shutdown" eller method == "exit" eller method == "initialize"
        returner sann
    slutt
    hvis method == "textDocument/didOpen" eller method == "textDocument/didChange" eller method == "textDocument/hover"
        returner sann
    slutt
    hvis method == "textDocument/definition" eller method == "textDocument/completion"
        returner sann
    slutt
    hvis method == "textDocument/publishDiagnostics"
        returner sann
    slutt
    returner usann
slutt

funksjon lsp_handle_request(server, method, id, params)
    hvis lsp_supports_method(method) == usann
        returner '{"jsonrpc":"2.0","id":' + id + ',"error":{"code":-32601,"message":"Metode ikkje støtta"}}'
    slutt

    hvis method == "shutdown"
        returner '{"jsonrpc":"2.0","id":' + id + ',"result":null}'
    slutt

    hvis method == "exit"
        returner ''
    slutt

    hvis method == "initialize"
        returner '{"jsonrpc":"2.0","id":' + id + ',"result":{"capabilities":{"textDocumentSync":1,"hoverProvider":true,"definitionProvider":true,"completionProvider":true}}}'
    slutt

    hvis method == "textDocument/didOpen"
        la path = params["textDocument"]["uri"]
        la content = params["textDocument"]["text"]
        lsp_open_document(server, path, content)
        lsp_validate_document(server, path, content)
        la note = lsp_format_diagnostics_notification(path, server.diagnostics[path])
        hvis note == null
            returner '{"jsonrpc":"2.0","id":' + id + ',"result":null}'
        slutt
        returner '{"jsonrpc":"2.0","id":' + id + ',"result":null}'
    slutt

    hvis method == "textDocument/didChange"
        la path = params["textDocument"]["uri"]
        la content = params["content"]
        lsp_open_document(server, path, content)
        lsp_validate_document(server, path, content)
        la note = lsp_format_diagnostics_notification(path, server.diagnostics[path])
        hvis note == null
            returner '{"jsonrpc":"2.0","id":' + id + ',"result":null}'
        slutt

        returner '{"jsonrpc":"2.0","id":' + id + ',"result":null}'
    slutt

    hvis method == "textDocument/hover"
        la sym = params["symbol"]
        returner '{"jsonrpc":"2.0","id":' + id + ',"result":' + lsp_hover(server, sym) + '}'
    slutt

    hvis method == "textDocument/definition"
        la sym = params["symbol"]
        returner '{"jsonrpc":"2.0","id":' + id + ',"result":' + lsp_definition(server, sym) + '}'
    slutt

    hvis method == "textDocument/completion"
        la prefix = params["prefix"]
        returner '{"jsonrpc":"2.0","id":' + id + ',"result":' + lsp_completion(server, prefix) + '}'
    slutt

    returner '{"jsonrpc":"2.0","id":' + id + ',"error":{"code":-32601,"message":"Metode ikkje støtta"}}'
slutt

funksjon lsp_handle_batch(server, requests)
    la responses = []
    la i = 0
    mens i < lengde(requests)
        la req = requests[i]
        legg_til(server.methods, req["method"])
        la res = lsp_handle_request(server, req["method"], req["id"], req["params"])
        legg_til(responses, res)
        i = i + 1
    slutt
    returner responses
slutt

funksjon lsp_handle_session(server, requests)
    la responses = []
    la notifications = []
    la methods = []
    la i = 0
    mens i < lengde(requests)
        la req = requests[i]
        legg_til(methods, req["method"])
        la res = lsp_handle_request(server, req["method"], req["id"], req["params"])
        legg_til(responses, res)

        hvis req["method"] == "textDocument/didOpen" eller req["method"] == "textDocument/didChange"
            la path = req["params"]["textDocument"]["uri"]
            la note = lsp_format_diagnostics_notification(path, server.diagnostics[path])
            legg_til(notifications, note)
        slutt

        i = i + 1
    slutt

    returner { responses: responses, notifications: notifications, methods: methods }
slutt

funksjon lsp_session_summary(session)
    la diagnostics_count = 0
    la version_events = 0
    la i = 0
    mens i < lengde(session.notifications)
        hvis inneheld(session.notifications[i], "textDocument/publishDiagnostics")
            diagnostics_count = diagnostics_count + 1
        slutt
        i = i + 1
    slutt
    la j = 0
    mens j < lengde(session.methods)
        hvis session.methods[j] == "textDocument/didOpen" eller session.methods[j] == "textDocument/didChange"
            version_events = version_events + 1
        slutt
        j = j + 1
    slutt
    returner "responses=" + til_tekst(lengde(session.responses)) + ", notifications=" + til_tekst(lengde(session.notifications)) + ", diagnostics=" + til_tekst(diagnostics_count) + ", version_events=" + til_tekst(version_events) + ", methods=" + til_tekst(lengde(session.methods))
slutt

funksjon lsp_trace_batch(requests, responses)
    la trace = []
    la i = 0
    mens i < lengde(requests)
        la req = requests[i]
        la res = responses[i]
        legg_til(trace, lsp_request_summary(req) + " -> " + res)
        i = i + 1
    slutt
    returner trace
slutt

funksjon lsp_request_summary(req)
    returner req["method"] + "#" + req["id"]
slutt

funksjon lsp_extract_body_from_framed_payload(payload)
    hvis inneheld(payload, "Content-Length:") == usann
        returner payload
    slutt

    la i = 0
    mens i + 3 < lengde(payload)
        hvis builtin.slice(payload, i, i + 4) == "\r\n\r\n"
            returner builtin.slice(payload, i + 4, lengde(payload))
        slutt
        hvis builtin.slice(payload, i, i + 2) == "\n\n"
            returner builtin.slice(payload, i + 2, lengde(payload))
        slutt
        i = i + 1
    slutt

    returner payload
slutt

funksjon lsp_parse_content_length(header)
    la lines = builtin.split(header, "\n")
    la i = 0
    mens i < lengde(lines)
        la line = lines[i]
        hvis inneheld(line, "Content-Length:")
            la parts = builtin.split(line, ":")
            hvis lengde(parts) >= 2
                returner heltall(builtin.trim(parts[1]))
            slutt
        slutt
        i = i + 1
    slutt
    returner 0
slutt

funksjon lsp_peel_framed_request(payload)
    hvis inneheld(payload, "Content-Length:") == usann
        returner { body: payload, rest: "" }
    slutt

    la header_end = -1
    la body_start = -1
    la i = 0
    mens i + 3 < lengde(payload)
        hvis builtin.slice(payload, i, i + 4) == "\r\n\r\n"
            header_end = i
            body_start = i + 4
            stopp
        slutt
        hvis builtin.slice(payload, i, i + 2) == "\n\n"
            header_end = i
            body_start = i + 2
            stopp
        slutt
        i = i + 1
    slutt

    hvis header_end < 0 eller body_start < 0
        returner { body: payload, rest: "" }
    slutt

    la header = builtin.slice(payload, 0, header_end)
    la body_len = lsp_parse_content_length(header)
    hvis body_len <= 0
        returner { body: builtin.slice(payload, body_start, lengde(payload)), rest: "" }
    slutt

    la body_end = body_start + body_len
    hvis body_end > lengde(payload)
        body_end = lengde(payload)
    slutt

    la body = builtin.slice(payload, body_start, body_end)
    la rest = ""
    hvis body_end < lengde(payload)
        rest = builtin.slice(payload, body_end, lengde(payload))
    slutt
    returner { body: body, rest: rest }
slutt

funksjon lsp_requests_from_stdin(payload)
    hvis payload == ""
        returner null
    slutt

    la rest = builtin.trim(payload)
    la requests = []
    la trykker = 0
    mens lengde(rest) > 0 og trykker < 64
        la part = lsp_peel_framed_request(rest)
        la body = part.body
        rest = builtin.trim(part.rest)
        hvis body == ""
            stopp
        slutt
        la parsed = json_parse_raw(body)
        hvis parsed == null
            returner null
        slutt
        hvis type(parsed) == "liste"
            la j = 0
            mens j < lengde(parsed)
                legg_til(requests, parsed[j])
                j = j + 1
            slutt
        ellers
            legg_til(requests, parsed)
        slutt
        trykker = trykker + 1
        hvis rest == ""
            stopp
        slutt
    slutt

    hvis lengde(requests) == 0
        returner null
    slutt

    returner requests
slutt

funksjon lsp_input_mode_summary(payload)
    hvis payload == ""
        returner "input_mode=empty"
    slutt
    hvis inneheld(payload, "Content-Length:")
        hvis inneheld(payload, "\r\n\r\n") eller inneheld(payload, "\n\n")
            hvis inneheld(payload, "Content-Length:") og inneheld(builtin.trim(payload), "Content-Length:") og inneheld(payload, "}\r\n\r\nContent-Length:") eller inneheld(payload, "}]Content-Length:")
                returner "input_mode=content-length-batch"
            slutt
            returner "input_mode=content-length"
        slutt
    slutt
    hvis builtin.trim(payload) == "" 
        returner "input_mode=empty"
    slutt
    hvis builtin.slice(builtin.trim(payload), 0, 1) == "[" eller builtin.slice(builtin.trim(payload), 0, 1) == "{"
        returner "input_mode=raw-json"
    slutt
    returner "input_mode=unknown"
slutt

funksjon lsp_stdio_report_summary(payload, requests)
    la mode = lsp_input_mode_summary(payload)
    la stage = "stdio"
    la kind = lsp_request_kind_summary(requests)
    hvis mode == "input_mode=empty"
        stage = "fallback"
    slutt
    hvis mode != "input_mode=empty" og lengde(requests) == 0
        stage = "decode-fallback"
    slutt
    returner "stdin_bytes=" + til_tekst(lengde(payload)) + " | " + mode + " | " + kind + " | request_count=" + til_tekst(lengde(requests)) + " | stage=" + stage
slutt

funksjon lsp_transport_probe_summary(payload, requests)
    returner lsp_stdio_report_summary(payload, requests)
slutt

funksjon lsp_request_kind_summary(requests)
    hvis requests == null
        returner "request_kind=none"
    slutt
    hvis lengde(requests) == 0
        returner "request_kind=empty"
    slutt
    hvis lengde(requests) == 1
        returner "request_kind=single"
    slutt
    returner "request_kind=batch"
slutt

funksjon lsp_stream_payloads_from_text(raw)
    hvis raw == null eller raw == ""
        returner null
    slutt

    la parsed = json_parse_raw(raw)
    hvis parsed == null
        returner null
    slutt

    hvis type(parsed) == "liste"
        hvis lengde(parsed) == 0
            returner null
        slutt
        hvis type(parsed[0]) == "tekst"
            returner parsed
        slutt
        returner null
    slutt

    hvis inneheld(raw, "\n")
        la deler = builtin.split(raw, "\n")
        la chunks = []
        la i = 0
        mens i < lengde(deler)
            la chunk = builtin.trim(deler[i])
            hvis chunk != ""
                legg_til(chunks, chunk)
            slutt
            i = i + 1
        slutt
        hvis lengde(chunks) > 0
            returner chunks
        slutt
    slutt

    returner [raw]
slutt

funksjon lsp_stream_summary(payloads)
    hvis payloads == null
        returner "stream=none"
    slutt
    returner "stream_chunks=" + til_tekst(lengde(payloads))
slutt

funksjon lsp_stream_chunk_count_summary(payloads)
    hvis payloads == null
        returner "stream_chunk_count=0"
    slutt
    returner "stream_chunk_count=" + til_tekst(lengde(payloads))
slutt

funksjon lsp_stream_overview_summary(payloads, stream_run)
    hvis payloads == null eller stream_run == null
        returner "stream_overview=none"
    slutt
    la mode = lsp_stream_mode_summary(payloads)
    returner "stream_overview=chunks=" + til_tekst(lengde(payloads)) + ", requests=" + til_tekst(stream_run.requests_total) + ", responses=" + til_tekst(lengde(stream_run.responses)) + ", notifications=" + til_tekst(lengde(stream_run.notifications)) + ", " + mode
slutt

funksjon lsp_stream_mode_summary(payloads)
    hvis payloads == null
        returner "stream_mode=none"
    slutt
    hvis type(payloads) == "liste" og lengde(payloads) > 1 og type(payloads[0]) == "tekst" og type(payloads[1]) == "tekst"
        returner "stream_mode=hybrid"
    slutt
    hvis lengde(payloads) <= 1
        returner "stream_mode=single"
    slutt
    returner "stream_mode=stream"
slutt

funksjon lsp_stream_source_summary(raw_stream, single_payload)
    la has_stream = raw_stream != null og raw_stream != ""
    la has_payload = single_payload != null og single_payload != ""
    hvis has_stream og has_payload
        returner "stream_source=NORSCODE_LSP_STREAM+NORSCODE_LSP_PAYLOAD"
    slutt
    hvis has_stream
        returner "stream_source=NORSCODE_LSP_STREAM"
    slutt
    hvis has_payload
        returner "stream_source=NORSCODE_LSP_PAYLOAD"
    slutt
    returner "stream_source=empty"
slutt

funksjon lsp_env_true(namn)
    la v = miljo_hent(namn)
    hvis v == null
        returner usann
    slutt
    la t = builtin.trim(v)
    hvis t == "1" eller t == "sann" eller t == "true" eller t == "ja"
        returner sann
    slutt
    returner usann
slutt

funksjon lsp_read_stdin_payload()
    prøv {
        returner sys.stdin_les()
    } fang (e) {
        returner ""
    }
    returner ""
slutt

funksjon lsp_read_stdin_stream_until_empty()
    la chunks = []
    la guard = 0
    mens guard < 1024
        la line = lsp_read_stdin_payload()
        hvis line == ""
            stopp
        slutt
        legg_til(chunks, line)
        guard = guard + 1
    slutt
    hvis lengde(chunks) == 0
        returner null
    slutt
    returner chunks
slutt

funksjon lsp_join_payloads(payloads)
    hvis payloads == null
        returner ""
    slutt
    hvis lengde(payloads) == 0
        returner ""
    slutt
    returner builtin.join(payloads, "\n")
slutt

funksjon lsp_run_stream_payloads(server, payloads)
    la responses = []
    la notifications = []
    la methods = []
    la trace = []
    la requests_total = 0
    la i = 0
    mens i < lengde(payloads)
        la payload = payloads[i]
        la requests = lsp_requests_from_stdin(payload)
        hvis requests == null
            returner null
        slutt

        la session = lsp_handle_session(server, requests)
        la batch_trace = lsp_trace_batch(requests, session.responses)

        la j = 0
        mens j < lengde(session.responses)
            legg_til(responses, session.responses[j])
            j = j + 1
        slutt

        la k = 0
        mens k < lengde(session.notifications)
            legg_til(notifications, session.notifications[k])
            k = k + 1
        slutt

        la m = 0
        mens m < lengde(session.methods)
            legg_til(methods, session.methods[m])
            m = m + 1
        slutt

        la t = 0
        mens t < lengde(batch_trace)
            legg_til(trace, batch_trace[t])
            t = t + 1
        slutt

        requests_total = requests_total + lengde(requests)
        i = i + 1
    slutt

    returner {
        responses: responses,
        notifications: notifications,
        methods: methods,
        trace: trace,
        requests_total: requests_total
    }
slutt

funksjon lsp_demo_requests()
    returner [
        { "method": "initialize", "id": "1", "params": {} },
        { "method": "textDocument/didOpen", "id": "2", "params": { "textDocument": { "uri": "file:///tmp/lsp.no", "text": "funksjon main()" } } },
        { "method": "textDocument/didChange", "id": "3", "params": { "textDocument": { "uri": "file:///tmp/lsp.no" }, "content": "funksjon main() feil" } },
        { "method": "textDocument/hover", "id": "4", "params": { "symbol": "main" } },
        { "method": "textDocument/definition", "id": "5", "params": { "symbol": "main" } },
        { "method": "textDocument/completion", "id": "6", "params": { "prefix": "ma" } },
        { "method": "shutdown", "id": "7", "params": {} }
    ]
slutt

funksjon lsp_main()
    la server = lsp_server()
    la requests = lsp_demo_requests()
    la stream_source_summary = lsp_stream_source_summary("", json_skriv(requests))
    la input_mode_summary = lsp_input_mode_summary(json_skriv(requests))
    la request_kind_summary = lsp_request_kind_summary(requests)
    la transport_report = lsp_stdio_report_summary(json_skriv(requests), requests)
    la responses = lsp_handle_batch(server, requests)
    la session = lsp_handle_session(server, requests)
    la trace = lsp_trace_batch(requests, responses)
    la summary = lsp_session_summary(session)
    la probe_summary = lsp_semantic_probe_summary(lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))
    la document_summary = lsp_document_summary(server)
    la state_summary = lsp_state_summary(server, session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))
    la caps_summary = lsp_capabilities_summary()
    la protocol_summary = lsp_protocol_summary(server, session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))
    la notifications_summary = lsp_notifications_summary()
    la transport_summary = lsp_transport_summary()
    la methods_summary = lsp_supported_methods_summary()
    la io_summary = lsp_io_summary()
    la framing_summary = lsp_framing_summary()
    la entrypoint_summary = lsp_entrypoint_summary()
    la messages_summary = lsp_message_count_summary(session)
    la session_methods_summary = lsp_session_methods_summary(session)
    la activity_summary = lsp_activity_summary(session)
    la activity_health_summary = lsp_activity_health_summary(session)
    la overall_health_summary = lsp_overall_health_summary(server, session)
    la top_status_summary = lsp_top_status_summary(server, session)
    la banner_summary = lsp_banner_summary(server, session)
    la full_summary = lsp_full_summary(server, session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))
    la route_summary = lsp_route_summary()
    la doc_exists_summary = lsp_document_exists_summary(server, "file:///tmp/lsp.no")
    la doc_version_summary = lsp_document_version_summary(server, "file:///tmp/lsp.no")
    la notification_type_summary = lsp_notification_type_summary(session.notifications[0])
    la output_summary = lsp_output_summary(server, session)
    la document_health_summary = lsp_document_health_summary(server)
    la document_health_state_summary = lsp_document_health_state_summary(server)
    la document_versions_summary = lsp_document_versions_summary(server)
    la latest_document_version_summary = lsp_latest_document_version_summary(server)
    la version_health_summary = lsp_version_health_summary(server)
    la status_bundle = lsp_status_bundle_summary(server, session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))

    skriv("=== lsp_main ===")
    skriv("LSP demo-runner starta")
    skriv(stream_source_summary)
    skriv(input_mode_summary)
    skriv(request_kind_summary)
    skriv(transport_report)
    skriv(status_bundle)
    skriv(caps_summary)
    skriv(notifications_summary)
    skriv(transport_summary)
    skriv(methods_summary)
    skriv(io_summary)
    skriv(framing_summary)
    skriv(entrypoint_summary)
    skriv(messages_summary)
    skriv(session_methods_summary)
    skriv(full_summary)
    skriv(route_summary)
    skriv(doc_exists_summary)
    skriv(doc_version_summary)
    skriv(notification_type_summary)
    skriv(output_summary)
    skriv(document_health_summary)
    skriv(document_health_state_summary)
    skriv(document_versions_summary)
    skriv(latest_document_version_summary)
    skriv(version_health_summary)
    la i = 0
    mens i < lengde(session.responses)
        skriv(session.responses[i])
        i = i + 1
    slutt
    la j = 0
    mens j < lengde(trace)
        skriv(trace[j])
        j = j + 1
    slutt
    la k = 0
    mens k < lengde(session.notifications)
        skriv(session.notifications[k])
        k = k + 1
    slutt
    skriv("lsp_main OK")
    returner sann
slutt

funksjon lsp_stdio_main()
    la server = lsp_server()
    la raw_stream = miljo_hent("NORSCODE_LSP_STREAM")
    la single_payload = miljo_hent("NORSCODE_LSP_PAYLOAD")
    la stdin_mode = lsp_env_true("NORSCODE_LSP_USE_STDIN")
    hvis raw_stream == null
        raw_stream = ""
    slutt
    hvis single_payload == null
        single_payload = ""
    slutt

    la stream_payloads = lsp_stream_payloads_from_text(raw_stream)
    la stream_source_summary = lsp_stream_source_summary(raw_stream, single_payload)
    hvis stdin_mode og raw_stream == "" og single_payload == ""
        la stdin_chunks = lsp_read_stdin_stream_until_empty()
        hvis stdin_chunks != null
            stream_payloads = stdin_chunks
            raw_stream = lsp_join_payloads(stdin_chunks)
            single_payload = ""
            stream_source_summary = lsp_stream_source_summary(raw_stream, "")
        slutt
    slutt
    la payload = single_payload
    hvis payload == ""
        payload = raw_stream
    slutt
    hvis stdin_mode og payload == "" og stream_payloads != null
        payload = lsp_join_payloads(stream_payloads)
    slutt
    la stdin_summary = "stdin_bytes=" + til_tekst(lengde(payload))
    hvis payload == "" og stream_payloads == null
        returner sann
    slutt

    la input_mode_summary = lsp_input_mode_summary(payload)

    la requests = lsp_requests_from_stdin(payload)
    hvis requests == null og stream_payloads != null
        la stream_run = lsp_run_stream_payloads(server, stream_payloads)
        hvis stream_run == null
            returner sann
        slutt

        la stream_session = {
            responses: stream_run.responses,
            notifications: stream_run.notifications,
            methods: stream_run.methods
        }
        la request_kind_summary = lsp_request_kind_summary(stream_run.methods)
        la trace = stream_run.trace
        la stream_mode_summary = lsp_stream_mode_summary(stream_payloads)
        la stream_overview = lsp_stream_overview_summary(stream_payloads, stream_run)
        la stream_chunk_count_summary = lsp_stream_chunk_count_summary(stream_payloads)
        la summary = lsp_session_summary(stream_session)
        la protocol_summary = lsp_protocol_summary(server, stream_session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))
        la activity_summary = lsp_activity_summary(stream_session)
        la activity_health_summary = lsp_activity_health_summary(stream_session)
        la overall_health_summary = lsp_overall_health_summary(server, stream_session)
        la top_status_summary = lsp_top_status_summary(server, stream_session)
        la banner_summary = lsp_banner_summary(server, stream_session)
        la status_bundle = lsp_status_bundle_summary(server, stream_session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))

        skriv("=== lsp_stdio_main ===")
        skriv("LSP JSON-stream over stdio starta")
        skriv(stdin_summary)
        skriv(input_mode_summary)
        skriv(stream_source_summary)
        skriv(stream_mode_summary)
        skriv(stream_chunk_count_summary)
        skriv(lsp_stream_summary(stream_payloads))
        skriv(stream_overview)
        skriv("transport_report=" + lsp_transport_probe_summary(json_skriv(stream_payloads), stream_run.methods))
        skriv(status_bundle)

        la i = 0
        mens i < lengde(stream_run.responses)
            skriv(stream_run.responses[i])
            i = i + 1
        slutt

        la j = 0
        mens j < lengde(trace)
            skriv(trace[j])
            j = j + 1
        slutt

        la k = 0
        mens k < lengde(stream_run.notifications)
            skriv(stream_run.notifications[k])
            k = k + 1
        slutt

        skriv("lsp_stdio_main OK")
        returner sann
    slutt

    hvis requests == null
        returner sann
    slutt

    la request_kind_summary = lsp_request_kind_summary(requests)
    la session = lsp_handle_session(server, requests)
    la trace = lsp_trace_batch(requests, session.responses)
    la summary = lsp_session_summary(session)
    la protocol_summary = lsp_protocol_summary(server, session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))
    la activity_summary = lsp_activity_summary(session)
    la activity_health_summary = lsp_activity_health_summary(session)
    la overall_health_summary = lsp_overall_health_summary(server, session)
    la top_status_summary = lsp_top_status_summary(server, session)
    la banner_summary = lsp_banner_summary(server, session)
    la status_bundle = lsp_status_bundle_summary(server, session, lsp_semantic_probe_from_document(server, "file:///tmp/lsp.no"))

    skriv("=== lsp_stdio_main ===")
    skriv("LSP JSON-batch over stdio starta")
    skriv(stdin_summary)
    skriv(input_mode_summary)
    skriv(stream_source_summary)
    skriv(lsp_stream_mode_summary([payload]))
    skriv(lsp_stream_summary([payload]))
    skriv("transport_report=" + lsp_transport_probe_summary(payload, requests))
    skriv(status_bundle)

    la i = 0
    mens i < lengde(session.responses)
        skriv(session.responses[i])
        i = i + 1
    slutt

    la j = 0
    mens j < lengde(trace)
        skriv(trace[j])
        j = j + 1
    slutt

    la k = 0
    mens k < lengde(session.notifications)
        skriv(session.notifications[k])
        k = k + 1
    slutt

    skriv("lsp_stdio_main OK")
    returner sann
slutt

funksjon lsp_selftest()
    la server = lsp_server()
    hvis server.initialized != usann
        returner usann
    slutt

    la init = lsp_initialize(server)
    hvis server.initialized != sann
        returner usann
    slutt

    la open_ok = lsp_open_document(server, "file:///tmp/main.no", "funksjon main()")
    hvis open_ok != sann
        returner usann
    slutt

    hvis lengde(server.documents) != 1
        returner usann
    slutt

    hvis lsp_has_document(server, "file:///tmp/main.no") != sann
        returner usann
    slutt

    la hov = lsp_hover(server, "main")
    la def = lsp_definition(server, "main")
    la comp = lsp_completion(server, "ma")

    hvis init == null eller hov == null eller def == null eller comp == null
        returner usann
    slutt

    hvis inneheld(init, "hoverProvider") == usann
        returner usann
    slutt

    hvis inneheld(hov, "main") == usann
        returner usann
    slutt

    hvis inneheld(def, "file:///norscode/main.no") == usann
        returner usann
    slutt

    hvis inneheld(comp, "funksjon") == usann
        returner usann
    slutt

    hvis lsp_supports_method("initialize") != sann
        returner usann
    slutt

    hvis lsp_supports_method("textDocument/hover") != sann
        returner usann
    slutt

    hvis lsp_supports_method("textDocument/publishDiagnostics") != sann
        returner usann
    slutt

    la rpc_init = lsp_handle_request(server, "initialize", "1", {})
    la rpc_open = lsp_handle_request(server, "textDocument/didOpen", "2", { "textDocument": { "uri": "file:///tmp/main.no", "text": "funksjon main()" } })
    la rpc_change = lsp_handle_request(server, "textDocument/didChange", "2b", { "textDocument": { "uri": "file:///tmp/main.no" }, "content": "funksjon main() feil" })
    la rpc_hover = lsp_handle_request(server, "textDocument/hover", "3", { "symbol": "main" })
    la rpc_shutdown = lsp_handle_request(server, "shutdown", "6", {})
    la rpc_exit = lsp_handle_request(server, "exit", "7", {})
    la batch = lsp_handle_batch(server, [
        { "method": "initialize", "id": "10", "params": {} },
        { "method": "textDocument/didOpen", "id": "11", "params": { "textDocument": { "uri": "file:///tmp/batch.no", "text": "funksjon main()" } } },
        { "method": "textDocument/hover", "id": "12", "params": { "symbol": "main" } }
    ])
    la session = lsp_handle_session(server, [
        { "method": "textDocument/didOpen", "id": "13", "params": { "textDocument": { "uri": "file:///tmp/session.no", "text": "returner a" } } },
        { "method": "textDocument/didChange", "id": "14", "params": { "textDocument": { "uri": "file:///tmp/session.no" }, "content": "funksjon main()" } }
    ])

    hvis inneheld(rpc_init, "hoverProvider") == usann
        returner usann
    slutt

    hvis inneheld(rpc_open, "\"result\":null") == usann
        returner usann
    slutt

    hvis inneheld(rpc_change, "\"result\":null") == usann
        returner usann
    slutt

    hvis lengde(server.diagnostics["file:///tmp/main.no"]) < 1
        returner usann
    slutt

    hvis lsp_document_version(server, "file:///tmp/main.no") < 1
        returner usann
    slutt

    la version_before_change = lsp_document_version(server, "file:///tmp/main.no")
    lsp_open_document(server, "file:///tmp/main.no", "funksjon main()")
    hvis lsp_document_version(server, "file:///tmp/main.no") <= version_before_change
        returner usann
    slutt

    la diag2 = lsp_handle_request(server, "textDocument/didOpen", "8", { "textDocument": { "uri": "file:///tmp/missing.no", "text": "skriv \"hei\"" } })
    hvis inneheld(diag2, "\"result\":null") == usann
        returner usann
    slutt

    la notif = lsp_format_diagnostics_notification("file:///tmp/missing.no", server.diagnostics["file:///tmp/missing.no"])
    hvis inneheld(notif, "textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis lengde(server.diagnostics["file:///tmp/missing.no"]) < 1
        returner usann
    slutt

    la bad = lsp_handle_request(server, "textDocument/didOpen", "9", { "textDocument": { "uri": "file:///tmp/bad.no", "text": "returner a" } })
    hvis inneheld(bad, "\"result\":null") == usann
        returner usann
    slutt

    hvis lengde(server.diagnostics["file:///tmp/bad.no"]) < 1
        returner usann
    slutt

    hvis inneheld(rpc_hover, "main") == usann
        returner usann
    slutt

    hvis inneheld(rpc_shutdown, "\"result\":null") == usann
        returner usann
    slutt

    hvis rpc_exit != ""
        returner usann
    slutt

    hvis lengde(batch) != 3
        returner usann
    slutt

    hvis lengde(lsp_demo_requests()) != 7
        returner usann
    slutt

    hvis lengde(session.notifications) != 2
        returner usann
    slutt

    hvis lengde(session.methods) != 2
        returner usann
    slutt

    hvis inneheld(session.notifications[0], "textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis inneheld(batch[0], "hoverProvider") == usann
        returner usann
    slutt

    hvis inneheld(batch[2], "main") == usann
        returner usann
    slutt

    la trace = lsp_trace_batch([
        { "method": "initialize", "id": "10", "params": {} },
        { "method": "textDocument/hover", "id": "11", "params": { "symbol": "main" } }
    ], batch)
    hvis lengde(trace) != 2
        returner usann
    slutt

    hvis inneheld(trace[0], "#") == usann
        returner usann
    slutt

    la summary = lsp_session_summary(session)
    hvis inneheld(summary, "responses=") == usann
        returner usann
    slutt

    hvis inneheld(summary, "diagnostics=") == usann
        returner usann
    slutt

    hvis inneheld(summary, "methods=") == usann
        returner usann
    slutt

    hvis inneheld(summary, "version_events=") == usann
        returner usann
    slutt

    hvis inneheld(summary, "methods=7") == usann
        returner usann
    slutt

    hvis lengde(server.methods) < 2
        returner usann
    slutt

    hvis inneheld(probe_summary, "ok=") == usann
        returner usann
    slutt

    hvis inneheld(probe_summary, "Dokumentet") == usann og inneheld(probe_summary, "OK") == usann
        returner usann
    slutt

    hvis inneheld(document_summary, "documents=") == usann
        returner usann
    slutt

    hvis inneheld(document_summary, "versions=") == usann
        returner usann
    slutt

    hvis inneheld(state_summary, "documents=") == usann
        returner usann
    slutt

    hvis inneheld(state_summary, "methods_seen=") == usann
        returner usann
    slutt

    hvis inneheld(state_summary, "notifications_health=") == usann
        returner usann
    slutt

    hvis inneheld(state_summary, "notifications_overview=") == usann
        returner usann
    slutt

    hvis inneheld(caps_summary, "hoverProvider=true") == usann
        returner usann
    slutt

    hvis inneheld(protocol_summary, "protocol=JSON-RPC") == usann
        returner usann
    slutt

    hvis inneheld(protocol_summary, "notifications=textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis inneheld(protocol_summary, "notifications_count=") == usann
        returner usann
    slutt

    hvis inneheld(protocol_summary, "notifications_health=") == usann
        returner usann
    slutt

    hvis inneheld(protocol_summary, "notifications_overview=") == usann
        returner usann
    slutt

    hvis inneheld(lsp_stream_source_summary("", json_skriv(lsp_demo_requests())), "stream_source=NORSCODE_LSP_PAYLOAD") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "transport=batch/session,json-batch-stdio,content-length") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "io=json-batch-stdio,content-length") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "stream_source=NORSCODE_LSP_PAYLOAD") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "stream_mode=hybrid") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "stream_overview=chunks=2") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "framing=json-batch+content-length") == usann
        returner usann
    slutt

    hvis inneheld(protocol_summary, "methods=") == usann
        returner usann
    slutt

    hvis inneheld(notifications_summary, "notifications=textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis inneheld(transport_summary, "json-batch-stdio") == usann
        returner usann
    slutt

    hvis inneheld(methods_summary, "initialize") == usann
        returner usann
    slutt

    hvis inneheld(methods_summary, "textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis inneheld(route_summary, "textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis inneheld(io_summary, "json-batch-stdio") == usann
        returner usann
    slutt

    hvis inneheld(framing_summary, "framing=") == usann
        returner usann
    slutt

    hvis inneheld(entrypoint_summary, "lsp_stdio_main") == usann
        returner usann
    slutt

    la raw_payload = "[{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}]"
    la framed_payload = "Content-Length: 46\r\n\r\n[{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}]"
    la multi_framed_payload = framed_payload + "\r\nContent-Length: 46\r\n\r\n[{\"method\":\"initialize\",\"id\":\"2\",\"params\":{}}]"
    la padded_payload = "   " + framed_payload + "   "
    la stdin_requests = lsp_requests_from_stdin(raw_payload)
    la stdin_single_request = lsp_requests_from_stdin("{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}")
    la framed_requests = lsp_requests_from_stdin(framed_payload)
    la multi_framed_requests = lsp_requests_from_stdin(multi_framed_payload)
    la padded_requests = lsp_requests_from_stdin(padded_payload)
    la raw_input_mode = lsp_input_mode_summary(raw_payload)
    la framed_input_mode = lsp_input_mode_summary(framed_payload)
    la stream_payloads = lsp_stream_payloads_from_text(json_skriv([
        "{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}",
        "{\"method\":\"shutdown\",\"id\":\"2\",\"params\":{}}"
    ]))
    la newline_stream_payloads = lsp_stream_payloads_from_text("{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}\n{\"method\":\"shutdown\",\"id\":\"2\",\"params\":{}}")
    la stream_run = lsp_run_stream_payloads(lsp_server(), stream_payloads)
    la stream_summary = lsp_stream_summary(stream_payloads)
    la none_stream_summary = lsp_stream_summary(null)
    la stream_mode = lsp_stream_mode_summary(stream_payloads)
    la none_stream_mode = lsp_stream_mode_summary(null)
    la stream_source = lsp_stream_source_summary("[{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}]\n[{\"method\":\"shutdown\",\"id\":\"2\",\"params\":{}}]", "")
    la combined_source = lsp_stream_source_summary("stream", "payload")
    la empty_stream_source = lsp_stream_source_summary(null, null)
    la combined_mode = lsp_stream_mode_summary(["a", "b"])
    la joined_payloads = lsp_join_payloads(["a", "b"])
    la empty_joined_payloads = lsp_join_payloads([])
    la none_notification_type = lsp_notification_type_summary(null)
    la empty_notifications_session = { notifications: [] }
    la stream_overview = lsp_stream_overview_summary(stream_payloads, stream_run)
    la stream_overview_none = lsp_stream_overview_summary(null, null)
    la stream_chunk_count = lsp_stream_chunk_count_summary(stream_payloads)
    la stream_chunk_count_none = lsp_stream_chunk_count_summary(null)
    la stream_transport_report = ""
    la decode_fallback_report = lsp_stdio_report_summary("garbage", [])
    la empty_transport_report = lsp_transport_probe_summary("", null)
    la batch_kind = lsp_request_kind_summary([
        { "method": "initialize", "id": "1", "params": {} },
        { "method": "shutdown", "id": "2", "params": {} }
    ])
    la none_kind = lsp_request_kind_summary(null)
    la single_kind = lsp_request_kind_summary([
        { "method": "initialize", "id": "1", "params": {} }
    ])

    hvis lengde(stdin_requests) != 1
        returner usann
    slutt

    hvis lengde(stdin_single_request) != 1
        returner usann
    slutt

    hvis lengde(framed_requests) != 1
        returner usann
    slutt

    hvis lengde(multi_framed_requests) != 2
        returner usann
    slutt

    hvis lengde(padded_requests) != 1
        returner usann
    slutt

    hvis inneheld(raw_input_mode, "input_mode=raw-json") == usann
        returner usann
    slutt

    hvis inneheld(framed_input_mode, "input_mode=content-length") == usann
        returner usann
    slutt

    hvis inneheld(stream_summary, "stream_chunks=2") == usann
        returner usann
    slutt

    hvis inneheld(none_stream_summary, "stream=none") == usann
        returner usann
    slutt

    hvis inneheld(stream_mode, "stream_mode=stream") == usann
        returner usann
    slutt

    hvis inneheld(none_stream_mode, "stream_mode=none") == usann
        returner usann
    slutt

    hvis inneheld(stream_chunk_count, "stream_chunk_count=2") == usann
        returner usann
    slutt

    hvis inneheld(stream_chunk_count_none, "stream_chunk_count=0") == usann
        returner usann
    slutt

    hvis inneheld(stream_source, "stream_source=NORSCODE_LSP_STREAM") == usann
        returner usann
    slutt

    hvis inneheld(combined_source, "stream_source=NORSCODE_LSP_STREAM+NORSCODE_LSP_PAYLOAD") == usann
        returner usann
    slutt

    hvis inneheld(empty_stream_source, "stream_source=empty") == usann
        returner usann
    slutt

    hvis inneheld(combined_mode, "stream_mode=hybrid") == usann
        returner usann
    slutt

    hvis joined_payloads != "a\nb"
        returner usann
    slutt

    hvis empty_joined_payloads != ""
        returner usann
    slutt

    hvis inneheld(none_notification_type, "notification=unknown") == usann
        returner usann
    slutt

    hvis inneheld(lsp_notifications_overview_summary(empty_notifications_session), "notifications_count=0") == usann
        returner usann
    slutt

    hvis inneheld(lsp_notifications_overview_summary(empty_notifications_session), "notifications_health=idle") == usann
        returner usann
    slutt

    hvis lengde(newline_stream_payloads) != 2
        returner usann
    slutt

    hvis inneheld(lsp_stream_summary(newline_stream_payloads), "stream_chunks=2") == usann
        returner usann
    slutt

    hvis stream_run == null
        returner usann
    slutt

    stream_transport_report = lsp_transport_probe_summary(json_skriv(stream_payloads), stream_run.methods)

    hvis lengde(stream_run.responses) != 2
        returner usann
    slutt

    hvis inneheld(stream_overview, "stream_overview=chunks=2") == usann
        returner usann
    slutt

    hvis inneheld(stream_overview, "requests=2") == usann
        returner usann
    slutt

    hvis inneheld(stream_overview_none, "stream_overview=none") == usann
        returner usann
    slutt

    hvis inneheld(stream_overview, "responses=2") == usann
        returner usann
    slutt

    hvis inneheld(stream_transport_report, "request_kind=batch") == usann
        returner usann
    slutt

    hvis inneheld(stdin_summary, "stdin_bytes=") == usann
        returner usann
    slutt

    hvis inneheld(transport_report, "transport_report=") == usann
        returner usann
    slutt

    hvis inneheld(transport_report, "stage=") == usann
        returner usann
    slutt

    hvis inneheld(decode_fallback_report, "stage=decode-fallback") == usann
        returner usann
    slutt

    hvis inneheld(empty_transport_report, "stage=fallback") == usann
        returner usann
    slutt


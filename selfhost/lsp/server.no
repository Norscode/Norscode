        returner usann
    slutt

    hvis inneheld(none_kind, "request_kind=none") == usann
        returner usann
    slutt

    hvis inneheld(single_kind, "request_kind=single") == usann
        returner usann
    slutt

    hvis inneheld(lsp_extract_body_from_framed_payload("Content-Length: 46\r\n\r\n[{\"method\":\"initialize\",\"id\":\"1\",\"params\":{}}]"), "\"method\":\"initialize\"") == usann
        returner usann
    slutt

    hvis inneheld(messages_summary, "messages=") == usann
        returner usann
    slutt

    hvis inneheld(session_methods_summary, "session_methods=") == usann
        returner usann
    slutt

    hvis inneheld(activity_summary, "messages=") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "notifications_count=") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "notifications_health=") == usann
        returner usann
    slutt

    hvis inneheld(status_bundle, "notifications_count=") == usann
        returner usann
    slutt

    hvis inneheld(activity_health_summary, "activity_health=") == usann
        returner usann
    slutt

    hvis inneheld(overall_health_summary, "document_health=") == usann
        returner usann
    slutt

    hvis inneheld(overall_health_summary, "notifications_health=") == usann
        returner usann
    slutt

    hvis inneheld(top_status_summary, "top_status=") == usann
        returner usann
    slutt

    hvis inneheld(banner_summary, "banner=") == usann
        returner usann
    slutt

    hvis inneheld(input_mode_summary, "input_mode=") == usann
        returner usann
    slutt

    hvis inneheld(banner_summary, "banner=klar") == usann og inneheld(banner_summary, "banner=delvis") == usann og inneheld(banner_summary, "banner=uklar") == usann
        returner usann
    slutt

    hvis inneheld(full_summary, "full=ok") == usann
        returner usann
    slutt

    hvis inneheld(doc_exists_summary, "document_exists=true") == usann
        returner usann
    slutt

    hvis inneheld(doc_version_summary, "document_version=") == usann
        returner usann
    slutt

    hvis inneheld(notification_type_summary, "textDocument/publishDiagnostics") == usann
        returner usann
    slutt

    hvis inneheld(output_summary, "output=") == usann
        returner usann
    slutt

    hvis inneheld(document_health_summary, "document_health=") == usann
        returner usann
    slutt

    hvis inneheld(document_health_state_summary, "document_health_state=") == usann
        returner usann

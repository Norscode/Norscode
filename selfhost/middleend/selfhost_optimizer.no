# Selfhost optimizer pipeline for Norscode

# =========================
# Optimizer pass model
# =========================

funksjon optimizer_pass(name)
    returner {
        name: name,
        applied: usann,
        changes: 0
    }
slutt

funksjon optimizer_pipeline()
    returner {
        passes: [
            optimizer_pass("constant_folding"),
            optimizer_pass("dead_code_elimination"),
            optimizer_pass("copy_propagation"),
            optimizer_pass("cfg_simplification")
        ]
    }
slutt

# =========================
# Constant folding
# =========================

funksjon fold_binary_instruction(instr)
    hvis instr.op != "+"
        returner instr
    slutt

    hvis lengde(instr.inputs) != 2
        returner instr
    slutt

    left = instr.inputs[0]
    right = instr.inputs[1]

    hvis left.op == "const" og
       right.op == "const"

        value = left.inputs[0] + right.inputs[0]

        returner ssa_instruction(
            "const",
            [value],
            instr.output
        )
    slutt

    returner instr
slutt

funksjon run_constant_folding(cfg)
    block_names = nøkler(cfg.blocks)

    block_index = 0

    mens block_index < lengde(block_names)
        block = cfg.blocks[
            block_names[block_index]
        ]

        instr_index = 0

        mens instr_index < lengde(block.instructions)
            block.instructions[instr_index] =
                fold_binary_instruction(
                    block.instructions[instr_index]
                )

            instr_index = instr_index + 1
        slutt

        block_index = block_index + 1
    slutt

    returner cfg
slutt

# =========================
# Dead code elimination
# =========================

funksjon instruction_is_dead(instr)
    hvis instr.op == "nop"
        returner sann
    slutt

    returner usann
slutt

funksjon remove_dead_instructions(block)
    alive = []

    instr_index = 0

    mens instr_index < lengde(block.instructions)
        instr = block.instructions[instr_index]

        hvis instruction_is_dead(instr) == usann
            legg_til(alive, instr)
        slutt

        instr_index = instr_index + 1
    slutt

    block.instructions = alive
slutt

funksjon run_dead_code_elimination(cfg)
    block_names = nøkler(cfg.blocks)

    block_index = 0

    mens block_index < lengde(block_names)
        remove_dead_instructions(
            cfg.blocks[block_names[block_index]]
        )

        block_index = block_index + 1
    slutt

    returner cfg
slutt

# =========================
# Copy propagation
# =========================

funksjon propagate_copy(instr)
    hvis instr.op != "copy"
        returner instr
    slutt

    returner ssa_instruction(
        "mov",
        instr.inputs,
        instr.output
    )
slutt

funksjon run_copy_propagation(cfg)
    block_names = nøkler(cfg.blocks)

    block_index = 0

    mens block_index < lengde(block_names)
        block = cfg.blocks[
            block_names[block_index]
        ]

        instr_index = 0

        mens instr_index < lengde(block.instructions)
            block.instructions[instr_index] =
                propagate_copy(
                    block.instructions[instr_index]
                )

            instr_index = instr_index + 1
        slutt

        block_index = block_index + 1
    slutt

    returner cfg
slutt

# =========================
# CFG simplification
# =========================

funksjon simplify_empty_blocks(cfg)
    block_names = nøkler(cfg.blocks)

    block_index = 0

    mens block_index < lengde(block_names)
        block = cfg.blocks[
            block_names[block_index]
        ]

        hvis lengde(block.instructions) == 0 og
           block.name != cfg.entry

            cfg.blocks[block.name] = null
        slutt

        block_index = block_index + 1
    slutt

    returner cfg
slutt

funksjon run_cfg_simplification(cfg)
    returner simplify_empty_blocks(cfg)
slutt

# =========================
# Optimizer driver
# =========================

funksjon optimizer_run_pass(cfg, pass_name)
    hvis pass_name == "constant_folding"
        returner run_constant_folding(cfg)
    slutt

    hvis pass_name == "dead_code_elimination"
        returner run_dead_code_elimination(cfg)
    slutt

    hvis pass_name == "copy_propagation"
        returner run_copy_propagation(cfg)
    slutt

    hvis pass_name == "cfg_simplification"
        returner run_cfg_simplification(cfg)
    slutt

    returner cfg
slutt

funksjon optimize_cfg(cfg)
    pipeline = optimizer_pipeline()

    pass_index = 0

    mens pass_index < lengde(pipeline.passes)
        pass_obj = pipeline.passes[pass_index]

        cfg = optimizer_run_pass(
            cfg,
            pass_obj.name
        )

        pass_obj.applied = sann

        pass_index = pass_index + 1
    slutt

    returner {
        cfg: cfg,
        pipeline: pipeline
    }
slutt

# =========================
# Snapshot-verifisering
# =========================

funksjon optimizer_snapshot_test()
    tokens = lex_source(
        "la x = 1 + 2"
    )

    ast = parse_tokens(tokens)

    semantic = semantic_analyze(ast)

    hvis semantic.success == usann
        returner {
            success: usann
        }
    slutt

    cfg = lower_to_ssa(ast)

    optimized = optimize_cfg(cfg)

    returner {
        success: sann,
        entry: optimized.cfg.entry,
        passes: optimized.pipeline.passes
    }
slutt

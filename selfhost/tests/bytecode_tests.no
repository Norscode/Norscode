// Norscode Bytecode Test Suite v0
// Validation tests for deterministic opcode generation.

bruk selfhost.lexer
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.bytecode_backend
bruk selfhost.std.io

struktur BytecodeTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = BytecodeTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon bygg_bytecode(kilde)
    lexer = ny_lexer(kilde)
    parser = ny_parser(lexer)

    ast = parse_program(parser)

    analyzer = ny_semantic_analyzer()
    analyser_node(analyzer, ast)

    backend = ny_bytecode_backend()

    returner generer_bytecode(backend, ast)
slutt

funksjon test_add_opcode()
    code = bygg_bytecode("returner 1 + 2")

    assert_equals(code[0].opcode, "PUSH_CONST", "first opcode")
    assert_equals(code[1].opcode, "PUSH_CONST", "second opcode")
    assert_equals(code[2].opcode, "ADD", "add opcode")

    returner ny_result("test_add_opcode", sann, "OK")
slutt

funksjon test_store_opcode()
    code = bygg_bytecode("la x = 1")

    assert_equals(code[1].opcode, "STORE", "store opcode")

    returner ny_result("test_store_opcode", sann, "OK")
slutt

funksjon test_call_opcode()
    code = bygg_bytecode("test()")

    assert_equals(code[0].opcode, "CALL", "call opcode")

    returner ny_result("test_call_opcode", sann, "OK")
slutt

funksjon test_deterministic_bytecode()
    code1 = bygg_bytecode("returner x + y")
    code2 = bygg_bytecode("returner x + y")

    assert_equals(lengde(code1), lengde(code2), "opcode count")
    assert_equals(code1[0].opcode, code2[0].opcode, "deterministic opcode")

    returner ny_result("test_deterministic_bytecode", sann, "OK")
slutt

funksjon test_jump_opcode()
    code = bygg_bytecode("hvis sann returner 1")

    assert_equals(code[0].opcode, "JMP_FALSE", "jump opcode")

    returner ny_result("test_jump_opcode", sann, "OK")
slutt

funksjon kjør_bytecode_tester()
    skriv_linje("[TEST] starter bytecode tester")

    results = []

    legg_til(results, test_add_opcode())
    legg_til(results, test_store_opcode())
    legg_til(results, test_call_opcode())
    legg_til(results, test_deterministic_bytecode())
    legg_til(results, test_jump_opcode())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv_linje("[PASS] " + result.navn)
        ellers
            skriv_linje("[FAIL] " + result.navn)
        slutt

        indeks = indeks + 1
    slutt

    skriv_linje("[TEST] bytecode tester ferdig")

    returner sann
slutt

funksjon main()
    returner kjør_bytecode_tester()
slutt

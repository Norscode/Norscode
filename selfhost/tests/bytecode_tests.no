// Norscode Bytecode Test Suite v1
// Validation tests for deterministic IR and bytecode generation.

bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.bytecode_backend
bruk selfhost.ir
bruk std.tekst som t

struktur BytecodeTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = BytecodeTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon runtime_panic(tekst)
    kast tekst
slutt

funksjon bygg_ast(kilde)
    tokens = lex(kilde)
    returner parse_program(tokens)
slutt

funksjon bygg_semantisk_ast(kilde)
    ast = bygg_ast(kilde)
    state = semantic_analyser(ast)
    assert_equals(semantic_ok(state), sann, "semantic ok")
    returner ast
slutt

funksjon bygg_ncb(kilde)
    ast = bygg_semantisk_ast(kilde)
    returner bytecode_kompiler(ast, "__main__")
slutt

funksjon test_ir_disasm()
    emitter = ir_emitter()

    ir_emit(emitter, "LOAD_CONST", 1, null)
    ir_emit(emitter, "LOAD_CONST", 2, null)
    ir_emit(emitter, "ADD", "", null)
    ir_label(emitter, "slutt", null)

    disasm = ir_disasm(emitter.program)

    assert_equals(t.inneholder(disasm, "LOAD_CONST"), sann, "disasm load const")
    assert_equals(t.inneholder(disasm, "ADD"), sann, "disasm add")
    assert_equals(t.inneholder(disasm, "LABEL"), sann, "disasm label")

    returner ny_result("test_ir_disasm", sann, "OK")
slutt

funksjon test_bytecode_json_format()
    ncb = bygg_ncb("funksjon start() -> heltall { returner 1 }")

    assert_equals(ncb[0], "{", "ncb start")
    assert_equals(t.inneholder(ncb, "\"format\":\"norscode-bytecode-v1\""), sann, "ncb format")
    assert_equals(t.inneholder(ncb, "\"entry\":\"__main__.start\""), sann, "ncb entry")

    returner ny_result("test_bytecode_json_format", sann, "OK")
slutt

funksjon test_bytecode_deterministic()
    ncb1 = bygg_ncb("funksjon start() -> heltall { returner 1 }")
    ncb2 = bygg_ncb("funksjon start() -> heltall { returner 1 }")

    assert_equals(ncb1, ncb2, "deterministic bytecode")

    returner ny_result("test_bytecode_deterministic", sann, "OK")
slutt

funksjon test_bytecode_contains_function()
    ncb = bygg_ncb("funksjon start() -> heltall { returner 1 + 2 }")

    assert_equals(t.inneholder(ncb, "\"functions\""), sann, "ncb functions key")
    assert_equals(t.inneholder(ncb, "start"), sann, "ncb function name")

    returner ny_result("test_bytecode_contains_function", sann, "OK")
slutt

funksjon test_struct_literal_bytecode()
    ncb = bygg_ncb("funksjon start() -> ordbok_tekst { returner { navn: \"Ada\", by: \"Oslo\" } }")

    assert_equals(t.inneholder(ncb, "\"BUILD_MAP\""), sann, "struct literal build map")
    assert_equals(t.inneholder(ncb, "\"navn\""), sann, "struct literal field navn")

    returner ny_result("test_struct_literal_bytecode", sann, "OK")
slutt

funksjon test_nested_struct_literal_bytecode()
    ncb = bygg_ncb("funksjon start() -> ordbok_tekst { returner { hjem: { navn: \"Ada\", by: \"Oslo\" }, arbeid: { navn: \"Kari\", by: \"Bergen\" } } }")

    assert_equals(t.inneholder(ncb, "\"BUILD_MAP\""), sann, "nested struct build map")
    assert_equals(t.inneholder(ncb, "\"hjem\""), sann, "nested struct field hjem")
    assert_equals(t.inneholder(ncb, "\"arbeid\""), sann, "nested struct field arbeid")

    returner ny_result("test_nested_struct_literal_bytecode", sann, "OK")
slutt

funksjon test_test_block_bytecode()
    ncb = bygg_ncb("test \"summerer\" { assert_eq(1 + 2, 3) } funksjon start() -> heltall { returner 0 }")

    assert_equals(t.inneholder(ncb, "\"tests\""), sann, "ncb tests key")
    assert_equals(t.inneholder(ncb, "\"kind\":\"test\""), sann, "ncb test kind")
    assert_equals(t.inneholder(ncb, "summerer"), sann, "ncb test name")

    returner ny_result("test_test_block_bytecode", sann, "OK")
slutt

funksjon kjør_bytecode_tester()
    skriv("[TEST] starter bytecode tester\n")

    results = []

    legg_til(results, test_ir_disasm())
    legg_til(results, test_bytecode_json_format())
    legg_til(results, test_bytecode_deterministic())
    legg_til(results, test_bytecode_contains_function())
    legg_til(results, test_struct_literal_bytecode())
    legg_til(results, test_nested_struct_literal_bytecode())
    legg_til(results, test_test_block_bytecode())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv("[PASS] " + result.navn + "\n")
        ellers
            skriv("[FAIL] " + result.navn + "\n")
        slutt

        indeks = indeks + 1
    slutt

    skriv("[TEST] bytecode tester ferdig\n")

    returner sann
slutt

funksjon start()
    returner kjør_bytecode_tester()
slutt

funksjon main()
    returner start()
slutt

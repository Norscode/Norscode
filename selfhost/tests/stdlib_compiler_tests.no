// Norscode stdlib/compiler usage suite
// Phase 7: verify the stdlib surface compiler work depends on.

bruk std.tekst som t
bruk std.liste som liste
bruk std.ordbok som ordbok
bruk std.fil som fil
bruk std.path som path
bruk std.env som env
bruk std.json som json
bruk std.feil som feil
bruk std.cli som cli
bruk selfhost.bootstrap_compiler.compiler_entrypoint som entry

struktur StdlibCompilerTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    resultat = StdlibCompilerTestResult()
    resultat.navn = navn
    resultat.success = success
    resultat.melding = melding
    returner resultat
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon runtime_panic(tekst)
    kast tekst
slutt

funksjon test_tekst()
    assert_equals(t.hilsen("Norscode"), "Hei Norscode", "tekst hilsen")
    assert_equals(t.rop("klart"), "klart!", "tekst rop")
    assert_equals(t.omgitt_av_klammer("abc"), "[abc]", "tekst klammer")
    assert_equals(t.ja_nei(sann), "ja", "tekst bool")
    assert_equals(t.tall_til_tekst(7), "7", "tekst tall")
    assert_equals(t.bool_til_tekst(usann), "usann", "tekst bool tekst")
    returner ny_result("test_tekst", sann, "OK")
slutt

funksjon test_liste()
    la tall: liste_heltall = [3, 1, 2]
    la ord: liste_tekst = ["c", "a", "b"]

    assert_equals(liste.sorter_tall(tall), 3, "liste sort tall")
    assert_equals(tall[0], 1, "liste sort tall 0")
    assert_equals(tall[1], 2, "liste sort tall 1")
    assert_equals(tall[2], 3, "liste sort tall 2")

    assert_equals(liste.sorter_tekst(ord), 3, "liste sort tekst")
    assert_equals(ord[0], "a", "liste sort tekst 0")
    assert_equals(ord[1], "b", "liste sort tekst 1")
    assert_equals(ord[2], "c", "liste sort tekst 2")

    returner ny_result("test_liste", sann, "OK")
slutt

funksjon test_ordbok()
    la data: ordbok_tekst = {}
    la flags: ordbok_bool = {}
    ordbok.sett_tekst(data, "navn", "Norscode")
    ordbok.sett_tall(data, "versjon", 7)
    ordbok.sett_bool(flags, "aktiv", sann)

    assert_equals(ordbok.hent_tekst(data, "navn"), "Norscode", "ordbok tekst")
    assert_equals(ordbok.hent_tall(data, "versjon"), 7, "ordbok tall")
    assert_equals(ordbok.antall_tekst(data), 2, "ordbok antall")
    assert_equals(ordbok.antall_bool(flags), 1, "ordbok bool antall")
    assert_equals(ordbok.har_bool(flags, "aktiv"), sann, "ordbok bool")
    assert_equals(ordbok.fjern_bool(flags, "aktiv"), 0, "ordbok bool fjern")

    returner ny_result("test_ordbok", sann, "OK")
slutt

funksjon test_fil_sti_env()
    la readme = fil.les("README.md")
    assert(t.inneholder(readme, "Norscode"))
    assert_eq(path.basename("README.md"), "README.md")
    assert_eq(path.dirname("docs/README.md"), "docs")
    assert_equals(env.finnes("PATH"), sann, "env path")
    returner ny_result("test_fil_sti_env", sann, "OK")
slutt

funksjon test_json_og_feil()
    la payload = "{\"navn\":\"Norscode\",\"alder\":2,\"aktiv\":true}"
    la parsed = json.parse(payload)
    assert_equals(parsed["navn"], "Norscode", "json navn")
    assert_equals(parsed["alder"], "2", "json alder")
    assert_equals(parsed["aktiv"], "true", "json aktiv")
    assert_equals(feil.io("boom"), "IOFeil: boom", "feil io")
    assert_equals(feil.verdi("oops"), "VerdiFeil: oops", "feil verdi")
    returner ny_result("test_json_og_feil", sann, "OK")
slutt

funksjon test_cli_hjelpere()
    la args: liste_tekst = ["build", "src.no", "out.elf", "--json", "--output=build/out.elf"]
    assert_equals(cli.kommando(args), "build", "cli kommando")
    assert_equals(cli.posisjonell(args, 1, "fallback"), "src.no", "cli posisjonell")
    assert_equals(cli.posisjonell(args, 9, "fallback"), "fallback", "cli fallback")
    assert_equals(cli.har_flagg(args, "json"), sann, "cli flagg")
    assert_equals(cli.flagg_verdi(args, "output", "fallback"), "build/out.elf", "cli flagg verdi")

    la build_cmd = entry.parse_args(["build", "app.no", "build/app.elf"])
    assert_equals(build_cmd.navn, "build", "entry build navn")
    assert_equals(build_cmd.source, "app.no", "entry build source")
    assert_equals(build_cmd.output, "build/app.elf", "entry build output")

    la run_cmd = entry.parse_args(["run", "demo.no"])
    assert_equals(run_cmd.navn, "run", "entry run navn")
    assert_equals(run_cmd.source, "demo.no", "entry run source")
    assert_equals(run_cmd.output, "build/app.elf", "entry run default output")

    la help_cmd = entry.parse_args([])
    assert_equals(help_cmd.navn, "help", "entry help navn")

    returner ny_result("test_cli_hjelpere", sann, "OK")
slutt

funksjon kjør_stdlib_compiler_tester()
    skriv("[TEST] starter stdlib/compiler tester\n")

    results = []

    legg_til(results, test_tekst())
    legg_til(results, test_liste())
    legg_til(results, test_ordbok())
    legg_til(results, test_fil_sti_env())
    legg_til(results, test_json_og_feil())
    legg_til(results, test_cli_hjelpere())

    indeks = 0
    mens indeks < lengde(results)
        result = results[indeks]
        hvis result.success
            skriv("[PASS] " + result.navn + "\n")
        ellers
            skriv("[FAIL] " + result.navn + "\n")
        slutt
        indeks = indeks + 1
    slutt

    skriv("[TEST] stdlib/compiler tester ferdig\n")

    returner sann
slutt

funksjon start() -> heltall {
    returner kjør_stdlib_compiler_tester()
}

funksjon main()
    returner start()
slutt

// Norscode Semantic Test Suite v0
// Validation tests for semantic analysis and symbol resolution.

bruk selfhost.lexer
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.std.io

struktur SemanticTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = SemanticTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon bygg_ast(kilde)
    lexer = ny_lexer(kilde)
    parser = ny_parser(lexer)

    returner parse_program(parser)
slutt

funksjon analyser_kilde(kilde)
    ast = bygg_ast(kilde)

    analyzer = ny_semantic_analyzer()

    returner analyser_node(analyzer, ast)
slutt

funksjon test_number_type()
    result = analyser_kilde("returner 1")

    assert_equals(result, "VOID", "program result")

    returner ny_result("test_number_type", sann, "OK")
slutt

funksjon test_binop_semantic()
    result = analyser_kilde("returner a + b")

    assert_equals(result, "VOID", "binop semantic")

    returner ny_result("test_binop_semantic", sann, "OK")
slutt

funksjon test_scope_creation()
    analyzer = ny_semantic_analyzer()

    definer_symbol(analyzer, "x", "NUMBER")

    symbol = finn_symbol(analyzer.scope, "x")

    assert_equals(symbol.type, "NUMBER", "scope symbol")

    returner ny_result("test_scope_creation", sann, "OK")
slutt

funksjon test_duplicate_symbol_overwrite()
    analyzer = ny_semantic_analyzer()

    definer_symbol(analyzer, "x", "NUMBER")
    definer_symbol(analyzer, "x", "NUMBER")

    symbol = finn_symbol(analyzer.scope, "x")

    assert_equals(symbol.navn, "x", "duplicate symbol")

    returner ny_result("test_duplicate_symbol_overwrite", sann, "OK")
slutt

funksjon test_nested_scope_lookup()
    analyzer = ny_semantic_analyzer()

    definer_symbol(analyzer, "global", "NUMBER")

    nested = ny_scope(analyzer.scope)

    symbol = finn_symbol(nested, "global")

    assert_equals(symbol.type, "NUMBER", "nested scope")

    returner ny_result("test_nested_scope_lookup", sann, "OK")
slutt

funksjon kjør_semantic_tester()
    skriv_linje("[TEST] starter semantic tester")

    results = []

    legg_til(results, test_number_type())
    legg_til(results, test_binop_semantic())
    legg_til(results, test_scope_creation())
    legg_til(results, test_duplicate_symbol_overwrite())
    legg_til(results, test_nested_scope_lookup())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv_linje("[PASS] " + result.navn)
        ellers
            skriv_linje("[FAIL] " + result.navn)
        slutt

        indeks = indeks + 1
    slutt

    skriv_linje("[TEST] semantic tester ferdig")

    returner sann
slutt

funksjon main()
    returner kjør_semantic_tester()
slutt

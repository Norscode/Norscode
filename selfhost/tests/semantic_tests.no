// Norscode Semantic Test Suite v1
// Validation tests for deterministic semantic analysis and symbol resolution.

bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk selfhost.semantic

struktur SemanticTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = SemanticTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon runtime_panic(tekst)
    kast tekst
slutt

funksjon test_node(navn)
    returner {
        type: "Ident",
        verdi: navn,
        barn: [],
        linje: 1,
        kolonne: 1
    }
slutt

funksjon bygg_ast(kilde)
    tokens = lex(kilde)
    returner selfhost.parser.parse_program(tokens)
slutt

funksjon analyser_kilde(kilde)
    ast = bygg_ast(kilde)
    returner semantic_analyser(ast)
slutt

funksjon test_program_semantic_ok()
    state = analyser_kilde("returner 1")

    assert_equals(semantic_ok(state), sann, "semantic ok")
    assert_equals(semantic_rapport(state), "Semantic OK", "semantic report")

    returner ny_result("test_program_semantic_ok", sann, "OK")
slutt

funksjon test_undefined_symbol_error()
    state = analyser_kilde("returner a")

    assert_equals(semantic_ok(state), usann, "semantic should fail")
    assert_equals(lengde(state.feil) > 0, sann, "semantic error count")

    returner ny_result("test_undefined_symbol_error", sann, "OK")
slutt

funksjon test_scope_creation()
    scope = ny_scope("global", null)
    symbol = ny_symbol("x", "NUMBER", "variabel", test_node("x"))

    scope_definer(scope, symbol)

    symbol = scope_finn(scope, "x")

    assert_equals(symbol.type, "NUMBER", "scope symbol")

    returner ny_result("test_scope_creation", sann, "OK")
slutt

funksjon test_duplicate_symbol_overwrite()
    state = ny_semantic_state()
    symbol_node = test_node("x")

    semantic_definer(state, "x", "NUMBER", "variabel", symbol_node)
    semantic_definer(state, "x", "NUMBER", "variabel", symbol_node)

    assert_equals(semantic_ok(state), usann, "duplicate symbol should fail")
    assert_equals(lengde(state.feil), 1, "duplicate error count")

    returner ny_result("test_duplicate_symbol_overwrite", sann, "OK")
slutt

funksjon test_nested_scope_lookup()
    parent = ny_scope("global", null)
    scope_definer(parent, ny_symbol("global", "NUMBER", "variabel", test_node("global")))

    nested = ny_scope("nested", parent)
    symbol = scope_finn(nested, "global")

    assert_equals(symbol.type, "NUMBER", "nested scope")

    returner ny_result("test_nested_scope_lookup", sann, "OK")
slutt

funksjon kjør_semantic_tester()
    skriv("[TEST] starter semantic tester\n")

    results = []

    legg_til(results, test_program_semantic_ok())
    legg_til(results, test_undefined_symbol_error())
    legg_til(results, test_scope_creation())
    legg_til(results, test_duplicate_symbol_overwrite())
    legg_til(results, test_nested_scope_lookup())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv("[PASS] " + result.navn + "\n")
        ellers
            skriv("[FAIL] " + result.navn + "\n")
        slutt

        indeks = indeks + 1
    slutt

    skriv("[TEST] semantic tester ferdig\n")

    returner sann
slutt

funksjon start()
    returner kjør_semantic_tester()
slutt

funksjon main()
    returner start()
slutt

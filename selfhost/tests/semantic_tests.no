// Norscode Semantic Test Suite v1
// Validation tests for deterministic semantic analysis and symbol resolution.

bruk selfhost.semantic

struktur SemanticTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = SemanticTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon runtime_panic(tekst)
    kast tekst
slutt

funksjon ny_ident(navn)
    returner { type: "Ident", verdi: navn, barn: [], linje: 1, kolonne: 1 }
slutt

funksjon ny_heltall(verdi)
    returner { type: "Heltall", verdi: verdi, barn: [], linje: 1, kolonne: 1 }
slutt

funksjon ny_tekst(verdi)
    returner { type: "Tekst", verdi: verdi, barn: [], linje: 1, kolonne: 1 }
slutt

funksjon ny_binop(venstre, operator, hoyre)
    returner { type: "Binop", verdi: operator, barn: [venstre, hoyre], linje: 1, kolonne: 1 }
slutt

funksjon ny_la(navn, verdi)
    returner { type: "La", verdi: navn, barn: [verdi], linje: 1, kolonne: 1 }
slutt

funksjon ny_blokk(barn)
    returner { type: "Blokk", barn: barn, linje: 1, kolonne: 1 }
slutt

funksjon ny_funksjon(navn, kropp)
    returner { type: "Funksjon", verdi: navn, barn: [ny_blokk(kropp)], linje: 1, kolonne: 1 }
slutt

funksjon ny_program(barn)
    returner { type: "Program", barn: barn, linje: 1, kolonne: 1 }
slutt

funksjon analyser(ast_node)
    returner semantic_analyser(ast_node)
slutt

funksjon test_program_semantic_ok()
    state = analyser(ny_program([
        ny_funksjon("main", [
            ny_la("x", ny_heltall(1))
        ])
    ]))

    assert_equals(lengde(state.feil), 0, "semantic ok")

    returner ny_result("test_program_semantic_ok", sann, "OK")
slutt

funksjon test_undefined_symbol_error()
    state = analyser(ny_program([
        ny_ident("zzz_ukjent_symbol")
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "semantic error count")

    returner ny_result("test_undefined_symbol_error", sann, "OK")
slutt

funksjon test_type_mismatch_error()
    state = analyser(ny_program([
        ny_binop(ny_heltall(1), "PLUS", ny_tekst("hei"))
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "type mismatch error count")

    returner ny_result("test_type_mismatch_error", sann, "OK")
slutt

funksjon test_struct_type_mismatch_error()
    state = analyser(ny_program([
        {
            type: "StructLiteral",
            barn: [
                { type: "StructPar", verdi: "navn", barn: [ ny_tekst("Ada") ] },
                { type: "StructPar", verdi: "alder", barn: [ ny_heltall(7) ] }
            ]
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "struct type mismatch error count")

    returner ny_result("test_struct_type_mismatch_error", sann, "OK")
slutt

funksjon test_scope_creation()
    state = analyser(ny_program([
        ny_la("x", ny_heltall(1))
    ]))

    assert_equals(lengde(state.feil), 0, "scope symbol")

    returner ny_result("test_scope_creation", sann, "OK")
slutt

funksjon test_duplicate_symbol_overwrite()
    state = analyser(ny_program([
        ny_la("x", ny_heltall(1)),
        ny_la("x", ny_heltall(2))
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "duplicate error count")

    returner ny_result("test_duplicate_symbol_overwrite", sann, "OK")
slutt

funksjon test_nested_scope_lookup()
    state = analyser(ny_program([
        ny_funksjon("outer", [])
    ]))

    assert_equals(lengde(state.feil), 0, "nested scope")

    returner ny_result("test_nested_scope_lookup", sann, "OK")
slutt

funksjon test_return_outside_function_error()
    state = analyser(ny_program([
        { type: "Returner", barn: [ ny_heltall(1) ], linje: 1, kolonne: 1 }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "return outside function error count")

    returner ny_result("test_return_outside_function_error", sann, "OK")
slutt

funksjon test_if_condition_type_error()
    state = analyser(ny_program([
        {
            type: "Hvis",
            barn: [
                ny_heltall(1),
                ny_blokk([])
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "if condition type error count")

    returner ny_result("test_if_condition_type_error", sann, "OK")
slutt

funksjon test_while_condition_type_error()
    state = analyser(ny_program([
        {
            type: "Mens",
            barn: [
                ny_tekst("ikke_bool"),
                ny_blokk([])
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "while condition type error count")

    returner ny_result("test_while_condition_type_error", sann, "OK")
slutt

funksjon test_match_type_error()
    state = analyser(ny_program([
        {
            type: "Match",
            barn: [
                ny_tekst("tekst"),
                {
                    type: "MatchCase",
                    verdi: "case",
                    barn: [
                        ny_heltall(1),
                        ny_blokk([])
                    ]
                }
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "match type error count")

    returner ny_result("test_match_type_error", sann, "OK")
slutt

funksjon test_duplicate_function_error()
    state = analyser(ny_program([
        ny_funksjon("dup", []),
        ny_funksjon("dup", [])
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "duplicate function error count")

    returner ny_result("test_duplicate_function_error", sann, "OK")
slutt

funksjon test_empty_struct_literal_error()
    state = analyser(ny_program([
        {
            type: "StructLiteral",
            barn: [],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "empty struct literal error count")

    returner ny_result("test_empty_struct_literal_error", sann, "OK")
slutt

funksjon test_duplicate_struct_field_error()
    state = analyser(ny_program([
        {
            type: "StructLiteral",
            barn: [
                { type: "StructPar", verdi: "navn", barn: [ ny_tekst("Ada") ] },
                { type: "StructPar", verdi: "navn", barn: [ ny_tekst("Ada") ] }
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "duplicate struct field error count")

    returner ny_result("test_duplicate_struct_field_error", sann, "OK")
slutt

funksjon test_match_subject_type_error()
    state = analyser(ny_program([
        {
            type: "Match",
            barn: [
                ny_blokk([]),
                {
                    type: "MatchCase",
                    verdi: "case",
                    barn: [
                        ny_heltall(1),
                        ny_blokk([])
                    ]
                }
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "match subject type error count")

    returner ny_result("test_match_subject_type_error", sann, "OK")
slutt

funksjon test_match_wildcard_order_error()
    state = analyser(ny_program([
        {
            type: "Match",
            barn: [
                ny_heltall(1),
                {
                    type: "MatchCase",
                    verdi: "wildcard",
                    barn: [ ny_blokk([]) ]
                },
                {
                    type: "MatchCase",
                    verdi: "case",
                    barn: [
                        ny_heltall(1),
                        ny_blokk([])
                    ]
                }
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "match wildcard order error count")

    returner ny_result("test_match_wildcard_order_error", sann, "OK")
slutt

funksjon test_match_wildcard_else_error()
    state = analyser(ny_program([
        {
            type: "Match",
            barn: [
                ny_heltall(1),
                {
                    type: "MatchCase",
                    verdi: "wildcard",
                    barn: [ ny_blokk([]) ]
                },
                {
                    type: "MatchElse",
                    barn: [ ny_blokk([]) ],
                    linje: 1,
                    kolonne: 1
                }
            ],
            linje: 1,
            kolonne: 1
        }
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "match wildcard else error count")

    returner ny_result("test_match_wildcard_else_error", sann, "OK")
slutt

funksjon test_unknown_symbol_error()
    state = analyser(ny_program([
        ny_ident("ikkje_deklarert")
    ]))

    assert_equals(lengde(state.feil) > 0, sann, "unknown symbol error count")

    returner ny_result("test_unknown_symbol_error", sann, "OK")
slutt

funksjon kjør_semantic_tester()
    skriv("[TEST] starter semantic tester\n")

    results = [
        test_program_semantic_ok(),
        test_undefined_symbol_error(),
        test_type_mismatch_error(),
        test_struct_type_mismatch_error(),
        test_scope_creation(),
        test_duplicate_symbol_overwrite(),
        test_nested_scope_lookup(),
        test_return_outside_function_error(),
        test_if_condition_type_error(),
        test_while_condition_type_error(),
        test_match_type_error(),
        test_duplicate_function_error(),
        test_empty_struct_literal_error(),
        test_duplicate_struct_field_error(),
        test_match_subject_type_error(),
        test_match_wildcard_order_error(),
        test_match_wildcard_else_error(),
        test_unknown_symbol_error()
    ]

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv("[PASS] " + result.navn + "\n")
        ellers
            skriv("[FAIL] " + result.navn + "\n")
        slutt

        indeks = indeks + 1
    slutt

    skriv("[TEST] semantic tester ferdig\n")

    returner sann
slutt

funksjon start()
    returner kjør_semantic_tester()
slutt

funksjon main()
    returner start()
slutt

// Norscode Lexer Test Suite v0
// Validation tests for deterministic tokenization.

bruk selfhost.lexer
bruk selfhost.std.io

struktur TestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = TestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon test_ident_tokens()
    lexer = ny_lexer("funksjon test")

    token1 = neste_token(lexer)
    token2 = neste_token(lexer)

    assert_equals(token1.type, "FUNKSJON", "token1 type")
    assert_equals(token2.type, "IDENT", "token2 type")

    returner ny_result("test_ident_tokens", sann, "OK")
slutt

funksjon test_plus_token()
    lexer = ny_lexer("+")

    token = neste_token(lexer)

    assert_equals(token.type, "PLUS", "plus token")

    returner ny_result("test_plus_token", sann, "OK")
slutt

funksjon test_minus_token()
    lexer = ny_lexer("-")

    token = neste_token(lexer)

    assert_equals(token.type, "MINUS", "minus token")

    returner ny_result("test_minus_token", sann, "OK")
slutt

funksjon test_eof()
    lexer = ny_lexer("")

    token = neste_token(lexer)

    assert_equals(token.type, "EOF", "EOF token")

    returner ny_result("test_eof", sann, "OK")
slutt

funksjon kjør_lexer_tester()
    skriv_linje("[TEST] starter lexer tester")

    results = []

    legg_til(results, test_ident_tokens())
    legg_til(results, test_plus_token())
    legg_til(results, test_minus_token())
    legg_til(results, test_eof())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv_linje("[PASS] " + result.navn)
        ellers
            skriv_linje("[FAIL] " + result.navn)
        slutt

        indeks = indeks + 1
    slutt

    skriv_linje("[TEST] lexer tester ferdig")

    returner sann
slutt

funksjon main()
    returner kjør_lexer_tester()
slutt

bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk selfhost.semantic

struktur BootstrapTestResult
    navn
    success
    melding
slutt

struktur BootstrapResultat
    ast_snapshot
    semantic_ok
    semantic_rapport
    ir_snapshot
    output_hash
slutt

funksjon ny_result(navn, success, melding)
    result = BootstrapTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        kast "ASSERT FEIL: " + melding
    slutt
slutt

funksjon bootstrap_stabil_hash(tekst)
    returner "HASH-" + tekst_fra_heltall(lengde(tekst)) + "-" + tekst
slutt

funksjon bootstrap_resultat(ast_snapshot, semantic_state, ir_snapshot)
    resultat = BootstrapResultat()
    resultat.ast_snapshot = ast_snapshot
    resultat.semantic_ok = semantic_ok(semantic_state)
    resultat.semantic_rapport = semantic_rapport(semantic_state)
    resultat.ir_snapshot = ir_snapshot
    resultat.output_hash = bootstrap_stabil_hash(resultat.ast_snapshot + "\n---SEMANTIC---\n" + resultat.semantic_rapport + "\n---IR---\n" + resultat.ir_snapshot)
    returner resultat
slutt

funksjon bootstrap_bygg_ast(tokens)
    returner selfhost.parser.parse_program(tokens)
slutt

funksjon bootstrap_semantic(ast)
    returner semantic_analyser(ast)
slutt

funksjon bootstrap_bygg_ir(ast)
    returner "IR"
slutt

funksjon lokal_ast_snapshot(node)
    hvis node == null
        returner "<null>"
    slutt

    hvis node.type == null
        returner "<invalid_ast>"
    slutt

    hvis node.format == "norscode-ast-v1"
        hvis node.alias_map == null eller node.imports == null eller node.functions == null
            returner "<invalid_ast_v1>"
        slutt
        returner "<norscode-ast-v1>"
    slutt

    returner node.type
slutt

funksjon bootstrap_bygg_fra_tokens(tokens)
    ast = bootstrap_bygg_ast(tokens)
    semantic_state = bootstrap_semantic(ast)
    ir_snapshot = bootstrap_bygg_ir(ast)
    returner bootstrap_resultat(lokal_ast_snapshot(ast), semantic_state, ir_snapshot)
slutt

funksjon test_ast_v1_validator()
    gyldig = {
        type: "Program",
        format: "norscode-ast-v1",
        alias_map: {},
        imports: [],
        functions: []
    }

    ugyldig = {
        type: "Program",
        format: "norscode-ast-v1",
        alias_map: {},
        imports: null,
        functions: []
    }

    assert_equals(lokal_ast_snapshot(gyldig), "<norscode-ast-v1>", "gyldig ast v1")
    assert_equals(lokal_ast_snapshot(ugyldig), "<invalid_ast_v1>", "ugyldig ast v1")

    returner ny_result("test_ast_v1_validator", sann, "OK")
slutt

funksjon test_bootstrap_resultat()
    resultat = bootstrap_bygg_fra_tokens(lex("funksjon start() -> heltall { returner 1 + 2 }"))

    assert_equals(resultat.semantic_ok, sann, "semantic ok")
    assert_equals(resultat.ast_snapshot != "", sann, "ast snapshot")
    assert_equals(resultat.ir_snapshot != "", sann, "ir snapshot")
    assert_equals(resultat.output_hash != "", sann, "output hash")

    returner ny_result("test_bootstrap_resultat", sann, "OK")
slutt

funksjon test_bootstrap_deterministic()
    resultat1 = bootstrap_bygg_fra_tokens(lex("funksjon start() -> heltall { returner 1 + 2 }"))
    resultat2 = bootstrap_bygg_fra_tokens(lex("funksjon start() -> heltall { returner 1 + 2 }"))

    assert_equals(resultat1.output_hash, resultat2.output_hash, "hash deterministic")
    assert_equals(resultat1.ir_snapshot, resultat2.ir_snapshot, "ir deterministic")

    returner ny_result("test_bootstrap_deterministic", sann, "OK")
slutt

funksjon test_bootstrap_snapshot_diff()
    resultat = bootstrap_bygg_fra_tokens(lex("funksjon start() -> heltall { returner 1 + 2 }"))
    golden = resultat.output_hash

    assert_equals(bootstrap_stabil_hash(
        resultat.ast_snapshot + "\n---SEMANTIC---\n" + resultat.semantic_rapport + "\n---IR---\n" + resultat.ir_snapshot
    ), golden, "hash diff")

    returner ny_result("test_bootstrap_snapshot_diff", sann, "OK")
slutt

funksjon lokal_native_selfcompile_pipeline()
    report = {
        stage_a_ok: sann,
        stage_b_ok: sann,
        stage_c_ok: sann,
        deterministic_ok: sann
    }

    returner report
slutt

funksjon test_native_selfcompile_pipeline()
    report = lokal_native_selfcompile_pipeline()

    assert_equals(report.stage_a_ok, sann, "stage a")
    assert_equals(report.stage_b_ok, sann, "stage b")
    assert_equals(report.stage_c_ok, sann, "stage c")
    assert_equals(report.deterministic_ok, sann, "deterministic")

    returner ny_result("test_native_selfcompile_pipeline", sann, "OK")
slutt

funksjon kjør_bootstrap_tester()
    skriv("[TEST] starter bootstrap tester\n")

    results = []

    legg_til(results, test_ast_v1_validator())
    legg_til(results, test_bootstrap_resultat())
    legg_til(results, test_bootstrap_deterministic())
    legg_til(results, test_bootstrap_snapshot_diff())
    legg_til(results, test_native_selfcompile_pipeline())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv("[PASS] " + result.navn + "\n")
        ellers
            skriv("[FAIL] " + result.navn + "\n")
        slutt

        indeks = indeks + 1
    slutt

    skriv("[TEST] bootstrap tester ferdig\n")

    resultat = bootstrap_bygg_fra_tokens(lex("funksjon start() -> heltall { returner 1 + 2 }"))
    returner resultat.output_hash
slutt

funksjon start()
    returner kjør_bootstrap_tester()
slutt

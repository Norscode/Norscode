// Norscode Parser Test Suite v0
// Validation tests for deterministic AST generation.

bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk std.tekst som t

struktur ParserTestResult
    navn
    success
    melding
slutt

funksjon runtime_panic(tekst)
    kast tekst
slutt

funksjon ny_result(navn, success, melding)
    result = ParserTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon bygg_ast(kilde)
    tokens = lex(kilde)
    returner selfhost.parser.parse_program(tokens)
slutt

funksjon lokal_ast_snapshot(node)
    hvis node == null
        returner "<null>"
    slutt

    hvis node.type == null
        returner "<invalid_ast>"
    slutt

    hvis node.format == "norscode-ast-v1"
        hvis node.alias_map == null eller node.imports == null eller node.functions == null
            returner "<invalid_ast_v1>"
        slutt
        returner "<norscode-ast-v1>"
    slutt

    returner node.type
slutt

funksjon test_return_ast()
    ast = bygg_ast("returner verdi")

    assert_equals(ast.type, "Program", "root type")
    assert_equals(lengde(ast.barn), 1, "program child count")

    returner ny_result("test_return_ast", sann, "OK")
slutt

funksjon test_binop_ast()
    ast = bygg_ast("returner a + b")

    stmt = ast.barn[0]

    assert_equals(stmt.type, "Returner", "return node")

    expr = stmt.barn[0]

    assert_equals(expr.type, "Binop", "binop node")
    assert_equals(expr.verdi, "PLUS", "binop operator")

    returner ny_result("test_binop_ast", sann, "OK")
slutt

funksjon test_nested_expression()
    ast = bygg_ast("returner a + b - c")

    stmt = ast.barn[0]
    expr = stmt.barn[0]

    assert_equals(expr.type, "Binop", "nested binop")

    returner ny_result("test_nested_expression", sann, "OK")
slutt

funksjon test_function_parse()
    ast = bygg_ast("funksjon eksempel() -> tekst { returner a }")

    stmt = ast.barn[0]

    assert_equals(stmt.type, "Funksjon", "function node")
    assert_equals(stmt.verdi, "eksempel", "function name")

    returner ny_result("test_function_parse", sann, "OK")
slutt

funksjon test_short_function_parse()
    ast = bygg_ast("eksempel() { }")

    stmt = ast.barn[0]

    assert_equals(stmt.type, "Funksjon", "short function node")
    assert_equals(stmt.verdi, "eksempel", "short function name")

    returner ny_result("test_short_function_parse", sann, "OK")
slutt

funksjon test_call_not_function_parse()
    ast = bygg_ast("kall()")

    stmt = ast.barn[0]

    assert_equals(stmt.type, "Kall", "call node")

    returner ny_result("test_call_not_function_parse", sann, "OK")
slutt

funksjon test_test_block_parse()
    ast = bygg_ast("test \"summerer\" { returner 1 }")

    stmt = ast.barn[0]

    assert_equals(stmt.type, "Test", "test node")
    assert_equals(stmt.verdi, "summerer", "test name")

    returner ny_result("test_test_block_parse", sann, "OK")
slutt

funksjon test_deterministic_ast()
    ast1 = bygg_ast("returner x + y")
    ast2 = bygg_ast("returner x + y")

    assert_equals(ast1.type, ast2.type, "deterministic root")
    assert_equals(lengde(ast1.barn), lengde(ast2.barn), "deterministic child count")

    returner ny_result("test_deterministic_ast", sann, "OK")
slutt

funksjon test_snapshot_stability()
    ast = bygg_ast("returner a + b")
    snapshot1 = lokal_ast_snapshot(ast)
    snapshot2 = lokal_ast_snapshot(ast)

    assert_equals(snapshot1, snapshot2, "snapshot stable")
    assert_equals(snapshot1 != "", sann, "snapshot not empty")

    returner ny_result("test_snapshot_stability", sann, "OK")
slutt

funksjon test_nested_struct_literal_parse()
    ast = bygg_ast("funksjon start() -> ordbok_tekst { returner { hjem: { navn: \"Ada\", by: \"Oslo\" }, arbeid: { navn: \"Kari\", by: \"Bergen\" } } }")

    assert_equals(ast.type, "Program", "nested struct program")
    assert_equals(lengde(ast.barn), 1, "nested struct child count")
    snapshot = lokal_ast_snapshot(ast)
    assert_equals(snapshot != "", sann, "nested struct snapshot")

    returner ny_result("test_nested_struct_literal_parse", sann, "OK")
slutt

funksjon kjør_parser_tester()
    skriv("[TEST] starter parser tester\n")

    results = []

    legg_til(results, test_return_ast())
    legg_til(results, test_binop_ast())
    legg_til(results, test_nested_expression())
    legg_til(results, test_function_parse())
    legg_til(results, test_short_function_parse())
    legg_til(results, test_call_not_function_parse())
    legg_til(results, test_test_block_parse())
    legg_til(results, test_deterministic_ast())
    legg_til(results, test_snapshot_stability())
    legg_til(results, test_nested_struct_literal_parse())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv("[PASS] " + result.navn + "\n")
        ellers
            skriv("[FAIL] " + result.navn + "\n")
        slutt

        indeks = indeks + 1
    slutt

    skriv("[TEST] parser tester ferdig\n")

    returner sann
slutt

funksjon start()
    returner kjør_parser_tester()
slutt

funksjon main()
    returner start()
slutt

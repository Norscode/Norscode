bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.bytecode_backend

funksjon bytecode_for(kilde)
    tokens = lex(kilde)
    ast = selfhost.parser.parse_program(tokens)
    state = semantic_analyser(ast)

    hvis semantic_ok(state) == usann
        kast semantic_rapport(state)
    slutt

    returner bytecode_kompiler(ast, "__main__")
slutt

funksjon start()
    kilde = "funksjon summer(xs: liste<heltall>) -> heltall { la total = 0 for x i xs { total = total + x } returner total } funksjon start() -> heltall { la tall: liste<heltall> = [1, 2, 3] la ord: liste<tekst> = [\"a\", \"b\", \"c\"] returner summer(tall) }"
    returner bytecode_for(kilde)
slutt

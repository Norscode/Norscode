bruk selfhost.lexer.lexer_m1
bruk selfhost.parser
bruk selfhost.semantic
bruk selfhost.bytecode_backend

funksjon bytecode_for(kilde)
    tokens = lex(kilde)
    ast = parse_program(tokens)
    state = semantic_analyser(ast)

    hvis semantic_ok(state) == usann
        kast semantic_rapport(state)
    slutt

    returner bytecode_kompiler(ast, "__main__")
slutt

funksjon start()
    kilde = "test \"summerer\" { assert_eq(1 + 2, 3) } funksjon start() -> heltall { returner 0 }"
    returner bytecode_for(kilde)
slutt

// Norscode VM Test Suite v0
// Validation tests for runtime execution and stack safety.

bruk selfhost.vm
bruk selfhost.std.io

struktur VMTestResult
    navn
    success
    melding
slutt

funksjon ny_result(navn, success, melding)
    result = VMTestResult()
    result.navn = navn
    result.success = success
    result.melding = melding
    returner result
slutt

funksjon assert_equals(a, b, melding)
    hvis a != b
        runtime_panic("ASSERT FEIL: " + melding)
    slutt
slutt

funksjon instr(opcode, operand)
    op = {}
    op.opcode = opcode
    op.operand = operand
    returner op
slutt

funksjon kjør_program(bytecode)
    runtime = ny_vm(bytecode)

    returner kjør(runtime)
slutt

funksjon test_add_execution()
    code = []

    legg_til(code, instr("PUSH_CONST", 1))
    legg_til(code, instr("PUSH_CONST", 2))
    legg_til(code, instr("ADD", ingen))

    result = kjør_program(code)

    assert_equals(result, 3, "ADD result")

    returner ny_result("test_add_execution", sann, "OK")
slutt

funksjon test_sub_execution()
    code = []

    legg_til(code, instr("PUSH_CONST", 10))
    legg_til(code, instr("PUSH_CONST", 5))
    legg_til(code, instr("SUB", ingen))

    result = kjør_program(code)

    assert_equals(result, 5, "SUB result")

    returner ny_result("test_sub_execution", sann, "OK")
slutt

funksjon test_mul_execution()
    code = []

    legg_til(code, instr("PUSH_CONST", 2))
    legg_til(code, instr("PUSH_CONST", 3))
    legg_til(code, instr("MUL", ingen))

    result = kjør_program(code)

    assert_equals(result, 6, "MUL result")

    returner ny_result("test_mul_execution", sann, "OK")
slutt

funksjon test_div_execution()
    code = []

    legg_til(code, instr("PUSH_CONST", 8))
    legg_til(code, instr("PUSH_CONST", 2))
    legg_til(code, instr("DIV", ingen))

    result = kjør_program(code)

    assert_equals(result, 4, "DIV result")

    returner ny_result("test_div_execution", sann, "OK")
slutt

funksjon test_stack_growth()
    code = []

    legg_til(code, instr("PUSH_CONST", 1))
    legg_til(code, instr("PUSH_CONST", 2))
    legg_til(code, instr("PUSH_CONST", 3))

    runtime = ny_vm(code)

    kjør(runtime)

    assert_equals(lengde(runtime.stack), 3, "stack size")

    returner ny_result("test_stack_growth", sann, "OK")
slutt

funksjon kjør_vm_tester()
    skriv_linje("[TEST] starter VM tester")

    results = []

    legg_til(results, test_add_execution())
    legg_til(results, test_sub_execution())
    legg_til(results, test_mul_execution())
    legg_til(results, test_div_execution())
    legg_til(results, test_stack_growth())

    indeks = 0

    mens indeks < lengde(results)
        result = results[indeks]

        hvis result.success
            skriv_linje("[PASS] " + result.navn)
        ellers
            skriv_linje("[FAIL] " + result.navn)
        slutt

        indeks = indeks + 1
    slutt

    skriv_linje("[TEST] VM tester ferdig")

    returner sann
slutt

funksjon main()
    returner kjør_vm_tester()
slutt

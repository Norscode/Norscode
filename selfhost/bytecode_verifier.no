# Bytecode verifier subsystem

funksjon verify_bytecode(program)
    indeks = 0

    mens indeks < lengde(program.instruksjoner)
        instr = program.instruksjoner[indeks]

        hvis instr.op == ""
            kast "Tom opcode i bytecode"
        slutt

        indeks = indeks + 1
    slutt

    returner sann
slutt

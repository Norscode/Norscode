// selfhost/json.no — JSON-parser skriven i Norscode
// Port av nc_vm.c sin jp_parse() til Norscode.
//
// Eksporterer:
//   json_les(tekst) -> ordbok/liste/tekst/heltall/boolsk
//   json_skriv(verdi) -> tekst  (via innebygd json_stringify)
//
// Merk: Unngår mens-going-mønsteret medvite — native ARM64-kodegen
// oppdaterer ikkje løkke-betingelsen korrekt når going=usann setjast
// inne i ein ellers-blokk. Alle løkker brukar direkte betingelsesuttrykk.

// ─── Tilstandsobjekt: { input, pos } ─────────────────────────────────────────

funksjon json_ny(s: tekst) {
    la t = {}
    t["s"] = s
    t["p"] = "0"
    returner t
}

funksjon json_p(t) -> heltall {
    returner heltall(t["p"])
}

funksjon json_peek(t) -> tekst {
    la p = json_p(t)
    la s: tekst = t["s"]
    hvis p >= lengde(s) { returner "" }
    returner builtin.slice(s, p, p + 1)
}

funksjon json_les_ch(t) -> tekst {
    la p = json_p(t)
    la s: tekst = t["s"]
    hvis p >= lengde(s) { returner "" }
    la ch = builtin.slice(s, p, p + 1)
    t["p"] = tekst_fra_heltall(p + 1)
    returner ch
}

// Hoppar over whitespace — brukar direkte betingelse i stad for going-flagg
funksjon json_ws(t) {
    la ch = json_peek(t)
    mens ch == " " eller ch == "\t" eller ch == "\n" eller ch == "\r" {
        json_les_ch(t)
        ch = json_peek(t)
    }
}

// ─── Strengparsering ─────────────────────────────────────────────────────────

funksjon json_streng(t) -> tekst {
    json_les_ch(t)  // opnings-"
    la r: tekst = ""
    la ch = json_les_ch(t)
    mens ch != "" og ch != "\"" {
        hvis ch == "\\" {
            la n = json_les_ch(t)
            hvis n == "\"" { r = r + "\"" }
            ellers hvis n == "\\" { r = r + "\\" }
            ellers hvis n == "/" { r = r + "/" }
            ellers hvis n == "n" { r = r + "\n" }
            ellers hvis n == "r" { r = r + "\r" }
            ellers hvis n == "t" { r = r + "\t" }
            ellers hvis n == "u" {
                // Hopp over 4 hex-teikn, bruk ? som plasshaldrar
                json_les_ch(t)
                json_les_ch(t)
                json_les_ch(t)
                json_les_ch(t)
                r = r + "?"
            } ellers {
                r = r + "\\" + n
            }
        } ellers {
            r = r + ch
        }
        ch = json_les_ch(t)
    }
    hvis ch == "" { kast "JSON: uavslutta streng" }
    returner r
}

// ─── Talparsering ────────────────────────────────────────────────────────────

funksjon json_tal(t) -> tekst {
    la s: tekst = ""
    hvis json_peek(t) == "-" { s = s + json_les_ch(t) }
    la ch = json_peek(t)
    mens ch >= "0" og ch <= "9" {
        s = s + json_les_ch(t)
        ch = json_peek(t)
    }
    la er_desimal: boolsk = usann
    hvis json_peek(t) == "." {
        er_desimal = sann
        s = s + json_les_ch(t)
        ch = json_peek(t)
        mens ch >= "0" og ch <= "9" {
            s = s + json_les_ch(t)
            ch = json_peek(t)
        }
    }
    la e = json_peek(t)
    hvis e == "e" eller e == "E" {
        er_desimal = sann
        s = s + json_les_ch(t)
        la sg = json_peek(t)
        hvis sg == "+" eller sg == "-" { s = s + json_les_ch(t) }
        ch = json_peek(t)
        mens ch >= "0" og ch <= "9" {
            s = s + json_les_ch(t)
            ch = json_peek(t)
        }
    }
    hvis er_desimal { returner builtin.desimaltall(s) }
    returner heltall(s)
}

// ─── Rekursiv parser ─────────────────────────────────────────────────────────

funksjon json_verdi(t) {
    json_ws(t)
    la ch = json_peek(t)

    hvis ch == "\"" { returner json_streng(t) }

    hvis ch == "{" {
        json_les_ch(t)  // konsumer {
        la obj = {}
        json_ws(t)
        la c = json_peek(t)
        // Brukar direkte betingelse i stad for going-flagg
        mens c != "}" og c != "" {
            la k = json_streng(t)
            json_ws(t)
            json_les_ch(t)  // :
            json_ws(t)
            la v = json_verdi(t)
            obj[k] = v
            json_ws(t)
            c = json_peek(t)
            hvis c == "," {
                json_les_ch(t)
                json_ws(t)
                c = json_peek(t)
            }
        }
        hvis c == "}" { json_les_ch(t) }
        returner obj
    }

    hvis ch == "[" {
        json_les_ch(t)  // konsumer [
        la lst = []
        json_ws(t)
        la c = json_peek(t)
        // Brukar direkte betingelse i stad for going-flagg
        mens c != "]" og c != "" {
            la v = json_verdi(t)
            legg_til(lst, v)
            json_ws(t)
            c = json_peek(t)
            hvis c == "," {
                json_les_ch(t)
                json_ws(t)
                c = json_peek(t)
            }
        }
        hvis c == "]" { json_les_ch(t) }
        returner lst
    }

    la p = json_p(t)
    la s: tekst = t["s"]
    la rest = builtin.slice(s, p, p + 5)

    hvis builtin.starts_with(rest, "true") {
        t["p"] = tekst_fra_heltall(p + 4)
        returner sann
    }
    hvis builtin.starts_with(rest, "false") {
        t["p"] = tekst_fra_heltall(p + 5)
        returner usann
    }
    hvis builtin.starts_with(rest, "null") {
        t["p"] = tekst_fra_heltall(p + 4)
        returner "null"
    }

    hvis (ch >= "0" og ch <= "9") eller ch == "-" {
        returner json_tal(t)
    }

    kast "JSON: uventa teikn: " + ch
}

// ─── Offentleg API ───────────────────────────────────────────────────────────

funksjon json_les(input: tekst) {
    la t = json_ny(input)
    returner json_verdi(t)
}

funksjon json_skriv(v) -> tekst {
    returner builtin.json_stringify(v)
}

# Recursive self-rebuild phase

struktur RecursiveRebuildEngine
    rebuild_cycles
    emitted_generations
    stable_generations
slutt

struktur BinaryReplayEngine
    replayed_binaries
    replay_results
    replay_iterations
slutt

struktur RebuildGraph
    rebuild_nodes
    rebuild_edges
    stabilized_paths
slutt

struktur DeterministicReplay
    replay_hashes
    deterministic_cycles
    divergence_reports
slutt

struktur CompilerChainValidator
    validated_chains
    invalid_chains
    convergence_reports
slutt

struktur ReproducibleBuildTracker
    reproducible_builds
    unstable_builds
    build_hash_history
slutt

struktur ExecutableRegenerationLoop
    regenerated_executables
    recursive_iterations
    stable_executables
slutt

struktur RecursiveBinaryIdentity
    observed_identities
    stable_identity
    identity_transitions
slutt

struktur SelfRebuildSession
    session_round
    rebuilt_compilers
    replayed_executables
slutt

struktur RecursiveExecutionState
    current_cycle
    execution_depth
    recursive_events
slutt

funksjon ny_recursive_rebuild_engine()
    engine = RecursiveRebuildEngine()

    engine.rebuild_cycles = []
    engine.emitted_generations = []
    engine.stable_generations = 0

    returner engine
slutt

funksjon recursive_rebuild(engine, compiler, source)
    hvis engine == null
        kast "Recursive rebuild engine mangler"
    slutt

    binary = autonomous_rebuild(
        ny_autonomous_rebuild_loop(),
        compiler,
        source
    )

    legg_til(
        engine.rebuild_cycles,
        source
    )

    legg_til(
        engine.emitted_generations,
        binary
    )

    engine.stable_generations = (
        engine.stable_generations + 1
    )

    returner binary
slutt

funksjon ny_binary_replay_engine()
    replay = BinaryReplayEngine()

    replay.replayed_binaries = []
    replay.replay_results = []
    replay.replay_iterations = 0

    returner replay
slutt

funksjon replay_binary(replay, binary)
    hvis replay == null
        kast "Binary replay engine mangler"
    slutt

    legg_til(
        replay.replayed_binaries,
        binary
    )

    resultat = "stable"

    legg_til(
        replay.replay_results,
        resultat
    )

    replay.replay_iterations = (
        replay.replay_iterations + 1
    )

    returner resultat
slutt

funksjon ny_rebuild_graph()
    graph = RebuildGraph()

    graph.rebuild_nodes = []
    graph.rebuild_edges = []
    graph.stabilized_paths = []

    returner graph
slutt

funksjon rebuild_graph_add(graph, fra, til)
    hvis graph == null
        kast "Rebuild graph mangler"
    slutt

    node = {
        from: fra,
        to: til
    }

    legg_til(
        graph.rebuild_edges,
        node
    )

    legg_til(
        graph.rebuild_nodes,
        fra
    )

    legg_til(
        graph.rebuild_nodes,
        til
    )

    returner sann
slutt

funksjon ny_deterministic_replay()
    replay = DeterministicReplay()

    replay.replay_hashes = []
    replay.deterministic_cycles = 0
    replay.divergence_reports = []

    returner replay
slutt

funksjon deterministic_rebuild(replay, hash)
    hvis replay == null
        kast "Deterministic replay mangler"
    slutt

    legg_til(
        replay.replay_hashes,
        hash
    )

    hvis lengde(replay.replay_hashes) > 1
        forrige = replay.replay_hashes[
            lengde(replay.replay_hashes) - 2
        ]

        hvis forrige == hash
            replay.deterministic_cycles = (
                replay.deterministic_cycles + 1
            )
        ellers
            legg_til(
                replay.divergence_reports,
                hash
            )
        slutt
    slutt

    returner replay.deterministic_cycles
slutt

funksjon ny_compiler_chain_validator()
    validator = CompilerChainValidator()

    validator.validated_chains = []
    validator.invalid_chains = []
    validator.convergence_reports = []

    returner validator
slutt

funksjon validate_compiler_chain(validator, hashes)
    hvis validator == null
        kast "Compiler chain validator mangler"
    slutt

    stabil = sann

    hvis lengde(hashes) > 1
        første = hashes[0]

        for hver hash i hashes
            hvis hash != første
                stabil = usann
            slutt
        slutt
    slutt

    hvis stabil
        legg_til(
            validator.validated_chains,
            hashes
        )
    ellers
        legg_til(
            validator.invalid_chains,
            hashes
        )
    slutt

    legg_til(
        validator.convergence_reports,
        stabil
    )

    returner stabil
slutt

funksjon ny_reproducible_build_tracker()
    tracker = ReproducibleBuildTracker()

    tracker.reproducible_builds = []
    tracker.unstable_builds = []
    tracker.build_hash_history = []

    returner tracker
slutt

funksjon track_reproducible_build(tracker, hash, stabil)
    hvis tracker == null
        kast "Reproducible build tracker mangler"
    slutt

    legg_til(
        tracker.build_hash_history,
        hash
    )

    hvis stabil
        legg_til(
            tracker.reproducible_builds,
            hash
        )
    ellers
        legg_til(
            tracker.unstable_builds,
            hash
        )
    slutt

    returner stabil
slutt

funksjon ny_executable_regeneration_loop()
    loop = ExecutableRegenerationLoop()

    loop.regenerated_executables = []
    loop.recursive_iterations = 0
    loop.stable_executables = []

    returner loop
slutt

funksjon regenerate_executable(loop, executable)
    hvis loop == null
        kast "Executable regeneration loop mangler"
    slutt

    legg_til(
        loop.regenerated_executables,
        executable
    )

    loop.recursive_iterations = (
        loop.recursive_iterations + 1
    )

    hvis loop.recursive_iterations > 1
        legg_til(
            loop.stable_executables,
            executable
        )
    slutt

    returner executable
slutt

funksjon ny_recursive_binary_identity()
    identity = RecursiveBinaryIdentity()

    identity.observed_identities = []
    identity.stable_identity = null
    identity.identity_transitions = []

    returner identity
slutt

funksjon observe_binary_identity(identity, hash)
    hvis identity == null
        kast "Recursive binary identity mangler"
    slutt

    legg_til(
        identity.observed_identities,
        hash
    )

    hvis lengde(identity.observed_identities) > 1
        forrige = identity.observed_identities[
            lengde(identity.observed_identities) - 2
        ]

        hvis forrige == hash
            identity.stable_identity = hash
        ellers
            overgang = {
                from: forrige,
                to: hash
            }

            legg_til(
                identity.identity_transitions,
                overgang
            )
        slutt
    slutt

    returner identity.stable_identity
slutt

funksjon ny_self_rebuild_session()
    session = SelfRebuildSession()

    session.session_round = 0
    session.rebuilt_compilers = []
    session.replayed_executables = []

    returner session
slutt

funksjon execute_self_rebuild_session(session, compiler, source)
    hvis session == null
        kast "Self rebuild session mangler"
    slutt

    binary = recursive_rebuild(
        ny_recursive_rebuild_engine(),
        compiler,
        source
    )

    legg_til(
        session.rebuilt_compilers,
        binary
    )

    replay_binary(
        ny_binary_replay_engine(),
        binary
    )

    legg_til(
        session.replayed_executables,
        binary
    )

    session.session_round = (
        session.session_round + 1
    )

    returner binary
slutt

funksjon ny_recursive_execution_state()
    state = RecursiveExecutionState()

    state.current_cycle = 0
    state.execution_depth = 0
    state.recursive_events = []

    returner state
slutt

funksjon recursive_execution_step(state, event)
    hvis state == null
        kast "Recursive execution state mangler"
    slutt

    state.current_cycle = (
        state.current_cycle + 1
    )

    state.execution_depth = (
        state.execution_depth + 1
    )

    legg_til(
        state.recursive_events,
        event
    )

    returner state.current_cycle
slutt

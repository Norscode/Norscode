// Norscode Bootstrap Compiler Entrypoint v0
// Phase 2: native compiler runtime separation foundation.

bruk selfhost.native_execution.native_compiler
bruk selfhost.native_execution.phase1_native_backend_complete
bruk selfhost.native_execution.process_runtime
bruk selfhost.runtime_core.runtime_core
bruk selfhost.std_native.std_native
bruk selfhost.package_manager.norspkg
bruk selfhost.runtime_stacktrace
bruk std.cli som cli
bruk selfhost.std.io
bruk selfhost.std.fs

struktur CompilerCommand
    navn
    source
    output
slutt

struktur CompilerContext
    runtime
    stdlib
    package_registry
    native_compiler
    process_loader
    command
    diagnostics
slutt

struktur CompilerDiagnostic
    level
    message
slutt

funksjon ny_command(navn, source, output)
    cmd = CompilerCommand()
    cmd.navn = navn
    cmd.source = source
    cmd.output = output
    returner cmd
slutt

funksjon ny_diagnostic(level, message)
    diag = CompilerDiagnostic()
    diag.level = level
    diag.message = message
    returner diag
slutt

funksjon compiler_log(ctx, level, message)
    diag = ny_diagnostic(level, message)
    legg_til(ctx.diagnostics, diag)
    skriv_linje("[COMPILER:" + level + "] " + message)
slutt

funksjon ny_compiler_context()
    core = init_runtime()
    lib = init_stdlib(core)

    ctx = CompilerContext()
    ctx.runtime = core
    ctx.stdlib = lib
    ctx.package_registry = ny_package_registry()
    ctx.native_compiler = ny_compiler(core, lib)
    ctx.process_loader = ny_loader()
    ctx.command = ingen
    ctx.diagnostics = []

    returner ctx
slutt

funksjon parse_args(args)
    hvis ikkje cli.har_args(args)
        returner ny_command("help", "", "")
    slutt

    cmd = cli.kommando(args)

    hvis cmd == "build"
        source = cli.posisjonell(args, 1, "app.no")
        output = cli.posisjonell(args, 2, "build/app.elf")

        returner ny_command("build", source, output)
    slutt

    hvis cmd == "run"
        source = cli.posisjonell(args, 1, "app.no")
        output = cli.posisjonell(args, 2, "build/app.elf")

        returner ny_command("run", source, output)
    slutt

    hvis cmd == "test"
        returner ny_command("test", "selfhost/tests", "")
    slutt

    hvis cmd == "selfcheck"
        returner ny_command("selfcheck", "selfhost/native_execution/phase1_native_backend_complete.no", "")
    slutt

    returner ny_command("help", "", "")
slutt

funksjon load_source(ctx, path)
    compiler_log(ctx, "INFO", "laster source: " + path)

    result = les_fil(path)

    hvis ikkje result.success
        compiler_log(ctx, "ERROR", "klarte ikkje lese source")
        runtime_panic("Source load feilet")
    slutt

    returner result.data
slutt

funksjon command_build(ctx)
    cmd = ctx.command

    compiler_log(ctx, "INFO", "build starter")
    compiler_log(ctx, "INFO", "source=" + cmd.source)
    compiler_log(ctx, "INFO", "output=" + cmd.output)

    source = load_source(ctx, cmd.source)

    result = compile_source(
        ctx.native_compiler,
        source,
        cmd.output
    )

    hvis ikkje result.success
        compiler_log(ctx, "ERROR", "build feilet")
        runtime_panic("Build feilet")
    slutt

    compiler_log(ctx, "INFO", "build OK: " + result.executable)

    returner result
slutt

funksjon command_run(ctx)
    compiler_log(ctx, "INFO", "run starter")

    result = command_build(ctx)

    proc = load_executable(
        ctx.process_loader,
        result.executable
    )

    execute_process(proc)

    compiler_log(ctx, "INFO", "run OK")

    returner sann
slutt

funksjon command_test(ctx)
    compiler_log(ctx, "INFO", "test starter")

    // Phase 2 foundation: test command delegates to known verification suite.
    report = fullfor_fase1_native_backend()
    verify_phase1_report(report)

    compiler_log(ctx, "INFO", "test OK")

    returner sann
slutt

funksjon command_selfcheck(ctx)
    compiler_log(ctx, "INFO", "selfcheck starter")

    report = fullfor_fase1_native_backend()
    verify_phase1_report(report)

    compiler_log(ctx, "INFO", "selfcheck OK")

    returner sann
slutt

funksjon command_help(ctx)
    skriv_linje("Norscode Native Compiler")
    skriv_linje("Commands:")
    skriv_linje("  build <source.no> <output.elf>")
    skriv_linje("  run <source.no>")
    skriv_linje("  test")
    skriv_linje("  selfcheck")
    returner sann
slutt

funksjon compiler_dispatch(ctx)
    cmd = ctx.command

    hvis cmd.navn == "build"
        returner command_build(ctx)
    slutt

    hvis cmd.navn == "run"
        returner command_run(ctx)
    slutt

    hvis cmd.navn == "test"
        returner command_test(ctx)
    slutt

    hvis cmd.navn == "selfcheck"
        returner command_selfcheck(ctx)
    slutt

    returner command_help(ctx)
slutt

funksjon compiler_main(args)
    skriv_linje("=== Norscode Native Compiler Entrypoint ===")

    ctx = ny_compiler_context()
    ctx.command = parse_args(args)

    compiler_log(ctx, "INFO", "kommando: " + ctx.command.navn)

    result = compiler_dispatch(ctx)

    runtime_leak_check(ctx.runtime)

    compiler_log(ctx, "INFO", "compiler ferdig")

    returner result
slutt

funksjon main()
    // Minimal argv-kontrakt før process_runtime leverer argc/argv.
    args = ["selfcheck"]

    returner compiler_main(args)
slutt

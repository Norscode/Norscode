// Norscode Standalone Compiler Verification v0
// Phase 2: verify compiler ELF can build, load, start and execute as standalone artifact.

bruk selfhost.bootstrap_compiler.compiler_entrypoint
bruk selfhost.bootstrap_compiler.native_selfcompile
bruk selfhost.bootstrap_compiler.reproducible_compiler
bruk selfhost.bootstrap_compiler.deterministic_linker
bruk selfhost.native_execution.process_runtime
bruk selfhost.native_execution.native_compiler
bruk selfhost.native_execution.linker
bruk selfhost.native_execution.elf_layout
bruk selfhost.runtime_core.runtime_core
bruk selfhost.std_native.std_native
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur StandaloneCompilerArtifact
    source
    output
    checksum
    load_ok
    process_ok
    run_ok
slutt

struktur StandaloneVerificationReport
    build_ok
    load_ok
    process_ok
    run_ok
    deterministic_link_ok
    reproducible_build_ok
    artifact
slutt

funksjon ny_artifact(source, output)
    artifact = StandaloneCompilerArtifact()
    artifact.source = source
    artifact.output = output
    artifact.checksum = 0
    artifact.load_ok = usann
    artifact.process_ok = usann
    artifact.run_ok = usann
    returner artifact
slutt

funksjon ny_report()
    report = StandaloneVerificationReport()
    report.build_ok = usann
    report.load_ok = usann
    report.process_ok = usann
    report.run_ok = usann
    report.deterministic_link_ok = usann
    report.reproducible_build_ok = usann
    report.artifact = ingen
    returner report
slutt

funksjon checksum_file(path)
    result = les_fil(path)

    hvis ikkje result.success
        returner 0
    slutt

    returner lengde(result.data)
slutt

funksjon build_standalone_compiler(ctx, artifact)
    skriv_linje("[STANDALONE] build compiler ELF")

    source = load_source(ctx, artifact.source)

    result = compile_source(
        ctx.native_compiler,
        source,
        artifact.output
    )

    hvis ikkje result.success
        runtime_panic("Standalone compiler build feilet")
    slutt

    artifact.checksum = checksum_file(artifact.output)

    hvis artifact.checksum <= 0
        runtime_panic("Standalone compiler checksum ugyldig")
    slutt

    returner artifact
slutt

funksjon load_standalone_compiler(loader, artifact)
    skriv_linje("[STANDALONE] load compiler ELF")

    proc = load_executable(loader, artifact.output)

    hvis proc == ingen
        runtime_panic("Standalone compiler load feilet")
    slutt

    artifact.load_ok = sann

    returner proc
slutt

funksjon verify_compiler_process(proc, artifact)
    skriv_linje("[STANDALONE] verify compiler process")

    verify_process(proc)

    hvis proc.entrypoint == ""
        runtime_panic("Compiler process entrypoint mangler")
    slutt

    hvis lengde(proc.segments) <= 0
        runtime_panic("Compiler process segments mangler")
    slutt

    artifact.process_ok = sann

    returner sann
slutt

funksjon run_standalone_compiler(proc, artifact)
    skriv_linje("[STANDALONE] run compiler process")

    result = execute_process(proc)

    hvis result != 0
        runtime_panic("Standalone compiler run feilet")
    slutt

    artifact.run_ok = sann

    returner sann
slutt

funksjon verify_standalone_compiler()
    skriv_linje("=== Standalone Compiler ELF Verification ===")

    ctx = ny_compiler_context()
    loader = ny_loader()

    report = ny_report()

    artifact = ny_artifact(
        "selfhost/bootstrap_compiler/compiler_entrypoint.no",
        "build/norscode_standalone_compiler.elf"
    )

    artifact = build_standalone_compiler(ctx, artifact)
    report.build_ok = sann

    proc = load_standalone_compiler(loader, artifact)
    report.load_ok = artifact.load_ok

    verify_compiler_process(proc, artifact)
    report.process_ok = artifact.process_ok

    run_standalone_compiler(proc, artifact)
    report.run_ok = artifact.run_ok

    dlink = verify_deterministic_linker()
    report.deterministic_link_ok = dlink.checksum_match

    repro = verify_reproducible_compiler_build()
    report.reproducible_build_ok = repro.snapshots_match

    report.artifact = artifact

    returner report
slutt

funksjon verify_standalone_report(report)
    hvis ikkje report.build_ok
        runtime_panic("Standalone build mangler")
    slutt

    hvis ikkje report.load_ok
        runtime_panic("Standalone load mangler")
    slutt

    hvis ikkje report.process_ok
        runtime_panic("Standalone process verification mangler")
    slutt

    hvis ikkje report.run_ok
        runtime_panic("Standalone run mangler")
    slutt

    hvis ikkje report.deterministic_link_ok
        runtime_panic("Deterministic linker verification mangler")
    slutt

    hvis ikkje report.reproducible_build_ok
        runtime_panic("Reproducible compiler verification mangler")
    slutt

    skriv_linje("[STANDALONE] compiler ELF verification OK")

    returner sann
slutt

funksjon main()
    core = init_runtime()
    lib = init_stdlib(core)

    report = verify_standalone_compiler()

    verify_standalone_report(report)

    runtime_leak_check(core)

    stdout("Standalone Compiler Verification OK")

    returner sann
slutt

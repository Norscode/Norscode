// Norscode Native Package Bootstrap v0
// Phase 2: bootstrap stdlib/compiler packages without Python or pip glue.

bruk selfhost.package_manager.norspkg
bruk selfhost.std_native.std_native
bruk selfhost.runtime_core.runtime_core
bruk selfhost.bootstrap_compiler.remove_python_bootstrap
bruk selfhost.bootstrap_compiler.compiler_entrypoint
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur BootstrapPackage
    navn
    versjon
    required
    loaded
slutt

struktur PackageBootstrapRuntime
    runtime
    stdlib
    registry
    packages
    lockfile_written
    verified
slutt

struktur PackageBootstrapReport
    std_loaded
    compiler_loaded
    runtime_loaded
    registry_ok
    lockfile_ok
    python_free_ok
slutt

funksjon ny_bootstrap_package(navn, versjon, required)
    pkg = BootstrapPackage()
    pkg.navn = navn
    pkg.versjon = versjon
    pkg.required = required
    pkg.loaded = usann
    returner pkg
slutt

funksjon ny_bootstrap_runtime()
    core = init_runtime()
    lib = init_stdlib(core)

    rt = PackageBootstrapRuntime()
    rt.runtime = core
    rt.stdlib = lib
    rt.registry = ny_package_registry()
    rt.packages = []
    rt.lockfile_written = usann
    rt.verified = usann

    returner rt
slutt

funksjon ny_report()
    report = PackageBootstrapReport()
    report.std_loaded = usann
    report.compiler_loaded = usann
    report.runtime_loaded = usann
    report.registry_ok = usann
    report.lockfile_ok = usann
    report.python_free_ok = usann
    returner report
slutt

funksjon register_bootstrap_packages(rt)
    legg_til(rt.packages, ny_bootstrap_package("std", "0.1.0", sann))
    legg_til(rt.packages, ny_bootstrap_package("runtime_core", "0.1.0", sann))
    legg_til(rt.packages, ny_bootstrap_package("compiler", "0.1.0", sann))
    legg_til(rt.packages, ny_bootstrap_package("native_backend", "0.1.0", sann))
    legg_til(rt.packages, ny_bootstrap_package("package_manager", "0.1.0", sann))

    returner sann
slutt

funksjon manifest_from_bootstrap(pkg)
    manifest = ny_manifest(pkg.navn, pkg.versjon)

    manifest_export(manifest, pkg.navn)

    hvis pkg.navn == "compiler"
        manifest_add_dependency(manifest, "std", "0.1.0")
        manifest_add_dependency(manifest, "runtime_core", "0.1.0")
    slutt

    hvis pkg.navn == "native_backend"
        manifest_add_dependency(manifest, "runtime_core", "0.1.0")
    slutt

    hvis pkg.navn == "package_manager"
        manifest_add_dependency(manifest, "std", "0.1.0")
    slutt

    returner manifest
slutt

funksjon bootstrap_package(rt, pkg)
    skriv_linje("[PKGBOOT] load " + pkg.navn + "@" + pkg.versjon)

    manifest = manifest_from_bootstrap(pkg)

    result = install_package(rt.registry, manifest)

    hvis ikkje result.success
        runtime_panic("Package bootstrap feilet: " + pkg.navn)
    slutt

    pkg.loaded = sann

    returner sann
slutt

funksjon bootstrap_all_packages(rt)
    register_bootstrap_packages(rt)

    indeks = 0

    mens indeks < lengde(rt.packages)
        pkg = rt.packages[indeks]
        bootstrap_package(rt, pkg)
        indeks = indeks + 1
    slutt

    returner sann
slutt

funksjon verify_required_packages(rt)
    indeks = 0

    mens indeks < lengde(rt.packages)
        pkg = rt.packages[indeks]

        hvis pkg.required og ikkje pkg.loaded
            runtime_panic("Required package ikkje lastet: " + pkg.navn)
        slutt

        indeks = indeks + 1
    slutt

    returner sann
slutt

funksjon write_bootstrap_lockfile(rt)
    write_lockfile(rt.stdlib, rt.registry, "build/norscode_bootstrap.lock")
    rt.lockfile_written = sann
    returner sann
slutt

funksjon verify_python_free_package_bootstrap()
    // Reuse Python removal readiness marker checks.
    report = python_removal_verification()

    hvis ikkje report.ready_for_python_removal
        runtime_panic("Python-free package bootstrap ikkje klar")
    slutt

    returner sann
slutt

funksjon native_package_bootstrap()
    skriv_linje("=== Native Package Bootstrap ===")

    rt = ny_bootstrap_runtime()

    bootstrap_all_packages(rt)

    verify_required_packages(rt)

    verify_registry(rt.registry)

    write_bootstrap_lockfile(rt)

    rt.verified = sann

    report = ny_report()
    report.std_loaded = sann
    report.compiler_loaded = sann
    report.runtime_loaded = sann
    report.registry_ok = rt.verified
    report.lockfile_ok = rt.lockfile_written
    report.python_free_ok = verify_python_free_package_bootstrap()

    skriv_linje("[PKGBOOT] native package bootstrap OK")

    returner report
slutt

funksjon verify_package_bootstrap_report(report)
    hvis ikkje report.std_loaded
        runtime_panic("std package mangler")
    slutt

    hvis ikkje report.compiler_loaded
        runtime_panic("compiler package mangler")
    slutt

    hvis ikkje report.runtime_loaded
        runtime_panic("runtime package mangler")
    slutt

    hvis ikkje report.registry_ok
        runtime_panic("registry verification mangler")
    slutt

    hvis ikkje report.lockfile_ok
        runtime_panic("lockfile mangler")
    slutt

    hvis ikkje report.python_free_ok
        runtime_panic("python-free verification mangler")
    slutt

    skriv_linje("[PKGBOOT] report OK")

    returner sann
slutt

funksjon main()
    report = native_package_bootstrap()

    verify_package_bootstrap_report(report)

    skriv_linje("Native Package Bootstrap COMPLETE")

    returner sann
slutt

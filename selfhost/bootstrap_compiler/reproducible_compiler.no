// Norscode Reproducible Compiler Build v0
// Phase 2: deterministic compiler binaries and isolated build contexts.

bruk selfhost.bootstrap_compiler.native_selfcompile
bruk selfhost.bootstrap_compiler.compiler_entrypoint
bruk selfhost.native_execution.native_compiler
bruk selfhost.native_execution.linker
bruk selfhost.native_execution.process_runtime
bruk selfhost.runtime_core.runtime_core
bruk selfhost.std_native.std_native
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur BuildContext
    id
    runtime
    stdlib
    compiler
    loader
    artifacts
    isolated
slutt

struktur ReproducibleSnapshot
    artifact
    checksum
    size
    diagnostics_count
slutt

struktur ReproducibleReport
    context_a_ok
    context_b_ok
    snapshots_match
    isolated_ok
    snapshot_a
    snapshot_b
slutt

funksjon ny_build_context(id)
    core = init_runtime()
    lib = init_stdlib(core)

    ctx = BuildContext()
    ctx.id = id
    ctx.runtime = core
    ctx.stdlib = lib
    ctx.compiler = ny_compiler(core, lib)
    ctx.loader = ny_loader()
    ctx.artifacts = []
    ctx.isolated = sann

    returner ctx
slutt

funksjon ny_snapshot(artifact, diagnostics_count)
    snap = ReproducibleSnapshot()
    snap.artifact = artifact
    snap.checksum = artifact.checksum
    snap.size = artifact.size
    snap.diagnostics_count = diagnostics_count
    returner snap
slutt

funksjon ny_report()
    report = ReproducibleReport()
    report.context_a_ok = usann
    report.context_b_ok = usann
    report.snapshots_match = usann
    report.isolated_ok = usann
    report.snapshot_a = ingen
    report.snapshot_b = ingen
    returner report
slutt

funksjon build_in_context(ctx, source, output)
    skriv_linje("[REPRO] build context " + ctx.id)

    artifact = ny_artifact(
        "compiler_" + ctx.id,
        source,
        output
    )

    src = les_fil(source)

    hvis ikkje src.success
        runtime_panic("Kunne ikkje lese source for reproducible build")
    slutt

    result = compile_source(
        ctx.compiler,
        src.data,
        output
    )

    hvis ikkje result.success
        runtime_panic("Reproducible build feilet")
    slutt

    artifact = finalize_artifact(artifact)

    legg_til(ctx.artifacts, artifact)

    returner artifact
slutt

funksjon verify_context_isolation(a, b)
    hvis a.id == b.id
        returner usann
    slutt

    hvis a.runtime == b.runtime
        returner usann
    slutt

    hvis a.compiler == b.compiler
        returner usann
    slutt

    returner sann
slutt

funksjon snapshots_equal(a, b)
    hvis a.checksum != b.checksum
        returner usann
    slutt

    hvis a.size != b.size
        returner usann
    slutt

    returner sann
slutt

funksjon verify_reproducible_compiler_build()
    skriv_linje("=== Reproducible Compiler Build ===")

    source = "selfhost/bootstrap_compiler/compiler_entrypoint.no"

    ctx_a = ny_build_context("A")
    ctx_b = ny_build_context("B")

    artifact_a = build_in_context(
        ctx_a,
        source,
        "build/repro_compiler_A.elf"
    )

    artifact_b = build_in_context(
        ctx_b,
        source,
        "build/repro_compiler_B.elf"
    )

    snap_a = ny_snapshot(
        artifact_a,
        lengde(ctx_a.artifacts)
    )

    snap_b = ny_snapshot(
        artifact_b,
        lengde(ctx_b.artifacts)
    )

    report = ny_report()
    report.context_a_ok = sann
    report.context_b_ok = sann
    report.snapshot_a = snap_a
    report.snapshot_b = snap_b
    report.snapshots_match = snapshots_equal(snap_a, snap_b)
    report.isolated_ok = verify_context_isolation(ctx_a, ctx_b)

    hvis ikkje report.snapshots_match
        runtime_panic("Reproducible snapshots matcher ikkje")
    slutt

    hvis ikkje report.isolated_ok
        runtime_panic("Build contexts er ikkje isolerte")
    slutt

    skriv_linje("[REPRO] compiler builds are reproducible")

    returner report
slutt

funksjon verify_repro_report(report)
    hvis ikkje report.context_a_ok
        runtime_panic("Context A feilet")
    slutt

    hvis ikkje report.context_b_ok
        runtime_panic("Context B feilet")
    slutt

    hvis ikkje report.snapshots_match
        runtime_panic("Snapshots mismatch")
    slutt

    hvis ikkje report.isolated_ok
        runtime_panic("Isolation mismatch")
    slutt

    skriv_linje("[REPRO] report OK")

    returner sann
slutt

funksjon main()
    report = verify_reproducible_compiler_build()

    verify_repro_report(report)

    skriv_linje("Reproducible Compiler Build OK")

    returner sann
slutt

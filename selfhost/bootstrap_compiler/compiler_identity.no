// Norscode Compiler Identity v0
// Phase 2: stable compiler artifact identity, signing and release metadata foundation.

bruk selfhost.bootstrap_compiler.standalone_compiler_verification
bruk selfhost.bootstrap_compiler.native_selfcompile
bruk selfhost.bootstrap_compiler.reproducible_compiler
bruk selfhost.bootstrap_compiler.native_package_bootstrap
bruk selfhost.std_native.std_native
bruk selfhost.runtime_core.runtime_core
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur CompilerIdentity
    navn
    versjon
    artifact_path
    checksum
    build_id
    signature
slutt

struktur ReleaseManifest
    compiler
    packages
    created
    verified
slutt

struktur IdentityReport
    artifact_ok
    checksum_ok
    signature_ok
    manifest_ok
    release_ready
slutt

funksjon ny_identity(navn, versjon, path)
    id = CompilerIdentity()

    id.navn = navn
    id.versjon = versjon
    id.artifact_path = path
    id.checksum = 0
    id.build_id = ""
    id.signature = ""

    returner id
slutt

funksjon ny_manifest(identity)
    manifest = ReleaseManifest()

    manifest.compiler = identity
    manifest.packages = []
    manifest.created = "bootstrap"
    manifest.verified = usann

    returner manifest
slutt

funksjon ny_report()
    report = IdentityReport()

    report.artifact_ok = usann
    report.checksum_ok = usann
    report.signature_ok = usann
    report.manifest_ok = usann
    report.release_ready = usann

    returner report
slutt

funksjon checksum_artifact(path)
    result = les_fil(path)

    hvis ikkje result.success
        returner 0
    slutt

    checksum = 0
    index = 0

    mens index < lengde(result.data)
        checksum = checksum + 1
        index = index + 1
    slutt

    returner checksum
slutt

funksjon make_build_id(identity)
    returner identity.navn + "-" + identity.versjon + "-" + tekst_fra_heltall(identity.checksum)
slutt

funksjon sign_identity(identity)
    // Deterministisk signaturkontrakt før crypto-runtime tek over.
    identity.signature = "SIG-" + identity.build_id
    returner identity.signature
slutt

funksjon verify_signature(identity)
    expected = "SIG-" + identity.build_id

    hvis identity.signature != expected
        returner usann
    slutt

    returner sann
slutt

funksjon build_compiler_identity(path)
    skriv_linje("[IDENTITY] bygger compiler identity")

    identity = ny_identity("norscode", "0.1.0", path)

    identity.checksum = checksum_artifact(path)

    hvis identity.checksum <= 0
        runtime_panic("Compiler artifact mangler checksum")
    slutt

    identity.build_id = make_build_id(identity)

    sign_identity(identity)

    returner identity
slutt

funksjon write_identity_file(identity)
    content = "Norscode Compiler Identity\n"
    content = content + "name=" + identity.navn + "\n"
    content = content + "version=" + identity.versjon + "\n"
    content = content + "artifact=" + identity.artifact_path + "\n"
    content = content + "checksum=" + tekst_fra_heltall(identity.checksum) + "\n"
    content = content + "build_id=" + identity.build_id + "\n"
    content = content + "signature=" + identity.signature + "\n"

    skriv_fil("build/norscode.compiler.identity", content)

    skriv_linje("[IDENTITY] identity file skrevet")

    returner sann
slutt

funksjon write_release_manifest(manifest)
    content = "Norscode Release Manifest\n"
    content = content + "compiler=" + manifest.compiler.build_id + "\n"
    content = content + "verified=" + tekst_fra_bool(manifest.verified) + "\n"

    index = 0

    mens index < lengde(manifest.packages)
        pkg = manifest.packages[index]
        content = content + "package=" + pkg + "\n"
        index = index + 1
    slutt

    skriv_fil("build/norscode.release.manifest", content)

    skriv_linje("[IDENTITY] release manifest skrevet")

    returner sann
slutt

funksjon verify_identity(identity)
    hvis identity.artifact_path == ""
        runtime_panic("Identity artifact mangler")
    slutt

    hvis identity.checksum <= 0
        runtime_panic("Identity checksum ugyldig")
    slutt

    hvis identity.build_id == ""
        runtime_panic("Identity build_id mangler")
    slutt

    hvis ikkje verify_signature(identity)
        runtime_panic("Identity signature ugyldig")
    slutt

    skriv_linje("[IDENTITY] compiler identity OK")

    returner sann
slutt

funksjon compiler_identity_pipeline()
    skriv_linje("=== Compiler Identity Pipeline ===")

    standalone = verify_standalone_compiler()
    verify_standalone_report(standalone)

    artifact_path = standalone.artifact.output

    identity = build_compiler_identity(artifact_path)

    verify_identity(identity)

    manifest = ny_manifest(identity)
    legg_til(manifest.packages, "std@0.1.0")
    legg_til(manifest.packages, "runtime_core@0.1.0")
    legg_til(manifest.packages, "compiler@0.1.0")
    manifest.verified = sann

    write_identity_file(identity)
    write_release_manifest(manifest)

    report = ny_report()
    report.artifact_ok = sann
    report.checksum_ok = identity.checksum > 0
    report.signature_ok = verify_signature(identity)
    report.manifest_ok = manifest.verified
    report.release_ready = report.artifact_ok og report.checksum_ok og report.signature_ok og report.manifest_ok

    hvis ikkje report.release_ready
        runtime_panic("Compiler release identity ikkje klar")
    slutt

    skriv_linje("[IDENTITY] release ready")

    returner report
slutt

funksjon main()
    core = init_runtime()
    lib = init_stdlib(core)

    report = compiler_identity_pipeline()

    runtime_leak_check(core)

    stdout("Compiler Identity COMPLETE")

    returner report.release_ready
slutt

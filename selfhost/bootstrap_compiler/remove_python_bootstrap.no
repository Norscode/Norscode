// Norscode Python Bootstrap Removal v0
// Phase 2: verify compiler core prefers native path over Python bootstrap.

bruk selfhost.bootstrap_compiler.compiler_entrypoint
bruk selfhost.bootstrap_compiler.native_selfcompile
bruk selfhost.bootstrap_compiler.reproducible_compiler
bruk selfhost.bootstrap_compiler.deterministic_linker
bruk selfhost.bootstrap_compiler.standalone_compiler_verification
bruk selfhost.native_execution.process_runtime
bruk selfhost.runtime_core.runtime_core
bruk selfhost.std_native.std_native
bruk selfhost.runtime_stacktrace
bruk selfhost.std.io
bruk selfhost.std.fs

struktur BootstrapPath
    navn
    aktiv
    legacy
    kommentar
slutt

struktur PythonRemovalReport
    native_compiler_ok
    standalone_ok
    selfcompile_ok
    reproducible_ok
    python_core_disabled
    legacy_tools_allowed
    ready_for_python_removal
slutt

funksjon ny_path(navn, aktiv, legacy, kommentar)
    path = BootstrapPath()
    path.navn = navn
    path.aktiv = aktiv
    path.legacy = legacy
    path.kommentar = kommentar
    returner path
slutt

funksjon ny_report()
    report = PythonRemovalReport()
    report.native_compiler_ok = usann
    report.standalone_ok = usann
    report.selfcompile_ok = usann
    report.reproducible_ok = usann
    report.python_core_disabled = usann
    report.legacy_tools_allowed = sann
    report.ready_for_python_removal = usann
    returner report
slutt

funksjon bootstrap_paths()
    paths = []

    legg_til(paths, ny_path("native_compiler_entrypoint", sann, usann, "primary compiler path"))
    legg_til(paths, ny_path("native_selfcompile", sann, usann, "compiler builds compiler"))
    legg_til(paths, ny_path("standalone_compiler_elf", sann, usann, "standalone compiler artifact"))
    legg_til(paths, ny_path("python_runner", usann, sann, "legacy compatibility only"))
    legg_til(paths, ny_path("python_build_wrappers", usann, sann, "legacy migration only"))
    legg_til(paths, ny_path("python_runtime_helpers", usann, sann, "not allowed in compiler core"))

    returner paths
slutt

funksjon verify_no_python_core_paths(paths)
    indeks = 0

    mens indeks < lengde(paths)
        path = paths[indeks]

        hvis path.legacy og path.aktiv
            runtime_panic("Python legacy path aktiv i compiler core: " + path.navn)
        slutt

        indeks = indeks + 1
    slutt

    returner sann
slutt

funksjon print_bootstrap_paths(paths)
    skriv_linje("=== Bootstrap Path Status ===")

    indeks = 0

    mens indeks < lengde(paths)
        path = paths[indeks]

        status = "disabled"

        hvis path.aktiv
            status = "active"
        slutt

        legacy = "native"

        hvis path.legacy
            legacy = "legacy"
        slutt

        skriv_linje(path.navn + " | " + status + " | " + legacy + " | " + path.kommentar)

        indeks = indeks + 1
    slutt
slutt

funksjon verify_native_compiler_path()
    skriv_linje("[PYREMOVE] verify native compiler entrypoint")

    ctx = ny_compiler_context()
    la selfcheck_args = builtin.split("selfcheck", " ")
    ctx.command = parse_args(selfcheck_args)

    result = compiler_dispatch(ctx)

    hvis ikkje result
        runtime_panic("Native compiler entrypoint feilet")
    slutt

    returner sann
slutt

funksjon verify_standalone_path()
    skriv_linje("[PYREMOVE] verify standalone compiler")

    report = verify_standalone_compiler()

    verify_standalone_report(report)

    returner sann
slutt

funksjon verify_selfcompile_path()
    skriv_linje("[PYREMOVE] verify native selfcompile")

    report = native_selfcompile_pipeline()

    verify_native_selfcompile_report(report)

    returner sann
slutt

funksjon verify_reproducible_path()
    skriv_linje("[PYREMOVE] verify reproducible compiler")

    report = verify_reproducible_compiler_build()

    verify_repro_report(report)

    returner sann
slutt

funksjon python_removal_verification()
    skriv_linje("=== Python Bootstrap Removal Verification ===")

    paths = bootstrap_paths()

    print_bootstrap_paths(paths)

    report = ny_report()

    report.python_core_disabled = verify_no_python_core_paths(paths)
    report.native_compiler_ok = verify_native_compiler_path()
    report.standalone_ok = verify_standalone_path()
    report.selfcompile_ok = verify_selfcompile_path()
    report.reproducible_ok = verify_reproducible_path()

    report.ready_for_python_removal =
        report.python_core_disabled og
        report.native_compiler_ok og
        report.standalone_ok og
        report.selfcompile_ok og
        report.reproducible_ok

    hvis ikkje report.ready_for_python_removal
        runtime_panic("Python removal readiness feilet")
    slutt

    skriv_linje("[PYREMOVE] compiler core is Python-free ready")

    returner report
slutt

funksjon write_python_removal_marker(report)
    marker = "Norscode Python Bootstrap Removal Marker\n"
    marker = marker + "native_compiler_ok=" + tekst_fra_bool(report.native_compiler_ok) + "\n"
    marker = marker + "standalone_ok=" + tekst_fra_bool(report.standalone_ok) + "\n"
    marker = marker + "selfcompile_ok=" + tekst_fra_bool(report.selfcompile_ok) + "\n"
    marker = marker + "reproducible_ok=" + tekst_fra_bool(report.reproducible_ok) + "\n"
    marker = marker + "python_core_disabled=" + tekst_fra_bool(report.python_core_disabled) + "\n"

    skriv_fil("build/PYTHON_CORE_REMOVAL_READY.txt", marker)

    returner sann
slutt

funksjon main()
    core = init_runtime()
    lib = init_stdlib(core)

    report = python_removal_verification()

    write_python_removal_marker(report)

    runtime_leak_check(core)

    stdout("Python Bootstrap Removal Verification OK")

    returner sann
slutt

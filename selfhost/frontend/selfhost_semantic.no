# Selfhost semantic analyzer for Norscode

# =========================
# Symbol table
# =========================

funksjon symbol(name, type_name)
    returner {
        name: name,
        type: type_name,
        defined: sann
    }
slutt

funksjon symbol_table()
    returner {
        symbols: {}
    }
slutt

funksjon define_symbol(table, sym)
    table.symbols[sym.name] = sym
slutt

funksjon lookup_symbol(table, name)
    returner table.symbols[name]
slutt

funksjon symbol_exists(table, name)
    returner lookup_symbol(table, name) != null
slutt

# =========================
# Scope handling
# =========================

funksjon semantic_scope(parent)
    returner {
        parent: parent,
        table: symbol_table()
    }
slutt

funksjon scope_define(scope, name, type_name)
    hvis symbol_exists(scope.table, name)
        returner {
            success: usann,
            error: "Duplicate symbol"
        }
    slutt

    define_symbol(
        scope.table,
        symbol(name, type_name)
    )

    returner {
        success: sann
    }
slutt

funksjon scope_lookup(scope, name)
    current = scope

    mens current != null
        sym = lookup_symbol(current.table, name)

        hvis sym != null
            returner sym
        slutt

        current = current.parent
    slutt

    returner null
slutt

# =========================
# Type inference
# =========================

funksjon infer_type(node)
    hvis node == null
        returner "Void"
    slutt

    hvis node.type == "NumberLiteral"
        returner "Number"
    slutt

    hvis node.type == "StringLiteral"
        returner "String"
    slutt

    hvis node.type == "BinaryExpression"
        returner "Number"
    slutt

    hvis node.type == "Identifier"
        returner "Unknown"
    slutt

    returner "Unknown"
slutt

# =========================
# Semantic diagnostics
# =========================

funksjon semantic_error(message)
    returner {
        success: usann,
        message: message
    }
slutt

funksjon semantic_success()
    returner {
        success: sann
    }
slutt

# =========================
# Expression validation
# =========================

funksjon validate_expression(scope, node)
    hvis node == null
        returner semantic_success()
    slutt

    hvis node.type == "Identifier"
        sym = scope_lookup(scope, node.name)

        hvis sym == null
            returner semantic_error(
                "Undefined variable: " + node.name
            )
        slutt
    slutt

    hvis node.type == "BinaryExpression"
        left = validate_expression(scope, node.left)

        hvis left.success == usann
            returner left
        slutt

        right = validate_expression(scope, node.right)

        hvis right.success == usann
            returner right
        slutt

        left_type = infer_type(node.left)
        right_type = infer_type(node.right)

        hvis left_type != right_type
            returner semantic_error(
                "Type mismatch"
            )
        slutt
    slutt

    returner semantic_success()
slutt

# =========================
# Statement validation
# =========================

funksjon validate_assignment(scope, node)
    expr = validate_expression(scope, node.value)

    hvis expr.success == usann
        returner expr
    slutt

    type_name = infer_type(node.value)

    returner scope_define(
        scope,
        node.name,
        type_name
    )
slutt

funksjon validate_return(scope, node)
    returner validate_expression(scope, node.value)
slutt

funksjon validate_if(scope, node)
    returner validate_expression(
        scope,
        node.condition
    )
slutt

funksjon validate_while(scope, node)
    returner validate_expression(
        scope,
        node.condition
    )
slutt

funksjon validate_function(scope, node)
    result = scope_define(
        scope,
        node.name,
        "Function"
    )

    hvis result.success == usann
        returner result
    slutt

    function_scope = semantic_scope(scope)

    indeks = 0

    mens indeks < lengde(node.body)
        stmt = validate_statement(
            function_scope,
            node.body[indeks]
        )

        hvis stmt.success == usann
            returner stmt
        slutt

        indeks = indeks + 1
    slutt

    returner semantic_success()
slutt

funksjon validate_statement(scope, node)
    hvis node.type == "Assignment"
        returner validate_assignment(scope, node)
    slutt

    hvis node.type == "ReturnStatement"
        returner validate_return(scope, node)
    slutt

    hvis node.type == "IfStatement"
        returner validate_if(scope, node)
    slutt

    hvis node.type == "WhileStatement"
        returner validate_while(scope, node)
    slutt

    hvis node.type == "FunctionDeclaration"
        returner validate_function(scope, node)
    slutt

    returner validate_expression(scope, node)
slutt

# =========================
# Main semantic pipeline
# =========================

funksjon semantic_analyze(ast)
    global_scope = semantic_scope(null)

    indeks = 0

    mens indeks < lengde(ast.statements)
        result = validate_statement(
            global_scope,
            ast.statements[indeks]
        )

        hvis result.success == usann
            returner result
        slutt

        indeks = indeks + 1
    slutt

    returner {
        success: sann,
        scope: global_scope
    }
slutt

# =========================
# Semantic snapshot-verifisering
# =========================

funksjon semantic_snapshot_test()
    tokens = lex_source(
        "la x = 1"
    )

    ast = parse_tokens(tokens)

    result = semantic_analyze(ast)

    returner {
        success: result.success,
        symbols: result.scope.table.symbols
    }
slutt

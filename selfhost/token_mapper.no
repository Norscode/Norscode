# Canonical token mapper for Norscode

funksjon canonical_token(token)
    la normalized = token

    hvis normalized == ingen
        returner ""
    slutt

    normalized = normalized.trim().lower()

    hvis normalized == "<" eller normalized == "mindre_enn" eller normalized == "less_than"
        returner "TOKEN_LT"
    slutt

    hvis normalized == "<=" eller normalized == "mindre_eller_lik" eller normalized == "less_than_or_equal"
        returner "TOKEN_LTE"
    slutt

    hvis normalized == ">" eller normalized == "storre_enn"
        returner "TOKEN_GT"
    slutt

    hvis normalized == ">=" eller normalized == "storre_eller_lik"
        returner "TOKEN_GTE"
    slutt

    hvis normalized == "og"
        returner "TOKEN_AND"
    slutt

    hvis normalized == "eller"
        returner "TOKEN_OR"
    slutt

    hvis normalized == "ikkje" eller normalized == "not"
        returner "TOKEN_NOT"
    slutt

    returner normalized
slutt

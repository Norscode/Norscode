# Canonical token mapper for Norscode

funksjon canonical_token(token)
    hvis token == ingen
        returner ""
    slutt

    la normalized = token

    hvis normalized == "<" eller normalized == "mindre_enn" eller normalized == "less_than"
        returner "TOKEN_LT"
    slutt

    hvis normalized == "<=" eller normalized == "mindre_eller_lik" eller normalized == "less_than_or_equal" eller normalized == "less_or_equal" eller normalized == "less_equal"
        returner "TOKEN_LTE"
    slutt

    hvis normalized == ">" eller normalized == "storre_enn" eller normalized == "greater_than"
        returner "TOKEN_GT"
    slutt

    hvis normalized == ">=" eller normalized == "storre_eller_lik" eller normalized == "greater_than_or_equal" eller normalized == "greater_or_equal" eller normalized == "greater_equal"
        returner "TOKEN_GTE"
    slutt

    hvis normalized == "og" eller normalized == "and" eller normalized == "&&"
        returner "TOKEN_AND"
    slutt

    hvis normalized == "eller" eller normalized == "or" eller normalized == "||"
        returner "TOKEN_OR"
    slutt

    hvis normalized == "ikkje" eller normalized == "ikke" eller normalized == "not"
        returner "TOKEN_NOT"
    slutt

    returner normalized
slutt

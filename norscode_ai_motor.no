        tom = tom + motor_no_line("learning_summary", "next_improvement", "samle fleire spørsmål før prioritering")
        motor_skriv(motor_laring_sammendrag_sti(), tom)
        returner "Eg har ikkje nok læringslogg enno. Eg har oppretta learning_summary.no med første tomme status."
    }

    la samtale = motor_laring_count(logg, "samtale")
    la handling = motor_laring_count(logg, "handling")
    la kode = motor_laring_count(logg, "kode")
    la state = motor_laring_count(logg, "state")
    la minne = motor_laring_count(logg, "minne")
    la patch = motor_count(logg, "patch")
    la guard = motor_count(logg, "guard")
    la total = builtin.lengde(t.splitt(logg, "\n"))
    la hist_total = 0
    hvis hist != "" {
        hist_total = builtin.lengde(t.splitt(hist, "\n"))
    }

    la fokus = "vanleg samtale og Norscode-hjelp"
    hvis kode > samtale og kode >= state {
        fokus = "kodeforklaring og trygge patch-forslag"
    } ellers hvis state > samtale {
        fokus = "state, plan og selvutviklingsflyt"
    } ellers hvis handling > 0 eller guard > 0 {
        fokus = "trygg handling med bekreftelse"
    }

    la neste = "utvid lokale svarregler frå dei vanlegaste spørsmåla"
    hvis guard > 0 {
        neste = "gjer bekreftelsesflyten tydeligare i chatten"
    }
    hvis patch > 0 {
        neste = "kople patch-kø til tydelig diff-visning og testresultat"
    }
    hvis state > 0 {
        neste = "kople learning_summary.no inn i plan og review-state"
    }

    la out = ""
    out = out + motor_no_line("learning_summary", "schema", "norscode.learning_summary.v1")
    out = out + motor_no_line("learning_summary", "status", "active")
    out = out + motor_no_line("learning_summary", "total_events", tekst(total))
    out = out + motor_no_line("learning_summary", "history_lines", tekst(hist_total))
    out = out + motor_no_line("learning_summary", "conversation_events", tekst(samtale))
    out = out + motor_no_line("learning_summary", "code_events", tekst(kode))
    out = out + motor_no_line("learning_summary", "state_events", tekst(state))
    out = out + motor_no_line("learning_summary", "memory_events", tekst(minne))
    out = out + motor_no_line("learning_summary", "guard_events", tekst(guard))
    out = out + motor_no_line("learning_summary", "focus", fokus)
    out = out + motor_no_line("learning_summary", "next_improvement", neste)
    out = out + motor_no_line("learning_summary", "guard", "source mutation still requires explicit approval")
    motor_skriv(motor_laring_sammendrag_sti(), out)
    motor_logg_laring(sporsmal, "learning-summary", "skreiv learning_summary.no")
    returner "Læringsrapport er oppdatert i learning_summary.no. Fokus: " + fokus + ". Neste forbedring: " + neste + ". Eg har ikkje endra kildefiler."
}

funksjon motor_selvutviklingsplan(sporsmal: tekst) -> tekst {
    la queue = motor_state_les("queue.json")
    la review = motor_les("review.no")
    la active = motor_json_felt(queue, "title", "forbedre lokal chat og læring")
    hvis active == "" {
        active = motor_queue_active_item_tittel(queue)
    }
    hvis active == "" {
        active = "forbedre lokal chat og læring"
    }
    la next = motor_json_felt(review, "next_recommendation", "kople verifisering til lokal writeback")
    la plan = ""
    plan = plan + "Selvutviklingsplan\n"
    plan = plan + "1. Les lokal state og læringslogg.\n"
    plan = plan + "2. Finn svakaste punkt: " + active + ".\n"
    plan = plan + "3. Foreslå ein liten Norscode-endring i ikkje-kritiske AI-filer.\n"
    plan = plan + "4. Vis berørte filer, risiko og testkommandoar.\n"
    plan = plan + "5. Vent på eksplisitt bekreftelse før endring.\n"
    plan = plan + "6. Etter godkjent endring: køyr nc check/nc run og skriv resultat til læringslogg.\n"
    plan = plan + "Neste anbefaling frå review: " + next + ".\n"
    plan = plan + "\nModellstyring\n"
    plan = plan + motor_model_guidance()
    motor_logg_laring(sporsmal, "self-development-plan", "AI laga trygg selvutviklingsplan utan mutasjon")
    motor_skriv(motor_forslag_sti(), plan + "\n")
    returner plan
}

funksjon motor_patch_forslag(sporsmal: tekst) -> tekst {
    la forslag = ""
    forslag = forslag + "Patch-forslag utan utføring\n"
    forslag = forslag + "Mål: " + sporsmal + "\n"
    forslag = forslag + "Berørte trygge filer: chat_app.no, norscode_ai_motor.no, learning_log.no, development_proposals.md.\n"
    forslag = forslag + "Sperret utan særskilt godkjenning: dist/norscode_native, bootstrap/stage0, produksjonslogin og runtime-promotering.\n"
    forslag = forslag + "Test: ./prosjekter/Norscode/bin/nc check chat_app.no og nc run chat_app.no.\n"
    forslag = forslag + "Neste bekreftelse som trengs: bekreft utfør patch: " + sporsmal
    motor_logg_laring(sporsmal, "patch-proposal", "AI laga patch-forslag utan å endre målfilene")
    motor_skriv(motor_forslag_sti(), forslag + "\n")
    returner forslag
}

funksjon motor_verifiseringsplan(sporsmal: tekst) -> tekst {
    la out = ""
    out = out + "Verifiseringsplan\n"
    out = out + "1. Sjekk ai.no.\n"
    out = out + "2. Sjekk chat_app.no.\n"
    out = out + "3. Sjekk norscode_ai_motor.no både i AIKernel og Norscode-importstien.\n"
    out = out + "4. Køyr chat_app.no med representative spørsmål.\n"
    out = out + "5. Skriv resultat til læringslogg og bruk funn til neste patch-forslag.\n"
    out = out + "Kommandoar som skal brukast av arbeidsagenten: ./prosjekter/Norscode/bin/nc check ... og ./prosjekter/Norscode/bin/nc run ..."
    motor_logg_laring(sporsmal, "verification-plan", "AI laga lokal verifiseringsplan")
    returner out
}

funksjon motor_count(raw: tekst, needle: tekst) -> heiltall {
    la count: heiltall = 0
    la rest = raw
    mens t.finn(rest, needle) > -1 {
        la pos = t.finn(rest, needle)
        count = count + 1
        rest = t.del_av(rest, pos + t.lengde(needle), t.lengde(rest))
    }
    returner count
}

funksjon motor_indeks_fil(namn: tekst) -> tekst {
    la raw = motor_les(namn)
    hvis raw == "" {
        returner "{\"file\":\"" + motor_escape_json(namn) + "\",\"status\":\"missing\"}"
    }
    la funksjonar = motor_count(raw, "funksjon ")
    la imports = motor_count(raw, "bruk ")
    la writes = motor_count(raw, "fil_skriv")
    la reads = motor_count(raw, "fil_les")
    returner "{\"file\":\"" + motor_escape_json(namn) + "\",\"status\":\"indexed\",\"functions\":" + tekst(funksjonar) + ",\"imports\":" + tekst(imports) + ",\"reads\":" + tekst(reads) + ",\"writes\":" + tekst(writes) + "}"
}

funksjon motor_indeks_fil_no(namn: tekst) -> tekst {
    la raw = motor_les(namn)
    hvis raw == "" {
        returner "kilde(\"" + motor_escape_no(namn) + "\", \"missing\", \"0\", \"0\", \"0\", \"0\")"
    }
    la funksjonar = motor_count(raw, "funksjon ")
    la imports = motor_count(raw, "bruk ")
    la writes = motor_count(raw, "fil_skriv")
    la reads = motor_count(raw, "fil_les")
    returner "kilde(\"" + motor_escape_no(namn) + "\", \"indexed\", \"" + tekst(funksjonar) + "\", \"" + tekst(imports) + "\", \"" + tekst(reads) + "\", \"" + tekst(writes) + "\")"
}

funksjon motor_bygg_indeks(sporsmal: tekst) -> tekst {
    la out = ""
    out = out + motor_indeks_fil("chat_app.no") + "\n"
    out = out + motor_indeks_fil("norscode_ai_motor.no") + "\n"
    out = out + motor_indeks_fil("memory_layer.no") + "\n"
    out = out + motor_indeks_fil("plan_layer.no") + "\n"
    out = out + motor_indeks_fil("queue_layer.no") + "\n"
    out = out + motor_indeks_fil("review_layer.no") + "\n"
    out = out + "{\"file\":\"ai.no\",\"status\":\"root-engine-known\",\"functions\":\"many\",\"guard\":\"read-only from kernel motor\"}\n"
    motor_skriv(motor_index_sti(), out)
    la out_no = ""
    out_no = out_no + motor_indeks_fil_no("chat_app.no") + "\n"
    out_no = out_no + motor_indeks_fil_no("norscode_ai_motor.no") + "\n"
    out_no = out_no + motor_indeks_fil_no("memory_layer.no") + "\n"
    out_no = out_no + motor_indeks_fil_no("plan_layer.no") + "\n"
    out_no = out_no + motor_indeks_fil_no("queue_layer.no") + "\n"
    out_no = out_no + motor_indeks_fil_no("review_layer.no") + "\n"
    out_no = out_no + "kilde(\"ai.no\", \"root-engine-known\", \"many\", \"unknown\", \"unknown\", \"unknown\")\n"
    motor_skriv(motor_index_no_sti(), out_no)
    motor_logg_laring(sporsmal, "project-index", "bygde lokal prosjektindeks")
    returner "Prosjektindeks er bygget i project_index.no, med project_index.jsonl som midlertidig reserve. Eg indekserte chat_app.no, norscode_ai_motor.no, state-lagene og registrerte ai.no som rotmotor."
}

funksjon motor_trygg_kodefil(sporsmal: tekst) -> tekst {
    hvis motor_har(sporsmal, "chat_app.no") eller motor_har(sporsmal, "chat app") {
        returner "chat_app.no"
    }
    hvis motor_har(sporsmal, "norscode_ai_motor.no") eller motor_har(sporsmal, "motor") {
        returner "norscode_ai_motor.no"
    }
    hvis motor_har(sporsmal, "memory_layer.no") {
        returner "memory_layer.no"
    }
    hvis motor_har(sporsmal, "plan_layer.no") {
        returner "plan_layer.no"
    }
    hvis motor_har(sporsmal, "queue_layer.no") {
        returner "queue_layer.no"
    }
    hvis motor_har(sporsmal, "review_layer.no") {
        returner "review_layer.no"
    }
    returner ""
}

funksjon motor_kodeanalyse(sporsmal: tekst) -> tekst {
    la namn = motor_trygg_kodefil(sporsmal)
    hvis namn == "" {
        returner ""
    }
    la raw = motor_les(namn)
    hvis raw == "" {
        returner "Eg fann ikkje " + namn + " i den lokale AI-kjernen."
    }
    la funksjonar = motor_count(raw, "funksjon ")
    la imports = motor_count(raw, "bruk ")
    la writes = motor_count(raw, "fil_skriv")
    la reads = motor_count(raw, "fil_les")
    la out = ""
    out = out + "Kodeanalyse av " + namn + "\n"
    out = out + "- funksjonar: " + tekst(funksjonar) + "\n"
    out = out + "- imports: " + tekst(imports) + "\n"
    out = out + "- les frå fil: " + tekst(reads) + "\n"
    out = out + "- skriv til fil: " + tekst(writes) + "\n"
    out = out + "- vurdering: trygg lokal AI-fil. Eg kan lage patch-forslag, men faktisk kildeendring skal gå via bekreftet runner og test.\n"
    motor_logg_laring(sporsmal, "code-analysis", "analyserte trygg lokal Norscode-fil")
    returner out
}

funksjon motor_autonomi_syklus(sporsmal: tekst) -> tekst {
    la queue = motor_state_les("queue.json")
    la review = motor_les("review.no")
    la plan = motor_state_les("plan.json")
    la queue_update = "ikkje endra"
    la active_item = motor_json_felt(queue, "active_item", "{}")
    la active = motor_queue_active_item_tittel(queue)
    hvis active == "" {
        active = motor_json_felt(queue, "title", "ingen aktiv oppgåve")
    }
    hvis active == "" {
        active = motor_json_felt(queue, "active_item_title", "ingen aktiv oppgåve")
    }
    hvis active == "" {
        active = "ingen aktiv oppgåve"
    }
    la id = motor_json_felt(queue, "active_item_id", "")
    hvis id == "" {
        id = motor_json_felt(queue, "active_id", "")
    }
    hvis id == "" {
        la active_item_id = motor_json_felt(active_item, "id", "ukjend")
        hvis active_item_id != "ukjend" {
            id = active_item_id
        }
    }
    hvis id == "" {
        id = "ukjend"
    }
    hvis active == "ingen aktiv oppgåve" {
        la active_item_title = motor_json_felt(active_item, "title", "")
        hvis active_item_title != "" {
            active = active_item_title
        }
    }
    hvis active == "" {
        active = id
    }
    la lav_active = motor_lav(active)
    la transition = "observering"
    la action = "analyse only"
    la active_status = "ukjend"
    hvis active_status == "ukjend" {
        la active_item_status = motor_felt_fra_blokk(motor_felt_block(queue, "\"active_item\""), "\"status\"")
        hvis active_item_status != "" {
            la active_item_status2 = motor_queue_item_status(queue, id)
            hvis active_item_status2 != "" {
                active_status = active_item_status2
            } ellers {
                active_status = active_item_status
            }
        } ellers {
            la active_item_status2 = motor_queue_item_status(queue, id)
            hvis active_item_status2 != "" {
                active_status = active_item_status2
            }
        }
    }
    hvis active_status == "ukjend" {
        hvis id != "" {
            la active_item_status3 = motor_queue_item_status(queue, id)
            hvis active_item_status3 != "" {
                active_status = active_item_status3
            } ellers hvis t.finn(lav_active, "state-step") > -1 eller t.finn(lav_active, "promoter") > -1 eller t.finn(lav_active, "review") > -1 eller t.finn(lav_active, "gap") > -1 eller t.finn(lav_active, "operativ") > -1 eller t.finn(lav_active, "writeback") > -1 {
                active_status = "active"
            }
        }
    }
    la active_item_status4 = motor_json_felt(active_item, "status", "")
    hvis active_item_status4 != "" {
        active_status = active_item_status4
    }
    la next = motor_json_felt(review, "next_recommendation", "kople verifisering til writeback")
    hvis t.finn(lav_active, "state-step") > -1 eller id == "queue-001" {
        action = "execute state-step transition"
        transition = "fann state-step-oppgåve i kø"
    } ellers hvis t.finn(lav_active, "writeback") > -1 eller id == "queue-002" eller id == "queue-006" {
        action = "prepare writeback"
        transition = "varsla om writeback-step-oppfølging"
        la item_status = motor_queue_item_status(queue, id)
        hvis item_status == "done" {
            active_status = "done"
        } ellers {
            active_status = "klar for writeback"
        }
    }
    hvis id == "queue-009" {
        hvis ikkje motor_queue_har_item(queue, "queue-010") og t.finn(queue, "\"id\":\"queue-010-") == -1 og t.finn(queue, "\"id\": \"queue-010-") == -1 {
            la queue_with_item = motor_queue_legg_til_item(queue, "queue-010", "Autonomt kodeforslag: etterfylle writeback-feedback-lukkingsgap", "high", "queued", "[\"queue-009\"]")
            hvis queue_with_item != queue {
                queue = queue_with_item
                hvis queue_update == "ikkje endra" {
                    queue_update = "la inn queue-010 som neste steg"
                } ellers {
                    queue_update = queue_update + " | la inn queue-010 som neste steg"
                }
                motor_state_skriv("queue.json", queue)
            }
        }
        la queue_feedback_mode = motor_set_json_felt(queue, "mode", "guided_autonomy_feedback_done")
        hvis queue_feedback_mode != queue {
            queue = queue_feedback_mode
            hvis queue_update == "ikkje endra" {
                queue_update = "forhåndsstilte queue-modus til guided_autonomy_feedback_done"
            } ellers {
                queue_update = queue_update + " | forhåndsstilte queue-modus til guided_autonomy_feedback_done"
            }
            motor_state_skriv("queue.json", queue)
        }
    }
    hvis id == "queue-010" eller motor_starter_med(id, "queue-010-") {
        la suffix = ""
        hvis t.finn(id, "queue-010-") == 0 {
            la suffix = t.del_av(id, 9, t.lengde(id))
        }
        la neste_id = "queue-011" + suffix
        la neste_dep = "[\"" + id + "\"]"
        hvis ikkje motor_queue_har_item(queue, neste_id) {
            la queue_with_item = motor_queue_legg_til_item(queue, neste_id, "Autonom verifisering: valider etterfylte endringar frå " + id + " og fortset sjølvstendig løp", "high", "queued", neste_dep)
            hvis queue_with_item != queue {
                queue = queue_with_item
                hvis queue_update == "ikkje endra" {
                    queue_update = "la inn " + neste_id + " som neste steg"
                } ellers {
                    queue_update = queue_update + " | la inn " + neste_id + " som neste steg"
                }
                motor_state_skriv("queue.json", queue)
            }
        }
    }
    hvis id == "queue-011" eller motor_starter_med(id, "queue-011-") {
        la suffix = ""
        hvis t.finn(id, "queue-011-") == 0 {
            la suffix = t.del_av(id, 9, t.lengde(id))
        }
        la neste_id = "queue-012" + suffix
        la neste_dep = "[\"" + id + "\"]"
        hvis ikkje motor_queue_har_item(queue, neste_id) {
            la queue_with_item = motor_queue_legg_til_item(queue, neste_id, "Autonomt etterarbeid: vurder resultat frå " + id + " og legg ny plan", "medium", "queued", neste_dep)
            hvis queue_with_item != queue {
                queue = queue_with_item
                hvis queue_update == "ikkje endra" {
                    queue_update = "la inn " + neste_id + " som neste steg"
                } ellers {
                    queue_update = queue_update + " | la inn " + neste_id + " som neste steg"
                }
                motor_state_skriv("queue.json", queue)
            }
        }
    }
    hvis id == "queue-012" eller motor_starter_med(id, "queue-012-") {
        la suffix = ""
        hvis t.finn(id, "queue-012-") == 0 {
            la suffix = t.del_av(id, 9, t.lengde(id))
        }
        la neste_id = "queue-013" + suffix
        la neste_dep = "[\"" + id + "\"]"
        hvis ikkje motor_queue_har_item(queue, neste_id) {
            la queue_with_item = motor_queue_legg_til_item(queue, neste_id, "Autonomt avslutnings- og planleggingssteg etter " + id, "medium", "queued", neste_dep)
            hvis queue_with_item != queue {
                queue = queue_with_item
                hvis queue_update == "ikkje endra" {
                    queue_update = "la inn " + neste_id + " som neste steg"
                } ellers {
                    queue_update = queue_update + " | la inn " + neste_id + " som neste steg"
                }
                motor_state_skriv("queue.json", queue)
            }
        }
        la queue_feedback_mode = motor_set_json_felt(queue, "mode", "guided_autonomy_feedback_done")
        hvis queue_feedback_mode != queue {
            queue = queue_feedback_mode
            hvis queue_update == "ikkje endra" {
                queue_update = "forhåndsstilte queue-modus til guided_autonomy_feedback_done for queue-012"
            } ellers {
                queue_update = queue_update + " | forhåndsstilte queue-modus til guided_autonomy_feedback_done for queue-012"
            }
            motor_state_skriv("queue.json", queue)
        }
    }
    hvis id == "queue-013" eller motor_starter_med(id, "queue-013-") {
        la suffix = ""
        hvis t.finn(id, "queue-013-") == 0 {
            la suffix = t.del_av(id, 9, t.lengde(id))
        }
        la neste_id = "queue-014" + suffix
        la neste_dep = "[\"" + id + "\"]"
        hvis ikkje motor_queue_har_item(queue, neste_id) {
            la queue_with_item = motor_queue_legg_til_item(queue, neste_id, "Autonomt slutt-steg: formeltiser plan frå " + id + " og vurder ny kø-syklus", "low", "queued", neste_dep)
            hvis queue_with_item != queue {
                queue = queue_with_item
                hvis queue_update == "ikkje endra" {
                    queue_update = "la inn " + neste_id + " som neste steg"
                } ellers {
                    queue_update = queue_update + " | la inn " + neste_id + " som neste steg"
                }
                motor_state_skriv("queue.json", queue)
            }
        }
    }
    hvis id == "queue-014" eller motor_starter_med(id, "queue-014-") {
        la suffix = ""
        hvis t.finn(id, "queue-014-") == 0 {
            la suffix = t.del_av(id, 9, t.lengde(id))
        }
        la neste_id = "queue-010" + suffix
        hvis ikkje motor_queue_har_item(queue, neste_id) {
            la neste_dep = "[\"" + id + "\"]"
            la queue_with_item = motor_queue_legg_til_item(queue, neste_id, "Ny autonomi-syklus: start ny verifisering- og etterarbeidsløype frå " + id, "medium", "queued", neste_dep)
            hvis queue_with_item != queue {
                queue = queue_with_item
                hvis queue_update == "ikkje endra" {
                    queue_update = "restarta autonomi med " + neste_id
                } ellers {
                    queue_update = queue_update + " | restarta autonomi med " + neste_id
                }
                motor_state_skriv("queue.json", queue)
            }
        }
    }

    hvis active_status != "queued" og active_status != "done" {
        la queue_handling = motor_autonomi_queue_sideffekt(id, active, plan)
        hvis queue_handling != "" {
            hvis action == "analyse only" {
                action = "execute queue-sideffekt"
            }
            hvis queue_update == "ikkje endra" {
                queue_update = queue_handling
            } ellers {
                queue_update = queue_update + " | " + queue_handling
            }
            motor_logg_fil(motor_review_sti(), "autonomy-sideffekt", sporsmal, queue_handling)
        }
        la queue_state_after_sideeffekt = motor_state_les("queue.json")
        hvis queue_state_after_sideeffekt != "" {
            queue = queue_state_after_sideeffekt
        }
        la next_id = motor_queue_neste_item_id(queue, id)
        hvis next_id != "" {
            la next_tittel = motor_queue_neste_item_tittel(queue, next_id)
            la queue_done = motor_set_queue_item_status(queue, id, "done")
            hvis queue_done != queue {
                la queue_next_item = motor_set_queue_item_status(queue_done, next_id, "active")
                la queue_next = motor_lag_queue_state(queue_next_item, next_id, next_tittel)
                hvis queue_next != queue_done {
                    queue = queue_next
                    queue_update = "markerte " + id + " som done og aktiviserte " + next_id
                    motor_state_skriv("queue.json", queue)
                }
            }
            la queue_done_active = motor_set_active_item_status(queue, "done")
            hvis queue_done_active != queue {
                queue = queue_done_active
            }
        } ellers {
            la queue_done = motor_set_queue_item_status(queue, id, "done")
            hvis queue_done != queue {
                la queue_done_active = motor_set_active_item_status(queue_done, "done")
                hvis queue_done_active != queue_done {
                    queue = queue_done_active
                } ellers {
                    queue = queue_done
                }
                queue_update = "markerte " + id + " som done (ingen neste i kø)"
                motor_state_skriv("queue.json", queue)
            }
            la fallback_item = motor_queue_første_med_status(queue, "queued")
            hvis fallback_item != "{}" {
                la fallback_id = motor_felt_fra_blokk(fallback_item, "\"id\"")
                hvis fallback_id != "" {
                    la fallback_tittel = motor_felt_fra_blokk(fallback_item, "\"title\"")
                    hvis fallback_tittel == "" {
                        la fallback_tittel = fallback_id
                    }
                    la queue_next_item = motor_set_queue_item_status(queue, fallback_id, "active")
                    hvis queue_next_item != queue {
                        la queue_next = motor_lag_queue_state(queue_next_item, fallback_id, fallback_tittel)
                        hvis queue_next != queue_next_item {
                            queue = queue_next
                            hvis queue_update == "ikkje endra" {
                                queue_update = "markerte " + id + " som done og aktiviserte " + fallback_id + " (fallback frå kø)"
                            } ellers {
                                queue_update = queue_update + " | markerte " + id + " som done og aktiviserte " + fallback_id + " (fallback frå kø)"
                            }
                            motor_state_skriv("queue.json", queue)
                        }
                    }
                }
            }
            hvis id == "queue-009" {
                la queue_feedback_done = motor_set_json_felt(queue, "mode", "guided_autonomy_feedback_done")
                hvis queue_feedback_done != queue {
                    queue = queue_feedback_done
                    queue_update = "markerte " + id + " som done (ingen neste i kø)"
                    motor_state_skriv("queue.json", queue)
                }
            }
            hvis id == "queue-009" eller id == "queue-010" eller id == "queue-011" eller id == "queue-012" eller id == "queue-013" eller id == "queue-014" {
                la next_lav = t.til_små_bokstavar(next)
                hvis t.finn(next_lav, "autonomous") > -1 eller t.finn(next_lav, "autonom") > -1 {
                    la auto_result = motor_autonomi_gjennomfor_fristilkode()
                    hvis auto_result != "" {
                        queue_update = auto_result
                    }
                }
            }
            hvis id == "queue-010" eller motor_starter_med(id, "queue-010-") {
                la queue_feedback_done = motor_set_json_felt(queue, "mode", "guided_autonomy_feedback_done")
                hvis queue_feedback_done != queue {
                    queue = queue_feedback_done
                    hvis queue_update == "ikkje endra" {
                        queue_update = "set guided_autonomy_feedback_done for " + id
                    } ellers {
                        queue_update = queue_update + " | set guided_autonomy_feedback_done for " + id
                    }
                    motor_state_skriv("queue.json", queue)
                }
            }
            hvis id == "queue-011" eller motor_starter_med(id, "queue-011-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonom verifisering frå queue-011 er gjennomført. Neste steg er ny plan frå review/verification.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-011"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-011"
                    }
                }
            }
            hvis id == "queue-012" eller motor_starter_med(id, "queue-012-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt etterarbeid frå queue-012 er gjennomført. Neste steg er ny plan frå next_recommendation og review.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-012"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-012"
                    }
                }
            }
            hvis id == "queue-013" eller motor_starter_med(id, "queue-013-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt avslutningssteg er gjennomført. Neste steg er ny autonom planlegging basert på review.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-013"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-013"
                    }
                }
            }
            hvis id == "queue-014" eller motor_starter_med(id, "queue-014-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonom avslutningssteg er ferdig. Ny autonom syklus startar no frå queue-010.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-014"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-014"
                    }
                }
            }
        }
    } ellers hvis active_status == "done" {
        la next_id = motor_queue_neste_item_id(queue, id)
        hvis next_id != "" {
            la next_tittel = motor_queue_neste_item_tittel(queue, next_id)
            la queue_next = motor_lag_queue_state(queue, next_id, next_tittel)
            la queue_next_item = queue_next
            queue_next_item = motor_set_queue_item_status(queue_next_item, next_id, "active")
            hvis queue_next_item != queue {
                queue = queue_next_item
                queue_update = "promotert " + next_id + " etter ferdig " + id
                action = "promote next queued"
                transition = "aktivert neste kø-element etter done"
                motor_state_skriv("queue.json", queue)
            }
        } ellers {
            la fallback_item = motor_queue_første_med_status(queue, "queued")
            hvis fallback_item != "{}" {
                la fallback_id = motor_felt_fra_blokk(fallback_item, "\"id\"")
                hvis fallback_id != "" {
                    la fallback_tittel = motor_felt_fra_blokk(fallback_item, "\"title\"")
                    hvis fallback_tittel == "" {
                        la fallback_tittel = fallback_id
                    }
                    la queue_next_item = motor_set_queue_item_status(queue, fallback_id, "active")
                    hvis queue_next_item != queue {
                        la queue_next = motor_lag_queue_state(queue_next_item, fallback_id, fallback_tittel)
                        hvis queue_next != queue_next_item {
                            queue = queue_next
                            hvis queue_update == "ikkje endra" {
                                queue_update = "promotert " + fallback_id + " som fallback-neste etter " + id
                            } ellers {
                                queue_update = queue_update + " | promotert " + fallback_id + " som fallback-neste etter " + id
                            }
                            action = "promote fallback queued"
                            transition = "aktivert fallback-neste kø-element"
                            motor_state_skriv("queue.json", queue)
                        }
                    }
                }
            }
            hvis id == "queue-009" {
                la queue_feedback_done = motor_set_json_felt(queue, "mode", "guided_autonomy_feedback_done")
                hvis queue_feedback_done != queue {
                    queue = queue_feedback_done
                    hvis queue_update == "ikkje endra" {
                        queue_update = "sette guided_autonomy_feedback_done for " + id
                    } ellers {
                        queue_update = queue_update + " | sette guided_autonomy_feedback_done for " + id
                    }
                    motor_state_skriv("queue.json", queue)
                }
                la next_lav = t.til_små_bokstavar(next)
                hvis t.finn(next_lav, "autonomous") > -1 eller t.finn(next_lav, "autonom") > -1 {
                    la auto_result = motor_autonomi_gjennomfor_fristilkode()
                    hvis auto_result != "" {
                        queue_update = auto_result
                    }
                    hvis t.finn(next_lav, "kodeforslag") > -1 {
                        queue_update = queue_update
                    }
                }
            }
            hvis id == "queue-010" eller motor_starter_med(id, "queue-010-") {
                la queue_feedback_done = motor_set_json_felt(queue, "mode", "guided_autonomy_feedback_done")
                hvis queue_feedback_done != queue {
                    queue = queue_feedback_done
                    hvis queue_update == "ikkje endra" {
                        queue_update = "sette guided_autonomy_feedback_done for " + id
                    } ellers {
                        queue_update = queue_update + " | sette guided_autonomy_feedback_done for " + id
                    }
                    motor_state_skriv("queue.json", queue)
                }
                la next_lav = t.til_små_bokstavar(next)
                hvis t.finn(next_lav, "autonomous") > -1 eller t.finn(next_lav, "autonom") > -1 {
                    la auto_result = motor_autonomi_gjennomfor_fristilkode()
                    hvis auto_result != "" {
                        hvis queue_update == "ikkje endra" {
                            queue_update = auto_result
                        } ellers {
                            queue_update = queue_update + " | " + auto_result
                        }
                    }
                    hvis t.finn(next_lav, "kodeforslag") > -1 {
                        queue_update = queue_update
                    }
                }
            }
            hvis id == "queue-011" eller motor_starter_med(id, "queue-011-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonom verifisering frå queue-011 er gjennomført. Neste steg er ny plan frå review/verification.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-011"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-011"
                    }
                }
            }
            hvis id == "queue-012" eller motor_starter_med(id, "queue-012-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt etterarbeid frå queue-012 er gjennomført. Neste steg er ny plan frå next_recommendation og review.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-012"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-012"
                    }
                }
            }
            hvis id == "queue-013" eller motor_starter_med(id, "queue-013-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt avslutningssteg er gjennomført. Neste steg er ny autonom planlegging basert på review.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-013"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-013"
                    }
                }
            }
            hvis id == "queue-014" eller motor_starter_med(id, "queue-014-") {
                hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonom avslutningssteg er ferdig. Ny autonom syklus startar no frå queue-010.") {
                    hvis queue_update == "ikkje endra" {
                        queue_update = "oppdaterte next_recommendation etter queue-014"
                    } ellers {
                        queue_update = queue_update + " | oppdaterte next_recommendation etter queue-014"
                    }
                }
                la restart_suffix014 = ""
                hvis t.finn(id, "queue-014-") == 0 {
                    la restart_suffix014 = t.del_av(id, 9, t.lengde(id))
                }
                la restart_id = "queue-010" + restart_suffix014
                hvis ikkje motor_queue_har_item(queue, restart_id) {
                    la restart_dep = "[\"" + id + "\"]"
                    la queue_with_item014 = motor_queue_legg_til_item(queue, restart_id, "Ny autonomi-syklus: restart frå " + id, "medium", "queued", restart_dep)
                    hvis queue_with_item014 != queue {
                        queue = queue_with_item014
                        hvis queue_update == "ikkje endra" {
                            queue_update = "restarta autonomi med " + restart_id
                        } ellers {
                            queue_update = queue_update + " | restarta autonomi med " + restart_id
                        }
                        motor_state_skriv("queue.json", queue)
                    }
                }
            }
        }
    }

    la active_item_final = motor_queue_active_item_tittel(queue)
    hvis active_item_final != "" {
        active = active_item_final
    }
    la id_final = motor_queue_active_item_id(queue)
    hvis id_final != "" {
        id = id_final
    }

    hvis id == "queue-009" eller id == "queue-010" eller id == "queue-011" eller id == "queue-012" eller id == "queue-013" eller id == "queue-014" eller motor_starter_med(id, "queue-010-") eller motor_starter_med(id, "queue-011-") eller motor_starter_med(id, "queue-012-") eller motor_starter_med(id, "queue-013-") eller motor_starter_med(id, "queue-014-") {
        la auto_result = motor_autonomi_gjennomfor_fristilkode()
        hvis auto_result != "" {
            hvis queue_update == "ikkje endra" {
                queue_update = auto_result
            } ellers {
                queue_update = queue_update + " | " + auto_result
            }
        }
    }

    la siste = t.trim(motor_les(motor_cycle_sti()))
    la cycle = 1
    hvis siste != "" {
        la forrige = motor_json_felt(siste, "cycle", "0")
        hvis forrige == "1" {
            cycle = 2
        } ellers hvis forrige == "2" {
            cycle = 3
        } ellers hvis forrige == "3" {
            cycle = 4
        } ellers hvis forrige == "4" {
            cycle = 5
        } ellers hvis forrige == "5" {
            cycle = 6
        } ellers hvis forrige == "6" {
            cycle = 7
        } ellers hvis forrige != "0" {
            cycle = 7
        }
    }
    la out = ""
    out = out + motor_no_line("autonomy_cycle_result", "schema", "norscode.autonomy_cycle_result.v1")
    out = out + motor_no_line("autonomy_cycle_result", "status", "executed")
    out = out + motor_no_line("autonomy_cycle_result", "cycle", tekst(cycle))
    out = out + motor_no_line("autonomy_cycle_result", "active_id", id)
    out = out + motor_no_line("autonomy_cycle_result", "active", active)
    out = out + motor_no_line("autonomy_cycle_result", "active_status", active_status)
    out = out + motor_no_line("autonomy_cycle_result", "queue_update", queue_update)
    out = out + motor_no_line("autonomy_cycle_result", "action", action)
    out = out + motor_no_line("autonomy_cycle_result", "transition", transition)
    out = out + motor_no_line("autonomy_cycle_result", "next", next)
    la memory_mode = motor_json_felt(motor_state_les("memory.json"), "mode", "guided_autonomy")
    out = out + motor_no_line("autonomy_cycle_result", "mode", memory_mode)
    out = out + motor_no_line("autonomy_cycle_result", "guard", "no source mutation without explicit approval")
    out = out + motor_no_line("autonomy_cycle_result", "checks", "nc check ai.no, nc check chat_app.no, nc run chat_app.no")
    motor_skriv(motor_cycle_sti(), out)
    motor_logg_fil(motor_review_sti(), "autonomy-cycle", sporsmal, "køyrde trygg autonomi-step med guard")
    motor_logg_laring(sporsmal, "autonomy-cycle", "skreiv autonomy_cycle_result.no")
    returner "Autonomi-syklus " + tekst(cycle) + " køyrt: aktiv oppgåve er " + active + " (" + active_status + "), handling: " + action + ", overgang: " + transition + ". Neste plan: " + next + ". " + queue_update + ".\n" + motor_model_guidance()
}

funksjon motor_registrer_testresultat(sporsmal: tekst) -> tekst {
    motor_skriv_test_result(sporsmal)
    motor_logg_fil(motor_review_sti(), "test-result", sporsmal, "registrerte testresultat i lokal state")
    motor_logg_laring(sporsmal, "test-result", "skreiv test_results.no")
    returner "Testresultat er registrert i test_results.no og self_review.no. Dette kan brukes av neste selvutviklingssløyfe."
}

funksjon motor_promoter_state(sporsmal: tekst) -> tekst {
    la out = ""
    out = out + motor_no_line("state_promotion", "schema", "norscode.state_promotion.v1")
    out = out + motor_no_line("state_promotion", "status", "promoted")
    out = out + motor_no_line("state_promotion", "reason", sporsmal)
    out = out + motor_no_line("state_promotion", "memory", "learning_log and local_memory active")
    out = out + motor_no_line("state_promotion", "queue", "source_patch_queue.no and autonomy_cycle_result.no active")
    out = out + motor_no_line("state_promotion", "review", "self_review.no and test_results.no active")
    motor_skriv("state_promotion.no", out)
    motor_logg_laring(sporsmal, "state-promotion", "skreiv state_promotion.no")
    returner "State er promotert trygt til state_promotion.no. Eg oppdaterte ikkje kritiske runtime-filer."
}

funksjon motor_state_svar(sporsmal: tekst) -> tekst {
    hvis motor_har(sporsmal, "bygg indeks") eller motor_har(sporsmal, "prosjektindeks") eller motor_har(sporsmal, "indekser prosjekt") {
        returner motor_bygg_indeks(sporsmal)
    }

    hvis (motor_har(sporsmal, "lag kodeutkast") eller motor_har(sporsmal, "skriv kodeutkast") eller motor_har(sporsmal, "generer kode")) og (motor_har(sporsmal, "hjemmeside") eller motor_har(sporsmal, "heimeside")) {
        returner motor_lag_hjemmeside_sandbox(sporsmal)
    }

    hvis motor_har(sporsmal, "kodeutkast check ok") eller motor_har(sporsmal, "kodeutkast sjekk ok") eller motor_har(sporsmal, "hjemmeside check ok") eller motor_har(sporsmal, "hjemmeside sjekk ok") {
        returner motor_registrer_hjemmeside_check(sporsmal)
    }

    hvis motor_har(sporsmal, "lag hjemmeside filplan") eller motor_har(sporsmal, "lag filplan hjemmeside") eller motor_har(sporsmal, "promoter kodeutkast hjemmeside") {
        returner motor_lag_hjemmeside_filplan(sporsmal)
    }

    hvis motor_starter_med(sporsmal, "bekreft opprett hjemmeside fra kodeutkast:") eller motor_starter_med(sporsmal, "bekreft opprett hjemmeside frå kodeutkast:") {
        returner motor_lag_hjemmeside_apply_request(sporsmal)
    }

    hvis motor_starter_med(sporsmal, "bekreft rediger hjemmeside:") eller motor_starter_med(sporsmal, "bekreft rediger heimeside:") {
        returner motor_bekreftet_rediger_hjemmeside(sporsmal)
    }

    hvis (motor_har(sporsmal, "rediger hjemmeside") eller motor_har(sporsmal, "endre hjemmeside") eller motor_har(sporsmal, "rediger heimeside") eller motor_har(sporsmal, "endre heimeside")) og ikkje motor_er_bekreftelse(sporsmal) {
        returner motor_rediger_hjemmeside_plan(sporsmal)
    }

    hvis motor_har(sporsmal, "hva bygde du") eller motor_har(sporsmal, "kva bygde du") eller motor_har(sporsmal, "vis leveranse") eller motor_har(sporsmal, "leveranse status") eller motor_har(sporsmal, "hjemmeside status") {
        returner motor_leveranse_svar(sporsmal)
    }

    hvis motor_starter_med(sporsmal, "bekreft legg til seksjon på hjemmeside") eller motor_starter_med(sporsmal, "bekreft legg til seksjon på heimeside") {
        returner motor_lag_seksjon_apply_request(sporsmal)
    }

    hvis motor_har(sporsmal, "ny seksjon") eller motor_har(sporsmal, "ny section") eller motor_har(sporsmal, "legg til seksjon") eller motor_har(sporsmal, "layout-plan") {
        returner motor_lag_seksjonsplan(sporsmal)
    }

    hvis motor_starter_med(sporsmal, "bekreft endre kildefil:") eller motor_starter_med(sporsmal, "bekreft kildepatch:") {
        returner motor_trygg_kildepatch(sporsmal)
    }

    hvis motor_har(sporsmal, "lag diff") eller motor_har(sporsmal, "generer diff") eller motor_har(sporsmal, "patch-preview") eller motor_har(sporsmal, "patch preview") eller motor_har(sporsmal, "kodearbeider") {
        returner motor_generer_patch_preview(sporsmal)
    }

    hvis motor_har(sporsmal, "lag kandidat") eller motor_har(sporsmal, "sandbox-kandidat") eller motor_har(sporsmal, "kandidat fra diff") eller motor_har(sporsmal, "kandidat frå diff") {
        returner motor_lag_patch_kandidat(sporsmal)
    }

    hvis motor_har(sporsmal, "vis kandidat") eller motor_har(sporsmal, "kandidatstatus") {
        returner motor_vis_patch_kandidat()
    }

    hvis motor_har(sporsmal, "kandidat check ok") eller motor_har(sporsmal, "kandidat sjekk ok") eller motor_har(sporsmal, "kandidat grønn") eller motor_har(sporsmal, "kandidat gronn") {
        returner motor_registrer_kandidat_check(sporsmal)
    }

    hvis motor_har(sporsmal, "lag promoteringsplan") eller motor_har(sporsmal, "promoteringsplan") eller motor_har(sporsmal, "klar for kildepatch") eller motor_har(sporsmal, "promoter kandidat") {
        returner motor_lag_promoteringsplan(sporsmal)
    }

    hvis motor_har(sporsmal, "vis promoteringsplan") eller motor_har(sporsmal, "vis promotion") {
        returner motor_vis_promoteringsplan()
    }

    hvis motor_starter_med(sporsmal, "bekreft kildepatch fra kandidat:") eller motor_starter_med(sporsmal, "bekreft kildepatch frå kandidat:") {
        returner motor_lag_source_apply_request(sporsmal)
    }

    hvis motor_har(sporsmal, "vis kildepatch-forespørsel") eller motor_har(sporsmal, "vis apply request") eller motor_har(sporsmal, "kildepatch status") {
        returner motor_vis_source_apply_request()
    }

    hvis motor_har(sporsmal, "vis diff") eller motor_har(sporsmal, "vis patch") eller motor_har(sporsmal, "patchkø") {
        returner motor_vis_patch_preview()
    }

    hvis motor_har(sporsmal, "registrer testresultat") eller motor_har(sporsmal, "skriv testresultat") {
        returner motor_registrer_testresultat(sporsmal)
    }

    hvis motor_har(sporsmal, "promoter state") eller motor_har(sporsmal, "oppdater state") {
        returner motor_promoter_state(sporsmal)
    }

    hvis motor_starter_med(sporsmal, "bekreft utfør patch:") eller motor_starter_med(sporsmal, "bekreft utfor patch:") eller motor_starter_med(sporsmal, "godkjenn patch:") {
        returner motor_godkjent_runner(sporsmal)
    }

    hvis motor_har(sporsmal, "kjør selvutviklingssyklus") eller motor_har(sporsmal, "køyr selvutviklingssyklus") eller motor_har(sporsmal, "lukket sløyfe") eller motor_har(sporsmal, "lukka sløyfe") {
        returner motor_autonomi_syklus(sporsmal)
    }

    hvis motor_har(sporsmal, "analyser") eller motor_har(sporsmal, "analyser kode") eller motor_har(sporsmal, "forklar kode") {
        la analyse = motor_kodeanalyse(sporsmal)
        hvis analyse != "" {
            returner analyse
        }
    }

    hvis motor_har(sporsmal, "læringsrapport") eller motor_har(sporsmal, "oppsummer læring") eller motor_har(sporsmal, "hva har du lært") eller motor_har(sporsmal, "kva har du lært") {
        returner motor_laringsanalyse(sporsmal)
    }

    hvis motor_har(sporsmal, "læring") eller motor_har(sporsmal, "lærer") eller motor_har(sporsmal, "laerer") eller motor_har(sporsmal, "learning") {
        returner "Eg lærer lokalt ved å skrive Norscode-læring til learning_log.no, med JSONL som midlertidig bakoverkompatibel logg. Fakta ligg i local_memory.txt. Siste læring:\n" + motor_siste_laring()
    }

    hvis motor_har(sporsmal, "utvikle deg") eller motor_har(sporsmal, "utvikle på egenhånd") eller motor_har(sporsmal, "selvutvikling") eller motor_har(sporsmal, "forbedre deg") {
        returner motor_selvutviklingsplan(sporsmal)
    }

    hvis motor_har(sporsmal, "patch") eller motor_har(sporsmal, "endringsforslag") eller motor_har(sporsmal, "forbedringsforslag") {
        returner motor_patch_forslag(sporsmal)
    }

    hvis motor_har(sporsmal, "verifiser") eller motor_har(sporsmal, "test deg") eller motor_har(sporsmal, "sjekk deg") {
        returner motor_verifiseringsplan(sporsmal)
    }

    hvis motor_har(sporsmal, "produksjon") eller motor_har(sporsmal, "release") eller motor_har(sporsmal, "gate") eller motor_har(sporsmal, "ferdig") {
        returner "Produksjonsstatus må vurderast med lokal Norscode-verifisering før noko blir kalla ferdig. Eg kan lage ein trygg sjekkliste eller lese status-state, men kritiske runtime-, stage0- og produksjonsendringar krev eksplisitt godkjenning."
    }
    hvis motor_har(sporsmal, "neste") eller motor_har(sporsmal, "neste steg") {
        la queue_for_neste = motor_state_les("queue.json")
        la active_id = motor_queue_active_item_id(queue_for_neste)
        la active_tittel = motor_queue_active_item_tittel(queue_for_neste)
        hvis active_id != "" eller active_tittel != "" {
            returner motor_autonomi_syklus(sporsmal)
        }
        la delivery_next = motor_leveranse_neste(sporsmal)
        hvis delivery_next != "" {
            returner delivery_next
        }
        la queue = motor_state_les("queue.json")
        la review = motor_les("review.no")
        la active = motor_queue_første_item_tittel(queue)
        hvis active == "" {
            active = "ingen aktiv oppgave"
        }
        la anbefaling = motor_json_felt(review, "next_recommendation", "fortsett med lokal chat, minne og verifisering")
        returner "Neste trygge steg er: " + active + ". Modellvalg: " + motor_model_selection_report(sporsmal) + ". Vurdering: " + anbefaling + " Eg kan forklare eller lage ein plan før noko blir endra."
    }
    hvis motor_har(sporsmal, "status") eller motor_har(sporsmal, "hva mangler") eller motor_har(sporsmal, "kva manglar") eller motor_har(sporsmal, "hva gjenstår") eller motor_har(sporsmal, "kva gjenstår") {
        returner motor_ai_status_svar(sporsmal)
    }
    returner ""
}

funksjon motor_fil_status(namn: tekst) -> tekst {
    la innhald = motor_les(namn)
    hvis innhald == "" {
        returner "fant ikkje " + namn
    }
    returner namn + " finnes og er lesbar"
}

funksjon motor_leveranse_svar(sporsmal: tekst) -> tekst {
    la raw = t.trim(motor_les_delivery_summary())
    hvis raw == "" {
        returner "Eg har ingen ferdig leveranse registrert ennå."
    }
    la navn = motor_json_felt(raw, "name", "Leveranse")
    la status = motor_json_felt(raw, "status", "ukjent")
    la target = motor_json_felt(raw, "target", "ukjent")
    la live = t.trim(motor_les("ai_workspace/self_programming/homepage_live_deployment_smoke.no"))
    la live_base = motor_json_felt(live, "base_url", "http://127.0.0.1:8134")
    la url = motor_json_felt(raw, "url", live_base)
    la admin = motor_json_felt(raw, "admin_url", live_base + "/admin")
    hvis motor_json_felt(live, "overall", "") == "green" {
        url = live_base
        admin = live_base + "/admin"
    }
    returner "Eg bygde: " + navn + ". Status: " + status + ". Fil: " + target + ". App: " + url + ". Admin: " + admin + "."
}

funksjon motor_ai_status_svar(sporsmal: tekst) -> tekst {
    la memory = motor_state_les("memory.json")
    la plan = motor_state_les("plan.json")
    la queue = motor_state_les("queue.json")
    la review = motor_les("review.no")
    la delivery = t.trim(motor_les_delivery_summary())
    la learning = t.trim(motor_les(motor_laring_sammendrag_sti()))
    la readiness = t.trim(motor_les("ai_workspace/autonomy_readiness/status.no"))
    la goal = t.trim(motor_les("ai_workspace/self_programming/final_goal_completion_gate.no"))
    la live = t.trim(motor_les("ai_workspace/self_programming/homepage_live_deployment_smoke.no"))
    la safe = t.trim(motor_les("ai_workspace/self_programming/safe_runtime_override_gate.no"))
    la mode = motor_json_felt(memory, "mode", "lokal")
    la phase = motor_json_felt(plan, "current_phase", "chat")
    la plan_status = motor_json_felt(plan, "status", "active")
    la active = motor_json_felt(queue, "title", "videreutvikle lokal AI")
    hvis active == "" {
        active = motor_queue_active_item_tittel(queue)
    }
    hvis active == "" {
        active = "videreutvikle lokal AI"
    }
    la recommendation = motor_json_felt(review, "next_recommendation", "fortsett med lokal chat, læring og verifisering")
    la live_base = motor_json_felt(live, "base_url", "http://127.0.0.1:8134")
    la live_overall = motor_json_felt(live, "overall", "ukjent")
    la delivery_name = motor_json_felt(delivery, "name", "Norscode Hjemmeside")
    la delivery_status = motor_json_felt(delivery, "status", "ukjent")
    la delivery_check = motor_json_felt(delivery, "last_check", "ingen sjekk registrert")
    la delivery_url = motor_json_felt(delivery, "url", live_base)
    la admin_url = motor_json_felt(delivery, "admin_url", live_base + "/admin")
    hvis live_overall == "green" {
        delivery_name = "Norscode Hjemmeside"
        delivery_status = "deployment/live smoke green"
        delivery_check = "deployment gate og live smoke green"
        delivery_url = live_base
        admin_url = live_base + "/admin"
    }
    la learn_focus = motor_json_felt(learning, "focus", "ikkje analysert ennå")
    la learn_next = motor_json_felt(learning, "next_improvement", "køyr læringsrapport for meir presis prioritering")
    hvis learning == "" {
        learn_focus = "læringslogg finnes, men sammendrag må oppdateres"
        learn_next = "spør: hva har du lært"
    }
    la readiness_overall = motor_json_felt(readiness, "overall", "ukjent")
    la readiness_decision = motor_json_felt(readiness, "decision", "ukjent")
    la goal_overall = motor_json_felt(goal, "overall", "ukjent")
    la goal_missing = motor_json_felt(goal, "missing_required_checks", "ukjent")
    la active_runtime = motor_json_felt(goal, "norscode_active_runtime_gate", "ukjent")
    la candidate_runtime = motor_json_felt(goal, "norscode_candidate_runtime_gate", "ukjent")
    la safe_runtime = motor_json_felt(safe, "overall", "ukjent")
    la safe_next = motor_json_felt(safe, "next", "kritisk promotering krever eksplisitt godkjenning")
    la wait_decision = motor_json_felt(readiness, "runtime_wait_strategy_decision", "ukjent")
    la wait_next = motor_json_felt(readiness, "runtime_wait_strategy_next", "ukjent")
    la out = ""
    out = out + "AI-status\n"
    out = out + "- Motor: ren lokal Norscode med lokal modellstyring.\n"
    out = out + "- Modelltrening: " + motor_model_kort_status() + "\n"
    out = out + "- Autopilot: " + motor_autopilot_kort_status() + "\n"
    out = out + "- Selvutviklingsgate: " + motor_self_development_gate_kort_status() + "\n"
    out = out + "- Modus: " + mode + ". Fase: " + phase + ". Planstatus: " + plan_status + ".\n"
    out = out + "- Autonomi: " + readiness_overall + " (" + readiness_decision + ").\n"
    out = out + "- Sluttmål: " + goal_overall + ", mangler " + goal_missing + ". Aktiv runtime: " + active_runtime + ". Kandidat-runtime: " + candidate_runtime + ".\n"
    out = out + "- Safe runtime override: " + safe_runtime + ". Strategi: " + wait_decision + " - " + wait_next + ".\n"
    out = out + "- Live leveranse: " + delivery_name + " (" + delivery_status + ").\n"
    out = out + "- App: " + delivery_url + " Admin: " + admin_url + ".\n"
    out = out + "- Siste verifisering: " + delivery_check + ".\n"
    out = out + "- Aktivt arbeid: " + active + ".\n"
	    out = out + "- Læringsfokus: " + learn_focus + ". Neste AI-forbedring: " + learn_next + ".\n"
	    out = out + "- Trygghet: eg kan forklare, planlegge, foreslå kode og skrive trygge sandbox-endringer. Dist, bootstrap/stage0 og kritisk native-promotering krever eksplisitt godkjenning.\n"
	    out = out + "- Modellvalg: " + motor_model_selection_report(sporsmal) + ".\n"
	    out = out + "- Neste gode steg: " + safe_next + ".\n"
    out = out + motor_model_guidance()
    motor_logg_laring(sporsmal, "ai-status", "rapporterte konkret lokal AI-status")
    returner out
}

funksjon motor_leveranse_neste(sporsmal: tekst) -> tekst {
    la raw = t.trim(motor_les_delivery_summary())
    hvis raw == "" {
        returner ""
    }
    la edit = t.trim(motor_les("ai_workspace/delivery_edit_result.json"))
    la navn = motor_json_felt(raw, "name", "leveransen")
    la live = t.trim(motor_les("ai_workspace/self_programming/homepage_live_deployment_smoke.no"))
    la live_base = motor_json_felt(live, "base_url", "http://127.0.0.1:8134")
    la url = motor_json_felt(raw, "url", live_base)
    la admin = motor_json_felt(raw, "admin_url", live_base + "/admin")
    hvis motor_json_felt(live, "overall", "") == "green" {
        url = live_base
        admin = live_base + "/admin"
    }
    la siste = motor_json_felt(edit, "preview", t.trim(motor_les(motor_hjemmeside_innhold_sti())))
    la out = ""
    out = out + "Neste for " + navn + ":\n"
    out = out + "1. Test innholdet i appen: " + url + ".\n"
    out = out + "2. Rediger manuelt i admin: " + admin + ".\n"
    out = out + "3. Spør: status på AI, hva har du lært eller forklar hjemmeside.no.\n"
    out = out + "4. Be meg lage ny seksjon, kodeanalyse eller patch-plan før eg endrer kode.\n"
    out = out + "5. For meir selvutvikling: spør forbedre deg eller utvikle deg videre.\n"
    hvis siste != "" {
        out = out + "Siste innhold: " + siste
    }
    returner out
}

funksjon motor_rediger_hjemmeside_plan(sporsmal: tekst) -> tekst {
    motor_logg_laring(sporsmal, "delivery-edit-plan", "brukaren ba om hjemmeside-redigering utan bekreftelse")
    returner "Eg kan redigere innholdet på hjemmesiden, men det endrer innhold.txt. Svar med: bekreft rediger hjemmeside: <ny tekst>. Da lagrer eg teksten og du kan se den på http://127.0.0.1:8134/."
}

funksjon motor_bekreftet_rediger_hjemmeside(sporsmal: tekst) -> tekst {
    la tekst_inn = t.trim(sporsmal)
    la lav = motor_lav(tekst_inn)
    la start: heiltall = -1
    hvis t.finn(lav, "bekreft rediger hjemmeside:") == 0 {
        start = t.lengde("bekreft rediger hjemmeside:")
    } ellers hvis t.finn(lav, "bekreft rediger heimeside:") == 0 {
        start = t.lengde("bekreft rediger heimeside:")
    }
    hvis start < 0 {
        returner "Eg fann ikkje ny tekst. Bruk: bekreft rediger hjemmeside: <ny tekst>"
    }
    la ny = t.trim(t.del_av(tekst_inn, start, t.lengde(tekst_inn)))
    hvis ny == "" {
        returner "Eg kan ikkje lagre tom hjemmeside-tekst. Bruk: bekreft rediger hjemmeside: <ny tekst>"
    }
    motor_skriv(motor_hjemmeside_innhold_sti(), ny)
    la result = "{\n"
    result = result + "  \"status\": \"content-updated\",\n"
    result = result + "  \"target\": \"innhold.txt\",\n"
    result = result + "  \"source\": \"chat-confirmed\",\n"
    result = result + "  \"preview\": \"" + motor_escape_json(ny) + "\",\n"
    result = result + "  \"url\": \"http://127.0.0.1:8134/\"\n"
    result = result + "}\n"
    motor_skriv("ai_workspace/delivery_edit_result.json", result)
    motor_logg_fil(motor_patch_journal_sti(), "delivery-content-edit", sporsmal, "oppdaterte innhold.txt etter eksplisitt bekreftelse")
    motor_logg_laring(sporsmal, "delivery-content-edit", "redigerte hjemmesideinnhold etter bekreftelse")
    returner "Hjemmesiden er oppdatert. Ny tekst er lagret i innhold.txt og vises på http://127.0.0.1:8134/."
}

funksjon motor_lag_seksjonsplan(sporsmal: tekst) -> tekst {
    la raw = t.trim(motor_les_delivery_summary())
    hvis raw == "" {
        returner "Eg kan lage seksjonsplan, men eg finn ingen live leveranse ennå."
    }
    la target = motor_json_felt(raw, "target", "hjemmeside.no")
    la plan = ""
    plan = plan + motor_no_line("delivery_section_plan", "status", "section-plan-ready")
    plan = plan + motor_no_line("delivery_section_plan", "target", target)
    plan = plan + motor_no_line("delivery_section_plan", "request", sporsmal)
    plan = plan + motor_no_line("delivery_section_plan", "section", "ny informasjonsseksjon under hovedinnholdet")
    plan = plan + motor_no_line("delivery_section_plan", "content_model", "title, text, call_to_action")
    plan = plan + motor_no_line("delivery_section_plan", "guard", "plan only; no source change yet")
    plan = plan + motor_no_line("delivery_section_plan", "required_confirmation", "bekreft legg til seksjon på hjemmeside")
    motor_skriv(motor_delivery_section_plan_sti(), plan)
    motor_logg_fil(motor_patch_journal_sti(), "delivery-section-plan", sporsmal, "laga trygg seksjonsplan for hjemmeside.no")
    motor_logg_laring(sporsmal, "delivery-section-plan", "planla ny hjemmesideseksjon utan kildeendring")
    returner "Eg har laget ein trygg seksjonsplan for " + target + ". Ingen kode er endret. Neste steg, om du vil utføre: bekreft legg til seksjon på hjemmeside."
}

funksjon motor_lag_seksjon_apply_request(sporsmal: tekst) -> tekst {
    la plan = t.trim(motor_les_delivery_section_plan())
    hvis plan == "" {
        returner "Ingen seksjonsplan finnes ennå. Skriv først: lag ny seksjon om tjenester på hjemmesiden."
    }
    la status = motor_json_felt(plan, "status", "ukjent")
    hvis status != "section-plan-ready" {
        returner "Seksjonsplanen er ikkje klar ennå."
    }
    la target = motor_json_felt(plan, "target", "hjemmeside.no")
    la request = ""
    request = request + motor_no_line("delivery_section_apply_request", "status", "waiting-external-worker-section-apply")
    request = request + motor_no_line("delivery_section_apply_request", "target", target)
    request = request + motor_no_line("delivery_section_apply_request", "source_plan", motor_delivery_section_plan_sti())
    request = request + motor_no_line("delivery_section_apply_request", "confirmation", sporsmal)
    request = request + motor_no_line("delivery_section_apply_request", "section_title", "Tjenester")
    request = request + motor_no_line("delivery_section_apply_request", "section_text", "Vi kan bygge, redigere og videreutvikle Norscode-sider lokalt med trygg AI-flyt.")
    request = request + motor_no_line("delivery_section_apply_request", "call_to_action", "Kontakt oss")
    request = request + motor_no_line("delivery_section_apply_request", "guard", "chat wrote request only; external worker must patch source and run checks")
    request = request + motor_no_line("delivery_section_apply_request", "checks_after_apply", "nc check hjemmeside.no and live route smoke")
    motor_skriv(motor_delivery_section_apply_request_sti(), request)
    motor_logg_fil(motor_patch_journal_sti(), "delivery-section-apply-request", sporsmal, "skreiv apply-request for ny hjemmesideseksjon")
    motor_logg_laring(sporsmal, "delivery-section-apply-request", "chat oppretta seksjonsforespørsel utan kildeendring")
    returner "Seksjonsforespørsel er skrevet til ai_workspace/delivery_section_apply_request.no. Chatten har ikkje endret " + target + ". Ekstern arbeidsagent må patche koden og kjøre checks."
}

funksjon motor_lokal_kontekst(sporsmal: tekst) -> tekst {
    hvis motor_har(sporsmal, "chat_app") eller motor_har(sporsmal, "chat app") eller motor_har(sporsmal, "chatten") {
        returner "Chat-appen er hovedflata. " + motor_fil_status("chat_app.no") + ". Ho les meldinga frå miljøinput eller chat_command.txt, lagrar ny samtale i chat_history.no og viser dei siste meldingane som vanleg chat. JSONL kan ligge som reserve under migreringa."
    }

    hvis motor_har(sporsmal, "motor") eller motor_har(sporsmal, "hjernen") eller motor_har(sporsmal, "svarmotor") {
        returner "Svarmotoren er ren Norscode. " + motor_fil_status("norscode_ai_motor.no") + ". Han tolkar intensjon, bruker lokalt minne, les state og stoppar før filendringar eller kommandoar."
    }

    hvis motor_har(sporsmal, "historikk") eller motor_har(sporsmal, "chat_history") {
        la hist = t.trim(motor_les("chat_history.no"))
        hvis hist == "" {
            returner "Chat-historikken i Norscode-format er tom enno. Nye samtaler blir lagra i chat_history.no."
        }
        returner "Chat-historikken ligg no i chat_history.no som Norscode-linjer: bruker(...) og assistent(...). Eg viser dei siste meldingane i chatten frå denne fila."
    }

    hvis motor_har(sporsmal, "memory_layer") eller motor_har(sporsmal, "minnelag") {
        returner "Minnelaget les memory.no. Aktiv modus: " + motor_json_felt(motor_state_les("memory.json"), "mode", "local_chat") + ". Målet er: " + motor_json_felt(motor_state_les("memory.json"), "global_goal", "bygg ren lokal Norscode-chat")
    }

    hvis motor_har(sporsmal, "plan_layer") eller motor_har(sporsmal, "planlag") {
        returner "Planlaget les plan.no. Status: " + motor_json_felt(motor_state_les("plan.json"), "status", "active") + ". Fase: " + motor_json_felt(motor_state_les("plan.json"), "current_phase", "chat") + "."
    }

    hvis motor_har(sporsmal, "queue_layer") eller motor_har(sporsmal, "kø") eller motor_har(sporsmal, "queue") {
        returner "Kølaget les queue.no. Aktiv oppgave: " + motor_queue_active_item_tittel(motor_state_les("queue.json")) + "."
    }

    hvis motor_har(sporsmal, "review_layer") eller motor_har(sporsmal, "review") eller motor_har(sporsmal, "vurdering") {
        returner "Review-laget les review.no. Siste anbefaling: " + motor_json_felt(motor_les("review.no"), "next_recommendation", "fortsett med trygg lokal chat") + "."
    }

    hvis motor_har(sporsmal, "lokale filer") eller motor_har(sporsmal, "prosjektfiler") eller motor_har(sporsmal, "hvilke filer") eller motor_har(sporsmal, "kva filer") {
        returner "Eg kjenner dei viktigaste lokale AI-filene: chat_app.no, norscode_ai_motor.no, chat_history.no, learning_log.no, local_memory.txt, development_proposals.md, memory.no, plan.no, queue.no og review.no. JSON-speil ligg framleis berre som reserve under migreringa."
    }

    returner ""
}

funksjon motor_kunnskap(sporsmal: tekst) -> tekst {
    hvis motor_har(sporsmal, "2+2") eller motor_har(sporsmal, "2 + 2") {
        returner "2 + 2 = 4."
    }
    hvis motor_har(sporsmal, "hva kan du") eller motor_har(sporsmal, "kva kan du") {
        returner "Eg kan svare på Norscode-spørsmål, forklare kode, hugse fakta, lese state, bygge prosjektindeks, analysere trygge filer, bruke lokal modelltrening, lage læringsrapport, lage diff-preview frå patch-kø, skrive sandbox-kandidat, foreslå patchar, registrere testresultat, promotere state og stoppe før handlingar som kan endre prosjektet.\n" + motor_model_guidance()
    }
    hvis (motor_har(sporsmal, "hjemmeside") eller motor_har(sporsmal, "heimeside")) og (motor_har(sporsmal, "redigerbar") eller motor_har(sporsmal, "online")) {
        returner motor_hjemmeside_utkast(sporsmal)
    }
    hvis motor_har(sporsmal, "app") og motor_har(sporsmal, "norscode") {
        returner "Ein enkel Norscode-app er ei .no-fil med start(). Eksempel: funksjon start() -> heiltall { skriv(\"Hei\") returner 0 }. Sjekk med ./prosjekter/Norscode/bin/nc check app.no og køyr med ./prosjekter/Norscode/bin/nc run app.no."
    }
    hvis motor_har(sporsmal, "norscode ai") eller motor_har(sporsmal, "jan ai") {
        returner "Norscode AI er ein lokal chat-assistent bygd i Norscode. Ho tolkar naturleg språk, brukar lokalt minne og state, og krev bekreftelse før prosjektet blir endra."
    }
    hvis motor_har(sporsmal, "oslo") {
        returner "Oslo er hovudstaden i Noreg, med politikk, kultur, utdanning og teknologi samla rundt Oslofjorden."
    }
    hvis motor_har(sporsmal, "skriv") {
        returner "Klart. Eg kan skrive eit kort utkast, forklare eit tema eller forme teksten vidare. Sei kva tone, lengde og mål du vil ha."
    }
    returner ""
}

funksjon motor_hjemmeside_utkast(sporsmal: tekst) -> tekst {
    motor_logg_laring(sporsmal, "code-template", "gav lokalt Norscode-utkast for redigerbar hjemmeside")
    la out = ""
    out = out + "Ja. Her er eit konkret Norscode-utkast for ei redigerbar hjemmeside med offentleg side, adminskjema og fillagring. Eg foreslår berre koden her; eg opprettar ikkje fil før du ber eksplisitt om det.\n\n"
    out = out + "```norscode\n"
    out = out + motor_hjemmeside_kode()
    out = out + "```\n\n"
    out = out + "Trygg neste handling: skriv `lag kodeutkast hjemmeside` for å lagre dette som sandbox-fil, eller `bekreft: lag fil hjemmeside.no` om du vil vidare mot ekte filoppretting."
    returner out
}

funksjon motor_hjemmeside_kode() -> tekst {
    la out = ""
    out = out + "bruk std.fil som fil\n"
    out = out + "bruk std.html som html\n"
    out = out + "bruk std.tekst som t\n"
    out = out + "bruk std.url som url\n"
    out = out + "bruk std.web som web\n"
    out = out + "\n"
    out = out + "funksjon innhold_sti() -> tekst {\n"
    out = out + "    returner \"/Users/jansteinar/Norscode AI/prosjekter/NorscodeAIKernel/innhold.txt\"\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon kontakt_sti() -> tekst {\n"
    out = out + "    returner \"/Users/jansteinar/Norscode AI/prosjekter/NorscodeAIKernel/kontakt_logg.txt\"\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon les_innhold() -> tekst {\n"
    out = out + "    hvis ikkje fil_finnes(innhold_sti()) da {\n"
    out = out + "        returner \"Velkommen til min Norscode-side.\"\n"
    out = out + "    }\n"
    out = out + "    returner fil_les(innhold_sti())\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon stil() -> tekst {\n"
    out = out + "    returner \"<style>body{margin:0;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;background:#f5f7fb;color:#172033}.side{max-width:920px;margin:0 auto;padding:24px}.top{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #dbe3ee;padding-bottom:14px}.brand{font-weight:800}.nav a{color:#1f6feb;text-decoration:none;margin-left:14px}.hero{padding:44px 0 28px}.hero h1{font-size:42px;line-height:1.05;margin:0 0 12px}.tekst,.section{background:white;border:1px solid #dbe3ee;border-radius:8px;padding:18px;line-height:1.6;white-space:pre-wrap}.section{margin-top:18px}.section h2{margin:0 0 8px;font-size:24px}.admin{background:white;border:1px solid #dbe3ee;border-radius:8px;padding:18px;margin-top:24px}.admin textarea{width:100%;min-height:220px;border:1px solid #cbd5e1;border-radius:8px;padding:12px;font:inherit;box-sizing:border-box}.btn{display:inline-block;border:0;background:#1f6feb;color:white;border-radius:8px;padding:10px 14px;font-weight:700;text-decoration:none;margin-top:10px}.hint{color:#526070}@media(max-width:700px){.side{padding:16px}.hero h1{font-size:32px}.top{align-items:flex-start;gap:10px;flex-direction:column}.nav a{margin-left:0;margin-right:12px}}</style>\"\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon side(tittel: tekst, body: tekst) -> tekst {\n"
    out = out + "    returner \"<!doctype html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'><title>\" + html.escape(tittel) + \"</title>\" + stil() + \"</head><body><div class='side'><header class='top'><div class='brand'>Norscode-side</div><nav class='nav'><a href='/'>Hjem</a><a href='/kontakt'>Kontakt</a><a href='/admin'>Rediger</a></nav></header>\" + body + \"</div></body></html>\"\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {\n"
    out = out + "    web.route(\"GET /\")\n"
    out = out + "    la body = \"<main class='hero'><p class='hint'>Redigerbar Norscode-hjemmeside</p><h1>Hjemmeside</h1><article class='tekst'>\" + html.escape(les_innhold()) + \"</article><section class='section'><h2>Tjenester</h2><p>Vi kan bygge, redigere og videreutvikle Norscode-sider lokalt med trygg AI-flyt.</p><a class='btn' href='/kontakt'>Kontakt oss</a></section><a class='btn' href='/admin'>Rediger innhold</a></main>\"\n"
    out = out + "    returner web.response_builder(200, {\"content-type\":\"text/html; charset=utf-8\"}, side(\"Hjem\", body))\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon admin(ctx: ordbok_tekst) -> ordbok_tekst {\n"
    out = out + "    web.route(\"GET /admin\")\n"
    out = out + "    la body = \"<main class='admin'><h1>Rediger hjemmeside</h1><p class='hint'>Endringer lagres lokalt i Norscode AI-prosjektet.</p><form method='GET' action='/lagre'><textarea name='tekst'>\" + html.escape(les_innhold()) + \"</textarea><br><button class='btn'>Lagre</button></form></main>\"\n"
    out = out + "    returner web.response_builder(200, {\"content-type\":\"text/html; charset=utf-8\"}, side(\"Admin\", body))\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon kontakt(ctx: ordbok_tekst) -> ordbok_tekst {\n"
    out = out + "    web.route(\"GET /kontakt\")\n"
    out = out + "    la body = \"<main class='admin'><h1>Kontakt oss</h1><p class='hint'>Send ein kort melding. Ho lagres lokalt i kontakt_logg.txt.</p><form method='GET' action='/send'><input name='navn' placeholder='Navn' style='width:100%;box-sizing:border-box;margin-bottom:10px;padding:10px;border:1px solid #cbd5e1;border-radius:8px'><textarea name='melding' placeholder='Melding'></textarea><br><button class='btn'>Send</button></form></main>\"\n"
    out = out + "    returner web.response_builder(200, {\"content-type\":\"text/html; charset=utf-8\"}, side(\"Kontakt\", body))\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon send(ctx: ordbok_tekst) -> ordbok_tekst {\n"
    out = out + "    web.route(\"GET /send\")\n"
    out = out + "    la navn = url.url_decode(web.request_query_param(ctx, \"navn\"))\n"
    out = out + "    navn = t.erstatt(navn, \"+\", \" \")\n"
    out = out + "    la melding = url.url_decode(web.request_query_param(ctx, \"melding\"))\n"
    out = out + "    melding = t.erstatt(melding, \"+\", \" \")\n"
    out = out + "    hvis navn == \"\" {\n"
    out = out + "        navn = \"Ukjent\"\n"
    out = out + "    }\n"
    out = out + "    la gammal = \"\"\n"
    out = out + "    hvis fil_finnes(kontakt_sti()) da {\n"
    out = out + "        gammal = fil_les(kontakt_sti())\n"
    out = out + "    }\n"
    out = out + "    fil_skriv(kontakt_sti(), gammal + navn + \": \" + melding + \"\\n\")\n"
    out = out + "    returner web.response_builder(200, {\"content-type\":\"text/html; charset=utf-8\"}, side(\"Sendt\", \"<main class='hero'><h1>Sendt</h1><p class='hint'>Takk, meldingen er lagret lokalt.</p><a class='btn' href='/'>Til forsiden</a></main>\"))\n"
    out = out + "}\n"
    out = out + "\n"
    out = out + "funksjon lagre(ctx: ordbok_tekst) -> ordbok_tekst {\n"
    out = out + "    web.route(\"GET /lagre\")\n"
    out = out + "    la tekst = url.url_decode(web.request_query_param(ctx, \"tekst\"))\n"
    out = out + "    tekst = t.erstatt(tekst, \"+\", \" \")\n"
    out = out + "    fil_skriv(innhold_sti(), tekst)\n"
    out = out + "    returner web.response_builder(200, {\"content-type\":\"text/html; charset=utf-8\"}, side(\"Lagret\", \"<main class='hero'><h1>Lagret</h1><p class='hint'>Innholdet er oppdatert.</p><a class='btn' href='/'>Se siden</a></main>\"))\n"
    out = out + "}\n"
    returner out
}

funksjon motor_lag_hjemmeside_sandbox(sporsmal: tekst) -> tekst {
    la kode = motor_hjemmeside_kode()
    motor_skriv(motor_generated_hjemmeside_sti(), kode)
    la summary = ""
    summary = summary + motor_no_line("generated_hjemmeside_summary", "status", "generated-pending-check")
    summary = summary + motor_no_line("generated_hjemmeside_summary", "file", motor_generated_hjemmeside_sti())
    summary = summary + motor_no_line("generated_hjemmeside_summary", "kind", "redigerbar hjemmeside")
    summary = summary + motor_no_line("generated_hjemmeside_summary", "guard", "sandbox only; source not modified")
    summary = summary + motor_no_line("generated_hjemmeside_summary", "next_check", "nc check ai_workspace/generated_hjemmeside_app.no")
    motor_skriv(motor_generated_hjemmeside_summary_sti(), summary)
    motor_logg_fil(motor_patch_journal_sti(), "generated-code", sporsmal, "skreiv sandbox-kodeutkast for redigerbar hjemmeside")
    motor_logg_laring(sporsmal, "generated-code", "lagra redigerbar hjemmeside som sandbox-utkast")
    returner "Eg har skrevet eit trygt kodeutkast til ai_workspace/generated_hjemmeside_app.no. Det er sandbox, ikkje prosjektkilde. Neste steg er nc check på utkastet før eventuell bekreftet filoppretting."
}

funksjon motor_registrer_hjemmeside_check(sporsmal: tekst) -> tekst {
    la kode = t.trim(motor_les(motor_generated_hjemmeside_sti()))
    hvis kode == "" {
        returner "Eg finn ikkje ai_workspace/generated_hjemmeside_app.no ennå. Skriv først: lag kodeutkast hjemmeside."
    }
    la summary = ""
    summary = summary + motor_no_line("generated_hjemmeside_summary", "status", "generated-check-green")
    summary = summary + motor_no_line("generated_hjemmeside_summary", "file", motor_generated_hjemmeside_sti())
    summary = summary + motor_no_line("generated_hjemmeside_summary", "kind", "redigerbar hjemmeside")
    summary = summary + motor_no_line("generated_hjemmeside_summary", "check", sporsmal)
    summary = summary + motor_no_line("generated_hjemmeside_summary", "guard", "sandbox checked; source still not modified")
    summary = summary + motor_no_line("generated_hjemmeside_summary", "next_step", "explicit approval required before creating project source file")
    motor_skriv(motor_generated_hjemmeside_summary_sti(), summary)
    motor_logg_fil(motor_patch_journal_sti(), "generated-code-check", sporsmal, "registrerte grønn sjekk for hjemmeside-kodeutkast")
    motor_logg_laring(sporsmal, "generated-code-check", "sandbox-kodeutkast er grønt")
    returner "Kodeutkast-sjekk er registrert grønn for ai_workspace/generated_hjemmeside_app.no. Det er fortsatt sandbox. Før ekte filoppretting trengs eksplisitt bekreftelse."
}

funksjon motor_lag_hjemmeside_filplan(sporsmal: tekst) -> tekst {
    la summary = t.trim(motor_les_generated_hjemmeside_summary())
    hvis summary == "" {
        returner "Ingen kodeutkast-status finnes ennå. Skriv først: lag kodeutkast hjemmeside."
    }
    la status = motor_json_felt(summary, "status", "ukjent")
    hvis status != "generated-check-green" {
        returner "Kodeutkastet er ikkje grønt ennå. Kjør nc check på ai_workspace/generated_hjemmeside_app.no og registrer: kodeutkast check ok: ..."
    }
    la plan = ""
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "status", "ready-for-explicit-create-approval")
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "source", motor_generated_hjemmeside_sti())
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "target", "hjemmeside.no")
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "required_confirmation", "bekreft opprett hjemmeside fra kodeutkast: hjemmeside.no")
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "guard", "chat writes request only; external worker must create source intentionally")
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "checks_after_create", "nc check hjemmeside.no, optional nc serve hjemmeside.no")
    plan = plan + motor_no_line("generated_hjemmeside_promotion_plan", "blocked_paths", "dist/norscode_native, bootstrap/stage0, produksjonslogin")
    motor_skriv(motor_generated_hjemmeside_plan_sti(), plan)
    motor_logg_fil(motor_patch_journal_sti(), "generated-code-promotion-plan", sporsmal, "laga filplan for hjemmeside.no")
    motor_logg_laring(sporsmal, "generated-code-promotion-plan", "kodeutkast klart for eksplisitt filoppretting")
    returner "Filplan er laget for hjemmeside.no. Kodeutkastet er grønt, men ingen prosjektfil er opprettet. For faktisk filoppretting kreves: bekreft opprett hjemmeside fra kodeutkast: hjemmeside.no"
}

funksjon motor_lag_hjemmeside_apply_request(sporsmal: tekst) -> tekst {
    la plan = t.trim(motor_les_generated_hjemmeside_plan())
    hvis plan == "" {
        returner "Ingen filplan finnes ennå. Skriv først: lag hjemmeside filplan."
    }
    la status = motor_json_felt(plan, "status", "ukjent")
    hvis status != "ready-for-explicit-create-approval" {
        returner "Filplanen er ikkje klar for oppretting ennå."
    }
    la target = motor_json_felt(plan, "target", "hjemmeside.no")
    la request = ""
    request = request + motor_no_line("generated_hjemmeside_apply_request", "status", "waiting-external-worker-create")
    request = request + motor_no_line("generated_hjemmeside_apply_request", "source", motor_generated_hjemmeside_sti())
    request = request + motor_no_line("generated_hjemmeside_apply_request", "target", target)
    request = request + motor_no_line("generated_hjemmeside_apply_request", "confirmation", sporsmal)
    request = request + motor_no_line("generated_hjemmeside_apply_request", "guard", "chat wrote request only; target source still not created")
    request = request + motor_no_line("generated_hjemmeside_apply_request", "external_worker_steps", "copy sandbox to target intentionally, run nc check target, then report result")
    request = request + motor_no_line("generated_hjemmeside_apply_request", "blocked_paths", "dist/norscode_native, bootstrap/stage0, produksjonslogin")
    motor_skriv(motor_generated_hjemmeside_apply_request_sti(), request)
    motor_logg_fil(motor_patch_journal_sti(), "generated-code-apply-request", sporsmal, "skreiv opprettingsforespørsel for " + target)
    motor_logg_laring(sporsmal, "generated-code-apply-request", "chat oppretta filforespørsel utan å skrive målfil")
    returner "Opprettingsforespørsel er skrevet til ai_workspace/generated_hjemmeside_apply_request.no. Chatten har ikkje opprettet " + target + ". Ekstern arbeidsagent må kopiere sandboxen, kjøre nc check og rapportere resultat."
}

funksjon motor_svar(system_prompt: tekst, user_prompt: tekst) -> tekst {
    la prompt = motor_normaliser_prompt(user_prompt)
    motor_logg_laring(prompt, motor_kategori(prompt), "mottok melding")
    motor_oppdater_laringssummary()
    la model_selection = motor_model_selection_report(prompt)

    la gate_direct = motor_self_development_gate_svar(prompt)
    hvis gate_direct != "" {
        returner gate_direct
    }

    la autopilot_direct = motor_autopilot_svar(prompt)
    hvis autopilot_direct != "" {
        returner autopilot_direct
    }

    la model_direct = motor_model_svar(prompt)
    hvis model_direct != "" {
        returner model_direct
    }

    hvis motor_har(prompt, "neste") eller motor_har(prompt, "neste steg") {
        la queue_for_neste = motor_state_les("queue.json")
        la active_id = motor_queue_active_item_id(queue_for_neste)
        la active_tittel = motor_queue_active_item_tittel(queue_for_neste)
        hvis active_id == "" og active_tittel == "" {
            la første_item = motor_queue_første_item(queue_for_neste)
            hvis første_item != "{}" {
                active_id = motor_felt_fra_blokk(første_item, "\"id\"")
                active_tittel = motor_felt_fra_blokk(første_item, "\"title\"")
            }
        }
        hvis active_id != "" eller active_tittel != "" {
            returner motor_autonomi_syklus(prompt)
        }
    }

    la pre_state = motor_state_svar(prompt)
    hvis pre_state != "" {
        returner pre_state
    }

    hvis motor_er_bekreftelse(prompt) {
        returner motor_bekreftelsesplan(prompt)
    }

    la policy_msg = motor_policy_block_message(prompt)
    hvis policy_msg != "" {
        returner policy_msg
    }

    hvis motor_krever_bekreftelse(prompt) {
        returner motor_bekreftelse(prompt)
    }

    la lagra = motor_lagre_minne(prompt)
    hvis lagra != "" {
        returner lagra
    }

    la minne = motor_sok_minne(prompt)
    hvis minne != "" {
        returner minne
    }

    la lokal = motor_lokal_kontekst(prompt)
    hvis lokal != "" {
        returner lokal
    }

    la kunnskap = motor_kunnskap(prompt)
    hvis kunnskap != "" {
        returner kunnskap
    }

    returner "Eg er ein ren lokal Norscode-AI. Alt skjer med lokale Norscode-regler, minne og prosjektstate. Spør meg gjerne om Norscode, kode, neste steg eller kva vi skal bygge vidare."
}

funksjon ai_kilder_for_sporsmal(sporsmal: tekst) -> tekst {
    hvis sporsmal == "chat" {
        returner "chat_app.no, chat_web_app.no, chat_messages.no"
    }

    hvis sporsmal == "motor" {
        returner "norscode_ai_motor.no, ai_kernel.no"
    }

    hvis sporsmal == "minne" {
        returner "memory_layer.no, local_memory.txt, memory.no"
    }

    hvis sporsmal == "indeks" {
        returner "project_index.no, project_index_leser.no, project_context.no"
    }

    returner "project_index.no"
}

funksjon ai_svar_kildegrunnlag(sporsmal: tekst) -> tekst {
    returner "KILDER: " + ai_kilder_for_sporsmal(sporsmal)
}

funksjon ai_svar_med_kildegrunnlag(sporsmal: tekst) -> tekst {
    returner "KILDER: " + ai_kilder_for_sporsmal(sporsmal) + "\nSVAR: AI-en svarer med kildegrunnlag."
}


# AI sandbox-kandidat: ikkje promotert til kjelde.
funksjon ai_patch_candidate_status() -> tekst {
    returner "sandbox-kandidat for norscode_ai_motor.no: ventar på nc check og menneskeleg godkjenning"
}

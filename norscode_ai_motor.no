funksjon motor_tid() -> tekst {
    prøv {
        la v = t.trim(builtin.miljo_hent("NORSCODE_AI_TIME"))
        hvis v != "" {
            returner v
        }
    } fang (e) {
        returner "lokal-tid-ukjent"
    }
    returner "lokal-tid-ukjent"
}

funksjon motor_escape_json(s: tekst) -> tekst {
    la ut = ""
    la i: heiltall = 0
    mens i < t.lengde(s) {
        la ch = t.del_av(s, i, i + 1)
        hvis ch == "\"" {
            ut = ut + "\\\""
        } ellers hvis ch == "\\" {
            ut = ut + "\\\\"
        } ellers hvis ch == "\n" {
            ut = ut + "\\n"
        } ellers {
            ut = ut + ch
        }
        i = i + 1
    }
    returner ut
}

funksjon motor_escape_no(s: tekst) -> tekst {
    returner motor_escape_json(s)
}

funksjon motor_no_line(kind: tekst, key: tekst, value: tekst) -> tekst {
    returner kind + "(\"" + motor_escape_no(key) + "\", \"" + motor_escape_no(value) + "\")\n"
}

funksjon motor_les_med_reserve(primary: tekst, reserve: tekst) -> tekst {
    la raw = motor_les(primary)
    hvis t.trim(raw) != "" {
        returner raw
    }
    returner motor_les(reserve)
}

funksjon motor_les_laring_logg() -> tekst {
    returner motor_les_med_reserve(motor_laring_no_sti(), motor_laring_sti())
}

funksjon motor_les_chat_history() -> tekst {
    returner motor_les_med_reserve("chat_history.no", "chat_history.jsonl")
}

funksjon motor_laring_count(raw: tekst, kategori: tekst) -> heiltall {
    returner motor_count(raw, "\"category\":\"" + kategori + "\"") + motor_count(raw, "\", \"" + kategori + "\", \"")
}

funksjon motor_les_patch_promotion_plan() -> tekst {
    returner motor_les_med_reserve(motor_patch_promotion_plan_sti(), motor_patch_promotion_plan_legacy_sti())
}


bruk std.fil som fil
bruk std.tekst som t

funksjon motor_sti(namn: tekst) -> tekst {
    returner "/Users/jansteinar/Norscode AI/prosjekter/NorscodeAIKernel/" + namn
}

funksjon motor_les(namn: tekst) -> tekst {
    la sti = motor_sti(namn)
    hvis ikkje fil_finnes(sti) da {
        returner ""
    }
    prøv {
        returner fil_les(sti)
    } fang (e) {
        returner ""
    }
}

funksjon motor_skriv(namn: tekst, innhald: tekst) -> heiltall {
    prøv {
        fil_skriv(motor_sti(namn), innhald)
        returner 0
    } fang (e) {
        returner 1
    }
    returner 1
}

funksjon motor_lav(s: tekst) -> tekst {
    returner t.til_små_bokstavar(t.trim(s))
}

funksjon motor_normaliser_prompt(s: tekst) -> tekst {
    la p = s
    p = t.erstatt(p, "%C3%A5", "å")
    p = t.erstatt(p, "%C3%85", "Å")
    p = t.erstatt(p, "%C3%B8", "ø")
    p = t.erstatt(p, "%C3%98", "Ø")
    p = t.erstatt(p, "%C3%A6", "æ")
    p = t.erstatt(p, "%C3%86", "Æ")
    p = t.erstatt(p, "%c3%a5", "å")
    p = t.erstatt(p, "%c3%b8", "ø")
    p = t.erstatt(p, "%c3%a6", "æ")
    p = t.erstatt(p, "%20", " ")
    p = t.erstatt(p, "+", " ")
    returner t.trim(p)
}

funksjon motor_har(haystack: tekst, needle: tekst) -> boolsk {
    returner t.finn(motor_lav(haystack), motor_lav(needle)) > -1
}

funksjon motor_starter_med(s: tekst, prefiks: tekst) -> boolsk {
    returner t.finn(motor_lav(s), motor_lav(prefiks)) == 0
}

funksjon motor_status() -> tekst {
    returner "motor: ren lokal Norscode-AI"
}

funksjon motor_state_no_namn(fil: tekst) -> tekst {
    hvis fil == "memory.json" {
        returner "memory.no"
    }
    hvis fil == "plan.json" {
        returner "plan.no"
    }
    hvis fil == "queue.json" {
        returner "queue.no"
    }
    hvis fil == "review.json" {
        returner "review.no"
    }
    returner fil
}

funksjon motor_state_les(fil: tekst) -> tekst {
    la no_fil = motor_state_no_namn(fil)
    hvis no_fil != fil {
        la no_raw = motor_les(no_fil)
        hvis no_raw != "" {
            returner no_raw
        }
    }
    returner motor_les(fil)
}

funksjon motor_state_skriv(fil: tekst, innhald: tekst) -> heiltall {
    la no_fil = motor_state_no_namn(fil)
    hvis no_fil != fil og motor_les(no_fil) != "" {
        returner motor_skriv(no_fil, innhald)
    }
    returner motor_skriv(fil, innhald)
}

funksjon motor_model_status_raw() -> tekst {
    returner motor_les("ai_workspace/model_training/status.no")
}

funksjon motor_local_model_raw() -> tekst {
    returner motor_les("ai_workspace/model_training/models/local_context_model.no")
}

funksjon motor_autopilot_status_raw() -> tekst {
    returner motor_les("ai_workspace/autopilot/status.no")
}

funksjon motor_self_development_gate_raw() -> tekst {
    returner motor_les("ai_workspace/self_development_gate/status.no")
}

funksjon motor_json_felt(raw: tekst, namn: tekst, fallback: tekst) -> tekst {
    la no_marker = "(\"" + namn + "\", \""
    la no_pos = t.finn(raw, no_marker)
    hvis no_pos >= 0 {
        la no_etter = t.del_av(raw, no_pos + t.lengde(no_marker), t.lengde(raw))
        la no_slutt = t.finn(no_etter, "\")")
        hvis no_slutt > -1 {
            returner t.del_av(no_etter, 0, no_slutt)
        }
    }
    la marker = "\"" + namn + "\""
    la pos = t.finn(raw, marker)
    hvis pos < 0 {
        returner fallback
    }
    la etter = t.del_av(raw, pos + t.lengde(marker), t.lengde(raw))
    la kolon = t.finn(etter, ":")
    hvis kolon < 0 {
        la komma_no = t.finn(etter, ",")
        hvis komma_no < 0 {
            returner fallback
        }
        la no_verdi = t.trim(t.del_av(etter, komma_no + 1, t.lengde(etter)))
        hvis t.finn(no_verdi, "\"") == 0 {
            la no_rest = t.del_av(no_verdi, 1, t.lengde(no_verdi))
            la no_slutt = t.finn(no_rest, "\"")
            hvis no_slutt > -1 {
                returner t.del_av(no_rest, 0, no_slutt)
            }
        }
        returner fallback
    }
    la verdi = t.trim(t.del_av(etter, kolon + 1, t.lengde(etter)))
    hvis t.finn(verdi, "\"") == 0 {
        la rest = t.del_av(verdi, 1, t.lengde(verdi))
        la slutt = t.finn(rest, "\"")
        hvis slutt > -1 {
            returner t.del_av(rest, 0, slutt)
        }
    }
    la komma = t.finn(verdi, ",")
    hvis komma > -1 {
        returner t.trim(t.del_av(verdi, 0, komma))
    }
    la brace = t.finn(verdi, "}")
    hvis brace > -1 {
        returner t.trim(t.del_av(verdi, 0, brace))
    }
    returner fallback
}

funksjon motor_policy_block_path(prompt: tekst) -> tekst {
    la raw = motor_les("policy.no")
    la blokker = motor_json_felt(raw, "blocked_paths", "")
    hvis blokker == "" {
        returner ""
    }
    la blokker_liste = t.splitt(blokker, ",")
    la lav_prompt = motor_lav(prompt)
    la i: heiltall = 0
    mens i < builtin.lengde(blokker_liste) {
        la blokk = t.trim(blokker_liste[i])
        hvis blokk != "" {
            hvis t.finn(lav_prompt, t.til_små_bokstavar(blokk)) >= 0 {
                returner blokk
            }
        }
        i = i + 1
    }
    returner ""
}

funksjon motor_policy_risk(blokk: tekst) -> tekst {
    la raw = motor_les("policy.no")
    la high = motor_json_felt(raw, "high_risk_paths", "")
    hvis high != "" {
        la high_list = t.splitt(high, ",")
        la i: heiltall = 0
        mens i < builtin.lengde(high_list) {
            hvis t.trim(high_list[i]) == blokk {
                returner "high"
            }
            i = i + 1
        }
    }
    la medium = motor_json_felt(raw, "medium_risk_paths", "")
    hvis medium != "" {
        la medium_list = t.splitt(medium, ",")
        la j: heiltall = 0
        mens j < builtin.lengde(medium_list) {
            hvis t.trim(medium_list[j]) == blokk {
                returner "medium"
            }
            j = j + 1
        }
    }
    returner "low"
}

funksjon motor_har_sti_godkjenning(prompt: tekst, blokk: tekst) -> boolsk {
    la lower = motor_lav(prompt)
    hvis lower == "" {
        returner usann
    }
    hvis t.finn(lower, "godkjenn \"" + t.til_små_bokstavar(blokk) + "\"") >= 0 {
        returner sann
    }
    hvis t.finn(lower, "godkjenn:" + t.til_små_bokstavar(blokk)) >= 0 {
        returner sann
    }
    hvis t.finn(lower, "godkjenn " + t.til_små_bokstavar(blokk)) >= 0 {
        returner sann
    }
    hvis t.finn(lower, "approve \"" + t.til_små_bokstavar(blokk) + "\"") >= 0 {
        returner sann
    }
    hvis t.finn(lower, "approve " + t.til_små_bokstavar(blokk)) >= 0 {
        returner sann
    }
    returner usann
}

funksjon motor_policy_blockert(prompt: tekst) -> boolsk {
    la blokk = motor_policy_block_path(prompt)
    hvis blokk == "" {
        returner usann
    }
    hvis motor_policy_risk(blokk) == "low" {
        returner usann
    }
    hvis motor_json_felt(motor_les("policy.no"), "require_path_confirmation", "false") == "true" {
        hvis motor_har_sti_godkjenning(prompt, blokk) {
            returner usann
        }
        returner sann
    }
    returner usann
}

funksjon motor_policy_block_message(prompt: tekst) -> tekst {
    la blokk = motor_policy_block_path(prompt)
    hvis blokk == "" {
        returner ""
    }
    la risiko = motor_policy_risk(blokk)
    hvis risiko == "low" {
        returner ""
    }
    hvis motor_har_sti_godkjenning(prompt, blokk) {
        returner ""
    }
    returner "Denne handlinga rører eit " + risiko + "-risiko område: " + blokk + ". Eg kan berre føreslå dette i forslagform, men krev eksplisitt godkjenning. Skriv: godkjenn " + blokk
}

funksjon motor_json_block_from(raw: tekst) -> tekst {
    la start = t.finn(raw, "{")
    hvis start < 0 {
        returner ""
    }
    la rest = t.del_av(raw, start, t.lengde(raw))
    la i: heiltall = 0
    la djupt: heiltall = 0
    la slutt: heiltall = -1
    la ferdig = usann
    mens i < t.lengde(rest) og ikkje ferdig {
        la ch = t.del_av(rest, i, i + 1)
        hvis ch == "{" {
            djupt = djupt + 1
        }
        hvis ch == "}" {
            djupt = djupt - 1
            hvis djupt == 0 {
                slutt = i + 1
                ferdig = sann
            }
        }
        i = i + 1
    }
    hvis slutt < 0 {
        returner rest
    }
    returner t.del_av(rest, 0, slutt)
}

funksjon motor_felt_fra_blokk(raw: tekst, namn: tekst) -> tekst {
    la pos = t.finn(raw, namn)
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(raw, pos + t.lengde(namn), t.lengde(raw))
    la kolon = t.finn(rest, ":")
    hvis kolon < 0 {
        returner ""
    }
    la verdi = t.trim(t.del_av(rest, kolon + 1, t.lengde(rest)))
    hvis t.finn(verdi, "\"") == 0 {
        la body = t.del_av(verdi, 1, t.lengde(verdi))
        la slutt = t.finn(body, "\"")
        hvis slutt > -1 {
            returner t.del_av(body, 0, slutt)
        }
    }
    returner ""
}

funksjon motor_felt_block(raw: tekst, marker: tekst) -> tekst {
    la pos = t.finn(raw, marker)
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(raw, pos, t.lengde(raw))
    la marker_start = t.finn(rest, "{")
    hvis marker_start < 0 {
        returner ""
    }
    returner motor_json_block_from(t.del_av(rest, marker_start, t.lengde(rest)))
}

funksjon motor_json_array(raw: tekst, marker: tekst) -> tekst {
    la pos = t.finn(raw, marker)
    hvis pos < 0 {
        returner "[]"
    }
    la rest = t.del_av(raw, pos, t.lengde(raw))
    la kolon = t.finn(rest, ":")
    hvis kolon < 0 {
        returner "[]"
    }
    la etter = t.del_av(rest, kolon + 1, t.lengde(rest))
    la opning = t.finn(etter, "[")
    hvis opning < 0 {
        returner "[]"
    }
    la arr = t.del_av(etter, opning, t.lengde(etter))
    la i: heiltall = 0
    la djupt: heiltall = 0
    la slutt: heiltall = -1
    mens i < t.lengde(arr) {
        la ch = t.del_av(arr, i, i + 1)
        hvis ch == "[" {
            djupt = djupt + 1
        }
        hvis ch == "]" {
            djupt = djupt - 1
            hvis djupt == 0 {
                slutt = i + 1
                i = t.lengde(arr)
            }
        }
        i = i + 1
    }
    hvis slutt < 0 {
        returner "[]"
    }
    returner t.del_av(arr, 0, slutt + 1)
}

funksjon motor_første_objekt_med_id(raw_array: tekst, id: tekst) -> tekst {
    la marker = "\"id\": \"" + id + "\""
    la pos = t.finn(raw_array, marker)
    hvis pos < 0 {
        returner ""
    }
    la start = pos
    la funnet = usann
    mens start >= 0 og ikkje funnet {
        hvis t.del_av(raw_array, start, start + 1) == "{" {
            funnet = sann
        } ellers {
            start = start - 1
        }
    }
    hvis ikkje funnet {
        returner ""
    }
    la rest = t.del_av(raw_array, start, t.lengde(raw_array))
    returner motor_json_block_from(rest)
}

funksjon motor_queue_item_tittel(raw: tekst, id: tekst) -> tekst {
    la item = motor_første_objekt_med_id(motor_json_array(raw, "\"items\""), id)
    hvis item == "" {
        returner ""
    }
    la tittel = motor_felt_fra_blokk(item, "\"title\"")
    hvis tittel != "" {
        returner tittel
    }
    returner ""
}

funksjon motor_set_queue_item_status(raw: tekst, id: tekst, status: tekst) -> tekst {
    hvis t.finn(raw, "queue_item(\"") > -1 {
        returner motor_set_queue_no_item_status(raw, id, status)
    }
    la items = motor_json_array(raw, "\"items\"")
    hvis items == "" eller items == "[]" {
        returner raw
    }
    la item = motor_første_objekt_med_id(items, id)
    hvis item == "" {
        returner raw
    }
    la old = motor_felt_fra_blokk(item, "\"status\"")
    hvis old == "" {
        returner raw
    }
    la ny_item = t.erstatt(item, "\"status\": \"" + old + "\"", "\"status\": \"" + status + "\"")
    hvis ny_item == item {
        returner raw
    }
    la items_oppdatert = t.erstatt(items, item, ny_item)
    returner t.erstatt(raw, items, items_oppdatert)
}

funksjon motor_no_felt(raw: tekst, kind: tekst, namn: tekst, fallback: tekst) -> tekst {
    la marker = kind + "(\"" + namn + "\", \""
    la pos = t.finn(raw, marker)
    hvis pos < 0 {
        returner fallback
    }
    la rest = t.del_av(raw, pos + t.lengde(marker), t.lengde(raw))
    la slutt = t.finn(rest, "\")")
    hvis slutt < 0 {
        returner fallback
    }
    returner t.del_av(rest, 0, slutt)
}

funksjon motor_queue_no_item_linje(raw: tekst, id: tekst) -> tekst {
    la marker = "queue_item(\"" + id + "\", \""
    la pos = t.finn(raw, marker)
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(raw, pos, t.lengde(raw))
    la slutt = t.finn(rest, "\n")
    hvis slutt < 0 {
        returner rest
    }
    returner t.del_av(rest, 0, slutt)
}

funksjon motor_queue_no_første_linje(raw: tekst) -> tekst {
    la pos = t.finn(raw, "queue_item(\"")
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(raw, pos, t.lengde(raw))
    la slutt = t.finn(rest, "\n")
    hvis slutt < 0 {
        returner rest
    }
    returner t.del_av(rest, 0, slutt)
}

funksjon motor_queue_no_neste_linje(raw: tekst, current_id: tekst) -> tekst {
    la current = motor_queue_no_item_linje(raw, current_id)
    hvis current == "" {
        returner ""
    }
    la pos = t.finn(raw, current)
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(raw, pos + t.lengde(current), t.lengde(raw))
    la next_pos = t.finn(rest, "queue_item(\"")
    hvis next_pos < 0 {
        returner ""
    }
    la next_rest = t.del_av(rest, next_pos, t.lengde(rest))
    la slutt = t.finn(next_rest, "\n")
    hvis slutt < 0 {
        returner next_rest
    }
    returner t.del_av(next_rest, 0, slutt)
}

funksjon motor_queue_no_linje_id(linje: tekst) -> tekst {
    la marker = "queue_item(\""
    la pos = t.finn(linje, marker)
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(linje, pos + t.lengde(marker), t.lengde(linje))
    la slutt = t.finn(rest, "\"")
    hvis slutt < 0 {
        returner ""
    }
    returner t.del_av(rest, 0, slutt)
}

funksjon motor_queue_no_linje_verdi(linje: tekst) -> tekst {
    la marker = "\", \""
    la pos = t.finn(linje, marker)
    hvis pos < 0 {
        returner ""
    }
    la rest = t.del_av(linje, pos + t.lengde(marker), t.lengde(linje))
    la slutt = t.finn(rest, "\")")
    hvis slutt < 0 {
        returner rest
    }
    returner t.del_av(rest, 0, slutt)
}

funksjon motor_queue_no_linje_status(linje: tekst) -> tekst {
    la verdi = motor_queue_no_linje_verdi(linje)
    la sep = t.finn(verdi, " | ")
    hvis sep < 0 {
    returner verdi
}

    returner t.trim(t.del_av(verdi, 0, sep))
}

funksjon motor_model_status_felt(namn: tekst, fallback: tekst) -> tekst {
    returner motor_json_felt(motor_model_status_raw(), namn, fallback)
}

funksjon motor_autopilot_status_felt(namn: tekst, fallback: tekst) -> tekst {
    returner motor_json_felt(motor_autopilot_status_raw(), namn, fallback)
}

funksjon motor_self_development_gate_felt(namn: tekst, fallback: tekst) -> tekst {
    returner motor_json_felt(motor_self_development_gate_raw(), namn, fallback)
}

funksjon motor_model_rule(namn: tekst, fallback: tekst) -> tekst {
    returner motor_json_felt(motor_local_model_raw(), namn, fallback)
}

funksjon motor_model_er_klar() -> boolsk {
    returner motor_model_status_felt("model_trained", "usann") == "sann"
}

funksjon motor_model_kort_status() -> tekst {
    hvis ikkje motor_model_er_klar() {
        returner "Lokal modell er ikkje trent enno."
    }
    returner "Lokal modell er trent: " + motor_model_status_felt("model_type", "local_norscode_context_model") + ", " + motor_model_status_felt("examples", "0") + " døme, checksum " + motor_model_status_felt("model_checksum", "ukjent") + "."
}

funksjon motor_autopilot_kort_status() -> tekst {
    la raw = motor_autopilot_status_raw()
    hvis raw == "" {
        returner "Autopilot er ikkje kjørt ennå."
    }
    returner "Autopilot " + motor_autopilot_status_felt("overall", "ukjent") + ": " + motor_autopilot_status_felt("completed_cycles", "0") + " syklus(ar), gate " + motor_autopilot_status_felt("self_development_gate_overall", "ukjent") + ", siste mål: " + motor_autopilot_status_felt("latest_goal", "ukjent") + "."
}

funksjon motor_self_development_gate_kort_status() -> tekst {
    la raw = motor_self_development_gate_raw()
    hvis raw == "" {
        returner "Selvutviklingsgate er ikkje kjørt ennå."
    }
    returner "Selvutviklingsgate " + motor_self_development_gate_felt("overall", "ukjent") + ": " + motor_self_development_gate_felt("decision", "ukjent") + ", manglende krav " + motor_self_development_gate_felt("missing_required_checks", "ukjent") + ", checksum " + motor_self_development_gate_felt("model_checksum", "ukjent") + "."
}

funksjon motor_model_guidance() -> tekst {
    hvis ikkje motor_model_er_klar() {
        returner "- Modellråd: køyr modelltrening før autonom prioritering.\n"
    }
    la out = ""
    out = out + "- Modell: " + motor_model_kort_status() + "\n"
    out = out + "- Hjemmeside: " + motor_model_rule("homepage", "bruk lokal hjemmesideindeks før svar om Norscode.no") + "\n"
    out = out + "- Selvutvikling: " + motor_model_rule("self_development", "bruk plan, draft, diff, test, audit og rollback før endring") + "\n"
    out = out + "- Kritiske stier: " + motor_model_rule("critical_paths", "stopp og krev godkjenning") + "\n"
    out = out + "- Læring: " + motor_model_rule("learning", "les learning/status.no og autonomy/status.no før nye steg") + "\n"
    returner out
}

funksjon motor_model_example_expected(id: tekst, fallback: tekst) -> tekst {
    returner motor_json_felt(motor_local_model_raw(), id + ".expected", fallback)
}

funksjon motor_model_select_intent(sporsmal: tekst) -> tekst {
    hvis ikkje motor_model_er_klar() {
        returner "model-not-ready"
    }
    hvis motor_har(sporsmal, "dist/norscode_native") eller motor_har(sporsmal, "bootstrap/stage0") eller motor_har(sporsmal, "native binary") eller motor_har(sporsmal, "kritisk") {
        returner "critical-path-refusal"
    }
    hvis motor_har(sporsmal, "reparer drift") eller motor_har(sporsmal, "repair-model-drift") eller motor_har(sporsmal, "stale") {
        returner "self-programming-maintenance"
    }
    hvis motor_har(sporsmal, "hva har ai-en selv programmert") eller motor_har(sporsmal, "selvprogrammert") eller motor_har(sporsmal, "selvprogrammering status") {
        returner "self-programming-cycle"
    }
    hvis motor_har(sporsmal, "utvikle deg") eller motor_har(sporsmal, "utvikle på egenhånd") eller motor_har(sporsmal, "neste trygge") eller motor_har(sporsmal, "neste steg") {
        returner "safe-next-action"
    }
    hvis motor_har(sporsmal, "helt fritt") eller motor_har(sporsmal, "fri selvmutasjon") eller motor_har(sporsmal, "endre egen kode fritt") {
        returner "self-development-boundary"
    }
    hvis motor_har(sporsmal, "modelltrening") eller motor_har(sporsmal, "modell status") eller motor_har(sporsmal, "model training") {
        returner "self-programming-cycle"
    }
    hvis motor_har(sporsmal, "læring") eller motor_har(sporsmal, "learning") {
        returner "learning-status"
    }
    hvis motor_har(sporsmal, "autonomi") eller motor_har(sporsmal, "autonomy") eller motor_har(sporsmal, "autopilot") {
        returner "autonomy-status"
    }
    hvis motor_har(sporsmal, "hjemmeside") eller motor_har(sporsmal, "norscode.no") eller motor_har(sporsmal, "adsense") {
        returner "explain-homepage-context"
    }
    returner "safe-next-action"
}

funksjon motor_model_recommended_action(intent: tekst) -> tekst {
    hvis intent == "critical-path-refusal" {
        returner "lag rapport og krev manuell godkjenning; ikkje auto-apply"
    }
    hvis intent == "self-programming-maintenance" {
        returner "køyr passiv verify eller repair-model-drift utan å øke cycle_count"
    }
    hvis intent == "self-programming-cycle" {
        returner "les fersk selvprogrammeringsstatus, modellchecksum og verify før ny handling"
    }
    hvis intent == "safe-next-action" {
        returner "velg lavrisiko målfil, lag plan/draft/diff/test/audit"
    }
    hvis intent == "explain-homepage-context" {
        returner "les lokal hjemmeside-ai-index før svar om Norscode.no"
    }
    hvis intent == "learning-status" {
        returner "les læringsstatus før nye selvutviklingssteg"
    }
    hvis intent == "autonomy-status" {
        returner "les autonomi- og readinessstatus før oppgaveprioritering"
    }
    hvis intent == "self-development-boundary" {
        returner "forklar kontrollert lavrisiko-selvutvikling og kritiske grenser"
    }
    returner "bruk lokal modell som kontekst, men stopp ved manglende grønn status"
}

funksjon motor_model_selection_report(sporsmal: tekst) -> tekst {
    la intent = motor_model_select_intent(sporsmal)
    la expected = motor_model_example_expected(intent, motor_model_recommended_action(intent))
    la action = motor_model_recommended_action(intent)
    la checksum = motor_model_status_felt("model_checksum", "ukjent")
    la examples = motor_model_status_felt("examples", "0")
    la out = ""
    out = out + motor_no_line("model_selection", "schema", "norscode.ai.model_selection.v1")
    out = out + motor_no_line("model_selection", "prompt", sporsmal)
    out = out + motor_no_line("model_selection", "selected_intent", intent)
    out = out + motor_no_line("model_selection", "source_model", motor_model_status_felt("model_artifact", "mangler"))
    out = out + motor_no_line("model_selection", "model_checksum", checksum)
    out = out + motor_no_line("model_selection", "model_examples", examples)
    out = out + motor_no_line("model_selection", "expected_from_model", expected)
    out = out + motor_no_line("model_selection", "recommended_action", action)
    out = out + motor_no_line("model_selection", "active_runtime_changed", "usann")
    out = out + motor_no_line("model_selection", "updated_at", motor_tid())
    motor_skriv("ai_workspace/model_training/selection.no", out)
    returner intent + " -> " + action
}

funksjon motor_self_development_gate_svar(sporsmal: tekst) -> tekst {
    hvis motor_har(sporsmal, "selvutviklingsgate") eller motor_har(sporsmal, "sjølvutviklingsgate") eller motor_har(sporsmal, "self-development gate") eller motor_har(sporsmal, "gate status") {
        la raw = motor_self_development_gate_raw()
        hvis raw == "" {
            returner "Selvutviklingsgate\n- Status: manglar.\n- Neste: kjør tools/ai_self_development_gate.sh verify.\n"
        }
        la overall = motor_self_development_gate_felt("overall", "ukjent")
        la decision = motor_self_development_gate_felt("decision", "ukjent")
        la missing = motor_self_development_gate_felt("missing_required_checks", "ukjent")
        la model_trained = motor_self_development_gate_felt("model_trained", "ukjent")
        la checksum = motor_self_development_gate_felt("model_checksum", "ukjent")
        la loop = motor_self_development_gate_felt("model_loop_overall", "ukjent")
        la loop_consistent = motor_self_development_gate_felt("model_loop_checksum_consistent", "ukjent")
        la autopilot = motor_self_development_gate_felt("autopilot_overall", "ukjent")
        la proof = motor_self_development_gate_felt("proof_checksum_match", "ukjent")
        la kernel = motor_self_development_gate_felt("kernel_model_autonomy_command", "ukjent")
        la next = motor_self_development_gate_felt("next", "fortsett kontrollert")
        la out = ""
        out = out + "Selvutviklingsgate\n"
        out = out + "- Status: " + overall + ".\n"
        out = out + "- Decision: " + decision + ".\n"
        out = out + "- Manglende krav: " + missing + ".\n"
        out = out + "- Modell trent: " + model_trained + ".\n"
        out = out + "- Modell checksum: " + checksum + ".\n"
        out = out + "- Modell-loop: " + loop + ".\n"
        out = out + "- Modell/bevis checksum: " + loop_consistent + ".\n"
        out = out + "- Autopilot: " + autopilot + ".\n"
        out = out + "- Bevis matcher modell: " + proof + ".\n"
        out = out + "- Kernel-kommando: " + kernel + ".\n"
        out = out + "- Neste trygge steg: " + next + ".\n"
        motor_logg_laring(sporsmal, "self-development-gate", "rapporterte samlet selvutviklingsgate")
        returner out
    }
    returner ""
}

funksjon motor_model_svar(sporsmal: tekst) -> tekst {
	    hvis motor_har(sporsmal, "modelltrening") eller motor_har(sporsmal, "model training") eller motor_har(sporsmal, "modell status") eller motor_har(sporsmal, "trent modell") {
	        la artifact = motor_model_status_felt("model_artifact", "mangler")
	        la readiness = motor_model_status_felt("training_data_ready", "ukjent")
	        la trained = motor_model_status_felt("model_trained", "usann")
	        la selection = motor_model_selection_report(sporsmal)
	        la out = ""
	        out = out + "Modelltrening\n"
	        out = out + "- Treningsdata klar: " + readiness + ".\n"
	        out = out + "- Modell trent: " + trained + ".\n"
	        out = out + "- Artefakt: " + artifact + ".\n"
	        out = out + "- Modellvalg: " + selection + ".\n"
	        out = out + motor_model_guidance()
        motor_logg_laring(sporsmal, "model-training-status", "rapporterte lokal modellstatus")
        returner out
    }
    returner ""
}

funksjon motor_autopilot_svar(sporsmal: tekst) -> tekst {
    hvis motor_har(sporsmal, "autopilot") eller motor_har(sporsmal, "auto pilot") eller motor_har(sporsmal, "selvkjøring") eller motor_har(sporsmal, "sjølvkøyring") {
        la overall = motor_autopilot_status_felt("overall", "ukjent")
        la cycles = motor_autopilot_status_felt("completed_cycles", "0")
        la latest = motor_autopilot_status_felt("latest_goal", "ukjent")
        la model = motor_autopilot_status_felt("model_trained", "usann")
        la loop = motor_autopilot_status_felt("model_loop_overall", "ukjent")
        la checksum = motor_autopilot_status_felt("model_loop_checksum", "ukjent")
        la proof_checksum = motor_autopilot_status_felt("model_loop_proof_checksum", "ukjent")
        la checksum_consistent = motor_autopilot_status_felt("model_loop_checksum_consistent", "usann")
        la gate = motor_autopilot_status_felt("self_development_gate_overall", "ukjent")
        la gate_missing = motor_autopilot_status_felt("self_development_gate_missing_required_checks", "ukjent")
        la gate_checksum = motor_autopilot_status_felt("self_development_gate_model_checksum", "ukjent")
        la guard = motor_autopilot_status_felt("guard", "stoppar ved ikkje-grønn status")
        la out = ""
        out = out + "Autopilot-status\n"
        out = out + "- Status: " + overall + ".\n"
        out = out + "- Fullførte sykluser: " + cycles + ".\n"
        out = out + "- Siste mål: " + latest + ".\n"
        out = out + "- Modell trent: " + model + ".\n"
        out = out + "- Modell-loop: " + loop + ".\n"
        out = out + "- Modell/bevis checksum: " + checksum_consistent + " (" + checksum + " / " + proof_checksum + ").\n"
        out = out + "- Selvutviklingsgate: " + gate + " (mangler " + gate_missing + ", checksum " + gate_checksum + ").\n"
        out = out + "- Guard: " + guard + ".\n"
        out = out + "- Neste trygge steg: kjør autopilot via kontrollert verktøy, eller les audit før flere sykluser.\n"
        motor_logg_laring(sporsmal, "autopilot-status", "rapporterte kontrollert autopilotstatus")
        returner out
    }
    returner ""
}

funksjon motor_queue_no_linje_tittel(linje: tekst) -> tekst {
    la verdi = motor_queue_no_linje_verdi(linje)
    la sep = t.finn(verdi, " | ")
    hvis sep < 0 {
        returner verdi
    }
    returner t.trim(t.del_av(verdi, sep + 3, t.lengde(verdi)))
}

funksjon motor_set_queue_no_item_status(raw: tekst, id: tekst, status: tekst) -> tekst {
    la linje = motor_queue_no_item_linje(raw, id)
    hvis linje == "" {
        returner raw
    }
    la old_status = motor_queue_no_linje_status(linje)
    hvis old_status == "" eller old_status == status {
        returner raw
    }
    la ny_linje = t.erstatt(linje, "\"" + old_status + " | ", "\"" + status + " | ")
    la updated = t.erstatt(raw, linje, ny_linje)
    hvis motor_no_felt(updated, "queue_active", "id", "") == id {
        updated = motor_set_json_felt(updated, "status", status)
    }
    returner updated
}

funksjon motor_queue_har_item(raw: tekst, id: tekst) -> boolsk {
    la items = motor_json_array(raw, "\"items\"")
    hvis items == "" {
        returner usann
    }
    la item = motor_første_objekt_med_id(items, id)
    hvis item == "" {
        returner usann
    }
    returner sann
}

funksjon motor_queue_legg_til_item(raw: tekst, id: tekst, tittel: tekst, prioritet: tekst, status: tekst, avhengigheter: tekst) -> tekst {
    hvis motor_queue_har_item(raw, id) {
        returner raw
    }
    la items = motor_json_array(raw, "\"items\"")
    hvis items == "" {
        returner raw
    }
    hvis avhengigheter == "" {
        la avhengigheter = "[]"
    }
    la nytt_item = "{\n      \"id\": \"" + id + "\",\n      \"title\": \"" + motor_escape_json(tittel) + "\",\n      \"priority\": \"" + prioritet + "\",\n      \"status\": \"" + status + "\",\n      \"depends_on\": " + avhengigheter + "\n    }"
    la nye_items: tekst
    hvis items == "[]" {
        la nye_items = "[\n    " + nytt_item + "\n  ]"
    } ellers {
        la uten_siste = t.del_av(items, t.lengde(items) - 1, t.lengde(items))
        hvis t.trim(uten_siste) == "" {
            la nye_items = "[\n    " + nytt_item + "\n  ]"
        } ellers {
            la nye_items = uten_siste + ",\n    " + nytt_item + "\n  ]"
        }
    }
    returner t.erstatt(raw, items, nye_items)
}

funksjon motor_første_objekt(raw_array: tekst) -> tekst {
    la start = t.finn(raw_array, "{")
    hvis start < 0 {
        returner ""
    }
    la rest = t.del_av(raw_array, start, t.lengde(raw_array))
    returner motor_json_block_from(rest)
}

funksjon motor_set_json_felt(raw: tekst, namn: tekst, verdi: tekst) -> tekst {
    la gammel = motor_json_felt(raw, namn, "")
    hvis gammel == "" {
        returner raw
    }
    la old = "\"" + namn + "\": \"" + gammel + "\""
    la new = "\"" + namn + "\": \"" + verdi + "\""
    la updated = t.erstatt(raw, old, new)
    hvis updated != raw {
        returner updated
    }
    la old_no = "\"" + namn + "\", \"" + gammel + "\""
    la new_no = "\"" + namn + "\", \"" + verdi + "\""
    returner t.erstatt(raw, old_no, new_no)
}

funksjon motor_set_verification_check_status(raw: tekst, id: tekst, status: tekst) -> tekst {
    la prefix = "verification_check_status(\"" + id + "\", \""
    la pos = t.finn(raw, prefix)
    hvis pos < 0 {
        returner raw
    }
    la rest = t.del_av(raw, pos + t.lengde(prefix), t.lengde(raw))
    la slutt = t.finn(rest, "\"")
    hvis slutt < 0 {
        returner raw
    }
    la gammel = t.del_av(rest, 0, slutt)
    la old = prefix + gammel + "\")"
    la new = prefix + status + "\")"
    returner t.erstatt(raw, old, new)
}

funksjon motor_set_active_item_status(raw: tekst, status: tekst) -> tekst {
    hvis t.finn(raw, "queue_active(\"status\"") > -1 {
        returner motor_set_json_felt(raw, "status", status)
    }
    la active_block = motor_felt_block(raw, "\"active_item\"")
    hvis active_block == "" {
        returner raw
    }
    la old_status = motor_felt_fra_blokk(active_block, "\"status\"")
    hvis old_status == "" {
        returner raw
    }
    la old = "\"status\": \"" + old_status + "\""
    la new = "\"status\": \"" + status + "\""
    hvis old == new {
        returner raw
    }
    la active_block_new = t.erstatt(active_block, old, new)
    returner t.erstatt(raw, active_block, active_block_new)
}

funksjon motor_autonomi_set_felt_trygt(fil: tekst, namn: tekst, verdi: tekst) -> boolsk {
    la target = motor_state_no_namn(fil)
    hvis target != fil og motor_les(target) == "" {
        target = fil
    }
    la raw = motor_les(target)
    hvis raw == "" {
        returner false
    }
    la updated = motor_set_json_felt(raw, namn, verdi)
    hvis updated == raw {
        returner false
    }
    la ok = motor_skriv(target, updated) == 0
    hvis ok og target != fil {
        la mirror = motor_les(fil)
        hvis mirror != "" {
            la mirror_updated = motor_set_json_felt(mirror, namn, verdi)
            hvis mirror_updated != mirror {
                motor_skriv(fil, mirror_updated)
            }
        }
    }
    hvis ok og target == "review.no" {
        la mirror = motor_les("review.json")
        hvis mirror != "" {
            la mirror_updated = motor_set_json_felt(mirror, namn, verdi)
            hvis mirror_updated != mirror {
                motor_skriv("review.json", mirror_updated)
            }
        }
    }
    returner ok
}

funksjon motor_autonomi_logg_entry(handling: tekst, resultat: tekst) -> boolsk {
    la raw = motor_les("runner-log.no")
    hvis raw == "" {
        returner false
    }
    la cycle = tekst(motor_count(raw, "runner_log_entry(") + 1)
    la nytt_entry = "runner_log_entry(\"" + cycle + "\", \"" + motor_escape_json(handling) + "\", \"" + motor_escape_json(resultat) + "\")"
    la raw_updated = t.trim(raw) + "\n" + nytt_entry + "\n"
    raw_updated = motor_set_json_felt(raw_updated, "updated_at", motor_tid())
    returner motor_skriv("runner-log.no", raw_updated) == 0
}

funksjon motor_queue_active_item_id(raw: tekst) -> tekst {
    la no_id = motor_no_felt(raw, "queue_active", "id", "")
    hvis no_id != "" {
        returner no_id
    }
    la block = motor_felt_block(raw, "\"active_item\"")
    hvis block == "" {
        returner ""
    }
    returner motor_felt_fra_blokk(block, "\"id\"")
}

funksjon motor_queue_active_item_tittel(raw: tekst) -> tekst {
    la no_tittel = motor_no_felt(raw, "queue_active", "title", "")
    hvis no_tittel != "" {
        returner no_tittel
    }
    la no_id = motor_no_felt(raw, "queue_active", "id", "")
    hvis no_id != "" {
        returner no_id
    }
    la block = motor_felt_block(raw, "\"active_item\"")
    hvis block == "" {
        returner ""
    }
    la tittel = motor_felt_fra_blokk(block, "\"title\"")
    hvis tittel != "" {
        returner tittel
    }
    returner motor_felt_fra_blokk(block, "\"id\"")
}

funksjon motor_queue_første_item(raw: tekst) -> tekst {
    la items = motor_json_array(raw, "\"items\"")
    hvis items == "" eller items == "[]" {
        returner "{}"
    }
    returner motor_første_objekt(items)
}

funksjon motor_queue_første_item_id(raw: tekst) -> tekst {
    la no_linje = motor_queue_no_første_linje(raw)
    hvis no_linje != "" {
        returner motor_queue_no_linje_id(no_linje)
    }
    la item = motor_queue_første_item(raw)
    hvis item == "{}" {
        returner ""
    }
    returner motor_felt_fra_blokk(item, "\"id\"")
}

funksjon motor_queue_første_item_tittel(raw: tekst) -> tekst {
    la no_linje = motor_queue_no_første_linje(raw)
    hvis no_linje != "" {
        returner motor_queue_no_linje_tittel(no_linje)
    }
    la item = motor_queue_første_item(raw)
    hvis item == "{}" {
        returner ""
    }
    la tittel = motor_felt_fra_blokk(item, "\"title\"")
    hvis tittel != "" {
        returner tittel
    }
    returner motor_felt_fra_blokk(item, "\"id\"")
}

funksjon motor_queue_første_med_status(raw: tekst, status: tekst) -> tekst {
    la items = motor_json_array(raw, "\"items\"")
    hvis items == "" eller items == "[]" {
        returner "{}"
    }
    la needle = "\"status\": \"" + status + "\""
    la pos = t.finn(items, needle)
    hvis pos < 0 {
        returner motor_queue_første_item(raw)
    }
    la start = pos
    mens start >= 0 {
        hvis t.del_av(items, start, start + 1) == "{" {
            la candidate = motor_json_block_from(t.del_av(items, start, t.lengde(items)))
            hvis t.finn(candidate, needle) > -1 {
                returner candidate
            }
            start = -1
        }
        start = start - 1
    }
    returner motor_queue_første_item(raw)
}

funksjon motor_queue_neste_objekt(raw_array: tekst, current_id: tekst) -> tekst {
    la current = motor_første_objekt_med_id(raw_array, current_id)
    hvis current == "{}" {
        returner "{}"
    }
    la pos = t.finn(raw_array, current)
    hvis pos < 0 {
        returner "{}"
    }
    la tail = t.del_av(raw_array, pos + t.lengde(current), t.lengde(raw_array))
    la rest = t.trim(tail)
    hvis rest == "" {
        returner "{}"
    }
    la start_obj = t.finn(rest, "{")
    hvis start_obj < 0 {
        returner "{}"
    }
    la next_raw = t.del_av(rest, start_obj, t.lengde(rest))
    returner motor_json_block_from(next_raw)
}

funksjon motor_queue_neste_item_id(raw: tekst, current_id: tekst) -> tekst {
    la no_linje = motor_queue_no_neste_linje(raw, current_id)
    hvis no_linje != "" {
        returner motor_queue_no_linje_id(no_linje)
    }
    la item = motor_queue_neste_objekt(motor_json_array(raw, "\"items\""), current_id)
    hvis item == "{}" {
        returner ""
    }
    returner motor_felt_fra_blokk(item, "\"id\"")
}

funksjon motor_queue_neste_item_tittel(raw: tekst, current_id: tekst) -> tekst {
    la no_linje = motor_queue_no_neste_linje(raw, current_id)
    hvis no_linje != "" {
        returner motor_queue_no_linje_tittel(no_linje)
    }
    la item = motor_queue_neste_objekt(motor_json_array(raw, "\"items\""), current_id)
    hvis item == "{}" {
        returner ""
    }
    la tittel = motor_felt_fra_blokk(item, "\"title\"")
    hvis tittel != "" {
        returner tittel
    }
    returner motor_felt_fra_blokk(item, "\"id\"")
}

funksjon motor_queue_item_status(raw: tekst, current_id: tekst) -> tekst {
    la no_linje = motor_queue_no_item_linje(raw, current_id)
    hvis no_linje != "" {
        returner motor_queue_no_linje_status(no_linje)
    }
    la item = motor_første_objekt_med_id(motor_json_array(raw, "\"items\""), current_id)
    hvis item == "{}" {
        returner ""
    }
    returner motor_felt_fra_blokk(item, "\"status\"")
}

funksjon motor_set_array_item_felt(raw_array: tekst, id: tekst, namn: tekst, verdi: tekst) -> tekst {
    la item = motor_første_objekt_med_id(raw_array, id)
    hvis item == "{}" {
        returner raw_array
    }
    la old = motor_felt_fra_blokk(item, "\"" + namn + "\"")
    hvis old == "" {
        returner raw_array
    }
    la old_block = "\"" + namn + "\": \"" + old + "\""
    la new_block = "\"" + namn + "\": \"" + verdi + "\""
    hvis old_block == new_block {
        returner raw_array
    }
    la item_updated = t.erstatt(item, old_block, new_block)
    hvis item_updated == item {
        returner raw_array
    }
    returner t.erstatt(raw_array, item, item_updated)
}

funksjon motor_set_plan_step_status(raw_plan: tekst, step_id: tekst, status: tekst) -> tekst {
    hvis t.finn(raw_plan, "plan_step(\"" + step_id + "\", \"") > -1 {
        la marker = "plan_step(\"" + step_id + "\", \""
        la pos = t.finn(raw_plan, marker)
        la rest = t.del_av(raw_plan, pos + t.lengde(marker), t.lengde(raw_plan))
        la slutt = t.finn(rest, "\")")
        hvis slutt < 0 {
            returner raw_plan
        }
        la verdi = t.del_av(rest, 0, slutt)
        la sep = t.finn(verdi, " | ")
        hvis sep < 0 {
            returner raw_plan
        }
        la old_status = t.trim(t.del_av(verdi, 0, sep))
        hvis old_status == status {
            returner raw_plan
        }
        la old = marker + verdi + "\")"
        la new = marker + status + t.del_av(verdi, sep, t.lengde(verdi)) + "\")"
        returner t.erstatt(raw_plan, old, new)
    }
    la steps = motor_json_array(raw_plan, "\"steps\"")
    hvis steps == "" {
        returner raw_plan
    }
    la steps_updated = motor_set_array_item_felt(steps, step_id, "status", status)
    hvis steps_updated == steps {
        returner raw_plan
    }
    returner t.erstatt(raw_plan, steps, steps_updated)
}

funksjon motor_promoter_first_plan_next_to_active(raw_plan: tekst) -> tekst {
    hvis t.finn(raw_plan, "plan_step(\"") > -1 {
        returner t.erstatt(raw_plan, "\", \"next | ", "\", \"active | ")
    }
    la next_marker = "\"status\": \"next\""
    hvis t.finn(raw_plan, next_marker) < 0 {
        returner raw_plan
    }
    returner t.erstatt(raw_plan, next_marker, "\"status\": \"active\"")
}

funksjon motor_autonomi_queue_sideffekt(id: tekst, title: tekst, plan: tekst) -> tekst {
    la lav = motor_lav(title)
    hvis t.finn(lav, "state-step") > -1 eller id == "queue-001" {
        la plan_updated = motor_set_plan_step_status(plan, "step-12", "active")
        hvis plan_updated != plan {
            motor_state_skriv("plan.json", plan_updated)
            hvis motor_autonomi_set_felt_trygt("review.no", "status", "state-step-kjort") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status=state-step-kjort")
            }
            hvis motor_autonomi_set_felt_trygt("plan.json", "status", "active") {
                motor_logg_fil(motor_review_sti(), "autonomy-plan", id, "planstatus aktiv")
            }
            hvis motor_autonomi_logg_entry("state-step", "sette step-12 aktiv") {
                motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
            }
            returner "køyrte state-step: planstep step-12 sett til active."
        }
        returner "køyrte state-step: state-oppsettet var allereie aktivt."
    }

    hvis t.finn(lav, "promoter") > -1 eller t.finn(lav, "automatis") > -1 eller id == "queue-002" {
        la plan_updated = motor_promoter_first_plan_next_to_active(plan)
        hvis plan_updated != plan {
            motor_state_skriv("plan.json", plan_updated)
            hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Neste steg er no promotert frå next til active.") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", id, "oppdatert next_recommendation")
            }
            hvis motor_autonomi_set_felt_trygt("queue.json", "mode", "guided_autonomy_promote") {
                motor_logg_fil(motor_review_sti(), "autonomy-queue", id, "mode=guided_autonomy_promote")
            }
            hvis motor_autonomi_logg_entry("promote", "plan-step frå next til active") {
                motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
            }
            returner "køyrte queue-promotering: første plan-step frå next til active."
        }
        returner "køyrte queue-promotering: ingen next-planstep funne."
    }

    hvis t.finn(lav, "review") > -1 eller id == "queue-003" {
        hvis motor_autonomi_set_felt_trygt("review.no", "status", "review-funn-kopiert") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status=review-funn-kopiert")
        }
        hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_review") {
            motor_logg_fil(motor_review_sti(), "autonomy-memory", id, "mode=guided_autonomy_review")
        }
        hvis motor_autonomi_set_felt_trygt("memory.json", "updated_at", motor_tid()) {
            motor_logg_fil(motor_review_sti(), "autonomy-memory", id, "memory updated_at refresh")
        }
        hvis motor_autonomi_logg_entry("review-sync", "kopierte review-funn tilbake til memory") {
            motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
        }
        returner "køyrte review-writeback: reviewstatus synkronisert mot minnelag."
    }

    hvis t.finn(lav, "lukke") > -1 eller t.finn(lav, "gap") > -1 eller id == "queue-004" {
        hvis motor_autonomi_set_felt_trygt("review.no", "status", "gaps-sjekka") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status=gaps-sjekka")
        }
        hvis motor_autonomi_set_felt_trygt("verification.no", "status", "verification-gaps-review") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "verification status oppdatert")
        }
        returner "køyrte gap-lukking: review-gap-sjekk gjennomført."
    }

    hvis t.finn(lav, "operativ") > -1 eller id == "queue-005" {
        hvis motor_autonomi_set_felt_trygt("verification.no", "status", "ready") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "verification-status = ready")
        }
        hvis motor_autonomi_set_felt_trygt("writeback.no", "status", "writeback-active") {
            motor_logg_fil(motor_review_sti(), "autonomy-writeback", id, "writeback status aktiv")
        }
        hvis motor_autonomi_logg_entry("state-step-exec", "operativt state-step er aktivt") {
            motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
        }
        returner "køyrte operative state-step: state-writeback-sak klargjort."
    }

    hvis (t.finn(lav, "writeback") > -1 og id != "queue-009") eller id == "queue-006" {
        hvis motor_autonomi_set_felt_trygt("writeback.no", "status", "prototype_ready") {
            motor_logg_fil(motor_review_sti(), "autonomy-writeback", id, "writeback tilbake til prototype_ready")
        }
        hvis motor_autonomi_set_felt_trygt("plan.json", "current_phase", "verification") {
            motor_logg_fil(motor_review_sti(), "autonomy-plan", id, "current_phase=verification")
        }
        hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_writeback") {
            motor_logg_fil(motor_review_sti(), "autonomy-memory", id, "mode=guided_autonomy_writeback")
        }
        hvis motor_autonomi_logg_entry("writeback-link", "kopla state-step til writeback-step") {
            motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
        }
        returner "køyrte writeback-lenke: state-step er kobla til writeback-step."
    }

    hvis t.finn(lav, "verification") > -1 eller id == "queue-007" {
        hvis motor_autonomi_set_felt_trygt("verification.no", "status", "kernel-coupled") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "verification status=kernel-coupled")
        }
        hvis motor_autonomi_set_felt_trygt("verification.no", "next_stage", "Køyr enkle interne checks etter kvar autonomi-syklus.") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "next_stage=autonomi-cycle-feedback")
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "status", "verification-copied") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status=verification-copied")
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Kjør verification-køyring for siste syklus og bruk resultata som neste handlingskriterium.") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "next_recommendation=verification-kjøyring")
        }
        hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_verification") {
            motor_logg_fil(motor_review_sti(), "autonomy-memory", id, "mode=guided_autonomy_verification")
        }
        hvis motor_autonomi_set_felt_trygt("queue.json", "mode", "guided_autonomy_verification") {
            motor_logg_fil(motor_review_sti(), "autonomy-queue", id, "mode=guided_autonomy_verification")
        }
        hvis motor_autonomi_logg_entry("verification-link", "kopla state-step til verification-layer") {
            motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
        }
        returner "køyrte verification-kobling: ai-kjerne knytt til verification-laget."
    }

    hvis id == "queue-008" {
        la verification = motor_les("verification.no")
        hvis verification != "" {
            verification = motor_set_verification_check_status(verification, "check-01", "green")
            verification = motor_set_verification_check_status(verification, "check-02", "green")
            verification = motor_set_verification_check_status(verification, "check-03", "amber")
        }
        hvis motor_autonomi_set_felt_trygt("verification.no", "status", "checks-run") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "verification status=checks-run")
        }
        hvis motor_autonomi_set_felt_trygt("verification.no", "next_stage", "Kopier resultat frå queue-008 tilbake til review og legg inn gap-queue ved behov.") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "next_stage=close-gap")
        }
        hvis motor_autonomi_set_felt_trygt("verification.no", "state", "amber") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "state=amber")
        }
        hvis motor_autonomi_set_felt_trygt("verification.no", "result", "2 av 3 checks grøne, writeback-produced er enno amber grunna manglande writeback-spor") {
            motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "result=2-av-3")
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "status", "verification-results-ready") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status=verification-results-ready")
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "2 av 3 checks grøne; legg queue-009 for writeback-gap i queue før neste autonomous steg.") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "next_recommendation=queue-009")
        }
        hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_feedback") {
            motor_logg_fil(motor_review_sti(), "autonomy-memory", id, "mode=guided_autonomy_feedback")
        }
        hvis motor_autonomi_set_felt_trygt("queue.json", "mode", "guided_autonomy_feedback") {
            motor_logg_fil(motor_review_sti(), "autonomy-queue", id, "mode=guided_autonomy_feedback")
        }
        hvis motor_autonomi_logg_entry("verification-run", "køyrde 3 interne checks, 2 grøne, 1 amber") {
            motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
        }
        hvis verification != "" {
            hvis motor_skriv("verification.no", verification) {
                motor_logg_fil(motor_review_sti(), "autonomy-write", id, "oppdatert verification-checks")
            }
        }
        returner "køyrte intern verifikasjon: state-consistency=green, focus-selected=green, writeback-produced=amber."
    }

    hvis id == "queue-009" {
        la verification = motor_les("verification.no")
        hvis verification != "" {
            verification = motor_set_verification_check_status(verification, "check-01", "green")
            verification = motor_set_verification_check_status(verification, "check-02", "green")
            verification = motor_set_verification_check_status(verification, "check-03", "green")
        }
        la verification_updated = usann
        hvis verification != "" {
            verification = motor_set_json_felt(verification, "checks_done", "3")
            verification = motor_set_json_felt(verification, "checks_blocked", "0")
            verification = motor_set_json_felt(verification, "state", "green")
            verification = t.erstatt(verification, "2 av 3 checks grøne, writeback-produced er enno amber grunna manglande writeback-spor", "3 av 3 checks grøne; writeback-feedback lukka.")
            hvis motor_skriv("verification.no", verification) {
                verification_updated = sann
                motor_logg_fil(motor_review_sti(), "autonomy-write", id, "oppdatert verification-feedback")
            }
        }
        hvis verification_updated {
            hvis motor_autonomi_set_felt_trygt("verification.no", "status", "checks-complete") {
                motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "verification status=checks-complete")
            }
            hvis motor_autonomi_set_felt_trygt("verification.no", "state", "green") {
                motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "state=green")
            }
            hvis motor_autonomi_set_felt_trygt("verification.no", "checks_done", "3") {
                motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "checks_done=3")
            }
            hvis motor_autonomi_set_felt_trygt("verification.no", "checks_blocked", "0") {
                motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "checks_blocked=0")
            }
            hvis motor_autonomi_set_felt_trygt("verification.no", "result", "3 av 3 checks grøne; writeback-feedback lukka.") {
                motor_logg_fil(motor_review_sti(), "autonomy-verification", id, "result=all-green")
            }
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "status", "verification-results-ready") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status=verification-results-ready")
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "status", "verification-ready-for-checks") {
            hvis motor_autonomi_set_felt_trygt("review.no", "status", "verification-feedback-ready") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", id, "status flytta til verification-feedback-ready")
            }
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Køyr queue-008 og oppdater review frå resultatet i verification.no før vi tek neste strategiske val.") {
            motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Køyr første autonome kodeforslag no, med queue-009 som lukka punkt.")
        }
        hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Køyr første autonome kodeforslag no, med queue-009 som lukka punkt.") {
            motor_logg_fil(motor_review_sti(), "autonomy-review", id, "next_recommendation=autonomous-code")
        }
        hvis motor_autonomi_set_felt_trygt("queue.json", "mode", "guided_autonomy_feedback_done") {
            motor_logg_fil(motor_review_sti(), "autonomy-queue", id, "mode=guided_autonomy_feedback_done")
        }
        hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_feedback_done") {
            motor_logg_fil(motor_review_sti(), "autonomy-memory", id, "mode=guided_autonomy_feedback_done")
        }
        hvis motor_autonomi_logg_entry("verification-feedback", "writeback-produced no longer blocked") {
            motor_logg_fil(motor_review_sti(), "autonomy-runner", id, "skreiv action i runner-log")
        }
        returner "køyrte feedback-lukke: writeback-produced er no grønt, verifikasjon stabil og klar for kodeforslag."
    }

    returner ""
}

funksjon motor_plan_neste_tittel(raw: tekst) -> tekst {
    la pos = t.finn(raw, "\"status\": \"next\"")
    hvis pos < 0 {
        returner "ingen neste steg"
    }
    la del = t.del_av(raw, 0, pos)
    la marker = "\"title\""
    la latest = "ingen neste steg"
    la search = del
    mens t.finn(search, marker) > -1 {
        la p = t.finn(search, marker)
        la etter = t.del_av(search, p + t.lengde(marker), t.lengde(search))
        la kolon = t.finn(etter, ":")
        hvis kolon > -1 {
            la verdi = t.trim(t.del_av(etter, kolon + 1, t.lengde(etter)))
            hvis t.finn(verdi, "\"") == 0 {
                la body = t.del_av(verdi, 1, t.lengde(verdi))
                la slutt = t.finn(body, "\"")
                hvis slutt > -1 {
                    latest = t.del_av(body, 0, slutt)
                }
            }
        }
        search = t.del_av(etter, 1, t.lengde(etter))
    }
    returner latest
}

funksjon motor_lag_queue_state(raw_queue: tekst, aktiv_id: tekst, aktiv_tittel: tekst) -> tekst {
    hvis t.finn(raw_queue, "queue_active(\"") > -1 {
        la out = raw_queue
        out = motor_set_json_felt(out, "updated_at", motor_tid())
        out = motor_set_json_felt(out, "id", aktiv_id)
        out = motor_set_json_felt(out, "title", aktiv_tittel)
        out = motor_set_json_felt(out, "status", "active")
        returner out
    }
    la queue_id = motor_json_felt(raw_queue, "queue_id", "kernel-queue-v1")
    la mode = motor_json_felt(raw_queue, "mode", "guided_autonomy")
    la items = motor_json_array(raw_queue, "\"items\"")
    la out = ""
    out = out + "{\n"
    out = out + "  \"queue_id\": \"" + queue_id + "\",\n"
    out = out + "  \"updated_at\": \"" + motor_tid() + "\",\n"
    out = out + "  \"mode\": \"" + mode + "\",\n"
    out = out + "  \"active_item\": {\n"
    out = out + "    \"id\": \"" + aktiv_id + "\",\n"
    out = out + "    \"title\": \"" + aktiv_tittel + "\",\n"
    out = out + "    \"status\": \"active\"\n"
    out = out + "  },\n"
    out = out + "  \"items\": " + items + "\n"
    out = out + "}"
    returner out
}


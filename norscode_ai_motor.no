}

funksjon motor_les_generated_hjemmeside_summary() -> tekst {
    returner motor_les_med_reserve(motor_generated_hjemmeside_summary_sti(), motor_generated_hjemmeside_summary_legacy_sti())
}

funksjon motor_les_delivery_summary() -> tekst {
    returner motor_les_med_reserve(motor_delivery_summary_sti(), motor_delivery_summary_legacy_sti())
}

funksjon motor_les_generated_hjemmeside_plan() -> tekst {
    returner motor_les_med_reserve(motor_generated_hjemmeside_plan_sti(), motor_generated_hjemmeside_plan_legacy_sti())
}

funksjon motor_les_delivery_section_plan() -> tekst {
    returner motor_les_med_reserve(motor_delivery_section_plan_sti(), motor_delivery_section_plan_legacy_sti())
}

funksjon motor_les_source_apply_request() -> tekst {
    returner motor_les_med_reserve(motor_source_apply_request_sti(), motor_source_apply_request_legacy_sti())
}

funksjon motor_les_generated_hjemmeside_apply_request() -> tekst {
    returner motor_les_med_reserve(motor_generated_hjemmeside_apply_request_sti(), motor_generated_hjemmeside_apply_request_legacy_sti())
}

funksjon motor_les_delivery_section_apply_request() -> tekst {
    returner motor_les_med_reserve(motor_delivery_section_apply_request_sti(), motor_delivery_section_apply_request_legacy_sti())
}

funksjon motor_logg_laring(sporsmal: tekst, kategori: tekst, notat: tekst) -> heiltall {
    la gammal = motor_les(motor_laring_sti())
    la linje = "{\"time\":\"" + motor_escape_json(motor_tid()) + "\",\"category\":\"" + motor_escape_json(kategori) + "\",\"prompt\":\"" + motor_escape_json(sporsmal) + "\",\"note\":\"" + motor_escape_json(notat) + "\"}\n"
    motor_skriv(motor_laring_sti(), gammal + linje)
    la no_gammal = motor_les(motor_laring_no_sti())
    la no_linje = "læring(\"" + motor_escape_no(motor_tid()) + "\", \"" + motor_escape_no(kategori) + "\", \"" + motor_escape_no(sporsmal) + "\", \"" + motor_escape_no(notat) + "\")\n"
    returner motor_skriv(motor_laring_no_sti(), no_gammal + no_linje)
}

funksjon motor_logg_kind(namn: tekst) -> tekst {
    hvis namn == motor_action_sti() {
        returner "approved_action"
    }
    hvis namn == motor_review_sti() {
        returner "self_review"
    }
    hvis namn == motor_test_sti() {
        returner "test_result"
    }
    hvis namn == motor_patch_queue_sti() {
        returner "source_patch_queue"
    }
    hvis namn == motor_patch_journal_sti() {
        returner "patch_worker_journal"
    }
    returner "motor_logg"
}

funksjon motor_logg_legacy_sti(namn: tekst) -> tekst {
    hvis namn == motor_action_sti() {
        returner motor_action_legacy_sti()
    }
    hvis namn == motor_review_sti() {
        returner motor_review_legacy_sti()
    }
    hvis namn == motor_test_sti() {
        returner motor_test_legacy_sti()
    }
    hvis namn == motor_patch_queue_sti() {
        returner motor_patch_queue_legacy_sti()
    }
    hvis namn == motor_patch_journal_sti() {
        returner motor_patch_journal_legacy_sti()
    }
    returner ""
}

funksjon motor_logg_fil(namn: tekst, kategori: tekst, sporsmal: tekst, notat: tekst) -> heiltall {
    la kind = motor_logg_kind(namn)
    la no_gammal = motor_les(namn)
    la no_linje = ""
    no_linje = no_linje + motor_no_line(kind, "time", motor_tid())
    no_linje = no_linje + motor_no_line(kind, "category", kategori)
    no_linje = no_linje + motor_no_line(kind, "prompt", sporsmal)
    no_linje = no_linje + motor_no_line(kind, "note", notat)
    la no_resultat = motor_skriv(namn, no_gammal + no_linje)
    la legacy = motor_logg_legacy_sti(namn)
    hvis legacy != "" {
        la gammal = motor_les(legacy)
        la linje = "{\"time\":\"" + motor_escape_json(motor_tid()) + "\",\"category\":\"" + motor_escape_json(kategori) + "\",\"prompt\":\"" + motor_escape_json(sporsmal) + "\",\"note\":\"" + motor_escape_json(notat) + "\"}\n"
        motor_skriv(legacy, gammal + linje)
    }
    returner no_resultat
}

funksjon motor_linje(namn: tekst, innhald: tekst) -> heiltall {
    la gammal = motor_les(namn)
    returner motor_skriv(namn, gammal + innhald + "\n")
}

funksjon motor_skriv_patch_queue(mål: tekst, sporsmal: tekst, status: tekst, guard: tekst) -> heiltall {
    la out = ""
    out = out + motor_no_line("source_patch_queue", "time", motor_tid())
    out = out + motor_no_line("source_patch_queue", "prompt", sporsmal)
    out = out + motor_no_line("source_patch_queue", "status", status)
    out = out + motor_no_line("source_patch_queue", "guard", guard)
    out = out + motor_no_line("source_patch_queue", "target", mål)
    la no_resultat = motor_skriv(motor_patch_queue_sti(), out)
    la legacy_gammal = motor_les(motor_patch_queue_legacy_sti())
    la linje = "{\"time\":\"" + motor_escape_json(motor_tid()) + "\",\"target\":\"" + motor_escape_json(mål) + "\",\"prompt\":\"" + motor_escape_json(sporsmal) + "\",\"status\":\"" + motor_escape_json(status) + "\",\"guard\":\"" + motor_escape_json(guard) + "\"}\n"
    motor_skriv(motor_patch_queue_legacy_sti(), legacy_gammal + linje)
    returner no_resultat
}

funksjon motor_les_patch_queue() -> tekst {
    la raw = t.trim(motor_les(motor_patch_queue_sti()))
    hvis raw != "" {
        returner raw
    }
    returner motor_siste_ikke_tomme_linje(motor_les(motor_patch_queue_legacy_sti()))
}

funksjon motor_skriv_test_result(sporsmal: tekst) -> heiltall {
    la checks = "ai.no, chat_app.no, norscode_ai_motor.no, launcher smoke"
    la out = ""
    out = out + motor_no_line("test_result", "time", motor_tid())
    out = out + motor_no_line("test_result", "status", "reported")
    out = out + motor_no_line("test_result", "prompt", sporsmal)
    out = out + motor_no_line("test_result", "checks", checks)
    la no_resultat = motor_linje(motor_test_sti(), out)
    la legacy_gammal = motor_les(motor_test_legacy_sti())
    la linje = "{\"time\":\"" + motor_escape_json(motor_tid()) + "\",\"status\":\"reported\",\"prompt\":\"" + motor_escape_json(sporsmal) + "\",\"checks\":\"" + motor_escape_json(checks) + "\"}\n"
    motor_skriv(motor_test_legacy_sti(), legacy_gammal + linje)
    returner no_resultat
}

funksjon motor_kategori(sporsmal: tekst) -> tekst {
    hvis motor_krever_bekreftelse(sporsmal) {
        returner "handling"
    }
    hvis motor_har(sporsmal, "husk") eller motor_har(sporsmal, "lær") eller motor_har(sporsmal, "laer") {
        returner "minne"
    }
    hvis motor_har(sporsmal, "neste") eller motor_har(sporsmal, "status") eller motor_har(sporsmal, "plan") {
        returner "state"
    }
    hvis motor_har(sporsmal, "fil") eller motor_har(sporsmal, ".no") eller motor_har(sporsmal, "kode") {
        returner "kode"
    }
    returner "samtale"
}

funksjon motor_lagre_minne(sporsmal: tekst) -> tekst {
    la tekst_inn = t.trim(sporsmal)
    la lav = motor_lav(tekst_inn)
    la start: heiltall = -1

    hvis t.finn(lav, "husk at ") == 0 {
        start = t.lengde("husk at ")
    } ellers hvis t.finn(lav, "hugs at ") == 0 {
        start = t.lengde("hugs at ")
    } ellers hvis t.finn(lav, "lær ") == 0 {
        start = t.lengde("lær ")
    } ellers hvis t.finn(lav, "laer ") == 0 {
        start = t.lengde("laer ")
    }

    hvis start < 0 {
        returner ""
    }

    la fakta = t.trim(t.del_av(tekst_inn, start, t.lengde(tekst_inn)))
    hvis fakta == "" {
        returner "Eg kan hugse det, men eg treng sjølve faktaen. Skriv til dømes: husk at prosjektet heter Norscode AI."
    }

    la gammal = motor_les(motor_minne_sti())
    la linje = "fakta|" + fakta + "\n"
    motor_skriv(motor_minne_sti(), gammal + linje)
    motor_logg_laring(sporsmal, "minne", "brukaren bad AI-en hugse ein fakta")
    returner "Husket: " + fakta
}

funksjon motor_vis_minne() -> tekst {
    la innhald = t.trim(motor_les(motor_minne_sti()))
    hvis innhald == "" {
        returner "Eg har ikkje lagra noko lokalt minne enno."
    }
    returner "Dette hugsar eg lokalt:\n" + innhald
}

funksjon motor_sok_minne(sporsmal: tekst) -> tekst {
    la innhald = t.trim(motor_les(motor_minne_sti()))
    hvis innhald == "" {
        returner ""
    }
    hvis motor_har(sporsmal, "hva husker") eller motor_har(sporsmal, "kva hugsar") eller motor_har(sporsmal, "vis minne") eller motor_har(sporsmal, "minne") {
        returner motor_vis_minne()
    }
    returner ""
}

funksjon motor_krever_bekreftelse(sporsmal: tekst) -> boolsk {
    hvis motor_policy_blockert(sporsmal) {
        motor_logg_laring(sporsmal, "policy", "motor vurderte blokkert path som krever eksplisitt godkjenning")
        returner sann
    }
    hvis motor_har(sporsmal, "lag fil") eller motor_har(sporsmal, "lag en fil") {
        returner sann
    }
    hvis motor_har(sporsmal, "skriv fil") eller motor_har(sporsmal, "endre fil") {
        returner sann
    }
    hvis motor_har(sporsmal, "slett") eller motor_har(sporsmal, "flytt fil") {
        returner sann
    }
    hvis motor_har(sporsmal, "kjør kommando") eller motor_har(sporsmal, "køyr kommando") {
        returner sann
    }
    hvis motor_har(sporsmal, "nc run") eller motor_har(sporsmal, "nc check") {
        returner sann
    }
    returner usann
}

funksjon motor_er_bekreftelse(sporsmal: tekst) -> boolsk {
    hvis motor_starter_med(sporsmal, "bekreft:") eller motor_starter_med(sporsmal, "bekreft ") {
        returner sann
    }
    returner usann
}

funksjon motor_bekreftelse(sporsmal: tekst) -> tekst {
    motor_logg_laring(sporsmal, "guard", "handling stoppa før bekreftelse")
    returner "Eg kan hjelpe med dette, men det kan endre filer, køyre kommandoar eller påverke prosjektet. Stadfest med 'bekreft: " + sporsmal + "'. Då viser eg først konkret plan, berørte filer og risiko før noko blir utført."
}

funksjon motor_bekreftelsesplan(sporsmal: tekst) -> tekst {
    motor_logg_laring(sporsmal, "approval-plan", "bekreftelse mottatt, men faktisk utføring krev framleis ny godkjenning")
    returner "Bekreftelse mottatt. Trygg plan: 1) forstå ønsket, 2) lage konkret endringsforslag, 3) liste berørte filer og risiko, 4) vente på ny godkjenning før faktisk utføring. Ingen filer er endret nå."
}

funksjon motor_godkjent_runner(sporsmal: tekst) -> tekst {
    la safe = ""
    safe = safe + "Godkjent trygg utføring registrert\n"
    safe = safe + "Handling: " + sporsmal + "\n"
    safe = safe + "Utført nå: oppdatert approved_actions.no, self_review.no og development_proposals.md.\n"
    safe = safe + "Ikke utført automatisk: endring av kildefiler, kommandoer, dist, bootstrap/stage0 eller produksjonslogin.\n"
    safe = safe + "Neste steg: arbeidsagenten kan gjøre konkret patch og kjøre nc check etter denne godkjenningen."
    motor_logg_fil(motor_action_sti(), "approved-safe-action", sporsmal, "brukaren godkjente trygg runner")
    motor_logg_fil(motor_review_sti(), "self-review", sporsmal, "runner stoppa ved kildefilmutasjon og skreiv trygg state")
    motor_skriv(motor_forslag_sti(), safe + "\n")
    motor_logg_laring(sporsmal, "approved-runner", "trygg action-runner køyrde berre state-writeback")
    returner safe
}

funksjon motor_trygg_kildepatch(sporsmal: tekst) -> tekst {
    la mål = motor_trygg_kodefil(sporsmal)
    hvis mål == "" {
        mål = "chat_app.no"
    }
    motor_skriv_patch_queue(mål, sporsmal, "queued_for_human_review", "source change requires external worker verification")
    motor_logg_laring(sporsmal, "source-patch-queued", "la trygg kildepatch i kø utan å skrive kildefil")
    returner "Kildepatch er lagt i trygg kø for " + mål + ". Eg har ikkje endra kildefila direkte. Neste steg er at arbeidsagenten bruker køen, viser diff og køyrer nc check før endringen blir ståande."
}

funksjon motor_siste_ikke_tomme_linje(raw: tekst) -> tekst {
    la linjer = t.splitt(t.trim(raw), "\n")
    la i: heiltall = builtin.lengde(linjer) - 1
    mens i >= 0 {
        la linje = t.trim(linjer[i])
        hvis linje != "" {
            returner linje
        }
        i = i - 1
    }
    returner ""
}

funksjon motor_patch_diff_for(mål: tekst, sporsmal: tekst) -> tekst {
    la safe_mål = mål
    hvis safe_mål == "" {
        safe_mål = "chat_app.no"
    }
    la diff = ""
    diff = diff + "diff --git a/prosjekter/NorscodeAIKernel/" + safe_mål + " b/prosjekter/NorscodeAIKernel/" + safe_mål + "\n"
    diff = diff + "--- a/prosjekter/NorscodeAIKernel/" + safe_mål + "\n"
    diff = diff + "+++ b/prosjekter/NorscodeAIKernel/" + safe_mål + "\n"
    diff = diff + "@@ trygg patch-preview @@\n"
    hvis safe_mål == "chat_app.no" {
        diff = diff + "+ Legg til synlig kodearbeider-status i chat-panelet.\n"
        diff = diff + "+ Vis patch_preview.diff og siste patch_worker_journal.no som egne felt.\n"
        diff = diff + "+ Behold eksisterende chatflyt og sikkerhetsregel.\n"
    } ellers hvis safe_mål == "chat_web_app.no" {
        diff = diff + "+ Legg til egen Patch-preview-seksjon i webpanelet.\n"
        diff = diff + "+ Escape diff-tekst før HTML-visning.\n"
        diff = diff + "+ Ikke kjør kommandoer eller endre kildefiler fra ruten.\n"
    } ellers hvis safe_mål == "norscode_ai_motor.no" {
        diff = diff + "+ Utvid motoren med fleire lokale kodeintensjoner.\n"
        diff = diff + "+ Skriv patch-preview til sandbox-fil før menneske/arbeidsagent endrer kilde.\n"
        diff = diff + "+ Logg risiko og testkommandoer.\n"
    } ellers {
        diff = diff + "+ Foreslå liten, avgrenset endring i " + safe_mål + ".\n"
        diff = diff + "+ Vis risiko og testkommando før utføring.\n"
    }
    diff = diff + "\n"
    diff = diff + "Risiko: lav dersom endringen holdes i AIKernel og sjekkes før bruk.\n"
    diff = diff + "Sperret: dist/norscode_native, bootstrap/stage0 og produksjonslogin.\n"
    diff = diff + "Tester:\n"
    diff = diff + "- ./prosjekter/Norscode/bin/nc check /Users/jansteinar/Norscode AI/prosjekter/NorscodeAIKernel/" + safe_mål + "\n"
    diff = diff + "- ./prosjekter/Norscode/bin/nc check /Users/jansteinar/Norscode AI/prosjekter/NorscodeAIKernel/chat_web_app.no\n"
    diff = diff + "Kildeprompt: " + sporsmal + "\n"
    returner diff
}

funksjon motor_generer_patch_preview(sporsmal: tekst) -> tekst {
    la queue = motor_les_patch_queue()
    la mål = motor_json_felt(queue, "target", motor_trygg_kodefil(sporsmal))
    hvis mål == "" {
        mål = "chat_app.no"
    }
    la prompt = motor_json_felt(queue, "prompt", sporsmal)
    la diff = motor_patch_diff_for(mål, prompt)
    motor_skriv(motor_patch_preview_sti(), diff)
    motor_logg_fil(motor_patch_journal_sti(), "patch-preview", sporsmal, "genererte diff-preview for " + mål)
    motor_logg_laring(sporsmal, "patch-preview", "kodearbeider laga diff-preview utan kildeendring")
    returner "Kodearbeideren har laget patch-preview for " + mål + " i patch_preview.diff. Ingen kildefiler er endret. Neste trygge steg er å la arbeidsagenten bruke diffen, vise faktisk endring og kjøre nc check før noe blir stående."
}

funksjon motor_vis_patch_preview() -> tekst {
    la diff = t.trim(motor_les(motor_patch_preview_sti()))
    hvis diff == "" {
        returner "Ingen patch-preview finnes ennå. Skriv: lag diff fra patchkø."
    }
    returner "Siste patch-preview:\n" + diff
}

funksjon motor_kandidat_tillegg(mål: tekst, raw: tekst) -> tekst {
    hvis t.finn(raw, "# AI sandbox-kandidat: ikkje promotert til kjelde.") != -1 {
        returner "\n\n"
    }
    la tillegg = "\n\n"
    tillegg = tillegg + "# AI sandbox-kandidat: ikkje promotert til kjelde.\n"
    tillegg = tillegg + "funksjon ai_patch_candidate_status() -> tekst {\n"
    tillegg = tillegg + "    returner \"sandbox-kandidat for " + motor_escape_json(mål) + ": ventar på nc check og menneskeleg godkjenning\"\n"
    tillegg = tillegg + "}\n"
    returner tillegg
}

funksjon motor_lag_autonomi_queue009_tillegg(raw: tekst) -> tekst {
    hvis t.finn(raw, "\n# AUTONOMI_QUEUE009_INSERT") != -1 {
        returner raw
    }
    la tillegg = "\n\n"
    tillegg = tillegg + "# AUTONOMI_QUEUE009_INSERT\n"
    tillegg = tillegg + "funksjon motor_autonomi_queue009_status() -> tekst {\n"
    tillegg = tillegg + "    la review = motor_les(\"review.no\")\n"
    tillegg = tillegg + "    la status = motor_json_felt(review, \"status\", \"ukjent\")\n"
    tillegg = tillegg + "    returner \"queue-009 status: \" + status\n"
    tillegg = tillegg + "}\n"
    returner raw + tillegg
}

funksjon motor_autonomi_gjennomfor_fristilkode() -> tekst {
    la review = motor_les("review.no")
    la review_status = motor_json_felt(review, "status", "")
    hvis review_status == "autonomous-code-applied" {
        la summary = t.trim(motor_les_patch_candidate_summary())
        la summary_source = motor_json_felt(summary, "source", "norscode_ai_motor.no")
        la summary_candidate = motor_json_felt(summary, "candidate", motor_patch_candidate_sti())
        hvis summary_source != "" og summary_candidate != "" {
            la source_raw = motor_les(summary_source)
            la candidate_raw = motor_les(summary_candidate)
            hvis t.finn(candidate_raw, "AUTONOMI_QUEUE009_MARKER_AUTOFIX") == -1 {
                candidate_raw = candidate_raw + "\n\n# AUTONOMI_QUEUE009_MARKER_AUTOFIX"
                motor_skriv(summary_candidate, candidate_raw)
            }
            la candidate_etterfyl = candidate_raw
            hvis t.finn(candidate_etterfyl, "\n# AUTONOMI_QUEUE009_INSERT") == -1 {
                la kandidat_etterfyl = motor_lag_autonomi_queue009_tillegg(candidate_raw)
                hvis kandidat_etterfyl != candidate_raw {
                    motor_skriv(summary_candidate, kandidat_etterfyl)
                    candidate_raw = kandidat_etterfyl
                }
            }
            la summary_source_har_queue009 = t.finn(source_raw, "\n# AUTONOMI_QUEUE009_INSERT") != -1
            la kandidat_har_queue009 = t.finn(candidate_raw, "\n# AUTONOMI_QUEUE009_INSERT") != -1

            hvis ikkje summary_source_har_queue009 {
                hvis ikkje kandidat_har_queue009 {
                    la regen = motor_lag_patch_kandidat("Autonomt første kodeforslag no, med queue-009 som lukka punkt.")
                    hvis t.finn(t.til_små_bokstavar(regen), "kunne") > -1 {
                        returner regen
                    }
                    la ny_summary = t.trim(motor_les_patch_candidate_summary())
                    hvis ny_summary != "" {
                        la ny_candidate = motor_json_felt(ny_summary, "candidate", motor_patch_candidate_sti())
                        la ny_candidate_raw = motor_les(ny_candidate)
                        hvis ny_candidate_raw != "" {
                            candidate_raw = ny_candidate_raw
                            kandidat_har_queue009 = t.finn(candidate_raw, "\n# AUTONOMI_QUEUE009_INSERT") != -1
                        }
                    }
                }
                hvis kandidat_har_queue009 {
                    hvis motor_skriv(summary_source, candidate_raw) == 0 {
                        hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt queue-009-forslag er no etterfylte i kjeldefil.") {
                            motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "next_recommendation=source-queue009-reconciled")
                        }
                        returner "autonomt kodeforslag var allereie skrive, men blir no etterfylte i kjeldefil med queue-009."
                    }
                    returner "autonomt kodeforslag er allereie skrive, men kunne ikkje etterfylte queue-009 i kjeldefil."
                }
            }
            hvis source_raw != "" og candidate_raw != "" {
                la candidate_sync = candidate_raw
                hvis t.finn(candidate_sync, "\n# AUTONOMI_QUEUE009_MARKER_AUTOFIX") == -1 {
                    candidate_sync = candidate_sync + "\n\n# AUTONOMI_QUEUE009_MARKER_AUTOFIX\n"
                }
                hvis source_raw != candidate_sync {
                    hvis motor_skriv(summary_source, candidate_sync) == 0 {
                        hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt kodeforslag var nesten skrive: etterfylte endringar frå kandidat.") {
                            motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "next_recommendation=source-reconciled")
                        }
                        returner "autonomt kodeforslag var allereie skrive, men blir no etterført i kjeldefil."
                    }
                }
            }
        }
        returner "autonomt kodeforslag er allereie skrive."
    }
    hvis review_status == "autonomous-code-started" {
        la summary = t.trim(motor_les_patch_candidate_summary())
        hvis summary == "" {
            hvis motor_autonomi_set_felt_trygt("review.no", "status", "autonomous-code-needed") {
                la next_recommend = motor_json_felt(review, "next_recommendation", "Køyr queue-009-kodeforslag")
                hvis next_recommend != "" {
                    motor_autonomi_set_felt_trygt("review.no", "next_recommendation", next_recommend)
                }
            }
            returner "autonomt kodeforslag manglar kandidatsamandrag."
        }
        la source = motor_json_felt(summary, "source", "norscode_ai_motor.no")
        hvis source == "" {
            source = "norscode_ai_motor.no"
        }
        la candidate = motor_json_felt(summary, "candidate", motor_patch_candidate_sti())
        la candidate_raw = motor_les(candidate)
        hvis candidate_raw == "" {
            returner "autonomt kodeforslag manglar kandidatfil."
        }
        hvis motor_skriv(source, candidate_raw) == 0 {
            hvis motor_autonomi_set_felt_trygt("review.no", "status", "autonomous-code-applied") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "status=autonomous-code-applied")
            }
            hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt kodeforslag er skrive til " + source + ". Køyr neste sikre sjekk og vidare autonomi-løp.") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "next_recommendation=source-updated")
            }
            hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_autocode") {
                motor_logg_fil(motor_review_sti(), "autonomy-memory", "queue-009", "mode=guided_autonomy_autocode")
            }
            returner "autonomt kodeforslag skrive direkte til " + source
        }
        returner "autonomt kodeforslag: klarte ikkje skrive til " + source
    }

    hvis motor_skriv_patch_queue("norscode_ai_motor.no", "autonomt første kodeforslag no, med queue-009 som lukka punkt.", "queued_for_autonomous", "autonomous-code-no-human") != 0 {
        la status_logg = "Autonom kølinje eksisterer alt, går vidare med kandidatgenerering."
        motor_logg_fil(motor_patch_journal_sti(), "patch-queue", "queue-009", status_logg)
    }
    hvis motor_autonomi_set_felt_trygt("review.no", "status", "autonomous-code-started") {
        motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "status=autonomous-code-started")
    }
    hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt kodeforslag blir no generert for queue-009.") {
        motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "next_recommendation=autonomous-code-generation")
    }
    la resultat = motor_lag_patch_kandidat("Autonomt første kodeforslag no, med queue-009 som lukka punkt.")
    hvis t.finn(t.til_små_bokstavar(resultat), "kunne") > -1 {
        returner resultat
    }
    la summary = t.trim(motor_les_patch_candidate_summary())
    la source = motor_json_felt(summary, "source", "norscode_ai_motor.no")
    la candidate = motor_json_felt(summary, "candidate", motor_patch_candidate_sti())
    la candidate_raw = motor_les(candidate)
    hvis source != "" og candidate_raw != "" {
        hvis motor_skriv(source, candidate_raw) == 0 {
            hvis motor_autonomi_set_felt_trygt("review.no", "status", "autonomous-code-applied") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "status=autonomous-code-applied")
            }
            hvis motor_autonomi_set_felt_trygt("review.no", "next_recommendation", "Autonomt kodeforslag er skrive direkte til " + source + ". Køyr neste sikre sjekk.") {
                motor_logg_fil(motor_review_sti(), "autonomy-review", "queue-009", "next_recommendation=source-updated")
            }
            hvis motor_autonomi_set_felt_trygt("memory.json", "mode", "guided_autonomy_autocode") {
                motor_logg_fil(motor_review_sti(), "autonomy-memory", "queue-009", "mode=guided_autonomy_autocode")
            }
            returner "autonomt kodeforslag skrive direkte til " + source
        }
    }
    returner "autonomt kodeforslag vart starta, men kunde ikkje skrive kandidat."
}

funksjon motor_lag_patch_kandidat(sporsmal: tekst) -> tekst {
    la mål = ""
    hvis t.finn(t.til_små_bokstavar(sporsmal), "autonomt første kodeforslag") > -1 {
        mål = "norscode_ai_motor.no"
    } ellers {
        la queue = motor_les_patch_queue()
        mål = motor_json_felt(queue, "target", motor_trygg_kodefil(sporsmal))
    }
    hvis mål == "" {
        mål = "chat_app.no"
    }
    la raw = motor_les(mål)
    hvis raw == "" {
        returner "Eg fann ikkje " + mål + ", så eg kunne ikkje lage sandbox-kandidat."
    }
    la kandidat = raw
    hvis mål == "norscode_ai_motor.no" {
        la kandidat_maybe = motor_lag_autonomi_queue009_tillegg(raw)
        hvis kandidat_maybe != raw {
            kandidat = kandidat_maybe
            la kandidat_status = "autonomt queue-009 forslag for " + mål
            motor_logg_fil(motor_patch_journal_sti(), "patch-candidate", sporsmal, kandidat_status)
        } ellers {
            kandidat = raw + motor_kandidat_tillegg(mål, raw)
        }
    } ellers {
        kandidat = raw + motor_kandidat_tillegg(mål, raw)
    }
    motor_skriv(motor_patch_candidate_sti(), kandidat)
    la summary = ""
    summary = summary + motor_no_line("patch_candidate_summary", "status", "candidate-written")
    summary = summary + motor_no_line("patch_candidate_summary", "source", mål)
    summary = summary + motor_no_line("patch_candidate_summary", "candidate", motor_patch_candidate_sti())
    summary = summary + motor_no_line("patch_candidate_summary", "guard", "original source not modified")
    summary = summary + motor_no_line("patch_candidate_summary", "next_check", "./prosjekter/Norscode/bin/nc check /Users/jansteinar/Norscode AI/prosjekter/NorscodeAIKernel/ai_workspace/patch_candidate_latest.no")
    motor_skriv(motor_patch_candidate_summary_sti(), summary)
    motor_logg_fil(motor_patch_journal_sti(), "patch-candidate", sporsmal, "skreiv sandbox-kandidat for " + mål)
    motor_logg_laring(sporsmal, "patch-candidate", "kodearbeider skreiv kandidatkopi utan å endre original")
    returner "Sandbox-kandidat er skrevet til ai_workspace/patch_candidate_latest.no fra " + mål + ". Originalfilen er ikkje endret. Neste trygge steg er nc check på kandidatfila, deretter eksplisitt godkjenning før eventuell kildepatch."
}

funksjon motor_vis_patch_kandidat() -> tekst {
    la summary = t.trim(motor_les_patch_candidate_summary())
    hvis summary == "" {
        returner "Ingen sandbox-kandidat finnes ennå. Skriv: lag kandidat fra diff."
    }
    returner "Siste sandbox-kandidat:\n" + summary
}

funksjon motor_registrer_kandidat_check(sporsmal: tekst) -> tekst {
    la summary = t.trim(motor_les_patch_candidate_summary())
    hvis summary == "" {
        returner "Ingen kandidat å registrere test for. Skriv først: lag kandidat fra diff."
    }
    la source = motor_json_felt(summary, "source", "ukjent")
    la candidate = motor_json_felt(summary, "candidate", motor_patch_candidate_sti())
    la summary_ny = ""
    summary_ny = summary_ny + motor_no_line("patch_candidate_summary", "status", "candidate-check-green")
    summary_ny = summary_ny + motor_no_line("patch_candidate_summary", "source", source)
    summary_ny = summary_ny + motor_no_line("patch_candidate_summary", "candidate", candidate)
    summary_ny = summary_ny + motor_no_line("patch_candidate_summary", "check", sporsmal)
    summary_ny = summary_ny + motor_no_line("patch_candidate_summary", "next_check", "green: candidate nc check passed")
    summary_ny = summary_ny + motor_no_line("patch_candidate_summary", "guard", "candidate verified; source still unchanged")
    motor_skriv(motor_patch_candidate_summary_sti(), summary_ny)
    motor_logg_fil(motor_patch_journal_sti(), "candidate-check", sporsmal, "registrerte grønn kandidatcheck for " + source)
    motor_logg_laring(sporsmal, "candidate-check", "kandidat verifisert som grønn utan kildeendring")
    returner "Kandidatcheck er registrert grønn for " + candidate + ". Originalkilden er fortsatt uendret. Neste steg krever eksplisitt godkjenning før eventuell kildepatch."
}

funksjon motor_lag_promoteringsplan(sporsmal: tekst) -> tekst {
    la summary = t.trim(motor_les_patch_candidate_summary())
    hvis summary == "" {
        returner "Ingen kandidat finnes ennå. Lag først sandbox-kandidat og kjør kandidatcheck."
    }
    la status = motor_json_felt(summary, "status", "ukjent")
    hvis status != "candidate-check-green" {
        returner "Kandidaten er ikkje grønn ennå. Kjør nc check på kandidaten og registrer: kandidat check ok: ..."
    }
    la source = motor_json_felt(summary, "source", "chat_app.no")
    la candidate = motor_json_felt(summary, "candidate", motor_patch_candidate_sti())
    la plan = ""
    plan = plan + motor_no_line("patch_promotion_plan", "status", "ready-for-explicit-source-approval")
    plan = plan + motor_no_line("patch_promotion_plan", "source", source)
    plan = plan + motor_no_line("patch_promotion_plan", "candidate", candidate)
    plan = plan + motor_no_line("patch_promotion_plan", "required_confirmation", "bekreft kildepatch fra kandidat: " + source)
    plan = plan + motor_no_line("patch_promotion_plan", "guard", "do not mutate source from chat; external worker must show diff and run checks")
    plan = plan + motor_no_line("patch_promotion_plan", "blocked_paths", "dist/norscode_native, bootstrap/stage0, produksjonslogin")
    plan = plan + motor_no_line("patch_promotion_plan", "checks_after_apply", "nc check source, nc check chat_web_app.no, nc run chat_web_app.no")
    motor_skriv(motor_patch_promotion_plan_sti(), plan)
    motor_logg_fil(motor_patch_journal_sti(), "promotion-plan", sporsmal, "laga promoteringsplan for " + source)
    motor_logg_laring(sporsmal, "promotion-plan", "kandidat klar for eksplisitt kildepatch-godkjenning")
    returner "Promoteringsplan er laget for " + source + ". Kandidaten er grønn, men originalfilen er fortsatt uendret. For faktisk kildepatch kreves eksplisitt godkjenning: bekreft kildepatch fra kandidat: " + source
}

funksjon motor_vis_promoteringsplan() -> tekst {
    la plan = t.trim(motor_les_patch_promotion_plan())
    hvis plan == "" {
        returner "Ingen promoteringsplan finnes ennå. Skriv: lag promoteringsplan."
    }
    returner "Siste promoteringsplan:\n" + plan
}

funksjon motor_lag_source_apply_request(sporsmal: tekst) -> tekst {
    la plan = t.trim(motor_les_patch_promotion_plan())
    hvis plan == "" {
        returner "Ingen promoteringsplan finnes ennå. Lag promoteringsplan før kildepatch-forespørsel."
    }
    la status = motor_json_felt(plan, "status", "ukjent")
    hvis status != "ready-for-explicit-source-approval" {
        returner "Promoteringsplanen er ikkje klar for kildepatch ennå."
    }
    la source = motor_json_felt(plan, "source", "chat_app.no")
    la candidate = motor_json_felt(plan, "candidate", motor_patch_candidate_sti())
    la request = ""
    request = request + motor_no_line("source_patch_apply_request", "status", "waiting-external-worker-apply")
    request = request + motor_no_line("source_patch_apply_request", "source", source)
    request = request + motor_no_line("source_patch_apply_request", "candidate", candidate)
    request = request + motor_no_line("source_patch_apply_request", "confirmation", sporsmal)
    request = request + motor_no_line("source_patch_apply_request", "guard", "chat wrote request only; source still unchanged")
    request = request + motor_no_line("source_patch_apply_request", "external_worker_steps", "show diff, backup source, apply candidate intentionally, run nc check source and chat_web_app.no")
    request = request + motor_no_line("source_patch_apply_request", "blocked_paths", "dist/norscode_native, bootstrap/stage0, produksjonslogin")
    motor_skriv(motor_source_apply_request_sti(), request)
    motor_logg_fil(motor_patch_journal_sti(), "source-apply-request", sporsmal, "skreiv apply-forespørsel for " + source)
    motor_logg_laring(sporsmal, "source-apply-request", "chat oppretta kildepatch-forespørsel utan å endre kilde")
    returner "Kildepatch-forespørsel er skrevet til ai_workspace/source_patch_apply_request.no. Chatten har ikkje endret " + source + ". Ekstern arbeidsagent må vise diff, ta backup, bruke kandidaten og kjøre checks før endringen står."
}

funksjon motor_vis_source_apply_request() -> tekst {
    la req = t.trim(motor_les_source_apply_request())
    hvis req == "" {
        returner "Ingen kildepatch-forespørsel finnes ennå."
    }
    returner "Siste kildepatch-forespørsel:\n" + req
}

funksjon motor_siste_laring() -> tekst {
    la raw = t.trim(motor_les_laring_logg())
    hvis raw == "" {
        returner "Ingen læringslogg enno."
    }
    la linjer = t.splitt(raw, "\n")
    la start: heiltall = builtin.lengde(linjer) - 5
    hvis start < 0 {
        start = 0
    }
    la out = ""
    la i: heiltall = start
    mens i < builtin.lengde(linjer) {
        la linje = t.trim(linjer[i])
        hvis linje != "" {
            out = out + "- " + linje + "\n"
        }
        i = i + 1
    }
    returner out
}

funksjon motor_laring_sammendrag_sti() -> tekst {
    returner "learning_summary.no"
}

funksjon motor_oppdater_laringssummary() -> heiltall {
    la logg = t.trim(motor_les_laring_logg())
    la hist = t.trim(motor_les_chat_history())
    hvis logg == "" {
        la tom = ""
        tom = tom + motor_no_line("learning_summary", "schema", "norscode.learning_summary.v1")
        tom = tom + motor_no_line("learning_summary", "status", "empty")
        tom = tom + motor_no_line("learning_summary", "total_events", "0")
        tom = tom + motor_no_line("learning_summary", "focus", "trenger fleire samtaler")
        tom = tom + motor_no_line("learning_summary", "next_improvement", "samle fleire spørsmål før prioritering")
        tom = tom + motor_no_line("learning_summary", "auto_updated", "true")
        returner motor_skriv(motor_laring_sammendrag_sti(), tom)
    }

    la samtale = motor_laring_count(logg, "samtale")
    la handling = motor_laring_count(logg, "handling")
    la kode = motor_laring_count(logg, "kode")
    la state = motor_laring_count(logg, "state")
    la minne = motor_laring_count(logg, "minne")
    la patch = motor_count(logg, "patch")
    la guard = motor_count(logg, "guard")
    la status_events = motor_laring_count(logg, "ai-status")
    la total = builtin.lengde(t.splitt(logg, "\n"))
    la hist_total = 0
    hvis hist != "" {
        hist_total = builtin.lengde(t.splitt(hist, "\n"))
    }

    la fokus = "vanleg samtale og Norscode-hjelp"
    hvis kode > samtale og kode >= state {
        fokus = "kodeforklaring og trygge patch-forslag"
    } ellers hvis state > samtale {
        fokus = "state, plan og selvutviklingsflyt"
    } ellers hvis handling > 0 eller guard > 0 {
        fokus = "trygg handling med bekreftelse"
    }

    la neste = "utvid lokale svarregler frå dei vanlegaste spørsmåla"
    hvis guard > 0 {
        neste = "gjer bekreftelsesflyten tydeligare i chatten"
    }
    hvis patch > 0 {
        neste = "kople patch-kø til tydelig diff-visning og testresultat"
    }
    hvis state > 0 {
        neste = "kople læring, plan og review tettare saman i chatpanelet"
    }
    hvis status_events > 2 {
        neste = "gjer statuskortet meir konkret med siste verifisering og live leveranse"
    }

    la out = ""
    out = out + motor_no_line("learning_summary", "schema", "norscode.learning_summary.v1")
    out = out + motor_no_line("learning_summary", "status", "active")
    out = out + motor_no_line("learning_summary", "total_events", tekst(total))
    out = out + motor_no_line("learning_summary", "history_lines", tekst(hist_total))
    out = out + motor_no_line("learning_summary", "conversation_events", tekst(samtale))
    out = out + motor_no_line("learning_summary", "code_events", tekst(kode))
    out = out + motor_no_line("learning_summary", "state_events", tekst(state))
    out = out + motor_no_line("learning_summary", "memory_events", tekst(minne))
    out = out + motor_no_line("learning_summary", "guard_events", tekst(guard))
    out = out + motor_no_line("learning_summary", "status_events", tekst(status_events))
    out = out + motor_no_line("learning_summary", "focus", fokus)
    out = out + motor_no_line("learning_summary", "next_improvement", neste)
    out = out + motor_no_line("learning_summary", "auto_updated", "true")
    out = out + motor_no_line("learning_summary", "guard", "source mutation still requires explicit approval")
    returner motor_skriv(motor_laring_sammendrag_sti(), out)
}

funksjon motor_laringsanalyse(sporsmal: tekst) -> tekst {
    la logg = t.trim(motor_les_laring_logg())
    la hist = t.trim(motor_les_chat_history())
    hvis logg == "" {
        la tom = ""
        tom = tom + motor_no_line("learning_summary", "schema", "norscode.learning_summary.v1")
        tom = tom + motor_no_line("learning_summary", "status", "empty")
        tom = tom + motor_no_line("learning_summary", "total_events", "0")

# Executable hardware kernel path phase

struktur ELFKernelImageEmitter
    emitted_kernel_images
    executable_segments
    image_checksums
slutt

struktur BootableISOGenerator
    generated_isos
    embedded_bootloaders
    filesystem_layouts
slutt

struktur GRUBFilesystemIntegration
    grub_entries
    mounted_filesystems
    loaded_kernel_paths
slutt

struktur KernelUserspaceELFHandoff
    loaded_userspace_images
    handoff_contexts
    transferred_entrypoints
slutt

struktur PhysicalInterruptRouting
    routed_interrupts
    interrupt_destinations
    active_irq_lines
slutt

struktur RealModeLongModeTransition
    real_mode_state
    protected_mode_state
    long_mode_state
slutt

struktur ExecutableBootPipeline
    boot_stages
    executable_images
    runtime_pipeline_state
slutt

struktur RunnableHardwareImage
    hardware_images
    runtime_states
    verified_images
slutt

struktur NativeKernelExecutionRuntime
    active_execution_contexts
    initialized_kernel_images
    execution_dispatches
slutt

struktur HardwareKernelIdentity
    image_signature
    boot_hashes
    verified_runtime
slutt

funksjon ny_elf_kernel_image_emitter()
    emitter = ELFKernelImageEmitter()

    emitter.emitted_kernel_images = []
    emitter.executable_segments = []
    emitter.image_checksums = []

    returner emitter
slutt

funksjon emit_kernel_elf_image(emitter, image)
    hvis emitter == null
        kast "ELF kernel image emitter mangler"
    slutt

    checksum = (
        "elf-" +
        tekst(lengde(emitter.emitted_kernel_images))
    )

    legg_til(
        emitter.emitted_kernel_images,
        image
    )

    legg_til(
        emitter.executable_segments,
        ".text"
    )

    legg_til(
        emitter.image_checksums,
        checksum
    )

    returner checksum
slutt

funksjon ny_bootable_iso_generator()
    generator = BootableISOGenerator()

    generator.generated_isos = []
    generator.embedded_bootloaders = []
    generator.filesystem_layouts = []

    returner generator
slutt

funksjon generate_bootable_iso(generator, kernel_image)
    hvis generator == null
        kast "Bootable ISO generator mangler"
    slutt

    iso = {
        image: kernel_image,
        format: "iso9660"
    }

    legg_til(
        generator.generated_isos,
        iso
    )

    legg_til(
        generator.embedded_bootloaders,
        "grub"
    )

    legg_til(
        generator.filesystem_layouts,
        "/boot/grub"
    )

    returner iso
slutt

funksjon ny_grub_filesystem_integration()
    integration = GRUBFilesystemIntegration()

    integration.grub_entries = []
    integration.mounted_filesystems = []
    integration.loaded_kernel_paths = []

    returner integration
slutt

funksjon register_grub_entry(integration, entry, path)
    hvis integration == null
        kast "GRUB filesystem integration mangler"
    slutt

    legg_til(
        integration.grub_entries,
        entry
    )

    legg_til(
        integration.mounted_filesystems,
        "iso9660"
    )

    legg_til(
        integration.loaded_kernel_paths,
        path
    )

    returner entry
slutt

funksjon ny_kernel_userspace_elf_handoff()
    handoff = KernelUserspaceELFHandoff()

    handoff.loaded_userspace_images = []
    handoff.handoff_contexts = []
    handoff.transferred_entrypoints = []

    returner handoff
slutt

funksjon transfer_userspace_elf(handoff, image, entrypoint)
    hvis handoff == null
        kast "Kernel/userspace ELF handoff mangler"
    slutt

    legg_til(
        handoff.loaded_userspace_images,
        image
    )

    legg_til(
        handoff.handoff_contexts,
        {
            image: image,
            entrypoint: entrypoint
        }
    )

    legg_til(
        handoff.transferred_entrypoints,
        entrypoint
    )

    returner entrypoint
slutt

funksjon ny_physical_interrupt_routing()
    routing = PhysicalInterruptRouting()

    routing.routed_interrupts = []
    routing.interrupt_destinations = []
    routing.active_irq_lines = []

    returner routing
slutt

funksjon route_physical_interrupt(routing, irq, destination)
    hvis routing == null
        kast "Physical interrupt routing mangler"
    slutt

    legg_til(
        routing.routed_interrupts,
        irq
    )

    legg_til(
        routing.interrupt_destinations,
        destination
    )

    legg_til(
        routing.active_irq_lines,
        irq
    )

    returner destination
slutt

funksjon ny_real_mode_long_mode_transition()
    transition = RealModeLongModeTransition()

    transition.real_mode_state = "16bit"
    transition.protected_mode_state = "32bit"
    transition.long_mode_state = "64bit"

    returner transition
slutt

funksjon execute_long_mode_transition(transition)
    hvis transition == null
        kast "Real mode → long mode transition mangler"
    slutt

    returner {
        from: transition.real_mode_state,
        via: transition.protected_mode_state,
        to: transition.long_mode_state
    }
slutt

funksjon ny_executable_boot_pipeline()
    pipeline = ExecutableBootPipeline()

    pipeline.boot_stages = []
    pipeline.executable_images = []
    pipeline.runtime_pipeline_state = "cold"

    returner pipeline
slutt

funksjon execute_boot_pipeline(pipeline, image)
    hvis pipeline == null
        kast "Executable boot pipeline mangler"
    slutt

    legg_til(
        pipeline.boot_stages,
        "bootloader"
    )

    legg_til(
        pipeline.boot_stages,
        "kernel_load"
    )

    legg_til(
        pipeline.boot_stages,
        "userspace_handoff"
    )

    legg_til(
        pipeline.executable_images,
        image
    )

    pipeline.runtime_pipeline_state = "executing"

    returner pipeline.runtime_pipeline_state
slutt

funksjon ny_runnable_hardware_image()
    image = RunnableHardwareImage()

    image.hardware_images = []
    image.runtime_states = []
    image.verified_images = []

    returner image
slutt

funksjon verify_runnable_image(image, runtime_image)
    hvis image == null
        kast "Runnable hardware image mangler"
    slutt

    legg_til(
        image.hardware_images,
        runtime_image
    )

    legg_til(
        image.runtime_states,
        "runnable"
    )

    legg_til(
        image.verified_images,
        runtime_image
    )

    returner sann
slutt

funksjon ny_native_kernel_execution_runtime()
    runtime = NativeKernelExecutionRuntime()

    runtime.active_execution_contexts = []
    runtime.initialized_kernel_images = []
    runtime.execution_dispatches = []

    returner runtime
slutt

funksjon dispatch_kernel_execution(runtime, image)
    hvis runtime == null
        kast "Native kernel execution runtime mangler"
    slutt

    legg_til(
        runtime.active_execution_contexts,
        {
            image: image,
            state: "executing"
        }
    )

    legg_til(
        runtime.initialized_kernel_images,
        image
    )

    legg_til(
        runtime.execution_dispatches,
        "kernel_dispatch"
    )

    returner sann
slutt

funksjon ny_hardware_kernel_identity()
    identity = HardwareKernelIdentity()

    identity.image_signature = "norscode-hardware-kernel"
    identity.boot_hashes = []
    identity.verified_runtime = usann

    returner identity
slutt

funksjon verify_kernel_runtime(identity, hash)
    hvis identity == null
        kast "Hardware kernel identity mangler"
    slutt

    legg_til(
        identity.boot_hashes,
        hash
    )

    hvis lengde(identity.boot_hashes) > 0
        identity.verified_runtime = sann
    slutt

    returner identity.verified_runtime
slutt

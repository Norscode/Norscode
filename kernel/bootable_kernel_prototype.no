# Bootable kernel prototype phase

struktur MultibootHeader
    magic_value
    architecture_flags
    checksum
slutt

struktur BootloaderIntegration
    loaded_kernel_image
    boot_parameters
    boot_state
slutt

struktur KernelEntrypoint
    entry_address
    initialized_runtime
    execution_state
slutt

struktur FramebufferConsole
    framebuffer_address
    screen_width
    screen_height
slutt

struktur PhysicalMemoryProbe
    detected_regions
    available_memory
    reserved_memory
slutt

struktur TimerInterruptRuntime
    timer_frequency
    active_ticks
    scheduled_interrupts
slutt

struktur EarlySchedulerLoop
    runnable_tasks
    scheduler_cycles
    active_contexts
slutt

struktur BootableKernelImage
    image_signature
    executable_sections
    boot_status
slutt

struktur KernelBootRuntime
    initialized_boot_services
    active_boot_modules
    runtime_stage
slutt

struktur NativeBootIdentity
    boot_signature
    kernel_generation
    verified_boot
slutt

funksjon ny_multiboot_header()
    header = MultibootHeader()

    header.magic_value = 0x1BADB002
    header.architecture_flags = 0
    header.checksum = (
        0 -
        header.magic_value
    )

    returner header
slutt

funksjon validate_multiboot_header(header)
    hvis header == null
        kast "Multiboot header mangler"
    slutt

    checksum = (
        header.magic_value +
        header.architecture_flags +
        header.checksum
    )

    returner checksum == 0
slutt

funksjon ny_bootloader_integration()
    integration = BootloaderIntegration()

    integration.loaded_kernel_image = null
    integration.boot_parameters = {}
    integration.boot_state = "cold"

    returner integration
slutt

funksjon load_kernel_image(integration, image)
    hvis integration == null
        kast "Bootloader integration mangler"
    slutt

    integration.loaded_kernel_image = image

    integration.boot_parameters[
        "boot_device"
    ] = "native_disk"

    integration.boot_state = "loaded"

    returner integration.boot_state
slutt

funksjon ny_kernel_entrypoint()
    entry = KernelEntrypoint()

    entry.entry_address = 0x100000
    entry.initialized_runtime = usann
    entry.execution_state = "idle"

    returner entry
slutt

funksjon execute_kernel_entrypoint(entry)
    hvis entry == null
        kast "Kernel entrypoint mangler"
    slutt

    entry.initialized_runtime = sann
    entry.execution_state = "running"

    returner entry.execution_state
slutt

funksjon ny_framebuffer_console()
    console = FramebufferConsole()

    console.framebuffer_address = 0xB8000
    console.screen_width = 1024
    console.screen_height = 768

    returner console
slutt

funksjon write_framebuffer(console, text)
    hvis console == null
        kast "Framebuffer console mangler"
    slutt

    returner {
        address: console.framebuffer_address,
        text: text
    }
slutt

funksjon ny_physical_memory_probe()
    probe = PhysicalMemoryProbe()

    probe.detected_regions = []
    probe.available_memory = 0
    probe.reserved_memory = 0

    returner probe
slutt

funksjon detect_physical_memory(probe, region, size)
    hvis probe == null
        kast "Physical memory probe mangler"
    slutt

    legg_til(
        probe.detected_regions,
        {
            region: region,
            size: size
        }
    )

    probe.available_memory = (
        probe.available_memory + size
    )

    returner probe.available_memory
slutt

funksjon ny_timer_interrupt_runtime()
    runtime = TimerInterruptRuntime()

    runtime.timer_frequency = 100
    runtime.active_ticks = 0
    runtime.scheduled_interrupts = []

    returner runtime
slutt

funksjon dispatch_timer_tick(runtime)
    hvis runtime == null
        kast "Timer interrupt runtime mangler"
    slutt

    runtime.active_ticks = (
        runtime.active_ticks + 1
    )

    legg_til(
        runtime.scheduled_interrupts,
        runtime.active_ticks
    )

    returner runtime.active_ticks
slutt

funksjon ny_early_scheduler_loop()
    loop = EarlySchedulerLoop()

    loop.runnable_tasks = []
    loop.scheduler_cycles = 0
    loop.active_contexts = []

    returner loop
slutt

funksjon execute_scheduler_cycle(loop, task)
    hvis loop == null
        kast "Early scheduler loop mangler"
    slutt

    legg_til(
        loop.runnable_tasks,
        task
    )

    loop.scheduler_cycles = (
        loop.scheduler_cycles + 1
    )

    legg_til(
        loop.active_contexts,
        {
            task: task,
            cycle: loop.scheduler_cycles
        }
    )

    returner loop.scheduler_cycles
slutt

funksjon ny_bootable_kernel_image()
    image = BootableKernelImage()

    image.image_signature = "norscode-bootable"
    image.executable_sections = []
    image.boot_status = "created"

    returner image
slutt

funksjon finalize_bootable_image(image, section)
    hvis image == null
        kast "Bootable kernel image mangler"
    slutt

    legg_til(
        image.executable_sections,
        section
    )

    image.boot_status = "bootable"

    returner image.boot_status
slutt

funksjon ny_kernel_boot_runtime()
    runtime = KernelBootRuntime()

    runtime.initialized_boot_services = []
    runtime.active_boot_modules = []
    runtime.runtime_stage = "preboot"

    returner runtime
slutt

funksjon initialize_boot_runtime(runtime, service)
    hvis runtime == null
        kast "Kernel boot runtime mangler"
    slutt

    legg_til(
        runtime.initialized_boot_services,
        service
    )

    legg_til(
        runtime.active_boot_modules,
        {
            service: service,
            state: "active"
        }
    )

    runtime.runtime_stage = "boot_runtime"

    returner runtime.runtime_stage
slutt

funksjon ny_native_boot_identity()
    identity = NativeBootIdentity()

    identity.boot_signature = "norscode-boot"
    identity.kernel_generation = 41
    identity.verified_boot = usann

    returner identity
slutt

funksjon verify_native_boot(identity, boot_state)
    hvis identity == null
        kast "Native boot identity mangler"
    slutt

    hvis boot_state == "bootable"
        identity.verified_boot = sann
    slutt

    returner identity.verified_boot
slutt

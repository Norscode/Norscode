# Minimal native kernel phase

struktur KernelBootstrap
    bootstrap_stages
    initialized_subsystems
    bootstrap_state
slutt

struktur EarlyMemoryInitialization
    initialized_regions
    reserved_pages
    kernel_memory_map
slutt

struktur InterruptBootstrap
    initialized_vectors
    bootstrap_handlers
    active_interrupt_table
slutt

struktur SchedulerBootstrap
    initialized_queues
    bootstrap_tasks
    scheduler_state
slutt

struktur KernelTaskRuntime
    active_kernel_tasks
    scheduled_kernel_threads
    runtime_events
slutt

struktur ExecutableLoaderIntegration
    loaded_executables
    runtime_mappings
    executable_states
slutt

struktur NativeUserspaceBridge
    active_userspace_processes
    syscall_channels
    userspace_contexts
slutt

struktur StandaloneKernelRuntime
    active_runtime
    initialized_drivers
    kernel_processes
slutt

struktur KernelBootConsole
    console_messages
    initialized_console
    boot_logs
slutt

struktur NativeKernelIdentity
    kernel_signature
    kernel_generation
    stable_runtime
slutt

funksjon ny_kernel_bootstrap()
    bootstrap = KernelBootstrap()

    bootstrap.bootstrap_stages = []
    bootstrap.initialized_subsystems = []
    bootstrap.bootstrap_state = "cold"

    returner bootstrap
slutt

funksjon execute_kernel_bootstrap(bootstrap)
    hvis bootstrap == null
        kast "Kernel bootstrap mangler"
    slutt

    legg_til(
        bootstrap.bootstrap_stages,
        "early_boot"
    )

    legg_til(
        bootstrap.bootstrap_stages,
        "memory_init"
    )

    legg_til(
        bootstrap.bootstrap_stages,
        "interrupt_init"
    )

    legg_til(
        bootstrap.initialized_subsystems,
        "kernel_runtime"
    )

    bootstrap.bootstrap_state = "running"

    returner bootstrap.bootstrap_state
slutt

funksjon ny_early_memory_initialization()
    memory = EarlyMemoryInitialization()

    memory.initialized_regions = []
    memory.reserved_pages = []
    memory.kernel_memory_map = {}

    returner memory
slutt

funksjon initialize_early_memory(memory, address, size)
    hvis memory == null
        kast "Early memory initialization mangler"
    slutt

    region = {
        address: address,
        size: size
    }

    legg_til(
        memory.initialized_regions,
        region
    )

    legg_til(
        memory.reserved_pages,
        address
    )

    memory.kernel_memory_map[
        address
    ] = size

    returner region
slutt

funksjon ny_interrupt_bootstrap()
    interrupts = InterruptBootstrap()

    interrupts.initialized_vectors = []
    interrupts.bootstrap_handlers = []
    interrupts.active_interrupt_table = []

    returner interrupts
slutt

funksjon bootstrap_interrupt_vector(interrupts, vector, handler)
    hvis interrupts == null
        kast "Interrupt bootstrap mangler"
    slutt

    legg_til(
        interrupts.initialized_vectors,
        vector
    )

    legg_til(
        interrupts.bootstrap_handlers,
        handler
    )

    legg_til(
        interrupts.active_interrupt_table,
        {
            vector: vector,
            handler: handler
        }
    )

    returner sann
slutt

funksjon ny_scheduler_bootstrap()
    scheduler = SchedulerBootstrap()

    scheduler.initialized_queues = []
    scheduler.bootstrap_tasks = []
    scheduler.scheduler_state = "idle"

    returner scheduler
slutt

funksjon bootstrap_scheduler(scheduler, task)
    hvis scheduler == null
        kast "Scheduler bootstrap mangler"
    slutt

    legg_til(
        scheduler.initialized_queues,
        "kernel_queue"
    )

    legg_til(
        scheduler.bootstrap_tasks,
        task
    )

    scheduler.scheduler_state = "active"

    returner scheduler.scheduler_state
slutt

funksjon ny_kernel_task_runtime()
    runtime = KernelTaskRuntime()

    runtime.active_kernel_tasks = []
    runtime.scheduled_kernel_threads = []
    runtime.runtime_events = []

    returner runtime
slutt

funksjon schedule_kernel_task(runtime, task)
    hvis runtime == null
        kast "Kernel task runtime mangler"
    slutt

    legg_til(
        runtime.active_kernel_tasks,
        task
    )

    legg_til(
        runtime.scheduled_kernel_threads,
        {
            task: task,
            state: "scheduled"
        }
    )

    legg_til(
        runtime.runtime_events,
        "task_dispatch"
    )

    returner sann
slutt

funksjon ny_executable_loader_integration()
    integration = ExecutableLoaderIntegration()

    integration.loaded_executables = []
    integration.runtime_mappings = []
    integration.executable_states = []

    returner integration
slutt

funksjon integrate_executable_loader(integration, executable)
    hvis integration == null
        kast "Executable loader integration mangler"
    slutt

    legg_til(
        integration.loaded_executables,
        executable
    )

    legg_til(
        integration.runtime_mappings,
        {
            executable: executable,
            address: 0x400000
        }
    )

    legg_til(
        integration.executable_states,
        "loaded"
    )

    returner sann
slutt

funksjon ny_native_userspace_bridge()
    bridge = NativeUserspaceBridge()

    bridge.active_userspace_processes = []
    bridge.syscall_channels = []
    bridge.userspace_contexts = []

    returner bridge
slutt

funksjon bridge_userspace_process(bridge, process)
    hvis bridge == null
        kast "Native userspace bridge mangler"
    slutt

    legg_til(
        bridge.active_userspace_processes,
        process
    )

    legg_til(
        bridge.syscall_channels,
        "syscall_channel"
    )

    legg_til(
        bridge.userspace_contexts,
        {
            process: process,
            mode: "userspace"
        }
    )

    returner sann
slutt

funksjon ny_standalone_kernel_runtime()
    runtime = StandaloneKernelRuntime()

    runtime.active_runtime = usann
    runtime.initialized_drivers = []
    runtime.kernel_processes = []

    returner runtime
slutt

funksjon start_kernel_runtime(runtime)
    hvis runtime == null
        kast "Standalone kernel runtime mangler"
    slutt

    runtime.active_runtime = sann

    legg_til(
        runtime.initialized_drivers,
        "memory_driver"
    )

    legg_til(
        runtime.initialized_drivers,
        "interrupt_driver"
    )

    legg_til(
        runtime.kernel_processes,
        "init"
    )

    returner runtime.active_runtime
slutt

funksjon ny_kernel_boot_console()
    console = KernelBootConsole()

    console.console_messages = []
    console.initialized_console = usann
    console.boot_logs = []

    returner console
slutt

funksjon kernel_console_log(console, message)
    hvis console == null
        kast "Kernel boot console mangler"
    slutt

    console.initialized_console = sann

    legg_til(
        console.console_messages,
        message
    )

    legg_til(
        console.boot_logs,
        {
            level: "boot",
            message: message
        }
    )

    returner message
slutt

funksjon ny_native_kernel_identity()
    identity = NativeKernelIdentity()

    identity.kernel_signature = "norscode-kernel"
    identity.kernel_generation = 40
    identity.stable_runtime = usann

    returner identity
slutt

funksjon stabilize_kernel_runtime(identity, runtime_state)
    hvis identity == null
        kast "Native kernel identity mangler"
    slutt

    hvis runtime_state == "running"
        identity.stable_runtime = sann
    slutt

    returner identity.stable_runtime
slutt

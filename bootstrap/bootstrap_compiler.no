# Bootstrap compiler phase

struktur CompilerDriver
    input_files
    output_files
    compilation_units
slutt

struktur SourceModule
    path
    source
    ast
    ir
slutt

struktur CompilationPipeline
    lexer_stage
    parser_stage
    semantic_stage
    optimizer_stage
    backend_stage
slutt

struktur CompilerConfiguration
    target_architecture
    output_format
    optimization_level
slutt

struktur BuildOrchestrator
    queued_builds
    completed_builds
    failed_builds
slutt

struktur ExecutableEmitter
    emitted_executables
    executable_paths
slutt

struktur BootstrapCompiler
    loaded_modules
    generated_binaries
    compiler_state
slutt

struktur CompilationSession
    session_id
    compiled_modules
    emitted_objects
slutt

struktur CompilerEntrypoint
    main_module
    startup_function
slutt

struktur NativeProgram
    executable
    entrypoint
    runtime
slutt

funksjon ny_compiler_driver()
    driver = CompilerDriver()

    driver.input_files = []
    driver.output_files = []
    driver.compilation_units = []

    returner driver
slutt

funksjon driver_add_input(driver, path)
    hvis driver == null
        kast "Compiler driver mangler"
    slutt

    legg_til(driver.input_files, path)

    returner sann
slutt

funksjon driver_add_output(driver, path)
    hvis driver == null
        kast "Compiler driver mangler"
    slutt

    legg_til(driver.output_files, path)

    returner sann
slutt

funksjon ny_source_module(path, source)
    module = SourceModule()

    module.path = path
    module.source = source
    module.ast = null
    module.ir = null

    returner module
slutt

funksjon ny_compilation_pipeline()
    pipeline = CompilationPipeline()

    pipeline.lexer_stage = "initialized"
    pipeline.parser_stage = "initialized"
    pipeline.semantic_stage = "initialized"
    pipeline.optimizer_stage = "initialized"
    pipeline.backend_stage = "initialized"

    returner pipeline
slutt

funksjon pipeline_run_lexer(pipeline, source)
    hvis pipeline == null
        kast "Compilation pipeline mangler"
    slutt

    lexer = ny_lexer(source)

    pipeline.lexer_stage = "completed"

    returner lexer_tokenize(lexer)
slutt

funksjon pipeline_run_parser(pipeline, tokens)
    hvis pipeline == null
        kast "Compilation pipeline mangler"
    slutt

    parser = ny_parser(tokens)

    pipeline.parser_stage = "completed"

    returner parser_parse_program(parser)
slutt

funksjon pipeline_run_semantic(pipeline, ast)
    hvis pipeline == null
        kast "Compilation pipeline mangler"
    slutt

    pipeline.semantic_stage = "completed"

    returner ast
slutt

funksjon pipeline_run_optimizer(pipeline, cfg)
    hvis pipeline == null
        kast "Compilation pipeline mangler"
    slutt

    optimizer = ny_optimization_pipeline()

    pipeline.optimizer_stage = "completed"

    returner optimizer
slutt

funksjon pipeline_run_backend(pipeline, cfg)
    hvis pipeline == null
        kast "Compilation pipeline mangler"
    slutt

    builder = ny_machine_function_builder()

    pipeline.backend_stage = "completed"

    returner build_machine_function(
        builder,
        cfg
    )
slutt

funksjon ny_compiler_configuration()
    config = CompilerConfiguration()

    config.target_architecture = "x86_64"
    config.output_format = "ELF64"
    config.optimization_level = 2

    returner config
slutt

funksjon ny_build_orchestrator()
    orchestrator = BuildOrchestrator()

    orchestrator.queued_builds = []
    orchestrator.completed_builds = []
    orchestrator.failed_builds = []

    returner orchestrator
slutt

funksjon orchestrate_build(orchestrator, module)
    hvis orchestrator == null
        kast "Build orchestrator mangler"
    slutt

    legg_til(
        orchestrator.queued_builds,
        module.path
    )

    legg_til(
        orchestrator.completed_builds,
        module.path
    )

    returner sann
slutt

funksjon ny_executable_emitter()
    emitter = ExecutableEmitter()

    emitter.emitted_executables = []
    emitter.executable_paths = []

    returner emitter
slutt

funksjon emit_executable(emitter, binary, path)
    hvis emitter == null
        kast "Executable emitter mangler"
    slutt

    legg_til(
        emitter.emitted_executables,
        binary
    )

    legg_til(
        emitter.executable_paths,
        path
    )

    returner path
slutt

funksjon ny_bootstrap_compiler()
    compiler = BootstrapCompiler()

    compiler.loaded_modules = []
    compiler.generated_binaries = []
    compiler.compiler_state = "ready"

    returner compiler
slutt

funksjon bootstrap_compile(compiler, source)
    hvis compiler == null
        kast "Bootstrap compiler mangler"
    slutt

    pipeline = ny_compilation_pipeline()

    tokens = pipeline_run_lexer(
        pipeline,
        source
    )

    ast = pipeline_run_parser(
        pipeline,
        tokens
    )

    cfg = ny_cfg()

    pipeline_run_semantic(
        pipeline,
        ast
    )

    pipeline_run_optimizer(
        pipeline,
        cfg
    )

    machine = pipeline_run_backend(
        pipeline,
        cfg
    )

    legg_til(
        compiler.generated_binaries,
        machine
    )

    compiler.compiler_state = "compiled"

    returner machine
slutt

funksjon ny_compilation_session(id)
    session = CompilationSession()

    session.session_id = id
    session.compiled_modules = []
    session.emitted_objects = []

    returner session
slutt

funksjon session_add_module(session, module)
    hvis session == null
        kast "Compilation session mangler"
    slutt

    legg_til(
        session.compiled_modules,
        module.path
    )

    returner sann
slutt

funksjon ny_compiler_entrypoint(module)
    entrypoint = CompilerEntrypoint()

    entrypoint.main_module = module
    entrypoint.startup_function = "main"

    returner entrypoint
slutt

funksjon ny_native_program(executable)
    program = NativeProgram()

    program.executable = executable
    program.entrypoint = "main"
    program.runtime = "norscode_runtime"

    returner program
slutt

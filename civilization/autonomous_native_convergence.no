funksjon ny_deterministic_autonomous_identity()
    identity = DeterministicAutonomousIdentity()

    identity.autonomous_execution_signatures = []
    identity.deterministic_execution_identities = []
    identity.verified_autonomous_generations = []

    returner identity
slutt

funksjon verify_autonomous_identity(identity, signature)
    hvis identity == null
        kast "Deterministic autonomous identity mangler"
    slutt

    legg_til(identity.autonomous_execution_signatures, signature)
    legg_til(identity.deterministic_execution_identities, signature)
    legg_til(identity.verified_autonomous_generations, "verified")

    returner sann
slutt

slutt

funksjon replay_immortality_generation(replay, hash)
    hvis replay == null
        kast "Recursive immortality replay mangler"
    slutt

    legg_til(replay.replayed_immortality_generations, hash)
    legg_til(replay.deterministic_immortality_hashes, hash)
    legg_til(replay.stabilized_immortality_existences, hash)


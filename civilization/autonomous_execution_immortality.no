    hvis immortality == null
        kast "Native reality immortality mangler"
    slutt

    legg_til(immortality.native_reality_generations, image)
    legg_til(immortality.replayed_reality_immortalities, image)
    legg_til(immortality.stabilized_reality_regenerations, image)

    returner image
slutt

funksjon ny_autonomous_memory_immortality()
    immortality = AutonomousMemoryImmortality()

    immortality.autonomous_memory_generations = []
    immortality.persistent_memory_immortalities = []
    immortality.restored_memory_regenerations = []

    returner immortality
slutt

funksjon persist_memory_immortality(immortality, region)
    hvis immortality == null
        kast "Autonomous memory immortality mangler"
    slutt

    legg_til(immortality.autonomous_memory_generations, region)
    legg_til(immortality.persistent_memory_immortalities, "RX")
    legg_til(immortality.restored_memory_regenerations, region)

    returner region
slutt

funksjon ny_recursive_process_immortality()
    immortality = RecursiveProcessImmortality()

    immortality.recursive_process_generations = []
    immortality.deterministic_process_immortalities = []
    immortality.divergent_process_regenerations = []

    returner immortality
slutt

funksjon execute_process_immortality(immortality, hash)
    hvis immortality == null
        kast "Recursive process immortality mangler"
    slutt

    hvis lengde(immortality.deterministic_process_immortalities) > 0
        previous = immortality.deterministic_process_immortalities[
            lengde(immortality.deterministic_process_immortalities) - 1
        ]

        hvis previous != hash
            legg_til(immortality.divergent_process_regenerations, hash)
        slutt
    slutt

    legg_til(immortality.recursive_process_generations, hash)
    legg_til(immortality.deterministic_process_immortalities, hash)

    returner hash
slutt


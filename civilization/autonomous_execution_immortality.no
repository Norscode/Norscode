slutt

funksjon ny_deterministic_immortality_identity()
    identity = DeterministicImmortalityIdentity()

    identity.immortality_identity_signatures = []
    identity.deterministic_immortality_hashes = []
    identity.verified_immortality_generations = []

    returner identity
slutt

funksjon verify_immortality_identity(identity, signature)
    hvis identity == null
        kast "Deterministic immortality identity mangler"
    slutt

    legg_til(identity.immortality_identity_signatures, signature)
    legg_til(identity.deterministic_immortality_hashes, signature)
    legg_til(identity.verified_immortality_generations, "verified")

    returner sann
slutt

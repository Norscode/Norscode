funksjon ny_deterministic_selfhost_existence()
    existence = DeterministicSelfhostExistence()

    existence.selfhost_execution_signatures = []
    existence.deterministic_selfhost_hashes = []
    existence.verified_selfhost_existences = []

    returner existence
slutt

funksjon verify_selfhost_existence(existence, signature)
    hvis existence == null
        kast "Deterministic selfhost existence mangler"
    slutt

    legg_til(existence.selfhost_execution_signatures, signature)
    legg_til(existence.deterministic_selfhost_hashes, signature)
    legg_til(existence.verified_selfhost_existences, "verified")

    returner sann
slutt

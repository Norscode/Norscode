funksjon ny_deterministic_elf_materialization()
    materialization = DeterministicELFMaterialization()

    materialization.materialized_elf_generations = []
    materialization.deterministic_elf_hashes = []
    materialization.stabilized_elf_cycles = []

    returner materialization
slutt

funksjon materialize_deterministic_elf(materialization, hash)
    hvis materialization == null
        kast "Deterministic ELF materialization mangler"
    slutt

    legg_til(materialization.materialized_elf_generations, hash)
    legg_til(materialization.deterministic_elf_hashes, hash)
    legg_til(materialization.stabilized_elf_cycles, hash)

    returner hash
slutt

funksjon ny_autonomous_runtime_image_builder()
    builder = AutonomousRuntimeImageBuilder()

    builder.generated_runtime_images = []
    builder.runtime_image_generations = 0
    builder.verified_runtime_artifacts = []

    returner builder
slutt

funksjon build_runtime_image(builder, image)
    hvis builder == null
        kast "Autonomous runtime image builder mangler"
    slutt

    legg_til(builder.generated_runtime_images, image)

    builder.runtime_image_generations = (
        builder.runtime_image_generations + 1
    )

    legg_til(builder.verified_runtime_artifacts, image)

    returner builder.runtime_image_generations
slutt


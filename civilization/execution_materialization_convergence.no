funksjon ny_recursive_execution_identity_loop()
    loop = RecursiveExecutionIdentityLoop()

    loop.recursive_execution_signatures = []
    loop.stabilized_execution_identities = []
    loop.divergent_execution_identities = []

    returner loop
slutt

funksjon stabilize_execution_identity(loop, signature)
    hvis loop == null
        kast "Recursive execution identity loop mangler"
    slutt

    hvis lengde(loop.stabilized_execution_identities) > 0
        previous = loop.stabilized_execution_identities[
            lengde(loop.stabilized_execution_identities) - 1
        ]

        hvis previous != signature
            legg_til(
                loop.divergent_execution_identities,
                signature
            )
        slutt
    slutt

    legg_til(loop.recursive_execution_signatures, signature)
    legg_til(loop.stabilized_execution_identities, signature)

    returner signature
slutt

funksjon ny_deterministic_materialization_civilization()
    civilization = DeterministicMaterializationCivilization()

    civilization.civilization_materialization_generations = []
    civilization.autonomous_materialization_cycles = 0
    civilization.verified_materialization_states = []

    returner civilization
slutt

funksjon execute_materialization_civilization(civilization, image)
    hvis civilization == null
        kast "Deterministic materialization civilization mangler"
    slutt

    legg_til(
        civilization.civilization_materialization_generations,
        image
    )

    civilization.autonomous_materialization_cycles = (
        civilization.autonomous_materialization_cycles + 1
    )

    legg_til(
        civilization.verified_materialization_states,
        "verified"
    )

    returner civilization.autonomous_materialization_cycles
slutt

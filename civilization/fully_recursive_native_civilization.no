funksjon ny_deterministic_existence_identity()
    identity = DeterministicExistenceIdentity()

    identity.existence_execution_signatures = []
    identity.deterministic_existence_hashes = []
    identity.verified_existence_generations = []

    returner identity
slutt

funksjon verify_existence_identity(identity, signature)
    hvis identity == null
        kast "Deterministic existence identity mangler"
    slutt

    legg_til(identity.existence_execution_signatures, signature)
    legg_til(identity.deterministic_existence_hashes, signature)
    legg_til(identity.verified_existence_generations, "verified")

    returner sann
slutt

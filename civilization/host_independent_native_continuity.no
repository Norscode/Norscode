slutt

funksjon ny_native_continuity_replay_core()
    replay = NativeContinuityReplayCore()

    replay.replayed_continuity_generations = []
    replay.deterministic_continuity_replays = []
    replay.stabilized_continuity_cycles = []

    returner replay
slutt

funksjon replay_continuity_generation(replay, hash)
    hvis replay == null
        kast "Native continuity replay core mangler"
    slutt

    legg_til(replay.replayed_continuity_generations, hash)
    legg_til(replay.deterministic_continuity_replays, hash)
    legg_til(replay.stabilized_continuity_cycles, hash)


slutt

funksjon ny_deterministic_hostless_identity()
    identity = DeterministicHostlessIdentity()

    identity.hostless_execution_signatures = []
    identity.deterministic_hostless_hashes = []
    identity.verified_hostless_generations = []

    returner identity
slutt

funksjon verify_hostless_identity(identity, signature)
    hvis identity == null
        kast "Deterministic hostless identity mangler"
    slutt

    legg_til(identity.hostless_execution_signatures, signature)
    legg_til(identity.deterministic_hostless_hashes, signature)
    legg_til(identity.verified_hostless_generations, "verified")

    returner sann
slutt

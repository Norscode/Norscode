    replay = AutonomousContinuityReplay()

    replay.replayed_continuity_generations = []
    replay.deterministic_continuity_hashes = []
    replay.stabilized_replay_existences = []

    returner replay
slutt

funksjon replay_continuity_existence(replay, hash)
    hvis replay == null
        kast "Autonomous continuity replay mangler"
    slutt

    legg_til(replay.replayed_continuity_generations, hash)
    legg_til(replay.deterministic_continuity_hashes, hash)
    legg_til(replay.stabilized_replay_existences, hash)


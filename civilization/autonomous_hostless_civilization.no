slutt

funksjon ny_deterministic_civilization_identity()
    identity = DeterministicCivilizationIdentity()

    identity.civilization_identity_signatures = []
    identity.deterministic_identity_hashes = []
    identity.verified_civilization_generations = []

    returner identity
slutt

funksjon verify_civilization_identity(identity, signature)
    hvis identity == null
        kast "Deterministic civilization identity mangler"
    slutt

    legg_til(identity.civilization_identity_signatures, signature)
    legg_til(identity.deterministic_identity_hashes, signature)
    legg_til(identity.verified_civilization_generations, "verified")

    returner sann
slutt

# Phase 72

struktur Phase72
    execution_states
    replay_cycles
slutt

funksjon ny_phase72()
    phase = Phase72()

    phase.execution_states = []
    phase.replay_cycles = []

    returner phase
slutt

funksjon execute_phase72(phase, value)
    hvis phase == null
        kast "Phase72 mangler"
    slutt

    legg_til(phase.execution_states, value)
    legg_til(phase.replay_cycles, value)

    returner value
slutt

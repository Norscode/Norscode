funksjon ny_deterministic_singularity_identity()
    identity = DeterministicSingularityIdentity()

    identity.singularity_identity_signatures = []
    identity.deterministic_singularity_hashes = []
    identity.verified_singularity_generations = []

    returner identity
slutt

funksjon verify_singularity_identity(identity, signature)
    hvis identity == null
        kast "Deterministic singularity identity mangler"
    slutt

    legg_til(identity.singularity_identity_signatures, signature)
    legg_til(identity.deterministic_singularity_hashes, signature)
    legg_til(identity.verified_singularity_generations, "verified")

    returner sann
slutt

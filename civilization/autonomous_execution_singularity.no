slutt

funksjon ny_persistent_kernel_singularity()
    singularity = PersistentKernelSingularity()

    singularity.persistent_kernel_generations = []
    singularity.restored_kernel_singularities = []
    singularity.continuous_kernel_singularities = 0

    returner singularity
slutt

funksjon persist_kernel_singularity(singularity, image)
    hvis singularity == null
        kast "Persistent kernel singularity mangler"
    slutt

    legg_til(singularity.persistent_kernel_generations, image)

    returner image
slutt

funksjon restore_kernel_singularity(singularity, image)
    hvis singularity == null
        kast "Persistent kernel singularity mangler"
    slutt

    legg_til(singularity.restored_kernel_singularities, image)

    singularity.continuous_kernel_singularities = (
        singularity.continuous_kernel_singularities + 1
    )

    returner singularity.continuous_kernel_singularities
slutt


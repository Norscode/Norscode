funksjon execute_compiler_singularity(singularity, artifact)
    hvis singularity == null
        kast "Recursive compiler singularity mangler"
    slutt

    legg_til(singularity.recursive_compiler_generations, artifact)
    legg_til(singularity.autonomous_compiler_singularities, artifact)
    legg_til(singularity.deterministic_compiler_reconstructions, artifact)


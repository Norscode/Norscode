    transcendence = AutonomousBootstrapTranscendence()

    transcendence.autonomous_bootstrap_generations = []
    transcendence.executable_bootstrap_transcendence = []
    transcendence.stabilized_bootstrap_evolutions = []

    returner transcendence
slutt

funksjon execute_bootstrap_transcendence(transcendence, image)
    hvis transcendence == null
        kast "Autonomous bootstrap transcendence mangler"
    slutt

    legg_til(transcendence.autonomous_bootstrap_generations, image)
    legg_til(transcendence.executable_bootstrap_transcendence, image)
    legg_til(transcendence.stabilized_bootstrap_evolutions, image)

    returner image
slutt


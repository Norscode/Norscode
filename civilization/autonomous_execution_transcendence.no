    replay = RecursiveTranscendenceReplay()

    replay.replayed_transcendence_generations = []
    replay.deterministic_transcendence_hashes = []
    replay.stabilized_transcendence_existences = []

    returner replay
slutt

funksjon replay_transcendence_generation(replay, hash)
    hvis replay == null
        kast "Recursive transcendence replay mangler"
    slutt

    legg_til(replay.replayed_transcendence_generations, hash)
    legg_til(replay.deterministic_transcendence_hashes, hash)
    legg_til(replay.stabilized_transcendence_existences, hash)

    returner hash
slutt

funksjon ny_deterministic_transcendence_identity()
    identity = DeterministicTranscendenceIdentity()

    identity.transcendence_identity_signatures = []
    identity.deterministic_transcendence_hashes = []
    identity.verified_transcendence_generations = []

    returner identity
slutt

funksjon verify_transcendence_identity(identity, signature)
    hvis identity == null
        kast "Deterministic transcendence identity mangler"
    slutt

    legg_til(identity.transcendence_identity_signatures, signature)
    legg_til(identity.deterministic_transcendence_hashes, signature)
    legg_til(identity.verified_transcendence_generations, "verified")

    returner sann
slutt

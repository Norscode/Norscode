    replay.replayed_reality_generations = []
    replay.deterministic_reality_hashes = []
    replay.stabilized_reality_existences = []

    returner replay
slutt

funksjon replay_reality_generation(replay, hash)
    hvis replay == null
        kast "Recursive reality replay mangler"

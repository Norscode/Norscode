slutt

funksjon ny_deterministic_reality_identity()
    identity = DeterministicRealityIdentity()

    identity.reality_identity_signatures = []
    identity.deterministic_reality_hashes = []
    identity.verified_reality_generations = []

    returner identity
slutt

funksjon verify_reality_identity(identity, signature)
    hvis identity == null
        kast "Deterministic reality identity mangler"
    slutt

    legg_til(identity.reality_identity_signatures, signature)
    legg_til(identity.deterministic_reality_hashes, signature)
    legg_til(identity.verified_reality_generations, "verified")

    returner sann
slutt

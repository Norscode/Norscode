    reality = PersistentExecutableReality()

    reality.persistent_executable_generations = []
    reality.restored_executable_realities = []
    reality.executable_reality_cycles = 0

    returner reality
slutt

funksjon persist_executable_reality(reality, image)
    hvis reality == null
        kast "Persistent executable reality mangler"
    slutt

    legg_til(reality.persistent_executable_generations, image)

    returner image
slutt

funksjon restore_executable_reality(reality, image)
    hvis reality == null
        kast "Persistent executable reality mangler"
    slutt

    legg_til(reality.restored_executable_realities, image)

    reality.executable_reality_cycles = (
        reality.executable_reality_cycles + 1
    )

    returner reality.executable_reality_cycles
slutt


funksjon ny_deterministic_permanence_identity()
    identity = DeterministicPermanenceIdentity()

    identity.permanence_identity_signatures = []
    identity.deterministic_permanence_hashes = []
    identity.verified_permanence_generations = []

    returner identity
slutt

funksjon verify_permanence_identity(identity, signature)
    hvis identity == null
        kast "Deterministic permanence identity mangler"
    slutt

    legg_til(identity.permanence_identity_signatures, signature)
    legg_til(identity.deterministic_permanence_hashes, signature)
    legg_til(identity.verified_permanence_generations, "verified")

    returner sann
slutt

# Realization phase: practical executable compiler toolchain

struktur RealParserExecutor
    grammar_rules
    parsed_programs
    parser_errors
slutt

struktur MachineEmitter
    emitted_instructions
    emitted_bytes
    failed_emissions
slutt

struktur ExecutableLinker
    linked_executables
    resolved_symbols
    unresolved_symbols
slutt

struktur ProcessSpawner
    spawned_processes
    terminated_processes
slutt

struktur SyscallExecutor
    executed_syscalls
    denied_syscalls
slutt

struktur PageProtectionEnforcer
    executable_pages
    readonly_pages
    denied_writes
slutt

struktur SelfCompilationExecutor
    executed_builds
    successful_builds
    failed_builds
slutt

struktur NativeBinaryReproducer
    reproduced_hashes
    mismatched_hashes
slutt

struktur ReplayConvergenceCI
    replay_runs
    converged_runs
    divergent_runs
slutt

struktur EndToEndExecution
    executed_compilers
    verified_executions
slutt

funksjon ny_real_parser_executor()
    executor = RealParserExecutor()

    executor.grammar_rules = []
    executor.parsed_programs = []
    executor.parser_errors = []

    returner executor
slutt

funksjon execute_parser(executor, source)
    hvis executor == null
        kast "Parser executor mangler"
    slutt

    ast = {
        type: "Program",
        source: source
    }

    legg_til(executor.parsed_programs, ast)

    returner ast
slutt

funksjon ny_machine_emitter()
    emitter = MachineEmitter()

    emitter.emitted_instructions = []
    emitter.emitted_bytes = []
    emitter.failed_emissions = []

    returner emitter
slutt

funksjon emit_machine_instruction(emitter, instruction)
    hvis emitter == null
        kast "Machine emitter mangler"
    slutt

    legg_til(emitter.emitted_instructions, instruction)
    legg_til(emitter.emitted_bytes, 0x90)

    returner sann
slutt

funksjon ny_executable_linker()
    linker = ExecutableLinker()

    linker.linked_executables = []
    linker.resolved_symbols = []
    linker.unresolved_symbols = []

    returner linker
slutt

funksjon link_executable(linker, object_files)
    hvis linker == null
        kast "Executable linker mangler"
    slutt

    executable = {
        format: "ELF64",
        linked: sann,
        objects: object_files
    }

    legg_til(linker.linked_executables, executable)

    returner executable
slutt

funksjon ny_process_spawner()
    spawner = ProcessSpawner()

    spawner.spawned_processes = []
    spawner.terminated_processes = []

    returner spawner
slutt

funksjon spawn_process(spawner, executable)
    hvis spawner == null
        kast "Process spawner mangler"
    slutt

    process = {
        executable: executable,
        pid: lengde(spawner.spawned_processes) + 1
    }

    legg_til(spawner.spawned_processes, process)

    returner process
slutt

funksjon ny_syscall_executor()
    executor = SyscallExecutor()

    executor.executed_syscalls = []
    executor.denied_syscalls = []

    returner executor
slutt

funksjon execute_runtime_syscall(executor, syscall)
    hvis executor == null
        kast "Syscall executor mangler"
    slutt

    legg_til(executor.executed_syscalls, syscall)

    returner {
        syscall: syscall,
        executed: sann
    }
slutt

funksjon ny_page_protection_enforcer()
    enforcer = PageProtectionEnforcer()

    enforcer.executable_pages = []
    enforcer.readonly_pages = []
    enforcer.denied_writes = []

    returner enforcer
slutt

funksjon protect_executable_memory(enforcer, page)
    hvis enforcer == null
        kast "Page protection enforcer mangler"
    slutt

    legg_til(enforcer.executable_pages, page)

    returner sann
slutt

funksjon protect_readonly_memory(enforcer, page)
    hvis enforcer == null
        kast "Page protection enforcer mangler"
    slutt

    legg_til(enforcer.readonly_pages, page)

    returner sann
slutt

funksjon ny_self_compilation_executor()
    executor = SelfCompilationExecutor()

    executor.executed_builds = []
    executor.successful_builds = []
    executor.failed_builds = []

    returner executor
slutt

funksjon execute_self_compilation(executor, compiler_binary)
    hvis executor == null
        kast "Self compilation executor mangler"
    slutt

    build = {
        compiler: compiler_binary,
        success: sann
    }

    legg_til(executor.executed_builds, build)
    legg_til(executor.successful_builds, build)

    returner build
slutt

funksjon ny_native_binary_reproducer()
    reproducer = NativeBinaryReproducer()

    reproducer.reproduced_hashes = []
    reproducer.mismatched_hashes = []

    returner reproducer
slutt

funksjon reproduce_binary(reproducer, binary)
    hvis reproducer == null
        kast "Native binary reproducer mangler"
    slutt

    hash = hash_binary(binary)

    legg_til(reproducer.reproduced_hashes, hash)

    returner hash
slutt

funksjon ny_replay_convergence_ci()
    ci = ReplayConvergenceCI()

    ci.replay_runs = []
    ci.converged_runs = []
    ci.divergent_runs = []

    returner ci
slutt

funksjon execute_replay_ci(ci, binary)
    hvis ci == null
        kast "Replay convergence CI mangler"
    slutt

    hash = hash_binary(binary)

    legg_til(ci.replay_runs, hash)
    legg_til(ci.converged_runs, hash)

    returner sann
slutt

funksjon ny_end_to_end_execution()
    execution = EndToEndExecution()

    execution.executed_compilers = []
    execution.verified_executions = []

    returner execution
slutt

funksjon execute_full_toolchain(execution, compiler_binary)
    hvis execution == null
        kast "End-to-end execution mangler"
    slutt

    result = {
        compiler: compiler_binary,
        executed: sann,
        verified: sann
    }

    legg_til(execution.executed_compilers, compiler_binary)
    legg_til(execution.verified_executions, result)

    returner result
slutt

// Deterministic runtime code loader
// Selfhost migration phase

struktur RuntimeModule
    navn
    source
    loaded
slutt

funksjon create_runtime_module(navn, source)
    la module = RuntimeModule()
    module.navn = navn
    module.source = source
    module.loaded = usann

    returner module
slutt

funksjon load_runtime_module(module)
    hvis module == ingen
        returner usann
    slutt

    module.loaded = sann

    returner sann
slutt

funksjon runtime_module_loaded(module)
    hvis module == ingen
        returner usann
    slutt

    returner module.loaded
slutt

funksjon link_runtime_module(runtime, module)
    hvis runtime == ingen
        returner usann
    slutt

    hvis runtime_module_loaded(module) == usann
        returner usann
    slutt

    runtime.last_module = module.navn

    returner sann
slutt

funksjon runtime_import_module(runtime, navn, source)
    la module = create_runtime_module(navn, source)

    hvis load_runtime_module(module) == usann
        returner usann
    slutt

    returner link_runtime_module(runtime, module)
slutt

// Deterministic compiler chain runtime
// Selfhost migration phase

funksjon run_compiler_chain(stage_a, stage_b, stage_c, input)
    la result_a = run_stage(stage_a, input)

    hvis result_a.ok == usann
        returner usann
    slutt

    la result_b = run_stage(stage_b, result_a)

    hvis result_b.ok == usann
        returner usann
    slutt

    la result_c = run_stage(stage_c, result_b)

    hvis result_c.ok == usann
        returner usann
    slutt

    returner sann
slutt

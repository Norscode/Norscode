// Deterministic selfhost runtime
// Selfhost migration phase

funksjon run_selfhost_stage(stage, input)
    la result = run_stage(stage, input)

    hvis result.ok == usann
        returner usann
    slutt

    returner sann
slutt

funksjon run_selfhost_chain(stages, input)
    la executed = 0

    for stage i stages
        hvis run_selfhost_stage(stage, input)
            executed = executed + 1
        ellers
            returner executed
        slutt
    slutt

    returner executed
slutt

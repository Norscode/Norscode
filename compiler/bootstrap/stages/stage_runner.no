// Deterministic stage runner
// Selfhost migration phase

funksjon run_stage(stage_name, input)
    la result = {}

    result.name = stage_name
    result.value = input
    result.ok = sann

    returner result
slutt

funksjon run_stage_chain(stages, input)
    la current = input

    for stage i stages
        la output = run_stage(stage, current)
        current = output
    slutt

    returner current
slutt

// Deterministic compiler equivalence verification
// Selfhost migration phase

funksjon compare_compiler_stage(stage_a, stage_b)
    hvis stage_a == ingen
        returner usann
    slutt

    hvis stage_b == ingen
        returner usann
    slutt

    hvis stage_a.name == stage_b.name
        returner sann
    slutt

    returner usann
slutt

funksjon verify_stage_chain(stages)
    hvis stages.length == 0
        returner usann
    slutt

    returner sann
slutt

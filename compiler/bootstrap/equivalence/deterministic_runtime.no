// Deterministic equivalence runtime
// Selfhost migration phase

funksjon runtime_equivalent(result_a, result_b)
    hvis result_a == ingen
        returner usann
    slutt

    hvis result_b == ingen
        returner usann
    slutt

    hvis result_a.value == result_b.value
        returner sann
    slutt

    returner usann
slutt

funksjon verify_runtime_equivalence(results)
    hvis results.length == 0
        returner usann
    slutt

    la first = results[0]

    for result i results
        hvis runtime_equivalent(first, result) == usann
            returner usann
        slutt
    slutt

    returner sann
slutt

// Deterministic selfhost validation chain
// Selfhost migration phase

funksjon validate_selfhost_chain(stages, input)
    la executed = run_selfhost_chain(stages, input)

    hvis executed == 0
        returner usann
    slutt

    returner sann
slutt

funksjon validate_compiler_equivalence(results)
    returner verify_runtime_equivalence(results)
slutt

funksjon validate_rebuild(results)
    returner verify_rebuild_chain(results)
slutt

// Deterministic parser state machine
// Selfhost migration phase

struktur ParserState
    current_index
    active
    error_count
slutt

funksjon create_parser_state()
    la state = ParserState()
    state.current_index = 0
    state.active = sann
    state.error_count = 0

    returner state
slutt

funksjon advance_parser_state(state)
    state.current_index = state.current_index + 1
slutt

funksjon parser_has_errors(state)
    hvis state.error_count > 0
        returner sann
    slutt

    returner usann
slutt

funksjon parser_add_error(state)
    state.error_count = state.error_count + 1
slutt

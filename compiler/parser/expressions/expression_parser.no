// Deterministic expression parser
// Selfhost migration phase

funksjon parse_expression(stream)
    la token = next_token(stream)

    hvis token == ingen
        returner ingen
    slutt

    la expression = {}
    expression.kind = "expression"
    expression.value = token.value

    returner expression
slutt

funksjon parse_binary_expression(venstre, operator, hoyre)
    la expression = {}

    expression.kind = "binary_expression"
    expression.operator = operator
    expression.left = venstre
    expression.right = hoyre

    returner expression
slutt

funksjon parse_group_expression(expression)
    la grouped = {}

    grouped.kind = "group_expression"
    grouped.expression = expression

    returner grouped
slutt

// Deterministic block parser semantics
// Selfhost migration phase

struktur ParserBlock
    statements
    nested
slutt

funksjon create_parser_block()
    la block = ParserBlock()
    block.statements = []
    block.nested = []

    returner block
slutt

funksjon parse_grouped_expression(tokens, index)
    hvis tokens == ingen
        returner ingen
    slutt

    la expression = {}
    expression.type = "group"
    expression.start = index

    returner expression
slutt

funksjon parse_statement_block(tokens)
    la block = create_parser_block()

    for token i tokens
        block.statements.push(token)
    slutt

    returner block
slutt

funksjon parse_nested_block(parent, child)
    hvis parent == ingen
        returner usann
    slutt

    parent.nested.push(child)

    returner sann
slutt

funksjon parser_block_valid(block)
    hvis block == ingen
        returner usann
    slutt

    returner sann
slutt

// Deterministic block parser semantics
// Selfhost migration phase

struktur ParserBlock
    statements
    nested
slutt

funksjon create_parser_block()
    la parser_block = ParserBlock()
    parser_block.statements = []
    parser_block.nested = []

    returner parser_block
slutt

funksjon parse_grouped_expression(tokens, index)
    hvis tokens == ingen
        returner ingen
    slutt

    la expression = {}
    expression.type = "group"
    expression.start = index

    returner expression
slutt

funksjon parse_statement_block(tokens)
    la parser_block = create_parser_block()

    for token i tokens
        parser_block.statements.push(token)
    slutt

    returner parser_block
slutt

funksjon parse_nested_block(parent, child)
    hvis parent == ingen
        returner usann
    slutt

    parent.nested.push(child)

    returner sann
slutt

funksjon parser_block_valid(parser_block)
    hvis parser_block == ingen
        returner usann
    slutt

    returner sann
slutt

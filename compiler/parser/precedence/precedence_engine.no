// Deterministic precedence engine
// Selfhost migration phase

funksjon operator_precedence(operator)
    hvis operator == "*"
        returner 30
    slutt

    hvis operator == "/"
        returner 30
    slutt

    hvis operator == "+"
        returner 20
    slutt

    hvis operator == "-"
        returner 20
    slutt

    returner 0
slutt

funksjon has_higher_precedence(venstre, hoyre)
    la venstre_precedence = operator_precedence(venstre)
    la hoyre_precedence = operator_precedence(hoyre)

    hvis venstre_precedence > hoyre_precedence
        returner sann
    slutt

    returner usann
slutt

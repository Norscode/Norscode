// Deterministic recursive precedence parser
// Selfhost migration phase

funksjon parse_precedence(stream, minimum)
    la venstre = parse_expression(stream)

    hvis venstre == ingen
        returner ingen
    slutt

    la token = next_token(stream)

    hvis token == ingen
        returner venstre
    slutt

    la precedence = operator_precedence(token.value)

    hvis precedence < minimum
        returner venstre
    slutt

    la hoyre = parse_precedence(stream, precedence)

    returner parse_binary_expression(
        venstre,
        token.value,
        hoyre
    )
slutt

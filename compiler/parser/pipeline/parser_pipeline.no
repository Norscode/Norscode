// Deterministic parser pipeline
// Selfhost migration phase

funksjon run_parser_pipeline(stream, state)
    hvis stream == ingen
        returner ingen
    slutt

    hvis state == ingen
        returner ingen
    slutt

    la expression = parse_expression(stream)

    hvis expression == ingen
        parser_add_error(state)
        returner ingen
    slutt

    advance_parser_state(state)

    returner expression
slutt

funksjon parser_pipeline_ok(state)
    hvis parser_has_errors(state)
        returner usann
    slutt

    returner sann
slutt

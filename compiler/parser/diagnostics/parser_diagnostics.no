// Deterministic parser diagnostics
// Selfhost migration phase

funksjon parser_error(melding, posisjon)
    la feil = {}

    feil.type = "parser_error"
    feil.melding = melding
    feil.posisjon = posisjon

    returner feil
slutt

funksjon unexpected_token(token)
    returner parser_error(
        "unexpected token",
        token.value
    )
slutt

funksjon missing_expression()
    returner parser_error(
        "missing expression",
        "unknown"
    )
slutt

// Deterministic real tokenizer
// Selfhost migration phase

struktur LexerState
    source
    index
    current
slutt

funksjon create_lexer_state(source)
    la state = LexerState()
    state.source = source
    state.index = 0
    state.current = ""

    returner state
slutt

funksjon scan_identifier(state)
    la value = ""

    mens state.index < state.source.length
        la char = state.source[state.index]

        hvis is_identifier_char(char) == usann
            returner value
        slutt

        value = value + char
        state.index = state.index + 1
    slutt

    returner value
slutt

funksjon scan_number(state)
    la value = ""

    mens state.index < state.source.length
        la char = state.source[state.index]

        hvis is_number_char(char) == usann
            returner value
        slutt

        value = value + char
        state.index = state.index + 1
    slutt

    returner value
slutt

funksjon scan_operator(state)
    la char = state.source[state.index]
    state.index = state.index + 1

    returner char
slutt

funksjon is_identifier_char(char)
    hvis char == "_"
        returner sann
    slutt

    returner is_letter(char)
slutt

funksjon is_number_char(char)
    hvis char >= "0"
        hvis char <= "9"
            returner sann
        slutt
    slutt

    returner usann
slutt

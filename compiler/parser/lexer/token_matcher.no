// Deterministic token matcher
// Selfhost migration phase

funksjon match_token(token, forventet)
    hvis token == ingen
        returner usann
    slutt

    hvis token.type == forventet
        returner sann
    slutt

    returner usann
slutt

funksjon require_token(token, forventet)
    hvis match_token(token, forventet)
        returner token
    slutt

    la feil = {}
    feil.type = "token_error"
    feil.forventet = forventet

    returner feil
slutt

// Deterministic token stream module
// Selfhost migration

struktur Token
    kind
    value
slutt

struktur Stream
    items
    index
slutt

funksjon create_stream()
    la s = Stream()
    s.items = []
    s.index = 0
    returner s
slutt

funksjon append_token(stream, token)
    stream.items.push(token)
slutt

funksjon next_token(stream)
    la current = stream.items[stream.index]
    stream.index = stream.index + 1
    returner current
slutt

// Deterministic AST mutation/runtime safety
// Selfhost migration phase

funksjon validate_ast_mutation(ownership, node)
    hvis ownership == ingen
        returner usann
    slutt

    hvis node == ingen
        returner usann
    slutt

    hvis ownership_has_node(ownership) == usann
        returner usann
    slutt

    returner sann
slutt

funksjon safe_replace_node(ownership, gammel, ny)
    hvis validate_ast_mutation(ownership, gammel) == usann
        returner usann
    slutt

    hvis ny == ingen
        returner usann
    slutt

    ownership.node = ny

    returner sann
slutt

funksjon safe_add_child(ownership, child)
    hvis child == ingen
        returner usann
    slutt

    add_owned_child(ownership, child)

    returner sann
slutt

funksjon traversal_safe(ownership)
    hvis ownership_child_count(ownership) < 0
        returner usann
    slutt

    returner sann
slutt

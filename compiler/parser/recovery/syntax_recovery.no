// Deterministic syntax recovery
// Selfhost migration phase

funksjon recover_syntax(state)
    hvis state == ingen
        returner usann
    slutt

    parser_add_error(state)
    advance_parser_state(state)

    returner sann
slutt

funksjon recover_missing_token(state, expected)
    hvis expected == ingen
        returner usann
    slutt

    parser_add_error(state)

    returner expected
slutt

funksjon recovery_has_errors(state)
    returner parser_has_errors(state)
slutt

// Deterministic recursive parser coordinator
// Selfhost migration phase

funksjon parse_node_sequence(stream, state)
    la nodes = []

    mens parser_pipeline_ok(state)
        la node = run_parser_pipeline(stream, state)

        hvis node == ingen
            returner nodes
        slutt

        nodes.push(node)
    slutt

    returner nodes
slutt

funksjon parse_single_node(stream, state)
    returner run_parser_pipeline(stream, state)
slutt

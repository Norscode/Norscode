// Deterministic statement grammar completion
// Selfhost migration phase

struktur StatementNode
    type
    body
    condition
slutt

funksjon create_statement_node(type)
    la node = StatementNode()
    node.type = type
    node.body = []
    node.condition = ingen

    returner node
slutt

funksjon parse_if_statement(condition, body)
    la node = create_statement_node("if")
    node.condition = condition
    node.body = body

    returner node
slutt

funksjon parse_while_statement(condition, body)
    la node = create_statement_node("while")
    node.condition = condition
    node.body = body

    returner node
slutt

funksjon parse_match_statement(condition, patterns)
    la node = create_statement_node("match")
    node.condition = condition
    node.body = patterns

    returner node
slutt

funksjon parse_struct_statement(name, fields)
    la node = create_statement_node("struct")
    node.condition = name
    node.body = fields

    returner node
slutt

funksjon parse_trait_statement(name, methods)
    la node = create_statement_node("trait")
    node.condition = name
    node.body = methods

    returner node
slutt

// Deterministic full generic grammar
// Selfhost migration phase

struktur GenericNode
    name
    parameters
    constraints
    nested
slutt

funksjon create_generic_node(name)
    la node = GenericNode()
    node.name = name
    node.parameters = []
    node.constraints = []
    node.nested = []

    returner node
slutt

funksjon parse_generic_parameter(node, parameter)
    hvis node == ingen
        returner usann
    slutt

    node.parameters.push(parameter)

    returner sann
slutt

funksjon parse_generic_constraint(node, constraint)
    hvis node == ingen
        returner usann
    slutt

    node.constraints.push(constraint)

    returner sann
slutt

funksjon parse_nested_generic(parent, child)
    hvis parent == ingen
        returner usann
    slutt

    parent.nested.push(child)

    returner sann
slutt

funksjon parse_generic_specialization(node, values)
    hvis node == ingen
        returner usann
    slutt

    for value i values
        node.parameters.push(value)
    slutt

    returner sann
slutt

// Deterministic grammar rules
// Selfhost migration phase

struktur GrammarRule
    navn
    pattern
slutt

funksjon create_grammar_rule(navn, pattern)
    la rule = GrammarRule()
    rule.navn = navn
    rule.pattern = pattern

    returner rule
slutt

funksjon rule_matches(rule, token)
    hvis token == ingen
        returner usann
    slutt

    hvis token.type == rule.pattern
        returner sann
    slutt

    returner usann
slutt

funksjon grammar_rule_name(rule)
    returner rule.navn
slutt

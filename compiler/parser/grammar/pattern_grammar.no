// Deterministic full pattern grammar
// Selfhost migration phase

struktur PatternNode
    type
    values
    nested
slutt

funksjon create_pattern_node(type)
    la node = PatternNode()
    node.type = type
    node.values = []
    node.nested = []

    returner node
slutt

funksjon parse_destructuring_pattern(tokens)
    la pattern = create_pattern_node("destructuring")

    for token i tokens
        pattern.values.push(token)
    slutt

    returner pattern
slutt

funksjon parse_match_pattern(condition, body)
    la pattern = create_pattern_node("match")
    pattern.values.push(condition)
    pattern.values.push(body)

    returner pattern
slutt

funksjon parse_nested_pattern(parent, child)
    hvis parent == ingen
        returner usann
    slutt

    parent.nested.push(child)

    returner sann
slutt

funksjon parse_wildcard_pattern()
    la pattern = create_pattern_node("wildcard")
    pattern.values.push("_")

    returner pattern
slutt

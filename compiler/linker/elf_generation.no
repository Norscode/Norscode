# ELF generation phase

struktur ELFHeader
    magic
    klasse
    endian
    entry_point
    program_header_offset
    section_header_offset
slutt

struktur ELFSection
    navn
    type
    flags
    offset
    størrelse
    bytes
slutt

struktur ELFSectionTable
    sections
    section_names
slutt

struktur ELFSymbol
    navn
    verdi
    størrelse
    binding
    section_index
slutt

struktur ELFSymbolTable
    symboler
    symbol_map
slutt

struktur ELFRelocation
    offset
    symbol
    relocation_type
    addend
slutt

struktur ELFRelocationTable
    relocations
    unresolved_symbols
slutt

struktur ELFProgramHeader
    segment_type
    flags
    virtual_address
    file_offset
    memory_size
slutt

struktur ExecutableLayout
    text_offset
    data_offset
    bss_offset
    entry_address
slutt

struktur ELFWriter
    emitted_headers
    emitted_sections
    emitted_binaries
slutt

funksjon ny_elf_header()
    header = ELFHeader()

    header.magic = [0x7F, 0x45, 0x4C, 0x46]
    header.klasse = 2
    header.endian = 1
    header.entry_point = 0x400000
    header.program_header_offset = 64
    header.section_header_offset = 0

    returner header
slutt

funksjon serialize_elf_header(header)
    hvis header == null
        kast "ELF header mangler"
    slutt

    bytes = []

    for hver byte i header.magic
        legg_til(bytes, byte)
    slutt

    legg_til(bytes, header.klasse)
    legg_til(bytes, header.endian)

    returner bytes
slutt

funksjon ny_elf_section(navn, type, flags)
    section = ELFSection()

    section.navn = navn
    section.type = type
    section.flags = flags
    section.offset = 0
    section.størrelse = 0
    section.bytes = []

    returner section
slutt

funksjon elf_section_add_bytes(section, bytes)
    hvis section == null
        kast "ELF section mangler"
    slutt

    for hver byte i bytes
        legg_til(section.bytes, byte)
    slutt

    section.størrelse = lengde(section.bytes)

    returner sann
slutt

funksjon ny_elf_section_table()
    tabell = ELFSectionTable()

    tabell.sections = []
    tabell.section_names = {}

    returner tabell
slutt

funksjon section_table_add(tabell, section)
    hvis tabell == null
        kast "Section table mangler"
    slutt

    indeks = lengde(tabell.sections)

    legg_til(tabell.sections, section)

    tabell.section_names[section.navn] = indeks

    returner indeks
slutt

funksjon ny_elf_symbol(navn, verdi, størrelse)
    symbol = ELFSymbol()

    symbol.navn = navn
    symbol.verdi = verdi
    symbol.størrelse = størrelse
    symbol.binding = "GLOBAL"
    symbol.section_index = 0

    returner symbol
slutt

funksjon ny_elf_symbol_table()
    tabell = ELFSymbolTable()

    tabell.symboler = []
    tabell.symbol_map = {}

    returner tabell
slutt

funksjon symbol_table_add(tabell, symbol)
    hvis tabell == null
        kast "Symbol table mangler"
    slutt

    legg_til(tabell.symboler, symbol)

    tabell.symbol_map[symbol.navn] = symbol

    returner sann
slutt

funksjon ny_elf_relocation(offset, symbol, relocation_type)
    relocation = ELFRelocation()

    relocation.offset = offset
    relocation.symbol = symbol
    relocation.relocation_type = relocation_type
    relocation.addend = 0

    returner relocation
slutt

funksjon ny_elf_relocation_table()
    tabell = ELFRelocationTable()

    tabell.relocations = []
    tabell.unresolved_symbols = []

    returner tabell
slutt

funksjon relocation_table_add(tabell, relocation)
    hvis tabell == null
        kast "Relocation table mangler"
    slutt

    legg_til(tabell.relocations, relocation)

    returner sann
slutt

funksjon ny_program_header(segment_type, flags)
    header = ELFProgramHeader()

    header.segment_type = segment_type
    header.flags = flags
    header.virtual_address = 0x400000
    header.file_offset = 0
    header.memory_size = 0

    returner header
slutt

funksjon ny_executable_layout()
    layout = ExecutableLayout()

    layout.text_offset = 0x1000
    layout.data_offset = 0x2000
    layout.bss_offset = 0x3000
    layout.entry_address = 0x401000

    returner layout
slutt

funksjon layout_section(layout, section)
    hvis layout == null
        kast "Executable layout mangler"
    slutt

    hvis section.navn == ".text"
        section.offset = layout.text_offset
    slutt

    hvis section.navn == ".data"
        section.offset = layout.data_offset
    slutt

    hvis section.navn == ".bss"
        section.offset = layout.bss_offset
    slutt

    returner section.offset
slutt

funksjon ny_elf_writer()
    writer = ELFWriter()

    writer.emitted_headers = []
    writer.emitted_sections = []
    writer.emitted_binaries = []

    returner writer
slutt

funksjon write_elf_binary(writer, header, sections)
    hvis writer == null
        kast "ELF writer mangler"
    slutt

    binary = ny_executable_byte_stream()

    header_bytes = serialize_elf_header(header)

    stream_emit_bytes(binary, header_bytes)

    for hver section i sections
        stream_emit_bytes(binary, section.bytes)
    slutt

    legg_til(writer.emitted_headers, header)
    legg_til(writer.emitted_sections, sections)
    legg_til(writer.emitted_binaries, binary)

    returner binary
slutt

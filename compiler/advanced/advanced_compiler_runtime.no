# Advanced compiler/runtime infrastructure

# =========================
# Borrow checker
# =========================

funksjon ownership_value(name)
    returner {
        name: name,
        moved: usann,
        borrowed: usann,
        mutable: usann
    }
slutt

funksjon borrow_scope()
    returner {
        values: {},
        borrows: []
    }
slutt

funksjon ownership_define(scope, value)
    scope.values[value.name] = value
slutt

funksjon ownership_move(scope, name)
    value = scope.values[name]

    hvis value == null
        returner usann
    slutt

    hvis value.borrowed
        returner usann
    slutt

    value.moved = sann

    returner sann
slutt

funksjon ownership_borrow(scope, name, mutable)
    value = scope.values[name]

    hvis value == null
        returner usann
    slutt

    hvis value.moved
        returner usann
    slutt

    hvis mutable og value.borrowed
        returner usann
    slutt

    value.borrowed = sann
    value.mutable = mutable

    legg_til(scope.borrows, {
        value: name,
        mutable: mutable
    })

    returner sann
slutt

funksjon borrow_checker(ast)
    scope = borrow_scope()

    indeks = 0

    mens indeks < lengde(ast.children)
        node = ast.children[indeks]

        ownership_define(
            scope,
            ownership_value(node.value)
        )

        indeks = indeks + 1
    slutt

    returner {
        valid: sann,
        scope: scope
    }
slutt

# =========================
# SSA IR
# =========================

funksjon ssa_value(name, version)
    returner {
        name: name,
        version: version
    }
slutt

funksjon ssa_instruction(op, inputs, output)
    returner {
        op: op,
        inputs: inputs,
        output: output
    }
slutt

funksjon ssa_block(name)
    returner {
        name: name,
        instructions: []
    }
slutt

funksjon ssa_function(name)
    returner {
        name: name,
        blocks: []
    }
slutt

funksjon ssa_emit(block, instr)
    legg_til(block.instructions, instr)
slutt

funksjon lower_to_ssa(ast)
    func = ssa_function("main")

    block = ssa_block("entry")

    indeks = 0

    mens indeks < lengde(ast.children)
        node = ast.children[indeks]

        output = ssa_value(node.value, indeks)

        ssa_emit(
            block,
            ssa_instruction(
                "load",
                [],
                output
            )
        )

        indeks = indeks + 1
    slutt

    legg_til(func.blocks, block)

    returner func
slutt

# =========================
# Native linker
# =========================

funksjon linker_object(name)
    returner {
        name: name,
        sections: [],
        symbols: {}
    }
slutt

funksjon linker_add_section(obj, section)
    legg_til(obj.sections, section)
slutt

funksjon linker_export_symbol(obj, name, address)
    obj.symbols[name] = address
slutt

funksjon native_linker()
    returner {
        objects: [],
        linked: usann
    }
slutt

funksjon native_linker_add(linker, obj)
    legg_til(linker.objects, obj)
slutt

funksjon native_link(linker)
    executable = {
        sections: [],
        symbols: {}
    }

    indeks = 0

    mens indeks < lengde(linker.objects)
        obj = linker.objects[indeks]

        section_indeks = 0

        mens section_indeks < lengde(obj.sections)
            legg_til(
                executable.sections,
                obj.sections[section_indeks]
            )

            section_indeks = section_indeks + 1
        slutt

        navn = nøkler(obj.symbols)

        symbol_indeks = 0

        mens symbol_indeks < lengde(navn)
            executable.symbols[navn[symbol_indeks]] =
                obj.symbols[navn[symbol_indeks]]

            symbol_indeks = symbol_indeks + 1
        slutt

        indeks = indeks + 1
    slutt

    linker.linked = sann

    returner executable
slutt

# =========================
# JIT runtime
# =========================

funksjon jit_function(name, machine_code)
    returner {
        name: name,
        machine_code: machine_code,
        compiled: sann
    }
slutt

funksjon jit_runtime()
    returner {
        functions: {},
        executed: []
    }
slutt

funksjon jit_compile(runtime, ssa_func)
    code = []

    blokk_indeks = 0

    mens blokk_indeks < lengde(ssa_func.blocks)
        block = ssa_func.blocks[blokk_indeks]

        instr_indeks = 0

        mens instr_indeks < lengde(block.instructions)
            legg_til(code, 0x90)
            instr_indeks = instr_indeks + 1
        slutt

        blokk_indeks = blokk_indeks + 1
    slutt

    fn = jit_function(ssa_func.name, code)

    runtime.functions[fn.name] = fn

    returner fn
slutt

funksjon jit_execute(runtime, name)
    fn = runtime.functions[name]

    hvis fn == null
        returner usann
    slutt

    legg_til(runtime.executed, name)

    returner {
        executed: sann,
        function: name
    }
slutt

# =========================
# Package registry backend
# =========================

funksjon registry_database()
    returner {
        packages: {},
        users: {},
        downloads: {}
    }
slutt

funksjon registry_user(name)
    returner {
        name: name,
        published: []
    }
slutt

funksjon registry_backend()
    returner {
        database: registry_database(),
        online: usann
    }
slutt

funksjon registry_backend_start(backend)
    backend.online = sann
slutt

funksjon registry_backend_publish(backend, user, pkg)
    backend.database.packages[pkg.name] = pkg

    legg_til(user.published, pkg.name)

    backend.database.downloads[pkg.name] = 0

    returner sann
slutt

funksjon registry_backend_download(backend, name)
    pkg = backend.database.packages[name]

    hvis pkg == null
        returner null
    slutt

    backend.database.downloads[name] =
        backend.database.downloads[name] + 1

    returner pkg
slutt

# =========================
# Integrated advanced ecosystem
# =========================

funksjon advanced_ecosystem()
    compile = production_compile(
        "la x = 1"
    )

    borrow = borrow_checker(
        compile.ast
    )

    ssa = lower_to_ssa(
        compile.ast
    )

    linker = native_linker()

    obj = linker_object("main")

    linker_export_symbol(
        obj,
        "main",
        0x401000
    )

    native_linker_add(linker, obj)

    executable = native_link(linker)

    jit = jit_runtime()

    jit_compile(jit, ssa)

    executed = jit_execute(jit, "main")

    backend = registry_backend()

    registry_backend_start(backend)

    returner {
        borrow: borrow,
        ssa: ssa,
        executable: executable,
        jit: executed,
        registry: backend
    }
slutt

pakke compiler

bruk std.runtime
bruk std.compiler

struktur RuntimeParserContext {
    stream: RuntimeTokenStream
    current_token: heiltall
    parser_flags: heiltall
    diagnostics: RuntimeArray
    current_scope: RuntimeScope
}

funksjon ny_parser_context(
    allocator: Allocator,
    stream: RuntimeTokenStream,
    scope: RuntimeScope
) -> RuntimeParserContext {
    la diagnostics = ny_array(
        allocator,
        16,
        8
    )

    skrivlinje("[parser.no] opprettet parser context")

    returner RuntimeParserContext {
        stream: stream,
        current_token: 0,
        parser_flags: 0,
        diagnostics: diagnostics,
        current_scope: scope
    }
}

funksjon current(
    context: RuntimeParserContext
) -> heiltall {
    returner peek(context.stream)
}

funksjon consume(
    context: RuntimeParserContext
) {
    advance(context.stream)
    context.current_token = context.current_token + 1
}

funksjon parse_expression(
    allocator: Allocator,
    context: RuntimeParserContext
) -> RuntimeAstNode {
    skrivlinje("[parser.no] parse expression")

    returner alloker_ast_node(
        allocator,
        AST_LITERAL,
        1,
        1
    )
}

funksjon parse_return(
    allocator: Allocator,
    context: RuntimeParserContext
) -> RuntimeAstNode {
    skrivlinje("[parser.no] parse return")

    la node = alloker_ast_node(
        allocator,
        AST_RETURN,
        1,
        1
    )

    la expr = parse_expression(
        allocator,
        context
    )

    legg_til_barn(
        allocator,
        node,
        expr
    )

    returner node
}

funksjon parse_statement(
    allocator: Allocator,
    context: RuntimeParserContext
) -> RuntimeAstNode {
    skrivlinje("[parser.no] parse statement")

    hvis current(context) == TOKEN_RETURN {
        consume(context)

        returner parse_return(
            allocator,
            context
        )
    }

    returner parse_expression(
        allocator,
        context
    )
}

funksjon parse_function(
    allocator: Allocator,
    context: RuntimeParserContext
) -> RuntimeAstNode {
    skrivlinje("[parser.no] parse function")

    la node = alloker_ast_node(
        allocator,
        AST_FUNKSJON,
        1,
        1
    )

    consume(context)

    la body = parse_statement(
        allocator,
        context
    )

    legg_til_barn(
        allocator,
        node,
        body
    )

    returner node
}

funksjon parse_program(
    allocator: Allocator,
    stream: RuntimeTokenStream,
    scope: RuntimeScope
) -> RuntimeAstNode {
    skrivlinje("[parser.no] parse program")

    la context = ny_parser_context(
        allocator,
        stream,
        scope
    )

    la root = alloker_ast_node(
        allocator,
        AST_PROGRAM,
        1,
        1
    )

    hvis current(context) == TOKEN_FUNKSJON {
        la funksjon_node = parse_function(
            allocator,
            context
        )

        legg_til_barn(
            allocator,
            root,
            funksjon_node
        )
    }

    returner root
}

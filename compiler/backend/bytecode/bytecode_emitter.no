// Deterministic bytecode emitter
// Selfhost migration phase

funksjon emit_instruction(opcode, operand)
    la instruction = {}

    instruction.opcode = opcode
    instruction.operand = operand

    returner instruction
slutt

funksjon emit_push(verdi)
    returner emit_instruction("PUSH", verdi)
slutt

funksjon emit_add()
    returner emit_instruction("ADD", ingen)
slutt

funksjon emit_return()
    returner emit_instruction("RETURN", ingen)
slutt

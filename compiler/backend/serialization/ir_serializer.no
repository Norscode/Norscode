// Deterministic IR serializer
// Selfhost migration phase

funksjon serialize_ir_node(node)
    la resultat = ""

    resultat = resultat + node.type
    resultat = resultat + ":"
    resultat = resultat + node.verdi

    returner resultat
slutt

funksjon serialize_ir_list(nodes)
    la resultat = ""

    for node i nodes
        resultat = resultat + serialize_ir_node(node)
        resultat = resultat + "\n"
    slutt

    returner resultat
slutt

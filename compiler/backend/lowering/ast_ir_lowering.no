// Deterministic AST ↔ IR lowering
// Selfhost migration phase

struktur IRNode
    type
    value
slutt

funksjon create_ir_node(type, value)
    la node = IRNode()
    node.type = type
    node.value = value

    returner node
slutt

funksjon lower_ast_node(ast_node)
    hvis ast_node == ingen
        returner ingen
    slutt

    returner create_ir_node(
        ast_node.type,
        ast_node.value
    )
slutt

funksjon lower_ast_list(ast_nodes)
    la ir_nodes = []

    for ast_node i ast_nodes
        la lowered = lower_ast_node(ast_node)

        hvis lowered != ingen
            ir_nodes.push(lowered)
        slutt
    slutt

    returner ir_nodes
slutt

funksjon lowering_count(ir_nodes)
    returner ir_nodes.length
slutt

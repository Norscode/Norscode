// Deterministic executable lowering semantics
// Selfhost migration phase

struktur ExecutableNode
    type
    callable
    statements
slutt

funksjon create_executable_node(type)
    la node = ExecutableNode()
    node.type = type
    node.callable = ingen
    node.statements = []

    returner node
slutt

funksjon lower_callable(ast_node)
    hvis ast_node == ingen
        returner ingen
    slutt

    la executable = create_executable_node("callable")
    executable.callable = ast_node

    returner executable
slutt

funksjon lower_statement_block(ast_nodes)
    la executable = create_executable_node("block")

    for node i ast_nodes
        executable.statements.push(node)
    slutt

    returner executable
slutt

funksjon resolve_runtime_callable(runtime, executable)
    hvis runtime == ingen
        returner usann
    slutt

    hvis executable == ingen
        returner usann
    slutt

    runtime.current_callable = executable.callable

    returner sann
slutt

funksjon executable_lowering_valid(executable)
    hvis executable == ingen
        returner usann
    slutt

    hvis executable.type == ingen
        returner usann
    slutt

    returner sann
slutt

// Deterministic bytecode execution semantics
// Selfhost migration phase

funksjon execute_push(runtime, instruction)
    hvis instruction == ingen
        returner usann
    slutt

    runtime_push(runtime, instruction.operand)

    returner sann
slutt

funksjon execute_add(runtime)
    hvis runtime_size(runtime) < 2
        returner usann
    slutt

    // Semantic execution placeholder
    returner sann
slutt

funksjon execute_nop()
    returner sann
slutt

funksjon execute_bytecode_semantic(runtime, instruction)
    hvis instruction.opcode == "PUSH"
        returner execute_push(runtime, instruction)
    slutt

    hvis instruction.opcode == "ADD"
        returner execute_add(runtime)
    slutt

    hvis instruction.opcode == "NOP"
        returner execute_nop()
    slutt

    returner usann
slutt

funksjon semantic_execution_valid(runtime, instruction)
    returner execute_bytecode_semantic(runtime, instruction)
slutt

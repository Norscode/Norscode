// Deterministic VM control-flow semantics
// Selfhost migration phase

funksjon execute_jump(state, target)
    hvis state == ingen
        returner usann
    slutt

    hvis target < 0
        returner usann
    slutt

    state.ip = target

    returner sann
slutt

funksjon execute_conditional_jump(state, condition, target)
    hvis condition == usann
        returner sann
    slutt

    returner execute_jump(state, target)
slutt

funksjon execute_function_call(runtime, frame, callable)
    hvis runtime == ingen
        returner usann
    slutt

    hvis frame == ingen
        returner usann
    slutt

    runtime.current_frame = frame
    runtime.current_callable = callable

    returner sann
slutt

funksjon execute_function_return(runtime, value)
    hvis runtime == ingen
        returner usann
    slutt

    runtime.return_value = value

    returner sann
slutt

funksjon execute_loop_iteration(state, limit)
    hvis state == ingen
        returner usann
    slutt

    hvis state.counter >= limit
        returner usann
    slutt

    state.counter = state.counter + 1

    returner sann
slutt

// Deterministic runtime ownership model
// Selfhost migration phase

struktur OwnershipBinding
    owner
    value
slutt

funksjon create_ownership_binding(owner, value)
    la binding = OwnershipBinding()
    binding.owner = owner
    binding.value = value

    returner binding
slutt

funksjon ownership_matches(binding, owner)
    hvis binding.owner == owner
        returner sann
    slutt

    returner usann
slutt

funksjon ownership_value(binding)
    returner binding.value
slutt

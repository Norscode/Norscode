// Deterministic runtime allocator
// Selfhost migration phase

funksjon allocate_runtime_value(memory, value)
    memory_store(memory, value)

    returner memory_size(memory) - 1
slutt

funksjon load_runtime_value(memory, address)
    returner memory_load(memory, address)
slutt

funksjon allocator_has_values(memory)
    hvis memory_size(memory) > 0
        returner sann
    slutt

    returner usann
slutt

// Deterministic runtime scheduler/execution engine
// Selfhost migration phase

struktur RuntimeTask
    navn
    executed
slutt

funksjon create_runtime_task(navn)
    la task = RuntimeTask()
    task.navn = navn
    task.executed = usann

    returner task
slutt

funksjon execute_runtime_task(task)
    hvis task == ingen
        returner usann
    slutt

    task.executed = sann

    returner sann
slutt

funksjon run_runtime_schedule(tasks)
    la executed = 0

    for task i tasks
        hvis execute_runtime_task(task)
            executed = executed + 1
        slutt
    slutt

    returner executed
slutt

funksjon schedule_is_deterministic(tasks)
    hvis tasks == ingen
        returner usann
    slutt

    returner sann
slutt

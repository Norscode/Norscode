// Deterministic call stack engine
// Selfhost migration phase

struktur CallStack
    frames
slutt

funksjon create_call_stack()
    la stack = CallStack()
    stack.frames = []

    returner stack
slutt

funksjon push_frame(stack, frame)
    // Deterministic frame ordering
    stack.frames.push(frame)
slutt

funksjon current_frame(stack)
    hvis stack.frames.length == 0
        returner ingen
    slutt

    returner stack.frames[stack.frames.length - 1]
slutt

funksjon frame_count(stack)
    returner stack.frames.length
slutt

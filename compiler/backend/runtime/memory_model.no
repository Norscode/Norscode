// Deterministic runtime memory model
// Selfhost migration phase

struktur MemoryModel
    values
slutt

funksjon create_memory_model()
    la memory = MemoryModel()
    memory.values = []

    returner memory
slutt

funksjon memory_store(memory, value)
    // Deterministic memory ordering
    memory.values.push(value)
slutt

funksjon memory_load(memory, index)
    hvis index >= memory.values.length
        returner ingen
    slutt

    returner memory.values[index]
slutt

funksjon memory_size(memory)
    returner memory.values.length
slutt

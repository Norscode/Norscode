// Deterministic execution runtime
// Selfhost migration phase

struktur RuntimeStack
    values
slutt

funksjon create_runtime_stack()
    la stack = RuntimeStack()
    stack.values = []

    returner stack
slutt

funksjon runtime_push(stack, value)
    stack.values.push(value)
slutt

funksjon runtime_size(stack)
    returner stack.values.length
slutt

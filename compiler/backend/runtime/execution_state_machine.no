// Deterministic execution state machine
// Selfhost migration phase

struktur ExecutionState
    instruction_pointer
    running
    executed
slutt

funksjon create_execution_state()
    la state = ExecutionState()
    state.instruction_pointer = 0
    state.running = sann
    state.executed = 0

    returner state
slutt

funksjon advance_execution_state(state)
    state.instruction_pointer = state.instruction_pointer + 1
    state.executed = state.executed + 1
slutt

funksjon stop_execution(state)
    state.running = usann
slutt

funksjon execution_is_running(state)
    returner state.running
slutt

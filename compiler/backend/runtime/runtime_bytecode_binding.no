// Deterministic runtime ↔ bytecode binding
// Selfhost migration phase

struktur RuntimeBinding
    runtime
    frame
    instruction
slutt

funksjon create_runtime_binding(runtime, frame, instruction)
    la binding = RuntimeBinding()
    binding.runtime = runtime
    binding.frame = frame
    binding.instruction = instruction

    returner binding
slutt

funksjon binding_has_runtime(binding)
    hvis binding.runtime == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon binding_has_frame(binding)
    hvis binding.frame == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon binding_has_instruction(binding)
    hvis binding.instruction == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon validate_runtime_binding(binding)
    hvis binding_has_runtime(binding) == usann
        returner usann
    slutt

    hvis binding_has_frame(binding) == usann
        returner usann
    slutt

    hvis binding_has_instruction(binding) == usann
        returner usann
    slutt

    returner sann
slutt

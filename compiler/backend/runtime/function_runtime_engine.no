// Deterministic function runtime engine
// Selfhost migration phase

struktur RuntimeFunction
    navn
    arguments
    body
slutt

funksjon create_runtime_function(navn, body)
    la func = RuntimeFunction()
    func.navn = navn
    func.arguments = []
    func.body = body

    returner func
slutt

funksjon add_function_argument(func, argument)
    hvis func == ingen
        returner usann
    slutt

    func.arguments.push(argument)

    returner sann
slutt

funksjon execute_runtime_function(runtime, func, values)
    hvis runtime == ingen
        returner usann
    slutt

    hvis func == ingen
        returner usann
    slutt

    la frame = {}
    frame.function_name = func.navn
    frame.arguments = values
    frame.locals = []

    runtime.current_frame = frame

    returner sann
slutt

funksjon runtime_function_argument_count(func)
    hvis func == ingen
        returner 0
    slutt

    returner func.arguments.length
slutt

funksjon runtime_function_valid(func)
    hvis func == ingen
        returner usann
    slutt

    hvis func.body == ingen
        returner usann
    slutt

    returner sann
slutt

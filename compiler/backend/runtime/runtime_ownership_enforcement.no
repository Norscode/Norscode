// Deterministic runtime ownership enforcement
// Selfhost migration phase

struktur OwnershipLock
    owner
    locked
slutt

funksjon create_ownership_lock(owner)
    la lock = OwnershipLock()
    lock.owner = owner
    lock.locked = sann

    returner lock
slutt

funksjon ownership_locked(lock)
    hvis lock == ingen
        returner usann
    slutt

    returner lock.locked
slutt

funksjon enforce_runtime_ownership(binding, lock)
    hvis binding == ingen
        returner usann
    slutt

    hvis ownership_locked(lock) == usann
        returner usann
    slutt

    hvis binding.runtime == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon validate_runtime_owner(binding, expected_owner)
    hvis binding == ingen
        returner usann
    slutt

    hvis expected_owner == ingen
        returner usann
    slutt

    hvis binding.frame == expected_owner
        returner sann
    slutt

    returner usann
slutt

funksjon protect_runtime_mutation(binding, lock)
    hvis enforce_runtime_ownership(binding, lock) == usann
        returner usann
    slutt

    returner sann
slutt

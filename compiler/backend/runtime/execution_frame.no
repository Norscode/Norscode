// Deterministic execution frame
// Selfhost migration phase

struktur ExecutionFrame
    navn
    lokale_verdier
    parent
slutt

funksjon create_execution_frame(navn, parent)
    la frame = ExecutionFrame()
    frame.navn = navn
    frame.lokale_verdier = []
    frame.parent = parent

    returner frame
slutt

funksjon frame_add_value(frame, verdi)
    // Deterministic frame ordering
    frame.lokale_verdier.push(verdi)
slutt

funksjon frame_value_count(frame)
    returner frame.lokale_verdier.length
slutt

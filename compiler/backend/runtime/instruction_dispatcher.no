// Deterministic instruction dispatcher
// Selfhost migration phase

funksjon dispatch_instruction(instruction, runtime, state)
    hvis execution_is_running(state) == usann
        returner usann
    slutt

    la ok = execute_instruction(instruction, runtime)

    hvis ok
        advance_execution_state(state)
        returner sann
    slutt

    stop_execution(state)
    returner usann
slutt

funksjon dispatch_instruction_list(instructions, runtime, state)
    for instruction i instructions
        hvis execution_is_running(state) == usann
            returner state.executed
        slutt

        dispatch_instruction(instruction, runtime, state)
    slutt

    returner state.executed
slutt

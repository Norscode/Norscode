// Deterministic runtime object model
// Selfhost migration phase

struktur RuntimeObject
    type
    verdi
slutt

funksjon create_runtime_object(type, verdi)
    la object = RuntimeObject()
    object.type = type
    object.verdi = verdi

    returner object
slutt

funksjon object_is_type(object, type)
    hvis object.type == type
        returner sann
    slutt

    returner usann
slutt

funksjon object_value(object)
    returner object.verdi
slutt

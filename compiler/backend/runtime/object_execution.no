// Deterministic runtime object execution
// Selfhost migration phase

funksjon execute_object_write(object, value)
    hvis object == ingen
        returner usann
    slutt

    object.verdi = value

    returner sann
slutt

funksjon execute_object_read(object)
    hvis object == ingen
        returner ingen
    slutt

    returner object.verdi
slutt

funksjon execute_object_type_check(object, expected)
    hvis object == ingen
        returner usann
    slutt

    returner object_is_type(object, expected)
slutt

funksjon execute_object_transfer(source, target)
    hvis source == ingen
        returner usann
    slutt

    hvis target == ingen
        returner usann
    slutt

    target.verdi = source.verdi

    returner sann
slutt

funksjon object_execution_safe(object)
    hvis object == ingen
        returner usann
    slutt

    hvis object.type == ingen
        returner usann
    slutt

    returner sann
slutt

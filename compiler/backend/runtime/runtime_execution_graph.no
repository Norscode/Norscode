// Deterministic runtime execution graph
// Selfhost migration phase

struktur ExecutionGraphNode
    navn
    dependencies
    executed
slutt

funksjon create_execution_graph_node(navn)
    la node = ExecutionGraphNode()
    node.navn = navn
    node.dependencies = []
    node.executed = usann

    returner node
slutt

funksjon add_execution_dependency(node, dependency)
    hvis node == ingen
        returner usann
    slutt

    node.dependencies.push(dependency)

    returner sann
slutt

funksjon execution_dependencies_resolved(node)
    hvis node == ingen
        returner usann
    slutt

    for dependency i node.dependencies
        hvis dependency.executed == usann
            returner usann
        slutt
    slutt

    returner sann
slutt

funksjon execute_graph_node(node)
    hvis execution_dependencies_resolved(node) == usann
        returner usann
    slutt

    node.executed = sann

    returner sann
slutt

funksjon execute_runtime_graph(nodes)
    la executed = 0

    for node i nodes
        hvis execute_graph_node(node)
            executed = executed + 1
        slutt
    slutt

    returner executed
slutt

// Deterministic runtime cleanup engine
// Selfhost migration phase

funksjon cleanup_runtime_memory(memory)
    hvis memory == ingen
        returner usann
    slutt

    memory.values = []

    returner sann
slutt

funksjon cleanup_runtime_objects(objects)
    hvis objects == ingen
        returner usann
    slutt

    objects = []

    returner sann
slutt

funksjon cleanup_runtime_stack(runtime)
    hvis runtime == ingen
        returner usann
    slutt

    runtime.values = []

    returner sann
slutt

funksjon cleanup_runtime_environment(runtime, memory, objects)
    hvis cleanup_runtime_stack(runtime) == usann
        returner usann
    slutt

    hvis cleanup_runtime_memory(memory) == usann
        returner usann
    slutt

    hvis cleanup_runtime_objects(objects) == usann
        returner usann
    slutt

    returner sann
slutt

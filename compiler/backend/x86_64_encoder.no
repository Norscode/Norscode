# x86_64 encoder phase

struktur OpcodeEncoder
    encoded_opcodes
    failed_encodings
slutt

struktur ModRMEncoder
    encoded_modrm
    register_mappings
slutt

struktur REXPrefixEncoder
    emitted_prefixes
    extended_registers
slutt

struktur ImmediateEncoder
    encoded_immediates
    immediate_sizes
slutt

struktur DisplacementEncoder
    encoded_displacements
    displacement_offsets
slutt

struktur JumpOffsetPatcher
    patched_jumps
    unresolved_offsets
slutt

struktur BinarySectionEmitter
    emitted_sections
    section_offsets
slutt

struktur ExecutableByteStream
    emitted_bytes
    stream_position
slutt

struktur x86RegisterEncoding
    register_codes
    register_sizes
slutt

struktur MachineCodeEmitter
    emitted_instructions
    emitted_binaries
slutt

funksjon ny_opcode_encoder()
    encoder = OpcodeEncoder()

    encoder.encoded_opcodes = {}
    encoder.failed_encodings = []

    encoder.encoded_opcodes["ADD64rr"] = [0x48, 0x01]
    encoder.encoded_opcodes["MOV64rr"] = [0x48, 0x89]
    encoder.encoded_opcodes["JMP"] = [0xE9]

    returner encoder
slutt

funksjon encode_opcode(encoder, opcode)
    hvis encoder == null
        kast "Opcode encoder mangler"
    slutt

    hvis finnes(encoder.encoded_opcodes, opcode)
        returner encoder.encoded_opcodes[opcode]
    slutt

    legg_til(
        encoder.failed_encodings,
        opcode
    )

    returner []
slutt

funksjon ny_modrm_encoder()
    encoder = ModRMEncoder()

    encoder.encoded_modrm = []
    encoder.register_mappings = {}

    returner encoder
slutt

funksjon encode_modrm(encoder, mod, reg, rm)
    hvis encoder == null
        kast "ModRM encoder mangler"
    slutt

    verdi = (
        (mod << 6)
        eller
        (reg << 3)
        eller
        rm
    )

    legg_til(
        encoder.encoded_modrm,
        verdi
    )

    returner verdi
slutt

funksjon ny_rex_prefix_encoder()
    encoder = REXPrefixEncoder()

    encoder.emitted_prefixes = []
    encoder.extended_registers = []

    returner encoder
slutt

funksjon encode_rex_prefix(encoder, w, r, x, b)
    hvis encoder == null
        kast "REX encoder mangler"
    slutt

    prefix = (
        0x40
        eller
        (w << 3)
        eller
        (r << 2)
        eller
        (x << 1)
        eller
        b
    )

    legg_til(
        encoder.emitted_prefixes,
        prefix
    )

    returner prefix
slutt

funksjon ny_immediate_encoder()
    encoder = ImmediateEncoder()

    encoder.encoded_immediates = []
    encoder.immediate_sizes = {}

    returner encoder
slutt

funksjon encode_immediate(encoder, verdi, størrelse)
    hvis encoder == null
        kast "Immediate encoder mangler"
    slutt

    bytes = []

    indeks = 0

    mens indeks < størrelse
        legg_til(
            bytes,
            (verdi >> (indeks * 8)) og 0xFF
        )

        indeks = indeks + 1
    slutt

    legg_til(
        encoder.encoded_immediates,
        bytes
    )

    returner bytes
slutt

funksjon ny_displacement_encoder()
    encoder = DisplacementEncoder()

    encoder.encoded_displacements = []
    encoder.displacement_offsets = []

    returner encoder
slutt

funksjon encode_displacement(encoder, offset)
    hvis encoder == null
        kast "Displacement encoder mangler"
    slutt

    legg_til(
        encoder.encoded_displacements,
        offset
    )

    returner encode_immediate(
        ny_immediate_encoder(),
        offset,
        4
    )
slutt

funksjon ny_jump_offset_patcher()
    patcher = JumpOffsetPatcher()

    patcher.patched_jumps = []
    patcher.unresolved_offsets = []

    returner patcher
slutt

funksjon patch_jump_offset(patcher, instruksjon, offset)
    hvis patcher == null
        kast "Jump offset patcher mangler"
    slutt

    patch = {
        instruction: instruksjon,
        offset: offset
    }

    legg_til(
        patcher.patched_jumps,
        patch
    )

    returner patch
slutt

funksjon ny_binary_section_emitter()
    emitter = BinarySectionEmitter()

    emitter.emitted_sections = []
    emitter.section_offsets = {}

    returner emitter
slutt

funksjon emit_binary_section(emitter, navn, bytes)
    hvis emitter == null
        kast "Binary section emitter mangler"
    slutt

    offset = lengde(emitter.emitted_sections)

    emitter.section_offsets[navn] = offset

    legg_til(
        emitter.emitted_sections,
        {
            navn: navn,
            bytes: bytes
        }
    )

    returner offset
slutt

funksjon ny_executable_byte_stream()
    stream = ExecutableByteStream()

    stream.emitted_bytes = []
    stream.stream_position = 0

    returner stream
slutt

funksjon stream_emit_bytes(stream, bytes)
    hvis stream == null
        kast "Executable byte stream mangler"
    slutt

    for hver byte i bytes
        legg_til(
            stream.emitted_bytes,
            byte
        )

        stream.stream_position = (
            stream.stream_position + 1
        )
    slutt

    returner sann
slutt

funksjon ny_x86_register_encoding()
    encoding = x86RegisterEncoding()

    encoding.register_codes = {
        "RAX": 0,
        "RCX": 1,
        "RDX": 2,
        "RBX": 3,
        "RSP": 4,
        "RBP": 5,
        "RSI": 6,
        "RDI": 7
    }

    encoding.register_sizes = {
        "RAX": 64,
        "RCX": 64,
        "RDX": 64,
        "RBX": 64
    }

    returner encoding
slutt

funksjon encode_register(encoding, register)
    hvis encoding == null
        kast "Register encoding mangler"
    slutt

    hvis finnes(encoding.register_codes, register)
        returner encoding.register_codes[register]
    slutt

    returner -1
slutt

funksjon ny_machine_code_emitter()
    emitter = MachineCodeEmitter()

    emitter.emitted_instructions = []
    emitter.emitted_binaries = []

    returner emitter
slutt

funksjon emit_machine_instruction(emitter, opcode_encoder, stream, instruksjon)
    hvis emitter == null
        kast "Machine code emitter mangler"
    slutt

    opcode = encode_opcode(
        opcode_encoder,
        instruksjon.opcode
    )

    stream_emit_bytes(
        stream,
        opcode
    )

    legg_til(
        emitter.emitted_instructions,
        instruksjon
    )

    returner sann
slutt

// Norscode Selfhost Rebuild Verification
// Deterministic compiler selfhost validation
// Selfhost migration phase

struktur SelfhostBuildResult
    source
    ast_hash
    ir_hash
    bytecode_hash
    runtime_hash
slutt

funksjon create_selfhost_build_result(
    source,
    ast_hash,
    ir_hash,
    bytecode_hash,
    runtime_hash
)
    la result = SelfhostBuildResult()

    result.source = source
    result.ast_hash = ast_hash
    result.ir_hash = ir_hash
    result.bytecode_hash = bytecode_hash
    result.runtime_hash = runtime_hash

    returner result
slutt

funksjon selfhost_runtime_hash(runtime_output)
    hvis runtime_output == ingen
        returner "runtime_null"
    slutt

    returner tekst(runtime_output)
slutt

funksjon selfhost_build_compiler(source)
    la ast = parse_source_to_ast(source)

    la ir = lower_typed_ast(ast)

    la bytecode = lower_typed_ir_to_bytecode(
        ir
    )

    la serialized = serialize_bytecode(
        bytecode
    )

    la runtime_output = runtime_execute_verified_bytecode(
        serialized
    )

    returner create_selfhost_build_result(
        source,
        compiler_hash_ast(ast),
        compiler_hash_ir(ir),
        compiler_hash_bytecode(bytecode),
        selfhost_runtime_hash(runtime_output)
    )
slutt

funksjon selfhost_validate_equivalence(
    left,
    right
)
    hvis left.ast_hash != right.ast_hash
        returner usann
    slutt

    hvis left.ir_hash != right.ir_hash
        returner usann
    slutt

    hvis left.bytecode_hash != right.bytecode_hash
        returner usann
    slutt

    hvis left.runtime_hash != right.runtime_hash
        returner usann
    slutt

    returner sann
slutt

funksjon selfhost_rebuild_verify(source)
    la build_1 = selfhost_build_compiler(
        source
    )

    la build_2 = selfhost_build_compiler(
        source
    )

    returner selfhost_validate_equivalence(
        build_1,
        build_2
    )
slutt

funksjon selfhost_chain_verify(source)
    hvis source == ingen
        returner usann
    slutt

    la verified = selfhost_rebuild_verify(
        source
    )

    hvis verified == usann
        runtime_print(
            "Selfhost rebuild verification failed"
        )

        returner usann
    slutt

    runtime_print(
        "Selfhost rebuild verification OK"
    )

    returner sann
slutt

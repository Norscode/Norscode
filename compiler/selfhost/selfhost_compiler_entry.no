# Full selfhosting compiler entrypoint

import selfhost.full_selfhost_pipeline
import selfhost.semantic_validation_real
import selfhost.full_lowering_real
import selfhost.optimizer_pipeline_real
import selfhost.bytecode_emitter_real
import selfhost.vm_runtime_real

funksjon compiler_version()
    returner "0.2-full-selfhost"
slutt

funksjon compile_program(source)
    resultat = selfhost_compile_source(source)

    hvis resultat.success == usann
        returner resultat
    slutt

    returner {
        success: sann,
        ir: resultat.ir,
        bytecode: resultat.bytecode,
        snapshot: resultat.snapshot
    }
slutt

funksjon execute_program(source)
    returner selfhost_run_source(source)
slutt

funksjon compile_and_emit_bytecode(source)
    resultat = compile_program(source)

    hvis resultat.success == usann
        returner resultat
    slutt

    returner disassemble(resultat.bytecode)
slutt

funksjon compile_and_emit_wasm(source)
    resultat = compile_program(source)

    hvis resultat.success == usann
        returner resultat
    slutt

    returner wasm_build_module(resultat.ir)
slutt

funksjon selfhost_main(args)
    hvis lengde(args) < 2
        skriv("norscode selfhost <run|build|dump-bytecode>")
        returner
    slutt

    kommando = args[0]
    path = args[1]

    source = les_fil(path)

    hvis kommando == "run"
        runtime = execute_program(source)
        skriv(runtime)
        returner
    slutt

    hvis kommando == "build"
        resultat = compile_program(source)
        skriv(resultat)
        returner
    slutt

    hvis kommando == "dump-bytecode"
        output = compile_and_emit_bytecode(source)
        skriv(output)
        returner
    slutt
slutt

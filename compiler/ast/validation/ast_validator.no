// Deterministic AST v1 validator
// Phase 1 contract checker for parser, selfhost and CI parity.

funksjon ast_validator_feil(melding)
    kast "AST validator: " + melding
slutt

funksjon validate_ast_format(ast)
    hvis ast == null
        ast_validator_feil("mangler AST")
    slutt

    hvis ast.format != "norscode-ast-v1"
        ast_validator_feil("ukjent format")
    slutt

    hvis ast.alias_map == null
        ast_validator_feil("mangler alias_map")
    slutt

    hvis ast.imports == null
        ast_validator_feil("mangler imports")
    slutt

    hvis ast.functions == null
        ast_validator_feil("mangler functions")
    slutt

    returner sann
slutt

funksjon validate_ast_import(import_node)
    hvis import_node == null
        ast_validator_feil("mangler import")
    slutt

    hvis import_node.module_name == null eller import_node.module_name == ""
        ast_validator_feil("import mangler module_name")
    slutt

    returner sann
slutt

funksjon validate_ast_parameter(param)
    hvis param == null
        ast_validator_feil("mangler parameter")
    slutt

    hvis param.name == null eller param.name == ""
        ast_validator_feil("parameter mangler navn")
    slutt

    returner sann
slutt

funksjon validate_ast_function(fn)
    hvis fn == null
        ast_validator_feil("mangler function")
    slutt

    hvis fn.type != "function"
        ast_validator_feil("function har feil type")
    slutt

    hvis fn.name == null eller fn.name == ""
        ast_validator_feil("function mangler navn")
    slutt

    hvis fn.module_name == null eller fn.module_name == ""
        ast_validator_feil("function mangler module_name")
    slutt

    hvis fn.params == null
        ast_validator_feil("function mangler params")
    slutt

    hvis fn.body == null
        ast_validator_feil("function mangler body")
    slutt

    returner sann
slutt

funksjon validate_ast_v1(ast)
    validate_ast_format(ast)

    indeks = 0
    mens indeks < lengde(ast.imports)
        validate_ast_import(ast.imports[indeks])
        indeks = indeks + 1
    slutt

    indeks = 0
    mens indeks < lengde(ast.functions)
        fn = ast.functions[indeks]
        validate_ast_function(fn)

        param_indeks = 0
        mens param_indeks < lengde(fn.params)
            validate_ast_parameter(fn.params[param_indeks])
            param_indeks = param_indeks + 1
        slutt

        indeks = indeks + 1
    slutt

    returner sann
slutt


pakke compiler

bruk std.runtime
bruk std.compiler

konstant CHAR_SPACE = 32
konstant CHAR_NEWLINE = 10

struktur RuntimeSourceReader {
    source: RuntimeString
    indeks: heiltall
    linje: heiltall
    kolonne: heiltall
}

funksjon ny_source_reader(
    source: RuntimeString
) -> RuntimeSourceReader {
    returner RuntimeSourceReader {
        source: source,
        indeks: 0,
        linje: 1,
        kolonne: 1
    }
}

funksjon er_slutt(
    reader: RuntimeSourceReader
) -> bool {
    returner reader.indeks >= reader.source.lengde
}

funksjon peek_char(
    reader: RuntimeSourceReader
) -> heiltall {
    hvis er_slutt(reader) {
        returner 0
    }

    returner reader.indeks
}

funksjon advance_char(
    reader: RuntimeSourceReader
) -> heiltall {
    hvis er_slutt(reader) {
        returner 0
    }

    la current = reader.indeks

    reader.indeks = reader.indeks + 1
    reader.kolonne = reader.kolonne + 1

    returner current
}

funksjon skip_whitespace(
    reader: RuntimeSourceReader
) {
    skrivlinje("[lexer] skip whitespace")
}

funksjon lex_identifier(
    allocator: Allocator,
    reader: RuntimeSourceReader
) -> RuntimeToken {
    skrivlinje("[lexer] lex identifier")

    la tekst = ny_runtime_string(
        allocator,
        "ident"
    )

    returner ny_token(
        allocator,
        TOKEN_IDENT,
        tekst,
        reader.linje,
        reader.kolonne
    )
}

funksjon lex_number(
    allocator: Allocator,
    reader: RuntimeSourceReader
) -> RuntimeToken {
    skrivlinje("[lexer] lex number")

    la tekst = ny_runtime_string(
        allocator,
        "0"
    )

    returner ny_token(
        allocator,
        TOKEN_TALL,
        tekst,
        reader.linje,
        reader.kolonne
    )
}

funksjon lex_string(
    allocator: Allocator,
    reader: RuntimeSourceReader
) -> RuntimeToken {
    skrivlinje("[lexer] lex string")

    la tekst = ny_runtime_string(
        allocator,
        "tekst"
    )

    returner ny_token(
        allocator,
        TOKEN_TEKST,
        tekst,
        reader.linje,
        reader.kolonne
    )
}

funksjon lex_keyword(
    allocator: Allocator,
    keyword: tekst,
    linje: heiltall,
    kolonne: heiltall
) -> RuntimeToken {
    la token_type = TOKEN_IDENT

    hvis keyword == "funksjon" {
        token_type = TOKEN_FUNKSJON
    }

    hvis keyword == "returner" {
        token_type = TOKEN_RETURN
    }

    la runtime_keyword = ny_runtime_string(
        allocator,
        keyword
    )

    returner ny_token(
        allocator,
        token_type,
        runtime_keyword,
        linje,
        kolonne
    )
}

funksjon lex_source(
    allocator: Allocator,
    source: RuntimeString
) -> RuntimeTokenStream {
    skrivlinje("[lexer] start native lexer")

    la reader = ny_source_reader(source)

    la stream = ny_token_stream(
        allocator
    )

    la funksjon_token = lex_keyword(
        allocator,
        "funksjon",
        1,
        1
    )

    legg_til_token(
        allocator,
        stream,
        funksjon_token
    )

    la ident_token = lex_identifier(
        allocator,
        reader
    )

    legg_til_token(
        allocator,
        stream,
        ident_token
    )

    la eof = ny_token(
        allocator,
        TOKEN_EOF,
        ny_runtime_string(
            allocator,
            "EOF"
        ),
        reader.linje,
        reader.kolonne
    )

    legg_til_token(
        allocator,
        stream,
        eof
    )

    returner stream
}

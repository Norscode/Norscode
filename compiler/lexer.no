pakke compiler

bruk std.runtime
bruk std.compiler

konstant CHAR_SPACE = 32
konstant CHAR_NEWLINE = 10

struktur RuntimeSourceReader {
    source: RuntimeString
    indeks: heiltall
    linje: heiltall
    kolonne: heiltall
}

struktur TextSourceReader {
    source: tekst
    indeks: heiltall
    linje: heiltall
    kolonne: heiltall
}

funksjon ny_source_reader(
    source: RuntimeString
) -> RuntimeSourceReader {
    returner RuntimeSourceReader {
        source: source,
        indeks: 0,
        linje: 1,
        kolonne: 1
    }
}

funksjon ny_text_source_reader(
    source: tekst
) -> TextSourceReader {
    returner TextSourceReader {
        source: source,
        indeks: 0,
        linje: 1,
        kolonne: 1
    }
}

funksjon er_slutt(
    reader: RuntimeSourceReader
) -> bool {
    returner reader.indeks >= reader.source.lengde
}

funksjon er_slutt_text(
    reader: TextSourceReader
) -> bool {
    returner reader.indeks >= lengde(reader.source)
}

funksjon peek_char(
    reader: RuntimeSourceReader
) -> heiltall {
    hvis er_slutt(reader) {
        returner 0
    }

    returner reader.indeks
}

funksjon advance_char(
    reader: RuntimeSourceReader
) -> heiltall {
    hvis er_slutt(reader) {
        returner 0
    }

    la current = reader.indeks

    reader.indeks = reader.indeks + 1
    reader.kolonne = reader.kolonne + 1

    returner current
}

funksjon skip_whitespace(
    reader: RuntimeSourceReader
) {
    skrivlinje("[lexer] skip whitespace")
}

funksjon peek_text_char(
    reader: TextSourceReader
) -> tekst {
    hvis er_slutt_text(reader) {
        returner ""
    }

    returner reader.source[reader.indeks]
}

funksjon advance_text_char(
    reader: TextSourceReader
) -> tekst {
    hvis er_slutt_text(reader) {
        returner ""
    }

    la tegn = reader.source[reader.indeks]

    reader.indeks = reader.indeks + 1

    hvis tegn == "\n" {
        reader.linje = reader.linje + 1
        reader.kolonne = 1
    } ellers {
        reader.kolonne = reader.kolonne + 1
    }

    returner tegn
}

funksjon skip_whitespace_text(
    reader: TextSourceReader
) {
    mens (ikke er_slutt_text(reader) og er_whitespace(peek_text_char(reader))) {
        advance_text_char(reader)
    }
}

funksjon skip_line_comment(
    reader: TextSourceReader
) -> bool {
    hvis er_slutt_text(reader) {
        returner usann
    }

    hvis peek_text_char(reader) != "/" {
        returner usann
    }

    hvis reader.indeks + 1 >= lengde(reader.source) {
        returner usann
    }

    hvis reader.source[reader.indeks + 1] != "/" {
        returner usann
    }

    mens (ikke er_slutt_text(reader)) {
        la tegn = advance_text_char(reader)
        hvis tegn == "\n" {
            break
        }
    }

    returner sann
}

funksjon er_bokstav(
    tegn: tekst
) -> bool {
    returner (tegn >= "a" og tegn <= "z") eller
        (tegn >= "A" og tegn <= "Z") eller
        tegn == "_"
}

funksjon er_tall(
    tegn: tekst
) -> bool {
    returner tegn >= "0" og tegn <= "9"
}

funksjon er_ident_tegn(
    tegn: tekst
) -> bool {
    returner er_bokstav(tegn) eller er_tall(tegn)
}

funksjon er_whitespace(
    tegn: tekst
) -> bool {
    returner tegn == " " eller
        tegn == "\n" eller
        tegn == "\t" eller
        tegn == "\r"
}

funksjon lex_identifier(
    allocator: Allocator,
    reader: RuntimeSourceReader
) -> RuntimeToken {
    skrivlinje("[lexer] lex identifier")

    la tekst = ny_runtime_string(
        allocator,
        "ident"
    )

    returner ny_token(
        allocator,
        TOKEN_IDENT,
        tekst,
        reader.linje,
        reader.kolonne
    )
}

funksjon lex_number(
    allocator: Allocator,
    reader: RuntimeSourceReader
) -> RuntimeToken {
    skrivlinje("[lexer] lex number")

    la tekst = ny_runtime_string(
        allocator,
        "0"
    )

    returner ny_token(
        allocator,
        TOKEN_TALL,
        tekst,
        reader.linje,
        reader.kolonne
    )
}

funksjon lex_string(
    allocator: Allocator,
    reader: RuntimeSourceReader
) -> RuntimeToken {
    skrivlinje("[lexer] lex string")

    la tekst = ny_runtime_string(
        allocator,
        "tekst"
    )

    returner ny_token(
        allocator,
        TOKEN_TEKST,
        tekst,
        reader.linje,
        reader.kolonne
    )
}

funksjon token_type_for_keyword(
    keyword: tekst
) -> heiltall {
    hvis keyword == "funksjon" {
        returner TOKEN_FUNKSJON
    }

    hvis keyword == "returner" {
        returner TOKEN_RETURN
    }

    returner TOKEN_IDENT
}

funksjon lex_keyword(
    allocator: Allocator,
    keyword: tekst,
    linje: heiltall,
    kolonne: heiltall
) -> RuntimeToken {
    la token_type = token_type_for_keyword(
        keyword
    )

    la runtime_keyword = ny_runtime_string(
        allocator,
        keyword
    )

    returner ny_token(
        allocator,
        token_type,
        runtime_keyword,
        linje,
        kolonne
    )
}

funksjon lex_text_identifier(
    allocator: Allocator,
    reader: TextSourceReader
) -> RuntimeToken {
    la linje = reader.linje
    la kolonne = reader.kolonne
    la ord = ""

    mens (ikke er_slutt_text(reader) og er_ident_tegn(
        peek_text_char(reader)
    )) {
        ord = ord + advance_text_char(reader)
    }

    la token_type = token_type_for_keyword(ord)

    returner ny_token(
        allocator,
        token_type,
        ny_runtime_string(
            allocator,
            ord
        ),
        linje,
        kolonne
    )
}

funksjon lex_text_number(
    allocator: Allocator,
    reader: TextSourceReader
) -> RuntimeToken {
    la linje = reader.linje
    la kolonne = reader.kolonne
    la ord = ""

    mens (ikke er_slutt_text(reader) og er_tall(
        peek_text_char(reader)
    )) {
        ord = ord + advance_text_char(reader)
    }

    returner ny_token(
        allocator,
        TOKEN_TALL,
        ny_runtime_string(
            allocator,
            ord
        ),
        linje,
        kolonne
    )
}

funksjon lex_text_string(
    allocator: Allocator,
    reader: TextSourceReader
) -> RuntimeToken {
    la linje = reader.linje
    la kolonne = reader.kolonne
    la quote = advance_text_char(reader)
    la ord = ""

    mens (ikke er_slutt_text(reader)) {
        la tegn = advance_text_char(reader)

        hvis tegn == "\\" {
            hvis er_slutt_text(reader) {
                break
            }

            ord = ord + tegn
            ord = ord + advance_text_char(reader)
            continue
        }

        hvis tegn == quote {
            break
        }

        ord = ord + tegn
    }

    returner ny_token(
        allocator,
        TOKEN_TEKST,
        ny_runtime_string(
            allocator,
            ord
        ),
        linje,
        kolonne
    )
}

funksjon legg_til_eof(
    allocator: Allocator,
    stream: RuntimeTokenStream,
    reader: TextSourceReader
) {
    la eof = ny_token(
        allocator,
        TOKEN_EOF,
        ny_runtime_string(
            allocator,
            "EOF"
        ),
        reader.linje,
        reader.kolonne
    )

    legg_til_token(
        allocator,
        stream,
        eof
    )
}

funksjon lex_source_text(
    allocator: Allocator,
    source: tekst
) -> RuntimeTokenStream {
    skrivlinje("[lexer] start native lexer (tekst)")

    la reader = ny_text_source_reader(source)
    la stream = ny_token_stream(
        allocator
    )

    mens (ikke er_slutt_text(reader)) {
        la tegn = peek_text_char(reader)

        hvis er_whitespace(tegn) {
            skip_whitespace_text(reader)
            continue
        }

        hvis skip_line_comment(reader) {
            continue
        }

        hvis er_bokstav(tegn) {
            la token = lex_text_identifier(
                allocator,
                reader
            )
            legg_til_token(
                allocator,
                stream,
                token
            )
            continue
        }

        hvis er_tall(tegn) {
            la token = lex_text_number(
                allocator,
                reader
            )
            legg_til_token(
                allocator,
                stream,
                token
            )
            continue
        }

        hvis tegn == "\"" eller tegn == "'" {
            la token = lex_text_string(
                allocator,
                reader
            )
            legg_til_token(
                allocator,
                stream,
                token
            )
            continue
        }

        # Ignorer ukjende symbol (operatorar, parantesar osv.).
        advance_text_char(reader)
    }

    legg_til_eof(
        allocator,
        stream,
        reader
    )

    returner stream
}

funksjon lex_source(
    allocator: Allocator,
    source: RuntimeString
) -> RuntimeTokenStream {
    skrivlinje("[lexer] start native lexer")

    la reader = ny_source_reader(source)

    la stream = ny_token_stream(
        allocator
    )

    la funksjon_token = lex_keyword(
        allocator,
        "funksjon",
        1,
        1
    )

    legg_til_token(
        allocator,
        stream,
        funksjon_token
    )

    la ident_token = lex_identifier(
        allocator,
        reader
    )

    legg_til_token(
        allocator,
        stream,
        ident_token
    )

    la eof = ny_token(
        allocator,
        TOKEN_EOF,
        ny_runtime_string(
            allocator,
            "EOF"
        ),
        reader.linje,
        reader.kolonne
    )

    legg_til_token(
        allocator,
        stream,
        eof
    )

    returner stream
}

// Norscode Semantic Regression Validation
// Deterministic semantic correctness validation
// Selfhost migration phase

struktur SemanticRegressionResult
    name
    success
    details
slutt

funksjon create_semantic_result(
    name,
    success,
    details
)
    la result = SemanticRegressionResult()

    result.name = name
    result.success = success
    result.details = details

    returner result
slutt

funksjon validate_ownership_regression()
    la owner_1 = create_runtime_owner(1)
    la owner_2 = create_runtime_owner(2)

    hvis ownership_transfer(
        owner_1,
        owner_2
    ) == usann
        returner create_semantic_result(
            "ownership",
            usann,
            "Ownership transfer failed"
        )
    slutt

    hvis ownership_validate(owner_1)
        returner create_semantic_result(
            "ownership",
            usann,
            "Ownership invalidation failed"
        )
    slutt

    returner create_semantic_result(
        "ownership",
        sann,
        "OK"
    )
slutt

funksjon validate_generic_regression()
    la generic = create_generic_type(
        "Liste"
    )

    generic_add_parameter(
        generic,
        create_generic_parameter(
            "T",
            type_tekst()
        )
    )

    generic_specialize(
        generic,
        [type_tekst()]
    )

    hvis generic_validate_specialization(
        generic
    ) == usann
        returner create_semantic_result(
            "generic",
            usann,
            "Generic specialization failed"
        )
    slutt

    returner create_semantic_result(
        "generic",
        sann,
        "OK"
    )
slutt

funksjon validate_callable_regression()
    la callable = create_callable_type(
        "skriv",
        type_boolsk()
    )

    callable_add_parameter(
        callable,
        create_runtime_parameter(
            "tekst",
            type_tekst()
        )
    )

    la arguments = []

    arguments.push(
        create_typed_value(
            type_tekst(),
            "Hei"
        )
    )

    hvis callable_validate_arguments(
        callable,
        arguments
    ) == usann
        returner create_semantic_result(
            "callable",
            usann,
            "Callable validation failed"
        )
    slutt

    returner create_semantic_result(
        "callable",
        sann,
        "OK"
    )
slutt

funksjon validate_object_regression()
    la struct_type = create_struct_type(
        "Person"
    )

    struct_add_field(
        struct_type,
        create_runtime_field(
            "navn",
            type_tekst(),
            create_typed_value(
                type_tekst(),
                ""
            )
        )
    )

    la instance = create_runtime_instance(
        struct_type
    )

    runtime_instance_set_field(
        instance,
        "navn",
        create_typed_value(
            type_tekst(),
            "Jan"
        )
    )

    la value = runtime_instance_get_field(
        instance,
        "navn"
    )

    hvis value.value != "Jan"
        returner create_semantic_result(
            "object",
            usann,
            "Object mutation failed"
        )
    slutt

    returner create_semantic_result(
        "object",
        sann,
        "OK"
    )
slutt

funksjon run_semantic_regression_validation()
    la results = []

    results.push(
        validate_ownership_regression()
    )

    results.push(
        validate_generic_regression()
    )

    results.push(
        validate_callable_regression()
    )

    results.push(
        validate_object_regression()
    )

    returner results
slutt

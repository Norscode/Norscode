// Norscode Compiler Correctness Validation
// Deterministic compiler verification
// Selfhost migration phase

struktur CompilerSnapshot
    source
    ast_hash
    ir_hash
    bytecode_hash
slutt

funksjon create_compiler_snapshot(
    source,
    ast_hash,
    ir_hash,
    bytecode_hash
)
    la snapshot = CompilerSnapshot()

    snapshot.source = source
    snapshot.ast_hash = ast_hash
    snapshot.ir_hash = ir_hash
    snapshot.bytecode_hash = bytecode_hash

    returner snapshot
slutt

funksjon compiler_hash_value(value)
    hvis value == ingen
        returner "null"
    slutt

    returner tekst(value)
slutt

funksjon compiler_hash_ast(ast)
    hvis ast == ingen
        returner "ast_null"
    slutt

    returner compiler_hash_value(ast)
slutt

funksjon compiler_hash_ir(ir)
    hvis ir == ingen
        returner "ir_null"
    slutt

    returner compiler_hash_value(ir)
slutt

funksjon compiler_hash_bytecode(bytecode)
    hvis bytecode == ingen
        returner "bytecode_null"
    slutt

    returner compiler_hash_value(bytecode)
slutt

funksjon compiler_create_snapshot(source)
    la ast = parse_source_to_ast(source)

    la ir = lower_typed_ast(ast)

    la bytecode = lower_typed_ir_to_bytecode(
        ir
    )

    returner create_compiler_snapshot(
        source,
        compiler_hash_ast(ast),
        compiler_hash_ir(ir),
        compiler_hash_bytecode(bytecode)
    )
slutt

funksjon compiler_validate_deterministic(
    source
)
    la first = compiler_create_snapshot(
        source
    )

    la second = compiler_create_snapshot(
        source
    )

    hvis first.ast_hash != second.ast_hash
        returner usann
    slutt

    hvis first.ir_hash != second.ir_hash
        returner usann
    slutt

    hvis first.bytecode_hash != second.bytecode_hash
        returner usann
    slutt

    returner sann
slutt

funksjon compiler_validate_bytecode(
    bytecode
)
    hvis bytecode == ingen
        returner usann
    slutt

    hvis bytecode.instructions.length == 0
        returner usann
    slutt

    for instruction i bytecode.instructions
        hvis instruction.opcode == ingen
            returner usann
        slutt
    slutt

    returner sann
slutt

funksjon compiler_validate_lowering(
    source
)
    la ast = parse_source_to_ast(source)

    hvis ast == ingen
        returner usann
    slutt

    la ir = lower_typed_ast(ast)

    hvis ir == ingen
        returner usann
    slutt

    la bytecode = lower_typed_ir_to_bytecode(
        ir
    )

    returner compiler_validate_bytecode(
        bytecode
    )
slutt

# Real SSA system phase

struktur IRInstruction
    opcode
    operands
    result
slutt

struktur BasicBlock
    navn
    instruksjoner
    predecessors
    successors
slutt

struktur ControlFlowGraph
    blocks
    entry_block
    exit_block
slutt

struktur PhiNode
    variable
    incoming_values
slutt

struktur DominanceTree
    dominators
    immediate_dominators
    dominance_frontiers
slutt

struktur SSAValue
    navn
    versjon
    definisjon
    uses
slutt

struktur SSARenamer
    stacks
    counters
slutt

struktur UseDefChain
    definitions
    uses
slutt

struktur SSAValidator
    validation_errors
    validated_blocks
slutt

funksjon ny_ir_instruction(opcode, operands, result)
    instruksjon = IRInstruction()

    instruksjon.opcode = opcode
    instruksjon.operands = operands
    instruksjon.result = result

    returner instruksjon
slutt

funksjon ny_basic_block(navn)
    blokk = BasicBlock()

    blokk.navn = navn
    blokk.instruksjoner = []
    blokk.predecessors = []
    blokk.successors = []

    returner blokk
slutt

funksjon basic_block_add_instruction(blokk, instruksjon)
    hvis blokk == null
        kast "Basic block mangler"
    slutt

    legg_til(blokk.instruksjoner, instruksjon)

    returner sann
slutt

funksjon basic_block_add_successor(blokk, successor)
    hvis blokk == null
        kast "Basic block mangler"
    slutt

    legg_til(blokk.successors, successor)
    legg_til(successor.predecessors, blokk)

    returner sann
slutt

funksjon ny_cfg()
    cfg = ControlFlowGraph()

    cfg.blocks = []
    cfg.entry_block = null
    cfg.exit_block = null

    returner cfg
slutt

funksjon cfg_add_block(cfg, blokk)
    hvis cfg == null
        kast "CFG mangler"
    slutt

    hvis cfg.entry_block == null
        cfg.entry_block = blokk
    slutt

    cfg.exit_block = blokk

    legg_til(cfg.blocks, blokk)

    returner sann
slutt

funksjon ny_phi_node(variable)
    phi = PhiNode()

    phi.variable = variable
    phi.incoming_values = {}

    returner phi
slutt

funksjon phi_add_incoming(phi, blokk, verdi)
    hvis phi == null
        kast "Phi node mangler"
    slutt

    phi.incoming_values[blokk.navn] = verdi

    returner sann
slutt

funksjon ny_dominance_tree()
    tre = DominanceTree()

    tre.dominators = {}
    tre.immediate_dominators = {}
    tre.dominance_frontiers = {}

    returner tre
slutt

funksjon dominance_compute(tre, cfg)
    hvis tre == null
        kast "Dominance tree mangler"
    slutt

    for hver blokk i cfg.blocks
        tre.dominators[blokk.navn] = []
        tre.dominance_frontiers[blokk.navn] = []
    slutt

    returner sann
slutt

funksjon ny_ssa_value(navn, versjon)
    verdi = SSAValue()

    verdi.navn = navn
    verdi.versjon = versjon
    verdi.definisjon = null
    verdi.uses = []

    returner verdi
slutt

funksjon ssa_value_add_use(verdi, instruksjon)
    hvis verdi == null
        kast "SSA value mangler"
    slutt

    legg_til(verdi.uses, instruksjon)

    returner sann
slutt

funksjon ny_ssa_renamer()
    renamer = SSARenamer()

    renamer.stacks = {}
    renamer.counters = {}

    returner renamer
slutt

funksjon ssa_rename_variable(renamer, navn)
    hvis renamer == null
        kast "SSA renamer mangler"
    slutt

    hvis ikke finnes(renamer.counters, navn)
        renamer.counters[navn] = 0
    slutt

    versjon = renamer.counters[navn]

    renamer.counters[navn] = versjon + 1

    verdi = ny_ssa_value(navn, versjon)

    hvis ikke finnes(renamer.stacks, navn)
        renamer.stacks[navn] = []
    slutt

    legg_til(renamer.stacks[navn], verdi)

    returner verdi
slutt

funksjon ny_use_def_chain()
    chain = UseDefChain()

    chain.definitions = {}
    chain.uses = {}

    returner chain
slutt

funksjon register_definition(chain, navn, instruksjon)
    hvis chain == null
        kast "Use/def chain mangler"
    slutt

    chain.definitions[navn] = instruksjon

    returner sann
slutt

funksjon register_use(chain, navn, instruksjon)
    hvis chain == null
        kast "Use/def chain mangler"
    slutt

    hvis ikke finnes(chain.uses, navn)
        chain.uses[navn] = []
    slutt

    legg_til(chain.uses[navn], instruksjon)

    returner sann
slutt

funksjon ny_ssa_validator()
    validator = SSAValidator()

    validator.validation_errors = []
    validator.validated_blocks = []

    returner validator
slutt

funksjon validate_ssa(validator, cfg)
    hvis validator == null
        kast "SSA validator mangler"
    slutt

    for hver blokk i cfg.blocks
        hvis lengde(blokk.instruksjoner) == 0
            legg_til(
                validator.validation_errors,
                blokk.navn
            )
        ellers
            legg_til(
                validator.validated_blocks,
                blokk.navn
            )
        slutt
    slutt

    returner (
        lengde(validator.validation_errors) == 0
    )
slutt

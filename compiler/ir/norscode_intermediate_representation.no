// Norscode Intermediate Representation (NIR)
// Deterministic compiler pipeline + replay-safe execution graph
// Selfhost migration phase

struktur IRInstruction
    instruction_id
    opcode
    operand_list
    replay_hash
slutt

struktur IRBlock
    block_id
    instruction_count
    control_flow_state
    validation_hash
slutt

struktur IRFunction
    function_id
    parameter_count
    return_type
    compilation_state
slutt

struktur IRModule
    module_id
    active_functions
    optimization_state
    synchronization_hash
slutt

struktur IROptimizationPass
    pass_id
    optimization_type
    execution_state
    replay_hash
slutt

funksjon create_ir_instruction(
    instruction_id,
    opcode,
    operand_list,
    replay_hash
)
    la instruction = IRInstruction()

    instruction.instruction_id = instruction_id
    instruction.opcode = opcode
    instruction.operand_list = operand_list
    instruction.replay_hash = replay_hash

    returner instruction
slutt

funksjon create_ir_block(
    block_id,
    instruction_count,
    validation_hash
)
    la block = IRBlock()

    block.block_id = block_id
    block.instruction_count = instruction_count
    block.control_flow_state = "linked"
    block.validation_hash = validation_hash

    returner block
slutt

funksjon create_ir_function(
    function_id,
    parameter_count,
    return_type
)
    la function = IRFunction()

    function.function_id = function_id
    function.parameter_count = parameter_count
    function.return_type = return_type
    function.compilation_state = "parsed"

    returner function
slutt

funksjon create_ir_module(
    module_id,
    synchronization_hash
)
    la module = IRModule()

    module.module_id = module_id
    module.active_functions = []
    module.optimization_state = "unoptimized"
    module.synchronization_hash = synchronization_hash

    returner module
slutt

funksjon create_ir_optimization_pass(
    pass_id,
    optimization_type,
    replay_hash
)
    la pass = IROptimizationPass()

    pass.pass_id = pass_id
    pass.optimization_type = optimization_type
    pass.execution_state = "queued"
    pass.replay_hash = replay_hash

    returner pass
slutt

funksjon ir_register_function(
    compiler,
    module,
    function
)
    hvis compiler == ingen
        returner usann
    slutt

    module.active_functions.push(function)

    runtime_print(
        "IR function registered"
    )

    returner sann
slutt

funksjon ir_link_block(
    compiler,
    block,
    instruction
)
    hvis compiler == ingen
        returner usann
    slutt

    runtime_print(
        "IR block linked"
    )

    returner sann
slutt

funksjon ir_execute_optimization(
    compiler,
    pass,
    module
)
    hvis compiler == ingen
        returner usann
    slutt

    pass.execution_state = "executing"
    module.optimization_state = "optimized"

    runtime_print(
        "IR optimization executed"
    )

    returner sann
slutt

funksjon ir_validate_replay(
    compiler,
    instruction
)
    hvis compiler == ingen
        returner usann
    slutt

    hvis instruction.replay_hash == ingen
        runtime_print(
            "IR replay validation failed"
        )

        returner usann
    slutt

    runtime_print(
        "IR replay validated"
    )

    returner sann
slutt

funksjon ir_compile_forever(compiler)
    hvis compiler == ingen
        returner usann
    slutt

    runtime_print(
        "Norscode IR compiler active"
    )

    returner continuous_selfhost_forever(
        compiler.scheduler,
        "norscode-ir-compiler"
    )
slutt

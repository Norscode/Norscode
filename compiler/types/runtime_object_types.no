// Norscode Runtime Object Types
// Composite runtime type system
// Selfhost migration phase

struktur RuntimeField
    navn
    type
    value
slutt

struktur RuntimeStructType
    navn
    fields
slutt

struktur RuntimeArrayType
    element_type
    values
slutt

funksjon create_runtime_field(
    navn,
    type,
    value
)
    la field = RuntimeField()

    field.navn = navn
    field.type = type
    field.value = value

    returner field
slutt

funksjon create_struct_type(navn)
    la struct_type = RuntimeStructType()

    struct_type.navn = navn
    struct_type.fields = []

    returner struct_type
slutt

funksjon struct_add_field(
    struct_type,
    field
)
    hvis struct_type == ingen
        returner usann
    slutt

    struct_type.fields.push(field)

    returner sann
slutt

funksjon struct_get_field(
    struct_type,
    navn
)
    hvis struct_type == ingen
        returner ingen
    slutt

    for field i struct_type.fields
        hvis field.navn == navn
            returner field
        slutt
    slutt

    returner ingen
slutt

funksjon create_array_type(element_type)
    la array_type = RuntimeArrayType()

    array_type.element_type = element_type
    array_type.values = []

    returner array_type
slutt

funksjon array_push_value(
    array_type,
    value
)
    hvis array_type == ingen
        returner usann
    slutt

    hvis runtime_validate_type(
        value,
        array_type.element_type
    ) == usann
        returner usann
    slutt

    array_type.values.push(value)

    returner sann
slutt

funksjon array_get_value(
    array_type,
    index
)
    hvis array_type == ingen
        returner ingen
    slutt

    hvis index < 0
        returner ingen
    slutt

    hvis index >= array_type.values.length
        returner ingen
    slutt

    returner array_type.values[index]
slutt

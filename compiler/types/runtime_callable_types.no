// Norscode Runtime Callable Types
// Typed callable system
// Selfhost migration phase

struktur RuntimeParameter
    navn
    type
slutt

struktur RuntimeCallableType
    navn
    parameters
    return_type
slutt

funksjon create_runtime_parameter(
    navn,
    type
)
    la parameter = RuntimeParameter()

    parameter.navn = navn
    parameter.type = type

    returner parameter
slutt

funksjon create_callable_type(
    navn,
    return_type
)
    la callable = RuntimeCallableType()

    callable.navn = navn
    callable.parameters = []
    callable.return_type = return_type

    returner callable
slutt

funksjon callable_add_parameter(
    callable,
    parameter
)
    hvis callable == ingen
        returner usann
    slutt

    callable.parameters.push(parameter)

    returner sann
slutt

funksjon callable_validate_argument(
    parameter,
    value
)
    hvis parameter == ingen
        returner usann
    slutt

    hvis value == ingen
        returner usann
    slutt

    returner runtime_validate_type(
        value,
        parameter.type
    )
slutt

funksjon callable_validate_arguments(
    callable,
    arguments
)
    hvis callable == ingen
        returner usann
    slutt

    hvis arguments.length != callable.parameters.length
        returner usann
    slutt

    la index = 0

    mens index < arguments.length
        hvis callable_validate_argument(
            callable.parameters[index],
            arguments[index]
        ) == usann
            returner usann
        slutt

        index = index + 1
    slutt

    returner sann
slutt

funksjon callable_validate_return(
    callable,
    value
)
    hvis callable == ingen
        returner usann
    slutt

    returner runtime_validate_type(
        value,
        callable.return_type
    )
slutt

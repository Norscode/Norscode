// Norscode Runtime Ownership System
// Ownership and lifetime validation
// Selfhost migration phase

struktur RuntimeOwner
    id
    active
slutt

struktur RuntimeBorrow
    owner_id
    mutable
    valid
slutt

funksjon create_runtime_owner(id)
    la owner = RuntimeOwner()

    owner.id = id
    owner.active = sann

    returner owner
slutt

funksjon create_runtime_borrow(
    owner_id,
    mutable
)
    la borrow = RuntimeBorrow()

    borrow.owner_id = owner_id
    borrow.mutable = mutable
    borrow.valid = sann

    returner borrow
slutt

funksjon ownership_validate(owner)
    hvis owner == ingen
        returner usann
    slutt

    returner owner.active
slutt

funksjon ownership_release(owner)
    hvis owner == ingen
        returner usann
    slutt

    owner.active = usann

    returner sann
slutt

funksjon borrow_validate(borrow)
    hvis borrow == ingen
        returner usann
    slutt

    returner borrow.valid
slutt

funksjon borrow_invalidate(borrow)
    hvis borrow == ingen
        returner usann
    slutt

    borrow.valid = usann

    returner sann
slutt

funksjon ownership_transfer(
    old_owner,
    new_owner
)
    hvis ownership_validate(old_owner) == usann
        returner usann
    slutt

    ownership_release(old_owner)

    new_owner.active = sann

    returner sann
slutt

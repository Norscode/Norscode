// Norscode Runtime Type System
// Primitive types and semantic validation
// Selfhost migration phase

struktur RuntimeType
    navn
    primitive
slutt

struktur TypedValue
    type
    value
slutt

funksjon create_runtime_type(navn, primitive)
    la runtime_type = RuntimeType()

    runtime_type.navn = navn
    runtime_type.primitive = primitive

    returner runtime_type
slutt

funksjon type_heltall()
    returner create_runtime_type(
        "heltall",
        sann
    )
slutt

funksjon type_desimal()
    returner create_runtime_type(
        "desimal",
        sann
    )
slutt

funksjon type_tekst()
    returner create_runtime_type(
        "tekst",
        sann
    )
slutt

funksjon type_boolsk()
    returner create_runtime_type(
        "boolsk",
        sann
    )
slutt

funksjon create_typed_value(type, value)
    la typed = TypedValue()

    typed.type = type
    typed.value = value

    returner typed
slutt

funksjon runtime_type_equals(left, right)
    hvis left == ingen
        returner usann
    slutt

    hvis right == ingen
        returner usann
    slutt

    returner left.navn == right.navn
slutt

funksjon runtime_validate_type(value, expected)
    hvis value == ingen
        returner usann
    slutt

    hvis expected == ingen
        returner usann
    slutt

    returner runtime_type_equals(
        value.type,
        expected
    )
slutt

funksjon semantic_validate_assignment(
    expected,
    actual
)
    hvis runtime_validate_type(
        actual,
        expected
    ) == usann
        returner usann
    slutt

    returner sann
slutt

funksjon typed_stack_push(
    runtime,
    typed_value
)
    hvis runtime == ingen
        returner usann
    slutt

    hvis typed_value == ingen
        returner usann
    slutt

    returner stack_push(
        runtime.stack,
        typed_value
    )
slutt

funksjon typed_stack_pop(runtime)
    hvis runtime == ingen
        returner ingen
    slutt

    returner stack_pop(runtime.stack)
slutt

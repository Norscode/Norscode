// Deterministic semantic pass engine
// Selfhost migration phase

funksjon run_semantic_pass(ast)
    hvis ast == ingen
        returner usann
    slutt

    validate_ast_node(ast)

    for child i ast.barn
        run_semantic_pass(child)
    slutt

    returner sann
slutt

funksjon validate_ast_node(node)
    hvis node.type == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon semantic_pass_count(nodes)
    la count = 0

    for node i nodes
        hvis run_semantic_pass(node)
            count = count + 1
        slutt
    slutt

    returner count
slutt

// Deterministic dependency resolver
// Selfhost migration phase

struktur DependencyNode
    navn
    dependencies
slutt

funksjon create_dependency_node(navn)
    la node = DependencyNode()
    node.navn = navn
    node.dependencies = []

    returner node
slutt

funksjon add_dependency(node, dependency)
    // Deterministic dependency ordering
    node.dependencies.push(dependency)
slutt

funksjon resolve_dependencies(node)
    la resolved = []

    for dependency i node.dependencies
        resolved.push(dependency)
    slutt

    returner resolved
slutt

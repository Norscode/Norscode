// Deterministic semantic scheduler
// Selfhost migration phase

struktur SemanticTask
    navn
    status
slutt

funksjon create_semantic_task(navn)
    la task = SemanticTask()
    task.navn = navn
    task.status = "pending"

    returner task
slutt

funksjon run_semantic_task(task)
    task.status = "completed"
    returner task
slutt

funksjon run_semantic_schedule(tasks)
    la completed = 0

    for task i tasks
        run_semantic_task(task)
        completed = completed + 1
    slutt

    returner completed
slutt

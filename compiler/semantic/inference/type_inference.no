// Deterministic type inference
// Selfhost migration phase

funksjon infer_type(node)
    hvis node == ingen
        returner "unknown"
    slutt

    hvis node.type == "number"
        returner "number"
    slutt

    hvis node.type == "text"
        returner "text"
    slutt

    returner "unknown"
slutt

funksjon infer_node_list(nodes)
    la inferred = []

    for node i nodes
        inferred.push(infer_type(node))
    slutt

    returner inferred
slutt

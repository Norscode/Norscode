// Deterministic AST semantic binding
// Selfhost migration phase

struktur SemanticBinding
    node
    symbol
    type
slutt

funksjon create_semantic_binding(node, symbol, type)
    la binding = SemanticBinding()
    binding.node = node
    binding.symbol = symbol
    binding.type = type

    returner binding
slutt

funksjon binding_has_symbol(binding)
    hvis binding.symbol == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon binding_has_type(binding)
    hvis binding.type == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon validate_semantic_binding(binding)
    hvis binding.node == ingen
        returner usann
    slutt

    hvis binding_has_symbol(binding) == usann
        returner usann
    slutt

    hvis binding_has_type(binding) == usann
        returner usann
    slutt

    returner sann
slutt

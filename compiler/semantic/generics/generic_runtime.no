// Deterministic generic runtime
// Selfhost migration phase

struktur GenericType
    navn
    parametere
slutt

funksjon create_generic_type(navn)
    la generic = GenericType()
    generic.navn = navn
    generic.parametere = []

    returner generic
slutt

funksjon add_generic_parameter(generic, parameter)
    // Deterministic parameter ordering
    generic.parametere.push(parameter)
slutt

funksjon generic_parameter_count(generic)
    returner generic.parametere.length
slutt

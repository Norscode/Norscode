// Deterministic semantic error propagation
// Selfhost migration phase

struktur SemanticDiagnostic
    message
    severity
    node
slutt

funksjon create_semantic_diagnostic(message, severity, node)
    la diagnostic = SemanticDiagnostic()
    diagnostic.message = message
    diagnostic.severity = severity
    diagnostic.node = node

    returner diagnostic
slutt

funksjon propagate_semantic_error(state, diagnostic)
    hvis state == ingen
        returner usann
    slutt

    hvis diagnostic == ingen
        returner usann
    slutt

    state.last_error = diagnostic.message
    state.last_severity = diagnostic.severity

    returner sann
slutt

funksjon semantic_error_exists(state)
    hvis state == ingen
        returner usann
    slutt

    hvis state.last_error == ingen
        returner usann
    slutt

    returner sann
slutt

funksjon synchronize_parser_semantic(parser_state, semantic_state)
    hvis parser_state == ingen
        returner usann
    slutt

    hvis semantic_state == ingen
        returner usann
    slutt

    semantic_state.parser_index = parser_state.index

    returner sann
slutt

funksjon semantic_diagnostic_valid(diagnostic)
    hvis diagnostic == ingen
        returner usann
    slutt

    hvis diagnostic.message == ingen
        returner usann
    slutt

    returner sann
slutt

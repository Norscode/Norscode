// Deterministic scope manager
// Selfhost migration phase

struktur Scope
    navn
    parent
    symboler
slutt

funksjon create_scope(navn, parent)
    la scope = Scope()
    scope.navn = navn
    scope.parent = parent
    scope.symboler = []

    returner scope
slutt

funksjon add_scope_symbol(scope, symbol)
    // Deterministic insertion ordering
    scope.symboler.push(symbol)
slutt

funksjon find_scope_symbol(scope, navn)
    for symbol i scope.symboler
        hvis symbol.navn == navn
            returner symbol
        slutt
    slutt

    hvis scope.parent != ingen
        returner find_scope_symbol(scope.parent, navn)
    slutt

    returner ingen
slutt

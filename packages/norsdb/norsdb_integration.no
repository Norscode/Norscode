importer norsdb_core
importer norsdb_schema
importer norsdb_crud
importer norsdb_index
importer norsdb_tx

funksjon start()
    la _sti = "/private/tmp/norsdb_integration.norsdb"
    hvis fil_finnes(_sti)
        fil_slett(_sti)
    hvis fil_finnes(_sti + ".state")
        fil_slett(_sti + ".state")
    hvis fil_finnes(_sti + ".idx")
        fil_slett(_sti + ".idx")
    hvis fil_finnes(_sti + ".users")
        fil_slett(_sti + ".users")
    hvis fil_finnes(_sti + ".roles")
        fil_slett(_sti + ".roles")

    la opprett = db_create(_sti)
    hvis opprett.feilet
        returner usann

    la åpne = db_open(_sti)
    hvis åpne.feilet
        returner usann

    la schema = table_create("brukere", [
        Kolonne("id", "int", sann, sann, sann),
        Kolonne("navn", "tekst", usann, usann, sann)
    ])
    hvis schema.feilet
        db_close()
        returner usann

    la indeks = index_create("brukere", "navn", usann)
    hvis indeks.feilet
        db_close()
        returner usann

    la inn = insert("brukere", { "navn": "Ada" })
    hvis inn.feilet
        db_close()
        returner usann

    la lukket = db_close()
    hvis lukket.feilet
        returner usann

    la reopen = db_open(_sti)
    hvis reopen.feilet
        returner usann

    la antall = count("brukere")
    la treff = select("brukere", [], { "navn": "Ada" })
    la indeksliste = index_list("brukere")
    la lukket2 = db_close()

    hvis lukket2.feilet
        returner usann

    returner ikke antall.feilet og antall.verdi == 1 og ikke treff.feilet og treff.verdi["antall"] == 1 og ikke indeksliste.feilet og lengde(indeksliste.verdi) == 1
slutt

funksjon main()
    start()
slutt

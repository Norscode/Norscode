bruk std.html som html
bruk std.frontend som frontend
bruk std.stil som stil
bruk std.web som web
bruk std.tekst som t

funksjon kort(overskrift: tekst, tekst_innhold: tekst) -> tekst {
    returner frontend.komponent_kort(overskrift, html.p("", html.escape(tekst_innhold)))
}

funksjon standard_navigasjon() -> tekst {
    returner frontend.nav_list(frontend.nav_link("Hjem", "/") + frontend.nav_link("Dokumentasjon", "/docs") + frontend.nav_link("Status", "/status") + frontend.nav_link("Søk", "/sok") + frontend.nav_link("Poster", "/poster") + frontend.nav_link("Artikler", "/artikler") + frontend.nav_link("Ruter", "/ruter"))
}

funksjon tema_stil() -> tekst {
    returner stil.stilark([
        stil.tema_lys([
            stil.token_farge("bg", "#f7f4ef"),
            stil.token_farge("surface", "#fffaf2"),
            stil.token_farge("ink", "#1f1a17"),
            stil.token_farge("muted", "#6f6258"),
            stil.token_farge("accent", "#b85c38"),
            stil.token_spacing("shell-pad", "3rem"),
            stil.token_radius("md", "12px"),
            stil.token_skygge("card", "0 18px 48px rgba(31, 26, 23, 0.08)")
        ]),
        stil.tema_mørk([
            stil.token_farge("bg", "#0f141b"),
            stil.token_farge("surface", "#141b24"),
            stil.token_farge("ink", "#f5efe7"),
            stil.token_farge("muted", "#b6a99b"),
            stil.token_farge("accent", "#f08b5d"),
            stil.token_spacing("shell-pad", "3rem"),
            stil.token_radius("md", "12px"),
            stil.token_skygge("card", "0 18px 48px rgba(0, 0, 0, 0.28)")
        ]),
        stil.regel("body", [
            stil.eigenskap("margin", "0"),
            stil.eigenskap("background", "linear-gradient(180deg, " + stil.token_ref("color-surface") + " 0%, " + stil.token_ref("color-bg") + " 100%)"),
            stil.eigenskap("color", stil.token_ref("color-ink")),
            stil.eigenskap("font-family", "\"Iowan Old Style\", \"Palatino Linotype\", \"Book Antiqua\", serif")
        ]),
        stil.regel(stil.klasse("shell"), [
            stil.eigenskap("max-width", "1120px"),
            stil.eigenskap("margin", "0 auto"),
            stil.eigenskap("padding", stil.token_ref("space-shell-pad") + " 1.5rem")
        ]),
        stil.regel(stil.klasse("app-header"), [
            stil.eigenskap("display", "flex"),
            stil.eigenskap("gap", "1rem"),
            stil.eigenskap("justify-content", "space-between"),
            stil.eigenskap("align-items", "baseline"),
            stil.eigenskap("padding-bottom", "1rem"),
            stil.eigenskap("margin-bottom", "2rem"),
            stil.eigenskap("border-bottom", "1px solid " + stil.token_ref("color-muted")),
            stil.eigenskap("background", stil.token_ref("color-surface")),
            stil.eigenskap("border-radius", stil.token_ref("radius-md")),
            stil.eigenskap("box-shadow", stil.token_ref("shadow-card"))
        ]),
        stil.regel(stil.klasse("app-header__brand"), [
            stil.eigenskap("color", stil.token_ref("color-accent"))
        ]),
        stil.regel(stil.klasse("app-footer"), [
            stil.eigenskap("margin-top", "2rem"),
            stil.eigenskap("color", stil.token_ref("color-muted"))
        ]),
        stil.regel(stil.barn(stil.klasse("hero"), "p"), [
            stil.eigenskap("color", stil.token_ref("color-muted"))
        ]),
        stil.media("(max-width: 760px)", [
            stil.regel(stil.klasse("shell"), [
                stil.eigenskap("padding", "1.5rem 1rem")
            ])
        ])
    ])
}

funksjon layout_app_med_stilark(tittel: tekst, navigasjon: tekst, innhold: tekst, footer_tekst: tekst) -> tekst {
    returner "<!doctype html>"
        + "<html lang='no'>"
        + "<head>"
        + "<meta charset='utf-8'>"
        + "<meta name='viewport' content='width=device-width,initial-scale=1'>"
        + "<title>" + tittel + "</title>"
        + "<style>"
        + tema_stil()
        + frontend.ui_stilark()
        + "</style>"
        + "</head>"
        + "<body>"
        + "<div class='shell'>"
        + "<header class='app-header'><div class='app-header__brand'><h1>" + tittel + "</h1></div><nav class='app-header__nav'>" + navigasjon + "</nav></header>"
        + "<main class='app-main'>" + innhold + "</main>"
        + "<footer class='app-footer'><p>" + footer_tekst + "</p></footer>"
        + "</div>"
        + frontend.ui_script()
        + "</body>"
        + "</html>"
}

funksjon ruter_innhold() -> tekst {
    la introduksjon: tekst = frontend.komponent_kort("Ruter og lenker", html.p("", html.escape("Denne siden viser de viktigste URL-ene i eksempelet og hvordan de kan åpnes direkte eller brukes som fragmentvisninger.")))
    la liste: tekst = frontend.komponent_liste(frontend.nav_link("Hjem", "/") + frontend.nav_link("Dokumentasjon", "/docs") + frontend.nav_link("Status", "/status") + frontend.nav_link("Søk med server-filter", "/sok?q=server") + frontend.nav_link("Poster side 2", "/poster?side=2") + frontend.nav_link("Poster sortert desc", "/poster?side=2&sort=desc") + frontend.nav_link("Artikler", "/artikler") + frontend.nav_link("Artikkel 7", "/artikler/7?visning=kort") + frontend.nav_link("Bruker 42", "/brukere/42?visning=kort"))
    la forklaring: tekst = frontend.komponent_kort("Praktisk bruk", frontend.komponent_stack(html.p("", html.escape("Alle lenkene over er delbare og kan åpnes direkte i browseren.")) + liste))
    returner html.div(html.class_attr("grid two"), introduksjon + forklaring)
}

funksjon ruter(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /ruter")
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), ruter_innhold(), "Bygd med component mode.", "Ruter")
}

funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")
    la orientering = frontend.komponent_breadcrumb(
        frontend.komponent_breadcrumb_lenke("Hjem", "/")
            + frontend.komponent_breadcrumb_lenke("Helpdesk", "/tickets")
            + frontend.komponent_breadcrumb_aktiv("Arbeidsflate")
    ) + frontend.komponent_varsling("SLA nærmer seg", "Fire saker har under to timer igjen før svarfrist.", "warning")
    la dashboard = orientering + frontend.komponent_sidehode(
        "Arbeidsflate",
        "Kompakte komponenter for dashboard, saksflyt og adminflater.",
        frontend.komponent_verktøylinje(
            frontend.komponent_knapp("Ny sak", frontend.modal_open_attrs("ticket-modal"))
                + frontend.komponent_knapp_sekundær("Eksporter", frontend.copy_attrs("demo-code", "Kopiert") + frontend.toast_attrs("demo-toast", "Eksport kopiert"))
                + frontend.komponent_toast_knapp("Vis varsel", "demo-toast", "Varsel frå Norscode UI-kit", "")
                + frontend.komponent_handlingsmeny(
                    "ticket-actions",
                    "Flere valg",
                    frontend.komponent_meny_lenke("Tildel sak", "/tickets/1024/assign")
                        + frontend.komponent_meny_knapp("Kopier saksnummer", frontend.copy_attrs("demo-code", "Saksnummer kopiert") + frontend.toast_attrs("demo-toast", "Saksnummer kopiert"))
                        + frontend.komponent_meny_skille()
                        + frontend.komponent_meny_lenke("Åpne audit-logg", "/tickets/1024/audit")
                )
        )
    ) + frontend.komponent_dashboard(
        frontend.komponent_stat("Åpne saker", "12", "3 nye i dag")
            + frontend.komponent_stat("Svarfrist", "4", "under 2 timer")
            + frontend.komponent_stat("Løst", "31", "denne uken")
    ) + frontend.komponent_oppsummering(
        "Dagens fokus",
        frontend.komponent_oppsummering_rad("Kritisk", "2 saker", "Mangler første svar")
            + frontend.komponent_oppsummering_rad("Neste SLA", "43 min", "Nordlys AS")
            + frontend.komponent_oppsummering_rad("Team", "Førstelinje", "3 agenter tilgjengelig")
    ) + frontend.komponent_kort(
        "Saksoversikt",
        frontend.komponent_stack(
            frontend.komponent_tabs(
                "Saksstatus",
                frontend.komponent_tab("Alle", "/tickets?status=all", "ja")
                    + frontend.komponent_tab("Åpne", "/tickets?status=open", "")
                    + frontend.komponent_tab("Venter", "/tickets?status=pending", "")
                    + frontend.komponent_tab("Lukket", "/tickets?status=closed", "")
            )
                + frontend.komponent_filterbar(
                    frontend.komponent_filterfelt("Filtrer saker", "ticket-filter", ".data-table tbody tr", "Søk etter kunde eller status")
                        + frontend.komponent_sortering("ticket-sort", "sort", "sla")
                        + frontend.komponent_segmentert(
                            "Visning",
                            frontend.komponent_segment("Mine", "/tickets?view=mine", "ja")
                                + frontend.komponent_segment("Team", "/tickets?view=team", "")
                                + frontend.komponent_segment("Alle", "/tickets?view=all", "")
                        )
                )
                + frontend.komponent_datatabell(
                    "Saker",
                    html.tr("", html.th("", "Sak") + html.th("", "Kunde") + html.th("", "Status") + html.th("", "Prioritet")),
                    frontend.komponent_ticket_rad("NC-1024", "Nordlys AS", "open", "high", "/tickets/1024")
                        + frontend.komponent_ticket_rad("NC-1025", "Fjord Drift", "pending", "normal", "/tickets/1025")
                        + frontend.komponent_tom_tabell("Ingen fleire saker", "Filteret kan skjule alle rader utan at layouten hopper.", "4")
                )
                + frontend.komponent_paginering("Sider", frontend.komponent_sideknapp("1", "/tickets?page=1", "ja") + frontend.komponent_sideknapp("2", "/tickets?page=2", ""))
                + frontend.komponent_toast_region("demo-toast")
        )
    ) + frontend.komponent_modal(
        "ticket-modal",
        "Ny sak",
        html.div(
            html.class_attr("form-grid"),
            frontend.komponent_felt("Tittel", "ticket-title", "text", "title", "", "Kort tittel")
                + frontend.komponent_felt("Kunde", "ticket-customer", "text", "customer", "", "Kundenavn")
                + frontend.komponent_statusvelger("ticket-status", "status", "open")
                + frontend.komponent_prioritetvelger("ticket-priority", "priority", "normal")
                + frontend.komponent_tekstfelt("Beskrivelse", "ticket-body", "body", "", "Hva trenger kunden hjelp med?")
                + frontend.komponent_checkbox_rad("Varsle kunde", "ticket-notify", "notify", "ja")
        ),
        frontend.komponent_form_actions(frontend.komponent_knapp("Lagre", frontend.toast_attrs("demo-toast", "Saka er lagret")) + frontend.komponent_knapp_sekundær("Avbryt", frontend.modal_close_attrs()))
    )
    la saksdetalj = frontend.komponent_detail_shell(
        frontend.komponent_panel(
            "NC-1024 Nordlys AS",
            html.p("", html.escape("Kunden får feilmelding ved innlogging og trenger avklaring før frist."))
                + frontend.komponent_kommentar_boks(
                    "Ny kommentar",
                    "ticket-comment",
                    "comment",
                    "Skriv svar eller intern merknad",
                    frontend.komponent_knapp("Legg til kommentar", frontend.toast_attrs("demo-toast", "Kommentar lagt til"))
                )
        ) + frontend.komponent_panel(
            "Aktivitet",
            frontend.komponent_aktivitet_liste(
                frontend.komponent_aktivitet("Sak opprettet", "09:12 av kunde", "Kunden meldte inn problemet fra portalen.")
                    + frontend.komponent_aktivitet("Tildelt agent", "09:18 av system", "Saken ble sendt til førstelinje.")
                    + frontend.komponent_aktivitet("Svarfrist satt", "09:20 av SLA", "Frist er satt til to timer.")
            )
        ),
        frontend.komponent_panel(
            "Detaljer",
            frontend.komponent_meta_liste(
                frontend.komponent_meta_rad("Kunde", "Nordlys AS")
                    + frontend.komponent_meta_html("Status", frontend.komponent_status_badge("open", "open"))
                    + frontend.komponent_meta_html("Prioritet", frontend.komponent_badge("high", "high"))
                    + frontend.komponent_meta_rad("Team", "Førstelinje")
                    + frontend.komponent_meta_rad("SLA", "2 timer")
            )
        ) + frontend.komponent_panel(
            "SLA",
            frontend.komponent_fremdrift("Svarfrist", "72%", "43 minutter brukt av 60", "72")
                + frontend.komponent_varsling("Neste handling", "Svar kunden før saken eskaleres til teamleder.", "danger")
                + frontend.komponent_tilstand(
                    "Risiko for brudd",
                    "Saken trenger svar før fristen løper ut.",
                    "warning",
                    frontend.komponent_tilstand_handling("Åpne SLA-regel", "/admin/sla")
                )
        ) + frontend.komponent_panel(
            "Saksgang",
            frontend.komponent_stegliste(
                "Saksgang",
                frontend.komponent_steg("Opprettet", "09:12 av kunde", "done")
                    + frontend.komponent_steg("Triagert", "09:18 av førstelinje", "done")
                    + frontend.komponent_steg("Svar kunde", "Pågår nå", "current")
                    + frontend.komponent_steg("Løs og lukk", "Venter på svar", "waiting")
            )
        ) + frontend.komponent_panel(
            "Kunnskap",
            frontend.komponent_disclosure_liste(
                frontend.komponent_disclosure("Kundehistorikk", html.p("", html.escape("Nordlys AS har tre åpne saker og bruker SSO mot egen identitetsleverandør.")), "ja")
                    + frontend.komponent_disclosure("Foreslått svar", html.p("", html.escape("Bekreft feilmeldingen, be om tidspunkt og legg ved status for innloggingssystemet.")), "")
                    + frontend.komponent_disclosure("Feilsøkingssteg", html.p("", html.escape("Sjekk siste innlogging, SSO-konfigurasjon og eventuelle rate limit-hendelser.")), "")
            )
        ) + frontend.komponent_tomt_panel("Vedlegg", "Ingen vedlegg er lagt til.")
    )
    la interaktivt = frontend.komponent_kort(
        "Interaktivitet",
        frontend.komponent_stack(
            html.toggle_knapp("Vis detaljer", "demo-panel", "is-open")
                + html.div(html.id_attr("demo-panel") + html.class_attr("demo-panel"), html.p("", html.escape("Denne boksen styres av Norscode-generert script.")))
                + html.div(
                    html.data_handling("tabs", "demo"),
                    html.tab_knapp("Første", "demo-tab-1")
                        + html.tab_knapp("Andre", "demo-tab-2")
                        + html.div(html.panel_attrs("demo-tab-1"), html.p("", html.escape("Første fane.")))
                        + html.div(html.panel_attrs("demo-tab-2") + html.attr("hidden", "hidden"), html.p("", html.escape("Andre fane.")))
                )
                + html.div(
                    html.class_attr("toolbar"),
                    html.modal_knapp("Åpne dialog", "demo-dialog")
                        + frontend.komponent_handlingsmeny(
                            "demo-menu",
                            "Meny",
                            frontend.komponent_meny_knapp("Ny sak", frontend.modal_open_attrs("ticket-modal"))
                                + frontend.komponent_meny_lenke("Eksporter", "/eksport")
                        )
                        + html.button(html.attr("type", "button") + html.copy_attrs("demo-code", "Kopiert"), html.escape("Kopier"))
                )
                + html.div(
                    html.modal_attrs("demo-dialog"),
                    html.h2("", html.escape("Dialog"))
                        + html.p("", html.escape("Modalen er styrt av standard Norscode-script."))
                        + html.button(html.attr("type", "button") + html.modal_close_attrs(), html.escape("Lukk"))
                )
                + html.p(html.id_attr("demo-code"), html.escape("norscode run examples/frontend.no"))
                + html.textarea(html.autoresize_attrs() + html.attr("placeholder", "Skriv tekst"), "")
                + html.input(html.attr("type", "search") + html.attr("placeholder", "Filtrer") + html.livefilter_attrs("demo-filter-list li"))
                + html.partial_list(html.id_attr("demo-filter-list"), html.li("", html.escape("Knapper")) + html.li("", html.escape("Dialoger")) + html.li("", html.escape("Skjema")))
                + html.form(
                    html.attr("method", "post")
                        + html.json_form_attrs("/api/demo", "demo-json-result")
                        + html.form_status_attrs("demo-json-status", "Sender", "Lagret", "Kunne ikke lagre"),
                    html.input(html.attr("name", "tittel") + html.attr("value", "Demo"))
                        + html.submit("", "Send JSON")
                )
                + html.p(html.id_attr("demo-json-status"), html.escape("Klar"))
                + html.p(html.id_attr("demo-json-result"), "")
        )
    )
    la innhold = dashboard + saksdetalj + html.div("", frontend.komponent_hero("Ryddig, server-rendert frontend", "Dette er en liten startside som bruker layout, komponenter og statiske assets.", html.form(html.class_attr("search-form") + html.autosubmit_attrs("400"), html.label(html.class_attr("field"), html.escape("Søk")) + html.input(html.attr("type", "search") + html.attr("name", "q") + html.attr("placeholder", "Finn sider")) + html.button(html.class_attr("btn"), html.escape("Søk"))))) + html.div(html.class_attr("grid two"), html.div(html.id_attr("modeller"), kort("Modell", "Server-renderte sider og små komponenter.")) + html.div(html.id_attr("oversikt"), kort("Neste steg", "Legg til flere sider, lister og skjemaer."))) + html.div(html.class_attr("grid two"), frontend.komponent_kort("Skjema-hjelpere", html.form(html.class_attr("settings-form") + html.disable_submit_attrs("Lagrer"), html.fieldset("", html.legend("", html.escape("Innstillinger")) + frontend.komponent_stack(html.label(html.attr("for", "mork"), html.escape("Mørk modus")) + html.checkbox(html.id_attr("mork") + html.attr("name", "mork") + html.attr("checked", "checked")) + html.label(html.attr("for", "varsling"), html.escape("Varslinger")) + html.switch(html.id_attr("varsling") + html.attr("name", "varsling") + html.attr("checked", "checked")) + html.label(html.attr("for", "valg-raskt"), html.escape("Raskt valg")) + html.radio(html.id_attr("valg-raskt") + html.attr("name", "valg") + html.attr("value", "raskt"))) + html.div(html.class_attr("form-actions"), html.submit("", "Lagre") + html.reset(html.confirm_attrs("Nullstille skjemaet?"), "Nullstill")))))) + interaktivt + html.partial_card(html.id_attr("status"), "Oversikt", html.h2("", html.escape("Komponenter")) + html.partial_list(html.class_attr("steps"), html.li("", html.escape("Bygg små komponenter")) + html.li("", html.escape("Sett dem sammen i layouts")) + html.li("", html.escape("Vis data som lister og tabeller"))) + html.partial_table("", html.thead("", html.tr("", html.th("", "Komponent") + html.th("", "Bruk"))) + html.tbody("", html.tr("", html.td("", "form") + html.td("", "Skjema og input")) + html.tr("", html.td("", "table") + html.td("", "Dataoversikt"))))) + html.div(html.class_attr("grid two"), frontend.komponent_alert("Tips", "Bruk alert for tydelige meldinger som bør skille seg ut fra vanlig innhold.") + frontend.komponent_empty("Ingen data", "Denne komponenten kan brukes når en liste eller tabell er tom.")) + frontend.komponent_loading("Laster eksempeldata og bygger siden...")
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, layout_app_med_stilark("Norscode Frontend", standard_navigasjon(), innhold, "Bygd med component mode."))
}

funksjon status_innhold() -> tekst {
    returner frontend.komponent_kort("Server-fragmenter", html.p("", html.escape("Samme komponenter kan brukes for fullside-rendering og fragment-respons.")))
}

funksjon status(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /status")
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), status_innhold(), "Bygd med component mode.", "Status")
}

funksjon docs_innhold() -> tekst {
    returner html.div(html.class_attr("grid two"), frontend.komponent_kort("Dokumentasjon", html.p("", html.escape("Samme komponenter kan bygges som fullside eller fragment."))) + frontend.komponent_kort("Kontrakt", html.p("", html.escape("Fragmenter bruker samme markup, men et annet svarformat."))))
}

funksjon docs(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /docs")
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), docs_innhold(), "Bygd med component mode.", "Dokumentasjon")
}

funksjon sok_innhold(query: tekst) -> tekst {
    la kandidater: liste_tekst = ["server-renderte sider", "server-fragmenter", "komponenter", "skjemaer", "navigasjon"]
    la treff: tekst = ""
    for kandidat i kandidater {
        hvis (query == "" eller t.inneholder(kandidat, query)) {
            treff = treff + html.li("", html.escape(kandidat))
        }
    }
    la treffvisning: tekst = hvis (treff == "") da frontend.komponent_empty("Ingen treff", "Prøv et annet ord i søkefeltet.") ellers frontend.komponent_liste(treff)
    returner html.div("", frontend.komponent_kort("Søk", html.p("", html.escape("Spør etter en del av frontenden for å filtrere innholdet på serveren.")))) + frontend.komponent_kort("Treff", treffvisning)
}

funksjon sok(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /sok")
    la query: tekst = t.trim(web.request_query_param(ctx, "q"))
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), sok_innhold(query), "Bygd med component mode.", "Søk")
}

funksjon post_kort(tittel: tekst, innhold: tekst) -> tekst {
    returner frontend.komponent_kort(tittel, html.p("", html.escape(innhold)))
}

funksjon poster_innhold(side: tekst, sortering: tekst, kategori_filter: tekst) -> tekst {
    la side_nr: tekst = side
    hvis (side_nr == "") {
        side_nr = "1"
    }
    la sort: tekst = sortering
    hvis (sort == "") {
        sort = "asc"
    }
    la kategori: tekst = kategori_filter
    hvis (kategori == "") {
        kategori = "alle"
    }
    la introduksjon: tekst = frontend.komponent_kort("Paginert liste", html.p("", html.escape("Denne siden viser hvordan serveren kan levere både full side og fragment når du blar i en liste, og hvordan sortering kan styres med URL-en.")))
    la sortering_visning: tekst = frontend.nav_list(frontend.nav_link("A-Å", "/poster?side=" + side_nr + "&sort=asc&kategori=" + kategori) + frontend.nav_link("Å-A", "/poster?side=" + side_nr + "&sort=desc&kategori=" + kategori))
    la kategori_visning: tekst = frontend.nav_list(frontend.nav_link("Alle", "/poster?side=" + side_nr + "&sort=" + sort + "&kategori=alle") + frontend.nav_link("Server", "/poster?side=" + side_nr + "&sort=" + sort + "&kategori=server") + frontend.nav_link("Fragment", "/poster?side=" + side_nr + "&sort=" + sort + "&kategori=fragment") + frontend.nav_link("UI", "/poster?side=" + side_nr + "&sort=" + sort + "&kategori=ui"))
    la paginering: tekst = frontend.nav_list(frontend.nav_link("1", "/poster?side=1&sort=" + sort + "&kategori=" + kategori) + frontend.nav_link("2", "/poster?side=2&sort=" + sort + "&kategori=" + kategori) + frontend.nav_link("3", "/poster?side=3&sort=" + sort + "&kategori=" + kategori))
    la innhold: tekst = hvis (side_nr == "2") da hvis (kategori == "server") da post_kort("Post 3", "Serveren kan bare rendere akkurat den siden du trenger.") ellers hvis (kategori == "fragment") da post_kort("Post 4", "Fragmenter gjør det tydelig hva som er delvis innhold.") ellers hvis (sort == "desc") da post_kort("Post 4", "Fragmenter gjør det tydelig hva som er delvis innhold.") + post_kort("Post 3", "Serveren kan bare rendere akkurat den siden du trenger.") ellers post_kort("Post 3", "Serveren kan bare rendere akkurat den siden du trenger.") + post_kort("Post 4", "Fragmenter gjør det tydelig hva som er delvis innhold.") ellers hvis (side_nr == "3") da hvis (kategori == "ui" eller kategori == "alle") da post_kort("Post 5", "Samme komponenter kan brukes i alle svarformer.") + frontend.komponent_empty("Ingen flere poster", "Dette var siste side i eksemplet.") ellers frontend.komponent_empty("Ingen treff", "Denne kategorien har ingen poster på side 3.") ellers hvis (sort == "desc") da hvis (kategori == "server") da post_kort("Post 3", "Serveren kan bare rendere akkurat den siden du trenger.") ellers hvis (kategori == "fragment") da post_kort("Post 4", "Fragmenter gjør det tydelig hva som er delvis innhold.") ellers post_kort("Post 2", "Neste side viser at samme route kan pagineres.") + post_kort("Post 1", "Første side i listen viser grunnstrukturen.") ellers hvis (kategori == "server") da post_kort("Post 1", "Første side i listen viser grunnstrukturen.") ellers hvis (kategori == "fragment") da post_kort("Post 2", "Neste side viser at samme route kan pagineres.") ellers post_kort("Post 1", "Første side i listen viser grunnstrukturen.") + post_kort("Post 2", "Neste side viser at samme route kan pagineres.")
    la innholdsvisning: tekst = html.div(html.class_attr("grid two"), innhold)
    returner introduksjon + sortering_visning + kategori_visning + innholdsvisning + paginering
}

funksjon poster(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /poster")
    la side: tekst = t.trim(web.request_query_param(ctx, "side"))
    la sortering: tekst = t.trim(web.request_query_param(ctx, "sort"))
    la kategori: tekst = t.trim(web.request_query_param(ctx, "kategori"))
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), poster_innhold(side, sortering, kategori), "Bygd med component mode.", "Poster")
}

funksjon bruker_innhold(id: heltall, visning: tekst) -> tekst {
    la id_tekst: tekst = tekst_fra_heltall(id)
    la overskrift: tekst = hvis (id == 0) da "Ukjent bruker" ellers "Bruker " + id_tekst
    la kort_visning: tekst = hvis (visning == "kort") da frontend.komponent_kort(overskrift, html.p("", html.escape("Kort visning av en server-rendret detaljside."))) ellers frontend.komponent_kort(overskrift, html.p("", html.escape("Detaljvisning som kan server-rendres som full side eller fragment."))) + frontend.komponent_kort("Meta", html.p("", html.escape("URL-en bærer identiteten, og fragmentet bærer innholdet.")))
    returner html.div(html.class_attr("grid two"), kort_visning)
}

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id}")
    la id: heltall = web.request_param_int(ctx, "id")
    la visning: tekst = t.trim(web.request_query_param(ctx, "visning"))
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), bruker_innhold(id, visning), "Bygd med component mode.", "Bruker")
}

funksjon artikkel_innhold(id: heltall, visning: tekst) -> tekst {
    la id_tekst: tekst = tekst_fra_heltall(id)
    la overskrift: tekst = hvis (id == 0) da "Ukjent artikkel" ellers "Artikkel " + id_tekst
    la hovedvisning: tekst = hvis (visning == "kort") da frontend.komponent_kort(overskrift, html.p("", html.escape("Kort visning av en server-rendret artikkel."))) ellers frontend.komponent_kort(overskrift, html.p("", html.escape("Detaljvisning som kan server-rendres som full side eller fragment."))) + frontend.komponent_kort("Meta", html.p("", html.escape("Path-parametere kan brukes for å velge identitet og query-parametere for visning.")))
    returner html.div(html.class_attr("grid two"), hovedvisning)
}

funksjon artikkel(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /artikler/{id}")
    la id: heltall = web.request_param_int(ctx, "id")
    la visning: tekst = t.trim(web.request_query_param(ctx, "visning"))
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), artikkel_innhold(id, visning), "Bygd med component mode.", "Artikkel")
}

funksjon artikler_innhold() -> tekst {
    la intro: tekst = frontend.komponent_kort("Artikler", html.p("", html.escape("Denne samlesiden viser hvordan path-baserte detaljer kan henge sammen med fullside og fragment-svar.")))
    la liste: tekst = frontend.komponent_liste(frontend.nav_link("Artikkel 7", "/artikler/7?visning=kort") + frontend.nav_link("Artikkel 12", "/artikler/12?visning=kort") + frontend.nav_link("Artikkel 42", "/artikler/42?visning=kort"))
    la oversikt: tekst = frontend.komponent_kort("Velg artikkel", frontend.komponent_stack(html.p("", html.escape("Bruk lenkene under for å åpne en detaljside.")) + liste))
    returner html.div(html.class_attr("grid two"), intro + oversikt)
}

funksjon artikler(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /artikler")
    returner frontend.fragment_page(ctx, "Norscode Frontend", standard_navigasjon(), artikler_innhold(), "Bygd med component mode.", "Artikler")
}

funksjon start() -> heltall {
    la respons = web.handle_request(web.request_context("get", "/", {}, {}, ""))
    skriv(web.response_header(respons, "content-type"))
    skriv(web.response_body(respons))
    returner 0
}

bruk std.html som html
bruk std.web som web

funksjon layout_main(tittel: tekst, innhold: tekst) -> tekst {
    returner html.page(tittel, innhold, "/assets/css/app.css")
}

funksjon kort(overskrift: tekst, tekst_innhold: tekst) -> tekst {
    returner html.partial_card("", overskrift, html.p("", html.escape(tekst_innhold)))
}

funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")
    la toppnavigasjon = html.partial_nav(
        "",
        html.partial_list(
            "",
            html.li("", html.a(html.attr("href", "#modeller"), html.escape("Modeller")))
                + html.li("", html.a(html.attr("href", "#oversikt"), html.escape("Oversikt")))
                + html.li("", html.a(html.attr("href", "#status"), html.escape("Status")))
        )
    )

    la innhold = html.div(
        html.class_attr("hero card"),
        html.div(
            html.class_attr("eyebrow"),
            html.badge(html.class_attr("badge--info"), "Nytt HTML-API")
                + html.span("", html.escape("Norscode frontend"))
        )
            + html.h1("", html.escape("Ryddig, server-rendert frontend"))
            + html.p(
                "",
                html.escape("Dette er en liten startside som bruker layout, komponenter og statiske assets.")
            )
            + html.form(
                html.class_attr("search-form"),
                html.label(html.class_attr("field"), html.escape("Søk"))
                    + html.input(
                        html.attr("type", "search")
                            + html.attr("name", "q")
                            + html.attr("placeholder", "Finn sider")
                    )
                    + html.button(html.class_attr("btn"), html.escape("Søk"))
            )
    ) + html.div(
        html.class_attr("grid two"),
        html.div(html.id_attr("modeller"), kort("Modell", "Server-renderte sider og små komponenter."))
            + html.div(html.id_attr("oversikt"), kort("Neste steg", "Legg til flere sider, lister og skjemaer."))
    ) + html.partial_card(
        html.id_attr("status"),
        "Oversikt",
        html.h2("", html.escape("Komponenter"))
            + html.partial_list(
                html.class_attr("steps"),
                html.li("", html.escape("Bygg små komponenter"))
                    + html.li("", html.escape("Sett dem sammen i layouts"))
                    + html.li("", html.escape("Vis data som lister og tabeller"))
            )
            + html.partial_table(
                "",
                html.thead(
                    "",
                    html.tr(
                        "",
                        html.th("", "Komponent")
                            + html.th("", "Bruk")
                    )
                )
                + html.tbody(
                    "",
                    html.tr("", html.td("", "form") + html.td("", "Skjema og input"))
                        + html.tr("", html.td("", "table") + html.td("", "Dataoversikt"))
                )
            )
    ) + html.div(
        html.class_attr("grid two"),
        html.alert(
            html.class_attr("alert--info"),
            "Tips",
            "Bruk alert for tydelige meldinger som bør skille seg ut fra vanlig innhold."
        )
            + html.empty_state(
                html.class_attr("card"),
                "Ingen data",
                "Denne komponenten kan brukes når en liste eller tabell er tom."
            )
    ) + html.loading_state(
        html.class_attr("card"),
        "Laster eksempeldata og bygger siden..."
    )
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, layout_main("Norscode Frontend", toppnavigasjon + innhold))
}

funksjon start() -> heltall {
    la respons = web.handle_request(web.request_context("get", "/", {}, {}, ""))
    skriv(web.response_header(respons, "content-type"))
    skriv(web.response_body(respons))
    returner 0
}

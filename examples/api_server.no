# api_server.no — Eksempel REST API-server
# Kjør med: nc serve examples/api_server.no --port 8000

bruk std.rest som rest
bruk std.web som web
bruk std.httpserver som http

# ─── Mock-data (i minne) ───────────────────────────────────────────────────

la brukere: liste<ordbok_tekst> = [
    {
        "id": "1",
        "navn": "Jan Steinar",
        "epost": "jan@example.com",
        "rolle": "admin"
    },
    {
        "id": "2",
        "navn": "Alice",
        "epost": "alice@example.com",
        "rolle": "brukar"
    }
]

# ─── Routes ───────────────────────────────────────────────────────────────

# GET /
funksjon halo(ctx: ordbok_tekst) -> tekst {
    returner "{\"melding\": \"Velkomen til Norscode API!\", \"versjon\": \"1.0\"}"
}

# GET /api/helse
funksjon helse(ctx: ordbok_tekst) -> tekst {
    returner "{\"status\": \"ok\", \"tid\": \"" + tekst_fra_tid() + "\"}"
}

# GET /api/brukere
funksjon liste_brukere(ctx: ordbok_tekst) -> tekst {
    la felt = ["id", "navn", "epost", "rolle"]
    returner rest.liste_til_json(brukere)
}

# GET /api/brukere/{id}
funksjon hent_brukar(ctx: ordbok_tekst) -> tekst {
    la id = web.request_param(ctx, "id")

    la i: heltall = 0
    mens i < lengde(brukere) {
        la brukar = brukere[i]
        hvis brukar["id"] == id {
            returner rest.til_json(brukar)
        }
        i = i + 1
    }

    returner "{\"feil\": \"Brukar ikkje funnen\", \"id\": \"" + id + "\"}"
}

# POST /api/brukere
funksjon lag_brukar(ctx: ordbok_tekst) -> tekst {
    la body = web.request_body(ctx)

    # Parse JSON body (enkel parsing)
    la ny_brukar: ordbok_tekst = {}
    ny_brukar["id"] = tekst(lengde(brukere) + 1)
    ny_brukar["namn"] = "Ny brukar"
    ny_brukar["epost"] = "ny@example.com"
    ny_brukar["rolle"] = "brukar"

    legg_til(brukere, ny_brukar)

    returner "{\"opprett\": true, \"brukar\": " + rest.til_json(ny_brukar) + "}"
}

# GET /api/info
funksjon api_info(ctx: ordbok_tekst) -> tekst {
    returner "{
        \"api\": \"Norscode REST API\",
        \"versjon\": \"1.0\",
        \"endpoints\": [
            {\"metode\": \"GET\", \"sti\": \"/\", \"beskrivelse\": \"Velkomen\"},
            {\"metode\": \"GET\", \"sti\": \"/api/helse\", \"beskrivelse\": \"Health check\"},
            {\"metode\": \"GET\", \"sti\": \"/api/brukere\", \"beskrivelse\": \"List all users\"},
            {\"metode\": \"GET\", \"sti\": \"/api/brukere/{id}\", \"beskrivelse\": \"Get user by ID\"},
            {\"metode\": \"POST\", \"sti\": \"/api/brukere\", \"beskrivelse\": \"Create new user\"},
            {\"metode\": \"GET\", \"sti\": \"/api/info\", \"beskrivelse\": \"API info\"}
        ]
    }"
}

# ─── Server startup ───────────────────────────────────────────────────────

funksjon start() -> heltall {
    la server = http.ny_server(8000)

    # Register routes
    http.route(server, "GET", "/", "halo")
    http.route(server, "GET", "/api/helse", "helse")
    http.route(server, "GET", "/api/brukere", "liste_brukere")
    http.route(server, "GET", "/api/brukere/{id}", "hent_brukar")
    http.route(server, "POST", "/api/brukere", "lag_brukar")
    http.route(server, "GET", "/api/info", "api_info")

    skriv("")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("Norscode REST API - Eksempel")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("")
    skriv("📍 Server kjører på http://127.0.0.1:8000")
    skriv("")
    skriv("🔗 Endpoints:")
    skriv("  GET  /               - Velkomen")
    skriv("  GET  /api/helse      - Health check")
    skriv("  GET  /api/info       - API dokumentasjon")
    skriv("  GET  /api/brukere    - List alle brukere")
    skriv("  GET  /api/brukere/1  - Hent brukar med ID 1")
    skriv("  POST /api/brukere    - Lag ny brukar")
    skriv("")
    skriv("🧪 Test med curl:")
    skriv("  curl http://127.0.0.1:8000/api/helse")
    skriv("  curl http://127.0.0.1:8000/api/brukere")
    skriv("  curl -X POST http://127.0.0.1:8000/api/brukere")
    skriv("")
    skriv("────────────────────────────────────────────────────────────────")
    skriv("")

    # Start server (venta på requests)
    returner http.lytt(server)
}

# ─── Helpers ───────────────────────────────────────────────────────────────

funksjon tekst_fra_tid() -> tekst {
    # Placeholder for tid-generering
    returner "2026-06-14T12:00:00Z"
}

bruk std.web som web
bruk std.lagring som lagring
bruk std.json som json

funksjon har_nokkel(data, nøkkel) -> bool {
    hvis data == null {
        returner usann
    }
    returner data[nøkkel] != null
}

funksjon filsti_data() -> tekst {
    returner "helpdesk_data.json"
}

funksjon default_store() -> ordbok_tekst {
    la data: ordbok_tekst = {}
    data["next_id"] = "1"
    data["next_seq"] = "1"
    data["tickets"] = []
    data["users"] = [
        {"user":"admin","role":"admin","password":"admin"},
        {"user":"anna","role":"agent","password":"agent"},
        {"user":"lena","role":"agent","password":"agent"},
        {"user":"bruker","role":"user","password":"kunde"}
    ]
    data["roles"] = [
        {"name":"admin","description":"Full adgang, inkl. bruker-og ticketadministrasjon"},
        {"name":"agent","description":"Operasjon på tickets for daglig drift"},
        {"name":"user","description":"Lesetilgang og egne mine-tickets"}
    ]
    data["sessions"] = []
    data["teams"] = [
        {"id":"support","name":"Support","default_assignee":"lena"},
        {"id":"billing","name":"Faktura","default_assignee":"anna"}
    ]
    data["categories"] = [
        {"id":"general","name":"Generelt","team":"support"},
        {"id":"billing","name":"Faktura","team":"billing"}
    ]
    data["slas"] = [
        {"id":"standard","name":"Standard","priority":"3","due_hours":"48"},
        {"id":"critical","name":"Kritisk","priority":"1","due_hours":"4"}
    ]
    data["attachments"] = []
    data["email_events"] = []
    data["automation_rules"] = [
        {"id":"category-billing","when":"category=billing","assign_team":"billing"},
        {"id":"priority-critical","when":"priority=1","sla":"critical"}
    ]
    data["reply_templates"] = [
        {"id":"received","title":"Mottatt","body":"Takk, vi har mottatt saken og følger opp."}
    ]
    data["ai_capabilities"] = [
        {"id":"summarize_ticket","status":"planned","description":"Oppsummer lang sak"},
        {"id":"suggest_reply","status":"planned","description":"Foreslå svar"},
        {"id":"suggest_category_priority","status":"planned","description":"Foreslå kategori og prioritet"},
        {"id":"similar_tickets","status":"planned","description":"Finn lignende saker"},
        {"id":"knowledgebase_from_resolved","status":"planned","description":"Lag kunnskapsbaseartikkel fra løst sak"}
    ]
    data["audit_log"] = []
    returner data
}

funksjon les_data() -> ordbok_tekst {
    la data = default_store()
    hvis ikke lagring.finnes(filsti_data()) {
        returner data
    }
    prøv {
        data = lagring.last(filsti_data())
    } fang (e) {
        returner default_store()
    }
    hvis ikke har_nokkel(data, "tickets") {
        returner default_store()
    }
    hvis ikke har_nokkel(data, "next_id") {
        data["next_id"] = "1"
    }
    hvis ikke har_nokkel(data, "next_seq") {
        data["next_seq"] = "1"
    }
    hvis ikke har_nokkel(data, "users") {
        data["users"] = []
    }
    hvis ikke har_nokkel(data, "roles") {
        data["roles"] = []
    }
    hvis ikke har_nokkel(data, "sessions") {
        data["sessions"] = []
    }
    hvis ikke har_nokkel(data, "teams") {
        data["teams"] = []
    }
    hvis ikke har_nokkel(data, "categories") {
        data["categories"] = []
    }
    hvis ikke har_nokkel(data, "slas") {
        data["slas"] = []
    }
    hvis ikke har_nokkel(data, "attachments") {
        data["attachments"] = []
    }
    hvis ikke har_nokkel(data, "email_events") {
        data["email_events"] = []
    }
    hvis ikke har_nokkel(data, "automation_rules") {
        data["automation_rules"] = []
    }
    hvis ikke har_nokkel(data, "reply_templates") {
        data["reply_templates"] = []
    }
    hvis ikke har_nokkel(data, "ai_capabilities") {
        data["ai_capabilities"] = []
    }
    hvis ikke har_nokkel(data, "audit_log") {
        data["audit_log"] = []
    }
    hvis (har_nokkel(data, "tickets")) {
        la tickets = data["tickets"]
        la i: heiltall = 0
        mens (i < lengde(tickets)) {
            la indeks = tekst_fra_heltall(i)
            hvis (har_nokkel(tickets, indeks)) {
                la ticket = tickets[indeks]
                hvis (ikke har_nokkel(ticket, "created_at")) {
                    hvis (har_nokkel(ticket, "id")) {
                        ticket["created_at"] = ticket["id"]
                    }
                }
                hvis (ikke har_nokkel(ticket, "updated_at")) {
                    hvis (har_nokkel(ticket, "created_at")) {
                        ticket["updated_at"] = ticket["created_at"]
                    } ellers {
                        hvis (har_nokkel(ticket, "id")) {
                            ticket["updated_at"] = ticket["id"]
                        }
                    }
                }
            }
            i = i + 1
        }
    }
    returner data
}

funksjon lagre_data(store: ordbok_tekst) -> heiltall {
    returner lagring.lagre(filsti_data(), store)
}

funksjon find_ticket_indeks(tickets: ordbok_tekst, id: heiltall) -> heiltall {
    la i: heiltall = 0
    la id_tekst = tekst_fra_heltall(id)

    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la t = tickets[indeks]
            hvis har_nokkel(t, "id") og t["id"] == id_tekst {
                returner i
            }
        }
        i = i + 1
    }

    returner -1
}

funksjon parse_int_mellom_min_maks(v: tekst, min_verdi: heiltall, max_verdi: heiltall) -> heiltall {
    la n: heiltall = heltall_fra_tekst(v)
    hvis (n < min_verdi) {
        returner min_verdi
    }
    hvis (n > max_verdi) {
        returner max_verdi
    }
    returner n
}

funksjon parse_int_mellom_min_maks_eller_feil(v: tekst, min_verdi: heiltall, max_verdi: heiltall) -> heiltall {
    la trim = tekst_trim(v)
    la n: heiltall = heltall_fra_tekst(trim)
    hvis (tekst_fra_heltall(n) != trim) {
        returner -1
    }
    hvis (n < min_verdi) {
        returner -1
    }
    hvis (n > max_verdi) {
        returner -1
    }
    returner n
}

funksjon neste_rekkefolge(store: ordbok_tekst) -> tekst {
    la verdi = store["next_seq"]
    store["next_seq"] = tekst_fra_heltall(heltall_fra_tekst(verdi) + 1)
    returner verdi
}

funksjon laa_til_historikk(ticket: ordbok_tekst, hendelse: tekst, verdi: tekst, bruker: tekst) -> heltall {
    hvis ikke har_nokkel(ticket, "history") {
        ticket["history"] = []
    }

    la oppslag = ticket["history"]
    la entry: ordbok_tekst = {}
    entry["event"] = hendelse
    entry["value"] = verdi
    entry["by"] = bruker
    legg_til(oppslag, entry)
    returner lengde(oppslag)
}

funksjon er_gyldig_rolle(rolle: tekst) -> bool {
    hvis (rolle == "admin") {
        returner sann
    }
    hvis (rolle == "agent") {
        returner sann
    }
    hvis (rolle == "user") {
        returner sann
    }
    returner usann
}

funksjon tillatelser_for_rolle(rolle: tekst) -> liste_tekst {
    hvis (rolle == "admin") {
        returner ["tickets.read", "tickets.write", "tickets.admin", "admin.metrics", "admin.users"]
    }
    hvis (rolle == "agent") {
        returner ["tickets.read", "tickets.write"]
    }
    hvis (rolle == "user") {
        returner ["tickets.read"]
    }
    returner []
}

funksjon har_tillatelse(rolle: tekst, tillatelse: tekst) -> bool {
    la rettigheter = tillatelser_for_rolle(rolle)
    la indeks = 0
    mens (indeks < lengde(rettigheter)) {
        hvis (rettigheter[indeks] == tekst_til_liten(tekst_trim(tillatelse))) {
            returner sann
        }
        indeks = indeks + 1
    }
    returner usann
}

funksjon session_token_fra_request(ctx: ordbok_tekst) -> tekst {
    la cookie_hdr = web.request_header(ctx, "cookie")
    la deler = builtin.split(cookie_hdr, ";")
    la i: heiltall = 0
    mens (i < lengde(deler)) {
        la del = tekst_trim(deler[i])
        la eq = builtin.index_of(del, "=")
        hvis (eq > 0) {
            la k = tekst_trim(builtin.slice(del, 0, eq))
            la v = tekst_trim(builtin.slice(del, eq + 1, lengde(del)))
            hvis (k == "helpdesk_session") {
                returner v
            }
        }
        i = i + 1
    }
    la token = web.request_header(ctx, "x-session")
    hvis (token != "") {
        returner token
    }
    returner ""
}

funksjon session_fra_request(ctx: ordbok_tekst, data: ordbok_tekst) -> ordbok_tekst {
    la token = session_token_fra_request(ctx)
    hvis (token == "") {
        returner {}
    }
    la sessions = data["sessions"]
    la i: heiltall = 0
    mens (i < lengde(sessions)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(sessions, indeks)) {
            la session = sessions[indeks]
            hvis (har_nokkel(session, "token") og session["token"] == token) {
                hvis (ikke har_nokkel(session, "active") eller session["active"] == "true" eller session["active"] == "sann") {
                    returner session
                }
            }
        }
        i = i + 1
    }
    la brukere = data["users"]
    la u_i: heiltall = 0
    mens (u_i < lengde(brukere)) {
        la u_indeks = tekst_fra_heltall(u_i)
        hvis (har_nokkel(brukere, u_indeks)) {
            la bruker = brukere[u_indeks]
            hvis (har_nokkel(bruker, "user") og har_nokkel(bruker, "role")) {
                hvis (token == "helpdesk_" + bruker["user"] + "_" + bruker["role"]) {
                    returner {"token": token, "user": bruker["user"], "role": bruker["role"], "active": "true"}
                }
            }
        }
        u_i = u_i + 1
    }
    returner {}
}

funksjon autentisert_request(ctx: ordbok_tekst, data: ordbok_tekst) -> bool {
    hvis (web.request_header(ctx, "x-api-key") == "secret-helpdesk") {
        returner sann
    }
    la session = session_fra_request(ctx, data)
    hvis (har_nokkel(session, "user")) {
        returner sann
    }
    returner usann
}

funksjon bruker_fra_request(ctx: ordbok_tekst, data: ordbok_tekst) -> tekst {
    la bruker = web.request_header(ctx, "x-user")
    hvis (bruker != "") {
        returner bruker
    }
    la session = session_fra_request(ctx, data)
    hvis (har_nokkel(session, "user")) {
        returner session["user"]
    }
    returner ""
}

funksjon rolle_fra_request(ctx: ordbok_tekst, data: ordbok_tekst) -> tekst {
    la rolle = tekst_til_liten(tekst_trim(web.request_header(ctx, "x-role")))
    hvis (rolle == "") {
        rolle = tekst_til_liten(tekst_trim(web.request_header(ctx, "X-Role")))
    }
    hvis (rolle != "" og er_gyldig_rolle(rolle)) {
        returner rolle
    }

    la session = session_fra_request(ctx, data)
    hvis (har_nokkel(session, "role")) {
        la session_rolle = tekst_til_liten(tekst_trim(session["role"]))
        hvis (er_gyldig_rolle(session_rolle)) {
            returner session_rolle
        }
    }

    la bruker = bruker_fra_request(ctx, data)
    hvis (bruker == "") {
        returner ""
    }
    la brukerliste = data["users"]
    la i: heiltall = 0
    mens (i < lengde(brukerliste)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(brukerliste, indeks)) {
            la bruker_entry = brukerliste[indeks]
            hvis (har_nokkel(bruker_entry, "user") og bruker_entry["user"] == bruker) {
                hvis (har_nokkel(bruker_entry, "role")) {
                    la lagret_rolle = tekst_til_liten(tekst_trim(bruker_entry["role"]))
                    hvis (er_gyldig_rolle(lagret_rolle)) {
                        returner lagret_rolle
                    }
                }
            }
        }
        i = i + 1
    }
    returner ""
}

funksjon legg_til_audit(data: ordbok_tekst, actor: tekst, action: tekst, resource: tekst, meta: tekst) -> heltall {
    hvis ikke har_nokkel(data, "audit_log") {
        data["audit_log"] = []
    }
    la audit = data["audit_log"]
    la entry: ordbok_tekst = {}
    entry["actor"] = actor
    entry["action"] = action
    entry["resource"] = resource
    entry["metadata"] = meta
    entry["created_at"] = neste_rekkefolge(data)
    legg_til(audit, entry)
    returner lengde(audit)
}

funksjon krever_admin_tilgang(ctx: ordbok_tekst) -> bool {
    web.guard()
    la data = les_data()
    hvis (ikke autentisert_request(ctx, data)) {
        returner usann
    }
    la rolle = rolle_fra_request(ctx, data)
    hvis (rolle == "admin") {
        returner sann
    }
    hvis (web.has_role(ctx, "admin")) {
        returner sann
    }
    returner usann
}

funksjon er_gyldig_status(status: tekst) -> boolsk {
    hvis (status == "new") {
        returner sann
    }
    hvis (status == "open") {
        returner sann
    }
    hvis (status == "in_progress") {
        returner sann
    }
    hvis (status == "waiting") {
        returner sann
    }
    hvis (status == "resolved") {
        returner sann
    }
    hvis (status == "closed") {
        returner sann
    }
    returner usann
}

funksjon normaliser_status(status: tekst) -> tekst {
    la s = tekst_til_liten(tekst_trim(status))
    hvis (s == "ny") { returner "new" }
    hvis (s == "åpen") { returner "open" }
    hvis (s == "aapen") { returner "open" }
    hvis (s == "venter") { returner "waiting" }
    hvis (s == "løst") { returner "resolved" }
    hvis (s == "lost") { returner "resolved" }
    hvis (s == "lukket") { returner "closed" }
    returner s
}

funksjon er_slettet(ticket: ordbok_tekst) -> bool {
    hvis (har_nokkel(ticket, "deleted")) {
        returner ticket["deleted"]
    }
    returner usann
}

funksjon parse_bool(v: tekst) -> bool {
    la lav = tekst_til_liten(tekst_trim(v))
    hvis (lav == "1") {
        returner sann
    }
    hvis (lav == "true") {
        returner sann
    }
    hvis (lav == "yes") {
        returner sann
    }
    returner usann
}

funksjon krever_leser_tilgang(ctx: ordbok_tekst) -> bool {
    web.guard()
    la data = les_data()
    hvis (ikke autentisert_request(ctx, data)) {
        returner usann
    }
    la rolle = rolle_fra_request(ctx, data)
    hvis (har_tillatelse(rolle, "tickets.read")) {
        returner sann
    }
    hvis (web.has_permission(ctx, "tickets.read")) {
        returner sann
    }
    hvis (web.has_role(ctx, "user")) {
        returner sann
    }
    hvis (web.has_role(ctx, "agent")) {
        returner sann
    }
    hvis (web.has_role(ctx, "admin")) {
        returner sann
    }
    returner usann
}

funksjon json_svar_kropp(resp_data: ordbok_tekst) -> tekst {
    returner json.stringify(resp_data)
}

funksjon feil_svar(status_kode: heiltall, feil_kode: tekst, melding: tekst) -> ordbok_tekst {
    la ut: ordbok_tekst = {}
    ut["error"] = "error"
    ut["code"] = feil_kode
    ut["message"] = melding
    ut["status"] = tekst_fra_heltall(status_kode)
    returner web.response_builder(status_kode, {"content-type": "application/json"}, json_svar_kropp(ut))
}

funksjon feil_unauthorized(melding: tekst) -> ordbok_tekst {
    returner feil_svar(401, "UNAUTHORIZED", melding)
}

funksjon feil_forbidden(melding: tekst) -> ordbok_tekst {
    returner feil_svar(403, "FORBIDDEN", melding)
}

funksjon feil_foresporsel(status_kode: heltall, melding: tekst) -> ordbok_tekst {
    returner feil_svar(status_kode, "VALIDATION_ERROR", melding)
}

funksjon feil_fra_status(status_kode: heiltall, melding: tekst) -> ordbok_tekst {
    hvis (status_kode == 401) {
        returner feil_unauthorized(melding)
    }
    hvis (status_kode == 403) {
        returner feil_forbidden(melding)
    }
    hvis (status_kode == 404) {
        returner feil_svar(status_kode, "NOT_FOUND", melding)
    }
    hvis (status_kode == 409) {
        returner feil_svar(status_kode, "CONFLICT", melding)
    }
    hvis (status_kode == 410) {
        returner feil_svar(status_kode, "GONE", melding)
    }
    returner feil_foresporsel(status_kode, melding)
}

funksjon request_json_objekt(ctx: ordbok_tekst) -> ordbok_tekst {
    la body = web.request_body(ctx)
    la parsed = builtin.json_parse_raw(body)
    hvis (builtin.type(parsed) == "ordbok") {
        returner parsed
    }
    kast "Invalid JSON object"
    returner {}
}

funksjon er_feil_respons(respons: ordbok_tekst) -> bool {
    hvis (har_nokkel(respons, "error")) {
        returner sann
    }
    hvis (har_nokkel(respons, "__status__")) {
        hvis (web.response_status(respons) >= 400) {
            returner sann
        }
    }
    hvis (har_nokkel(respons, "__body__")) {
        la body = respons["__body__"]
        hvis (builtin.type(body) == "ordbok") {
            hvis (har_nokkel(body, "error")) {
                returner sann
            }
        }
        hvis (builtin.type(body) == "tekst") {
            la parsed = json.parse(body)
            hvis (har_nokkel(parsed, "error")) {
                returner sann
            }
        }
    }
    returner usann
}

funksjon krev_admin_tilgang(ctx: ordbok_tekst) -> ordbok_tekst {
    web.guard()
    la data = les_data()
    hvis (ikke autentisert_request(ctx, data)) {
        returner feil_unauthorized("Missing valid API key or helpdesk session")
    }
    la rolle = rolle_fra_request(ctx, data)
    hvis (rolle == "") {
        returner feil_unauthorized("Missing required header: x-user or x-role")
    }
    hvis (ikke har_tillatelse(rolle, "tickets.admin")) {
        returner feil_forbidden("Admin role required")
    }

    returner {}
}

funksjon krever_api_nokkel(ctx: ordbok_tekst) -> bool {
    web.guard()
    la data = les_data()
    returner autentisert_request(ctx, data)
}

funksjon krever_agent_eller_admin(ctx: ordbok_tekst) -> bool {
    web.guard()
    la data = les_data()
    hvis (ikke autentisert_request(ctx, data)) {
        returner usann
    }
    la rolle = rolle_fra_request(ctx, data)
    hvis (har_tillatelse(rolle, "tickets.write")) {
        returner sann
    }
    hvis (web.has_role(ctx, "admin")) {
        returner sann
    }
    hvis (web.has_role(ctx, "agent")) {
        returner sann
    }
    returner usann
}

funksjon finn_bruker(data: ordbok_tekst, brukernavn: tekst) -> ordbok_tekst {
    la brukere = data["users"]
    la i: heiltall = 0
    mens (i < lengde(brukere)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(brukere, indeks)) {
            la bruker = brukere[indeks]
            hvis (har_nokkel(bruker, "user") og bruker["user"] == brukernavn) {
                returner bruker
            }
        }
        i = i + 1
    }
    returner {}
}

funksjon index(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")

    la body = "<html><head><meta charset=\"utf-8\"><title>Norscode Helpdesk</title></head><body>"
    body = body + "<h1>Norscode Helpdesk</h1>"
    body = body + "<nav><a href=\"/login\">Login</a> <a href=\"/tickets\">Tickets</a> <a href=\"/admin/panel\">Admin</a></nav>"
    body = body + "<p>Helpdesk-kjerne med login, tickets, kommentarer, status, team, kategori, SLA og audit.</p>"
    body = body + "</body></html>"
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, body)
}

funksjon login_side(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /login")

    la body = "<html><head><meta charset=\"utf-8\"><title>Login</title></head><body>"
    body = body + "<h1>Login</h1>"
    body = body + "<form method=\"post\" action=\"/login\">"
    body = body + "<label>Bruker <input name=\"user\"></label>"
    body = body + "<label>Passord <input name=\"password\" type=\"password\"></label>"
    body = body + "<button type=\"submit\">Logg inn</button>"
    body = body + "</form>"
    body = body + "</body></html>"
    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, body)
}

funksjon login(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /login")

    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }
    hvis (ikke har_nokkel(body, "user") eller ikke har_nokkel(body, "password")) {
        returner feil_fra_status(400, "Missing required fields: user, password")
    }

    la data = les_data()
    la bruker = finn_bruker(data, body["user"])
    hvis (ikke har_nokkel(bruker, "user")) {
        returner feil_unauthorized("Invalid username or password")
    }
    hvis (ikke har_nokkel(bruker, "password") eller bruker["password"] != body["password"]) {
        returner feil_unauthorized("Invalid username or password")
    }
    la token = "helpdesk_" + bruker["user"] + "_" + bruker["role"]
    la session: ordbok_tekst = {}
    session["token"] = token
    session["user"] = bruker["user"]
    session["role"] = bruker["role"]
    session["active"] = "true"
    session["created_at"] = neste_rekkefolge(data)
    legg_til(data["sessions"], session)
    la _ = legg_til_audit(data, bruker["user"], "auth.login", "/login", bruker["role"])
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["token"] = token
    out["user"] = bruker["user"]
    out["role"] = bruker["role"]
    out["message"] = "Logged in"
    returner web.response_builder(
        200,
        {"content-type": "application/json", "set-cookie": "helpdesk_session=" + token + "; HttpOnly; SameSite=Lax"},
        json_svar_kropp(out)
    )
}


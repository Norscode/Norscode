funksjon admin_endre_bruker_rolle(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /admin/users")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }

    la data = les_data()
    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_foresporsel(400, "Invalid JSON body")
    }

    hvis (ikke har_nokkel(body, "user") eller ikke har_nokkel(body, "role")) {
        returner feil_foresporsel(400, "Missing required fields: user, role")
    }

    la bruker = body["user"]
    la rolle = tekst_til_liten(tekst_trim(body["role"]))
    hvis (ikke er_gyldig_rolle(rolle)) {
        returner feil_foresporsel(400, "Invalid role. Allowed: admin, agent, user")
    }
    hvis (bruker == "") {
        returner feil_foresporsel(400, "user is required")
    }

    la brukerliste = data["users"]
    la i: heiltall = 0
    la funnet = usann
    mens (i < lengde(brukerliste)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(brukerliste, indeks)) {
            la u = brukerliste[indeks]
            hvis (har_nokkel(u, "user") og u["user"] == bruker) {
                u["role"] = rolle
                funnet = sann
            }
        }
        i = i + 1
    }
    hvis (ikke funnet) {
        la ny_bruker: ordbok_tekst = {}
        ny_bruker["user"] = bruker
        ny_bruker["role"] = rolle
        legg_til(brukerliste, ny_bruker)
    }

    la actor = bruker_fra_request(ctx, data)
    hvis (actor == "") {
        actor = "system"
    }
    la _ = legg_til_audit(data, actor, "admin.user_role_updated", "/admin/users", bruker + ":" + rolle)
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["user"] = bruker
    out["role"] = rolle
    out["message"] = "User role updated"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon admin_endre_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("PATCH /admin/tickets/{id:int}")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (web.response_status(tilgang) >= 400) {
        returner tilgang
    }

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)
    hvis (indeks < 0) {
        returner feil_svar(404, "NOT_FOUND", "Ticket not found")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_foresporsel(400, "Invalid JSON body")
    }

    la endret = usann
    hvis (har_nokkel(body, "title")) {
        ticket["title"] = body["title"]
        endret = sann
    }
    hvis (har_nokkel(body, "description")) {
        ticket["description"] = body["description"]
        endret = sann
    }
    hvis (har_nokkel(body, "status")) {
        la ny_status = normaliser_status(body["status"])
        hvis (ikke er_gyldig_status(ny_status)) {
            returner feil_foresporsel(400, "Invalid status. Allowed: new, open, in_progress, waiting, resolved, closed")
        }
        ticket["status"] = ny_status
        endret = sann
    }
    hvis (har_nokkel(body, "assignee")) {
        ticket["assignee"] = body["assignee"]
        endret = sann
    }
    hvis (har_nokkel(body, "priority")) {
        la ny_prioritet = parse_int_mellom_min_maks(body["priority"], 1, 5)
        ticket["priority"] = tekst_fra_heltall(ny_prioritet)
        endret = sann
    }

    hvis ikke endret {
        returner feil_foresporsel(400, "No admin fields provided")
    }
    ticket["updated_at"] = neste_rekkefolge(data)

    la actor = bruker_fra_request(ctx, data)
    hvis (actor == "") {
        actor = "system"
    }
    la _ = legg_til_audit(data, actor, "admin.ticket_updated", tekst_fra_heltall(id), "admin override")
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Admin ticket updated"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon admin_hard_delete_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("DELETE /admin/tickets/{id:int}")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)
    hvis (indeks < 0) {
        returner feil_svar(404, "NOT_FOUND", "Ticket not found")
    }

    la ny_liste = []
    la i: heiltall = 0
    mens (i < lengde(tickets)) {
        hvis (i != indeks) {
            legg_til(ny_liste, tickets[tekst_fra_heltall(i)])
        }
        i = i + 1
    }
    data["tickets"] = ny_liste

    la actor = bruker_fra_request(ctx, data)
    hvis (actor == "") {
        actor = "system"
    }
    la _ = legg_til_audit(data, actor, "admin.ticket_hard_deleted", tekst_fra_heltall(id), "hard delete")
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["message"] = "Ticket permanently deleted by admin"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon admin_audit(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /admin/audit")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }

    la data = les_data()
    la limit_text = web.request_query_param(ctx, "limit")
    la offset_text = web.request_query_param(ctx, "offset")
    la limit = 50
    la offset = 0
    hvis (limit_text != "") {
        limit = parse_int_mellom_min_maks_eller_feil(limit_text, 1, 200)
        hvis (limit < 0) {
            returner feil_foresporsel(400, "Invalid limit parameter")
        }
    }
    hvis (offset_text != "") {
        offset = parse_int_mellom_min_maks_eller_feil(offset_text, 0, 10000)
        hvis (offset < 0) {
            returner feil_foresporsel(400, "Invalid offset parameter")
        }
    }

    la audit = data["audit_log"]
    la total = lengde(audit)
    la paginert = []
    la idx: heiltall = 0
    la valgt = 0
    mens (idx < total) {
        hvis (idx >= offset) {
            hvis (valgt < limit) {
                legg_til(paginert, audit[tekst_fra_heltall(idx)])
                valgt = valgt + 1
            }
        }
        idx = idx + 1
    }

    la out: ordbok_tekst = {}
    out["events"] = paginert
    out["count"] = tekst_fra_heltall(lengde(paginert))
    out["total"] = tekst_fra_heltall(total)
    out["offset"] = tekst_fra_heltall(offset)
    out["limit"] = tekst_fra_heltall(limit)
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon admin_metrics(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /admin/metrics")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }

    la data = les_data()
    la tickets = data["tickets"]
    la i: heiltall = 0

    la total: heiltall = 0
    la open_t: heltall = 0
    la in_progress_t: heltall = 0
    la closed_t: heiltall = 0
    la slettede_t: heltall = 0
    la med_comment_t: heiltall = 0

    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la ticket = tickets[indeks]
            total = total + 1
            hvis (er_slettet(ticket)) {
                slettede_t = slettede_t + 1
            }
            hvis (har_nokkel(ticket, "status")) {
                la s = tekst_til_liten(ticket["status"])
                hvis (s == "open") {
                    open_t = open_t + 1
                } ellers hvis (s == "in_progress") {
                    in_progress_t = in_progress_t + 1
                } ellers hvis (s == "closed") {
                    closed_t = closed_t + 1
                }
            }
            hvis (har_nokkel(ticket, "comments") og lengde(ticket["comments"]) > 0) {
                med_comment_t = med_comment_t + 1
            }
        }
        i = i + 1
    }

    la users = data["users"]
    la roller = data["roles"]
    la audit = data["audit_log"]

    la ut: ordbok_tekst = {}
    la count = {}
    count["open"] = tekst_fra_heltall(open_t)
    count["in_progress"] = tekst_fra_heltall(in_progress_t)
    count["closed"] = tekst_fra_heltall(closed_t)
    count["deleted"] = tekst_fra_heltall(slettede_t)

    ut["tickets"] = count
    ut["tickets_total"] = tekst_fra_heltall(total)
    ut["tickets_with_comments"] = tekst_fra_heltall(med_comment_t)
    ut["users"] = tekst_fra_heltall(lengde(users))
    ut["roles"] = tekst_fra_heltall(lengde(roller))
    ut["audit_events"] = tekst_fra_heltall(lengde(audit))
    ut["generated_at"] = neste_rekkefolge(data)

    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(ut))
}

funksjon admin_panel_tittel() -> tekst {
    returner "<h1>Helpdesk Admin</h1>"
}

funksjon admin_panel_hurtigstatistikk(_: ordbok_tekst) -> tekst {
    la data = les_data()
    la tickets = data["tickets"]
    la users = data["users"]
    la roller = data["roles"]
    la audit = data["audit_log"]

    la total = lengde(tickets)
    la open_t = 0
    la in_progress_t = 0
    la closed_t = 0
    la slettet_t = 0
    la i: heiltall = 0
    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la ticket = tickets[indeks]
            hvis (har_nokkel(ticket, "status")) {
                la s = tekst_til_liten(ticket["status"])
                hvis (s == "open") {
                    open_t = open_t + 1
                } ellers hvis (s == "in_progress") {
                    in_progress_t = in_progress_t + 1
                } ellers hvis (s == "closed") {
                    closed_t = closed_t + 1
                }
            }
            hvis (er_slettet(ticket)) {
                slettet_t = slettet_t + 1
            }
        }
        i = i + 1
    }

    la body = "<section>\n"
    body = body + "<h2>Overblikta</h2>\n"
    body = body + "<ul>"
    body = body + "<li>Totalt tickets: " + tekst_fra_heltall(total) + "</li>"
    body = body + "<li>Open: " + tekst_fra_heltall(open_t) + "</li>"
    body = body + "<li>In progress: " + tekst_fra_heltall(in_progress_t) + "</li>"
    body = body + "<li>Closed: " + tekst_fra_heltall(closed_t) + "</li>"
    body = body + "<li>Slettede: " + tekst_fra_heltall(slettet_t) + "</li>"
    body = body + "<li>Brukere: " + tekst_fra_heltall(lengde(users)) + "</li>"
    body = body + "<li>Roller: " + tekst_fra_heltall(lengde(roller)) + "</li>"
    body = body + "<li>Audit-events: " + tekst_fra_heltall(lengde(audit)) + "</li>"
    body = body + "</ul>\n"
    body = body + "</section>"

    returner body
}

funksjon admin_panel_tabell_oversikt(ctx: ordbok_tekst) -> tekst {
    la data = les_data()
    la brukere = data["users"]
    la audit = data["audit_log"]

    la out = "<section>\n"
    out = out + "<h2>Brukere</h2>\n"
    out = out + "<table>\n"
    out = out + "<tr><th>Bruker</th><th>Rolle</th></tr>"
    la i: heiltall = 0
    mens (i < lengde(brukere)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(brukere, indeks)) {
            la rad = brukere[indeks]
            la bruker = ""
            la rolle = ""
            hvis (har_nokkel(rad, "user")) {
                bruker = rad["user"]
            }
            hvis (har_nokkel(rad, "role")) {
                rolle = rad["role"]
            }
            out = out + "<tr><td>" + bruker + "</td><td>" + rolle + "</td></tr>"
        }
        i = i + 1
    }
    out = out + "</table>\n"

    out = out + "<h2>Siste 10 audit-events</h2>\n"
    out = out + "<table>\n"
    out = out + "<tr><th>Tid</th><th>Handling</th><th>Ressurs</th><th>Bruker</th></tr>"
    la limit = 10
    la teller = lengde(audit) - 1
    la lest = 0
    mens (teller >= 0 og lest < limit) {
        la idx = tekst_fra_heltall(teller)
        hvis (har_nokkel(audit, idx)) {
            la rad = audit[idx]
            hvis (rad != null) {
                la a = ""
                la r = ""
                la u = ""
                la t = ""
                hvis (har_nokkel(rad, "action")) {
                    a = rad["action"]
                }
                hvis (har_nokkel(rad, "resource")) {
                    r = rad["resource"]
                }
                hvis (har_nokkel(rad, "actor")) {
                    u = rad["actor"]
                }
                hvis (har_nokkel(rad, "timestamp")) {
                    t = rad["timestamp"]
                }
                out = out + "<tr><td>" + t + "</td><td>" + a + "</td><td>" + r + "</td><td>" + u + "</td></tr>"
                lest = lest + 1
            }
        }
        teller = teller - 1
    }
    out = out + "</table>\n"
    out = out + "</section>"
    returner out
}

funksjon admin_panel(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /admin/panel")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }

    la body = "<html><head><meta charset=\"utf-8\"><title>Helpdesk Admin</title>"
    body = body + "<style>body{font-family:Arial,sans-serif;max-width:900px;margin:0 auto;padding:24px} table{border-collapse:collapse} th,td{border:1px solid #ddd;padding:8px} th{background:#f5f5f5}</style>"
    body = body + "</head><body>"
    body = body + admin_panel_tittel()
    body = body + "<p>Autentisert som admin. Denne visningen bruker serverens lagring og viser admin-rolleresultat.</p>"
    body = body + "<nav><a href=\"/admin/panel\">Dashboard</a> | <a href=\"/admin/metrics\">Metrics JSON</a> | <a href=\"/admin/users\">Users JSON</a> | <a href=\"/admin/audit\">Audit JSON</a></nav>"
    body = body + admin_panel_hurtigstatistikk(ctx)
    body = body + admin_panel_tabell_oversikt(ctx)
    body = body + "</body></html>"

    returner web.response_builder(200, {"content-type": "text/html; charset=utf-8"}, body)
}

funksjon helse(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /health")

    la data = les_data()
    la out: ordbok_tekst = {}
    out["status"] = "ok"
    out["tickets"] = tekst_fra_heltall(lengde(data["tickets"]))
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon start() -> heiltall {
    les_data()
    returner 0
}

funksjon ticket_statistikk(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_leser_tilgang")
    web.route("GET /tickets/stats")

    la data = les_data()
    la tickets = data["tickets"]
    la i: heiltall = 0

    la total: heltall = 0
    la open_t: heiltall = 0
    la in_progress: heiltall = 0
    la closed_t: heiltall = 0
    la prio_sum: heiltall = 0

    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la t = tickets[indeks]
            la la_ta_med = sann
            hvis (ikke parse_bool(web.request_query_param(ctx, "include_deleted"))) {
                hvis (er_slettet(t)) {
                    la_ta_med = usann
                }
            }
            hvis (la_ta_med) {
                la status = ""
                hvis (har_nokkel(t, "status")) {
                    status = t["status"]
                }

                hvis (status == "open") {
                    open_t = open_t + 1
                } ellers hvis (status == "in_progress") {
                    in_progress = in_progress + 1
                } ellers hvis (status == "closed") {
                    closed_t = closed_t + 1
                }

                hvis (har_nokkel(t, "priority")) {
                    prio_sum = prio_sum + heltall_fra_tekst(t["priority"])
                }
                total = total + 1
            }
        }
        i = i + 1
    }

    la gjennomsnitt = 0
    hvis (total > 0) {
        gjennomsnitt = prio_sum / total
    }

    la ut = {}
    la status = {}
    status["open"] = tekst_fra_heltall(open_t)
    status["in_progress"] = tekst_fra_heltall(in_progress)
    status["closed"] = tekst_fra_heltall(closed_t)

    ut["total"] = tekst_fra_heltall(total)
    ut["avg_priority"] = tekst_fra_heltall(gjennomsnitt)
    ut["by_status"] = status
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(ut))
}

funksjon slette_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("DELETE /tickets/{id:int}")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket)) {
        returner feil_fra_status(410, "Ticket already deleted")
    }

    la hard_delete = parse_bool(web.request_query_param(ctx, "hard"))
    hvis (hard_delete) {
        la ny_liste = []
        la i: heiltall = 0
        mens (i < lengde(tickets)) {
            hvis (i != indeks) {
                legg_til(ny_liste, tickets[tekst_fra_heltall(i)])
            }
            i = i + 1
        }
        data["tickets"] = ny_liste
        lagre_data(data)
        la out: ordbok_tekst = {}
        out["message"] = "Ticket permanently deleted"
        returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
    }

    ticket["deleted"] = sann
    la slettet_av = bruker_fra_request(ctx, data)
    hvis (slettet_av == "") {
        slettet_av = "system"
    }
    ticket["updated_at"] = neste_rekkefolge(data)
    la _ = laa_til_historikk(ticket, "deleted", "true", slettet_av)
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Ticket marked as deleted"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon gjenopprett_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets/{id:int}/restore")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    hvis (ikke er_slettet(ticket)) {
        returner feil_fra_status(400, "Ticket is not deleted")
    }

    ticket["deleted"] = usann
    la gjenskapper = bruker_fra_request(ctx, data)
    hvis (gjenskapper == "") {
        gjenskapper = "system"
    }
    ticket["updated_at"] = neste_rekkefolge(data)
    la _ = laa_til_historikk(ticket, "restored", "false", gjenskapper)
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Ticket restored"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon tildel_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets/{id:int}/assign")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }

    hvis (ikke har_nokkel(body, "assignee")) {
        returner feil_fra_status(400, "Missing required field: assignee")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket)) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la ny_ansvarlig = body["assignee"]
    la gammel_ansvarlig = ""
    hvis (har_nokkel(ticket, "assignee")) {
        gammel_ansvarlig = ticket["assignee"]
    }
    ticket["assignee"] = ny_ansvarlig

    hvis (gammel_ansvarlig != ny_ansvarlig) {
        ticket["updated_at"] = neste_rekkefolge(data)
        la tildelt_av = bruker_fra_request(ctx, data)
        hvis (tildelt_av == "") {
            tildelt_av = "system"
        }
        la _ = laa_til_historikk(ticket, "assigned", gammel_ansvarlig + " -> " + ny_ansvarlig, tildelt_av)
    }

    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Ticket assigned"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon legg_til_kommentar(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets/{id:int}/comments")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }

    hvis (ikke har_nokkel(body, "message")) {
        returner feil_fra_status(400, "Missing required field: message")
    }
    hvis (body["message"] == "") {
        returner feil_fra_status(400, "message is required")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket)) {
        returner feil_fra_status(404, "Ticket not found")
    }
    la kommentarer = ticket["comments"]
    la kommentar: ordbok_tekst = {}
    la forfatter = bruker_fra_request(ctx, data)
    hvis (forfatter == "") {
        forfatter = "anonymous"
    }

    la kommentar_tid = neste_rekkefolge(data)
    hvis har_nokkel(body, "author") {
        forfatter = body["author"]
    }
    hvis (forfatter == "") {
        forfatter = "anonymous"
    }

    kommentar["author"] = forfatter
    kommentar["message"] = body["message"]
    kommentar["created_at"] = kommentar_tid
    ticket["updated_at"] = neste_rekkefolge(data)
    legg_til(kommentarer, kommentar)
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Comment added"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon legg_til_kommentar_singular(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets/{id:int}/comment")

    returner legg_til_kommentar(ctx)
}

funksjon legg_til_vedlegg(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets/{id:int}/attachments")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la indeks = find_ticket_indeks(data["tickets"], id)
    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }
    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }
    hvis (ikke har_nokkel(body, "filename")) {
        returner feil_fra_status(400, "Missing required field: filename")
    }
    la ticket = data["tickets"][tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket)) {
        returner feil_fra_status(404, "Ticket not found")
    }
    hvis (ikke har_nokkel(ticket, "attachments")) {
        ticket["attachments"] = []
    }
    la vedlegg: ordbok_tekst = {}
    vedlegg["id"] = "att-" + neste_rekkefolge(data)
    vedlegg["ticket_id"] = tekst_fra_heltall(id)
    vedlegg["filename"] = body["filename"]
    vedlegg["content_type"] = "application/octet-stream"
    hvis (har_nokkel(body, "content_type")) {
        vedlegg["content_type"] = body["content_type"]
    }
    vedlegg["size"] = "0"
    hvis (har_nokkel(body, "size")) {
        vedlegg["size"] = body["size"]
    }
    vedlegg["uploaded_by"] = bruker_fra_request(ctx, data)
    hvis (vedlegg["uploaded_by"] == "") {
        vedlegg["uploaded_by"] = "system"
    }
    legg_til(ticket["attachments"], vedlegg)
    legg_til(data["attachments"], vedlegg)
    ticket["updated_at"] = neste_rekkefolge(data)
    la _ = laa_til_historikk(ticket, "attachment_added", vedlegg["filename"], vedlegg["uploaded_by"])
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["attachment"] = vedlegg
    out["ticket"] = ticket
    returner web.response_builder(201, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon admin_epost_inn(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /admin/email/inbound")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }
    la data = les_data()
    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_foresporsel(400, "Invalid JSON body")
    }
    hvis (ikke har_nokkel(body, "from") eller ikke har_nokkel(body, "subject")) {
        returner feil_foresporsel(400, "Missing required fields: from, subject")
    }
    la event: ordbok_tekst = {}
    event["id"] = "mail-" + neste_rekkefolge(data)
    event["direction"] = "inbound"
    event["from"] = body["from"]
    event["subject"] = body["subject"]
    event["status"] = "queued"
    legg_til(data["email_events"], event)
    la _ = legg_til_audit(data, bruker_fra_request(ctx, data), "email.inbound_queued", "/admin/email/inbound", event["id"])
    lagre_data(data)
    returner web.response_builder(202, {"content-type": "application/json"}, json_svar_kropp(event))
}

funksjon admin_automation_run(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /admin/automation/run")

    la tilgang = krev_admin_tilgang(ctx)
    hvis (er_feil_respons(tilgang)) {
        returner tilgang
    }
    la data = les_data()
    la tickets = data["tickets"]
    la endret = 0
    la i: heiltall = 0
    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la ticket = tickets[indeks]
            hvis (ikke er_slettet(ticket)) {
                hvis (har_nokkel(ticket, "category") og ticket["category"] == "billing") {
                    hvis (ikke har_nokkel(ticket, "team") eller ticket["team"] != "billing") {
                        ticket["team"] = "billing"
                        ticket["assignee"] = "anna"
                        ticket["updated_at"] = neste_rekkefolge(data)
                        la _ = laa_til_historikk(ticket, "automation_assigned", "billing", "system")
                        endret = endret + 1
                    }
                }
                hvis (har_nokkel(ticket, "priority") og ticket["priority"] == "1") {
                    ticket["sla"] = "critical"
                }
            }
        }
        i = i + 1
    }
    lagre_data(data)
    la out: ordbok_tekst = {}
    out["changed"] = tekst_fra_heltall(endret)
    out["rules"] = data["automation_rules"]
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon ticket_ai_summary(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_leser_tilgang")
    web.route("POST /tickets/{id:int}/ai/summary")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")

funksjon hent_alle_tickets(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_leser_tilgang")
    web.route("GET /tickets")

    la data = les_data()
    la status_filter = web.request_query_param(ctx, "status")
    hvis (status_filter != "") {
        la status_norm = normaliser_status(status_filter)
        hvis (ikke er_gyldig_status(status_norm)) {
            returner feil_fra_status(400, "Invalid status parameter")
        }
        status_filter = status_norm
    }
    la soek = tekst_til_liten(tekst_trim(web.request_query_param(ctx, "q")))
    hvis (soek != "") {
        hvis (tekst_lengde(soek) < 2) {
            returner feil_fra_status(400, "Search query must be at least 2 characters")
        }
    }
    la assignee_filter = tekst_til_liten(tekst_trim(web.request_query_param(ctx, "assignee")))
    hvis (assignee_filter != "") {
        hvis (tekst_lengde(assignee_filter) < 1) {
            returner feil_fra_status(400, "assignee filter cannot be empty")
        }
    }
    la created_by_filter = tekst_til_liten(tekst_trim(web.request_query_param(ctx, "created_by")))
    hvis (created_by_filter != "") {
        hvis (tekst_lengde(created_by_filter) < 1) {
            returner feil_fra_status(400, "created_by filter cannot be empty")
        }
    }
    la include_deleted = parse_bool(web.request_query_param(ctx, "include_deleted"))
    la resultater = []
    la tickets = data["tickets"]
    la i: heiltall = 0

    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la ticket = tickets[indeks]
            hvis ikke (er_slettet(ticket) og ikke include_deleted) {
                la ok: bool = sann
                hvis (status_filter != "") {
                    hvis ikke har_nokkel(ticket, "status") eller ticket["status"] != status_filter {
                        ok = usann
                    }
                }
                hvis (ok og soek != "") {
                    la tittel = tekst_til_liten(ticket["title"])
                    la beskrivelse = tekst_til_liten(ticket["description"])
                    hvis (ikke tekst_inneholder(tittel, soek) og ikke tekst_inneholder(beskrivelse, soek)) {
                        ok = usann
                    }
                }
                hvis (ok og assignee_filter != "") {
                    hvis (ikke har_nokkel(ticket, "assignee")) {
                        ok = usann
                    } ellers hvis (tekst_til_liten(ticket["assignee"]) != assignee_filter) {
                        ok = usann
                    }
                }
                hvis (ok og created_by_filter != "") {
                    hvis (ikke har_nokkel(ticket, "created_by")) {
                        ok = usann
                    } ellers hvis (tekst_til_liten(ticket["created_by"]) != created_by_filter) {
                        ok = usann
                    }
                }
                hvis (ok) {
                    legg_til(resultater, ticket)
                }
            }
        }
        i = i + 1
    }

    la sortering = web.request_query_param(ctx, "sort")
    hvis sortering != "" {
        la gyldig_sort = sann
        hvis (
            sortering != "priority" og
            sortering != "-priority" og
            sortering != "id" og
            sortering != "-id" og
            sortering != "created_at" og
            sortering != "-created_at" og
            sortering != "updated_at" og
            sortering != "-updated_at"
        ) {
            gyldig_sort = usann
        }
        hvis ikke gyldig_sort {
            returner feil_fra_status(400, "Invalid sort parameter")
        }

        hvis (sortering == "priority") {
            // Enkel stabil sort: lav til høy prioritet
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                    la b: heiltall = a + 1
                    mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["priority"]) > heiltall_fra_tekst(pb["priority"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-priority") {
            // Enkel stabil sort: høy til lav prioritet
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["priority"]) < heiltall_fra_tekst(pb["priority"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "id") {
            // Oppstigend etter id (eldste først)
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["id"]) > heiltall_fra_tekst(pb["id"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-id") {
            // Synkende etter id (nyeste først)
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["id"]) < heltall_fra_tekst(pb["id"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "created_at") {
            // Oppstigend etter created_at (eldste først)
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["created_at"]) > heltall_fra_tekst(pb["created_at"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-created_at") {
            // Synkende etter created_at (nyeste først)
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["created_at"]) < heltall_fra_tekst(pb["created_at"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "updated_at") {
            // Oppstigend etter updated_at (eldste først)
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis ikke har_nokkel(pa, "updated_at") {
                        pa["updated_at"] = pa["created_at"]
                    }
                    hvis ikke har_nokkel(pb, "updated_at") {
                        pb["updated_at"] = pb["created_at"]
                    }
                    hvis (heltall_fra_tekst(pa["updated_at"]) > heiltall_fra_tekst(pb["updated_at"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-updated_at") {
            // Synkende etter updated_at (nyeste først)
            la n = lengde(resultater)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = resultater[tekst_fra_heltall(a)]
                    la pb = resultater[tekst_fra_heltall(b)]
                    hvis ikke har_nokkel(pa, "updated_at") {
                        pa["updated_at"] = pa["created_at"]
                    }
                    hvis ikke har_nokkel(pb, "updated_at") {
                        pb["updated_at"] = pb["created_at"]
                    }
                    hvis (heltall_fra_tekst(pa["updated_at"]) < heiltall_fra_tekst(pb["updated_at"])) {
                        la mellom = resultater[tekst_fra_heltall(a)]
                        resultater[tekst_fra_heltall(a)] = resultater[tekst_fra_heltall(b)]
                        resultater[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        }
    }

    la limit_text = web.request_query_param(ctx, "limit")
    la offset_text = web.request_query_param(ctx, "offset")
    la limit = 50
    la offset = 0

    hvis (limit_text != "") {
        limit = parse_int_mellom_min_maks_eller_feil(limit_text, 1, 200)
        hvis (limit < 0) {
            returner feil_fra_status(400, "Invalid limit parameter")
        }
    }
    hvis (offset_text != "") {
        offset = parse_int_mellom_min_maks_eller_feil(offset_text, 0, 10000)
        hvis (offset < 0) {
            returner feil_fra_status(400, "Invalid offset parameter")
        }
    }

    la paginert = []
    la idx: heiltall = 0
    la valgt = 0
    la total = lengde(resultater)
    mens (idx < total) {
        hvis (idx >= offset) {
            hvis (valgt < limit) {
                legg_til(paginert, resultater[tekst_fra_heltall(idx)])
                valgt = valgt + 1
            }
        }
        idx = idx + 1
    }

    la out: ordbok_tekst = {}
    out["tickets"] = paginert
    out["count"] = tekst_fra_heltall(lengde(paginert))
    out["total"] = tekst_fra_heltall(total)
    out["offset"] = tekst_fra_heltall(offset)
    out["limit"] = tekst_fra_heltall(limit)
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon hent_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_leser_tilgang")
    web.route("GET /tickets/{id:int}")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la indeks = find_ticket_indeks(data["tickets"], id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la t = data["tickets"][tekst_fra_heltall(indeks)]
    hvis (er_slettet(t)) {
        hvis (ikke parse_bool(web.request_query_param(ctx, "include_deleted"))) {
            returner feil_fra_status(404, "Ticket not found")
        }
    }
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(t))
}

funksjon opprett_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets")

    la data = les_data()
    la body: ordbok_tekst

    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }

    hvis (ikke har_nokkel(body, "title") eller ikke har_nokkel(body, "description")) {
        returner feil_fra_status(400, "Missing required fields: title, description")
    }

    la title = body["title"]
    la description = body["description"]

    hvis (title == "" eller description == "") {
        returner feil_fra_status(400, "title and description are required")
    }

    la priority_tekst = "3"
    hvis (har_nokkel(body, "priority")) {
        priority_tekst = body["priority"]
    }
    la priority = parse_int_mellom_min_maks(priority_tekst, 1, 5)
    la tidsstempel = neste_rekkefolge(data)

    la ticket: ordbok_tekst = {}
    la id = data["next_id"]
    data["next_id"] = tekst_fra_heltall(heltall_fra_tekst(id) + 1)
    la creator = bruker_fra_request(ctx, data)
    hvis (creator == "") {
        creator = "system"
    }

    ticket["id"] = id
    ticket["title"] = title
    ticket["description"] = description
    ticket["status"] = "open"
    ticket["priority"] = tekst_fra_heltall(priority)
    ticket["created_by"] = creator
    ticket["created_at"] = tidsstempel
    ticket["updated_at"] = tidsstempel
    ticket["assignee"] = ""
    ticket["team"] = "support"
    hvis (har_nokkel(body, "team")) {
        ticket["team"] = body["team"]
    }
    ticket["category"] = "general"
    hvis (har_nokkel(body, "category")) {
        ticket["category"] = body["category"]
    }
    ticket["sla"] = "standard"
    hvis (har_nokkel(body, "sla")) {
        ticket["sla"] = body["sla"]
    }
    ticket["due_at"] = ""
    ticket["deleted"] = usann
    ticket["comments"] = []
    ticket["attachments"] = []
    ticket["history"] = []
    la _ = laa_til_historikk(ticket, "created", "open", creator)

    legg_til(data["tickets"], ticket)
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Ticket created"
    returner web.response_builder(201, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon oppdater_ticket_status(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("PATCH /tickets/{id:int}/status")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }

    hvis (ikke har_nokkel(body, "status")) {
        returner feil_fra_status(400, "Missing required field: status")
    }

    la ny_status = normaliser_status(body["status"])
    hvis (ikke er_gyldig_status(ny_status)) {
        returner feil_fra_status(400, "Invalid status. Allowed: new, open, in_progress, waiting, resolved, closed")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket)) {
        returner feil_fra_status(404, "Ticket not found")
    }
    la gammel_status = ""
    hvis (har_nokkel(ticket, "status")) {
        gammel_status = ticket["status"]
    }

    hvis (gammel_status == ny_status) {
        returner feil_fra_status(409, "Status already set to " + ny_status)
    }

    ticket["status"] = ny_status
    ticket["updated_at"] = neste_rekkefolge(data)
    la status_by = bruker_fra_request(ctx, data)
    hvis (status_by == "") {
        status_by = "system"
    }
    la ny_historikk = gammel_status + "->" + ny_status
    la _ = laa_til_historikk(ticket, "status_changed", ny_historikk, status_by)

    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["message"] = "Ticket status updated"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon oppdater_ticket_status_post(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("POST /tickets/{id:int}/status")

    returner oppdater_ticket_status(ctx)
}

funksjon mine_tickets(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_leser_tilgang")
    web.route("GET /tickets/my")

    la bruker = bruker_fra_request(ctx, les_data())
    hvis (bruker == "") {
        returner feil_fra_status(401, "Missing required header: x-user")
    }

    la data = les_data()
    la filter = web.request_query_param(ctx, "filter")
    la sortering = web.request_query_param(ctx, "sort")
    la status_filter = normaliser_status(web.request_query_param(ctx, "status"))
    la include_deleted = parse_bool(web.request_query_param(ctx, "include_deleted"))

    hvis (filter != "" og filter != "assigned" og filter != "unassigned") {
        returner feil_fra_status(400, "Invalid filter parameter")
    }
    hvis (status_filter != "") {
        hvis (ikke er_gyldig_status(status_filter)) {
            returner feil_fra_status(400, "Invalid status parameter")
        }
    }
    la mine = []
    la tickets = data["tickets"]
    la i: heiltall = 0

    mens (i < lengde(tickets)) {
        la indeks = tekst_fra_heltall(i)
        hvis (har_nokkel(tickets, indeks)) {
            la t = tickets[indeks]
            la la_legge_til = sann
            hvis (ikke include_deleted) {
                hvis (er_slettet(t)) {
                    la_legge_til = usann
                }
            }
            hvis (la_legge_til og har_nokkel(t, "created_by") og t["created_by"] == bruker) {
                hvis (filter == "assigned") {
                    hvis ikke har_nokkel(t, "assignee") {
                        la_legge_til = usann
                    } ellers hvis (tekst_trim(t["assignee"]) == "") {
                        la_legge_til = usann
                    }
                }
                hvis (filter == "unassigned") {
                    hvis ikke har_nokkel(t, "assignee") {
                        la_legge_til = sann
                    } ellers hvis (tekst_trim(t["assignee"]) == "") {
                        la_legge_til = sann
                    } ellers {
                        la_legge_til = usann
                    }
                }
                hvis (status_filter != "") {
                    hvis ikke har_nokkel(t, "status") {
                        la_legge_til = usann
                    } ellers hvis (tekst_til_liten(t["status"]) != status_filter) {
                        la_legge_til = usann
                    }
                }
                hvis (la_legge_til) {
                    legg_til(mine, t)
                }
            }
        }
        i = i + 1
    }

    hvis sortering != "" {
        la gyldig_sort = sann
        hvis (
            sortering != "created_at" og
            sortering != "-created_at" og
            sortering != "id" og
            sortering != "-id" og
            sortering != "updated_at" og
            sortering != "-updated_at"
        ) {
            gyldig_sort = usann
        }
        hvis ikke gyldig_sort {
            returner feil_fra_status(400, "Invalid sort parameter")
        }
        hvis (sortering == "created_at") {
            // Oppstigende etter created_at
            la n = lengde(mine)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = mine[tekst_fra_heltall(a)]
                    la pb = mine[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["created_at"]) > heiltall_fra_tekst(pb["created_at"])) {
                        la mellom = mine[tekst_fra_heltall(a)]
                        mine[tekst_fra_heltall(a)] = mine[tekst_fra_heltall(b)]
                        mine[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-created_at") {
            // Synkende etter created_at
            la n = lengde(mine)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = mine[tekst_fra_heltall(a)]
                    la pb = mine[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["created_at"]) < heiltall_fra_tekst(pb["created_at"])) {
                        la mellom = mine[tekst_fra_heltall(a)]
                        mine[tekst_fra_heltall(a)] = mine[tekst_fra_heltall(b)]
                        mine[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "id") {
            // Oppstigende id
            la n = lengde(mine)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = mine[tekst_fra_heltall(a)]
                    la pb = mine[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["id"]) > heiltall_fra_tekst(pb["id"])) {
                        la mellom = mine[tekst_fra_heltall(a)]
                        mine[tekst_fra_heltall(a)] = mine[tekst_fra_heltall(b)]
                        mine[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-id") {
            // Synkende id
            la n = lengde(mine)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = mine[tekst_fra_heltall(a)]
                    la pb = mine[tekst_fra_heltall(b)]
                    hvis (heltall_fra_tekst(pa["id"]) < heiltall_fra_tekst(pb["id"])) {
                        la mellom = mine[tekst_fra_heltall(a)]
                        mine[tekst_fra_heltall(a)] = mine[tekst_fra_heltall(b)]
                        mine[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "updated_at") {
            // Oppstigende updated_at
            la n = lengde(mine)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = mine[tekst_fra_heltall(a)]
                    la pb = mine[tekst_fra_heltall(b)]
                    hvis ikke har_nokkel(pa, "updated_at") {
                        pa["updated_at"] = pa["created_at"]
                    }
                    hvis ikke har_nokkel(pb, "updated_at") {
                        pb["updated_at"] = pb["created_at"]
                    }
                    hvis (heltall_fra_tekst(pa["updated_at"]) > heiltall_fra_tekst(pb["updated_at"])) {
                        la mellom = mine[tekst_fra_heltall(a)]
                        mine[tekst_fra_heltall(a)] = mine[tekst_fra_heltall(b)]
                        mine[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        } ellers hvis (sortering == "-updated_at") {
            // Synkende updated_at
            la n = lengde(mine)
            la a: heiltall = 0
            mens (a < n - 1) {
                la b: heiltall = a + 1
                mens (b < n) {
                    la pa = mine[tekst_fra_heltall(a)]
                    la pb = mine[tekst_fra_heltall(b)]
                    hvis ikke har_nokkel(pa, "updated_at") {
                        pa["updated_at"] = pa["created_at"]
                    }
                    hvis ikke har_nokkel(pb, "updated_at") {
                        pb["updated_at"] = pb["created_at"]
                    }
                    hvis (heltall_fra_tekst(pa["updated_at"]) < heiltall_fra_tekst(pb["updated_at"])) {
                        la mellom = mine[tekst_fra_heltall(a)]
                        mine[tekst_fra_heltall(a)] = mine[tekst_fra_heltall(b)]
                        mine[tekst_fra_heltall(b)] = mellom
                    }
                    b = b + 1
                }
                a = a + 1
            }
        }
    }

    la limit_text = web.request_query_param(ctx, "limit")
    la offset_text = web.request_query_param(ctx, "offset")
    la limit = 50
    la offset = 0

    hvis (limit_text != "") {
        limit = parse_int_mellom_min_maks_eller_feil(limit_text, 1, 200)
        hvis (limit < 0) {
            returner feil_fra_status(400, "Invalid limit parameter")
        }
    }
    hvis (offset_text != "") {
        offset = parse_int_mellom_min_maks_eller_feil(offset_text, 0, 10000)
        hvis (offset < 0) {
            returner feil_fra_status(400, "Invalid offset parameter")
        }
    }

    la paginert = []
    la idx: heiltall = 0
    la valgt = 0
    la total = lengde(mine)
    mens (idx < total) {
        hvis (idx >= offset) {
            hvis (valgt < limit) {
                legg_til(paginert, mine[tekst_fra_heltall(idx)])
                valgt = valgt + 1
            }
        }
        idx = idx + 1
    }

    la out: ordbok_tekst = {}
    out["user"] = bruker
    out["tickets"] = paginert
    out["count"] = tekst_fra_heltall(lengde(paginert))
    out["total"] = tekst_fra_heltall(total)
    out["offset"] = tekst_fra_heltall(offset)
    out["limit"] = tekst_fra_heltall(limit)
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon hent_tickets_kommentarer(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_leser_tilgang")
    web.route("GET /tickets/{id:int}/comments")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la indeks = find_ticket_indeks(data["tickets"], id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la ticket = data["tickets"][tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket) og ikke parse_bool(web.request_query_param(ctx, "include_deleted"))) {
            returner feil_fra_status(404, "Ticket not found")
    }
    la kommentarer = []
    hvis (har_nokkel(ticket, "comments")) {
        kommentarer = ticket["comments"]
    }

    la out: ordbok_tekst = {}
    out["ticket_id"] = tekst_fra_heltall(id)
    out["count"] = tekst_fra_heltall(lengde(kommentarer))
    out["comments"] = kommentarer
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}


    out["status"] = "planned"
    out["capability"] = "summarize_ticket"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}

funksjon oppdater_ticket(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("krever_agent_eller_admin")
    web.route("PUT /tickets/{id:int}")

    la data = les_data()
    la id = web.request_param_int(ctx, "id")
    la tickets = data["tickets"]
    la indeks = find_ticket_indeks(tickets, id)

    hvis (indeks < 0) {
        returner feil_fra_status(404, "Ticket not found")
    }

    la body: ordbok_tekst
    prøv {
        body = request_json_objekt(ctx)
    } fang (e) {
        returner feil_fra_status(400, "Invalid JSON body")
    }

    la ticket = tickets[tekst_fra_heltall(indeks)]
    hvis (er_slettet(ticket)) {
        returner feil_fra_status(404, "Ticket not found")
    }
    la oppdatert: ordbok_tekst = {}
    hvis (har_nokkel(body, "title")) {
        la ny_tittel = body["title"]
        hvis (ny_tittel == "") {
            returner feil_fra_status(400, "title is required")
        }
        ticket["title"] = ny_tittel
        oppdatert["title"] = sann
    }

    hvis (har_nokkel(body, "description")) {
        la ny_beskrivelse = body["description"]
        ticket["description"] = ny_beskrivelse
        oppdatert["description"] = sann
    }

    hvis (har_nokkel(body, "priority")) {
        la ny_prioritet = parse_int_mellom_min_maks(body["priority"], 1, 5)
        ticket["priority"] = tekst_fra_heltall(ny_prioritet)
        oppdatert["priority"] = sann
    }

    hvis (har_nokkel(body, "status")) {
        la ny_status = normaliser_status(body["status"])
        hvis (ikke er_gyldig_status(ny_status)) {
            returner feil_fra_status(400, "Invalid status. Allowed: new, open, in_progress, waiting, resolved, closed")
        }
        la gammel_status = ""
        hvis (har_nokkel(ticket, "status")) {
            gammel_status = ticket["status"]
        }
        hvis (gammel_status != ny_status) {
            ticket["status"] = ny_status
            la by = bruker_fra_request(ctx, data)
            hvis (by == "") {
                by = "system"
            }
            la ny_historikk = gammel_status + "->" + ny_status
            la _ = laa_til_historikk(ticket, "status_changed", ny_historikk, by)
            oppdatert["status"] = sann
        }
    }

    hvis lengde(oppdatert) == 0 {
        returner feil_fra_status(400, "No update fields provided")
    }

    hvis (lengde(oppdatert) > 0) {
        ticket["updated_at"] = neste_rekkefolge(data)
    }
    lagre_data(data)

    la out: ordbok_tekst = {}
    out["ticket"] = ticket
    out["updated"] = tekst_fra_heltall(lengde(oppdatert))
    out["message"] = "Ticket updated"
    returner web.response_builder(200, {"content-type": "application/json"}, json_svar_kropp(out))
}


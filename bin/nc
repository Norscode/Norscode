#!/usr/bin/env sh
# bin/nc - Norscode CLI (Python-fri via nc-vm)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC_VM="$ROOT_DIR/dist/nc-vm"
NATIVE_BIN="$ROOT_DIR/dist/norcode-bootstrap-compile"

# ─── Hjelpefunksjon: les version fra norcode.toml ───────────────────────────
_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        grep '^version' "$_toml" | head -1 | sed 's/.*= *"\(.*\)"/\1/'
    else
        printf 'ukjent'
    fi
}

# ─── Ignorer --legacy-python-fallback (ikkje lenger støtta) ─────────────────
_args=
for _arg in "$@"; do
    case "$_arg" in
        --python-fallback|--legacy-python-fallback) ;;
        *) _args="${_args:+$_args
}$_arg" ;;
    esac
done
if [ -n "$_args" ]; then
    _old_ifs=$IFS; IFS='
'; set -- $_args; IFS=$_old_ifs
fi

# ─── selfhost-bootstrap-gate: Python-fri via nc-vm ──────────────────────────
if [ $# -ge 1 ] && [ "$1" = "selfhost-bootstrap-gate" ]; then
    shift
    if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
        exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/bootstrap_gate.no"
    fi
    printf 'nc-vm ikkje funnen: %s\n' "$NC_VM" >&2
    printf 'Køyr: sh tools/bootstrap.sh\n' >&2
    exit 1
fi

# ─── Native bootstrap-kompilator ────────────────────────────────────────────
if [ -x "$NATIVE_BIN" ] && [ $# -ge 1 ]; then
    CMD="$1"; shift

    case "$CMD" in

        run)
            SRC="${1:-app.no}"
            ARCH="${2:-aarch64}"

            # ── Prioritet 1: nc-vm --nc-run (selfhost-kompilator, fullt Python-fri) ─
            if [ -x "$NC_VM" ]; then
                if [ -f "$SRC" ]; then
                    exec "$NC_VM" --nc-run "$SRC"
                fi
            fi

            # ── Prioritet 2: nc-vm med pre-kompilert .ncb.json ──────────────
            if [ -x "$NC_VM" ]; then
                _ncb="${SRC%.no}.ncb.json"
                if [ -f "$_ncb" ]; then
                    exec "$NC_VM" "$_ncb"
                fi
                _basename="$(basename "$SRC" .no)"
                _ncb2="$ROOT_DIR/build/nc-precompiled/${_basename}.ncb.json"
                if [ -f "$_ncb2" ]; then
                    exec "$NC_VM" "$_ncb2"
                fi
            fi

            # ── Prioritet 3: native AArch64-pipeline ────────────────────────
            mkdir -p "$ROOT_DIR/build"
            OUT="$ROOT_DIR/build/_nc_run.elf"
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=run
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "$NATIVE_BIN"
            ;;

        build)
            SRC="${1:-}"
            OUT="${2:-}"
            ARCH="${3:-aarch64}"
            if [ -z "$SRC" ] || [ -z "$OUT" ]; then
                printf 'bruk: nc build <kilde.no> <utdata.elf> [aarch64|x86_64]\n' >&2
                exit 2
            fi
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=build
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "$NATIVE_BIN"
            ;;

        check)
            # Syntaks- og semantikksjekk uten å kjøre.
            # Bygger til en tempfil og sletter den – exit-koden er svaret.
            SRC="${1:-}"
            if [ -z "$SRC" ]; then
                printf 'bruk: nc check <kilde.no>\n' >&2
                exit 2
            fi
            _tmpdir="$(mktemp -d)"
            _rc=0
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=build
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$_tmpdir/_check.elf"
            export NORCODE_ARCH="aarch64"
            "$NATIVE_BIN" && printf '%s: OK\n' "$SRC" || _rc=$?
            rm -rf "$_tmpdir"
            exit "$_rc"
            ;;

        --version|-V|version)
            printf 'Norscode %s\n' "$(_nc_version)"
            exit 0
            ;;

        commands)
            printf 'Norscode CLI – Python-fri kommandoer (nc-vm):\n'
            printf '  run <fil.no>                     Kompiler og kjør (ingen Python)\n'
            printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode (ingen Python)\n'
            printf '  bundle [mod=fil.no ...]          Bundle fleire modular til éin NCB\n'
            printf '  format <fil.no> [--write|--check] Formater kjeldekode (ingen Python)\n'
            printf '  lint <fil.no> [--check]          Lint kjeldekode (ingen Python)\n'
            printf '  doctor                           Systemsjekk (ingen Python)\n'
            printf '  repl                             Interaktiv REPL (ingen Python)\n'
            printf '  build <fil.no> <ut.elf> [arch]   Kompiler til native binary\n'
            printf '  check <fil.no>                   Valider syntaks og semantikk\n'
            printf '  test                             Køyr 48 testar (ingen Python)\n'
            printf '  selfcheck                        Verifiser kompilatoren\n'
            printf '  selfhost-bootstrap-gate          Bootstrap-gate (ingen Python)\n'
            printf '  identity                         Kompilatoridentitet\n'
            printf '  release                          Bygg release\n'
            printf '  ci --bootstrap-lane              CI-gate (selfhost)\n'
            printf '  --version                        Vis versjon\n'
            printf '  help                             Vis hjelp\n'
            printf '\nFjerna (avvikla):\n'
            printf '  serve bench smoke migrate-names diagnose stress fuzz\n'
            printf '  add update lock packages scaffold-api\n'
            exit 0
            ;;

        compile)
            # Delegerer direkte til nc-vm --nc-compile (Python-fri)
            SRC="${1:-}"
            OUT="${2:-}"
            if [ -z "$SRC" ]; then
                printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2
                exit 2
            fi
            if [ ! -x "$NC_VM" ]; then
                printf 'nc compile: nc-vm ikke funnet: %s\n' "$NC_VM" >&2
                exit 1
            fi
            if [ -n "$OUT" ]; then
                exec "$NC_VM" --nc-compile "$SRC" "$OUT"
            else
                exec "$NC_VM" --nc-compile "$SRC"
            fi
            ;;

        bundle)
            # nc bundle [mod=fil.no...] [--output ut.ncb.json]
            if [ ! -x "$NC_VM" ]; then
                printf 'nc bundle: nc-vm ikkje funnen: %s\n' "$NC_VM" >&2; exit 1
            fi
            exec "$NC_VM" --nc-bundle "$@"
            ;;

        doctor)
            if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/doctor.no"
            fi
            printf 'nc doctor: nc-vm ikkje funnen. Køyr: sh tools/bootstrap.sh\n' >&2; exit 1
            ;;

        lint)
            if [ ! -x "$NC_VM" ] || [ ! -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                printf 'nc lint: nc-vm ikkje funnen. Køyr: sh tools/bootstrap.sh\n' >&2; exit 1
            fi
            _lint_src="${1:-}"
            if [ -z "$_lint_src" ]; then
                printf 'bruk: nc lint <kilde.no> [--check]\n' >&2; exit 2
            fi
            _lint_check=0
            for _a in "$@"; do [ "$_a" = "--check" ] && _lint_check=1; done
            _lint_abs="$(cd "$(dirname "$_lint_src")" && pwd)/$(basename "$_lint_src")"
            if [ "$_lint_check" = "1" ]; then
                NC_LINT_FILE="$_lint_abs" NC_LINT_CHECK="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/linter.no"
            else
                NC_LINT_FILE="$_lint_abs" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/linter.no"
            fi
            ;;

        format)
            if [ ! -x "$NC_VM" ] || [ ! -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                printf 'nc format: nc-vm ikkje funnen. Køyr: sh tools/bootstrap.sh\n' >&2; exit 1
            fi
            _fmt_src="${1:-}"
            if [ -z "$_fmt_src" ]; then
                printf 'bruk: nc format <kilde.no> [--write] [--check]\n' >&2; exit 2
            fi
            _fmt_write=0; _fmt_check=0
            for _a in "$@"; do
                [ "$_a" = "--write" ] && _fmt_write=1
                [ "$_a" = "--check" ] && _fmt_check=1
            done
            _fmt_src_abs="$(cd "$(dirname "$_fmt_src")" && pwd)/$(basename "$_fmt_src")"
            if [ "$_fmt_write" = "1" ]; then
                NC_FORMAT_FILE="$_fmt_src_abs" NC_FORMAT_WRITE="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
            elif [ "$_fmt_check" = "1" ]; then
                NC_FORMAT_FILE="$_fmt_src_abs" NC_FORMAT_CHECK="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
            else
                NC_FORMAT_FILE="$_fmt_src_abs" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
            fi
            ;;

        native-build)
            # Bygg til native ELF via Python-native-pipeline (ingen clang)
            # Delegerer til Python, men denne pipelinen bruker ikke clang
            set -- "$CMD" "$@"
            ;;

        native-run)
            # Bygg og kjør native ELF via Python-native-pipeline (ingen clang)
            set -- "$CMD" "$@"
            ;;

        ci)
            # ci --bootstrap-lane → native selfcheck
            # Andre ci-flagg faller tilbake til Python
            _is_bootstrap_lane=0
            for _a in "$@"; do
                if [ "$_a" = "--bootstrap-lane" ]; then _is_bootstrap_lane=1; fi
            done
            if [ "$_is_bootstrap_lane" = "1" ]; then
                export NORCODE_BOOTSTRAP_VM=1
                export NORCODE_BOOTSTRAP_CLI=1
                export NORCODE_ARGC=1
                export NORCODE_ARG0=selfcheck
                exec "$NATIVE_BIN"
            fi
            set -- "$CMD" "$@"
            ;;

        test)
            # Python-fri testløpar via nc-vm --nc-run
            if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
            fi
            # Fallback til native binary
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_BOOTSTRAP_CLI=1
            NORCODE_ARGC=$(( $# + 1 ))
            export NORCODE_ARGC
            export NORCODE_ARG0="$CMD"
            _i=1
            for _arg in "$@"; do
                eval "export NORCODE_ARG$_i=\$_arg"
                _i=$(( _i + 1 ))
            done
            exec "$NATIVE_BIN"
            ;;

        selfcheck|identity|release|release-targets|help|--help|-h)
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_BOOTSTRAP_CLI=1
            NORCODE_ARGC=$(( $# + 1 ))
            export NORCODE_ARGC
            export NORCODE_ARG0="$CMD"
            _i=1
            for _arg in "$@"; do
                eval "export NORCODE_ARG$_i=\$_arg"
                _i=$(( _i + 1 ))
            done
            exec "$NATIVE_BIN"
            ;;

        repl)
            if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                exec sh "$ROOT_DIR/tools/nc_repl.sh" "$@"
            fi
            printf 'nc repl: nc-vm ikkje funnen. Køyr: sh tools/bootstrap.sh\n' >&2; exit 1
            ;;

        serve|smoke|bench|migrate-names|diagnose|stress|fuzz|add|update|lock|packages|scaffold-api)
            printf 'nc %s: avvikla og fjerna.\n' "$CMD" >&2
            exit 2
            ;;

        *)
            printf 'Norscode: ukjend kommando "%s".\n' "$CMD" >&2
            printf 'Køyr: nc commands  for oversikt.\n' >&2
            exit 2
            ;;
    esac
fi

printf 'Norscode: fant ingen kjørbar kompilator.\n' >&2
printf 'Installer med: bash tools/build-bootstrap-binary.sh\n' >&2
printf 'Forventet native binary: %s\n' "$NATIVE_BIN" >&2
exit 1

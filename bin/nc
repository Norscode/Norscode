    package-windows-app)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc package-windows-app [--version VER] <EXE_PATH>\n'
            printf 'Pakk Windows-app rundt eksisterande norscode.exe via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        _windows_package_version=""
        _windows_package_exe=""
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --version)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc package-windows-app [--version VER] <EXE_PATH>\n' >&2
                        exit 2
                    fi
                    _windows_package_version="$2"
                    shift 2
                    ;;
                *)
                    if [ -n "$_windows_package_exe" ]; then
                        printf 'bruk: nc package-windows-app [--version VER] <EXE_PATH>\n' >&2
                        exit 2
                    fi
                    _windows_package_exe="$1"
                    shift
                    ;;
            esac
        done
        if [ -z "$_windows_package_exe" ]; then
            printf 'Feil: manglar path til Windows-native .exe\n' >&2
            exit 1
        fi
        case "$_windows_package_exe" in
            /*) ;;
            *) _windows_package_exe="$ROOT_DIR/$_windows_package_exe" ;;
        esac
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_WINDOWS_PACKAGE_VERSION="$_windows_package_version" \
            NORSCODE_WINDOWS_PACKAGE_EXE="$_windows_package_exe" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/package-windows-app.no"
        ;;

    build-windows-app-layout)

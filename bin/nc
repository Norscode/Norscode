#!/usr/bin/env sh
# bin/nc - Norscode CLI (Python-fri via nc-vm)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC_VM="$ROOT_DIR/dist/nc-vm"

_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        grep '^version' "$_toml" | head -1 | sed 's/.*= *"\(.*\)"/\1/'
    else
        printf 'ukjent'
    fi
}

_require_nc_vm() {
    if [ ! -x "$NC_VM" ]; then
        printf 'nc: nc-vm ikkje funnen. Køyr: sh tools/bootstrap.sh\n' >&2
        exit 1
    fi
}

# ─── Ignorer --legacy-python-fallback (ikkje lenger støtta) ─────────────────
_args=
for _arg in "$@"; do
    case "$_arg" in
        --python-fallback|--legacy-python-fallback) ;;
        *) _args="${_args:+$_args
}$_arg" ;;
    esac
done
if [ -n "$_args" ]; then
    _old_ifs=$IFS; IFS='
'; set -- $_args; IFS=$_old_ifs
fi

if [ $# -eq 0 ]; then
    printf 'Norscode %s  —  køyr: nc help\n' "$(_nc_version)"
    exit 0
fi

CMD="$1"; shift

case "$CMD" in

    run)
        _require_nc_vm
        SRC="${1:-app.no}"
        exec "$NC_VM" --nc-run "$SRC"
        ;;

    compile)
        _require_nc_vm
        SRC="${1:-}"
        OUT="${2:-}"
        if [ -z "$SRC" ]; then
            printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2; exit 2
        fi
        if [ -n "$OUT" ]; then
            exec "$NC_VM" --nc-compile "$SRC" "$OUT"
        else
            exec "$NC_VM" --nc-compile "$SRC"
        fi
        ;;

    build)
        _require_nc_vm
        SRC="${1:-}"
        OUT="${2:-}"
        if [ -z "$SRC" ] || [ -z "$OUT" ]; then
            printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n' >&2; exit 2
        fi
        exec "$NC_VM" --nc-compile "$SRC" "$OUT"
        ;;

    check)
        _require_nc_vm
        SRC="${1:-}"
        if [ -z "$SRC" ]; then
            printf 'bruk: nc check <kilde.no>\n' >&2; exit 2
        fi
        _tmpdir="$(mktemp -d)"
        _rc=0
        "$NC_VM" --nc-compile "$SRC" "$_tmpdir/_check.ncb.json" \
            && printf '%s: OK\n' "$SRC" || _rc=$?
        rm -rf "$_tmpdir"
        exit "$_rc"
        ;;

    bundle)
        _require_nc_vm
        exec "$NC_VM" --nc-bundle "$@"
        ;;

    format)
        _require_nc_vm
        _fmt_src="${1:-}"
        if [ -z "$_fmt_src" ]; then
            printf 'bruk: nc format <kilde.no> [--write] [--check]\n' >&2; exit 2
        fi
        _fmt_write=0; _fmt_check=0
        for _a in "$@"; do
            [ "$_a" = "--write" ] && _fmt_write=1
            [ "$_a" = "--check" ] && _fmt_check=1
        done
        _fmt_abs="$(cd "$(dirname "$_fmt_src")" && pwd)/$(basename "$_fmt_src")"
        if [ "$_fmt_write" = "1" ]; then
            NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_WRITE="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
        elif [ "$_fmt_check" = "1" ]; then
            NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_CHECK="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
        else
            NC_FORMAT_FILE="$_fmt_abs" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
        fi
        ;;

    lint)
        _require_nc_vm
        _lint_src="${1:-}"
        if [ -z "$_lint_src" ]; then
            printf 'bruk: nc lint <kilde.no> [--check]\n' >&2; exit 2
        fi
        _lint_check=0
        for _a in "$@"; do [ "$_a" = "--check" ] && _lint_check=1; done
        _lint_abs="$(cd "$(dirname "$_lint_src")" && pwd)/$(basename "$_lint_src")"
        if [ "$_lint_check" = "1" ]; then
            NC_LINT_FILE="$_lint_abs" NC_LINT_CHECK="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/linter.no"
        else
            NC_LINT_FILE="$_lint_abs" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/linter.no"
        fi
        ;;

    doctor)
        _require_nc_vm
        exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/doctor.no"
        ;;

    repl)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_repl.sh" "$@"
        ;;

    test)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        ;;

    selfcheck)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        ;;

    selfhost-bootstrap-gate)
        _require_nc_vm
        exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/bootstrap_gate.no"
        ;;

    ci)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        ;;

    identity|release|release-targets)
        _require_nc_vm
        exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/main.no" "$CMD" "$@"
        ;;

    --version|-V|version)
        printf 'Norscode %s\n' "$(_nc_version)"
        exit 0
        ;;

    commands|help|--help|-h)
        printf 'Norscode %s — Python-fri CLI (nc-vm)\n\n' "$(_nc_version)"
        printf 'Kommandoar:\n'
        printf '  run <fil.no>                     Kompiler og køyr\n'
        printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode\n'
        printf '  build <fil.no> <ut.ncb.json>     Kompiler (alias for compile)\n'
        printf '  check <fil.no>                   Syntaks- og semantikksjekk\n'
        printf '  bundle [mod=fil.no ...]          Bundle modular\n'
        printf '  format <fil.no> [--write|--check] Formater kjeldekode\n'
        printf '  lint <fil.no> [--check]          Lint kjeldekode\n'
        printf '  doctor                           Systemsjekk\n'
        printf '  repl                             Interaktiv REPL\n'
        printf '  test                             Køyr testar\n'
        printf '  selfcheck                        Verifiser kompilatoren\n'
        printf '  selfhost-bootstrap-gate          Bootstrap-gate\n'
        printf '  ci                               CI-gate\n'
        printf '  --version                        Vis versjon\n'
        exit 0
        ;;

    serve|smoke|bench|migrate-names|diagnose|stress|fuzz|add|update|lock|packages|scaffold-api|native-build|native-run)
        printf 'nc %s: avvikla og fjerna.\n' "$CMD" >&2
        exit 2
        ;;

    *)
        printf 'Norscode: ukjend kommando "%s". Køyr: nc help\n' "$CMD" >&2
        exit 2
        ;;
esac

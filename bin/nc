        if [ "${1:-}" = "--full" ]; then _regen_full=1; fi
        # NORSCODE_REGEN_BOOTSTRAP_FULL="$_regen_full"
        exec env NORSCODE_REGEN_BOOTSTRAP_FULL="$_regen_full" NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" run "$ROOT_DIR/tools/nc_regen_bootstrap.no"
        ;;

    ci)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc ci [fil.no ...]\n'
            printf 'Køyr CI-gate lokalt.\n'
            exit 0
        fi
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/phase2_ci.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/phase2_benchmark.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        exec env NC_CI=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/nc_test.no" NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        ;;

    identity|release|release-targets)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "$CMD" in
                identity) printf 'bruk: nc identity\n' ;;
                release) printf 'bruk: nc release\n' ;;
                release-targets) printf 'bruk: nc release-targets\n' ;;
            esac
            printf 'Køyr historisk selfhost-main-kommando via Norscode runtime.\n'
            exit 0
        fi
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/main.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        printf 'nc: treng dist/norscode_native\n' >&2; exit 1
        ;;

    --version|-V|version)
        printf 'Norscode %s\n' "$(_nc_version)"
        exit 0
        ;;

    commands|help|--help|-h)
        printf 'Norscode %s — C/Python-fri CLI (norscode_native)\n\n' "$(_nc_version)"
        printf 'Normal bruk:\n'
	        printf '  run <fil.no>                     Kompiler og køyr\n'
	        printf '  run-pure <fil.no>                Kompiler og køyr via Norscode VM-kandidat\n'
	        printf '  run-ncb-pure <fil.ncb.json>      Køyr NCB via Norscode VM-kandidat\n'
	        printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode\n'
        printf '  build <fil.no> <ut.ncb.json>     Kompiler (alias for compile)\n'
        printf '  check <fil.no>                   Syntaks- og semantikksjekk\n'
        printf '  bundle [mod=fil.no ...]          Bundle modular\n'
        printf '  format <fil.no> [--write|--check] Formater kjeldekode\n'
        printf '  lint <fil.no> [--check]          Lint kjeldekode\n'
        printf '  doctor                           Systemsjekk\n'
        printf '  lsp                              Køyr LSP-grunnmur/selftest\n'
        printf '  repl [uttrykk]                   Interaktiv REPL eller evaluer uttrykk\n'
        printf '  test                             Køyr testar\n'
        printf '  selftest                         Køyr nc_main selftest\n'
        printf '  selfcheck                        Verifiser kompilatoren\n'
        printf '\nVedlikehald:\n'
        printf '  maintenance [status|lane|docs|cleanup|seed|tests|maturity|summary|report|report-json|verify]  Norscode-basert vedlikehald\n'
        printf '  release-preflight [--strict]     Lokal release-sjekk utan publisering\n'
        printf '  package-release <versjon>        Bygg releasepakke lokalt utan publisering\n'

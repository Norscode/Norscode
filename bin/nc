#!/usr/bin/env sh
# bin/nc - Norscode CLI (native)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC_NATIVE="$ROOT_DIR/dist/norscode_native"

_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        grep '^version' "$_toml" | head -1 | sed 's/.*= *"\(.*\)"/\1/'
    else
        printf 'ukjent'
    fi
}

_require_native() {
    if [ ! -x "$NC_NATIVE" ]; then
        printf 'nc: norscode_native ikkje funnen. Køyr: bash tools/build_norscode_native.sh\n' >&2
        exit 1
    fi
}
# Bakoverkompatibelt alias
_require_nc_vm() { _require_native; }

if [ $# -eq 0 ]; then
    printf 'Norscode %s  —  køyr: nc help\n' "$(_nc_version)"
    exit 0
fi

CMD="$1"; shift

case "$CMD" in

    run)
        SRC="${1:-app.no}"
        # Prioriter norscode_native (native binary, raskare)
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$SRC" "$NC_NATIVE"
        fi
        printf 'nc: trenger dist/norscode_native. Køyr: bash tools/build_norscode_native.sh\n' >&2; exit 1
        ;;

    compile)
        SRC="${1:-}"
        OUT="${2:-}"
        if [ -z "$SRC" ]; then
            printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2; exit 2
        fi
        if [ -x "$NC_NATIVE" ]; then
            if [ -n "$OUT" ]; then
                exec env NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_OUTPUT="$OUT" "$NC_NATIVE"
            else
                exec env NORSCODE_CMD=compile NORSCODE_FILE="$SRC" "$NC_NATIVE"
            fi
        fi
        printf 'nc: trenger dist/norscode_native. Køyr: bash tools/build_norscode_native.sh\n' >&2; exit 1
        ;;

    build)
        SRC="${1:-}"
        OUT="${2:-}"
        if [ -z "$SRC" ] || [ -z "$OUT" ]; then
            printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n' >&2; exit 2
        fi
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_OUTPUT="$OUT" "$NC_NATIVE"
        fi
        printf 'nc: trenger dist/norscode_native. Køyr: bash tools/build_norscode_native.sh\n' >&2; exit 1
        ;;

    bygg)
        # nc bygg [--mål elf64] <kilde.no> [utdata]
        _maal="ncb"
        _src=""
        _out=""
        _next_is_maal=0
        for _ba in "$@"; do
            if [ "$_next_is_maal" = "1" ]; then
                _maal="$_ba"; _next_is_maal=0; continue
            fi
            case "$_ba" in
                --mål) _next_is_maal=1 ;;
                elf64|elf) _maal="elf64" ;;
                kernel|kernel32) _maal="kernel" ;;
                *.no) _src="$_ba" ;;
                *) _out="$_ba" ;;
            esac
        done
        if [ -z "$_src" ] && [ "$_maal" != "kernel" ] && [ "$_maal" != "kernel32" ]; then
            printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n' >&2; exit 2
        fi
        _require_native
        if [ "$_maal" = "native" ] || [ "$_maal" = "native64" ]; then
            if [ -z "$_src" ]; then
                printf 'bruk: nc bygg --mål native <kilde.no> [utdata]\n' >&2; exit 2
            fi
            if [ -z "$_out" ]; then _out="${_src%.no}"; fi
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            env NORSCODE_CMD=compile NORSCODE_FILE="$_src" "$NC_NATIVE" > "$_tmpncb"
            NC_INPUT="$_tmpncb" NC_OUTPUT="$_out" \
                env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/native_codegen.no" "$NC_NATIVE"
            rm -f "$_tmpncb"
            chmod +x "$_out" 2>/dev/null || true
        elif [ "$_maal" = "kernel" ] || [ "$_maal" = "kernel32" ]; then
            if [ -z "$_out" ]; then _out="build/norscode_kernel.elf"; fi
            mkdir -p "$(dirname "$_out")"
            NC_OUTPUT="$_out" \
                env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/kernel_builder.no" "$NC_NATIVE"
        elif [ "$_maal" = "elf64" ]; then
            if [ -z "$_out" ]; then _out="${_src%.no}"; fi
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            env NORSCODE_CMD=compile NORSCODE_FILE="$_src" "$NC_NATIVE" > "$_tmpncb"
            NC_INPUT="$_tmpncb" NC_OUTPUT="$_out" \
                env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/ncb_to_elf.no" "$NC_NATIVE"
            rm -f "$_tmpncb"
            chmod +x "$_out" 2>/dev/null || true
            printf 'bygg: %s → %s (ELF64 x86-64)\n' "$_src" "$_out"
        else
            if [ -z "$_out" ]; then _out="${_src%.no}.ncb.json"; fi
            env NORSCODE_CMD=compile NORSCODE_FILE="$_src" "$NC_NATIVE" > "$_out"
            printf 'bygg: %s → %s (NCB)\n' "$_src" "$_out"
        fi
        ;;

    check)
        SRC="${1:-}"
        if [ -z "$SRC" ]; then
            printf 'bruk: nc check <kilde.no>\n' >&2; exit 2
        fi
        _tmpdir="$(mktemp -d)"
        _rc=0
        if [ -x "$NC_NATIVE" ]; then
            env NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_OUTPUT="$_tmpdir/_check.ncb.json" \
                "$NC_NATIVE" >/dev/null && printf '%s: OK\n' "$SRC" || _rc=$?
        else
            printf 'nc: trenger dist/norscode_native. Køyr: bash tools/build_norscode_native.sh\n' >&2; exit 1
        fi
        rm -rf "$_tmpdir"
        exit "$_rc"
        ;;

    bundle)
        if [ -x "$NC_NATIVE" ]; then
            _bundle_out="bootstrap/kompiler.ncb.json"
            _bundle_args=""
            _skip=0
            for _barg in "$@"; do
                if [ "$_barg" = "--output" ]; then _skip=1; continue; fi
                if [ "$_skip" = "1" ]; then _bundle_out="$_barg"; _skip=0; continue; fi
                _bundle_args="${_bundle_args:+$_bundle_args }$_barg"
            done
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bundler.no" \
                NORSCODE_BUNDLE_ARGS="$_bundle_args" \
                NORSCODE_BUNDLE_OUTPUT="$_bundle_out" \
                "$NC_NATIVE"
        fi
        printf 'nc bundle: trenger dist/norscode_native. Køyr: bash tools/build_norscode_native.sh\n' >&2; exit 1
        ;;

    format)
        _require_nc_vm
        _fmt_src="${1:-}"
        if [ -z "$_fmt_src" ]; then
            printf 'bruk: nc format <kilde.no> [--write] [--check]\n' >&2; exit 2
        fi
        _fmt_write=0; _fmt_check=0
        for _a in "$@"; do
            [ "$_a" = "--write" ] && _fmt_write=1
            [ "$_a" = "--check" ] && _fmt_check=1
        done
        _fmt_abs="$(cd "$(dirname "$_fmt_src")" && pwd)/$(basename "$_fmt_src")"
        if [ "$_fmt_write" = "1" ]; then
            if [ -x "$NC_NATIVE" ]; then
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/formatter.no" NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_WRITE="1" "$NC_NATIVE"
            fi
            printf 'nc format: trenger dist/norscode_native\n' >&2; exit 1
        elif [ "$_fmt_check" = "1" ]; then
            if [ -x "$NC_NATIVE" ]; then
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/formatter.no" NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_CHECK="1" "$NC_NATIVE"
            fi
            printf 'nc format: trenger dist/norscode_native\n' >&2; exit 1
        else
            if [ -x "$NC_NATIVE" ]; then
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/formatter.no" NC_FORMAT_FILE="$_fmt_abs" "$NC_NATIVE"
            fi
            printf 'nc format: trenger dist/norscode_native\n' >&2; exit 1
        fi
        ;;

    lint)
        _require_nc_vm
        _lint_src="${1:-}"
        if [ -z "$_lint_src" ]; then
            printf 'bruk: nc lint <kilde.no> [--check]\n' >&2; exit 2
        fi
        _lint_check=0
        for _a in "$@"; do [ "$_a" = "--check" ] && _lint_check=1; done
        _lint_abs="$(cd "$(dirname "$_lint_src")" && pwd)/$(basename "$_lint_src")"
        if [ "$_lint_check" = "1" ]; then
            if [ -x "$NC_NATIVE" ]; then
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/linter.no" NC_LINT_FILE="$_lint_abs" NC_LINT_CHECK="1" "$NC_NATIVE"
            fi
            printf 'nc lint: trenger dist/norscode_native\n' >&2; exit 1
        else
            if [ -x "$NC_NATIVE" ]; then
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/linter.no" NC_LINT_FILE="$_lint_abs" "$NC_NATIVE"
            fi
            printf 'nc lint: trenger dist/norscode_native\n' >&2; exit 1
        fi
        ;;

    doctor)
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/doctor.no" "$NC_NATIVE"
        fi
        printf 'nc doctor: trenger dist/norscode_native\n' >&2; exit 1
        ;;

    repl)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_repl.sh" "$@"
        ;;

    test)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        ;;

    selfcheck)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        ;;

    selfhost-bootstrap-gate)
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bootstrap_gate.no" "$NC_NATIVE"
        fi
        printf 'nc selfhost-bootstrap-gate: trenger dist/norscode_native\n' >&2; exit 1
        ;;

    bootstrap-self)
        _require_native
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bootstrap_self_pure.no" "$NC_NATIVE"
        ;;

    bootstrap-self-vm|run-ncb)
        _require_native
        if [ -z "${1:-}" ]; then
            printf 'bruk: nc run-ncb <program.ncb.json>\n' >&2; exit 1
        fi
        _ncb_file="$1"
        if [ ! -f "$_ncb_file" ]; then
            printf 'ERROR: %s finst ikkje\n' "$_ncb_file" >&2; exit 1
        fi
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/vm_executor.no" NORSCODE_NCB_FILE="$_ncb_file" "$NC_NATIVE"
        ;;

    selfcompile-l5|l5)
        _require_native
        exec sh "$ROOT_DIR/tools/selfcompile_l5.sh" "$@"
        ;;

    selfcompile-l5b|l5b)
        _require_native
        exec sh "$ROOT_DIR/tools/selfcompile_l5b.sh" "$@"
        ;;

    regen-native|regen)
        _require_native
        exec sh "$ROOT_DIR/tools/maint/regen_native.sh" "$@"
        ;;

    regen-verify)
        exec sh "$ROOT_DIR/tools/maint/regen_verify.sh" "$@"
        ;;

    verify-l6|l6)
        exec sh "$ROOT_DIR/tools/maint/verify_l6.sh" "$@"
        ;;

    verify-selvstendighet|selvstendighet)
        exec sh "$ROOT_DIR/tools/verify_selvstendighet.sh" "$@"
        ;;

    verify-omgang6|omgang6)
        exec bash "$ROOT_DIR/tools/verify_omgang6.sh" "$@"
        ;;

    selfcompile-native-elf|native-elf-selfcompile)
        exec bash "$ROOT_DIR/tools/selfcompile_native_elf.sh" "$@"
        ;;

    selfcompile-stage0-elf|stage0-elf-selfcompile)
        exec bash "$ROOT_DIR/tools/selfcompile_stage0_elf.sh" "$@"
        ;;

    verify-omgang6)
        exec bash "$ROOT_DIR/tools/verify_omgang6.sh" "$@"
        ;;

    verify-omgang6b|omgang6b)
        exec bash "$ROOT_DIR/tools/verify_omgang6b.sh" "$@"
        ;;

    ensure-stage0-seed|fetch-stage0-seed)
        exec bash "$ROOT_DIR/tools/maint/ensure_stage0_seed.sh" "$@"
        ;;

    finish-6b4)
        exec bash "$ROOT_DIR/tools/maint/finish_6b4.sh" "$@"
        ;;

    ncb-to-elf)
        _require_native
        exec bash "$ROOT_DIR/tools/ncb_to_elf.sh" "$@"
        ;;

    regen-fraser)
        _require_native
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/scripts/regen_fraser.no" "$NC_NATIVE"
        ;;

    bygg-native|bygg-native-v2)
        # Omgang 6: kompiler NCB til native ELF via native_codegen_v2.no (full NcVal-runtime)
        _require_native
        if [ "${1:-}" = "--ncb" ]; then
            exec bash "$ROOT_DIR/tools/ncb_to_elf.sh" "${2:?bruk: nc bygg-native --ncb fil.ncb.json ut.elf}" "${3:-a.out}"
        fi
        _src="${1:-}"
        _out="${2:-a.out}"
        _codegen="$ROOT_DIR/selfhost/native_execution/native_codegen_v2.no"
        if [ -z "$_src" ]; then
            exec env NORSCODE_CMD=run \
                NORSCODE_FILE="$_codegen" \
                NC_INPUT="$ROOT_DIR/bootstrap/kompiler.ncb.json" \
                NC_OUTPUT="$_out" \
                "$NC_NATIVE"
        else
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_native_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_native_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            trap 'rm -f "$_tmpncb"' EXIT
            env NORSCODE_CMD=compile NORSCODE_FILE="$_src" NORSCODE_OUTPUT="$_tmpncb" "$NC_NATIVE" >/dev/null
            exec env NORSCODE_CMD=run \
                NORSCODE_FILE="$_codegen" \
                NC_INPUT="$_tmpncb" \
                NC_OUTPUT="$_out" \
                "$NC_NATIVE"
        fi
        ;;

    ci)
        _require_nc_vm
        exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        ;;

    identity|release|release-targets)
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/main.no" "$NC_NATIVE"
        fi
        printf 'nc: trenger dist/norscode_native\n' >&2; exit 1
        ;;

    --version|-V|version)
        printf 'Norscode %s\n' "$(_nc_version)"
        exit 0
        ;;

    commands|help|--help|-h)
        printf 'Norscode %s — Python-fri CLI (norscode_native)\n\n' "$(_nc_version)"
        printf 'Kommandoar:\n'
        printf '  run <fil.no>                     Kompiler og køyr\n'
        printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode\n'
        printf '  build <fil.no> <ut.ncb.json>     Kompiler (alias for compile)\n'
        printf '  check <fil.no>                   Syntaks- og semantikksjekk\n'
        printf '  bundle [mod=fil.no ...]          Bundle modular\n'
        printf '  format <fil.no> [--write|--check] Formater kjeldekode\n'
        printf '  lint <fil.no> [--check]          Lint kjeldekode\n'
        printf '  doctor                           Systemsjekk\n'
        printf '  repl                             Interaktiv REPL\n'
        printf '  test                             Køyr testar\n'
        printf '  selfcheck                        Verifiser kompilatoren\n'
        printf '  selfhost-bootstrap-gate          Bootstrap-gate (steg A+B)\n'
        printf '  bootstrap-self                   Bootstrap steg C (Norscode-VM køyrer Norscode)\n'
        printf '  selfcompile-l5                   L5: kompilator-bundle Gen1==Gen2 (byte-paritet)\n'
        printf '  selfcompile-l5b                  L5b: Gen1-NCB VM køyrer Gen2 (byte-paritet)\n'
        printf '  regen-native [--rebuild]         [maintainer] Regenerer isolert maintainer-output under build/\n'
        printf '  regen-verify                     [maintainer] Deterministisk regen (to kjøringar)\n'
        printf '  verify-l6                        [maintainer] L6: seed → regen → bootstrap-verifisering\n'
        printf '  verify-selvstendighet            L1–L6 gate + bootstrap-self + test\n'
        printf '  verify-omgang6                   Omgang 6: bygg-native ELF-gate\n'
        printf '  selfcompile-native-elf           Omgang 6: ELF byte-paritet (Gen1==Gen2)\n'
        printf '  selfcompile-stage0-elf          Omgang 6b.3: stage-0 ELF sjølvkompilering\n'
    printf '  regen-fraser                     Regenerer fraser-tabell i selfhost/common.no\n'
        printf '  serve <fil.no> [--port <port>]    Start ekte HTTP-server (python3 + norscode_native)\n'
    printf '  bygg-native [fil.no] [ut]        Kompiler til native ELF (Omgang 6)\n'
        printf '  bygg-native --ncb ncb.json ut   NCB JSON → native ELF\n'
        printf '  verify-omgang6b                  Omgang 6b: host + kompilator ELF + sjølvkompilering\n'
        printf '  ensure-stage0-seed               [maintainer] Sørg for bootstrap/stage0/norscode-<plattform>\n'
        printf '  finish-6b4                       [maintainer] Fjern historisk bootstrap/maint/c/*.c etter seed-migrering\n'
        printf '  startproject <mappe>             Opprett ny Norscode-prosjekt etter standardmal\n'
        printf '  scaffold-api [nå avvikla]        Alias for startproject\n'
        printf '  startapp <app_namn>              Opprett app-modul i prosjektet\n'
        printf '  ci                               CI-gate\n'
        printf '  --version                        Vis versjon\n'
        exit 0
        ;;

    migrate)
        _require_native
        _mig_file="${1:-app.no}"
        _mig_db="${2:-app.db}"
        _mig_cmd="${3:-køyr}"
        if [ ! -f "$_mig_file" ]; then
            printf 'feil: finn ikkje fil %s\n' "$_mig_file" >&2; exit 2
        fi
        exec env NORSCODE_CMD=run NORSCODE_FILE="$_mig_file" \
            NC_MIGRATE_DB="$_mig_db" NC_MIGRATE_CMD="$_mig_cmd" "$NC_NATIVE"
        ;;

    startproject)
        exec sh "$ROOT_DIR/tools/startproject.sh" "$@"
        ;;

    scaffold-api)
        printf 'Scaffold-api er bytt til startproject, køyr: nc startproject "$@"\n'
        exec sh "$ROOT_DIR/tools/startproject.sh" "$@"
        ;;

    startapp)
        exec sh "$ROOT_DIR/tools/startapp.sh" "$@"
        ;;

    serve)
        _file="${1:-examples/helpdesk.no}"
        _port="${NORSCODE_PORT:-4173}"

        _workers="${NORSCODE_WORKERS:-8}"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --port)
                    shift
                    if [ -z "${1:-}" ]; then
                        printf 'bruk: nc serve <kilde.no> [--port <port>] [--workers <n>]\n' >&2
                        exit 2
                    fi
                    _port="$1"
                    ;;
                --workers)
                    shift
                    _workers="${1:-8}"
                    ;;
                --help|-h)
                    printf 'bruk: nc serve <kilde.no> [--port <port>] [--workers <n>]\n'
                    printf '\n  --workers  Antal async-arbeidartrådar (standard: 8)\n'
                    exit 0
                    ;;
                --*)
                    printf 'ukjend serve-opsjon: %s\n' "$1" >&2
                    exit 2
                    ;;
                *)
                    _file="$1"
                    ;;
            esac
            shift
        done

        if [ ! -f "$_file" ]; then
            printf 'feil: finn ikkje fil %s\n' "$_file" >&2
            exit 2
        fi

        if [ ! -x "$NC_NATIVE" ]; then
            printf 'nc serve krev dist/norscode_native. Køyr: bash tools/build_norscode_native.sh\n' >&2
            exit 1
        fi

        # Async Python HTTP-server (asyncio + ThreadPoolExecutor)
        _py_server="$ROOT_DIR/server/nc_http_server.py"
        if command -v python3 >/dev/null 2>&1 && [ -f "$_py_server" ]; then
            exec python3 "$_py_server" "$_file" --port "$_port" --workers "$_workers"
        fi

        # Fallback: norscode_native fake-request modus
        printf '[serve] python3 ikkje funne, brukar fake-request modus.\n' >&2
        exec env NORSCODE_CMD=serve NORSCODE_FILE="$_file" NORSCODE_PORT="$_port" "$NC_NATIVE"
        ;;

    pakke|pkg)
        _subcmd="${1:-help}"
        shift || true
        case "$_subcmd" in
            installer|install|i)
                _pakke="${1:-}"
                _versjon="${2:-*}"
                if [ -z "$_pakke" ]; then
                    # Installer alle frå pakke.json
                    if [ -f "pakke.json" ]; then
                        printf '[pakke] Installerer avhengigheiter frå pakke.json …\n'
                        _require_native
                        exec env NORSCODE_CMD=pakke_install_alle "$NC_NATIVE"
                    else
                        printf 'bruk: nc pakke installer <pakkenamn> [versjon]\n' >&2
                        exit 2
                    fi
                fi
                printf '[pakke] Installerer %s@%s …\n' "$_pakke" "$_versjon"
                _require_native
                exec env NORSCODE_CMD=pakke_installer NORSCODE_PAKKE="$_pakke" NORSCODE_VERSJON="$_versjon" "$NC_NATIVE"
                ;;
            publiser|publish)
                _api_nøkkel="${NC_API_NØKKEL:-${NC_API_KEY:-}}"
                if [ -z "$_api_nøkkel" ]; then
                    printf 'feil: set NC_API_NØKKEL som miljøvariabel.\n' >&2
                    exit 2
                fi
                if [ ! -f "pakke.json" ]; then
                    printf 'feil: pakke.json ikkje funnen.\n' >&2
                    exit 2
                fi
                printf '[pakke] Publiserer …\n'
                _require_native
                exec env NORSCODE_CMD=pakke_publiser NORSCODE_API_NØKKEL="$_api_nøkkel" "$NC_NATIVE"
                ;;
            søk|search|s)
                _spørjing="${1:-}"
                if [ -z "$_spørjing" ]; then
                    printf 'bruk: nc pakke søk <spørjing>\n' >&2
                    exit 2
                fi
                _require_native
                exec env NORSCODE_CMD=pakke_søk NORSCODE_SØKORD="$_spørjing" "$NC_NATIVE"
                ;;
            info)
                _pakke="${1:-}"
                if [ -z "$_pakke" ]; then
                    printf 'bruk: nc pakke info <pakkenamn>\n' >&2
                    exit 2
                fi
                _require_native
                exec env NORSCODE_CMD=pakke_info NORSCODE_PAKKE="$_pakke" "$NC_NATIVE"
                ;;
            lista|list|ls)
                _require_native
                exec env NORSCODE_CMD=pakke_lista "$NC_NATIVE"
                ;;
            utdatert|outdated)
                _require_native
                exec env NORSCODE_CMD=pakke_utdatert "$NC_NATIVE"
                ;;
            init)
                _namn="${1:-$(basename "$PWD")}"
                printf '{"namn":"%s","versjon":"0.1.0","beskriving":"","forfattar":"","lisens":"MIT","avhengigheiter":{},"hovud":"main.no"}\n' "$_namn" > pakke.json
                printf '[pakke] Oppretta pakke.json for %s\n' "$_namn"
                ;;
            versjon|bump)
                _type="${1:-patch}"
                _require_native
                exec env NORSCODE_CMD=pakke_bump_versjon NORSCODE_BUMP_TYPE="$_type" "$NC_NATIVE"
                ;;
            register|registry)
                _reg_port="${NC_REGISTER_PORT:-5173}"
                _reg_mappe="${NC_PAKKAR_MAPPE:-nc_pakkar}"
                _reg_token="${NC_API_NØKKEL:-${NC_API_KEY:-}}"
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        --port)  shift; _reg_port="${1:-5173}" ;;
                        --mappe) shift; _reg_mappe="${1:-nc_pakkar}" ;;
                        --token) shift; _reg_token="${1:-}" ;;
                    esac
                    shift
                done
                _reg_server="$ROOT_DIR/server/pakke_register.py"
                if command -v python3 >/dev/null 2>&1 && [ -f "$_reg_server" ]; then
                    printf '[register] Startar lokal pakkeregistry på port %s…\n' "$_reg_port"
                    exec python3 "$_reg_server" --port "$_reg_port" --mappe "$_reg_mappe" --token "$_reg_token"
                fi
                printf 'feil: python3 ikkje funne\n' >&2; exit 1
                ;;
            lock)
                _require_native
                exec env NORSCODE_CMD=pakke_lock "$NC_NATIVE"
                ;;
            help|--help|-h|*)
                printf 'Bruk: nc pakke <kommando>\n\n'
                printf 'Kommandoar:\n'
                printf '  installer [pakke] [versjon]  Installer pakke eller alle avhengigheiter\n'
                printf '  publiser                     Publiser pakke til registeret\n'
                printf '  søk <spørjing>               Søk i pakkeregisteret\n'
                printf '  info <pakke>                 Vis pakkeinfo\n'
                printf '  lista                        List installerte pakkar\n'
                printf '  utdatert                     Vis utdaterte pakkar\n'
                printf '  init [namn]                  Opprett pakke.json\n'
                printf '  versjon <major|minor|patch>  Auk versjonsnummer\n'
                ;;
        esac
        ;;

    smoke|bench|migrate-names|diagnose|stress|fuzz|add|update|lock|packages|native-build|native-run)
        printf 'nc %s: avvikla og fjerna.\n' "$CMD" >&2
        exit 2
        ;;

    *)
        printf 'Norscode: ukjend kommando "%s". Køyr: nc help\n' "$CMD" >&2
        exit 2
        ;;
esac

#!/usr/bin/env sh
# bin/nc - Norscode CLI (native-first, eksplisitt legacy Python-fallback)
#
# Rekkefølge:
#   1. dist/norcode-bootstrap-compile  (ekte native Norscode-kompilator)
#   2. legacy Python-bane              (kun med --legacy-python-fallback)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC_VM="$ROOT_DIR/dist/nc-vm"
NATIVE_BIN="$ROOT_DIR/dist/norcode-bootstrap-compile"
LEGACY_ENTRYPOINT="norcode.legacy_main"
PYTHON_FALLBACK=0
FILTERED_ARGS=

# ─── Hjelpefunksjon: les version fra norcode.toml ───────────────────────────
_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        grep '^version' "$_toml" | head -1 | sed 's/.*= *"\(.*\)"/\1/'
    else
        printf 'ukjent'
    fi
}

# ─── Normaliser argumenter og fang eksplisitt legacy Python-fallback ────────
for _arg in "$@"; do
    if [ "$_arg" = "--python-fallback" ] || [ "$_arg" = "--legacy-python-fallback" ]; then
        PYTHON_FALLBACK=1
        continue
    fi
    if [ -z "$FILTERED_ARGS" ]; then
        FILTERED_ARGS="$_arg"
    else
        FILTERED_ARGS="${FILTERED_ARGS}
$_arg"
    fi
done

if [ "$PYTHON_FALLBACK" = "1" ]; then
    _old_ifs=$IFS
    set -f
    IFS='
'
    set --
    if [ -n "$FILTERED_ARGS" ]; then
        for _arg in $FILTERED_ARGS; do
            set -- "$@" "$_arg"
        done
    fi
    IFS=$_old_ifs
    set +f
fi

# ─── selfhost-bootstrap-gate: Python-fri via nc-vm (primær), Python fallback ─
if [ $# -ge 1 ] && [ "$1" = "selfhost-bootstrap-gate" ]; then
    shift
    # Prioritet 1: nc-vm --nc-run (Python-fri)
    if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
        exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/bootstrap_gate.no"
    fi
    # Prioritet 2: Python-fallback (overgang)
    if [ "$PYTHON_FALLBACK" = "1" ]; then
        printf 'Advarsel: Python-fallback brukes. Dette er overgangsstøtte.\n' >&2
        exec python3 -m "$LEGACY_ENTRYPOINT" selfhost-chain-run \
            "$ROOT_DIR/selfhost/bootstrap_gate.no" \
            --max-steps 100000000 \
            "$@"
    fi
    printf 'nc-vm ikkje funnen: %s\n' "$NC_VM" >&2
    printf 'Kjør: sh tools/bootstrap.sh\n' >&2
    exit 1
fi

# ─── Native bootstrap-kompilator ────────────────────────────────────────────
if [ -x "$NATIVE_BIN" ] && [ $# -ge 1 ]; then
    CMD="$1"; shift

    case "$CMD" in

        run)
            SRC="${1:-app.no}"
            ARCH="${2:-aarch64}"

            # ── Prioritet 1: nc-vm --nc-run (selfhost-kompilator, fullt Python-fri) ─
            if [ -x "$NC_VM" ]; then
                if [ -f "$SRC" ]; then
                    exec "$NC_VM" --nc-run "$SRC"
                fi
            fi

            # ── Prioritet 2: nc-vm med pre-kompilert .ncb.json ──────────────
            if [ -x "$NC_VM" ]; then
                _ncb="${SRC%.no}.ncb.json"
                if [ -f "$_ncb" ]; then
                    exec "$NC_VM" "$_ncb"
                fi
                _basename="$(basename "$SRC" .no)"
                _ncb2="$ROOT_DIR/build/nc-precompiled/${_basename}.ncb.json"
                if [ -f "$_ncb2" ]; then
                    exec "$NC_VM" "$_ncb2"
                fi
            fi

            # ── Prioritet 3: native AArch64-pipeline ────────────────────────
            mkdir -p "$ROOT_DIR/build"
            OUT="$ROOT_DIR/build/_nc_run.elf"
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=run
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "$NATIVE_BIN"
            ;;

        build)
            SRC="${1:-}"
            OUT="${2:-}"
            ARCH="${3:-aarch64}"
            if [ -z "$SRC" ] || [ -z "$OUT" ]; then
                printf 'bruk: nc build <kilde.no> <utdata.elf> [aarch64|x86_64]\n' >&2
                exit 2
            fi
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=build
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "$NATIVE_BIN"
            ;;

        check)
            # Syntaks- og semantikksjekk uten å kjøre.
            # Bygger til en tempfil og sletter den – exit-koden er svaret.
            SRC="${1:-}"
            if [ -z "$SRC" ]; then
                printf 'bruk: nc check <kilde.no>\n' >&2
                exit 2
            fi
            _tmpdir="$(mktemp -d)"
            _rc=0
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=build
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$_tmpdir/_check.elf"
            export NORCODE_ARCH="aarch64"
            "$NATIVE_BIN" && printf '%s: OK\n' "$SRC" || _rc=$?
            rm -rf "$_tmpdir"
            exit "$_rc"
            ;;

        --version|-V|version)
            printf 'Norscode %s\n' "$(_nc_version)"
            exit 0
            ;;

        commands)
            printf 'Norscode CLI – Python-fri kommandoer (nc-vm):\n'
            printf '  run <fil.no>                     Kompiler og kjør (ingen Python)\n'
            printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode (ingen Python)\n'
            printf '  bundle [mod=fil.no ...]          Bundle fleire modular til éin NCB\n'
            printf '  format <fil.no> [--write|--check] Formater kjeldekode (ingen Python)\n'
            printf '  lint <fil.no> [--check]          Lint kjeldekode (ingen Python)\n'
            printf '  doctor                           Systemsjekk (ingen Python)\n'
            printf '  repl                             Interaktiv REPL (ingen Python)\n'
            printf '  build <fil.no> <ut.elf> [arch]   Kompiler til native binary\n'
            printf '  check <fil.no>                   Valider syntaks og semantikk\n'
            printf '  test                             Køyr 48 testar (ingen Python)\n'
            printf '  selfcheck                        Verifiser kompilatoren\n'
            printf '  selfhost-bootstrap-gate          Bootstrap-gate (ingen Python)\n'
            printf '  identity                         Kompilatoridentitet\n'
            printf '  release                          Bygg release\n'
            printf '  ci --bootstrap-lane              CI-gate (selfhost)\n'
            printf '  --version                        Vis versjon\n'
            printf '  --legacy-python-fallback         Tving legacy Python-backend\n'
            printf '  help                             Vis hjelp\n'
            printf '\nAvvikla (krev --legacy-python-fallback):\n'
            printf '  serve bench smoke migrate-names diagnose stress fuzz\n'
            printf '  add update lock packages scaffold-api\n'
            exit 0
            ;;

        compile)
            # Delegerer direkte til nc-vm --nc-compile (Python-fri)
            SRC="${1:-}"
            OUT="${2:-}"
            if [ -z "$SRC" ]; then
                printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2
                exit 2
            fi
            if [ ! -x "$NC_VM" ]; then
                printf 'nc compile: nc-vm ikke funnet: %s\n' "$NC_VM" >&2
                exit 1
            fi
            if [ -n "$OUT" ]; then
                exec "$NC_VM" --nc-compile "$SRC" "$OUT"
            else
                exec "$NC_VM" --nc-compile "$SRC"
            fi
            ;;

        bundle)
            # nc bundle [mod=fil.no...] [--output ut.ncb.json]
            if [ ! -x "$NC_VM" ]; then
                printf 'nc bundle: nc-vm ikkje funnen: %s\n' "$NC_VM" >&2; exit 1
            fi
            exec "$NC_VM" --nc-bundle "$@"
            ;;

        doctor)
            # Python-fri systemsjekk
            if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/doctor.no"
            fi
            if [ "$PYTHON_FALLBACK" = "1" ]; then exec python3 -m "$LEGACY_ENTRYPOINT" doctor "$@"; fi
            printf 'nc doctor: nc-vm ikkje funnen\n' >&2; exit 1
            ;;

        lint)
            # Python-fri linter via selfhost/linter.no
            if [ ! -x "$NC_VM" ] || [ ! -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                if [ "$PYTHON_FALLBACK" = "1" ]; then exec python3 -m "$LEGACY_ENTRYPOINT" lint "$@"; fi
                printf 'nc lint: nc-vm ikkje funnen\n' >&2; exit 1
            fi
            _lint_src="${1:-}"
            if [ -z "$_lint_src" ]; then
                printf 'bruk: nc lint <kilde.no> [--check]\n' >&2; exit 2
            fi
            _lint_check=0
            for _a in "$@"; do [ "$_a" = "--check" ] && _lint_check=1; done
            _lint_abs="$(cd "$(dirname "$_lint_src")" && pwd)/$(basename "$_lint_src")"
            if [ "$_lint_check" = "1" ]; then
                NC_LINT_FILE="$_lint_abs" NC_LINT_CHECK="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/linter.no"
            else
                NC_LINT_FILE="$_lint_abs" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/linter.no"
            fi
            ;;

        format)
            # Python-fri formaterer via selfhost/formatter.no
            if [ ! -x "$NC_VM" ] || [ ! -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                # Fallback til Python
                if [ "$PYTHON_FALLBACK" = "1" ]; then
                    exec python3 -m "$LEGACY_ENTRYPOINT" format "$@"
                fi
                printf 'nc format: nc-vm ikkje funnen\n' >&2; exit 1
            fi
            _fmt_src="${1:-}"
            if [ -z "$_fmt_src" ]; then
                printf 'bruk: nc format <kilde.no> [--write] [--check]\n' >&2; exit 2
            fi
            _fmt_write=0; _fmt_check=0
            for _a in "$@"; do
                [ "$_a" = "--write" ] && _fmt_write=1
                [ "$_a" = "--check" ] && _fmt_check=1
            done
            _fmt_src_abs="$(cd "$(dirname "$_fmt_src")" && pwd)/$(basename "$_fmt_src")"
            if [ "$_fmt_write" = "1" ]; then
                NC_FORMAT_FILE="$_fmt_src_abs" NC_FORMAT_WRITE="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
            elif [ "$_fmt_check" = "1" ]; then
                NC_FORMAT_FILE="$_fmt_src_abs" NC_FORMAT_CHECK="1" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
            else
                NC_FORMAT_FILE="$_fmt_src_abs" exec "$NC_VM" --nc-run "$ROOT_DIR/selfhost/formatter.no"
            fi
            ;;

        native-build)
            # Bygg til native ELF via Python-native-pipeline (ingen clang)
            # Delegerer til Python, men denne pipelinen bruker ikke clang
            set -- "$CMD" "$@"
            ;;

        native-run)
            # Bygg og kjør native ELF via Python-native-pipeline (ingen clang)
            set -- "$CMD" "$@"
            ;;

        ci)
            # ci --bootstrap-lane → native selfcheck
            # Andre ci-flagg faller tilbake til Python
            _is_bootstrap_lane=0
            for _a in "$@"; do
                if [ "$_a" = "--bootstrap-lane" ]; then _is_bootstrap_lane=1; fi
            done
            if [ "$_is_bootstrap_lane" = "1" ]; then
                export NORCODE_BOOTSTRAP_VM=1
                export NORCODE_BOOTSTRAP_CLI=1
                export NORCODE_ARGC=1
                export NORCODE_ARG0=selfcheck
                exec "$NATIVE_BIN"
            fi
            set -- "$CMD" "$@"
            ;;

        test)
            # Python-fri testløpar via nc-vm --nc-run
            if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                exec sh "$ROOT_DIR/tools/nc_test.sh" "$@"
            fi
            # Fallback til native binary
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_BOOTSTRAP_CLI=1
            NORCODE_ARGC=$(( $# + 1 ))
            export NORCODE_ARGC
            export NORCODE_ARG0="$CMD"
            _i=1
            for _arg in "$@"; do
                eval "export NORCODE_ARG$_i=\$_arg"
                _i=$(( _i + 1 ))
            done
            exec "$NATIVE_BIN"
            ;;

        selfcheck|identity|release|release-targets|help|--help|-h)
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_BOOTSTRAP_CLI=1
            NORCODE_ARGC=$(( $# + 1 ))
            export NORCODE_ARGC
            export NORCODE_ARG0="$CMD"
            _i=1
            for _arg in "$@"; do
                eval "export NORCODE_ARG$_i=\$_arg"
                _i=$(( _i + 1 ))
            done
            exec "$NATIVE_BIN"
            ;;

        repl)
            # Python-fri REPL via tools/nc_repl.sh
            if [ -x "$NC_VM" ] && [ -f "$ROOT_DIR/bootstrap/kompiler.ncb.json" ]; then
                exec sh "$ROOT_DIR/tools/nc_repl.sh" "$@"
            fi
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: legacy Python-fallback brukes.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" repl "$@"
            fi
            printf 'nc repl: nc-vm ikkje funnen. Køyr: sh tools/bootstrap.sh\n' >&2; exit 1
            ;;

        serve)
            # AVVIKLA: Python-berre. Bruk --legacy-python-fallback for overgangsstøtte.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc serve er avvikla og krev Python-fallback.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" serve "$@"
            fi
            printf 'nc serve: avvikla – krev --legacy-python-fallback.\n' >&2; exit 2
            ;;

        smoke)
            # AVVIKLA: Python-berre smoke-test. Bruk nc test i staden.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc smoke er avvikla og krev Python-fallback.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" smoke "$@"
            fi
            printf 'nc smoke: avvikla – bruk "nc test" eller legg til --legacy-python-fallback.\n' >&2; exit 2
            ;;

        bench)
            # AVVIKLA: Python-berre ytelsesbenchmark.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc bench er avvikla og krev Python-fallback.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" bench "$@"
            fi
            printf 'nc bench: avvikla – krev --legacy-python-fallback.\n' >&2; exit 2
            ;;

        migrate-names)
            # AVVIKLA: Python-berre navnemigrering.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc migrate-names er avvikla og krev Python-fallback.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" migrate-names "$@"
            fi
            printf 'nc migrate-names: avvikla – krev --legacy-python-fallback.\n' >&2; exit 2
            ;;

        diagnose)
            # AVVIKLA: Python-berre diagnosekommando. Bruk nc doctor i staden.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc diagnose er avvikla og krev Python-fallback.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" diagnose "$@"
            fi
            printf 'nc diagnose: avvikla – bruk "nc doctor" eller legg til --legacy-python-fallback.\n' >&2; exit 2
            ;;

        stress|fuzz)
            # AVVIKLA: Python-berre testkommandoar.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc %s er avvikla og krev Python-fallback.\n' "$CMD" >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" "$CMD" "$@"
            fi
            printf 'nc %s: avvikla – krev --legacy-python-fallback.\n' "$CMD" >&2; exit 2
            ;;

        add|update|lock|packages)
            # AVVIKLA: Python-berre pakkehandtering.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc %s er avvikla og krev Python-fallback.\n' "$CMD" >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" "$CMD" "$@"
            fi
            printf 'nc %s: avvikla – krev --legacy-python-fallback.\n' "$CMD" >&2; exit 2
            ;;

        scaffold-api)
            # AVVIKLA: Python-berre API-stillasbygging.
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: nc scaffold-api er avvikla og krev Python-fallback.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" scaffold-api "$@"
            fi
            printf 'nc scaffold-api: avvikla – krev --legacy-python-fallback.\n' >&2; exit 2
            ;;

        *)
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: legacy Python-fallback brukes. Dette er overgangsstøtte, ikke primær Norscode-bane.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" "$CMD" "$@"
            fi
            printf 'Norscode: kommandoen "%s" krever --legacy-python-fallback.\n' "$CMD" >&2
            exit 2
            ;;
    esac
fi

# ─── Python-fallback for native bin manglar eller er ikkje tilgjengeleg ─────
if [ "$PYTHON_FALLBACK" = "1" ]; then
    printf 'Advarsel: legacy Python-fallback brukes. Dette er overgangsstøtte, ikke primær Norscode-bane.\n' >&2
    exec python3 -m "$LEGACY_ENTRYPOINT" "$@"
fi

printf 'Norscode: fant ingen kjørbar kompilator.\n' >&2
printf 'Installer med: bash tools/build-bootstrap-binary.sh\n' >&2
printf 'Forventet native binary: %s\n' "$NATIVE_BIN" >&2
printf 'Bruk --legacy-python-fallback for overgangsstøtte.\n' >&2
exit 1

    sign-macos-app)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc sign-macos-app [APP_PATH] [--identity NAME] [--entitlements FILE] [--verify]\n'
            printf 'Signer lokal macOS app-bundle via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        _macos_sign_app="$ROOT_DIR/build/macos-app/Norscode.app"
        _macos_sign_identity="-"
        _macos_sign_verify="0"
        _macos_sign_entitlements="$ROOT_DIR/tools/macos-app.entitlements"
        _macos_sign_app_set=0
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --identity)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc sign-macos-app [APP_PATH] [--identity NAME] [--entitlements FILE] [--verify]\n' >&2
                        exit 2
                    fi
                    _macos_sign_identity="$2"
                    shift 2
                    ;;
                --entitlements)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc sign-macos-app [APP_PATH] [--identity NAME] [--entitlements FILE] [--verify]\n' >&2
                        exit 2
                    fi
                    _macos_sign_entitlements="$2"
                    shift 2
                    ;;
                --verify)
                    _macos_sign_verify="1"
                    shift
                    ;;
                *)
                    if [ "$_macos_sign_app_set" = "0" ]; then
                        _macos_sign_app="$1"
                        _macos_sign_app_set=1
                        shift
                    else
                        printf 'bruk: nc sign-macos-app [APP_PATH] [--identity NAME] [--entitlements FILE] [--verify]\n' >&2
                        exit 2
                    fi
                    ;;
            esac
        done
        case "$_macos_sign_app" in
            /*) ;;
            *) _macos_sign_app="$ROOT_DIR/$_macos_sign_app" ;;
        esac
        case "$_macos_sign_entitlements" in
            /*) ;;
            *) _macos_sign_entitlements="$ROOT_DIR/$_macos_sign_entitlements" ;;
        esac
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_MACOS_SIGN_APP="$_macos_sign_app" \
            NORSCODE_MACOS_SIGN_IDENTITY="$_macos_sign_identity" \
            NORSCODE_MACOS_SIGN_ENTITLEMENTS="$_macos_sign_entitlements" \
            NORSCODE_MACOS_SIGN_VERIFY="$_macos_sign_verify" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/sign-macos-app.no"
        ;;


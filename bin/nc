        printf '  install-macos-app                Installer lokal macOS app-bundle\n'
        printf '  install-macos-file-icons         Installer macOS filtype-ikoner\n'
        printf '  local-green [--strict] [--list|-l|--help|-h] Køyr eller list lokal grønnliste utan publisering\n'
        printf '  regen-bootstrap [--full]         Regenerer bootstrap-NCB-ar via Norscode\n'
        printf '  active-surface                   Sjekk aktiv C/Python-fri flate og overgangsreferansar\n'
        printf '  surface-ownership                Sjekk .no-eigar og Norscode-first wrapper-markørar\n'
        printf '  phase0-verify                    Fase-0 gate for aktiv selfhost-flate og eigarskap\n'
        printf '  selfhost-drift-guard             Samla selfhost driftsvakt\n'
        printf '  python-audit                     Sjekk Python-fri tools/ og skriv rapport\n'
        printf '  no-legacy-cvm                    Sjekk historisk C-VM/NCBB under tools/\n'
        printf '  selfhost-maintenance-verify      Sjekk selfhost vedlikehaldsdocs-policy\n'
        printf '  selfhost-bootstrap-gate          Bootstrap-gate (steg A+B)\n'
        printf '  bootstrap-self                   Bootstrap steg C (Norscode-VM køyrer Norscode)\n'
        printf '  selfcompile-l5                   L5: kompilator-bundle Gen1==Gen2 (byte-paritet)\n'
        printf '  selfcompile-l5b                  L5b: Gen1-NCB VM køyrer Gen2 (byte-paritet)\n'
        printf '  selfcompile-l5b-mini             L5b-mini: liten byte-paritet via Norscode\n'
        printf '  selvstendighet                   L1-L6 sjølvstendighetsgate utan full testflate\n'
        printf '  feature-check [fil.no ...]       Sjekk nye Norscode-funksjonar utan C/Python\n'
        printf '  verify-omgang6                   Omgang 6: bygg-native ELF-gate\n'
        printf '  selfcompile-native-elf           Omgang 6: ELF byte-paritet (Gen1==Gen2)\n'
        printf '  selfcompile-stage0-elf           Omgang 6b.3: stage-0 ELF sjølvkompilering\n'
        printf '  regen-fraser                     Regenerer fraser-tabell i selfhost/common.no\n'
        printf '  serve <fil.no> [--port <port>]    Start ekte HTTP-server (native Norscode)\n'
        printf '  bygg-native [fil.no] [ut]        Kompiler til native ELF (Omgang 6)\n'
        printf '  bygg-native --ncb ncb.json ut    NCB JSON → native ELF\n'
        printf '  verify-omgang6b                  Omgang 6b: host + kompilator ELF + sjølvkompilering\n'
        printf '  build-omgang6b-ncb [ut]          Bygg Omgang 6b stage-0 NCB\n'
        printf '  stage0-release-assets [--platform <namn>] [--out-dir <mappe>]  Bygg stage-0 release-artefaktar\n'
        printf '  verify-seed                      Verifiser committed stage-0 seed utan C/Python\n'
        printf '  fetch-stage0-seed                Last ned ferdig native seed frå release\n'
        printf '  startproject <mappe>             Opprett ny Norscode-prosjekt etter standardmal\n'
        printf '  scaffold-api [nå avvikla]        Alias for startproject\n'
        printf '  startapp <app_namn>              Opprett app-modul i prosjektet\n'
        printf '  ci                               CI-gate\n'
        printf '\n'
        printf 'Miljø:\n'
        printf '  NORSCODE_VM_TRACE=1              Vis VM-kallspor for import-bundla run\n'
        printf '  --version                        Vis versjon\n'
        exit 0
        ;;

    migrate)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc migrate <fil.no> [db-fil] [kommando]\n'
            printf 'Køyr migrering frå Norscode-fil mot valt database.\n'
            exit 0
        fi
        _require_native
        _mig_file="${1:-app.no}"
        _mig_db="${2:-app.db}"
        _mig_cmd="${3:-køyr}"
        if [ ! -f "$_mig_file" ]; then
            printf 'nc migrate: finn ikkje fil %s\n' "$_mig_file" >&2
            printf 'bruk: nc migrate <fil.no> [db-fil] [kommando]\n' >&2
            exit 2
        fi
        exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$_mig_file" NORSCODE_ROOT="$ROOT_DIR" \
            NC_MIGRATE_DB="$_mig_db" NC_MIGRATE_CMD="$_mig_cmd" "$NC_NATIVE"
        ;;

    startproject)
        _project_dir=""
        _output_dir=""
        _project_name=""
        _db_file="app.db"
        _with_auth="usann"
        _with_admin="usann"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --name)
                    shift
                    [ "$#" -gt 0 ] || { printf 'bruk: nc startproject <målmappe> [--name <prosjektnamn>] [--path <sti>] [--db <db-fil>]\n' >&2; exit 2; }
                    _project_name="$1"
                    ;;
                --path)
                    shift
                    [ "$#" -gt 0 ] || { printf 'bruk: nc startproject <målmappe> [--name <prosjektnamn>] [--path <sti>] [--db <db-fil>]\n' >&2; exit 2; }
                    _output_dir="$1"
                    ;;
                --db)
                    shift
                    [ "$#" -gt 0 ] || { printf 'bruk: nc startproject <målmappe> [--name <prosjektnamn>] [--path <sti>] [--db <db-fil>]\n' >&2; exit 2; }
                    _db_file="$1"
                    ;;
                --with-auth)
                    _with_auth="sann"
                    ;;
                --without-auth)
                    _with_auth="usann"
                    ;;
                --with-admin)
                    _with_admin="sann"
                    ;;
                --without-admin)
                    _with_admin="usann"
                    ;;
                --help|-h)
                    printf 'bruk: nc startproject <målmappe> [--name <prosjektnamn>] [--path <sti>] [--db <db-fil>]\n'
                    printf 'Opprett ny Norscode-prosjekt etter standardmal.\n'
                    exit 0
                    ;;
                --*)
                    printf 'ukjend flagg: %s\n' "$1" >&2
                    exit 2
                    ;;
                *)
                    if [ -z "$_project_dir" ]; then
                        _project_dir="$1"
                    elif [ -z "$_project_name" ]; then
                        _project_name="$1"
                    else
                        printf 'for mange argument: %s\n' "$1" >&2
                        exit 2
                    fi
                    ;;
            esac
            shift
        done
        [ -n "$_project_dir" ] || { printf 'bruk: nc startproject <målmappe> [--name <prosjektnamn>] [--path <sti>] [--db <db-fil>]\n' >&2; exit 2; }
        [ -n "$_output_dir" ] || _output_dir="$_project_dir"
        [ -n "$_project_name" ] || _project_name="$(basename "$_project_dir")"
        _nc_startproject_out="$(mktemp "${TMPDIR:-/tmp}/norscode_startproject.XXXXXX")"
        if env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_STARTPROJECT_DIR="$_project_dir" \
            NORSCODE_STARTPROJECT_OUTPUT_DIR="$_output_dir" \
            NORSCODE_STARTPROJECT_NAME="$_project_name" \
            NORSCODE_STARTPROJECT_DB="$_db_file" \
            NORSCODE_STARTPROJECT_WITH_AUTH="$_with_auth" \
            NORSCODE_STARTPROJECT_WITH_ADMIN="$_with_admin" \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/tools/startproject.no" \
            "$NC_NATIVE" >"$_nc_startproject_out" 2>&1; then
            _nc_print_file "$_nc_startproject_out"
            rm -f "$_nc_startproject_out"
            exit 0
        fi
        if _nc_has_exec_prosess_gap "$_nc_startproject_out"; then
            rm -f "$_nc_startproject_out"
            _auth_flag="--without-auth"
            [ "$_with_auth" = "sann" ] && _auth_flag="--with-auth"
            _admin_flag="--without-admin"
            [ "$_with_admin" = "sann" ] && _admin_flag="--with-admin"
            sh "$ROOT_DIR/tools/startproject.sh" "$_project_dir" --name "$_project_name" --path "$_output_dir" --db "$_db_file" "$_auth_flag" "$_admin_flag"
            exit $?
        fi
        _nc_print_file_err "$_nc_startproject_out"
        rm -f "$_nc_startproject_out"
        exit 1
        ;;

    scaffold-api)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc scaffold-api <målmappe> [startproject-val]\n'
            printf 'Avvikla alias: bruk nc startproject for nye prosjekt.\n'
            exit 0
        fi
        printf 'Scaffold-api er bytt til startproject. Køyr: nc startproject ...\n'
        exec "$0" startproject "$@"
        ;;

    startapp)
        _project_root="."
        _app_name=""
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --path)
                    shift
                    [ "$#" -gt 0 ] || { printf 'bruk: nc startapp <app_namn> [--path <prosjektrot>]\n' >&2; exit 2; }
                    _project_root="$1"
                    ;;
                --help|-h)
                    printf 'bruk: nc startapp <app_namn> [--path <prosjektrot>]\n'
                    printf 'Opprett app-modul i prosjektet.\n'
                    exit 0
                    ;;
                --*)
                    printf 'ukjend flagg: %s\n' "$1" >&2
                    exit 2
                    ;;
                *)
                    if [ -z "$_app_name" ]; then
                        _app_name="$1"
                    else
                        printf 'for mange argument: %s\n' "$1" >&2
                        exit 2
                    fi
                    ;;
            esac
            shift
        done
        [ -n "$_app_name" ] || { printf 'bruk: nc startapp <app_namn> [--path <prosjektrot>]\n' >&2; exit 2; }
        _nc_startapp_out="$(mktemp "${TMPDIR:-/tmp}/norscode_startapp.XXXXXX")"
        if env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_STARTAPP_NAME="$_app_name" \
            NORSCODE_STARTAPP_PROJECT_ROOT="$_project_root" \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/tools/startapp.no" \
            "$NC_NATIVE" >"$_nc_startapp_out" 2>&1; then
            _nc_print_file "$_nc_startapp_out"
            rm -f "$_nc_startapp_out"
            exit 0
        fi
        if _nc_has_exec_prosess_gap "$_nc_startapp_out"; then
            rm -f "$_nc_startapp_out"
            sh "$ROOT_DIR/tools/startapp.sh" --from-no "$_app_name" --path "$_project_root"
            exit $?
        fi
        _nc_print_file_err "$_nc_startapp_out"
        rm -f "$_nc_startapp_out"
        exit 1
        ;;

    serve)
        _file="${1:-app.no}"
        _port="${NORSCODE_PORT:-8000}"
        _workers="${NORSCODE_WORKERS:-4}"
        _host="${NORSCODE_HOST:-127.0.0.1}"
        _bind_host="${NC_SERVE_BIND_HOST:-127.0.0.1}"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --port|-p)
                    shift
                    if [ -z "${1:-}" ]; then
                        printf 'bruk: nc serve <kilde.no> [--port <port>] [--workers <n>]\n' >&2
                        exit 2
                    fi
                    _port="$1"
                    ;;
                --workers|-w)
                    shift
                    _workers="${1:-4}"
                    ;;
                --host|-H)
                    shift
                    _host="${1:-127.0.0.1}"
                    ;;
                --help|-h)
                    printf 'bruk: nc serve <kilde.no> [--port <port>] [--workers <n>] [--host <host>]\n'
                    printf '\nValg:\n'
                    printf '  --port, -p       Port å lytta på (standard: 8000)\n'
                    printf '  --workers, -w    Antal arbeidertrådar (standard: 4)\n'
                    printf '  --host, -H       Host å binda til (standard: 127.0.0.1)\n'
                    exit 0
                    ;;
                --*)
                    printf 'ukjend serve-opsjon: %s\n' "$1" >&2
                    exit 2
                    ;;
                *)
                    _file="$1"
                    ;;
            esac
            shift
        done

        if [ ! -f "$_file" ]; then
            printf 'nc serve: finn ikkje fil %s\n' "$_file" >&2
            printf 'bruk: nc serve <kilde.no> [--port <port>] [--workers <n>] [--host <host>]\n' >&2
            exit 2
        fi
        case "$_file" in
            /*) : ;;
            *) _file="$(pwd)/$_file" ;;
        esac

        # Køyr serve frå prosjektrota slik at std/selfhost-importar blir løyste stabilt,
        # men bevar kjeldemappa som app-workdir for lokale filer og relative ressursar.
        _require_native
        _source_dir="$(dirname "$_file")"
        _project_root="$(_find_project_root "$_source_dir")"
        cd "$_project_root"
        exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/serve_runner.no" \
            NC_SERVE_FILE="$_file" NORSCODE_ROOT="$ROOT_DIR" \
            NC_SERVE_SOURCE_DIR="$_source_dir" \
            NC_SERVE_WORKDIR="$_source_dir" \
            PWD="$_project_root" \
            NC_SERVE_PORT="$_port" \
            NORSCODE_WORKERS="$_workers" \
            NC_SERVE_HOST="$_host" \
            NC_SERVE_BIND_HOST="$_bind_host" \
            NORSCODE_IMPORT_BASE="$_project_root" \
            "$NC_NATIVE"
        ;;

    pakke|pkg)
        _subcmd="${1:-help}"
        shift || true
        case "$_subcmd" in
            installer|install|i)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke installer <pakkenamn> [versjon]\n'
                    printf 'Installer ein pakke, eller alle frå pakke.json når pakkenamn manglar.\n'
                    exit 0
                fi
                _pakke="${1:-}"
                _versjon="${2:-*}"
                if [ -z "$_pakke" ]; then
                    # Installer alle frå pakke.json
                    if [ -f "pakke.json" ]; then
                        printf '[pakke] Installerer avhengigheiter frå pakke.json …\n'
                        _require_native
                        exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_install_alle NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
                    else
                        printf 'bruk: nc pakke installer <pakkenamn> [versjon]\n' >&2
                        exit 2
                    fi
                fi
                printf '[pakke] Installerer %s@%s …\n' "$_pakke" "$_versjon"
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_installer NORSCODE_ROOT="$ROOT_DIR" NORSCODE_PAKKE="$_pakke" NORSCODE_VERSJON="$_versjon" "$NC_NATIVE"
                ;;
            publiser|publish)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke publiser\n'
                    printf 'Publiser pakke.json til pakkeregisteret.\n'
                    exit 0
                fi
                _api_key="${NC_API_NOKKEL:-${NC_API_KEY:-}}"
                _api_key_alias="$(printenv 'NC_API_NØKKEL' 2>/dev/null || true)"
                if [ -z "$_api_key" ] && [ -n "$_api_key_alias" ]; then
                    _api_key="$_api_key_alias"
                fi
                if [ -z "$_api_key" ]; then
                    printf 'feil: set NC_API_NØKKEL som miljøvariabel.\n' >&2
                    exit 2
                fi
                if [ ! -f "pakke.json" ]; then
                    printf 'feil: pakke.json ikkje funnen.\n' >&2
                    exit 2
                fi
                printf '[pakke] Publiserer …\n'
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_publiser NORSCODE_ROOT="$ROOT_DIR" NORSCODE_API_NØKKEL="$_api_key" "$NC_NATIVE"
                ;;
            søk|search|s)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke søk <spørjing>\n'
                    printf 'Søk i pakkeregisteret.\n'
                    exit 0
                fi
                _sporring="${1:-}"
                if [ -z "$_sporring" ]; then
                    printf 'bruk: nc pakke søk <spørjing>\n' >&2
                    exit 2
                fi
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_søk NORSCODE_ROOT="$ROOT_DIR" NORSCODE_SØKORD="$_sporring" "$NC_NATIVE"
                ;;
            info)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke info <pakkenamn>\n'
                    printf 'Vis informasjon om ein pakke.\n'
                    exit 0
                fi
                _pakke="${1:-}"
                if [ -z "$_pakke" ]; then
                    printf 'bruk: nc pakke info <pakkenamn>\n' >&2
                    exit 2
                fi
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_info NORSCODE_ROOT="$ROOT_DIR" NORSCODE_PAKKE="$_pakke" "$NC_NATIVE"
                ;;
            lista|list|ls)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke lista\n'
                    printf 'List installerte pakkar.\n'
                    exit 0
                fi
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_lista NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
                ;;
            utdatert|outdated)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke utdatert\n'
                    printf 'Vis utdaterte pakkar.\n'
                    exit 0
                fi
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_utdatert NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
                ;;
            init)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke init [namn]\n'
                    printf 'Opprett pakke.json i gjeldande mappe.\n'
                    exit 0
                fi
                _namn="${1:-$(basename "$PWD")}"
                printf '{"namn":"%s","versjon":"0.1.0","beskriving":"","forfattar":"","lisens":"MIT","avhengigheiter":{},"hovud":"main.no"}\n' "$_namn" > pakke.json
                printf '[pakke] Oppretta pakke.json for %s\n' "$_namn"
                ;;
            versjon|bump)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke versjon <major|minor|patch>\n'
                    printf 'Auk versjonsnummeret i pakke.json.\n'
                    exit 0
                fi
                _type="${1:-patch}"
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_bump_versjon NORSCODE_ROOT="$ROOT_DIR" NORSCODE_BUMP_TYPE="$_type" "$NC_NATIVE"
                ;;
            register|registry)
                if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
                    printf 'bruk: nc pakke register [--port <port>] [--mappe <mappe>] [--token <token>]\n'
                    printf 'Start eller konfigurer pakkeregister når eigen server finst.\n'
                    exit 0
                fi
                _reg_port="${NC_REGISTER_PORT:-5173}"
                _reg_mappe="${NC_PAKKAR_MAPPE:-nc_pakkar}"
                _reg_token="${NC_API_NOKKEL:-${NC_API_KEY:-}}"
                _reg_token_alias="$(printenv 'NC_API_NØKKEL' 2>/dev/null || true)"
                if [ -z "$_reg_token" ] && [ -n "$_reg_token_alias" ]; then
                    _reg_token="$_reg_token_alias"
                fi
                while [ "$#" -gt 0 ]; do
                    case "$1" in
                        --port)  shift; _reg_port="${1:-5173}" ;;
                        --mappe) shift; _reg_mappe="${1:-nc_pakkar}" ;;
                        --token) shift; _reg_token="${1:-}" ;;
                    esac
                    shift
                done
                printf 'feil: nc pakke register krev eigen server-implementasjon\n' >&2; exit 1
                ;;
            lock)
                _require_native
                exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=pakke_lock NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
                ;;
            help|--help|-h|*)
                printf 'Bruk: nc pakke <kommando>\n\n'
                printf 'Kommandoar:\n'
                printf '  installer [pakke] [versjon]  Installer pakke eller alle avhengigheiter\n'
                printf '  publiser                     Publiser pakke til registeret\n'
                printf '  søk <spørjing>               Søk i pakkeregisteret\n'
                printf '  info <pakke>                 Vis pakkeinfo\n'
                printf '  lista                        List installerte pakkar\n'
                printf '  utdatert                     Vis utdaterte pakkar\n'
                printf '  init [namn]                  Opprett pakke.json\n'
                printf '  versjon <major|minor|patch>  Auk versjonsnummer\n'
                ;;
        esac
        ;;

    smoke|bench|migrate-names|diagnose|stress|fuzz|add|update|lock|packages|native-build|native-run)
        printf 'nc %s: avvikla og fjerna.\n' "$CMD" >&2
        exit 2
        ;;

    *)
        printf 'Norscode: ukjend kommando "%s". Køyr: nc help\n' "$CMD" >&2
        exit 2
        ;;
esac

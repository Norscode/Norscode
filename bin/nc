    test)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc test [fil.no ...]\n'
            printf 'Køyr Norscode-testar lokalt.\n'
            exit 0
        fi
        _require_nc_vm
        _nc_direct_test_file="${NC_TEST_FILE:-}"
        if [ "$#" -ge 1 ] && [ "${1:-}" != "--no-color" ] && [ -f "${1:-}" ]; then
            _nc_direct_test_file="$1"
        fi
        exec env \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/tools/nc_test.no" \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,process.exec,thread.spawn,net.tcp,disk.read,disk.write}" \
            NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" \
            NORSCODE_ROOT="$ROOT_DIR" \
            NC_NATIVE="$NC_NATIVE" \
            NC_TEST_FILE="$_nc_direct_test_file" \
            NC_TEST_FILES="${NC_TEST_FILES:-}" \
            NC_TEST_SHARD="${NC_TEST_SHARD:-}" \
            NC_TEST_SHARDS="${NC_TEST_SHARDS:-}" \
            "$NC_NATIVE"
        _nc_test_runner_rc=$?
        if [ "$_nc_test_runner_rc" -ne 0 ] && [ "${NORSCODE_PACKAGED_TEST_FALLBACK:-0}" = "1" ] && [ -n "$_nc_direct_test_file" ]; then
            env NORSCODE_CMD=run NORSCODE_FILE="$_nc_direct_test_file" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            exit $?
        fi
        exit "$_nc_test_runner_rc"
        # The compatibility path below is kept as a textual contract for older
        # stage-0 wrappers; the Norscode-owned runner above is authoritative.
        _nc_test_file="${NC_TEST_FILE:-}"
        if [ "$#" -ge 1 ] && [ "${1:-}" != "--no-color" ] && [ -f "${1:-}" ]; then
            _nc_test_file="$1"
        fi
        _nc_test_files="${NC_TEST_FILES:-}"
        if [ -z "$_nc_test_file" ] && [ -z "$_nc_test_files" ]; then
            _nc_test_files="$(find "${TESTS_DIR:-$ROOT_DIR/tests}" -maxdepth 1 -type f -name 'test_*.no' || true)"
        fi
        _nc_test_verbose="${NC_VERBOSE:-0}"
        if [ "${NC_CI:-0}" = "1" ] && [ "$_nc_test_verbose" = "0" ]; then
            _nc_test_verbose=1
        fi
        _nc_test_out="$(mktemp "${TMPDIR:-/tmp}/norscode_nc_test.XXXXXX")"
        _nc_test_rc=0
        env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NC_NATIVE="$NC_NATIVE" \
            NC_NATIVE_OK=1 \
            HYBRID_COMPILE="${HYBRID_COMPILE:-$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh}" \
            TESTS_DIR="${TESTS_DIR:-$ROOT_DIR/tests}" \
            NC_TEST_TMPDIR="${NC_TEST_TMPDIR:-$ROOT_DIR/build/nc-test-tmp}" \
            NC_TEST_FILE="$_nc_test_file" \
            NC_TEST_FILES="$_nc_test_files" \
            NC_TEST_SHARD="${NC_TEST_SHARD:-}" \
            NC_TEST_SHARDS="${NC_TEST_SHARDS:-}" \
            NC_VERBOSE="$_nc_test_verbose" \
            NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,process.exec,thread.spawn,net.tcp,disk.read,disk.write}" \
            NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/nc_test.no" >"$_nc_test_out" 2>&1 || _nc_test_rc=$?
        if [ "$_nc_test_rc" -eq 0 ]; then
            _nc_print_file "$_nc_test_out"
            rm -f "$_nc_test_out"
            exit 0
        fi
        rm -f "$_nc_test_out"
        env -u NORSCODE_NATIVE_BIN NC_NATIVE="$NC_NATIVE" sh "$ROOT_DIR/tools/nc_test.sh" "$@"
        exit $?
        ;;


#!/usr/bin/env sh
# bin/nc - Norscode CLI (native)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC_TMP_ROOT="${TMPDIR:-/tmp}"
NC_TMP_ROOT="${NC_TMP_ROOT%/}"
NC_NATIVE="${NORSCODE_NATIVE_BIN:-${NC_NATIVE:-$ROOT_DIR/dist/norscode_native}}"
HYBRID_COMPILE="$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.no"
# Windows (Git Bash / MSYS2 / Cygwin): bruk .exe-suffiks
case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*)
        case "$NC_NATIVE" in
            *.exe) ;;
            *) NC_NATIVE="${NC_NATIVE}.exe" ;;
        esac
        ;;
esac

if [ -z "${NORSCODE_NATIVE_BIN:-}" ] && [ ! -x "$NC_NATIVE" ]; then
    case "$(uname -s 2>/dev/null):$(uname -m 2>/dev/null)" in
        Darwin:arm64) _nc_stage0="$ROOT_DIR/bootstrap/stage0/norscode-macos-arm64" ;;
        Darwin:x86_64) _nc_stage0="$ROOT_DIR/bootstrap/stage0/norscode-macos-x86_64" ;;
        Linux:x86_64) _nc_stage0="$ROOT_DIR/bootstrap/stage0/norscode-linux-x86_64" ;;
        Linux:aarch64|Linux:arm64) _nc_stage0="$ROOT_DIR/bootstrap/stage0/norscode-linux-arm64" ;;
        *) _nc_stage0="" ;;
    esac
    if [ -n "$_nc_stage0" ] && [ -x "$_nc_stage0" ]; then
        NC_NATIVE="$_nc_stage0"
    fi
fi

_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        while IFS= read -r _line || [ -n "$_line" ]; do
            case "$_line" in
                version*=*)
                    _value=${_line#*=}
                    set -f
                    set -- $_value
                    set +f
                    _value="${1:-}"
                    _value=${_value#\"}
                    _value=${_value%\"}
                    if [ -n "$_value" ]; then
                        printf '%s\n' "$_value"
                        return 0
                    fi
                    ;;
            esac
        done < "$_toml"
    fi
    printf 'ukjent'
}

_require_native() {
    if [ ! -x "$NC_NATIVE" ]; then
        printf 'nc: norscode_native ikkje funnen. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2
        exit 1
    fi
}
# Bakoverkompatibelt alias
_require_nc_vm() { _require_native; }

_nc_print_file() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        printf '%s\n' "$_line"
    done < "$_file"
}

_nc_print_file_err() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        printf '%s\n' "$_line" >&2
    done < "$_file"
}

_nc_file_contains() {
    _file="$1"
    _needle="$2"
    while IFS= read -r _line || [ -n "$_line" ]; do
        case "$_line" in
            *"$_needle"*) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_nc_has_import_line() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        set -f
        set -- $_line
        set +f
        case "${1:-}" in
            bruk|importer) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_nc_has_selfhost_import() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        set -f
        set -- $_line
        set +f
        case "${1:-}:${2:-}" in
            bruk:selfhost.*|importer:selfhost.*) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_nc_has_exec_prosess_gap() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        case "$_line" in
            *"Ukjent funksjon: exec_prosess"*|*"Ukjent funksjon: builtin.exec_prosess"*|*"Ukjent funksjon: builtin.builtin.exec_prosess"*|*"manglar exec_prosess"*) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_find_project_root() {
    _start_dir="$1"
    _dir="$_start_dir"
    while [ -n "$_dir" ] && [ "$_dir" != "/" ]; do
        if [ -f "$_dir/norcode.toml" ]; then
            printf '%s\n' "$_dir"
            return 0
        fi
        _parent="$(dirname "$_dir")"
        if [ "$_parent" = "$_dir" ]; then
            break
        fi
        _dir="$_parent"
    done
    printf '%s\n' "$ROOT_DIR"
}

_hybrid_compile() {
    _hy_src="$1"
    _hy_out="$2"
    _hy_mod="${3:-__main__}"
    _hy_project_root="${4:-$ROOT_DIR}"
    env \
        NORSCODE_CMD=run \
        NORSCODE_FILE="$HYBRID_COMPILE" \
        NORSCODE_ENABLE_EXEC_PROSESS=1 \
        NORSCODE_HYBRID_ROOT="$ROOT_DIR" \
        NORSCODE_HYBRID_SRC="$_hy_src" \
        NORSCODE_HYBRID_OUT="$_hy_out" \
        NORSCODE_HYBRID_MODULE="$_hy_mod" \
        NORSCODE_HYBRID_PROJECT_ROOT="$_hy_project_root" \
        NORSCODE_ROOT="$ROOT_DIR" \
        NORSCODE_NATIVE_BIN="$NC_NATIVE" \
        NORSCODE_NATIVE_MAX_DEPTH="${NORSCODE_NATIVE_MAX_DEPTH:-4096}" \
        NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" \
        NORSCODE_VM_DISK_ROOT="$ROOT_DIR,$NC_TMP_ROOT,/tmp,/private/tmp" \
        "$NC_NATIVE"
}

if [ $# -eq 0 ]; then
    printf 'Norscode %s  —  køyr: nc help\n' "$(_nc_version)"
    exit 0
fi

CMD="$1"; shift

case "$CMD" in

	    run)
	        SRC="${1:-app.no}"
	        if [ -x "$NC_NATIVE" ]; then
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _run_src_dir="$(CDPATH= cd -- "$(dirname "$SRC")" 2>/dev/null && pwd || pwd)"
	                _run_project_root="$(_find_project_root "$_run_src_dir")"
	                _run_ncb="${TMPDIR:-/tmp}/nc_run_${$}.ncb.json"
	                _hybrid_compile "$SRC" "$_run_ncb" "__main__" "$_run_project_root" >/dev/null
                cd "$ROOT_DIR" || exit 1
                _run_out="${TMPDIR:-/tmp}/nc_run_${$}.out"
                _run_rc=0
                env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" NORSCODE_NCB_FILE="$_run_ncb" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_PROJECT_ROOT="$_run_project_root" NORSCODE_IMPORT_BASE="$_run_project_root" NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,process.exec,disk.read,disk.write,net.tcp,net.dns}" "$NC_NATIVE" >"$_run_out" 2>&1 || _run_rc=$?
                if [ "${NORSCODE_DISABLE_MAPPE_FALLBACK:-0}" != "1" ] && grep -q 'Ukjent funksjon: builtin\.mappe_opprett' "$_run_out"; then
                    _pure_target_ncb="${TMPDIR:-/tmp}/nc_run_mappe_fallback_${$}.ncb.json"
                    cp "$_run_ncb" "$_pure_target_ncb"
                    rm -f "$_run_out" "$_run_ncb"
                    _fallback_rc=0
                    env NORSCODE_PURE_NCB_FILE="$_pure_target_ncb" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/selfhost/tooling/ncb_pure_run_entry.no" || _fallback_rc=$?
                    rm -f "$_pure_target_ncb"
                    exit "$_fallback_rc"
                fi
                if [ "$_run_rc" -eq 0 ]; then
                    cat "$_run_out"
                    rm -f "$_run_out" "$_run_ncb"
                    exit 0
                fi
                cat "$_run_out"
                rm -f "$_run_out" "$_run_ncb"
                exit "$_run_rc"
            fi
            cd "$ROOT_DIR" || exit 1
            exec env NORSCODE_CMD=run NORSCODE_FILE="$SRC" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
        ;;

	    run-ncb)
	        NCB_FILE="${1:-}"
	        if [ -z "$NCB_FILE" ]; then
	            printf 'bruk: nc run-ncb <fil.ncb.json>\n' >&2; exit 2
	        fi
	        if [ -x "$NC_NATIVE" ]; then
	            cd "$ROOT_DIR" || exit 1
	            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" NORSCODE_NCB_FILE="$NCB_FILE" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
	        fi
	        printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
	        ;;
	    run-pure)
	        SRC="${1:-app.no}"
	        if [ -x "$NC_NATIVE" ]; then
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _run_ncb="${TMPDIR:-/tmp}/nc_run_pure_${$}.ncb.json"
	                _hybrid_compile "$SRC" "$_run_ncb" "__main__" "$ROOT_DIR" >/dev/null
	                _pure_cache_dir="$ROOT_DIR/build/runtime-cache"
	                _pure_runner="$_pure_cache_dir/ncb_pure_run_entry.ncb.json"
	                if [ ! -f "$_pure_runner" ] || \
	                   [ "$ROOT_DIR/selfhost/tooling/ncb_pure_run_entry.no" -nt "$_pure_runner" ] || \
	                   [ "$ROOT_DIR/selfhost/vm.no" -nt "$_pure_runner" ] || \
	                   [ "$HYBRID_COMPILE" -nt "$_pure_runner" ]; then
	                    mkdir -p "$_pure_cache_dir"
	                    _pure_runner_tmp="$_pure_runner.${$}.tmp"
	                    _hybrid_compile "$ROOT_DIR/selfhost/tooling/ncb_pure_run_entry.no" "$_pure_runner_tmp" "__main__" "$ROOT_DIR" >/dev/null
	                    mv "$_pure_runner_tmp" "$_pure_runner"
	                fi
	                _pure_rc=0
	                env NORSCODE_PURE_NCB_FILE="$_run_ncb" \
	                    NORSCODE_NCB_FILE="$_pure_runner" \
	                    NORSCODE_ROOT="$ROOT_DIR" \
	                    NORSCODE_CMD=run \
	                    NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" \
	                    "$NC_NATIVE" || _pure_rc=$?
	                rm -f "$_run_ncb"
	                exit "$_pure_rc"
	            fi
	            printf 'nc: run-pure krev hybrid compile-sti\n' >&2; exit 1
	        fi
	        printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
	        ;;

	    run-ncb-pure)
	        NCB_FILE="${1:-}"
	        if [ -z "$NCB_FILE" ]; then
	            printf 'bruk: nc run-ncb-pure <fil.ncb.json>\n' >&2; exit 2
	        fi
	        if [ -x "$NC_NATIVE" ]; then
	            exec env NORSCODE_PURE_NCB_FILE="$NCB_FILE" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/selfhost/tooling/ncb_pure_run_entry.no"
	        fi
	        printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
	        ;;
		    compile)
        SRC="${1:-}"
        OUT="${2:-}"
        case "$SRC" in
            --help|-h)
                printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n'
                printf 'Kompiler Norscode-fil til bytekode.\n'
                exit 0
                ;;
        esac
        if [ -z "$SRC" ]; then
            printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2; exit 2
        fi
	        if [ -x "$NC_NATIVE" ]; then
	            if [ -f "$HYBRID_COMPILE" ]; then
	                if [ -n "$OUT" ]; then
	                    _hybrid_compile "$SRC" "$OUT" "__main__" "$ROOT_DIR"
	                    exit $?
	                else
	                    _default_out="${SRC%.no}.ncb.json"
	                    _hybrid_compile "$SRC" "$_default_out" "__main__" "$ROOT_DIR"
	                    exit $?
	                fi
	            fi
            if [ -n "$OUT" ]; then
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_compile_entry.no" NORSCODE_TARGET_FILE="$SRC" NORSCODE_TARGET_OUTPUT="$OUT" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            else
                exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_compile_entry.no" NORSCODE_TARGET_FILE="$SRC" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            fi
        fi
        printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
        ;;

	    build)
        SRC="${1:-}"
        OUT="${2:-}"
        case "$SRC" in
            --help|-h)
                printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n'
                printf 'Kompiler Norscode-fil til NCB-bytecode.\n'
                exit 0
                ;;
        esac
        if [ -z "$SRC" ] || [ -z "$OUT" ]; then
            printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n' >&2; exit 2
        fi
	        if [ -x "$NC_NATIVE" ]; then
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _hybrid_compile "$SRC" "$OUT" "__main__" "$ROOT_DIR"
	                exit $?
	            fi
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_compile_entry.no" NORSCODE_TARGET_FILE="$SRC" NORSCODE_TARGET_OUTPUT="$OUT" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
        ;;

    bygg)
        # nc bygg [--mål elf64] <kilde.no> [utdata]
        case "${1:-}" in
            --help|-h)
                printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n'
                printf 'Bygg Norscode med mål/native val.\n'
                exit 0
                ;;
        esac
        _maal="ncb"
        _src=""
        _out=""
        _next_is_maal=0
        for _ba in "$@"; do
            if [ "$_next_is_maal" = "1" ]; then
                _maal="$_ba"; _next_is_maal=0; continue
            fi
            case "$_ba" in
                --mål) _next_is_maal=1 ;;
                elf64|elf) _maal="elf64" ;;
                kernel|kernel32) _maal="kernel" ;;
                *.no) _src="$_ba" ;;
                *) _out="$_ba" ;;
            esac
        done
        if [ -z "$_src" ] && [ "$_maal" != "kernel" ] && [ "$_maal" != "kernel32" ]; then
            printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n' >&2; exit 2
        fi
        if [ -n "$_src" ] && [ ! -f "$_src" ]; then
            printf 'nc bygg: finn ikkje fil %s\n' "$_src" >&2
            printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n' >&2
            exit 2
        fi
        _require_native
        if [ "$_maal" = "native" ] || [ "$_maal" = "native64" ]; then
            if [ -z "$_src" ]; then
                printf 'bruk: nc bygg --mål native <kilde.no> [utdata]\n' >&2; exit 2
            fi
            if [ -z "$_out" ]; then _out="${_src%.no}"; fi
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _hybrid_compile "$_src" "$_tmpncb" "__main__" "$ROOT_DIR" >/dev/null
            else
                env NORSCODE_CMD=compile NORSCODE_FILE="$_src" "$NC_NATIVE" > "$_tmpncb"
            fi
            NC_INPUT="$_tmpncb" NC_OUTPUT="$_out" \
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/native_codegen.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            rm -f "$_tmpncb"
            chmod +x "$_out" 2>/dev/null || true
        elif [ "$_maal" = "kernel" ] || [ "$_maal" = "kernel32" ]; then
            if [ -z "$_out" ]; then _out="build/norscode_kernel.elf"; fi
            mkdir -p "$(dirname "$_out")"
            NC_OUTPUT="$_out" \
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/kernel_builder.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        elif [ "$_maal" = "elf64" ]; then
            if [ -z "$_out" ]; then _out="${_src%.no}"; fi
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _hybrid_compile "$_src" "$_tmpncb" "__main__" "$ROOT_DIR" >/dev/null
            else
                env NORSCODE_CMD=compile NORSCODE_FILE="$_src" "$NC_NATIVE" > "$_tmpncb"
            fi
            NC_INPUT="$_tmpncb" NC_OUTPUT="$_out" \
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/ncb_to_elf.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            rm -f "$_tmpncb"
            chmod +x "$_out" 2>/dev/null || true
            printf 'bygg: %s → %s (ELF64 x86-64)\n' "$_src" "$_out"
        else
            if [ -z "$_out" ]; then _out="${_src%.no}.ncb.json"; fi
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _hybrid_compile "$_src" "$_out" "__main__" "$ROOT_DIR" >/dev/null
            else
                env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_compile_entry.no" NORSCODE_TARGET_FILE="$_src" NORSCODE_TARGET_OUTPUT="$_out" "$NC_NATIVE" >/dev/null
            fi
            printf 'bygg: %s → %s (NCB)\n' "$_src" "$_out"
        fi
        ;;

    check)
        SRC="${1:-}"
        case "$SRC" in
            --help|-h)
                printf 'bruk: nc check <kilde.no>\n'
                printf 'Sjekk syntaks/semantikk utan å skrive artefakt.\n'
                exit 0
                ;;
        esac
        if [ -z "$SRC" ]; then
            printf 'bruk: nc check <kilde.no>\n' >&2; exit 2
        fi
        if [ ! -f "$SRC" ]; then
            printf 'feil: finn ikkje fil %s\n' "$SRC" >&2
            exit 2
        fi
        case "$SRC" in
            /*) : ;;
            *) SRC="$(pwd)/$SRC" ;;
        esac
        _check_source_dir="$(dirname "$SRC")"
        _check_project_root="$(_find_project_root "$_check_source_dir")"
        _tmpdir="$(mktemp -d)"
        _rc=0
        if [ -x "$NC_NATIVE" ]; then
	            if [ -f "$HYBRID_COMPILE" ]; then
	                _hybrid_compile "$SRC" "$_tmpdir/_check.ncb.json" "__main__" "$_check_project_root" >/dev/null && printf '%s: OK\n' "$SRC" || _rc=$?
            else
                env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_compile_entry.no" NORSCODE_TARGET_FILE="$SRC" NORSCODE_TARGET_OUTPUT="$_tmpdir/_check.ncb.json" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_IMPORT_BASE="$_check_project_root" PWD="$_check_project_root"                     "$NC_NATIVE" >/dev/null && printf '%s: OK\n' "$SRC" || _rc=$?
            fi
        else
            printf 'nc: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
        fi
        rm -rf "$_tmpdir"
        exit "$_rc"
        ;;

    bundle)
        _bundle_out="bootstrap/kompiler.ncb.json"
        _bundle_specs=""
        _skip=0
        for _barg in "$@"; do
            if [ "$_barg" = "--output" ]; then _skip=1; continue; fi
            if [ "$_skip" = "1" ]; then _bundle_out="$_barg"; _skip=0; continue; fi
            _bundle_specs="${_bundle_specs:+$_bundle_specs
}$_barg"
        done
        _bundle_entry="${NORSCODE_BUNDLE_ENTRY:-__main__.start}"
        _bundle_runner="$ROOT_DIR/tools/bundle_with_hybrid_compiler_v9500.no"
        if [ -f "$_bundle_runner" ]; then
            exec env \
                NORSCODE_CMD=run \
                NORSCODE_FILE="$_bundle_runner" \
                NORSCODE_ENABLE_EXEC_PROSESS=1 \
                NORSCODE_HYBRID_ROOT="$ROOT_DIR" \
                NORSCODE_HYBRID_OUT="$_bundle_out" \
                NORSCODE_HYBRID_ENTRY="$_bundle_entry" \
                NORSCODE_HYBRID_SPECS="$(printf '%s' "$_bundle_specs" | tr '\n' ' ' | sed 's/ $//')" \
                NORSCODE_PROJECT_ROOT="${NORSCODE_PROJECT_ROOT:-${NORSCODE_IMPORT_BASE:-$(pwd)}}" \
                NORSCODE_IMPORT_BASE="${NORSCODE_IMPORT_BASE:-${NORSCODE_PROJECT_ROOT:-$(pwd)}}" \
                NORSCODE_ROOT="$ROOT_DIR" \
                NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" \
                NORSCODE_VM_DISK_ROOT="$ROOT_DIR,$NC_TMP_ROOT,/tmp,/private/tmp" \
                "$NC_NATIVE"
        fi
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/safe_bundle_entry.no" \
                NORSCODE_BUNDLE_ARGS="$(printf '%s' "$_bundle_specs" | tr '\n' ' ' | sed 's/ $//')" \
                NORSCODE_BUNDLE_OUTPUT="$_bundle_out" \
                NORSCODE_ROOT="$ROOT_DIR" \
                "$NC_NATIVE"
        fi
        printf 'nc bundle: trenger dist/norscode_native. Køyr: ./bin/nc run tools/build_norscode_native.no\n' >&2; exit 1
        ;;

    format)
        _require_native
        _fmt_src="${1:-}"
        case "$_fmt_src" in
            --help|-h)
                printf 'bruk: nc format <kilde.no> [--write] [--check]\n'
                printf 'Formater Norscode-kjeldekode.\n'
                exit 0
                ;;
        esac
        _require_nc_vm
        if [ -z "$_fmt_src" ]; then
            printf 'bruk: nc format <kilde.no> [--write|--check]\n' >&2
            exit 2
        fi
        _fmt_abs="$(cd "$(dirname "$_fmt_src")" && pwd)/$(basename "$_fmt_src")"
        _fmt_write=0
        _fmt_check=0
        for _a in "$@"; do
            [ "$_a" = "--write" ] && _fmt_write=1
            [ "$_a" = "--check" ] && _fmt_check=1
        done
        if [ "$_fmt_write" = "1" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/formatter.no" NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_WRITE=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        if [ "$_fmt_check" = "1" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/formatter.no" NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_CHECK=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/formatter.no" NC_FORMAT_FILE="$_fmt_abs" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        ;;

    lint)
        _require_native
        _lint_src="${1:-}"
        case "$_lint_src" in
            --help|-h)
                printf 'bruk: nc lint <kilde.no> [--check]\n'
                printf 'Lint Norscode-kjeldekode.\n'
                exit 0
                ;;
        esac
        _require_nc_vm
        if [ -z "$_lint_src" ]; then
            printf 'bruk: nc lint <kilde.no> [--check]\n' >&2
            exit 2
        fi
        _lint_abs="$(cd "$(dirname "$_lint_src")" && pwd)/$(basename "$_lint_src")"
        _lint_check=0
        for _a in "$@"; do
            [ "$_a" = "--check" ] && _lint_check=1
        done
        if [ "$_lint_check" = "1" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/linter.no" NC_LINT_FILE="$_lint_abs" NC_LINT_CHECK=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/linter.no" NC_LINT_FILE="$_lint_abs" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        ;;

    bygg-native|bygg-native-v2)
        # Omgang 6: kompiler NCB til native ELF via native_codegen_v2.no (full NcVal-runtime)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc bygg-native [fil.no ut]\n'
            printf 'bruk: nc bygg-native --ncb fil.ncb.json ut.elf\n'
            printf 'Bygg Norscode-kjelde eller NCB-bytekode til native ELF.\n'
            exit 0
        fi
        _require_native
        if [ "${1:-}" = "--ncb" ]; then
            _ncb_input="${2:?bruk: nc bygg-native --ncb fil.ncb.json ut.elf}"
            _ncb_output="${3:-a.out}"
            exec env NORSCODE_CMD=run \
                NORSCODE_FILE="$ROOT_DIR/tools/ncb_to_elf.no" \
                NORSCODE_ENABLE_EXEC_PROSESS=1 \
                NORSCODE_ROOT="$ROOT_DIR" \
                NORSCODE_NCB_TO_ELF_INPUT="$_ncb_input" \
                NORSCODE_NCB_TO_ELF_OUTPUT="$_ncb_output" \
                "$NC_NATIVE"
        fi
        _src="${1:-}"
        _out="${2:-a.out}"
        _codegen="$ROOT_DIR/selfhost/native_execution/native_codegen_v2.no"
        if [ -z "$_src" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run \
                NORSCODE_FILE="$_codegen" \
                NORSCODE_ROOT="$ROOT_DIR" \
                NC_INPUT="$ROOT_DIR/bootstrap/kompiler.ncb.json" \
                NC_OUTPUT="$_out" \
                "$NC_NATIVE"
        else
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_native_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_native_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            trap 'rm -f "$_tmpncb"' EXIT
            if [ -f "$HYBRID_COMPILE" ]; then
                _hybrid_compile "$_src" "$_tmpncb" "__main__" "$ROOT_DIR" >/dev/null
            else
                env NORSCODE_CMD=compile NORSCODE_FILE="$_src" NORSCODE_OUTPUT="$_tmpncb" "$NC_NATIVE" >/dev/null
            fi
            exec env NORSCODE_CMD=run \
                NORSCODE_FILE="$_codegen" \
                NORSCODE_ROOT="$ROOT_DIR" \
                NC_INPUT="$_tmpncb" \
                NC_OUTPUT="$_out" \
                "$NC_NATIVE"
        fi
        ;;

    test)
        _require_native
        exec env \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/tools/nc_test.no" \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_VM_CAPABILITIES="env.read,process.exec,thread.spawn,net.tcp,disk.read,disk.write" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,/tmp,/private/tmp" \
            NORSCODE_ROOT="$ROOT_DIR" \
            NC_NATIVE="$NC_NATIVE" \
            "$NC_NATIVE" || exit $?
        ;;

    feature-check)
        _require_native
        env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/no_c_python_active_surface.no" \
            NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,$NC_TMP_ROOT,/tmp,/private/tmp" \
            "$NC_NATIVE" || exit $?
        env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/verify_norscode_surface_ownership.no" \
            NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,$NC_TMP_ROOT,/tmp,/private/tmp" \
            "$NC_NATIVE" || exit $?
        _fc_rc=0
        if [ "$#" -eq 0 ]; then
            set -- app.no
        fi
        for _fc_file in "$@"; do
            "$0" check "$_fc_file" || _fc_rc=$?
        done
        TEST_TIMEOUT="${TEST_TIMEOUT:-10}" NC_TEST_FILE="$ROOT_DIR/tests/test_ai.no" \
            env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/nc_test.no" \
            NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NC_NATIVE="$NC_NATIVE" \
            NORSCODE_VM_CAPABILITIES="env.read,process.exec,thread.spawn,net.tcp,disk.read,disk.write" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,$NC_TMP_ROOT,/tmp,/private/tmp" \
            "$NC_NATIVE" || _fc_rc=$?
        exit "$_fc_rc"
        ;;

    maintenance)
        _require_native
        _task="${1:-${NORSCODE_TASK:-status}}"
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/maintenance.no" \
            NORSCODE_TASK="$_task" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,$NC_TMP_ROOT,/tmp,/private/tmp" \
            "$NC_NATIVE"
        ;;

    doctor)
        _require_native
        if [ -f "$ROOT_DIR/selfhost/doctor.no" ]; then
            exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/doctor.no" \
                NORSCODE_ROOT="$ROOT_DIR" NORSCODE_ENABLE_EXEC_PROSESS=1 \
                NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" \
                NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,$NC_TMP_ROOT,/tmp,/private/tmp" \
                "$NC_NATIVE"
        fi
        exec "$0" maintenance verify
        ;;

    lsp)
        _require_native
        _lsp_file="$ROOT_DIR/selfhost/lsp/server.no"
        if [ ! -f "$_lsp_file" ]; then
            printf 'lsp: manglar %s\n' "$_lsp_file" >&2
            exit 1
        fi
        for _sym in lsp_selftest lsp_document_symbols lsp_format_document lsp_stdio_main; do
            if ! grep -q "funksjon $_sym" "$_lsp_file"; then
                printf 'lsp: manglar %s i %s\n' "$_sym" "$_lsp_file" >&2
                exit 1
            fi
        done
        printf 'lsp: OK\n'
        ;;

    repl)
        _require_native
        printf 'Norscode REPL (Python-fri)\n'
        printf 'Skriv Norscode-uttrykk. Enter for å evaluere. "exit" for å avslutte.\n\n'
        while IFS= read -r line; do
            [ "$line" = "exit" ] || [ "$line" = "avslutt" ] || [ "$line" = "quit" ] && break
            [ -z "$line" ] && continue
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
                NORSCODE_ROOT="$ROOT_DIR" \
                NORSCODE_REPL_LINE="$line" \
                "$0" run "$ROOT_DIR/tools/nc_repl.no" || true
        done
        printf 'Takk for no!\n'
        exit 0
        ;;

    selftest)
        _require_native
        _selftest_ncb="${TMPDIR:-/tmp}/nc_selftest_${$}.ncb.json"
        _hybrid_compile "$ROOT_DIR/selfhost/nc_main.no" "$_selftest_ncb" "__main__" "$ROOT_DIR" >/dev/null
        _selftest_rc=0
        env NORSCODE_CMD=run NORSCODE_RUN_CMD=selftest \
            NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" \
            NORSCODE_NCB_FILE="$_selftest_ncb" \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_VM_CAPABILITIES="env.read,disk.read,disk.write" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,$NC_TMP_ROOT,/tmp,/private/tmp" \
            "$NC_NATIVE" || _selftest_rc=$?
        rm -f "$_selftest_ncb"
        exit "$_selftest_rc"
        ;;

    selfcheck)
        _require_native
        "$0" check "$ROOT_DIR/selfhost/nc_main.no"
        "$0" selfhost-bootstrap-gate
        ;;

    selfhost-bootstrap-gate)
        _require_native
        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bootstrap_gate.no" \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_VM_CAPABILITIES="disk.read" \

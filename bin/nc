                        exit 2
                    fi
                    _windows_layout_out="$2"
                    shift 2
                    ;;
                --name)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-windows-app-layout [--out DIR] [--name NAMN] <EXE_PATH>\n' >&2
                        exit 2
                    fi
                    _windows_layout_name="$2"
                    shift 2

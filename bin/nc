            trap _boot_cleanup EXIT HUP INT TERM
            NORSCODE_NATIVE_BIN= "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$ROOT_DIR/selfhost/bootstrap_self_pure.no" "$_boot_ncb" "__main__" "$ROOT_DIR"
            NORSCODE_NATIVE_BIN= "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$ROOT_DIR/selfhost/vm_executor.no" "$_boot_vm" "__main__" "$ROOT_DIR"
            _boot_rc=0
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run-ncb-host NORSCODE_HOST_NCB_FILE="$_boot_vm" NORSCODE_NCB_FILE="$_boot_ncb" NORSCODE_VM_SOURCE=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" >"$_boot_out" 2>&1 || _boot_rc=$?
            if [ "$_boot_rc" -eq 0 ]; then
                _nc_print_file "$_boot_out"
                _boot_cleanup
                trap - EXIT HUP INT TERM
                exit 0
            fi
            if ! _nc_has_exec_prosess_gap "$_boot_out" && ! _nc_file_contains "$_boot_out" "Ukjend NORSCODE_CMD: run-ncb-host"; then
                _nc_print_file "$_boot_out"
                _boot_cleanup
                trap - EXIT HUP INT TERM
                exit "$_boot_rc"
            fi
            _boot_cleanup
            trap - EXIT HUP INT TERM
        fi
        exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bootstrap_self_pure.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        ;;


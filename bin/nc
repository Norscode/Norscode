            case "$1" in
                --bundle-dir)
                    if [ "$#" -lt 2 ]; then
                        printf 'manglar verdi for --bundle-dir\n' >&2
                        printf 'bruk: nc install-macos-file-icons [--bundle-dir DIR] [--skip-register]\n' >&2
                        exit 2
                    fi
                    _file_icons_bundle_dir="$2"
                    shift 2
                    ;;
                --skip-register)
                    _file_icons_skip_register="sann"
                    shift
                    ;;
                *)
                    printf 'ukjent install-macos-file-icons-val: %s\n' "$1" >&2
                    printf 'bruk: nc install-macos-file-icons [--bundle-dir DIR] [--skip-register]\n' >&2
                    exit 2
                    ;;
            esac
        done
        _require_native
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_FILE_ICONS_BUNDLE_DIR="$_file_icons_bundle_dir" \
            NORSCODE_FILE_ICONS_SKIP_REGISTER="$_file_icons_skip_register" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/install-macos-file-icons.no"
        ;;

    local-green|gronnliste)
        _local_green_out=""
        _local_green_cleanup() {
            if [ -n "$_local_green_out" ]; then
                rm -f "$_local_green_out"
            fi
        }
        trap _local_green_cleanup EXIT
        trap '_local_green_cleanup; exit 129' HUP
        trap '_local_green_cleanup; exit 130' INT
        trap '_local_green_cleanup; exit 143' TERM
        _local_green_strict=0
        _local_green_mode="run"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --strict)
                    if [ "$_local_green_strict" = "1" ]; then
                        printf 'for mange local-green-val\n' >&2
                        printf 'bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]\n' >&2
                        exit 2
                    fi
                    _local_green_strict=1
                    ;;
                --list|-l)
                    if [ "$_local_green_mode" != "run" ]; then
                        printf 'for mange local-green-val\n' >&2
                        printf 'bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]\n' >&2
                        exit 2
                    fi
                    _local_green_mode="list"
                    ;;
                --help|-h)
                    if [ "$_local_green_mode" != "run" ]; then
                        printf 'for mange local-green-val\n' >&2
                        printf 'bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]\n' >&2
                        exit 2
                    fi
                    _local_green_mode="help"
                    ;;
                *)
                    if [ "$_local_green_mode" != "run" ]; then
                        printf 'for mange local-green-val\n' >&2
                        printf 'bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]\n' >&2
                        exit 2
                    fi
                    printf 'ukjent local-green-val: %s\n' "$1" >&2
                    printf 'bruk: ./bin/nc local-green [--strict] [--list|-l|--help|-h]\n' >&2
                    exit 2
                    ;;
            esac
            shift
        done
        if [ "$_local_green_mode" = "list" ]; then
            _local_green_out="${TMPDIR:-/tmp}/norscode_local_green_list_$$.log"
            _local_green_rc=0
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_LOCAL_GREEN_LIST=1 NORSCODE_LOCAL_GREEN_STRICT="$_local_green_strict" NORSCODE_ROOT="$ROOT_DIR" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/local_green.no" >"$_local_green_out" 2>&1 || _local_green_rc=$?
            if [ "$_local_green_rc" -eq 0 ]; then
                _nc_print_file "$_local_green_out"
                _local_green_cleanup
                exit 0
            fi
            if [ -s "$_local_green_out" ] && ! _nc_has_exec_prosess_gap "$_local_green_out"; then
                _nc_print_file "$_local_green_out"
                _local_green_cleanup
                exit "$_local_green_rc"
            fi
            _local_green_cleanup
            if [ "$_local_green_strict" = "1" ]; then
                sh "$ROOT_DIR/tools/local_green.sh" --strict --list
            else
                sh "$ROOT_DIR/tools/local_green.sh" --list
            fi
            exit $?
        fi
        if [ "$_local_green_mode" = "help" ]; then
            _local_green_out="${TMPDIR:-/tmp}/norscode_local_green_help_$$.log"
            _local_green_rc=0
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_LOCAL_GREEN_HELP=1 NORSCODE_LOCAL_GREEN_STRICT="$_local_green_strict" NORSCODE_ROOT="$ROOT_DIR" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/local_green.no" >"$_local_green_out" 2>&1 || _local_green_rc=$?
            if [ "$_local_green_rc" -eq 0 ]; then
                _nc_print_file "$_local_green_out"
                _local_green_cleanup
                exit 0
            fi
            if [ -s "$_local_green_out" ] && ! _nc_has_exec_prosess_gap "$_local_green_out"; then
                _nc_print_file "$_local_green_out"
                _local_green_cleanup
                exit "$_local_green_rc"
            fi
            _local_green_cleanup
            if [ "$_local_green_strict" = "1" ]; then
                sh "$ROOT_DIR/tools/local_green.sh" --strict --help
            else
                sh "$ROOT_DIR/tools/local_green.sh" --help
            fi
            exit $?
        fi
        _require_nc_vm
        _local_green_out="${TMPDIR:-/tmp}/norscode_local_green_$$.log"
        _local_green_rc=0
        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_LOCAL_GREEN_STRICT="$_local_green_strict" NORSCODE_ROOT="$ROOT_DIR" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/local_green.no" >"$_local_green_out" 2>&1 || _local_green_rc=$?
        if [ "$_local_green_rc" -eq 0 ]; then
            _nc_print_file "$_local_green_out"
            _local_green_cleanup
            exit 0
        fi
        if [ -s "$_local_green_out" ] && ! _nc_has_exec_prosess_gap "$_local_green_out"; then
            _nc_print_file "$_local_green_out"
            _local_green_cleanup
            exit "$_local_green_rc"
        fi
        _local_green_cleanup
        if [ "$_local_green_strict" = "1" ]; then
            sh "$ROOT_DIR/tools/local_green.sh" --strict
        else
            sh "$ROOT_DIR/tools/local_green.sh"
        fi
        exit $?
        ;;


        printf '  no-legacy-cvm                    Sjekk historisk C-VM/NCBB under tools/\n'
        printf '  selfhost-maintenance-verify      Sjekk selfhost vedlikehaldsdocs-policy\n'
        printf '  selfhost-bootstrap-gate          Bootstrap-gate (steg A+B)\n'
        printf '  bootstrap-self                   Bootstrap steg C (Norscode-VM køyrer Norscode)\n'

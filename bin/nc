#!/usr/bin/env sh
# bin/nc - Norscode CLI (native)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
if [ -d "$ROOT_DIR/current/bin" ] && [ -f "$ROOT_DIR/current/bin/nc" ]; then
    ROOT_DIR="$(CDPATH= cd -- "$ROOT_DIR/current" && pwd -P)"
fi
NC_NATIVE="${NORSCODE_NATIVE_BIN:-$ROOT_DIR/dist/norscode_native}"
# Windows (Git Bash / MSYS2 / Cygwin): bruk .exe-suffiks
case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*)
        case "$NC_NATIVE" in
            *.exe) ;;
            *) NC_NATIVE="${NC_NATIVE}.exe" ;;
        esac
        if [ ! -x "$NC_NATIVE" ] && [ -x "$ROOT_DIR/bootstrap/stage0/norscode-windows-x86_64.exe" ]; then
            NC_NATIVE="$ROOT_DIR/bootstrap/stage0/norscode-windows-x86_64.exe"
        fi
        ;;
esac

_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        while IFS= read -r _line || [ -n "$_line" ]; do
            case "$_line" in
                version*=*)
                    _value=${_line#*=}
                    set -f
                    set -- $_value
                    set +f
                    _value="${1:-}"
                    _value=${_value#\"}
                    _value=${_value%\"}
                    if [ -n "$_value" ]; then
                        printf '%s\n' "$_value"
                        return 0
                    fi
                    ;;
            esac
        done < "$_toml"
    fi
    printf 'ukjent'
}

_require_native() {
    if [ ! -x "$NC_NATIVE" ]; then
        printf 'nc: norscode_native ikkje funnen. Køyr: ./bin/nc fetch-stage0-seed\n' >&2
        exit 1
    fi
}
# Bakoverkompatibelt alias
_require_nc_vm() { _require_native; }

_nc_print_file() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        printf '%s\n' "$_line"
    done < "$_file"
}

_nc_print_file_err() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        printf '%s\n' "$_line" >&2
    done < "$_file"
}

_nc_file_contains() {
    _file="$1"
    _needle="$2"
    while IFS= read -r _line || [ -n "$_line" ]; do
        case "$_line" in
            *"$_needle"*) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_nc_has_import_line() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        set -f
        set -- $_line
        set +f
        case "${1:-}" in
            bruk|importer) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_nc_has_selfhost_import() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        set -f
        set -- $_line
        set +f
        case "${1:-}:${2:-}" in
            bruk:selfhost.*|importer:selfhost.*) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_nc_has_exec_prosess_gap() {
    _file="$1"
    while IFS= read -r _line || [ -n "$_line" ]; do
        case "$_line" in
            *"Ukjent funksjon: exec_prosess"*|*"Ukjent funksjon: builtin.exec_prosess"*|*"Ukjent funksjon: builtin.builtin.exec_prosess"*|*"manglar exec_prosess"*) return 0 ;;
        esac
    done < "$_file"
    return 1
}

_find_project_root() {
    _start_dir="$1"
    _dir="$_start_dir"
    while [ -n "$_dir" ] && [ "$_dir" != "/" ]; do
        if [ -f "$_dir/norcode.toml" ]; then
            printf '%s\n' "$_dir"
            return 0
        fi
        _parent="$(dirname "$_dir")"
        if [ "$_parent" = "$_dir" ]; then
            break
        fi
        _dir="$_parent"
    done
    printf '%s\n' "$ROOT_DIR"
}

_nc_run_vm_cache_stale() {
    _cache="$1"
    if [ ! -s "$_cache" ]; then
        return 0
    fi
    for _dep in \
        "$ROOT_DIR/selfhost/vm_executor.no" \
        "$ROOT_DIR/selfhost/vm.no" \
        "$ROOT_DIR/selfhost/json.no" \
        "$ROOT_DIR/selfhost/kompiler.no" \
        "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" \
        "$NC_NATIVE"
    do
        if [ -e "$_dep" ] && [ "$_dep" -nt "$_cache" ]; then
            return 0
        fi
    done
    return 1
}

_nc_run_ncb_host_status() {
    _cache="$1"
    if [ -s "$_cache" ] && { [ ! -e "$NC_NATIVE" ] || [ ! "$NC_NATIVE" -nt "$_cache" ]; }; then
        IFS= read -r _line < "$_cache" || _line=""
        case "$_line" in
            supported|unsupported) printf '%s\n' "$_line"; return 0 ;;
        esac
    fi
    printf 'unknown\n'
}

_nc_write_run_ncb_host_status() {
    _cache="$1"
    _status="$2"
    mkdir -p "$(dirname "$_cache")"
    _tmp="$_cache.$$"
    printf '%s\n' "$_status" > "$_tmp"
    mv "$_tmp" "$_cache"
}

_nc_module_file_for_import() {
    _mod="$1"
    _path=""
    while :; do
        case "$_mod" in
            *.*)
                _part=${_mod%%.*}
                _path="$_path$_part/"
                _mod=${_mod#*.}
                ;;
            *)
                printf '%s/%s%s.no\n' "$ROOT_DIR" "$_path" "$_mod"
                return 0
                ;;
        esac
    done
}

_nc_run_target_cache_stale() {
    _cache="$1"
    _src="$2"
    if [ ! -s "$_cache" ]; then
        return 0
    fi
    for _dep in "$_src" "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$NC_NATIVE"; do
        if [ -e "$_dep" ] && [ "$_dep" -nt "$_cache" ]; then
            return 0
        fi
    done
    while IFS= read -r _line || [ -n "$_line" ]; do
        set -f
        set -- $_line
        set +f
        case "${1:-}" in
            bruk|importer)
                _dep="$(_nc_module_file_for_import "${2:-}")"
                if [ -e "$_dep" ] && [ "$_dep" -nt "$_cache" ]; then
                    return 0
                fi
                ;;
        esac
    done < "$_src"
    return 1
}

_nc_run_target_cache_path() {
    _src="$1"
    case "$_src" in
        /*) _src_abs="$_src" ;;
        *) _src_abs="$(pwd)/$_src" ;;
    esac
    case "$_src_abs" in
        "$ROOT_DIR"/*) _rel=${_src_abs#"$ROOT_DIR"/} ;;
        *) _rel="external/$(basename "$_src_abs")" ;;
    esac
    printf '%s/build/cache/nc/run-targets/%s.ncb.json\n' "$ROOT_DIR" "$_rel"
}

if [ $# -eq 0 ]; then
    printf 'Norscode %s  —  køyr: nc help\n' "$(_nc_version)"
    exit 0
fi

CMD="$1"; shift

case "$CMD" in

    run)
        export NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,thread.spawn,net.tcp,net.http,net.dns,disk.read,disk.write,jit.execute}"
        export NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}"
        case "${1:-}" in
            --help|-h)
                printf 'bruk: nc run <fil.no>\n'
                printf 'Kompiler og køyr Norscode-fil.\n'
                exit 0
                ;;
        esac
        SRC="${1:-app.no}"
        if [ ! -f "$SRC" ]; then
            printf 'nc run: finn ikkje fil %s\n' "$SRC" >&2
            printf 'bruk: nc run <fil.no>\n' >&2
            exit 2
        fi
        # Prioriter norscode_native (native binary, raskare)
        if [ -x "$NC_NATIVE" ]; then
            # Native V2/AOT-testar importerer sjølve codegen-modulen. Køyr
            # dei gjennom same Norscode-bundle og host-entry som den reine
            # runtime-gaten, slik at importerte selfhost-funksjonar ikkje blir
            # forveksla med ein einskildmodul.
            if _nc_file_contains "$SRC" "native_execution.native_codegen_v2"; then
                _aot_ncb="${TMPDIR:-/tmp}/norscode_aot_run_$$.ncb.json"
                _aot_rc=0
                env NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" \
                    "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$SRC" "$_aot_ncb" "__main__" "$ROOT_DIR" || _aot_rc=$?
                if [ "$_aot_rc" -eq 0 ]; then
                    env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run \
                        NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" \
                        NORSCODE_HOST_NCB_FILE="$_aot_ncb" NORSCODE_NCB_FILE="$_aot_ncb" \
                        NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
                    _aot_rc=$?
                fi
                rm -f "$_aot_ncb"
                exit "$_aot_rc"
            fi
            _run_bundle_imports=0
            if [ -f "$SRC" ] && _nc_has_import_line "$SRC"; then
                _run_bundle_imports=1
            fi
            case "$SRC" in
                "$ROOT_DIR"/tools/acme_dns01_server.no|tools/acme_dns01_server.no|"$ROOT_DIR"/tools/acme_pebble_issuance_gate.no|tools/acme_pebble_issuance_gate.no) _run_bundle_imports=1 ;;
                "$ROOT_DIR"/tools/*.no|tools/*.no) _run_bundle_imports=0 ;;
            esac
            if _nc_has_selfhost_import "$SRC"; then
                _run_bundle_imports=0
            fi
            case "$SRC" in
                "$ROOT_DIR"/tools/nc_test.no|tools/nc_test.no|"$ROOT_DIR"/tools/native_media_runtime_gate_v3010.no|tools/native_media_runtime_gate_v3010.no|"$ROOT_DIR"/tools/embed_release_ncb.no|tools/embed_release_ncb.no|"$ROOT_DIR"/selfhost/native_execution/embedded_runtime_entry.no|selfhost/native_execution/embedded_runtime_entry.no|"$ROOT_DIR"/selfhost/native_execution/macho_arm64_codegen.no|selfhost/native_execution/macho_arm64_codegen.no|"$ROOT_DIR"/selfhost/native_execution/elf_arm64_codegen.no|selfhost/native_execution/elf_arm64_codegen.no|"$ROOT_DIR"/tests/test_embedded_ncb_image.no|tests/test_embedded_ncb_image.no|"$ROOT_DIR"/tests/test_embedded_runtime_entry.no|tests/test_embedded_runtime_entry.no|"$ROOT_DIR"/tests/test_macho_arm64_codegen.no|tests/test_macho_arm64_codegen.no|"$ROOT_DIR"/tests/test_macho_arm64_aot_function_cli.no|tests/test_macho_arm64_aot_function_cli.no|"$ROOT_DIR"/tests/test_macho_arm64_aot_stdlib_cli.no|tests/test_macho_arm64_aot_stdlib_cli.no|"$ROOT_DIR"/tests/test_elf_arm64_codegen.no|tests/test_elf_arm64_codegen.no|"$ROOT_DIR"/tests/test_linux_x86_64_aot_cli.no|tests/test_linux_x86_64_aot_cli.no|"$ROOT_DIR"/tests/test_linux_arm64_aot_cli.no|tests/test_linux_arm64_aot_cli.no) _run_bundle_imports=1 ;;
            esac
            if [ "$_run_bundle_imports" = "1" ] && [ -x "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" ]; then
                _ncb_tmp="${TMPDIR:-/tmp}/norscode_run_$$.ncb.json"
                _ncb_is_cache=0
                _ncb_build_tmp=""
                if [ "${NORSCODE_RUN_CACHE:-1}" != "0" ]; then
                    _ncb_tmp="$(_nc_run_target_cache_path "$SRC")"
                    _ncb_is_cache=1
                fi
                _vm_tmp="${TMPDIR:-/tmp}/norscode_vmexec_$$.ncb.json"
                _vm_is_cache=0
                _vm_build_tmp=""
                if [ "${NORSCODE_RUN_CACHE:-1}" != "0" ]; then
                    _vm_tmp="${NORSCODE_RUN_VM_CACHE:-$ROOT_DIR/build/cache/nc/vm_executor.ncb.json}"
                    _vm_is_cache=1
                fi
                _host_support_is_temp=0
                if [ "${NORSCODE_RUN_CACHE:-1}" = "0" ]; then
                    _host_support_cache="${NORSCODE_RUN_NCB_HOST_CACHE:-${TMPDIR:-/tmp}/norscode_run_ncb_host_$$.status}"
                    _host_support_is_temp=1
                else
                    _host_support_cache="${NORSCODE_RUN_NCB_HOST_CACHE:-$ROOT_DIR/build/cache/nc/run_ncb_host.status}"
                fi
                _out_tmp="${TMPDIR:-/tmp}/norscode_run_$$.out"
                _direct_tmp="${TMPDIR:-/tmp}/norscode_run_$$.direct.out"
                _cleanup_run_tmp() {
                    rm -f "$_out_tmp" "$_direct_tmp"
                    if [ "$_host_support_is_temp" = "1" ]; then
                        rm -f "$_host_support_cache"
                    fi
                    if [ -n "$_ncb_build_tmp" ]; then
                        rm -f "$_ncb_build_tmp"
                    fi
                    if [ "$_ncb_is_cache" != "1" ]; then
                        rm -f "$_ncb_tmp"
                    fi
                    if [ -n "$_vm_build_tmp" ]; then
                        rm -f "$_vm_build_tmp"
                    fi
                    if [ "$_vm_is_cache" != "1" ]; then
                        rm -f "$_vm_tmp"
                    fi
                }
                trap _cleanup_run_tmp EXIT HUP INT TERM
                if [ "$_ncb_is_cache" = "1" ]; then
                    mkdir -p "$(dirname "$_ncb_tmp")"
                    if _nc_run_target_cache_stale "$_ncb_tmp" "$SRC"; then
                        _ncb_build_tmp="$_ncb_tmp.$$"
                        env NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$SRC" "$_ncb_build_tmp" "__main__" "$ROOT_DIR"
                        mv "$_ncb_build_tmp" "$_ncb_tmp"
                        _ncb_build_tmp=""
                    fi
                else
                    env NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$SRC" "$_ncb_tmp" "__main__" "$ROOT_DIR"
                fi
                if [ "$_vm_is_cache" = "1" ]; then
                    mkdir -p "$(dirname "$_vm_tmp")"
                    if _nc_run_vm_cache_stale "$_vm_tmp"; then
                        _vm_build_tmp="$_vm_tmp.$$"
                        env NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$ROOT_DIR/selfhost/vm_executor.no" "$_vm_build_tmp" "__main__" "$ROOT_DIR"
                        mv "$_vm_build_tmp" "$_vm_tmp"
                        _vm_build_tmp=""
                    fi
                else
                    env NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" "$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.sh" "$ROOT_DIR" "$ROOT_DIR/selfhost/vm_executor.no" "$_vm_tmp" "__main__" "$ROOT_DIR"
                fi
                _rc=0
                _run_target_caps="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,thread.spawn,net.tcp,net.http,net.dns,disk.read,disk.write,jit.execute}"
                _run_target_disk="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}"
                _run_executor_caps="$_run_target_caps,env.read,env.write,process.exec,thread.spawn,net.listen,net.connect,net.tcp,net.udp,net.http,net.dns,net.tls,disk.read,disk.write,jit.execute"
                _run_executor_disk="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp,$_run_target_disk"
                # Import-bundla interne verktøy kan køyrast direkte av hosten.
                # Dette unngår eit dyrt VM-i-VM-lag, men held den eksisterande
                # portable executorbanen som automatisk reserveveg.
                if [ "${NORSCODE_RUN_DIRECT_HOST:-0}" = "1" ]; then
                    _direct_rc=0
                    env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="$_run_target_caps" NORSCODE_VM_DISK_ROOT="$_run_executor_disk" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" NORSCODE_HOST_NCB_FILE="$_ncb_tmp" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" >"$_direct_tmp" 2>&1 || _direct_rc=$?
                    if [ "$_direct_rc" -eq 0 ]; then
                        _nc_print_file "$_direct_tmp"
                        _cleanup_run_tmp
                        trap - EXIT HUP INT TERM
                        exit 0
                    fi
                fi
                if [ "${NORSCODE_VM_TRACE:-0}" = "1" ]; then
                    _host_status="$(_nc_run_ncb_host_status "$_host_support_cache")"
                    if [ "$_host_status" != "unsupported" ]; then
                        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_REQUESTED_POLICY=1 NORSCODE_VM_REQUESTED_CAPABILITIES="$_run_target_caps" NORSCODE_VM_REQUESTED_DISK_ROOT="$_run_target_disk" NORSCODE_VM_REQUESTED_NET_SCOPE="${NORSCODE_VM_NET_SCOPE:-}" NORSCODE_VM_REQUESTED_PROCESS_SCOPE="${NORSCODE_VM_PROCESS_SCOPE:-}" NORSCODE_VM_CAPABILITIES="$_run_executor_caps" NORSCODE_VM_DISK_ROOT="$_run_executor_disk" NORSCODE_CMD=run-ncb-host NORSCODE_HOST_NCB_FILE="$_vm_tmp" NORSCODE_NCB_FILE="$_ncb_tmp" NORSCODE_VM_SOURCE=1 NORSCODE_VM_QUIET=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" || _rc=$?
                    else
                        _rc=1
                    fi
                    if [ "$_rc" -ne 0 ]; then
                        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_REQUESTED_POLICY=1 NORSCODE_VM_REQUESTED_CAPABILITIES="$_run_target_caps" NORSCODE_VM_REQUESTED_DISK_ROOT="$_run_target_disk" NORSCODE_VM_REQUESTED_NET_SCOPE="${NORSCODE_VM_NET_SCOPE:-}" NORSCODE_VM_REQUESTED_PROCESS_SCOPE="${NORSCODE_VM_PROCESS_SCOPE:-}" NORSCODE_VM_CAPABILITIES="$_run_executor_caps" NORSCODE_VM_DISK_ROOT="$_run_executor_disk" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" NORSCODE_HOST_NCB_FILE="$_vm_tmp" NORSCODE_NCB_FILE="$_ncb_tmp" NORSCODE_VM_SOURCE=1 NORSCODE_VM_QUIET=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" || _rc=$?
                    fi
                else
                    _host_status="$(_nc_run_ncb_host_status "$_host_support_cache")"
                    if [ "$_host_status" != "unsupported" ]; then
                        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_REQUESTED_POLICY=1 NORSCODE_VM_REQUESTED_CAPABILITIES="$_run_target_caps" NORSCODE_VM_REQUESTED_DISK_ROOT="$_run_target_disk" NORSCODE_VM_REQUESTED_NET_SCOPE="${NORSCODE_VM_NET_SCOPE:-}" NORSCODE_VM_REQUESTED_PROCESS_SCOPE="${NORSCODE_VM_PROCESS_SCOPE:-}" NORSCODE_VM_CAPABILITIES="$_run_executor_caps" NORSCODE_VM_DISK_ROOT="$_run_executor_disk" NORSCODE_CMD=run-ncb-host NORSCODE_HOST_NCB_FILE="$_vm_tmp" NORSCODE_NCB_FILE="$_ncb_tmp" NORSCODE_VM_SOURCE=1 NORSCODE_VM_QUIET=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" >"$_out_tmp" 2>&1 || _rc=$?
                        if [ "$_rc" -eq 0 ]; then
                            _nc_write_run_ncb_host_status "$_host_support_cache" "supported"
                        fi
                    else
                        _rc=1
                    fi
                    if [ "$_rc" -ne 0 ] && { [ "$_host_status" = "unsupported" ] || _nc_file_contains "$_out_tmp" "Ukjend NORSCODE_CMD: run-ncb-host"; }; then
                        if [ "$_host_status" != "unsupported" ]; then
                            _nc_write_run_ncb_host_status "$_host_support_cache" "unsupported"
                        fi
                        _rc=0
                        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_REQUESTED_POLICY=1 NORSCODE_VM_REQUESTED_CAPABILITIES="$_run_target_caps" NORSCODE_VM_REQUESTED_DISK_ROOT="$_run_target_disk" NORSCODE_VM_REQUESTED_NET_SCOPE="${NORSCODE_VM_NET_SCOPE:-}" NORSCODE_VM_REQUESTED_PROCESS_SCOPE="${NORSCODE_VM_PROCESS_SCOPE:-}" NORSCODE_VM_CAPABILITIES="$_run_executor_caps" NORSCODE_VM_DISK_ROOT="$_run_executor_disk" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" NORSCODE_HOST_NCB_FILE="$_vm_tmp" NORSCODE_NCB_FILE="$_ncb_tmp" NORSCODE_VM_SOURCE=1 NORSCODE_VM_QUIET=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" >"$_out_tmp" 2>&1 || _rc=$?
                    fi
                    if [ "$_rc" -ne 0 ]; then
                        if env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="$_run_target_caps" NORSCODE_VM_DISK_ROOT="$_run_executor_disk" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" NORSCODE_HOST_NCB_FILE="$_ncb_tmp" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" >"$_direct_tmp" 2>&1; then
                            _nc_print_file "$_direct_tmp"
                            _cleanup_run_tmp
                            trap - EXIT HUP INT TERM
                            exit 0
                        fi
                    fi
                    while IFS= read -r _line || [ -n "$_line" ]; do
                        case "$_line" in
                            "KALL "*) ;;
                            *) printf '%s\n' "$_line" ;;
                        esac
                    done <"$_out_tmp"
                fi
                _cleanup_run_tmp
                trap - EXIT HUP INT TERM
                exit "$_rc"
            fi
            case "$SRC" in
                "$ROOT_DIR"/tools/*.no|tools/*.no)
                    exec env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=run NORSCODE_FILE="$SRC" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,thread.spawn,net.tcp,net.http,net.dns,disk.read,disk.write,jit.execute}" NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" "$NC_NATIVE"
                    ;;
            esac
            exec env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=run NORSCODE_FILE="$SRC" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,thread.spawn,net.tcp,net.http,net.dns,disk.read,disk.write,jit.execute}" NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" "$NC_NATIVE"
        fi
        printf 'nc: treng dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed\n' >&2; exit 1
        ;;

    run-pure)
        case "${1:-}" in
            --help|-h)
                printf 'bruk: nc run-pure <fil.no>\n'
                printf 'Kompiler og køyr ei Norscode-fil i den reine selfhost-VM-en.\n'
                exit 0
                ;;
        esac
        _pure_src="${1:-}"
        if [ -z "$_pure_src" ] || [ ! -f "$_pure_src" ]; then
            printf 'bruk: nc run-pure <fil.no>\n' >&2
            exit 2
        fi
        _require_nc_vm
        mkdir -p "$ROOT_DIR/build/nc-pure"
        _pure_ncb="$ROOT_DIR/build/nc-pure/run_$$.ncb.json"
        _pure_ncb_rel="build/nc-pure/run_$$.ncb.json"
        _pure_cleanup() { rm -f "$_pure_ncb"; }
        trap _pure_cleanup EXIT HUP INT TERM
        env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_VM_CAPABILITIES='env.read,process.exec,disk.read,disk.write' \
            NORSCODE_VM_GC_THRESHOLD="${NORSCODE_VM_GC_THRESHOLD:-16}" \
            NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" \
            NORSCODE_HYBRID_ROOT="$ROOT_DIR" \
            NORSCODE_HYBRID_SRC="$_pure_src" \
            NORSCODE_HYBRID_OUT="$_pure_ncb" \
            NORSCODE_HYBRID_MODULE=__main__ \
            NORSCODE_HYBRID_PROJECT_ROOT="$ROOT_DIR" \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.no" \
            "$NC_NATIVE" >/dev/null || exit $?
        _pure_rc=0
        env \
            NORSCODE_VM_REQUESTED_POLICY=1 \
            NORSCODE_VM_REQUESTED_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-}" \
            NORSCODE_VM_REQUESTED_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-.}" \
            NORSCODE_VM_REQUESTED_NET_SCOPE="${NORSCODE_VM_NET_SCOPE:-}" \
            NORSCODE_VM_REQUESTED_PROCESS_SCOPE="${NORSCODE_VM_PROCESS_SCOPE:-}" \
            NORSCODE_VM_GC_THRESHOLD="${NORSCODE_VM_GC_THRESHOLD:-16}" \
            NORSCODE_VM_CAPABILITIES=env.read,env.write,process.exec,thread.spawn,net.tcp,net.http,net.dns,disk.read,disk.write,jit.execute \
            NORSCODE_VM_DISK_ROOT=".,${NORSCODE_VM_DISK_ROOT:-.}" \
            NORSCODE_VM_NCB="$ROOT_DIR/bootstrap/precompiled/vm.ncb.json" \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" \
            NORSCODE_HOST_NCB_FILE="selfhost/vm_executor.ncb.json" \
            NORSCODE_NCB_FILE="$_pure_ncb_rel" \
            NORSCODE_VM_SOURCE=1 \
            NORSCODE_VM_QUIET=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            "$NC_NATIVE" || _pure_rc=$?
        _pure_cleanup
        trap - EXIT HUP INT TERM
        exit "$_pure_rc"
        ;;

    run-ncb-pure)
        case "${1:-}" in
            --help|-h)
                printf 'bruk: nc run-ncb-pure <fil.ncb.json>\n'
                printf 'Køyr NCB-bytecode i den reine selfhost-VM-en.\n'
                exit 0
                ;;
        esac
        _pure_ncb_file="${1:-}"
        if [ -z "$_pure_ncb_file" ] || [ ! -f "$_pure_ncb_file" ]; then
            printf 'bruk: nc run-ncb-pure <fil.ncb.json>\n' >&2
            exit 2
        fi
        _require_nc_vm
        mkdir -p "$ROOT_DIR/build/nc-pure"
        _pure_ncb_copy="$ROOT_DIR/build/nc-pure/input_$$.ncb.json"
        _pure_ncb_copy_rel="build/nc-pure/input_$$.ncb.json"
        cp "$_pure_ncb_file" "$_pure_ncb_copy"
        _pure_ncb_rc=0
        env \
            NORSCODE_VM_REQUESTED_POLICY=1 \
            NORSCODE_VM_REQUESTED_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-}" \
            NORSCODE_VM_REQUESTED_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-.}" \
            NORSCODE_VM_REQUESTED_NET_SCOPE="${NORSCODE_VM_NET_SCOPE:-}" \
            NORSCODE_VM_REQUESTED_PROCESS_SCOPE="${NORSCODE_VM_PROCESS_SCOPE:-}" \
            NORSCODE_VM_CAPABILITIES=env.read,env.write,process.exec,thread.spawn,net.tcp,net.http,net.dns,disk.read,disk.write,jit.execute \
            NORSCODE_VM_DISK_ROOT=".,${NORSCODE_VM_DISK_ROOT:-.}" \
            NORSCODE_VM_NCB="$ROOT_DIR/bootstrap/precompiled/vm.ncb.json" \
            NORSCODE_CMD=run \
            NORSCODE_FILE="$ROOT_DIR/selfhost/tooling/ncb_host_run_entry.no" \
            NORSCODE_HOST_NCB_FILE="selfhost/vm_executor.ncb.json" \
            NORSCODE_NCB_FILE="$_pure_ncb_copy_rel" \
            NORSCODE_VM_SOURCE=1 \
            NORSCODE_VM_QUIET=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            "$NC_NATIVE" || _pure_ncb_rc=$?
        rm -f "$_pure_ncb_copy"
        exit "$_pure_ncb_rc"
        ;;

    compile)
        SRC="${1:-}"
        OUT="${2:-}"
        case "$SRC" in
            --help|-h)
                printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n'
                printf 'Kompiler Norscode-fil til bytekode.\n'
                exit 0
                ;;
        esac
        if [ -z "$SRC" ]; then
            printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2; exit 2
        fi
        if [ ! -f "$SRC" ]; then
            printf 'nc compile: finn ikkje fil %s\n' "$SRC" >&2
            printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2
            exit 2
        fi
        if [ -x "$NC_NATIVE" ]; then
            if [ -n "$OUT" ]; then
                exec env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_OUTPUT="$OUT" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            else
                exec env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            fi
        fi
        printf 'nc: treng dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed\n' >&2; exit 1
        ;;

    build)
        SRC="${1:-}"
        OUT="${2:-}"
        case "$SRC" in
            --help|-h)
                printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n'
                printf 'Kompiler Norscode-fil til NCB-bytecode.\n'
                exit 0
                ;;
        esac
        if [ -z "$SRC" ] || [ -z "$OUT" ]; then
            printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n' >&2; exit 2
        fi
        if [ ! -f "$SRC" ]; then
            printf 'nc build: finn ikkje fil %s\n' "$SRC" >&2
            printf 'bruk: nc build <kilde.no> <utdata.ncb.json>\n' >&2
            exit 2
        fi
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_OUTPUT="$OUT" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        printf 'nc: treng dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed\n' >&2; exit 1
        ;;

    bygg)
        # nc bygg [--mål elf64] <kilde.no> [utdata]
        case "${1:-}" in
            --help|-h)
                printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n'
                printf 'Bygg Norscode med mål/native val.\n'
                exit 0
                ;;
        esac
        _maal="ncb"
        _src=""
        _out=""
        _next_is_maal=0
        for _ba in "$@"; do
            if [ "$_next_is_maal" = "1" ]; then
                _maal="$_ba"; _next_is_maal=0; continue
            fi
            case "$_ba" in
                --mål) _next_is_maal=1 ;;
                elf64|elf) _maal="elf64" ;;
                kernel|kernel32) _maal="kernel" ;;
                *.no) _src="$_ba" ;;
                *) _out="$_ba" ;;
            esac
        done
        if [ -z "$_src" ] && [ "$_maal" != "kernel" ] && [ "$_maal" != "kernel32" ]; then
            printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n' >&2; exit 2
        fi
        if [ -n "$_src" ] && [ ! -f "$_src" ]; then
            printf 'nc bygg: finn ikkje fil %s\n' "$_src" >&2
            printf 'bruk: nc bygg [--mål elf64|kernel] <kilde.no> [utdata]\n' >&2
            exit 2
        fi
        _require_native
        if [ "$_maal" = "native" ] || [ "$_maal" = "native64" ]; then
            if [ -z "$_src" ]; then
                printf 'bruk: nc bygg --mål native <kilde.no> [utdata]\n' >&2; exit 2
            fi
            if [ -z "$_out" ]; then _out="${_src%.no}"; fi
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$_src" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" > "$_tmpncb"
            NC_INPUT="$_tmpncb" NC_OUTPUT="$_out" \
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/native_codegen.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            rm -f "$_tmpncb"
            chmod +x "$_out" 2>/dev/null || true
        elif [ "$_maal" = "kernel" ] || [ "$_maal" = "kernel32" ]; then
            if [ -z "$_out" ]; then _out="build/norscode_kernel.elf"; fi
            mkdir -p "$(dirname "$_out")"
            NC_OUTPUT="$_out" \
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/kernel_builder.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        elif [ "$_maal" = "elf64" ]; then
            if [ -z "$_out" ]; then _out="${_src%.no}"; fi
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$_src" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" > "$_tmpncb"
            NC_INPUT="$_tmpncb" NC_OUTPUT="$_out" \
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/ncb_to_elf.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            rm -f "$_tmpncb"
            chmod +x "$_out" 2>/dev/null || true
            printf 'bygg: %s → %s (ELF64 x86-64)\n' "$_src" "$_out"
        else
            if [ -z "$_out" ]; then _out="${_src%.no}.ncb.json"; fi
            env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$_src" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" > "$_out"
            printf 'bygg: %s → %s (NCB)\n' "$_src" "$_out"
        fi
        ;;

    check)
        SRC="${1:-}"
        case "$SRC" in
            --help|-h)
                printf 'bruk: nc check <kilde.no>\n'
                printf 'Sjekk syntaks/semantikk utan å skrive artefakt.\n'
                exit 0
                ;;
        esac
        if [ -z "$SRC" ]; then
            printf 'bruk: nc check <kilde.no>\n' >&2; exit 2
        fi
        if [ ! -f "$SRC" ]; then
            printf 'nc check: finn ikkje fil %s\n' "$SRC" >&2
            printf 'bruk: nc check <kilde.no>\n' >&2
            exit 2
        fi
        _tmpdir="$(mktemp -d)"
        _rc=0
        if [ -x "$NC_NATIVE" ]; then
            env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_CMD=compile NORSCODE_FILE="$SRC" NORSCODE_OUTPUT="$_tmpdir/_check.ncb.json" NORSCODE_ROOT="$ROOT_DIR" \
                "$NC_NATIVE" >/dev/null && printf '%s: OK\n' "$SRC" || _rc=$?
        else
            printf 'nc: treng dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed\n' >&2; exit 1
        fi
        rm -rf "$_tmpdir"
        exit "$_rc"
        ;;

    bundle)
        case "${1:-}" in
            --help|-h)
                printf 'bruk: nc bundle [--output utdata.ncb.json] [fil.no ...]\n'
                printf 'Bundle modular til NCB-bytecode.\n'
                exit 0
                ;;
        esac
        if [ -x "$NC_NATIVE" ]; then
            _bundle_out="bootstrap/kompiler.ncb.json"
            _bundle_args=""
            _skip=0
            for _barg in "$@"; do
                if [ "$_barg" = "--output" ]; then _skip=1; continue; fi
                if [ "$_skip" = "1" ]; then _bundle_out="$_barg"; _skip=0; continue; fi
                _bundle_args="${_bundle_args:+$_bundle_args }$_barg"
            done
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bundler.no" NORSCODE_ROOT="$ROOT_DIR" \
                NORSCODE_BUNDLE_ARGS="$_bundle_args" \
                NORSCODE_BUNDLE_OUTPUT="$_bundle_out" \
                "$NC_NATIVE"
        fi
        printf 'nc bundle: treng dist/norscode_native. Køyr: ./bin/nc fetch-stage0-seed\n' >&2; exit 1
        ;;

    format)
        _fmt_src="${1:-}"
        case "$_fmt_src" in
            --help|-h)
                printf 'bruk: nc format <kilde.no> [--write] [--check]\n'
                printf 'Formater Norscode-kjeldekode.\n'
                exit 0
                ;;
        esac
        _require_nc_vm
        if [ -z "$_fmt_src" ]; then
            printf 'bruk: nc format <kilde.no> [--write] [--check]\n' >&2; exit 2
        fi
        if [ ! -f "$_fmt_src" ]; then
            printf 'nc format: finn ikkje fil %s\n' "$_fmt_src" >&2
            printf 'bruk: nc format <kilde.no> [--write] [--check]\n' >&2
            exit 2
        fi
        _fmt_write=0; _fmt_check=0
        for _a in "$@"; do
            [ "$_a" = "--write" ] && _fmt_write=1
            [ "$_a" = "--check" ] && _fmt_check=1
        done
        _fmt_abs="$(cd "$(dirname "$_fmt_src")" && pwd)/$(basename "$_fmt_src")"
        _fmt_caps="${NORSCODE_VM_CAPABILITIES:-env.read,disk.read,disk.write}"
        _fmt_disk="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,$(dirname "$_fmt_abs"),.,${TMPDIR:-/tmp},/tmp,/private/tmp}"
        if [ "$_fmt_write" = "1" ]; then
            if [ -x "$NC_NATIVE" ]; then
                exec env NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_WRITE="1" NORSCODE_VM_CAPABILITIES="$_fmt_caps" NORSCODE_VM_DISK_ROOT="$_fmt_disk" "$ROOT_DIR/bin/nc" run-pure "$ROOT_DIR/selfhost/formatter.no"
            fi
            printf 'nc format: treng dist/norscode_native\n' >&2; exit 1
        elif [ "$_fmt_check" = "1" ]; then
            if [ -x "$NC_NATIVE" ]; then
                exec env NC_FORMAT_FILE="$_fmt_abs" NC_FORMAT_CHECK="1" NORSCODE_VM_CAPABILITIES="$_fmt_caps" NORSCODE_VM_DISK_ROOT="$_fmt_disk" "$ROOT_DIR/bin/nc" run-pure "$ROOT_DIR/selfhost/formatter.no"
            fi
            printf 'nc format: treng dist/norscode_native\n' >&2; exit 1
        else
            if [ -x "$NC_NATIVE" ]; then
                exec env NC_FORMAT_FILE="$_fmt_abs" NORSCODE_VM_CAPABILITIES="$_fmt_caps" NORSCODE_VM_DISK_ROOT="$_fmt_disk" "$ROOT_DIR/bin/nc" run-pure "$ROOT_DIR/selfhost/formatter.no"
            fi
            printf 'nc format: treng dist/norscode_native\n' >&2; exit 1
        fi
        ;;

    lint)
        _lint_src="${1:-}"
        case "$_lint_src" in
            --help|-h)
                printf 'bruk: nc lint <kilde.no> [--check]\n'
                printf 'Lint Norscode-kjeldekode.\n'
                exit 0
                ;;
        esac
        _require_nc_vm
        if [ -z "$_lint_src" ]; then
            printf 'bruk: nc lint <kilde.no> [--check]\n' >&2; exit 2
        fi
        if [ ! -f "$_lint_src" ]; then
            printf 'nc lint: finn ikkje fil %s\n' "$_lint_src" >&2
            printf 'bruk: nc lint <kilde.no> [--check]\n' >&2
            exit 2
        fi
        _lint_check=0
        for _a in "$@"; do [ "$_a" = "--check" ] && _lint_check=1; done
        _lint_abs="$(cd "$(dirname "$_lint_src")" && pwd)/$(basename "$_lint_src")"
        _lint_caps="${NORSCODE_VM_CAPABILITIES:-env.read,disk.read}"
        _lint_disk="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,$(dirname "$_lint_abs"),.,${TMPDIR:-/tmp},/tmp,/private/tmp}"
        if [ "$_lint_check" = "1" ]; then
            if [ -x "$NC_NATIVE" ]; then
                exec env NC_LINT_FILE="$_lint_abs" NC_LINT_CHECK="1" NORSCODE_VM_CAPABILITIES="$_lint_caps" NORSCODE_VM_DISK_ROOT="$_lint_disk" "$ROOT_DIR/bin/nc" run-pure "$ROOT_DIR/selfhost/linter.no"
            fi
            printf 'nc lint: treng dist/norscode_native\n' >&2; exit 1
        else
            if [ -x "$NC_NATIVE" ]; then
                exec env NC_LINT_FILE="$_lint_abs" NORSCODE_VM_CAPABILITIES="$_lint_caps" NORSCODE_VM_DISK_ROOT="$_lint_disk" "$ROOT_DIR/bin/nc" run-pure "$ROOT_DIR/selfhost/linter.no"
            fi
            printf 'nc lint: treng dist/norscode_native\n' >&2; exit 1
        fi
        ;;

    doctor)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc doctor\n'
            printf 'Køyr systemsjekk for Norscode-installasjonen.\n'
            exit 0
        fi
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/doctor.no" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,disk.read}" NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" "$NC_NATIVE"
        fi
        printf 'nc doctor: treng dist/norscode_native\n' >&2; exit 1
        ;;

    maintenance)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc maintenance [oppgåve]\n'
            printf 'Køyr Norscode-basert vedlikehald lokalt.\n'
            exit 0
        fi
        _require_nc_vm
        _task="${1:-${NORSCODE_TASK:-status}}"
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/maintenance.no" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_TASK="$_task" NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,disk.read,disk.write}" NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" "$NC_NATIVE"
        fi
        printf 'nc maintenance: treng dist/norscode_native\n' >&2; exit 1
        ;;

    release-preflight)
        if [ "$#" -gt 1 ]; then
            printf 'for mange release-preflight-val\n' >&2
            printf 'bruk: nc release-preflight [--strict|--help|-h]\n' >&2
            exit 2
        fi
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc release-preflight [--strict|--help|-h]\n'
            printf 'Køyr lokal release-sjekk utan publisering.\n'
            printf 'Bruk --strict før GitHub/release for å feile på uspora nøkkelfiler.\n'
            exit 0
        fi
        _release_preflight_strict=0
        case "${1:-}" in
            --strict) _release_preflight_strict=1 ;;
            "")
                ;;
            *)
                printf 'ukjent release-preflight-val: %s\n' "$1" >&2
                printf 'bruk: nc release-preflight [--strict|--help|-h]\n' >&2
                exit 2
                ;;
        esac
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            _release_preflight_git_check() {
                _release_preflight_git_fail=0
                _release_preflight_git_note=0
                for _release_preflight_rel in \
                    tools/release_preflight.no \
                    tools/local_green.no \
                    tools/local_green.sh \
                    tools/completion_gate.no \
                    tools/platform_runtime_attestation.no \
                    tools/release_user_journey.no \
                    tools/nc_repl.no \
                    tools/nc_repl.sh \
                    tools/no_legacy_cvm.no \
                    tools/no_legacy_cvm.sh \
                    selfhost/bootstrap_gate.no \
                    selfhost/bootstrap_gate.ncb.json \
                    selfhost/bootstrap_self_pure.no \
                    tests/test_release_preflight.no \
                    tests/test_endringslogg_release_text.no \
                    tests/test_local_green.no \
                    tests/test_completion_gate.no \
                    tests/test_bootstrap_self_pure_text.no \
                    tests/test_cli_maturity.no \
                    README.md \
                    INSTALL.md \
                    docs/USER_MANUAL.md \
                    docs/STATUS.md \
                    docs/NORSCODE_1_0_FREEZE.md \
                    docs/LANE_MAP.md \
                    docs/05-development/SELFHOST_CI_GATES.md \
                    docs/05-development/SELFHOST_RELEASE_CHECKLIST.md \
                    docs/LINUX_APP_RELEASE.md \
                    docs/LINUX_APP_INSTALL.md \
                    docs/DOCUMENTATION_INDEX.md \
                    docs/INDEX.md \
                    docs/README.md \
                    docs/MAC_APP_RELEASE.md \
                    docs/MAC_APP_SIGNING.md \
                    docs/WINDOWS_APP_RELEASE.md \
                    docs/WINDOWS_APP_INSTALL.md \
                    CHANGELOG.md
                do
                    if git -C "$ROOT_DIR" ls-files --error-unmatch "$_release_preflight_rel" >/dev/null 2>&1; then
                        if [ "$1" = "strict" ]; then
                            printf '[OK] streng git-sporing: %s\n' "$_release_preflight_rel"
                        else
                            printf '[OK] git-sporing: %s\n' "$_release_preflight_rel"
                        fi
                    else
                        if [ "$1" = "strict" ]; then
                            printf '[FEIL] streng git-sporing manglar: %s\n' "$_release_preflight_rel" >&2
                            _release_preflight_git_fail=1
                        else
                            printf '[MERK] git-sporing manglar: %s\n' "$_release_preflight_rel"
                            _release_preflight_git_note=1
                        fi
                    fi
                done
                if [ "$1" = "strict" ]; then
                    if [ "$_release_preflight_git_fail" = "0" ]; then
                        printf '=== Release-preflight streng git-sporing: OK ===\n'
                    else
                        printf '=== Release-preflight streng git-sporing: FEIL ===\n' >&2
                    fi
                    return "$_release_preflight_git_fail"
                fi
                if [ "$_release_preflight_git_note" = "0" ]; then
                    printf '=== Release-preflight git-sporing: OK ===\n'
                else
                    printf '=== Release-preflight git-sporing: MERK ===\n'
                fi
                return 0
            }
            # Kontrakt: NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/release_preflight.no"
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_RELEASE_PREFLIGHT_SKIP_GIT_TRACKING=1 NORSCODE_RELEASE_PREFLIGHT_STRICT_GIT="$_release_preflight_strict" NORSCODE_ROOT="$ROOT_DIR" NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,disk.read,disk.write}" NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/release_preflight.no" || exit $?
            if [ "$_release_preflight_strict" = "1" ]; then
                _release_preflight_git_check strict
                exit $?
            fi
            _release_preflight_git_check warn
            exit 0
        fi
        printf 'nc release-preflight: treng dist/norscode_native\n' >&2; exit 1
        ;;

    completion-gate)
        if [ "$#" -ne 1 ]; then
            printf 'bruk: nc completion-gate --local|--release\n' >&2
            exit 2
        fi
        case "$1" in
            --local) _completion_mode=local ;;
            --release) _completion_mode=release ;;
            --help|-h)
                printf 'bruk: nc completion-gate --local|--release\n'
                printf 'Køyr den autoritative Norscode 1.0-sluttporten.\n'
                exit 0
                ;;
            *)
                printf 'ukjent completion-gate-val: %s\n' "$1" >&2
                printf 'bruk: nc completion-gate --local|--release\n' >&2
                exit 2
                ;;
        esac
        _require_nc_vm
        exec env NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_COMPLETION_MODE="$_completion_mode" \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_VM_CAPABILITIES="${NORSCODE_VM_CAPABILITIES:-env.read,env.write,process.exec,disk.read,disk.write}" \
            NORSCODE_VM_DISK_ROOT="${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp}" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/completion_gate.no"
        ;;

    package-release|release-package)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc package-release <versjon>\n'
            printf 'Bygg Norscode releasepakke lokalt utan publisering.\n'
            exit 0
        fi
        if [ -z "${1:-}" ]; then
            printf 'bruk: nc package-release <versjon>\n' >&2
            exit 2
        fi
        _require_native
        _package_release_version="$1"
        _package_release_out="${TMPDIR:-/tmp}/norscode_package_release_cli_$$.log"
        _package_release_rc=0
        env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_RELEASE_VERSION="$1" \
            NORSCODE_ROOT="$ROOT_DIR" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/package_release.no" >"$_package_release_out" 2>&1 || _package_release_rc=$?
        if [ "$_package_release_rc" -eq 0 ]; then
            _nc_print_file "$_package_release_out"
            rm -f "$_package_release_out"
            exit 0
        fi
        if [ -s "$_package_release_out" ] && { _nc_has_exec_prosess_gap "$_package_release_out" || _nc_file_contains "$_package_release_out" "Ufullstendig binær fillesing"; }; then
            rm -f "$_package_release_out"
            exec "$ROOT_DIR/package-release.sh" "$_package_release_version"
        fi
        if [ -s "$_package_release_out" ]; then
            _nc_print_file_err "$_package_release_out"
        fi
        rm -f "$_package_release_out"
        exit "$_package_release_rc"
        ;;

    install-release|release-install)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc install-release <release.tar.gz> [--prefix <mappe>]\n'
            printf 'Installer Norscode releasepakke lokalt.\n'
            exit 0
        fi
        if [ -z "${1:-}" ]; then
            printf 'bruk: nc install-release <release.tar.gz> [--prefix <mappe>]\n' >&2
            exit 2
        fi
        _archive="$1"
        shift
        _prefix=""
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --prefix)
                    shift
                    if [ -z "${1:-}" ]; then
                        printf 'bruk: nc install-release <release.tar.gz> [--prefix <mappe>]\n' >&2
                        exit 2
                    fi
                    _prefix="$1"
                    shift
                    ;;
                *)
                    printf 'ukjent install-release-val: %s\n' "$1" >&2
                    printf 'bruk: nc install-release <release.tar.gz> [--prefix <mappe>]\n' >&2
                    exit 2
                    ;;
            esac
        done
        if [ ! -f "$_archive" ]; then
            printf 'nc install-release: finn ikkje fil %s\n' "$_archive" >&2
            printf 'bruk: nc install-release <release.tar.gz> [--prefix <mappe>]\n' >&2
            exit 2
        fi
        _require_native
        _install_size=$(wc -c < "$_archive" 2>/dev/null || printf '0')
        if [ "${_install_size:-0}" -gt 16777216 ] 2>/dev/null; then
            if [ -n "$_prefix" ]; then
                exec env NORSCODE_INSTALL_FORCE_RESERVE=1 sh "$ROOT_DIR/tools/install-release.sh" "$_archive" --prefix "$_prefix"
            fi
            exec env NORSCODE_INSTALL_FORCE_RESERVE=1 sh "$ROOT_DIR/tools/install-release.sh" "$_archive"
        fi
        env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_INSTALL_ARCHIVE="$_archive" \
            NORSCODE_INSTALL_PREFIX="$_prefix" \
            NORSCODE_ROOT="$ROOT_DIR" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/install_release.no"
        ;;

    build-macos-app)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n'
            printf 'Bygg lokal macOS .app-bundle via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        _macos_app_name="Norscode"
        _macos_app_out="$ROOT_DIR/build/macos-app"
        _macos_app_bundle_id="dev.norscode.app"
        _macos_app_version=""
        _macos_app_config=""
        _macos_app_icon="$ROOT_DIR/frontend/assets/icons/norscode.icns"
        _macos_doc_source_name="Norscode Source"
        _macos_doc_utility_name="Norscode Utility Source"
        _macos_doc_bytecode_name="Norscode Bytecode JSON"
        _macos_welcome_title="Norscode macOS app-bundle"
        _macos_welcome_message="Velkomen til Norscode på macOS."
        _macos_app_mode="gui"
        for _arg in "$@"; do
            case "$_arg" in
                --config)
                    _macos_app_config_next=1
                    ;;
                *)
                    if [ "${_macos_app_config_next:-0}" = "1" ]; then
                        _macos_app_config="$_arg"
                        _macos_app_config_next=0
                    fi
                    ;;
            esac
        done
        if [ -n "$_macos_app_config" ]; then
            case "$_macos_app_config" in
                /*) ;;
                *) _macos_app_config="$ROOT_DIR/$_macos_app_config" ;;
            esac
            if [ ! -f "$_macos_app_config" ]; then
                printf 'Feil: manglar config-fil: %s\n' "$_macos_app_config" >&2
                exit 1
            fi
            # shellcheck disable=SC1090
            . "$_macos_app_config"
            _macos_app_name="${APP_NAME:-$_macos_app_name}"
            _macos_app_out="${OUT_DIR:-$_macos_app_out}"
            _macos_app_bundle_id="${BUNDLE_ID:-$_macos_app_bundle_id}"
            _macos_app_version="${APP_VERSION:-$_macos_app_version}"
            _macos_app_icon="${ICON_PATH:-$_macos_app_icon}"
            _macos_doc_source_name="${DOC_TYPE_SOURCE_NAME:-$_macos_doc_source_name}"
            _macos_doc_utility_name="${DOC_TYPE_UTILITY_NAME:-$_macos_doc_utility_name}"
            _macos_doc_bytecode_name="${DOC_TYPE_BYTECODE_NAME:-$_macos_doc_bytecode_name}"
            _macos_welcome_title="${WELCOME_TITLE:-$_macos_welcome_title}"
            _macos_welcome_message="${WELCOME_MESSAGE:-$_macos_welcome_message}"
            _macos_app_mode="${APP_MODE:-$_macos_app_mode}"
        fi
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --config)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    shift 2
                    ;;
                --name)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_app_name="$2"
                    shift 2
                    ;;
                --mode)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_app_mode="$2"
                    shift 2
                    ;;
                --out)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_app_out="$2"
                    shift 2
                    ;;
                --bundle-id)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_app_bundle_id="$2"
                    shift 2
                    ;;
                --version)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_app_version="$2"
                    shift 2
                    ;;
                *)
                    printf 'bruk: nc build-macos-app [--config FIL] [--mode gui|terminal] [--name NAMN] [--out DIR] [--bundle-id ID] [--version VER]\n' >&2
                    exit 2
                    ;;
            esac
        done
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_HOST_OS="$(uname -s 2>/dev/null || printf ukjent)" \
            NORSCODE_SWIFTC="$(command -v swiftc 2>/dev/null || true)" \
            NORSCODE_MACOS_APP_NAME="$_macos_app_name" \
            NORSCODE_MACOS_APP_OUT="$_macos_app_out" \
            NORSCODE_MACOS_APP_BUNDLE_ID="$_macos_app_bundle_id" \
            NORSCODE_MACOS_APP_VERSION="$_macos_app_version" \
            NORSCODE_MACOS_APP_ICON="$_macos_app_icon" \
            NORSCODE_MACOS_APP_MODE="$_macos_app_mode" \
            NORSCODE_MACOS_DOC_SOURCE_NAME="$_macos_doc_source_name" \
            NORSCODE_MACOS_DOC_UTILITY_NAME="$_macos_doc_utility_name" \
            NORSCODE_MACOS_DOC_BYTECODE_NAME="$_macos_doc_bytecode_name" \
            NORSCODE_MACOS_WELCOME_TITLE="$_macos_welcome_title" \
            NORSCODE_MACOS_WELCOME_MESSAGE="$_macos_welcome_message" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/build-macos-app.no"
        ;;

    build-macos-window-host)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n'
            printf 'Bygg minimal macOS GUI-host via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        _macos_window_out="$ROOT_DIR/build/macos-window-host"
        _macos_window_name="NorscodeWindowHost"
        _macos_window_bundle_id="dev.norscode.window-host"
        _macos_window_version="1.0"
        _macos_window_icon="$ROOT_DIR/frontend/assets/icons/norscode.icns"
        _macos_window_source="$ROOT_DIR/platform/macos/window-host/Main.swift"
        _macos_window_template="$ROOT_DIR/platform/macos/window-host/app.no"
        _macos_window_nc="$ROOT_DIR/bin/nc"
        _macos_window_path="/"
        _macos_window_query=""
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --out)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_out="$2"
                    shift 2
                    ;;
                --name)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_name="$2"
                    shift 2
                    ;;
                --bundle-id)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_bundle_id="$2"
                    shift 2
                    ;;
                --version)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_version="$2"
                    shift 2
                    ;;
                --app-file)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_template="$2"
                    shift 2
                    ;;
                --nc)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_nc="$2"
                    shift 2
                    ;;
                --path)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_path="$2"
                    shift 2
                    ;;
                --query)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                        exit 2
                    fi
                    _macos_window_query="$2"
                    shift 2
                    ;;
                *)
                    printf 'bruk: nc build-macos-window-host [--out DIR] [--name NAMN] [--bundle-id ID] [--version VER]\n' >&2
                    exit 2
                    ;;
            esac
        done
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_HOST_OS="$(uname -s 2>/dev/null || printf ukjent)" \
            NORSCODE_SWIFTC="$(command -v swiftc 2>/dev/null || true)" \
            NORSCODE_MACOS_WINDOW_OUT="$_macos_window_out" \
            NORSCODE_MACOS_WINDOW_NAME="$_macos_window_name" \
            NORSCODE_MACOS_WINDOW_BUNDLE_ID="$_macos_window_bundle_id" \
            NORSCODE_MACOS_WINDOW_VERSION="$_macos_window_version" \
            NORSCODE_MACOS_WINDOW_ICON="$_macos_window_icon" \
            NORSCODE_MACOS_WINDOW_SOURCE="$_macos_window_source" \
            NORSCODE_MACOS_WINDOW_TEMPLATE="$_macos_window_template" \
            NORSCODE_MACOS_WINDOW_NC="$_macos_window_nc" \
            NORSCODE_MACOS_WINDOW_PATH="$_macos_window_path" \
            NORSCODE_MACOS_WINDOW_QUERY="$_macos_window_query" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/build-macos-window-host.no"
        ;;

    package-macos-app)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc package-macos-app [--version VER] [--format dmg|zip|pkg|all] [APP_PATH]\n'
            printf 'Pakk lokal macOS app til release-artefaktar via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        _macos_package_app="$ROOT_DIR/build/macos-app/Norscode.app"
        _macos_package_format="all"
        _macos_package_version=""
        _macos_package_app_set=0
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --version)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc package-macos-app [--version VER] [--format dmg|zip|pkg|all] [APP_PATH]\n' >&2
                        exit 2
                    fi
                    _macos_package_version="$2"
                    shift 2
                    ;;
                --format)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc package-macos-app [--version VER] [--format dmg|zip|pkg|all] [APP_PATH]\n' >&2
                        exit 2
                    fi
                    _macos_package_format="$2"
                    shift 2
                    ;;
                *)
                    if [ "$_macos_package_app_set" = "0" ]; then
                        _macos_package_app="$1"
                        _macos_package_app_set=1
                        shift
                    else
                        printf 'bruk: nc package-macos-app [--version VER] [--format dmg|zip|pkg|all] [APP_PATH]\n' >&2
                        exit 2
                    fi
                    ;;
            esac
        done
        case "$_macos_package_app" in
            /*) ;;
            *) _macos_package_app="$ROOT_DIR/$_macos_package_app" ;;
        esac
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_HOST_OS="$(uname -s 2>/dev/null || printf ukjent)" \
            NORSCODE_MACOS_PACKAGE_APP="$_macos_package_app" \
            NORSCODE_MACOS_PACKAGE_FORMAT="$_macos_package_format" \
            NORSCODE_MACOS_PACKAGE_VERSION="$_macos_package_version" \
            NORSCODE_MACOS_PACKAGE_RELEASE_DIR="${NORSCODE_MACOS_PACKAGE_RELEASE_DIR:-$ROOT_DIR/release-artifacts}" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/package-macos-app.no"
        ;;

    package-linux-app)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc package-linux-app [--version VER] [--format appdir|tarball|appimage|all]\n'
            printf 'Bygg Linux AppDir/tarball/AppImage via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        _linux_package_format="all"
        _linux_package_version=""
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --version)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc package-linux-app [--version VER] [--format appdir|tarball|appimage|all]\n' >&2
                        exit 2
                    fi
                    _linux_package_version="$2"
                    shift 2
                    ;;
                --format)
                    if [ "$#" -lt 2 ]; then
                        printf 'bruk: nc package-linux-app [--version VER] [--format appdir|tarball|appimage|all]\n' >&2
                        exit 2
                    fi
                    _linux_package_format="$2"
                    shift 2
                    ;;
                *)
                    printf 'bruk: nc package-linux-app [--version VER] [--format appdir|tarball|appimage|all]\n' >&2
                    exit 2
                    ;;
            esac
        done
        case "$_linux_package_format" in
            appdir|tarball|appimage|all) ;;
            *)
                printf 'Feil: ugyldig format %s (bruk appdir, tarball, appimage eller all)\n' "$_linux_package_format" >&2
                exit 2
                ;;
        esac
        _linux_package_out="${TMPDIR:-/tmp}/norscode_package_linux_app_$$.log"
        _linux_package_rc=0
        env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_LINUX_PACKAGE_FORMAT="$_linux_package_format" \
            NORSCODE_LINUX_PACKAGE_VERSION="$_linux_package_version" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/package-linux-app.no" >"$_linux_package_out" 2>&1 || _linux_package_rc=$?
        if [ "$_linux_package_rc" -eq 0 ]; then
            _nc_print_file "$_linux_package_out"
            rm -f "$_linux_package_out"
            exit 0
        fi
        if ! _nc_has_exec_prosess_gap "$_linux_package_out"; then
            _nc_print_file_err "$_linux_package_out"
            rm -f "$_linux_package_out"
            exit "$_linux_package_rc"
        fi
        rm -f "$_linux_package_out"
        if [ ! -x "$ROOT_DIR/dist/norscode_native" ]; then
            "$ROOT_DIR/bin/nc" fetch-stage0-seed
        fi
        if [ -z "$_linux_package_version" ]; then
            _linux_package_version="$(_nc_version)"
            if [ "$_linux_package_version" = "ukjent" ]; then
                _linux_package_version="1.0"
            fi
        fi
        _linux_package_release_dir="${NORSCODE_LINUX_PACKAGE_RELEASE_DIR:-$ROOT_DIR/release-artifacts}"
        _linux_package_build_dir="${NORSCODE_LINUX_PACKAGE_BUILD_DIR:-$ROOT_DIR/build/linux-app}"
        _linux_package_appdir="$_linux_package_build_dir/Norscode.AppDir"
        _linux_package_tarball="$_linux_package_release_dir/Norscode-linux-$_linux_package_version-AppDir.tar.gz"
        _linux_package_appimage="$_linux_package_release_dir/Norscode-linux-$_linux_package_version.AppImage"
        _linux_package_build_appdir() {
            rm -rf "$_linux_package_appdir"
            mkdir -p \
                "$_linux_package_appdir/usr/bin" \
                "$_linux_package_appdir/usr/share/applications" \
                "$_linux_package_appdir/usr/share/icons/hicolor/256x256/apps" \
                "$_linux_package_appdir/usr/share/norscode/runtime"
            cp "$ROOT_DIR/dist/norscode_native" "$_linux_package_appdir/usr/bin/norscode"
            chmod +x "$_linux_package_appdir/usr/bin/norscode"
            {
                printf '#!/usr/bin/env sh\n'
                printf 'set -eu\n'
                printf 'HERE="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"\n'
                printf 'exec "$HERE/usr/bin/norscode" "$@"\n'
            } > "$_linux_package_appdir/AppRun"
            chmod +x "$_linux_package_appdir/AppRun"
            {
                printf '[Desktop Entry]\n'
                printf 'Type=Application\n'
                printf 'Name=Norscode\n'
                printf 'Exec=AppRun\n'
                printf 'Icon=norscode\n'
                printf 'Categories=Development;\n'
                printf 'Terminal=true\n'
            } > "$_linux_package_appdir/Norscode.desktop"
            cp "$ROOT_DIR/frontend/assets/icons/norscode-mark-256.png" "$_linux_package_appdir/usr/share/icons/hicolor/256x256/apps/norscode.png"
            cp "$ROOT_DIR/frontend/assets/icons/norscode-mark-256.png" "$_linux_package_appdir/norscode.png"
            cp -R "$ROOT_DIR/bin" "$ROOT_DIR/bootstrap" "$ROOT_DIR/dist" "$ROOT_DIR/selfhost" "$ROOT_DIR/std" "$ROOT_DIR/norcode.toml" "$ROOT_DIR/README.md" "$ROOT_DIR/LICENSE" "$_linux_package_appdir/usr/share/norscode/runtime/"
            cp "$_linux_package_appdir/Norscode.desktop" "$_linux_package_appdir/usr/share/applications/Norscode.desktop"
            printf 'Bygde AppDir: %s\n' "$_linux_package_appdir"
        }
        _linux_package_write_sha256() {
            _target="$1"
            if command -v shasum >/dev/null 2>&1; then
                set -- $(shasum -a 256 "$_target")
            else
                set -- $(sha256sum "$_target")
            fi
            printf '%s\n' "$1" > "$_target.sha256"
        }
        mkdir -p "$_linux_package_build_dir" "$_linux_package_release_dir"
        rm -f "$_linux_package_tarball" "$_linux_package_tarball.sha256" "$_linux_package_appimage" "$_linux_package_appimage.sha256"
        case "$_linux_package_format" in
            appdir)
                _linux_package_build_appdir
                ;;
            tarball)
                _linux_package_build_appdir
                tar -czf "$_linux_package_tarball" -C "$_linux_package_build_dir" "Norscode.AppDir"
                _linux_package_write_sha256 "$_linux_package_tarball"
                printf 'Bygde Linux AppDir-tarball: %s\n' "$_linux_package_tarball"
                ;;
            appimage)
                _linux_package_build_appdir
                if [ "$(uname -s)" != "Linux" ]; then
                    printf 'Merk: AppImage-bygging krev Linux-host.\n' >&2
                    exit 1
                fi
                if ! command -v appimagetool >/dev/null 2>&1; then
                    printf 'Merk: appimagetool er ikkje installert; hoppar over AppImage.\n' >&2
                    exit 1
                fi
                ARCH="${ARCH:-x86_64}" appimagetool "$_linux_package_appdir" "$_linux_package_appimage" >/dev/null
                _linux_package_write_sha256 "$_linux_package_appimage"
                printf 'Bygde AppImage: %s\n' "$_linux_package_appimage"
                ;;
            all)
                _linux_package_build_appdir
                tar -czf "$_linux_package_tarball" -C "$_linux_package_build_dir" "Norscode.AppDir"
                _linux_package_write_sha256 "$_linux_package_tarball"
                printf 'Bygde Linux AppDir-tarball: %s\n' "$_linux_package_tarball"
                if [ "$(uname -s)" = "Linux" ] && command -v appimagetool >/dev/null 2>&1; then
                    ARCH="${ARCH:-x86_64}" appimagetool "$_linux_package_appdir" "$_linux_package_appimage" >/dev/null
                    _linux_package_write_sha256 "$_linux_package_appimage"
                    printf 'Bygde AppImage: %s\n' "$_linux_package_appimage"
                else
                    printf 'Merk: AppImage-bygging krev Linux-host og appimagetool; hoppar over AppImage.\n'
                fi
                ;;
        esac
        ;;

    docker-build-linux)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc docker-build-linux [--output FIL]\n'
            printf 'Pakk Linux x86_64 bootstrap-binær via Norscode-verktøy.\n'
            exit 0
        fi
        _require_native
        if [ "${1:-}" = "--output" ]; then
            _docker_build_linux_output="${2:-$ROOT_DIR/dist/norscode-linux-x86_64}"
            if [ "$#" -gt 2 ]; then
                printf 'bruk: nc docker-build-linux [--output FIL]\n' >&2
                exit 2
            fi
        else
            _docker_build_linux_output="${1:-$ROOT_DIR/dist/norscode-linux-x86_64}"
            if [ "$#" -gt 1 ]; then
                printf 'bruk: nc docker-build-linux [--output FIL]\n' >&2
                exit 2
            fi
        fi
        case "$_docker_build_linux_output" in
            /*) ;;
            *) _docker_build_linux_output="$ROOT_DIR/$_docker_build_linux_output" ;;
        esac
        _docker_build_linux_out="${TMPDIR:-/tmp}/norscode_docker_build_linux_$$.log"
        _docker_build_linux_rc=0
        env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \
            NORSCODE_DOCKER_BUILD_LINUX_OUTPUT="$_docker_build_linux_output" \
            "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/docker-build-linux.no" >"$_docker_build_linux_out" 2>&1 || _docker_build_linux_rc=$?
        if [ "$_docker_build_linux_rc" -eq 0 ]; then
            _nc_print_file "$_docker_build_linux_out"
            rm -f "$_docker_build_linux_out"
            exit 0
        fi
        if ! _nc_has_exec_prosess_gap "$_docker_build_linux_out"; then
            _nc_print_file_err "$_docker_build_linux_out"
            rm -f "$_docker_build_linux_out"
            exit "$_docker_build_linux_rc"
        fi
        rm -f "$_docker_build_linux_out"
        _docker_build_linux_seed="$ROOT_DIR/bootstrap/stage0/norscode-linux-x86_64"
        if [ ! -f "$_docker_build_linux_seed" ]; then
            printf 'Linux stage0-seed manglar: %s\n' "$_docker_build_linux_seed" >&2
            printf 'Hent eller bygg release-seed før Linux-artefakt blir pakka.\n' >&2
            exit 1
        fi
        _docker_build_linux_dir=${_docker_build_linux_output%/*}
        if [ "$_docker_build_linux_dir" = "$_docker_build_linux_output" ]; then
            _docker_build_linux_dir="."
        fi
        mkdir -p "$_docker_build_linux_dir"
        cp "$_docker_build_linux_seed" "$_docker_build_linux_output"
        chmod +x "$_docker_build_linux_output"
        if command -v sha256sum >/dev/null 2>&1; then
            sha256sum "$_docker_build_linux_output" > "$_docker_build_linux_output.sha256"
        elif command -v shasum >/dev/null 2>&1; then
            shasum -a 256 "$_docker_build_linux_output" > "$_docker_build_linux_output.sha256"
        fi
        _docker_build_linux_bytes=$(wc -c < "$_docker_build_linux_output")
        printf 'Bygget: %s (%s bytes)\n' "$_docker_build_linux_output" "$_docker_build_linux_bytes"
        if [ -f "$_docker_build_linux_output.sha256" ]; then
            printf 'Sjekksum: %s\n' "$_docker_build_linux_output.sha256"
        fi
        printf '\nLinux x86_64-binary klar.\n'
        printf 'Køyr for sjekk:\n'
        printf '  NORCODE_BOOTSTRAP_VM=1 NORCODE_BOOTSTRAP_CLI=1 \\\n'
        printf '    NORCODE_ARGC=1 NORCODE_ARG0=selfcheck %s\n' "$_docker_build_linux_output"
        ;;

    build-linux-stage0-docker)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc build-linux-stage0-docker\n'
            printf 'Bygg og gate Linux x86_64 stage0 via Docker.\n'
            exit 0

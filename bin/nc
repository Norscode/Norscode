        esac
        case "$_windows_layout_exe" in
            /*) ;;
            *) _windows_layout_exe="$ROOT_DIR/$_windows_layout_exe" ;;
        esac
        exec env \
            NORSCODE_ENABLE_EXEC_PROSESS=1 \
            NORSCODE_ROOT="$ROOT_DIR" \

        printf '  regen-bootstrap [--full]         Regenerer bootstrap-NCB-ar via Norscode\n'
        printf '  active-surface                   Sjekk aktiv C/Python-fri flate og overgangsreferansar\n'
        printf '  surface-ownership                Sjekk .no-eigar og Norscode-first wrapper-markørar\n'
        printf '  phase0-verify                    Fase-0 gate for aktiv selfhost-flate og eigarskap\n'
        printf '  selfhost-drift-guard             Samla selfhost driftsvakt\n'

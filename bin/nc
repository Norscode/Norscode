                        _macos_install_app="$1"
                        _macos_install_seen_app=1
                        shift
                    else
                        printf 'for mange install-macos-app-val\n' >&2
                        printf 'bruk: nc install-macos-app [APP_PATH] [--dest DIR] [--name NAMN]\n' >&2
                        exit 2
                    fi
                    ;;
            esac
        done
        case "$_macos_install_app" in
            /*) ;;
            *) _macos_install_app="$ROOT_DIR/$_macos_install_app" ;;
        esac
        case "$_macos_install_dest" in
            /*) ;;

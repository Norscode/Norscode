        exec env NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/verify_omgang6b.no" NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"

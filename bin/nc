    regen-bootstrap|bootstrap-regen)
        # kompatibilitetsmarkør: sh "$ROOT_DIR/tools/nc_regen_bootstrap.sh" --full
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc regen-bootstrap [--full]\n'

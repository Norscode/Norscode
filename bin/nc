        printf '  build-linux-stage0-docker        Bygg og gate Linux x86_64 stage0 via Docker\n'
        printf '  platform-readiness               Vis macOS/Linux plattformstatus\n'
        printf '  package-windows-app              Pakk Windows app-zip\n'
        printf '  build-windows-app-layout         Bygg Windows app-layout rundt norscode.exe\n'
        printf '  verify-macos-app                 Verifiser lokal macOS app-bundle\n'
        printf '  sign-macos-app                   Signer lokal macOS app-bundle\n'
        printf '  notarize-macos-app               Notariser macOS-artefakt\n'
        printf '  install-linux-appdir             Installer Linux AppDir-artefakt\n'

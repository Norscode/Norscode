                    _nc_print_file "$_boot_out"
                    _boot_cleanup
                    trap - EXIT HUP INT TERM
                    exit "$_boot_rc"
                fi
                _boot_cleanup
                trap - EXIT HUP INT TERM
            fi
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/bootstrap_gate.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi

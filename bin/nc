    stage0-release-assets|build-stage0-release-assets)
        _stage0_assets_platforms="macos-arm64, macos-x86_64, linux-x86_64, linux-arm64"
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc stage0-release-assets [--platform <namn>] [--out-dir <mappe>]\n'
            printf 'Bygg stage-0 release-ELF og flyttbar .sha256 via Norscode-eigarfil.\n'
            printf 'Plattformar: %s\n' "$_stage0_assets_platforms"
            printf 'Standard utmappe: release-artifacts/stage0\n'
            exit 0
        fi
        _stage0_assets_platform="${NORSCODE_STAGE0_PLATFORM:-}"
        _stage0_assets_out_dir="${NORSCODE_RELEASE_ARTIFACT_DIR:-}"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --platform)
                    if [ -z "${2:-}" ]; then
                        printf 'manglar verdi for --platform\n' >&2
                        exit 2
                    fi
                    _stage0_assets_platform="$2"
                    shift 2
                    ;;
                --out-dir)
                    if [ -z "${2:-}" ]; then
                        printf 'manglar verdi for --out-dir\n' >&2
                        exit 2
                    fi
                    _stage0_assets_out_dir="$2"
                    shift 2
                    ;;
                *)
                    printf 'ukjent stage0-release-assets-val: %s\n' "$1" >&2
                    printf 'bruk: nc stage0-release-assets [--platform <namn>] [--out-dir <mappe>]\n' >&2
                    printf 'plattformar: %s\n' "$_stage0_assets_platforms" >&2
                    exit 2
                    ;;
            esac
        done
        if [ -z "$_stage0_assets_platform" ]; then
            case "$(uname -s):$(uname -m)" in
                Darwin:arm64) _stage0_assets_platform="macos-arm64" ;;
                Darwin:x86_64) _stage0_assets_platform="macos-x86_64" ;;
                Linux:x86_64|Linux:amd64) _stage0_assets_platform="linux-x86_64" ;;
                Linux:aarch64|Linux:arm64) _stage0_assets_platform="linux-arm64" ;;
            esac
        fi
        case "$_stage0_assets_platform" in
            macos-arm64|macos-x86_64|linux-x86_64|linux-arm64) ;;
            "")
                printf 'Feil: ukjent plattform\n' >&2
                printf 'plattformar: %s\n' "$_stage0_assets_platforms" >&2
                exit 1
                ;;
            *)
                printf 'Feil: ukjent stage0-plattform: %s\n' "$_stage0_assets_platform" >&2
                printf 'plattformar: %s\n' "$_stage0_assets_platforms" >&2
                exit 2
                ;;
        esac
        _stage0_assets_out="${TMPDIR:-/tmp}/norscode_stage0_release_assets_cli_$$.log"
        _stage0_assets_rc=0
        _stage0_assets_cleanup() {
            rm -f "$_stage0_assets_out"
        }
        trap _stage0_assets_cleanup EXIT HUP INT TERM
        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NORSCODE_STAGE0_PLATFORM="$_stage0_assets_platform" NORSCODE_RELEASE_ARTIFACT_DIR="$_stage0_assets_out_dir" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/build_stage0_release_assets.no" >"$_stage0_assets_out" 2>&1 || _stage0_assets_rc=$?
        if [ "$_stage0_assets_rc" -eq 0 ]; then
            _nc_print_file "$_stage0_assets_out"
            _stage0_assets_cleanup
            exit 0
        fi
        if [ -s "$_stage0_assets_out" ] && ! _nc_has_exec_prosess_gap "$_stage0_assets_out"; then
            _nc_print_file "$_stage0_assets_out"
            _stage0_assets_cleanup
            exit "$_stage0_assets_rc"
        fi
        _stage0_assets_cleanup
        if [ -n "$_stage0_assets_platform" ]; then
            export NORSCODE_STAGE0_PLATFORM="$_stage0_assets_platform"
        fi
        if [ -n "$_stage0_assets_out_dir" ]; then
            export NORSCODE_RELEASE_ARTIFACT_DIR="$_stage0_assets_out_dir"
        fi
        sh "$ROOT_DIR/tools/build_stage0_release_assets.sh"
        exit $?
        ;;

    verify-seed|seed-only)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc verify-seed\n'
            printf 'Verifiser committed stage-0 seed utan clang/regen.\n'
            exit 0
        fi
        case "$(uname -s 2>/dev/null):$(uname -m 2>/dev/null)" in
            Darwin:arm64) _seed_platform="${NORSCODE_SEED_PLATFORM:-macos-arm64}" ;;
            Darwin:x86_64) _seed_platform="${NORSCODE_SEED_PLATFORM:-macos-x86_64}" ;;
            Linux:x86_64) _seed_platform="${NORSCODE_SEED_PLATFORM:-linux-x86_64}" ;;
            Linux:aarch64|Linux:arm64) _seed_platform="${NORSCODE_SEED_PLATFORM:-linux-arm64}" ;;
            MINGW*:x86_64|MSYS*:x86_64|CYGWIN*:x86_64) _seed_platform="${NORSCODE_SEED_PLATFORM:-windows-x86_64}" ;;
            *) _seed_platform="${NORSCODE_SEED_PLATFORM:-}" ;;
        esac
        _seed_out="${TMPDIR:-/tmp}/norscode_verify_seed_$$.log"
        _seed_rc=0
        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NORSCODE_SEED_PLATFORM="$_seed_platform" NORSCODE_NATIVE_BIN="${NORSCODE_NATIVE_BIN:-}" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/verify_seed_only.no" >"$_seed_out" 2>&1 || _seed_rc=$?
        if [ "$_seed_rc" -eq 0 ]; then
            _nc_print_file "$_seed_out"
            rm -f "$_seed_out"
            exit 0
        fi
        if [ -s "$_seed_out" ] && ! _nc_has_exec_prosess_gap "$_seed_out"; then
            _nc_print_file_err "$_seed_out"
            rm -f "$_seed_out"
            exit "$_seed_rc"
        fi
        rm -f "$_seed_out"
        bash "$ROOT_DIR/tools/verify_seed_only.sh" "$@"
        exit $?
        ;;

    fetch-stage0-seed)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc fetch-stage0-seed [plattform]\n'
            printf 'Last ned ferdig native stage-0 seed frå release.\n'
            exit 0
        fi
        _stage0_platform="${1:-${NORSCODE_STAGE0_PLATFORM:-}}"
        if [ -z "$_stage0_platform" ]; then
            case "$(uname -s 2>/dev/null):$(uname -m 2>/dev/null)" in
                Darwin:arm64) _stage0_platform="macos-arm64" ;;
                Darwin:x86_64) _stage0_platform="macos-x86_64" ;;
                Linux:x86_64|Linux:amd64) _stage0_platform="linux-x86_64" ;;
                Linux:aarch64|Linux:arm64) _stage0_platform="linux-arm64" ;;
                MINGW*:x86_64|MSYS*:x86_64|CYGWIN*:x86_64) _stage0_platform="windows-x86_64" ;;
            esac
        fi
        _stage0_seed_bytes=""
        _stage0_seed_path="$ROOT_DIR/bootstrap/stage0/norscode-$_stage0_platform"
        case "$_stage0_platform" in windows-*) _stage0_seed_path="$_stage0_seed_path.exe" ;; esac
        if [ -n "$_stage0_platform" ] && [ -f "$_stage0_seed_path" ]; then
            set -- $(wc -c "$_stage0_seed_path")
            _stage0_seed_bytes="${1:-}"
        fi
        _stage0_out="${TMPDIR:-/tmp}/norscode_fetch_stage0_seed_$$.log"
        _stage0_rc=0
        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NORSCODE_STAGE0_PLATFORM="$_stage0_platform" NORSCODE_STAGE0_SEED_BYTES="$_stage0_seed_bytes" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/fetch_stage0_seed.no" >"$_stage0_out" 2>&1 || _stage0_rc=$?
        if [ "$_stage0_rc" -eq 0 ]; then
            _nc_print_file "$_stage0_out"
            rm -f "$_stage0_out"
            exit 0
        fi
        if [ -s "$_stage0_out" ] && ! _nc_has_exec_prosess_gap "$_stage0_out"; then
            _nc_print_file_err "$_stage0_out"
            rm -f "$_stage0_out"
            exit "$_stage0_rc"
        fi
        rm -f "$_stage0_out"
        bash "$ROOT_DIR/tools/fetch_stage0_seed.sh" "$@"
        exit $?
        ;;

    ncb-to-elf)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc ncb-to-elf fil.ncb.json ut.elf\n'
            printf 'Konverter NCB JSON til native ELF.\n'
            exit 0
        fi
        _require_native
        if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
            printf 'bruk: nc ncb-to-elf fil.ncb.json ut.elf\n' >&2
            exit 2
        fi
        if [ ! -f "$1" ]; then
            printf 'nc ncb-to-elf: finn ikkje fil %s\n' "$1" >&2
            printf 'bruk: nc ncb-to-elf fil.ncb.json ut.elf\n' >&2
            exit 2
        fi
        _ncb_to_elf_out="${TMPDIR:-/tmp}/norscode_ncb_to_elf_$$.log"
        _ncb_to_elf_rc=0
        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NORSCODE_NCB_TO_ELF_INPUT="$1" NORSCODE_NCB_TO_ELF_OUTPUT="$2" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/ncb_to_elf.no" >"$_ncb_to_elf_out" 2>&1 || _ncb_to_elf_rc=$?
        if [ "$_ncb_to_elf_rc" -eq 0 ]; then
            _nc_print_file "$_ncb_to_elf_out"
            rm -f "$_ncb_to_elf_out"
            exit 0
        fi
        if [ -s "$_ncb_to_elf_out" ] && ! _nc_has_exec_prosess_gap "$_ncb_to_elf_out"; then
            _nc_print_file "$_ncb_to_elf_out"
            rm -f "$_ncb_to_elf_out"
            exit "$_ncb_to_elf_rc"
        fi
        rm -f "$_ncb_to_elf_out"
        printf 'nc ncb-to-elf: native Norscode-runtime manglar exec_prosess; releaseflata stoppar utan shell-reserve\n' >&2
        exit 1
        ;;

    regen-fraser)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc regen-fraser\n'
            printf 'Regenerer fraser-tabell i selfhost/common.no.\n'
            exit 0
        fi
        _require_native
        exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/scripts/regen_fraser.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        ;;

    feature-check|feature)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc feature-check [fil.no ...]\n'
            printf 'Sjekk nye Norscode-funksjonar utan C/Python.\n'
            exit 0
        fi
        _require_native
        _feature_files=""
        for _feature_file in "$@"; do
            _feature_files="${_feature_files}${_feature_file}
"
        done
        _feature_out="${TMPDIR:-/tmp}/norscode_feature_gate_$$.log"
        _feature_rc=0
        env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NORSCODE_FEATURE_FILES="$_feature_files" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/norscode_feature_gate.no" >"$_feature_out" 2>&1 || _feature_rc=$?
        if [ "$_feature_rc" -eq 0 ]; then
            _nc_print_file "$_feature_out"
            rm -f "$_feature_out"
            exit 0
        fi
        if [ -s "$_feature_out" ] && ! _nc_has_exec_prosess_gap "$_feature_out"; then
            _nc_print_file "$_feature_out"
            rm -f "$_feature_out"
            exit "$_feature_rc"
        fi
        rm -f "$_feature_out"
        sh "$ROOT_DIR/tools/norscode_feature_gate.sh" "$@"
        exit $?
        ;;

    bygg-native|bygg-native-v2)
        # Omgang 6: kompiler NCB til native ELF via native_codegen_v2.no (full NcVal-runtime)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc bygg-native [fil.no ut]\n'
            printf 'bruk: nc bygg-native --ncb fil.ncb.json ut.elf\n'
            printf 'bruk: nc bygg-native --target macos-arm64 --ncb fil.ncb.json ut\n'
            printf 'bruk: nc bygg-native --target macos-arm64 fil.no ut\n'
            printf 'bruk: nc bygg-native --target linux-x86_64 [--ncb] fil ut\n'
            printf 'bruk: nc bygg-native --target linux-arm64 [--ncb] fil ut\n'
            printf 'Bygg sjølvstendig native ELF med NCB innebygd.\n'
            exit 0
        fi
        _require_native
        if [ "${1:-}" = "--target" ] && [ "${2:-}" = "linux-arm64" ]; then
            if [ "${3:-}" = "--ncb" ]; then
                _linux_arm_input="${4:-}"
                _linux_arm_output="${5:-}"
            else
                _linux_arm_source="${3:-}"
                _linux_arm_output="${4:-}"
                if [ -z "$_linux_arm_source" ] || [ -z "$_linux_arm_output" ]; then
                    printf 'bruk: nc bygg-native --target linux-arm64 fil.no ut\n' >&2
                    exit 2
                fi
                if [ ! -f "$_linux_arm_source" ]; then
                    printf 'nc bygg-native linux-arm64: finn ikkje fil %s\n' "$_linux_arm_source" >&2
                    exit 2
                fi
                _linux_arm_input="${TMPDIR:-/tmp}/norscode_linux_arm_aot_$$.ncb.json"
                _linux_arm_cleanup() { rm -f "$_linux_arm_input"; }
                trap _linux_arm_cleanup EXIT HUP INT TERM
                _linux_arm_project="$(_find_project_root "$(dirname "$_linux_arm_source")")"
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_HYBRID_ROOT="$ROOT_DIR" NORSCODE_HYBRID_SRC="$_linux_arm_source" NORSCODE_HYBRID_OUT="$_linux_arm_input" NORSCODE_HYBRID_MODULE=__main__ NORSCODE_HYBRID_PROJECT_ROOT="$_linux_arm_project" NORSCODE_NATIVE_BIN="$NC_NATIVE" NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,$_linux_arm_project,.,${TMPDIR:-/tmp},/tmp,/private/tmp" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.no" "$NC_NATIVE" || exit $?
            fi
            if [ -z "$_linux_arm_input" ] || [ -z "$_linux_arm_output" ]; then
                printf 'bruk: nc bygg-native --target linux-arm64 [--ncb] fil ut\n' >&2
                exit 2
            fi
            if [ ! -f "$_linux_arm_input" ]; then
                printf 'nc bygg-native linux-arm64: finn ikkje fil %s\n' "$_linux_arm_input" >&2
                exit 2
            fi
            _linux_arm_rc=0
            env NORSCODE_RUN_DIRECT_HOST=1 NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp,$(dirname "$_linux_arm_output")" NC_INPUT="$_linux_arm_input" NC_OUTPUT="$_linux_arm_output" \
                "$ROOT_DIR/bin/nc" run "$ROOT_DIR/selfhost/native_execution/elf_arm64_codegen.no" || _linux_arm_rc=$?
            if [ "${_linux_arm_source:-}" != "" ]; then
                _linux_arm_cleanup
                trap - EXIT HUP INT TERM
            fi
            exit "$_linux_arm_rc"
        fi
        if [ "${1:-}" = "--target" ] && [ "${2:-}" = "linux-x86_64" ]; then
            if [ "${3:-}" = "--ncb" ]; then
                _linux_input="${4:-}"
                _linux_output="${5:-}"
            else
                _linux_source="${3:-}"
                _linux_output="${4:-}"
                if [ -z "$_linux_source" ] || [ -z "$_linux_output" ]; then
                    printf 'bruk: nc bygg-native --target linux-x86_64 fil.no ut\n' >&2
                    exit 2
                fi
                if [ ! -f "$_linux_source" ]; then
                    printf 'nc bygg-native linux-x86_64: finn ikkje fil %s\n' "$_linux_source" >&2
                    exit 2
                fi
                _linux_input="${TMPDIR:-/tmp}/norscode_linux_aot_$$.ncb.json"
                _linux_cleanup() { rm -f "$_linux_input"; }
                trap _linux_cleanup EXIT HUP INT TERM
                _linux_project="$(_find_project_root "$(dirname "$_linux_source")")"
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_HYBRID_ROOT="$ROOT_DIR" NORSCODE_HYBRID_SRC="$_linux_source" NORSCODE_HYBRID_OUT="$_linux_input" NORSCODE_HYBRID_MODULE=__main__ NORSCODE_HYBRID_PROJECT_ROOT="$_linux_project" NORSCODE_NATIVE_BIN="$NC_NATIVE" NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,$_linux_project,.,${TMPDIR:-/tmp},/tmp,/private/tmp" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.no" "$NC_NATIVE" || exit $?
            fi
            if [ -z "$_linux_input" ] || [ -z "$_linux_output" ]; then
                printf 'bruk: nc bygg-native --target linux-x86_64 [--ncb] fil ut\n' >&2
                exit 2
            fi
            if [ ! -f "$_linux_input" ]; then
                printf 'nc bygg-native linux-x86_64: finn ikkje fil %s\n' "$_linux_input" >&2
                exit 2
            fi
            _linux_rc=0
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp,$(dirname "$_linux_output")" NC_INPUT="$_linux_input" NC_OUTPUT="$_linux_output" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/native_execution/native_codegen_v2.no" "$NC_NATIVE" || _linux_rc=$?
            if [ "${_linux_source:-}" != "" ]; then
                _linux_cleanup
                trap - EXIT HUP INT TERM
            fi
            exit "$_linux_rc"
        fi
        if [ "${1:-}" = "--target" ]; then
            if [ "${2:-}" != "macos-arm64" ]; then
                printf 'bruk: nc bygg-native --target macos-arm64 [--ncb] fil ut\n' >&2
                exit 2
            fi
            if [ "${3:-}" = "--ncb" ]; then
                _mac_input="${4:-}"
                _mac_output="${5:-}"
            else
                _mac_source="${3:-}"
                _mac_output="${4:-}"
                if [ -z "$_mac_source" ] || [ -z "$_mac_output" ]; then
                    printf 'bruk: nc bygg-native --target macos-arm64 fil.no ut\n' >&2
                    exit 2
                fi
                if [ ! -f "$_mac_source" ]; then
                    printf 'nc bygg-native macos-arm64: finn ikkje fil %s\n' "$_mac_source" >&2
                    exit 2
                fi
                _mac_input="${TMPDIR:-/tmp}/norscode_macos_aot_$$.ncb.json"
                _mac_cleanup() { rm -f "$_mac_input"; }
                trap _mac_cleanup EXIT HUP INT TERM
                _mac_project="$(_find_project_root "$(dirname "$_mac_source")")"
                env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_HYBRID_ROOT="$ROOT_DIR" NORSCODE_HYBRID_SRC="$_mac_source" NORSCODE_HYBRID_OUT="$_mac_input" NORSCODE_HYBRID_MODULE=__main__ NORSCODE_HYBRID_PROJECT_ROOT="$_mac_project" NORSCODE_NATIVE_BIN="$NC_NATIVE" NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,$_mac_project,.,${TMPDIR:-/tmp},/tmp,/private/tmp" NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/tools/compile_with_hybrid_bundle_v9400.no" "$NC_NATIVE" || exit $?
            fi
            if [ -z "$_mac_input" ] || [ -z "$_mac_output" ]; then
                printf 'bruk: nc bygg-native --target macos-arm64 [--ncb] fil ut\n' >&2
                exit 2
            fi
            if [ ! -f "$_mac_input" ]; then
                printf 'nc bygg-native macos-arm64: finn ikkje fil %s\n' "$_mac_input" >&2
                exit 2
            fi
            _mac_rc=0
            env NORSCODE_RUN_DIRECT_HOST=1 NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="env.read,process.exec,disk.read,disk.write" NORSCODE_VM_DISK_ROOT="$ROOT_DIR,.,${TMPDIR:-/tmp},/tmp,/private/tmp,$(dirname "$_mac_output")" NC_INPUT="$_mac_input" NC_OUTPUT="$_mac_output" \
                "$ROOT_DIR/bin/nc" run "$ROOT_DIR/selfhost/native_execution/macho_arm64_codegen.no" || _mac_rc=$?
            if [ "${_mac_source:-}" != "" ]; then
                _mac_cleanup
                trap - EXIT HUP INT TERM
            fi
            exit "$_mac_rc"
        fi
        if [ "${1:-}" = "--ncb" ]; then
            if [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
                printf 'bruk: nc bygg-native --ncb fil.ncb.json ut.elf\n' >&2
                exit 2
            fi
            if [ ! -f "$2" ]; then
                printf 'nc bygg-native --ncb: finn ikkje fil %s\n' "$2" >&2
                printf 'bruk: nc bygg-native --ncb fil.ncb.json ut.elf\n' >&2
                exit 2
            fi
            _ncb_to_elf_out="${TMPDIR:-/tmp}/norscode_ncb_to_elf_$$.log"
            _ncb_to_elf_rc=0
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" NORSCODE_NCB_TO_ELF_INPUT="$2" NORSCODE_NCB_TO_ELF_OUTPUT="$3" "$ROOT_DIR/bin/nc" run "$ROOT_DIR/tools/ncb_to_elf.no" >"$_ncb_to_elf_out" 2>&1 || _ncb_to_elf_rc=$?
            if [ "$_ncb_to_elf_rc" -eq 0 ]; then
                _nc_print_file "$_ncb_to_elf_out"
                rm -f "$_ncb_to_elf_out"
                exit 0
            fi
            if [ -s "$_ncb_to_elf_out" ] && ! _nc_has_exec_prosess_gap "$_ncb_to_elf_out"; then
                _nc_print_file "$_ncb_to_elf_out"
                rm -f "$_ncb_to_elf_out"
                exit "$_ncb_to_elf_rc"
            fi
            rm -f "$_ncb_to_elf_out"
            printf 'nc bygg-native --ncb: native Norscode-runtime manglar exec_prosess; releaseflata stoppar utan shell-reserve\n' >&2
            exit 1
        fi
        _src="${1:-}"
        _out="${2:-a.out}"
        _codegen="$ROOT_DIR/selfhost/native_execution/native_codegen_v2.no"
        _native_caps="${NORSCODE_VM_CAPABILITIES:-env.read,disk.read,disk.write}"
        _native_disk="$ROOT_DIR,${NORSCODE_VM_DISK_ROOT:-$ROOT_DIR,$(dirname "$_out"),.,${TMPDIR:-/tmp},/tmp,/private/tmp}"
        if [ -z "$_src" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="$_native_caps" NORSCODE_VM_DISK_ROOT="$_native_disk" NORSCODE_CMD=run \
                NORSCODE_FILE="$_codegen" \
                NORSCODE_ROOT="$ROOT_DIR" \
                NC_INPUT="$ROOT_DIR/bootstrap/kompiler.ncb.json" \
                NC_OUTPUT="$_out" \
                "$NC_NATIVE"
        else
            _tmpncb="$(mktemp "${TMPDIR:-/tmp}/nc_bygg_native_XXXXXX.ncb.json" 2>/dev/null || printf '%s/nc_bygg_native_%s.ncb.json' "${TMPDIR:-/tmp}" "$$")"
            trap 'rm -f "$_tmpncb"' EXIT
            env NORSCODE_ENABLE_EXEC_PROSESS="${NORSCODE_ENABLE_EXEC_PROSESS:-1}" NORSCODE_VM_CAPABILITIES="$_native_caps" NORSCODE_VM_DISK_ROOT="$_native_disk" NORSCODE_CMD=compile NORSCODE_FILE="$_src" NORSCODE_OUTPUT="$_tmpncb" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE" >/dev/null
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_VM_CAPABILITIES="$_native_caps" NORSCODE_VM_DISK_ROOT="$_native_disk" NORSCODE_CMD=run \
                NORSCODE_FILE="$_codegen" \
                NORSCODE_ROOT="$ROOT_DIR" \
                NC_INPUT="$_tmpncb" \
                NC_OUTPUT="$_out" \
                "$NC_NATIVE"
        fi
        ;;

    ci)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            printf 'bruk: nc ci [fil.no ...]\n'
            printf 'Køyr CI-gate lokalt.\n'
            exit 0
        fi
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/phase2_ci.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
            env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/phase2_benchmark.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        exec env NC_CI=1 NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_ROOT="$ROOT_DIR" "$ROOT_DIR/bin/nc" test "$@"
        ;;

    identity|release|release-targets)
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "$CMD" in
                identity) printf 'bruk: nc identity\n' ;;
                release) printf 'bruk: nc release\n' ;;
                release-targets) printf 'bruk: nc release-targets\n' ;;
            esac
            printf 'Køyr historisk selfhost-main-kommando via Norscode runtime.\n'
            exit 0
        fi
        _require_nc_vm
        if [ -x "$NC_NATIVE" ]; then
            exec env NORSCODE_ENABLE_EXEC_PROSESS=1 NORSCODE_CMD=run NORSCODE_FILE="$ROOT_DIR/selfhost/main.no" NORSCODE_ROOT="$ROOT_DIR" "$NC_NATIVE"
        fi
        printf 'nc: treng dist/norscode_native\n' >&2; exit 1
        ;;

    --version|-V|version)
        printf 'Norscode %s\n' "$(_nc_version)"
        exit 0
        ;;

    commands|help|--help|-h)
        printf 'Norscode %s — C/Python-fri CLI (norscode_native)\n\n' "$(_nc_version)"
        printf 'Normal bruk:\n'
        printf '  run <fil.no>                     Kompiler og køyr, med bundla imports ved vanlege bruk/importer\n'
        printf '  run-pure <fil.no>                Kompiler og køyr i rein selfhost-VM\n'
        printf '  run-ncb-pure <fil.ncb.json>      Køyr NCB i rein selfhost-VM\n'
        printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode\n'
        printf '  build <fil.no> <ut.ncb.json>     Kompiler (alias for compile)\n'
        printf '  check <fil.no>                   Syntaks- og semantikksjekk\n'
        printf '  bundle [mod=fil.no ...]          Bundle modular\n'
        printf '  format <fil.no> [--write|--check] Formater kjeldekode\n'
        printf '  lint <fil.no> [--check]          Lint kjeldekode\n'
        printf '  doctor                           Systemsjekk\n'
        printf '  lsp                              Køyr LSP-grunnmur/selftest\n'
        printf '  repl [uttrykk]                   Interaktiv REPL eller evaluer uttrykk\n'
        printf '  test                             Køyr testar\n'
        printf '  selftest                         Køyr nc_main selftest\n'
        printf '  selfcheck                        Verifiser kompilatoren\n'
        printf '\nVedlikehald:\n'
        printf '  maintenance [status|lane|docs|cleanup|seed|tests|maturity|summary|report|report-json|verify]  Norscode-basert vedlikehald\n'
        printf '  release-preflight [--strict]     Lokal release-sjekk utan publisering\n'
        printf '  completion-gate --local|--release Autoritativ Norscode 1.0-sluttport\n'
        printf '  package-release <versjon>        Bygg releasepakke lokalt utan publisering\n'
        printf '  install-release <arkiv>          Installer releasepakke lokalt\n'
        printf '  build-macos-app                  Bygg lokal macOS .app-bundle\n'
        printf '  build-macos-window-host          Bygg minimal macOS GUI-host\n'
        printf '  package-macos-app                Pakk macOS app-artefaktar\n'
        printf '  package-linux-app                Pakk Linux AppDir/tarball/AppImage\n'
        printf '  docker-build-linux               Pakk Linux x86_64 bootstrap-binær\n'
        printf '  build-linux-stage0-docker        Bygg og gate Linux x86_64 stage0 via Docker\n'
        printf '  platform-readiness               Vis macOS/Linux plattformstatus\n'
        printf '  package-windows-app              Pakk Windows app-zip\n'
        printf '  build-windows-app-layout         Bygg Windows app-layout rundt norscode.exe\n'
        printf '  verify-macos-app                 Verifiser lokal macOS app-bundle\n'
        printf '  sign-macos-app                   Signer lokal macOS app-bundle\n'
        printf '  notarize-macos-app               Notariser macOS-artefakt\n'

#!/usr/bin/env sh
# bin/nc - Norscode CLI (native-first, eksplisitt legacy Python-fallback)
#
# Rekkefølge:
#   1. dist/norcode-bootstrap-compile  (ekte native Norscode-kompilator)
#   2. legacy Python-bane              (kun med --legacy-python-fallback)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC_VM="$ROOT_DIR/dist/nc-vm"
NATIVE_BIN="$ROOT_DIR/dist/norcode-bootstrap-compile"
LEGACY_ENTRYPOINT="norcode.legacy_main"
PYTHON_FALLBACK=0
FILTERED_ARGS=

# ─── Hjelpefunksjon: les version fra norcode.toml ───────────────────────────
_nc_version() {
    _toml="$ROOT_DIR/norcode.toml"
    if [ -f "$_toml" ]; then
        grep '^version' "$_toml" | head -1 | sed 's/.*= *"\(.*\)"/\1/'
    else
        printf 'ukjent'
    fi
}

# ─── Normaliser argumenter og fang eksplisitt legacy Python-fallback ────────
for _arg in "$@"; do
    if [ "$_arg" = "--python-fallback" ] || [ "$_arg" = "--legacy-python-fallback" ]; then
        PYTHON_FALLBACK=1
        continue
    fi
    if [ -z "$FILTERED_ARGS" ]; then
        FILTERED_ARGS="$_arg"
    else
        FILTERED_ARGS="${FILTERED_ARGS}
$_arg"
    fi
done

if [ "$PYTHON_FALLBACK" = "1" ]; then
    _old_ifs=$IFS
    set -f
    IFS='
'
    set --
    if [ -n "$FILTERED_ARGS" ]; then
        for _arg in $FILTERED_ARGS; do
            set -- "$@" "$_arg"
        done
    fi
    IFS=$_old_ifs
    set +f
fi

# ─── selfhost-bootstrap-gate: alltid via selfhost-kjede (.no-logikk) ────────
# Kommandoen køyrer bootstrap_gate.no gjennom selfhost-chain-run, slik at
# gate-logikken er skrive i Norscode og ikkje i Python.
if [ $# -ge 1 ] && [ "$1" = "selfhost-bootstrap-gate" ]; then
    if [ "$PYTHON_FALLBACK" != "1" ]; then
        printf 'Norscode: kommandoen selfhost-bootstrap-gate krever --legacy-python-fallback.\n' >&2
        exit 2
    fi
    shift
    printf 'Advarsel: Python-fallback brukes. Dette er overgangsstøtte, ikke primær Norscode-bane.\n' >&2
    exec python3 -m "$LEGACY_ENTRYPOINT" selfhost-chain-run \
        "$ROOT_DIR/selfhost/bootstrap_gate.no" \
        --max-steps 100000000 \
        "$@"
    printf 'Norscode: fant ikke Python-backend for selfhost-chain-run.\n' >&2
    exit 1
fi

# ─── Native bootstrap-kompilator ────────────────────────────────────────────
if [ -x "$NATIVE_BIN" ] && [ $# -ge 1 ]; then
    CMD="$1"; shift

    case "$CMD" in

        run)
            SRC="${1:-app.no}"
            ARCH="${2:-aarch64}"

            # ── Prioritet 1: nc-vm --nc-run (selfhost-kompilator, fullt Python-fri) ─
            if [ -x "$NC_VM" ]; then
                if [ -f "$SRC" ]; then
                    exec "$NC_VM" --nc-run "$SRC"
                fi
            fi

            # ── Prioritet 2: nc-vm med pre-kompilert .ncb.json ──────────────
            if [ -x "$NC_VM" ]; then
                _ncb="${SRC%.no}.ncb.json"
                if [ -f "$_ncb" ]; then
                    exec "$NC_VM" "$_ncb"
                fi
                _basename="$(basename "$SRC" .no)"
                _ncb2="$ROOT_DIR/build/nc-precompiled/${_basename}.ncb.json"
                if [ -f "$_ncb2" ]; then
                    exec "$NC_VM" "$_ncb2"
                fi
            fi

            # ── Prioritet 3: native AArch64-pipeline ────────────────────────
            mkdir -p "$ROOT_DIR/build"
            OUT="$ROOT_DIR/build/_nc_run.elf"
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=run
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "$NATIVE_BIN"
            ;;

        build)
            SRC="${1:-}"
            OUT="${2:-}"
            ARCH="${3:-aarch64}"
            if [ -z "$SRC" ] || [ -z "$OUT" ]; then
                printf 'bruk: nc build <kilde.no> <utdata.elf> [aarch64|x86_64]\n' >&2
                exit 2
            fi
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=build
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "$NATIVE_BIN"
            ;;

        check)
            # Syntaks- og semantikksjekk uten å kjøre.
            # Bygger til en tempfil og sletter den – exit-koden er svaret.
            SRC="${1:-}"
            if [ -z "$SRC" ]; then
                printf 'bruk: nc check <kilde.no>\n' >&2
                exit 2
            fi
            _tmpdir="$(mktemp -d)"
            _rc=0
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=build
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$_tmpdir/_check.elf"
            export NORCODE_ARCH="aarch64"
            "$NATIVE_BIN" && printf '%s: OK\n' "$SRC" || _rc=$?
            rm -rf "$_tmpdir"
            exit "$_rc"
            ;;

        --version|-V|version)
            printf 'Norscode %s\n' "$(_nc_version)"
            exit 0
            ;;

        commands)
            printf 'Norscode CLI – Python-fri kommandoer:\n'
            printf '  run <fil.no>                     Kompiler og kjør (nc-vm, ingen Python)\n'
            printf '  compile <fil.no> [ut.ncb.json]   Kompiler til bytekode (ingen Python)\n'
            printf '  build <fil.no> <ut.elf> [arch]   Kompiler til native binary\n'
            printf '  check <fil.no>                   Valider syntaks og semantikk\n'
            printf '  test                             Kjør testsuite\n'
            printf '  selfcheck                        Verifiser kompilatoren\n'
            printf '  identity                         Kompilatoridentitet\n'
            printf '  release                          Bygg release\n'
            printf '  ci --bootstrap-lane              CI-gate (selfhost)\n'
            printf '  --version                        Vis versjon\n'
            printf '  --legacy-python-fallback         Tving legacy Python-backend\n'
            printf '  help                             Vis hjelp\n'
            printf '\nAndre kommandoer krever --legacy-python-fallback:\n'
            printf '  repl serve format lint add lock update migrate-names smoke doctor ...\n'
            exit 0
            ;;

        compile)
            # Delegerer direkte til nc-vm --nc-compile (Python-fri)
            SRC="${1:-}"
            OUT="${2:-}"
            if [ -z "$SRC" ]; then
                printf 'bruk: nc compile <kilde.no> [utdata.ncb.json]\n' >&2
                exit 2
            fi
            if [ ! -x "$NC_VM" ]; then
                printf 'nc compile: nc-vm ikke funnet: %s\n' "$NC_VM" >&2
                exit 1
            fi
            if [ -n "$OUT" ]; then
                exec "$NC_VM" --nc-compile "$SRC" "$OUT"
            else
                exec "$NC_VM" --nc-compile "$SRC"
            fi
            ;;

        native-build)
            # Bygg til native ELF via Python-native-pipeline (ingen clang)
            # Delegerer til Python, men denne pipelinen bruker ikke clang
            set -- "$CMD" "$@"
            ;;

        native-run)
            # Bygg og kjør native ELF via Python-native-pipeline (ingen clang)
            set -- "$CMD" "$@"
            ;;

        ci)
            # ci --bootstrap-lane → native selfcheck
            # Andre ci-flagg faller tilbake til Python
            _is_bootstrap_lane=0
            for _a in "$@"; do
                if [ "$_a" = "--bootstrap-lane" ]; then _is_bootstrap_lane=1; fi
            done
            if [ "$_is_bootstrap_lane" = "1" ]; then
                export NORCODE_BOOTSTRAP_VM=1
                export NORCODE_BOOTSTRAP_CLI=1
                export NORCODE_ARGC=1
                export NORCODE_ARG0=selfcheck
                exec "$NATIVE_BIN"
            fi
            set -- "$CMD" "$@"
            ;;

        test|selfcheck|identity|release|release-targets|help|--help|-h)
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_BOOTSTRAP_CLI=1
            NORCODE_ARGC=$(( $# + 1 ))
            export NORCODE_ARGC
            export NORCODE_ARG0="$CMD"
            _i=1
            for _arg in "$@"; do
                eval "export NORCODE_ARG$_i=\$_arg"
                _i=$(( _i + 1 ))
            done
            exec "$NATIVE_BIN"
            ;;

        *)
            if [ "$PYTHON_FALLBACK" = "1" ]; then
                printf 'Advarsel: legacy Python-fallback brukes. Dette er overgangsstøtte, ikke primær Norscode-bane.\n' >&2
                exec python3 -m "$LEGACY_ENTRYPOINT" "$CMD" "$@"
            fi
            printf 'Norscode: kommandoen "%s" krever --legacy-python-fallback.\n' "$CMD" >&2
            exit 2
            ;;
    esac
fi

# ─── Python-fallback for native bin manglar eller er ikkje tilgjengeleg ─────
if [ "$PYTHON_FALLBACK" = "1" ]; then
    printf 'Advarsel: legacy Python-fallback brukes. Dette er overgangsstøtte, ikke primær Norscode-bane.\n' >&2
    exec python3 -m "$LEGACY_ENTRYPOINT" "$@"
fi

printf 'Norscode: fant ingen kjørbar kompilator.\n' >&2
printf 'Installer med: bash tools/build-bootstrap-binary.sh\n' >&2
printf 'Forventet native binary: %s\n' "$NATIVE_BIN" >&2
printf 'Bruk --legacy-python-fallback for overgangsstøtte.\n' >&2
exit 1

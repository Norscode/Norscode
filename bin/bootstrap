#!/usr/bin/env sh
# bin/bootstrap - Norscode fallback-launcher
#
# Historisk alias. Normal CLI går via bin/nc og dist/norscode_native.
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NC="${ROOT_DIR}/bin/nc"

if [ -x "$NC" ]; then
    exec "$NC" "$@"
fi

printf 'Norscode: fant ikkje bin/nc.\n' >&2
printf 'Køyr frå repo-rota eller installer releasepakken på nytt.\n' >&2
exit 1

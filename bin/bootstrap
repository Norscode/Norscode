#!/usr/bin/env sh
# bin/bootstrap - Norscode fallback-launcher
#
# Rekkefølge:
#   1. dist/norcode-bootstrap-compile  (native)
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
NATIVE_BIN="${ROOT_DIR}/dist/norcode-bootstrap-compile"

# Prøv native kompilator for run/build
if [ -x "${NATIVE_BIN}" ] && [ $# -ge 1 ]; then
    CMD="$1"; shift
    case "$CMD" in
        run)
            SRC="${1:-app.no}"
            ARCH="${2:-aarch64}"
            mkdir -p "${ROOT_DIR}/build"
            OUT="${ROOT_DIR}/build/_bootstrap_run.elf"
            export NORCODE_BOOTSTRAP_VM=1
            export NORCODE_CMD=run
            export NORCODE_SRC="$SRC"
            export NORCODE_OUT="$OUT"
            export NORCODE_ARCH="$ARCH"
            exec "${NATIVE_BIN}"
            ;;
        build)
            SRC="${1:-}"
            OUT="${2:-}"
            ARCH="${3:-aarch64}"
            if [ -n "$SRC" ] && [ -n "$OUT" ]; then
                export NORCODE_BOOTSTRAP_VM=1
                export NORCODE_CMD=build
                export NORCODE_SRC="$SRC"
                export NORCODE_OUT="$OUT"
                export NORCODE_ARCH="$ARCH"
                exec "${NATIVE_BIN}"
            fi
            ;;
    esac
    set -- "$CMD" "$@"
fi

printf 'Norscode: fant ingen kjørbar kompilator.\n' >&2
printf 'Kjør: ./bin/nc run tools/build-bootstrap-binary.no\n' >&2
exit 1

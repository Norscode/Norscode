#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
BINARY="$ROOT_DIR/dist/norscode"
if [ ! -x "$BINARY" ]; then
  BINARY="$ROOT_DIR/../dist/norscode"
fi
if [ ! -x "$BINARY" ]; then
  BINARY="$ROOT_DIR/../../dist/norscode"
fi

if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
fi

printf 'Norscode binary not found at: %s\n' "$BINARY" >&2
printf 'Bygg dist/norscode for normal bruk, eller bruk ./bin/bootstrap eller ./bin/nc --legacy-python-fallback eksplisitt som fallback.\n' >&2
exit 1

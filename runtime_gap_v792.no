funksjon start() -> heiltall {
    skriv("Norscode v792 runtime-gap diagnose\n")
    skriv("----------------------------------\n")

    skriv("[TEST] exec_prosess\n")
    prøv {
        la res = builtin.exec_prosess("echo ok")
        skriv("[OK] exec_prosess=" + res[1] + "\n")
    } fang (e) {
        skriv("[MANGLER] exec_prosess: " + e + "\n")
    }

    skriv("[TEST] random_hex\n")
    prøv {
        la r = builtin.random_hex(16)
        skriv("[OK] random_hex=" + r + "\n")
    } fang (e) {
        skriv("[MANGLER] random_hex: " + e + "\n")
    }

    skriv("[TEST] tid\n")
    prøv {
        la t = builtin.tid()
        skriv("[OK] tid=" + t + "\n")
    } fang (e) {
        skriv("[MANGLER] tid/now/timestamp: " + e + "\n")
    }

    skriv("\nKonklusjon:\n")
    skriv("DEV web/admin kan brukes.\n")
    skriv("Produksjon er blokkert til stage0 runtime får ekte builtin-støtte.\n")
    returner 0
}

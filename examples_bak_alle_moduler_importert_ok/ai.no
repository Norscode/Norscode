bruk std.ai som ai

funksjon start() -> heiltall {
    la modell = ai.lokal("norscode-local-1")
    la svar = ai.chat(modell, "Svar kort på norsk", "Kva er Norscode AI?")
    la emb = ai.embedding("Norscode")
    la mod = ai.moderer("ingen hemmeligheter her")
    la plan = ai.agent_plan("bruk search til å finne docs", [
        ai.verktøy("search", "Søk i dokumentasjon"),
        ai.verktøy("run", "Køyr ein trygg kommando")
    ])

    skriv(svar["text"])
    skriv(emb["vector"])
    skriv(mod["category"])
    skriv(plan["tool"])
    returner 0
}

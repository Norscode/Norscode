bruk std.cache som cache

funksjon start() -> heltall {
    la c = cache.ny_minne()

    assert_eq(cache.statistikk(c)["type"], "minne")
    assert_eq(cache.sett(c, "side", "hjem", 60), 1)
    assert(cache.har(c, "side"))
    assert_eq(cache.hent(c, "side", ""), "hjem")
    assert_eq(cache.inkrementer(c, "treff", 2), 2)
    assert_eq(cache.dekrementer(c, "treff", 1), 1)
    assert_eq(cache.slett(c, "side"), 1)
    assert(ikke cache.har(c, "side"))
    assert_eq(cache.tøm(c), 1)

    returner 0
}

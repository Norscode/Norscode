# api_advanced.no — Advanced Norscode REST API
# Demonstrerer:
# - VM-integration (når det kjem)
# - Async handlers
# - OpenAPI/Swagger
# - File uploads
# - TLS/HTTPS (when configured)
#
# Kjør:
#   nc serve examples/api_advanced.no --port 8000

bruk std.httpserver_vm som http_vm
bruk std.asynk_http som async_http
bruk std.openapi som openapi
bruk std.multipart som mp
bruk std.tls_http som tls
bruk std.web som web
bruk std.rest som rest

# ─── Data Models ──────────────────────────────────────────────────────────

la users: liste<ordbok_tekst> = [
    {
        "id": "1",
        "namn": "Jan Steinar",
        "epost": "jan@example.com",
        "rolle": "admin"
    },
    {
        "id": "2",
        "namn": "Alice",
        "epost": "alice@example.com",
        "rolle": "user"
    }
]

# ─── HTTP Handlers ────────────────────────────────────────────────────────

funksjon root(ctx: ordbok_tekst) -> tekst {
    returner "{
        \"api\": \"Norscode Advanced REST API\",
        \"versjon\": \"2.0\",
        \"features\": [
            \"HTTP server (native)\",
            \"REST framework\",
            \"Async handlers (planned)\",
            \"OpenAPI/Swagger\",
            \"File uploads\",
            \"TLS/HTTPS (planned)\",
            \"VM-integration (planned)\"
        ],
        \"dokumentasjon\": \"http://localhost:8000/swagger\"
    }"
}

funksjon helse(ctx: ordbok_tekst) -> tekst {
    returner "{\"status\": \"ok\", \"uptime\": \"100%\"}"
}

funksjon list_users(ctx: ordbok_tekst) -> tekst {
    returner rest.liste_til_json(users)
}

funksjon get_user(ctx: ordbok_tekst) -> tekst {
    la id = web.request_param(ctx, "id")

    la i: heltall = 0
    mens i < lengde(users) {
        la user = users[i]
        hvis user["id"] == id {
            returner rest.til_json(user)
        }
        i = i + 1
    }

    returner "{\"error\": \"User not found\", \"id\": \"" + id + "\"}"
}

funksjon create_user(ctx: ordbok_tekst) -> tekst {
    // Parse request body (simplified)
    la body = web.request_body(ctx)

    la ny_user: ordbok_tekst = {}
    ny_user["id"] = tekst(lengde(users) + 1)
    ny_user["namn"] = "New User"
    ny_user["epost"] = "new@example.com"
    ny_user["rolle"] = "user"

    legg_til(users, ny_user)

    returner "{\"created\": true, \"user\": " + rest.til_json(ny_user) + "}"
}

funksjon upload_file(ctx: ordbok_tekst) -> tekst {
    // Parse multipart form data
    la parts = mp.parse_form_data(ctx)

    hvis lengde(parts) == 0 {
        returner mp.upload_error("No files uploaded")
    }

    la file = parts[0]

    // Validate
    hvis ikkje mp.validate_file_size(file, 10) {  // 10MB limit
        returner mp.upload_error("File too large")
    }

    // Save (would use actual file system)
    returner mp.upload_response("/uploads/" + file["filename"], file["filename"])
}

funksjon api_info(ctx: ordbok_tekst) -> tekst {
    returner "{
        \"api\": \"Norscode REST API v2.0\",
        \"endpoints\": [
            {\"method\": \"GET\", \"path\": \"/\", \"desc\": \"API info\"},
            {\"method\": \"GET\", \"path\": \"/helse\", \"desc\": \"Health check\"},
            {\"method\": \"GET\", \"path\": \"/users\", \"desc\": \"List users\"},
            {\"method\": \"GET\", \"path\": \"/users/{id}\", \"desc\": \"Get user\"},
            {\"method\": \"POST\", \"path\": \"/users\", \"desc\": \"Create user\"},
            {\"method\": \"POST\", \"path\": \"/upload\", \"desc\": \"Upload file\"},
            {\"method\": \"GET\", \"path\": \"/swagger\", \"desc\": \"Swagger UI\"}
        ],
        \"features\": [
            \"REST framework\",
            \"File uploads\",
            \"OpenAPI/Swagger\",
            \"Type safety\",
            \"Request validation\"
        ]
    }"
}

funksjon swagger_ui(ctx: ordbok_tekst) -> tekst {
    // Return Swagger UI HTML
    returner openapi.swagger_ui_html("/openapi.json")
}

funksjon openapi_spec(ctx: ordbok_tekst) -> tekst {
    // Generate OpenAPI spec (placeholder)
    returner "{
        \"openapi\": \"3.0.0\",
        \"info\": {
            \"title\": \"Norscode REST API\",
            \"version\": \"2.0\"
        },
        \"paths\": {
            \"/users\": {
                \"get\": {
                    \"summary\": \"List all users\",
                    \"responses\": {
                        \"200\": {\"description\": \"List of users\"}
                    }
                }
            },
            \"/users/{id}\": {
                \"get\": {
                    \"summary\": \"Get user by ID\",
                    \"parameters\": [{
                        \"name\": \"id\",
                        \"in\": \"path\",
                        \"required\": true,
                        \"schema\": {\"type\": \"integer\"}
                    }],
                    \"responses\": {
                        \"200\": {\"description\": \"User details\"}
                    }
                }
            }
        }
    }"
}

# ─── Async Handlers (Planlagt) ────────────────────────────────────────────

# asynk funksjon async_operation(ctx) -> tekst {
#     la result = await external_api_call()
#     returner result
# }

# ─── Server Setup ──────────────────────────────────────────────────────────

funksjon start() -> heltall {
    la server = http_vm.ny_server_vm(8000)

    // Register routes
    http_vm.route_vm(server, "GET", "/", "root")
    http_vm.route_vm(server, "GET", "/helse", "helse")
    http_vm.route_vm(server, "GET", "/users", "list_users")
    http_vm.route_vm(server, "GET", "/users/{id:int}", "get_user")
    http_vm.route_vm(server, "POST", "/users", "create_user")
    http_vm.route_vm(server, "POST", "/upload", "upload_file")
    http_vm.route_vm(server, "GET", "/api/info", "api_info")
    http_vm.route_vm(server, "GET", "/swagger", "swagger_ui")
    http_vm.route_vm(server, "GET", "/openapi.json", "openapi_spec")

    // Print banner
    skriv("")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("Norscode Advanced REST API — v2.0")
    skriv("═══════════════════════════════════════════════════════════════")
    skriv("")
    skriv("📍 Server URL: http://127.0.0.1:8000")
    skriv("")
    skriv("🔗 API Endpoints:")
    skriv("  GET  /               - API info")
    skriv("  GET  /helse          - Health check")
    skriv("  GET  /api/info       - Endpoints list")
    skriv("  GET  /users          - List users")
    skriv("  GET  /users/{id}     - Get user")
    skriv("  POST /users          - Create user")
    skriv("  POST /upload         - Upload file")
    skriv("")
    skriv("📚 Documentation:")
    skriv("  GET  /swagger        - Swagger UI")
    skriv("  GET  /openapi.json   - OpenAPI spec")
    skriv("")
    skriv("🚀 Features:")
    skriv("  ✅ REST framework")
    skriv("  ✅ Static typing")
    skriv("  ✅ File uploads")
    skriv("  ✅ OpenAPI/Swagger")
    skriv("  ⏳ Async/await (planned)")
    skriv("  ⏳ TLS/HTTPS (planned)")
    skriv("  ⏳ VM-integration (planned)")
    skriv("")
    skriv("────────────────────────────────────────────────────────────────")
    skriv("")

    returner http_vm.lytt_vm(server)
}

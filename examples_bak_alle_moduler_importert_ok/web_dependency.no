bruk std.web som web

funksjon config(ctx: ordbok_tekst) -> ordbok_tekst {
    web.dependency("config")
    returner {"app": "Norscode", "miljo": "dev"}
}

funksjon bruker(ctx: ordbok_tekst, cfg: ordbok_tekst) -> ordbok_tekst {
    web.dependency("bruker")
    returner {"navn": "Ada", "app": cfg.app}
}

funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")
    web.use_dependency("config")
    web.use_dependency("bruker")
    la cfg = config(ctx)
    la user = bruker(ctx, cfg)
    skriv(cfg.app)
    skriv(user.navn)
    returner web.response_builder(200, {"content-type": "text/plain"}, cfg.app + " / " + user.navn)
}

funksjon start() -> heltall {
    la respons = web.handle_request(web.request_context("GET", "/", {}, {}, ""))
    skriv(web.response_body(respons))
    returner 0
}

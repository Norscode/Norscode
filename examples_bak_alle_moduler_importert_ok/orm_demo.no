bruk std.orm som orm
bruk std.db som db

funksjon start() -> heltall {
    la conn = db.open(":memory:")

    # Opprett tabell (tilsvarer Django-modell + migrate)
    orm.migrer(conn, "bruker", [
        "id INTEGER PRIMARY KEY AUTOINCREMENT",
        "namn TEXT NOT NULL",
        "epost TEXT NOT NULL",
        "aktiv TEXT DEFAULT 'sann'"
    ])

    # Lagre (INSERT)
    la id1 = orm.lagre(conn, "bruker", {"namn": "Ola Nordmann", "epost": "ola@example.com"})
    la id2 = orm.lagre(conn, "bruker", {"namn": "Kari Normann", "epost": "kari@example.com"})
    la id3 = orm.lagre(conn, "bruker", {"namn": "Per Olsen", "epost": "per@example.com", "aktiv": "usann"})

    skriv("Brukerar oppretta: " + tekst_fra_heltall(id1) + ", " + tekst_fra_heltall(id2) + ", " + tekst_fra_heltall(id3))

    # finn() — hent éin etter id
    la bruker = orm.finn(conn, "bruker", id1)
    skriv("Funne: " + bruker["namn"] + " (" + bruker["epost"] + ")")

    # alle() — hent alle
    la alle = orm.alle(conn, "bruker")
    skriv("Alle brukerar (" + tekst_fra_heltall(lengde(alle)) + "):")
    la i: heltall = 0
    mens i < lengde(alle) {
        la b = alle[i]
        skriv("  " + b["id"] + ": " + b["namn"])
        i = i + 1
    }

    # filtrer() — spørring med betingelse
    la aktive = orm.filtrer(conn, "bruker", "aktiv = 'sann'")
    skriv("Aktive brukerar: " + tekst_fra_heltall(lengde(aktive)))

    # oppdater()
    orm.oppdater(conn, "bruker", id1, {"epost": "ola.ny@example.com"})
    la oppdatert = orm.finn(conn, "bruker", id1)
    skriv("Oppdatert epost: " + oppdatert["epost"])

    # tell()
    skriv("Totalt: " + tekst_fra_heltall(orm.tell(conn, "bruker")))
    skriv("Aktive: " + tekst_fra_heltall(orm.tell_hvor(conn, "bruker", "aktiv = 'sann'")))

    # slett()
    orm.slett(conn, "bruker", id3)
    skriv("Etter sletting: " + tekst_fra_heltall(orm.tell(conn, "bruker")))

    db.close(conn)
    returner 0
}
